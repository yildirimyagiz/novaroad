// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  GENERICS E2E INTEGRATION TESTS                                              ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use std::io::println;

// ══════════════════════════════════════════════════════════════════════════════
// TEST 1: Generic Function - Identity
// ══════════════════════════════════════════════════════════════════════════════

fn identity<T>(x: T) -> T {
    yield x;
}

fn test_identity() {
    println("TEST: Generic identity function");
    
    let a = identity(42);
    assert(a == 42, "identity(42) == 42");
    
    let b = identity(3.14);
    assert(b == 3.14, "identity(3.14) == 3.14");
    
    let c = identity("hello");
    assert(c == "hello", "identity('hello') == 'hello'");
    
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 2: Generic Function - Max
// ══════════════════════════════════════════════════════════════════════════════

fn max<T>(a: T, b: T) -> T {
    check a > b { yield a; } else { yield b; }
}

fn test_max() {
    println("TEST: Generic max function");
    
    let m1 = max(10, 20);
    assert(m1 == 20, "max(10, 20) == 20");
    
    let m2 = max(3.14, 2.71);
    assert(m2 == 3.14, "max(3.14, 2.71) == 3.14");
    
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 3: Generic Struct - Box<T>
// ══════════════════════════════════════════════════════════════════════════════

data Box<T> {
    value: T,
}

fn test_generic_struct() {
    println("TEST: Generic data Box<T>");
    
    let b1 = Box { value: 42 };
    assert(b1.value == 42, "Box<i64> works");
    
    let b2 = Box { value: "hello" };
    assert(b2.value == "hello", "Box<String> works");
    
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 4: Option<T>
// ══════════════════════════════════════════════════════════════════════════════

cases Option<T> {
    Some(T),
    None,
}

fn unwrap_or<T>(opt: Option<T>, default: T) -> T {
    match opt {
        Some(x) => x,
        None => default,
    }
}

fn test_option() {
    println("TEST: Option<T> with generics");
    
    let some_val: Option<i64> = Option::Some(42);
    let none_val: Option<i64> = Option::None;
    
    let r1 = unwrap_or(some_val, 0);
    assert(r1 == 42, "unwrap_or(Some(42), 0) == 42");
    
    let r2 = unwrap_or(none_val, 99);
    assert(r2 == 99, "unwrap_or(None, 99) == 99");
    
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 5: Result<T, E>
// ══════════════════════════════════════════════════════════════════════════════

cases Result<T, E> {
    Ok(T),
    Err(E),
}

fn divide(a: i64, b: i64) -> Result<i64, String> {
    check b == 0 {
        yield Result::Err("Division by zero".into());
    }
    yield Result::Ok(a / b);
}

fn test_result() {
    println("TEST: Result<T, E> with generics");
    
    let success = divide(10, 2);
    match success {
        Ok(v) => assert(v == 5, "10 / 2 == 5"),
        Err(_) => assert(false, "Should not error"),
    }
    
    let failure = divide(10, 0);
    match failure {
        Ok(_) => assert(false, "Should error"),
        Err(msg) => assert(msg == "Division by zero", "Error message correct"),
    }
    
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 6: Multiple Type Parameters
// ══════════════════════════════════════════════════════════════════════════════

fn map<T, U>(opt: Option<T>, f: fn(T) -> U) -> Option<U> {
    match opt {
        Some(x) => Some(f(x)),
        None => None,
    }
}

fn test_multiple_type_params() {
    println("TEST: Multiple type parameters");
    
    let some_num: Option<i64> = Option::Some(42);
    let doubled = map(some_num, |x| x * 2);
    
    match doubled {
        Some(v) => assert(v == 84, "map(Some(42), *2) == Some(84)"),
        None => assert(false, "Should be Some"),
    }
    
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 7: Generic + Error Propagation
// ══════════════════════════════════════════════════════════════════════════════

fn safe_divide(a: i64, b: i64) -> Result<i64, String> {
    let result = divide(a, b)?;  // Error propagation with generics!
    Ok(result);
}

fn test_generic_error_propagation() {
    println("TEST: Generics + error propagation");
    
    match safe_divide(20, 4) {
        Ok(v) => assert(v == 5, "20 / 4 == 5"),
        Err(_) => assert(false, "Should succeed"),
    }
    
    match safe_divide(20, 0) {
        Ok(_) => assert(false, "Should fail"),
        Err(_) => assert(true, "Error propagated"),
    }
    
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// MAIN - Run All Tests
// ══════════════════════════════════════════════════════════════════════════════

fn main() {
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  GENERICS E2E INTEGRATION TESTS                              ║");
    println("╚══════════════════════════════════════════════════════════════╝");
    println("");
    
    test_identity();
    test_max();
    test_generic_struct();
    test_option();
    test_result();
    test_multiple_type_params();
    test_generic_error_propagation();
    
    println("");
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  ✓ ALL GENERICS TESTS PASSED!                                ║");
    println("╚══════════════════════════════════════════════════════════════╝");
    println("");
    println("🎉 Result<T, E> FULLY WORKS!");
    println("🎉 Option<T> FULLY WORKS!");
    println("🎉 Generic functions FULLY WORK!");
}
