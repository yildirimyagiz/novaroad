// Integration Tests - Full Stack

#[test]
fn test_web_server() {
    let server = create_test_server();
    
    // Test home route
    let response = server.get("/");
    assert_eq!(response.status, 200);
    assert!(response.body.contains("Welcome"));
    
    // Test API route
    let api_response = server.get("/api");
    assert_eq!(api_response.status, 200);
    assert_eq!(api_response.content_type, "application/json");
}

#[test]
fn test_database_connection() {
    let db = Database::connect("sqlite::memory:");
    
    db.execute("CREATE TABLE users (id INTEGER, name TEXT)");
    db.execute("INSERT INTO users VALUES (1, 'Alice')");
    
    let result = db.query("SELECT * FROM users");
    assert_eq!(result.len(), 1);
    assert_eq!(result[0].name, "Alice");
}

#[test]
fn test_async_runtime() {
    let result = block_on(async {
        let x = async_fetch("http://example.com").await;
        yield x.len();
    });
    
    assert!(result > 0);
}

#[test]
fn test_ffi_c_interop() {
    extern "C" {
        fn strlen(s: *const u8) -> usize;
    }
    
    let s = "Hello";
    let len = unsafe { strlen(s.as_ptr()) };
    
    assert_eq!(len, 5);
}

#[test]
fn test_neural_network() {
    let model = Network::new();
    model.add(Layer::dense(2, 1));
    
    let input = tensor([[1.0, 2.0]]);
    let output = model.forward(input);
    
    assert_eq!(output.data(), [1, 1]);
}

fn main() {
    println("Running integration tests...");
    
    test_web_server();
    test_database_connection();
    test_async_runtime();
    test_ffi_c_interop();
    test_neural_network();
    
    println("✅ All tests passed!");
}
