// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  PATTERN MATCHING E2E TESTS                                                  ║
// ║  End-to-end integration tests for match expressions                          ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use std::io::println;

// ══════════════════════════════════════════════════════════════════════════════
// TEST 1: Basic Integer Matching
// ══════════════════════════════════════════════════════════════════════════════

fn test_basic_int_match() {
    println("TEST: Basic integer matching");
    
    let x = 2;
    let result = match x {
        0 => "zero",
        1 => "one",
        2 => "two",
        _ => "other",
    };
    
    assert(result == "two", "Should match 2");
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 2: Tuple Pattern Matching
// ══════════════════════════════════════════════════════════════════════════════

fn test_tuple_patterns() {
    println("TEST: Tuple pattern matching");
    
    let point = (3, 4);
    
    let quadrant = match point {
        (0, 0) => "origin",
        (x, 0) => "x-axis",
        (0, y) => "y-axis",
        (x, y) check x > 0 && y > 0 => "quadrant I",
        (x, y) check x < 0 && y > 0 => "quadrant II",
        (x, y) check x < 0 && y < 0 => "quadrant III",
        (x, y) check x > 0 && y < 0 => "quadrant IV",
    };
    
    assert(quadrant == "quadrant I", "Point (3,4) in quadrant I");
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 3: Option<T> Matching
// ══════════════════════════════════════════════════════════════════════════════

cases Option<T> {
    Some(T),
    None,
}

fn test_option_matching() {
    println("TEST: Option<T> pattern matching");
    
    let some_val: Option<i64> = Option::Some(42);
    let none_val: Option<i64> = Option::None;
    
    let result1 = match some_val {
        Some(x) => x * 2,
        None => 0,
    };
    
    let result2 = match none_val {
        Some(x) => x * 2,
        None => -1,
    };
    
    assert(result1 == 84, "Some(42) * 2 = 84");
    assert(result2 == -1, "None = -1");
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 4: Result<T, E> Matching
// ══════════════════════════════════════════════════════════════════════════════

cases Result<T, E> {
    Ok(T),
    Err(E),
}

fn divide(a: i64, b: i64) -> Result<i64, String> {
    check b == 0 {
        yield Result::Err("Division by zero".into());
    }
    yield Result::Ok(a / b);
}

fn test_result_matching() {
    println("TEST: Result<T, E> pattern matching");
    
    let success = divide(10, 2);
    let failure = divide(10, 0);
    
    let val1 = match success {
        Ok(x) => x,
        Err(_) => -1,
    };
    
    let val2 = match failure {
        Ok(x) => x,
        Err(msg) => -1,
    };
    
    assert(val1 == 5, "10 / 2 = 5");
    assert(val2 == -1, "Division by zero returns -1");
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 5: Or-Patterns
// ══════════════════════════════════════════════════════════════════════════════

fn test_or_patterns() {
    println("TEST: Or-pattern matching");
    
    let digit = 5;
    
    let parity = match digit {
        1 | 3 | 5 | 7 | 9 => "odd",
        0 | 2 | 4 | 6 | 8 => "even",
        _ => "unknown",
    };
    
    assert(parity == "odd", "5 is odd");
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 6: Nested Pattern Matching
// ══════════════════════════════════════════════════════════════════════════════

fn test_nested_patterns() {
    println("TEST: Nested pattern matching");
    
    let nested: Option<Result<i64, String>> = Option::Some(Result::Ok(42));
    
    let value = match nested {
        Some(Ok(x)) => x,
        Some(Err(_)) => -1,
        None => 0,
    };
    
    assert(value == 42, "Nested Some(Ok(42)) = 42");
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 7: Guard Expressions
// ══════════════════════════════════════════════════════════════════════════════

fn test_guards() {
    println("TEST: Guard expressions");
    
    let num = 15;
    
    let category = match num {
        x check x < 0 => "negative",
        x check x == 0 => "zero",
        x check x < 10 => "small",
        x check x < 100 => "medium",
        _ => "large",
    };
    
    assert(category == "medium", "15 is medium");
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 8: Complex Enum Matching
// ══════════════════════════════════════════════════════════════════════════════

cases Message {
    Quit,
    Move { x: i64, y: i64 },
    Write(String),
    ChangeColor(i64, i64, i64),
}

fn test_complex_enum() {
    println("TEST: Complex cases matching");
    
    let msg1 = Message::Quit;
    let msg2 = Message::Move { x: 10, y: 20 };
    let msg3 = Message::Write("hello".into());
    
    let result1 = match msg1 {
        Quit => 0,
        _ => 1,
    };
    
    let result2 = match msg2 {
        Move { x, y } => x + y,
        _ => 0,
    };
    
    let result3 = match msg3 {
        Write(s) => s.len(),
        _ => 0,
    };
    
    assert(result1 == 0, "Quit = 0");
    assert(result2 == 30, "Move(10, 20) = 30");
    assert(result3 == 5, "Write('hello') length = 5");
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 9: Wildcard in Tuple
// ══════════════════════════════════════════════════════════════════════════════

fn test_wildcard_in_tuple() {
    println("TEST: Wildcard in tuple patterns");
    
    let triple = (1, 2, 3);
    
    let result = match triple {
        (1, _, _) => "starts with 1",
        (_, 2, _) => "middle is 2",
        (_, _, 3) => "ends with 3",
        _ => "other",
    };
    
    assert(result == "starts with 1", "First pattern matches");
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 10: Match as Expression
// ══════════════════════════════════════════════════════════════════════════════

fn test_match_expression() {
    println("TEST: Match as expression");
    
    let fibonacci = fn(n: i64) -> i64 {
        match n {
            0 => 0,
            1 => 1,
            n => fibonacci(n - 1) + fibonacci(n - 2),
        }
    };
    
    let fib5 = fibonacci(5);
    assert(fib5 == 5, "fib(5) = 5");
    
    let fib10 = fibonacci(10);
    assert(fib10 == 55, "fib(10) = 55");
    
    println("✓ PASS");
}

// ══════════════════════════════════════════════════════════════════════════════
// MAIN - Run All Tests
// ══════════════════════════════════════════════════════════════════════════════

fn main() {
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  PATTERN MATCHING E2E TESTS                                  ║");
    println("╚══════════════════════════════════════════════════════════════╝");
    println("");
    
    test_basic_int_match();
    test_tuple_patterns();
    test_option_matching();
    test_result_matching();
    test_or_patterns();
    test_nested_patterns();
    test_guards();
    test_complex_enum();
    test_wildcard_in_tuple();
    test_match_expression();
    
    println("");
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  ✓ ALL TESTS PASSED!                                         ║");
    println("╚══════════════════════════════════════════════════════════════╝");
}
