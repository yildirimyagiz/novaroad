fn heavy_compute(n: i64) -> f64 {
    let var sum = 0.0;
    let var i = 0;
    while i < n {
        let var j = 0;
        while j < n {
            sum = sum + 1.0;
            j = j + 1;
        }
        i = i + 1;
    }
    yield sum;
}

fn main() {
    let result = heavy_compute(1000);
    print("Result: ");
    // print(result); // Assume print supports f64 or use print_float
    print_float(result);
}
