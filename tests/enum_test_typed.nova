enum Color {
    Red,
    Green,
    Blue,
    Custom(i32, i32, i32)
}

fn print_color(c: Color) {
    match c {
        Red => println("It is Red"),
        Green => println("It is Green"),
        Blue => println("It is Blue"),
        Custom => println("It is a Custom color"),
    }
}

fn main() {
    let r = Color::Red;
    let g = Color::Green;
    let b = Color::Blue;
    let c = Color::Custom(10, 20, 30);

    print_color(r);
    print_color(g);
    print_color(b);
    print_color(c);
}
