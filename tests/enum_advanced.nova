enum Shape {
    Circle(i32),
    Rectangle(i32, i32),
    Point
}

fn describe(s) {
    match s {
        Circle => println("Circle"),
        Rectangle => println("Rectangle"),
        Point => println("Point"),
        _ => println("Unknown"),
    }
}

fn main() {
    let c = Shape::Circle(5);
    let r = Shape::Rectangle(10, 20);
    let p = Shape::Point;

    describe(c);
    describe(r);
    describe(p);
}
