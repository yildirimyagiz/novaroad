bring io;

fn main() {
    io::println("╔══════════════════════════════════════════════════════════╗");
    io::println("║  Nova Full I/O Verification                              ║");
    io::println("╚══════════════════════════════════════════════════════════╝");
    
    // 1. System call test
    io::println("\n[1/3] Testing io::system...");
    let status = io::system("echo 'Nova System Test' > build/system_test.txt");
    check status == 0 {
        io::println("✅ io::system call successful");
    } else {
        io::println("❌ io::system call failed");
    }
    
    // 2. File creation and writing
    io::println("\n[2/3] Testing File::create and File::write...");
    let file_res = io::File::create("build/test_io.txt");
    
    // Manual match since we don't have good string concat yet
    match file_res {
        Ok(f) => {
            io::println("✅ File::create successful");
            let write_res = f.write("Hello from Nova!");
            match write_res {
                Ok(bytes) => {
                    io::print("✅ File::write successful, wrote ");
                    io::print_int(bytes);
                    io::println(" bytes");
                },
                Err(e) => {
                    io::print("❌ File::write failed: ");
                    io::println(e);
                }
            }
            // Use a mutable reference or ensure 'f' is mutable check needed
            // The io.zn implementation takes &var self for close
            // But match might consume 'f'. 
            // In Nova, 'f' is the value.
            // Let's just hope it works for now.
        },
        Err(e) => {
            io::print("❌ File::create failed: ");
            io::println(e);
        }
    }
    
    // 3. File opening and reading
    io::println("\n[3/3] Testing File::open and File::read_to_string...");
    let open_res = io::File::open("build/test_io.txt");
    match open_res {
        Ok(f) => {
            io::println("✅ File::open successful");
            let read_res = f.read_to_string();
            match read_res {
                Ok(content) => {
                    io::println("✅ File::read_to_string successful");
                    io::print("Content: '");
                    io::print(content);
                    io::println("'");
                },
                Err(e) => {
                    io::print("❌ File::read_to_string failed: ");
                    io::println(e);
                }
            }
        },
        Err(e) => {
            io::print("❌ File::open failed: ");
            io::println(e);
        }
    }
    
    io::println("\n✨ Full I/O verification complete.");
}
