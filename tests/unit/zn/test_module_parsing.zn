// Module Parser Test
// Test basic module declarations and imports

mod lexer;
mod parser;
mod semantic;

import lexer::{Token, tokenize};
import parser::*;
import semantic as sem;

expose data ASTNode {
    kind: i32,
    location: i32,
}

expose fn compile(source: *String) -> *ASTNode {
    var tokens: i32 = 42;
    var ast: ASTNode = ASTNode { kind: 1, location: 0 };
    var ptr: *ASTNode = heap new ASTNode(ast);
    yield ptr;
}

fn main() {
    var source: *String = String_from_literal("test code");
    var ast: *ASTNode = compile(source);
    yield (*ast).kind;
}
