// Nova ML Tensor Test Suite
// Tests ml_tensor module import and operations

import ml_tensor::{zeros, ones, Tensor, tensor_numel, tensor_add,
                   tensor_mul, tensor_sub, tensor_ndim,
                   tensor_zeros_like, tensor_ones_like,
                   tensor_matmul, relu, sigmoid, softmax, tanh_act,
                   tensor_reshape, tensor_sum, linear_forward};

fn test_tensor_creation() {
    println("TEST: Tensor oluşturma...");
    
    let z = zeros(10);
    assert(tensor_numel(z) == 10, "zeros(10) → numel=10");
    println("  ✓ zeros(10) OK");
    
    let o = ones(5);
    assert(tensor_numel(o) == 5, "ones(5) → numel=5");
    println("  ✓ ones(5) OK");
    
    println("✓ Tensor oluşturma testleri geçti");
}

fn test_tensor_ops() {
    println("TEST: Temel tensor operasyonları...");
    
    let c = tensor_add(zeros(4), ones(4));
    assert(tensor_numel(c) == 4, "tensor_add boyut koruyor");
    println("  ✓ tensor_add OK");
    
    let d = tensor_sub(ones(4), zeros(4));
    assert(tensor_numel(d) == 4, "tensor_sub boyut koruyor");
    println("  ✓ tensor_sub OK");
    
    let e = tensor_mul(zeros(4), ones(4));
    assert(tensor_numel(e) == 4, "tensor_mul boyut koruyor");
    println("  ✓ tensor_mul OK");
    
    println("✓ Temel operasyon testleri geçti");
}

fn test_tensor_activations() {
    println("TEST: Aktivasyon fonksiyonları...");
    
    let r = relu(ones(8));
    assert(tensor_numel(r) == 8, "relu boyut koruyor");
    println("  ✓ relu OK");
    
    let s = sigmoid(ones(8));
    assert(tensor_numel(s) == 8, "sigmoid boyut koruyor");
    println("  ✓ sigmoid OK");
    
    let sm = softmax(ones(8));
    assert(tensor_numel(sm) == 8, "softmax boyut koruyor");
    println("  ✓ softmax OK");
    
    let th = tanh_act(ones(8));
    assert(tensor_numel(th) == 8, "tanh boyut koruyor");
    println("  ✓ tanh_act OK");
    
    println("✓ Aktivasyon testleri geçti");
}

fn test_tensor_matmul() {
    println("TEST: Matmul...");
    
    let a = zeros(16);
    let b = ones(16);
    let c = tensor_matmul(a, b);
    assert(tensor_numel(c) == 16, "matmul sonuç tensörü");
    println("  ✓ tensor_matmul OK");
    
    println("✓ Matmul testleri geçti");
}

fn test_tensor_like() {
    println("TEST: zeros_like / ones_like...");
    
    let z = tensor_zeros_like(zeros(12));
    assert(tensor_numel(z) == 12, "zeros_like boyut eşleşiyor");
    println("  ✓ tensor_zeros_like OK");
    
    let o = tensor_ones_like(zeros(12));
    assert(tensor_numel(o) == 12, "ones_like boyut eşleşiyor");
    println("  ✓ tensor_ones_like OK");
    
    println("✓ Like operasyon testleri geçti");
}

fn test_linear_layer() {
    println("TEST: Linear layer forward pass...");
    
    let input  = zeros(784);
    let weight = ones(256);
    let bias   = zeros(256);
    let output = linear_forward(input, weight, bias);
    assert(tensor_ndim(output) == 2, "linear output 2D");
    println("  ✓ linear_forward OK");
    
    println("✓ Linear layer testleri geçti");
}

fn main() {
    println("══════════════════════════════════════");
    println("Nova ML Tensor Test Suite v2");
    println("══════════════════════════════════════");
    
    test_tensor_creation();
    test_tensor_ops();
    test_tensor_activations();
    test_tensor_matmul();
    test_tensor_like();
    test_linear_layer();
    
    println("");
    println("✅ Tüm ML tensor testleri geçti!");
}
