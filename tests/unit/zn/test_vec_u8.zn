// Vec_u8 Implementation
// Dynamic array for bytes (buffer management)

data Vec_u8 {
    data: *u8,
    len: usize,
    capacity: usize,
}

// Create new empty Vec_u8
fn Vec_u8_new() -> *Vec_u8 {
    var initial_capacity: usize = 8;
    var data: *u8 = heap new u8(initial_capacity);

    var vec: Vec_u8 = Vec_u8 {
        data: data,
        len: 0,
        capacity: initial_capacity
    };

    var ptr: *Vec_u8 = heap new Vec_u8(vec);
    yield ptr;
}

// Push byte to Vec_u8
fn Vec_u8_push(vec: *Vec_u8, value: u8) {
    // TODO: Check check we need to resize
    // For now, assume capacity is enough

    // (*vec).data[(*vec).len] = value;
    (*vec).len = (*vec).len + 1;
}

// Get length
fn Vec_u8_len(vec: *Vec_u8) -> usize {
    yield (*vec).len;
}

// Get element at index
fn Vec_u8_get(vec: *Vec_u8, index: usize) -> u8 {
    // TODO: Bounds checking
    // For now, assume valid index
    // yield (*vec).data[index];
    yield 0; // Placeholder
}

// Test Vec_u8 operations
fn test_vec_u8() {
    var vec: *Vec_u8 = Vec_u8_new();

    Vec_u8_push(vec, 72);  // 'H'
    Vec_u8_push(vec, 101); // 'e'
    Vec_u8_push(vec, 108); // 'l'
    Vec_u8_push(vec, 108); // 'l'
    Vec_u8_push(vec, 111); // 'o'

    var len: usize = Vec_u8_len(vec); // Should be 5

    // Free vec when done
    heap free (*vec).data;
    heap free vec;

    yield len;
}

fn main() {
    var result: usize = test_vec_u8();
    yield result;
}
