// Test: Check (check) conditional statements
// Mevcut compiler desteği: check keyword

fn test_check_basic() -> i64 {
    var result = 0;
    var x = 10;
    
    check x > 5 {
        result = 1;
    }
    
    yield result;
}

fn test_check_with_else() -> i64 {
    var result = 0;
    var x = 3;
    
    check x > 5 {
        result = 1;
    } else {
        result = -1;
    }
    
    yield result;
}

fn test_nested_check() -> i64 {
    var x = 10;
    var y = 20;
    var result = 0;
    
    check x > 5 {
        check y > 15 {
            result = 100;
        }
    }
    
    yield result;
}

fn main() -> i64 {
    var t1 = test_check_basic();
    var t2 = test_check_with_else();
    var t3 = test_nested_check();
    
    // t1 should be 1, t2 should be -1, t3 should be 100
    var sum = t1 + t2 + t3;
    yield sum;  // Should be 100
}
