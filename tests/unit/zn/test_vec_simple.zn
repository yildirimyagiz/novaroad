// Simple Vec_u8 Test
// Test basic Vec_u8 parsing

data Vec_u8 {
    data: *u8,
    len: usize,
    capacity: usize,
}

fn test_simple_vec() {
    var vec: Vec_u8 = Vec_u8 {
        data: heap new u8(8),
        len: 0,
        capacity: 8
    };

    yield vec.len;
}

fn main() {
    var result: usize = test_simple_vec();
    yield result;
}
