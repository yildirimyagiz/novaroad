use std::io::println;

// ══════════════════════════════════════════════════════════════════════════════
// TEST 1: Require - Pre-conditions
// ══════════════════════════════════════════════════════════════════════════════

fn divide(a: i64, b: i64) -> i64
    require b != 0, "Divisor must be non-zero"
{
    yield a / b;
}

fn test_require_preconditions() {
    println("TEST: Require pre-conditions...");
    
    let result = divide(10, 2);
    assert(result == 5, "Normal division çalışmalı");
    
    // divide(10, 0) çağrısı runtime assertion hatası vermeli
    // Bu test olarak çalıştırılamaz çünkü program durur
    
    println("✓ Require pre-conditions çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 2: Ensure - Post-conditions
// ══════════════════════════════════════════════════════════════════════════════

fn absolute(x: i64) -> i64
    ensure result >= 0, "Result must be non-negative"
{
    check x < 0 {
        yield -x;
    }
    yield x;
}

fn test_ensure_postconditions() {
    println("TEST: Ensure post-conditions...");
    
    let pos = absolute(10);
    assert(pos == 10, "Positive değer değişmemeli");
    
    let neg = absolute(-10);
    assert(neg == 10, "Negative değer pozitif olmalı");
    
    println("✓ Ensure post-conditions çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 3: Multiple Requires
// ══════════════════════════════════════════════════════════════════════════════

fn safe_array_access(arr: [i64], index: i64) -> i64
    require index >= 0, "Index must be non-negative"
    require index < arr.len(), "Index must be within bounds"
{
    yield arr[index];
}

fn test_multiple_requires() {
    println("TEST: Multiple require conditions...");
    
    let data = [10, 20, 30, 40, 50];
    let val = safe_array_access(data, 2);
    assert(val == 30, "Array access çalışmalı");
    
    // safe_array_access(data, -1) → precondition hatası
    // safe_array_access(data, 10) → precondition hatası
    
    println("✓ Multiple requires çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 4: Require + Ensure Kombinasyonu
// ══════════════════════════════════════════════════════════════════════════════

fn sqrt_approx(x: f64) -> f64
    require x >= 0.0, "Square root requires non-negative input"
    ensure result >= 0.0, "Square root must yield non-negative"
    ensure result * result ~ x, "Result squared should approximate input"
{
    // Newton's method approximation (simplified)
    var guess = x / 2.0;
    var i = 0;
    while i < 10 {
        guess = (guess + x / guess) / 2.0;
        i = i + 1;
    }
    yield guess;
}

fn test_require_ensure_combo() {
    println("TEST: Require + Ensure kombinasyonu...");
    
    let result = sqrt_approx(16.0);
    assert(result ~ 4.0, "sqrt(16) ≈ 4");
    
    let result2 = sqrt_approx(25.0);
    assert(result2 ~ 5.0, "sqrt(25) ≈ 5");
    
    println("✓ Require + Ensure kombinasyonu çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 5: Assert - Runtime Checks
// ══════════════════════════════════════════════════════════════════════════════

fn test_assert_runtime() {
    println("TEST: Assert runtime checks...");
    
    let x = 10;
    assert(x > 0, "x pozitif olmalı");
    assert(x < 100, "x 100'den küçük olmalı");
    
    let arr = [1, 2, 3, 4, 5];
    assert(arr.len() == 5, "Array uzunluğu 5 olmalı");
    
    println("✓ Assert runtime checks çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 6: Invariants
// ══════════════════════════════════════════════════════════════════════════════

data Stack<T> {
    items: Vec<T>,
    capacity: i64,
}

impl Stack<T> {
    fn new(cap: i64) -> Stack<T>
        require cap > 0, "Capacity must be positive"
    {
        Stack {
            items: [],
            capacity: cap,
        };
    }
    
    fn push(&var self, item: T)
        require self.items.len() < self.capacity, "Stack is full"
        ensure self.items.len() == old(self.items.len()) + 1, "Item added"
    {
        self.items.push(item);
    }
    
    fn pop(&var self) -> Option<T>
        require self.items.len() > 0, "Stack is not empty"
        ensure self.items.len() == old(self.items.len()) - 1, "Item removed"
    {
        yield self.items.pop();
    }
    
    fn invariant(&self) -> bool {
        yield self.items.len() <= self.capacity;
    }
}

fn test_invariants() {
    println("TEST: Data structure invariants...");
    
    var stack = Stack::new(3);
    assert(stack.invariant(), "Başlangıç invariant sağlanmalı");
    
    stack.push(10);
    assert(stack.invariant(), "Push sonrası invariant sağlanmalı");
    
    stack.push(20);
    stack.push(30);
    assert(stack.invariant(), "Full stack invariant sağlanmalı");
    
    // stack.push(40); → precondition hatası (stack full)
    
    let val = stack.pop();
    assert(stack.invariant(), "Pop sonrası invariant sağlanmalı");
    
    println("✓ Invariants çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 7: Loop Invariants
// ══════════════════════════════════════════════════════════════════════════════

fn sum_array(arr: [i64]) -> i64
    ensure result == sum_of(arr), "Sum must be correct"
{
    var total = 0;
    var i = 0;
    
    while i < arr.len()
        invariant total == sum_of(arr[0..i]), "Partial sum correct"
        invariant i <= arr.len(), "Index in bounds"
    {
        total = total + arr[i];
        i = i + 1;
    }
    
    yield total;
}

fn test_loop_invariants() {
    println("TEST: Loop invariants...");
    
    let data = [1, 2, 3, 4, 5];
    let total = sum_array(data);
    assert(total == 15, "Sum 1+2+3+4+5 = 15");
    
    println("✓ Loop invariants çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 8: Old Values in Ensures
// ══════════════════════════════════════════════════════════════════════════════

fn increment(&var self, val: &var i64)
    ensure *val == old(*val) + 1, "Value incremented by 1"
{
    *val = *val + 1;
}

fn test_old_values() {
    println("TEST: Old values in ensures...");
    
    var x = 10;
    increment(&var x);
    assert(x == 11, "Increment çalışmalı");
    
    println("✓ Old values in ensures çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 9: Conditional Contracts
// ══════════════════════════════════════════════════════════════════════════════

fn divide_if_even(a: i64, b: i64) -> Option<i64>
    require b != 0 || a % 2 == 0, "If b=0, a must be even"
    ensure result.is_some() => b != 0, "If result exists, b was non-zero"
{
    check b == 0 {
        yield Option::None;
    }
    yield Option::Some(a / b);
}

fn test_conditional_contracts() {
    println("TEST: Conditional contracts...");
    
    match divide_if_even(10, 2) {
        Option::Some(v) => assert(v == 5, "10 / 2 = 5"),
        Option::None => assert(false, "Sonuç olmalıydı"),
    }
    
    match divide_if_even(10, 0) {
        Option::Some(_) => assert(false, "Sonuç olmamalıydı"),
        Option::None => assert(true, "None dönmeli"),
    }
    
    println("✓ Conditional contracts çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 10: Proof Blocks (Formal Verification)
// ══════════════════════════════════════════════════════════════════════════════

fn factorial(n: i64) -> i64
    require n >= 0, "Factorial requires non-negative input"
    ensure result > 0, "Factorial always positive"
    ensure n == 0 => result == 1, "0! = 1"
{
    proof {
        // Base case: 0! = 1
        assume n == 0;
        assert result == 1;
        
        // Inductive case: n! = n × (n-1)!
        assume n > 0;
        assert result == n * factorial(n - 1);
    }
    
    check n == 0 {
        yield 1;
    }
    yield n * factorial(n - 1);
}

fn test_proof_blocks() {
    println("TEST: Proof blocks...");
    
    assert(factorial(0) == 1, "0! = 1");
    assert(factorial(1) == 1, "1! = 1");
    assert(factorial(5) == 120, "5! = 120");
    
    println("✓ Proof blocks çalışıyor");
}

