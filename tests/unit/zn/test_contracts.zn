fn main() {
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  NOVA CONTRACTS TEST SUITE                                   ║");
    println("╚══════════════════════════════════════════════════════════════╝");
    println("");
    
    test_require_preconditions();
    test_ensure_postconditions();
    test_multiple_requires();
    test_require_ensure_combo();
    test_assert_runtime();
    test_invariants();
    test_loop_invariants();
    test_old_values();
    test_conditional_contracts();
    test_proof_blocks();
    
    println("");
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  ✓ TÜM CONTRACT TESTLERİ BAŞARILI                            ║");
    println("╚══════════════════════════════════════════════════════════════╝");
}
