// Simple HashMap Test
// Test basic HashMap parsing

data HashMapEntry {
    key: *String,
    value: i32,  // Simplified to i32
    next: *HashMapEntry,
}

data HashMap {
    buckets: *HashMapEntry,
    capacity: usize,
    size: usize,
}

fn test_simple_hashmap() {
    var map: HashMap = HashMap {
        buckets: heap new HashMapEntry(16),
        capacity: 16,
        size: 0
    };

    yield map.size;
}

fn main() {
    var result: usize = test_simple_hashmap();
    yield result;
}
