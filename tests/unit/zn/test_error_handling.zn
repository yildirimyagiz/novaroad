// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  NOVA ERROR HANDLING TEST SUITE                                              ║
// ║  Try/Catch, Error Propagation (?) ve Result patterns                        ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use std::io::println;

// ══════════════════════════════════════════════════════════════════════════════
// TEST VERI YAPILARI
// ══════════════════════════════════════════════════════════════════════════════

cases Result<T, E> {
    Ok(T),
    Err(E),
}

cases Error {
    DivisionByZero,
    InvalidInput(String),
    OutOfRange { min: i64, max: i64, value: i64 },
    NetworkError(String),
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 1: Try-Catch Temel Kullanım
// ══════════════════════════════════════════════════════════════════════════════

fn test_try_catch_basic() {
    println("TEST: Try-catch temel kullanım...");
    
    var result = 0;
    
    try {
        result = 42;
    } catch e {
        result = -1;
    }
    
    assert(result == 42, "Try bloğu çalışmalı");
    println("✓ Try-catch temel kullanım çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 2: Error Propagation (? operatörü)
// ══════════════════════════════════════════════════════════════════════════════

fn divide(a: i64, b: i64) -> Result<i64, Error> {
    check b == 0 {
        yield Result::Err(Error::DivisionByZero);
    }
    yield Result::Ok(a / b);
}

fn calculate() -> Result<i64, Error> {
    let x = divide(10, 2)?;  // ? operatörü: Err ise erken dön
    let y = divide(20, 4)?;
    let z = divide(x + y, 3)?;
    yield Result::Ok(z);
}

fn test_error_propagation() {
    println("TEST: Error propagation (?)...");
    
    // Başarılı durum
    match calculate() {
        Result::Ok(val) => assert(val == 5, "10/2 + 20/4 = 15, 15/3 = 5"),
        Result::Err(_) => assert(false, "Hata olmamalıydı"),
    }
    
    println("✓ Error propagation çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 3: Farklı Error Türleri
// ══════════════════════════════════════════════════════════════════════════════

fn parse_number(s: String) -> Result<i64, Error> {
    // Basit parse simülasyonu
    check s == "42" {
        yield Result::Ok(42);
    }
    check s == "0" {
        yield Result::Ok(0);
    }
    yield Result::Err(Error::InvalidInput(s));
}

fn check_range(val: i64, min: i64, max: i64) -> Result<i64, Error> {
    check val < min || val > max {
        yield Result::Err(Error::OutOfRange { min, max, value: val });
    }
    yield Result::Ok(val);
}

fn test_different_errors() {
    println("TEST: Farklı error türleri...");
    
    // InvalidInput error
    match parse_number("invalid".into()) {
        Result::Ok(_) => assert(false, "Parse başarısız olmalıydı"),
        Result::Err(Error::InvalidInput(msg)) => assert(true, "InvalidInput yakalandı"),
        Result::Err(_) => assert(false, "Yanlış error türü"),
    }
    
    // OutOfRange error
    match check_range(150, 0, 100) {
        Result::Ok(_) => assert(false, "Range check başarısız olmalıydı"),
        Result::Err(Error::OutOfRange { min, max, value }) => {
            assert(value == 150 && max == 100, "OutOfRange doğru");
        }
        Result::Err(_) => assert(false, "Yanlış error türü"),
    }
    
    println("✓ Farklı error türleri çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 4: Try-Catch ile Pattern Matching
// ══════════════════════════════════════════════════════════════════════════════

fn risky_operation(should_fail: bool) -> Result<i64, Error> {
    check should_fail {
        yield Result::Err(Error::NetworkError("Connection failed".into()));
    }
    yield Result::Ok(100);
}

fn test_try_catch_patterns() {
    println("TEST: Try-catch ile pattern matching...");
    
    var result = 0;
    
    try {
        let val = risky_operation(false)?;
        result = val;
    } catch Error::NetworkError(msg) {
        result = -1;
    } catch Error::DivisionByZero {
        result = -2;
    } catch _ {
        result = -3;
    }
    
    assert(result == 100, "Başarılı operasyon 100 dönmeli");
    
    // Şimdi hatalı durum
    var result2 = 0;
    try {
        let val = risky_operation(true)?;
        result2 = val;
    } catch Error::NetworkError(msg) {
        result2 = -1;
    } catch _ {
        result2 = -3;
    }
    
    assert(result2 == -1, "NetworkError yakalanmalı");
    
    println("✓ Try-catch pattern matching çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 5: Nested Try-Catch
// ══════════════════════════════════════════════════════════════════════════════

fn test_nested_try_catch() {
    println("TEST: Nested try-catch...");
    
    var outer_result = 0;
    var inner_result = 0;
    
    try {
        outer_result = 1;
        try {
            inner_result = 2;
            let x = divide(10, 2)?;
            inner_result = x;
        } catch _ {
            inner_result = -1;
        }
        outer_result = inner_result + 10;
    } catch _ {
        outer_result = -99;
    }
    
    assert(inner_result == 5, "İç try sonucu 5 olmalı");
    assert(outer_result == 15, "Dış try sonucu 15 olmalı");
    
    println("✓ Nested try-catch çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 6: Result Chaining
// ══════════════════════════════════════════════════════════════════════════════

fn test_result_chaining() {
    println("TEST: Result chaining...");
    
    // map kullanımı
    let result1 = Result::Ok(5);
    let mapped = match result1 {
        Result::Ok(v) => Result::Ok(v * 2),
        Result::Err(e) => Result::Err(e),
    };
    
    match mapped {
        Result::Ok(v) => assert(v == 10, "Map çalışmalı"),
        Result::Err(_) => assert(false, "Hata olmamalı"),
    }
    
    // and_then kullanımı (simüle)
    let result2 = Result::Ok(10);
    let chained = match result2 {
        Result::Ok(v) => divide(v, 2),
        Result::Err(e) => Result::Err(e),
    };
    
    match chained {
        Result::Ok(v) => assert(v == 5, "Chain çalışmalı"),
        Result::Err(_) => assert(false, "Hata olmamalı"),
    }
    
    println("✓ Result chaining çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 7: Error Context
// ══════════════════════════════════════════════════════════════════════════════

fn test_error_context() {
    println("TEST: Error context...");
    
    fn operation_with_context(x: i64) -> Result<i64, Error> {
        let result = divide(x, 0);
        match result {
            Result::Err(Error::DivisionByZero) => {
                // Error'a context ekle
                yield Result::Err(Error::InvalidInput("Division by zero in operation_with_context".into()));
            }
            other => yield other,
        }
    }
    
    match operation_with_context(10) {
        Result::Ok(_) => assert(false, "Hata olmalıydı"),
        Result::Err(Error::InvalidInput(msg)) => {
            assert(msg.contains("context"), "Context bilgisi olmalı");
        }
        Result::Err(_) => assert(false, "Yanlış error türü"),
    }
    
    println("✓ Error context çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 8: Multiple Error Propagation
// ══════════════════════════════════════════════════════════════════════════════

fn multi_step_operation() -> Result<i64, Error> {
    let a = parse_number("42")?;
    let b = divide(a, 2)?;
    let c = check_range(b, 0, 50)?;
    yield Result::Ok(c);
}

fn test_multiple_propagation() {
    println("TEST: Multiple error propagation...");
    
    match multi_step_operation() {
        Result::Ok(v) => assert(v == 21, "Tüm adımlar başarılı olmalı"),
        Result::Err(_) => assert(false, "Hata olmamalı"),
    }
    
    println("✓ Multiple error propagation çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 9: Unwrap ve Expect (Panic)
// ══════════════════════════════════════════════════════════════════════════════

fn test_unwrap_expect() {
    println("TEST: Unwrap ve expect...");
    
    let ok_result: Result<i64, Error> = Result::Ok(42);
    
    // Unwrap başarılı durumda
    match ok_result {
        Result::Ok(v) => {
            let unwrapped = v;
            assert(unwrapped == 42, "Unwrap çalışmalı");
        }
        Result::Err(_) => assert(false, "Ok olmalıydı"),
    }
    
    // Unwrap başarısız durumda panic etmeli (test edilemez, çünkü program çöker)
    // let err_result: Result<i64, Error> = Result::Err(Error::DivisionByZero);
    // let will_panic = err_result.unwrap();  // PANIC!
    
    println("✓ Unwrap/expect davranışı doğru");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 10: Error Recovery
// ══════════════════════════════════════════════════════════════════════════════

fn test_error_recovery() {
    println("TEST: Error recovery...");
    
    fn safe_divide(a: i64, b: i64) -> i64 {
        match divide(a, b) {
            Result::Ok(v) => v,
            Result::Err(_) => 0,  // Error durumunda varsayılan değer
        }
    }
    
    let result1 = safe_divide(10, 2);
    assert(result1 == 5, "Başarılı division");
    
    let result2 = safe_divide(10, 0);
    assert(result2 == 0, "Error recovery varsayılan değer");
    
    println("✓ Error recovery çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// MAIN - Tüm Testleri Çalıştır
// ══════════════════════════════════════════════════════════════════════════════

fn main() {
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  NOVA ERROR HANDLING TEST SUITE                              ║");
    println("╚══════════════════════════════════════════════════════════════╝");
    println("");
    
    test_try_catch_basic();
    test_error_propagation();
    test_different_errors();
    test_try_catch_patterns();
    test_nested_try_catch();
    test_result_chaining();
    test_error_context();
    test_multiple_propagation();
    test_unwrap_expect();
    test_error_recovery();
    
    println("");
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  ✓ TÜM ERROR HANDLING TESTLERİ BAŞARILI                      ║");
    println("╚══════════════════════════════════════════════════════════════╝");
}
