// ══════════════════════════════════════════════════════════════════════════════
// Nova Unit Algebra — Kapsamlı Type Testi
// Tüm numeric tipler (i32, i64, f32, f64, u8, usize) × Tüm SI birimleri
// ══════════════════════════════════════════════════════════════════════════════

use std::io::println;

// ─────────────────────────────────────────────────────────────────────────────
// BÖLÜM 1: Numeric Type'lar × SI Base Units
// ─────────────────────────────────────────────────────────────────────────────

fn test_i32_units() {
    println("TEST 1: i32 × SI base units");

    let len_i32:   qty<i32, m>   = 10.m;
    let mass_i32:  qty<i32, kg>  = 5.kg;
    let time_i32:  qty<i32, s>   = 3.s;
    let curr_i32:  qty<i32, A>   = 2.A;
    let temp_i32:  qty<i32, K>   = 300.K;
    let mol_i32:   qty<i32, mol> = 1.mol;

    let len2  = len_i32 + 5.m;
    let mass2 = mass_i32 * 2;
    let time2 = time_i32 - 1.s;

    assert(len2  == 15.m,  "i32 m add");
    assert(mass2 == 10.kg, "i32 kg mul");
    assert(time2 == 2.s,   "i32 s sub");

    println("✓ i32 × SI base units");
}

fn test_i64_units() {
    println("TEST 2: i64 × SI base units");

    let dist:  qty<i64, m>   = 1000.m;
    let mass:  qty<i64, kg>  = 80.kg;
    let dur:   qty<i64, s>   = 3600.s;
    let curr:  qty<i64, A>   = 15.A;
    let temp:  qty<i64, K>   = 273.K;
    let amt:   qty<i64, mol> = 6.mol;
    let lum:   qty<i64, cd>  = 100.cd;

    let dist2 = dist + 500.m;
    let mass2 = mass - 10.kg;

    assert(dist2 == 1500.m, "i64 m add");
    assert(mass2 == 70.kg,  "i64 kg sub");

    println("✓ i64 × SI base units");
}

fn test_f32_units() {
    println("TEST 3: f32 × SI base units");

    let len:  qty<f32, m>   = 3.14.m;
    let mass: qty<f32, kg>  = 9.81.kg;
    let time: qty<f32, s>   = 0.5.s;
    let curr: qty<f32, A>   = 1.5.A;
    let temp: qty<f32, K>   = 293.15.K;

    let doubled = len * 2;
    assert(doubled ~ 6.28.m, "f32 m double");

    println("✓ f32 × SI base units");
}

fn test_f64_units() {
    println("TEST 4: f64 × SI base units");

    let len:  qty<f64, m>   = 299792458.0.m;
    let mass: qty<f64, kg>  = 9.10938e-31.kg;
    let time: qty<f64, s>   = 1.616e-35.s;
    let curr: qty<f64, A>   = 1.602e-19.A;
    let temp: qty<f64, K>   = 1.416e32.K;

    let doubled_len = len * 2.0;
    assert(doubled_len ~ 599584916.0.m, "f64 m double");

    println("✓ f64 × SI base units");
}

fn test_u8_units() {
    println("TEST 5: u8 × SI base units");

    let small_len:  qty<u8, m>  = 100.m;
    let small_mass: qty<u8, kg> = 50.kg;
    let small_time: qty<u8, s>  = 255.s;

    let sum = small_len + 55.m;
    assert(sum == 155.m, "u8 m add");

    println("✓ u8 × SI base units");
}

fn test_usize_units() {
    println("TEST 6: usize × SI base units");

    let count_m:   qty<usize, m>   = 42.m;
    let count_kg:  qty<usize, kg>  = 100.kg;
    let count_s:   qty<usize, s>   = 60.s;

    let total = count_m + 8.m;
    assert(total == 50.m, "usize m add");

    println("✓ usize × SI base units");
}


// ─────────────────────────────────────────────────────────────────────────────
// BÖLÜM 2: SI Derived Units — Tüm Türetilmiş Birimler
// ─────────────────────────────────────────────────────────────────────────────

fn test_mechanical_units() {
    println("TEST 7: Mekanik türetilmiş birimler");

    // Newton: kg·m/s²
    let force:    qty<f64, N>        = 50.0.N;
    let force2:   qty<f64, kg·m/s²>  = 50.0.kg·m/s²;

    // Joule: kg·m²/s²
    let energy:   qty<f64, J>        = 100.0.J;
    let energy2:  qty<f64, kg·m²/s²> = 100.0.kg·m²/s²;

    // Watt: kg·m²/s³
    let power:    qty<f64, W>        = 1000.0.W;

    // Pascal: kg/(m·s²)
    let pressure: qty<f64, Pa>       = 101325.0.Pa;

    // Hertz: 1/s
    let freq:     qty<f64, Hz>       = 440.0.Hz;

    let force_sum  = force + 10.0.N;
    let energy_sum = energy + 50.0.J;

    assert(force_sum  == 60.0.N,   "N add");
    assert(energy_sum == 150.0.J,  "J add");

    println("✓ Mekanik türetilmiş birimler");
}

fn test_electrical_derived_units() {
    println("TEST 8: Elektriksel türetilmiş birimler");

    // Volt: kg·m²/(A·s³)
    let voltage:     qty<f64, V>  = 230.0.V;

    // Coulomb: A·s
    let charge:      qty<f64, C>  = 1.602e-19.C;

    // Ohm: kg·m²/(A²·s³)
    let resistance:  qty<f64, Ω>  = 100.0.Ω;

    // Farad: A²·s⁴/(kg·m²)
    let capacitance: qty<f64, F>  = 100e-6.F;

    // Siemens: A²·s³/(kg·m²)
    let conductance: qty<f64, S>  = 0.01.S;

    // Henry: kg·m²/(A²·s²)
    let inductance:  qty<f64, H>  = 0.001.H;

    // Tesla: kg/(A·s²)
    let flux_density: qty<f64, T> = 1.5.T;

    // Weber: kg·m²/(A·s²)
    let flux:        qty<f64, Wb> = 0.5.Wb;

    let v_sum = voltage + 10.0.V;
    let r_sum = resistance + 50.0.Ω;

    assert(v_sum ~ 240.0.V,  "V add");
    assert(r_sum ~ 150.0.Ω,  "Ω add");

    println("✓ Elektriksel türetilmiş birimler");
}

fn test_photometric_units() {
    println("TEST 9: Fotometrik birimler");

    // Candela (base)
    let intensity: qty<f64, cd>  = 100.0.cd;

    // Lumen: cd·sr (sr = steradyan = dimensionless)
    let lum_flux:  qty<f64, lm>  = 800.0.lm;

    // Lux: cd·sr/m²
    let illuminance: qty<f64, lx> = 500.0.lx;

    let cd_sum = intensity + 50.0.cd;
    assert(cd_sum == 150.0.cd, "cd add");

    println("✓ Fotometrik birimler");
}

fn test_radiological_units() {
    println("TEST 10: Radyolojik birimler");

    // Becquerel: 1/s (radioactivity)
    let activity:    qty<f64, Bq> = 1000.0.Bq;

    // Gray: m²/s² (absorbed dose)
    let abs_dose:    qty<f64, Gy> = 0.01.Gy;

    // Sievert: m²/s² (effective dose)
    let eff_dose:    qty<f64, Sv> = 0.001.Sv;

    let act_sum = activity + 500.0.Bq;
    assert(act_sum ~ 1500.0.Bq, "Bq add");

    println("✓ Radyolojik birimler");
}

fn test_chemical_units() {
    println("TEST 11: Kimyasal birimler");

    // Mole (base)
    let amount:  qty<f64, mol>  = 2.5.mol;

    // Katal: mol/s (catalytic activity)
    let catalytic: qty<f64, kat> = 0.5.kat;

    let mol_sum = amount + 1.5.mol;
    assert(mol_sum ~ 4.0.mol, "mol add");

    println("✓ Kimyasal birimler");
}


// ─────────────────────────────────────────────────────────────────────────────
// BÖLÜM 3: SI Prefix Testleri (kilo, mega, milli, micro...)
// ─────────────────────────────────────────────────────────────────────────────

fn test_si_prefixes() {
    println("TEST 12: SI prefix'leri");

    // kilo (1e3)
    let km:   qty<f64, km>  = 1.0.km;
    let kg_:  qty<f64, kg>  = 1.0.kg;

    // milli (1e-3)
    let mm:   qty<f64, mm>  = 500.0.mm;
    let ms:   qty<f64, ms>  = 100.0.ms;
    let mg:   qty<f64, mg>  = 250.0.mg;

    // micro (1e-6)
    let μm:   qty<f64, μm>  = 10.0.μm;
    let μA:   qty<f64, μA>  = 50.0.μA;
    let μs:   qty<f64, μs>  = 1.0.μs;

    // nano (1e-9)
    let nm:   qty<f64, nm>  = 700.0.nm;
    let ns:   qty<f64, ns>  = 10.0.ns;

    // mega (1e6)
    let MHz_: qty<f64, MHz> = 2400.0.MHz;
    let MW:   qty<f64, MW>  = 1.0.MW;
    let MPa:  qty<f64, MPa> = 200.0.MPa;

    // giga (1e9)
    let GHz:  qty<f64, GHz> = 3.6.GHz;
    let GB_:  qty<f64, Gb>  = 8.0.Gb;

    // centi (1e-2)
    let cm:   qty<f64, cm>  = 100.0.cm;

    let mm_sum = mm + 250.0.mm;
    assert(mm_sum ~ 750.0.mm, "mm add");

    let nm_sum = nm + 100.0.nm;
    assert(nm_sum ~ 800.0.nm, "nm add");

    println("✓ SI prefix'leri");
}

// ─────────────────────────────────────────────────────────────────────────────
// BÖLÜM 4: Compound / Composite Units — Bileşik Birimler
// ─────────────────────────────────────────────────────────────────────────────

fn test_compound_units_all() {
    println("TEST 13: Bileşik birimler (tam liste)");

    // Hız
    let v:      qty<f64, m/s>      = 30.0.m/s;
    let v_kmh:  qty<f64, km/h>     = 108.0.km/h;

    // İvme
    let a:      qty<f64, m/s²>     = 9.81.m/s²;

    // Kuvvet alanı (gravitational field)
    let g_fld:  qty<f64, N/kg>     = 9.81.N/kg;

    // Enerji yoğunluğu
    let e_dens: qty<f64, J/kg>     = 43e6.J/kg;

    // Özgül ısı
    let c_heat: qty<f64, J/kg·K>   = 4186.0.J/kg·K;

    // Termal iletkenlik
    let k_th:   qty<f64, W/m·K>    = 50.0.W/m·K;

    // Viskozite (dinamik)
    let visc:   qty<f64, Pa·s>     = 0.001.Pa·s;

    // Elektrik alan
    let e_fld:  qty<f64, V/m>      = 1000.0.V/m;

    // Magnetik alan
    let h_fld:  qty<f64, A/m>      = 795.8.A/m;

    // Özdirenç
    let rho_r:  qty<f64, Ω·m>      = 1.7e-8.Ω·m;

    // Işık hızı bağıntısı
    let c_light: qty<f64, m/s>     = 299792458.0.m/s;

    let v_sum = v + 10.0.m/s;
    assert(v_sum ~ 40.0.m/s, "m/s add");

    let a_sum = a + 0.19.m/s²;
    assert(a_sum ~ 10.0.m/s², "m/s² add");

    println("✓ Bileşik birimler");
}

// ─────────────────────────────────────────────────────────────────────────────
// BÖLÜM 5: Arithmetic Operations — Tüm İşlemler
// ─────────────────────────────────────────────────────────────────────────────

fn test_unit_arithmetic_all() {
    println("TEST 14: Birim aritmetiği (tüm işlemler)");

    // Addition
    let a1: qty<f64, m>  = 3.0.m;
    let a2: qty<f64, m>  = 4.0.m;
    assert(a1 + a2 == 7.0.m, "add m");

    // Subtraction
    let s1: qty<f64, kg> = 10.0.kg;
    let s2: qty<f64, kg> = 3.5.kg;
    assert(s1 - s2 ~ 6.5.kg, "sub kg");

    // Multiplication (qty × scalar)
    let m1: qty<f64, m>  = 5.0.m;
    assert(m1 * 3.0 == 15.0.m, "mul scalar");
    assert(3.0 * m1 == 15.0.m, "mul scalar lhs");

    // Division (qty / scalar)
    let d1: qty<f64, m>  = 100.0.m;
    assert(d1 / 4.0 ~ 25.0.m, "div scalar");

    // Multiplication (qty × qty → compound)
    let force:  qty<f64, N> = 10.0.N;
    let dist:   qty<f64, m> = 5.0.m;
    let work    = force * dist;  // N·m = J
    assert(work ~ 50.0.J, "N × m = J");

    // Power
    let vel:    qty<f64, m/s> = 10.0.m/s;
    let ke_dim  = vel ** 2;     // (m/s)² = m²/s²
    let mass:   qty<f64, kg>  = 2.0.kg;
    let ke      = 0.5 * mass * (vel ** 2);
    assert(ke ~ 100.0.J, "KE = ½mv²");

    // Comparison operators
    let x: qty<f64, m> = 5.0.m;
    let y: qty<f64, m> = 3.0.m;
    assert(x > y,  "m gt");
    assert(y < x,  "m lt");
    assert(x >= x, "m gte");
    assert(y <= y, "m lte");
    assert(x != y, "m neq");

    // Approximate equality
    let pi_m: qty<f64, m> = 3.14159.m;
    assert(pi_m ~ 3.14.m, "approx eq m");

    println("✓ Birim aritmetiği");
}

// ─────────────────────────────────────────────────────────────────────────────
// BÖLÜM 6: Unit Conversion — Birim Dönüşümleri
// ─────────────────────────────────────────────────────────────────────────────

fn test_unit_conversions_all() {
    println("TEST 15: Birim dönüşümleri");

    // Uzunluk dönüşümleri
    let d_km: qty<f64, km> = 1.0.km;
    let d_m   = d_km in m;
    assert(d_m ~ 1000.0.m, "km → m");

    let d_mm: qty<f64, mm> = 1000.0.mm;
    let d_m2  = d_mm in m;
    assert(d_m2 ~ 1.0.m, "mm → m");

    let d_cm: qty<f64, cm> = 100.0.cm;
    let d_m3  = d_cm in m;
    assert(d_m3 ~ 1.0.m, "cm → m");

    // Kütle dönüşümleri
    let m_g: qty<f64, g> = 1000.0.g;
    let m_kg  = m_g in kg;
    assert(m_kg ~ 1.0.kg, "g → kg");

    // Sıcaklık dönüşümleri
    let t_c: qty<f64, °C> = 0.0.°C;
    let t_k   = t_c in K;
    assert(t_k ~ 273.15.K, "°C → K");

    let t_c2: qty<f64, °C> = 100.0.°C;
    let t_k2  = t_c2 in K;
    assert(t_k2 ~ 373.15.K, "100°C → K");

    // Frekans
    let f_khz: qty<f64, kHz> = 1.0.kHz;
    let f_hz   = f_khz in Hz;
    assert(f_hz ~ 1000.0.Hz, "kHz → Hz");

    let f_mhz: qty<f64, MHz> = 1.0.MHz;
    let f_hz2  = f_mhz in Hz;
    assert(f_hz2 ~ 1e6.Hz, "MHz → Hz");

    // Güç
    let p_kw: qty<f64, kW> = 1.0.kW;
    let p_w   = p_kw in W;
    assert(p_w ~ 1000.0.W, "kW → W");

    // Basınç
    let p_kpa: qty<f64, kPa> = 101.325.kPa;
    let p_pa   = p_kpa in Pa;
    assert(p_pa ~ 101325.0.Pa, "kPa → Pa");

    println("✓ Birim dönüşümleri");
}


// ─────────────────────────────────────────────────────────────────────────────
// BÖLÜM 7: Physics Domain Tests — Gerçek Fizik Formülleri
// ─────────────────────────────────────────────────────────────────────────────

fn test_mechanics() {
    println("TEST 16: Mekanik formüller");

    // Newton'un 2. yasası: F = m·a
    let m:   qty<f64, kg>    = 5.0.kg;
    let a:   qty<f64, m/s²>  = 2.0.m/s²;
    let f    = m * a;
    assert(f ~ 10.0.N, "F = m·a");

    // Kinetik enerji: KE = ½mv²
    let v:   qty<f64, m/s>   = 10.0.m/s;
    let ke   = 0.5 * m * (v ** 2);
    assert(ke ~ 250.0.J, "KE = ½mv²");

    // Potansiyel enerji: PE = mgh
    let g:   qty<f64, m/s²>  = 9.81.m/s²;
    let h:   qty<f64, m>     = 5.0.m;
    let pe   = m * g * h;
    assert(pe ~ 245.25.J, "PE = mgh");

    // Momentum: p = mv
    let p    = m * v;
    assert(p ~ 50.0.kg·m/s, "p = mv");

    // İş: W = F·d
    let d:   qty<f64, m>     = 3.0.m;
    let w    = f * d;
    assert(w ~ 30.0.J, "W = F·d");

    // Güç: P = W/t
    let t:   qty<f64, s>     = 6.0.s;
    let pwr  = w / t;
    assert(pwr ~ 5.0.W, "P = W/t");

    println("✓ Mekanik formüller");
}

fn test_thermodynamics() {
    println("TEST 17: Termodinamik formüller");

    // Q = mcΔT (ısı)
    let m:    qty<f64, kg>   = 1.0.kg;
    let c:    qty<f64, J/kg·K> = 4186.0.J/kg·K;
    let dT:   qty<f64, K>    = 10.0.K;
    let q     = m * c * dT;
    assert(q ~ 41860.0.J, "Q = mcΔT");

    // Sıcaklık dönüşümleri
    let body_temp: qty<f64, °C> = 37.0.°C;
    let body_k     = body_temp in K;
    assert(body_k ~ 310.15.K, "37°C → K");

    let abs_zero:  qty<f64, °C> = -273.15.°C;
    let abs_k      = abs_zero in K;
    assert(abs_k ~ 0.0.K, "abs zero");

    println("✓ Termodinamik formüller");
}

fn test_electromagnetism() {
    println("TEST 18: Elektromanyetizma formülleri");

    // Ohm yasası: V = I·R
    let i:   qty<f64, A>  = 2.0.A;
    let r:   qty<f64, Ω>  = 50.0.Ω;
    let v    = i * r;
    assert(v ~ 100.0.V, "V = I·R");

    // Güç: P = V·I
    let p    = v * i;
    assert(p ~ 200.0.W, "P = V·I");

    // Güç: P = I²·R
    let p2   = (i ** 2) * r;
    assert(p2 ~ 200.0.W, "P = I²R");

    // Kapasite: Q = C·V
    let c:   qty<f64, F>  = 100e-6.F;
    let q    = c * v;
    assert(q ~ 0.01.C, "Q = CV");

    // Endüktans enerjisi: E = ½LI²
    let l:   qty<f64, H>  = 0.1.H;
    let e    = 0.5 * l * (i ** 2);
    assert(e ~ 0.2.J, "E = ½LI²");

    println("✓ Elektromanyetizma formülleri");
}

fn test_optics() {
    println("TEST 19: Optik formüller");

    // Işık hızı: c = λ·f
    let lambda: qty<f64, nm>  = 550.0.nm;
    let f_vis:  qty<f64, Hz>  = 545e12.Hz;
    let c_calc  = lambda * f_vis;
    // c ≈ 3×10⁸ m/s (nm × Hz = nm/s → convert)

    // Kırılma indisi: n = c/v
    let c_light: qty<f64, m/s> = 3e8.m/s;
    let v_glass: qty<f64, m/s> = 2e8.m/s;
    let n        = c_light / v_glass;
    assert(n ~ 1.5, "n = c/v glass");

    println("✓ Optik formüller");
}

// ─────────────────────────────────────────────────────────────────────────────
// BÖLÜM 8: Array ve Struct ile Unit Algebra
// ─────────────────────────────────────────────────────────────────────────────

fn test_unit_in_arrays() {
    println("TEST 20: Array içinde birim değerleri");

    let distances: [qty<f64, m>; 5] = [1.0.m, 2.0.m, 3.0.m, 4.0.m, 5.0.m];
    let masses:    [qty<f64, kg>; 3] = [70.0.kg, 80.0.kg, 90.0.kg];

    // Sum of distances
    let total_d = distances[0] + distances[1] + distances[2] +
                  distances[3] + distances[4];
    assert(total_d == 15.0.m, "array sum m");

    // Average mass
    let avg_m = (masses[0] + masses[1] + masses[2]) / 3.0;
    assert(avg_m ~ 80.0.kg, "array avg kg");

    println("✓ Array içinde birim değerleri");
}

fn test_unit_in_functions() {
    println("TEST 21: Fonksiyon parametrelerinde birimler");

    fn speed(dist: qty<f64, m>, time: qty<f64, s>) -> qty<f64, m/s> {
        yield dist / time;
    }

    fn kinetic_energy(mass: qty<f64, kg>, vel: qty<f64, m/s>) -> qty<f64, J> {
        yield 0.5 * mass * (vel ** 2);
    }

    fn celsius_to_kelvin(t: qty<f64, °C>) -> qty<f64, K> {
        yield t in K;
    }

    fn ohms_law_voltage(current: qty<f64, A>, resistance: qty<f64, Ω>) -> qty<f64, V> {
        yield current * resistance;
    }

    let v   = speed(100.0.m, 10.0.s);
    assert(v ~ 10.0.m/s, "speed fn");

    let ke  = kinetic_energy(2.0.kg, 10.0.m/s);
    assert(ke ~ 100.0.J, "KE fn");

    let tk  = celsius_to_kelvin(100.0.°C);
    assert(tk ~ 373.15.K, "C→K fn");

    let vlt = ohms_law_voltage(3.0.A, 10.0.Ω);
    assert(vlt ~ 30.0.V, "Ohm fn");

    println("✓ Fonksiyon parametrelerinde birimler");
}

// ─────────────────────────────────────────────────────────────────────────────
// BÖLÜM 9: Non-SI / Imperial Units
// ─────────────────────────────────────────────────────────────────────────────

fn test_non_si_units() {
    println("TEST 22: Non-SI ve özel birimler");

    // Elektronvolt
    let e_eV:   qty<f64, eV>   = 13.6.eV;

    // Atmosfer
    let p_atm:  qty<f64, atm>  = 1.0.atm;

    // Litre
    let vol_L:  qty<f64, L>    = 1.5.L;

    // Dakika
    let t_min:  qty<f64, min>  = 60.0.min;

    // Saat
    let t_hr:   qty<f64, h>    = 1.0.h;

    // Açısal birimler
    let ang_deg: qty<f64, deg>  = 180.0.deg;
    let ang_rad: qty<f64, rad>  = 3.14159.rad;

    // RPM
    let rpm:    qty<f64, rpm>   = 3000.0.rpm;

    println("✓ Non-SI birimler");
}

// ─────────────────────────────────────────────────────────────────────────────
// BÖLÜM 10: Özel Type Kombinasyonları
// ─────────────────────────────────────────────────────────────────────────────

fn test_type_combinations() {
    println("TEST 23: Tip kombinasyonları");

    // i32 × derived units
    let f_i32:  qty<i32, N>   = 10.N;
    let e_i32:  qty<i32, J>   = 50.J;
    let p_i32:  qty<i32, Pa>  = 101325.Pa;
    let v_i32:  qty<i32, V>   = 220.V;

    // f32 × derived units
    let f_f32:  qty<f32, N>   = 9.81.N;
    let e_f32:  qty<f32, J>   = 4.186.J;
    let v_f32:  qty<f32, V>   = 3.3.V;

    // i64 × derived units
    let f_i64:  qty<i64, N>   = 1000.N;
    let e_i64:  qty<i64, J>   = 86400.J;

    // usize × measurement counts
    let samples: qty<usize, Hz> = 44100.Hz;
    let pixels:  qty<usize, lx> = 300.lx;

    let f_sum = f_i32 + 5.N;
    assert(f_sum == 15.N, "i32 N add");

    println("✓ Tip kombinasyonları");
}

fn test_dimensional_analysis_extended() {
    println("TEST 24: Genişletilmiş boyutsal analiz");

    // Yoğunluk: ρ = m/V → kg/m³
    let mass:   qty<f64, kg>   = 7874.0.kg;
    let vol:    qty<f64, m³>   = 1.0.m³;
    let density = mass / vol;
    assert(density ~ 7874.0.kg/m³, "ρ = m/V");

    // Basınç: P = F/A → N/m² = Pa
    let force:  qty<f64, N>    = 1000.0.N;
    let area:   qty<f64, m²>   = 0.01.m²;
    let pressure = force / area;
    assert(pressure ~ 100000.0.Pa, "P = F/A");

    // Özgül ağırlık: γ = ρ·g → kg/(m²·s²)
    let rho:    qty<f64, kg/m³> = 1000.0.kg/m³;
    let g:      qty<f64, m/s²>  = 9.81.m/s²;
    let gamma   = rho * g;
    assert(gamma ~ 9810.0.N/m³, "γ = ρg");

    // Akış hızı: Q = A·v → m³/s
    let area2:  qty<f64, m²>   = 0.05.m²;
    let vel:    qty<f64, m/s>  = 2.0.m/s;
    let flow    = area2 * vel;
    assert(flow ~ 0.1.m³/s, "Q = Av");

    println("✓ Genişletilmiş boyutsal analiz");
}

// ─────────────────────────────────────────────────────────────────────────────
// MAIN — Tüm testleri çalıştır
// ─────────────────────────────────────────────────────────────────────────────

fn main() {
    println("══════════════════════════════════════════════════════════════");
    println("Nova Unit Algebra — Kapsamlı Type Testleri");
    println("══════════════════════════════════════════════════════════════");
    println("");

    // Numeric type × SI base
    test_i32_units();
    test_i64_units();
    test_f32_units();
    test_f64_units();
    test_u8_units();
    test_usize_units();

    // SI derived units
    test_mechanical_units();
    test_electrical_derived_units();
    test_photometric_units();
    test_radiological_units();
    test_chemical_units();

    // SI prefixes
    test_si_prefixes();

    // Compound units
    test_compound_units_all();

    // Arithmetic
    test_unit_arithmetic_all();

    // Conversions
    test_unit_conversions_all();

    // Physics domain
    test_mechanics();
    test_thermodynamics();
    test_electromagnetism();
    test_optics();

    // Arrays and functions
    test_unit_in_arrays();
    test_unit_in_functions();

    // Non-SI
    test_non_si_units();

    // Type combinations
    test_type_combinations();
    test_dimensional_analysis_extended();

    println("");
    println("══════════════════════════════════════════════════════════════");
    println("✅ Tüm unit algebra testleri BAŞARILI!");
    println("══════════════════════════════════════════════════════════════");
}
