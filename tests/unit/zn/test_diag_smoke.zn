// Diagnostics Runtime Smoke Test
// Test error reporting with spans and source context
// XFAIL: intentional syntax error for diagnostics testing

fn test_syntax_error() {
    // This should generate syntax error
    var x = ;  // Missing expression after =
}

fn test_unknown_symbol() {
    // This should generate unknown symbol error
    var x = nonexistent_function();
}

fn test_type_error() {
    // This should generate type mismatch error
    var x: i32 = "string";  // String assigned to int
}

fn main() {
    // This should work fine
    var result: i32 = 42;
    yield result;
}
