// Test: Extended operators - simplified version
// Test arithmetic and comparison operators

fn test_arithmetic() -> i64 {
    var a = 10;
    var b = 3;
    var result = 0;
    
    result = a + b;
    result = result + a - b;
    result = result + a * b;
    result = result + a / b;
    
    yield result;
}

fn test_comparison() -> i64 {
    var x = 10;
    var result = 0;
    
    check x < 20 {
        result = 1;
    }
    
    check x == 10 {
        result = result + 10;
    }
    
    yield result;
}

fn test_compound() -> i64 {
    var x = 10;
    
    x = x + 5;
    x = x - 3;
    x = x * 2;
    
    yield x;
}

fn main() -> i64 {
    var t1 = test_arithmetic();
    var t2 = test_comparison();
    var t3 = test_compound();
    
    var total = t1 + t2 + t3;
    yield total;
}
