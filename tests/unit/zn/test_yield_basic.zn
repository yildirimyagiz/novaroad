// Test: Yield keyword for returns
// Mevcut compiler desteği: yield keyword

fn simple_yield() -> i64 {
    yield 42;
}

fn yield_with_calc() -> i64 {
    var x = 10;
    var y = 20;
    yield x + y;
}

fn early_yield(x: i64) -> i64 {
    check x < 0 {
        yield -1;
    }
    check x == 0 {
        yield 0;
    }
    yield 1;
}

fn yield_in_loop() -> i64 {
    var i = 0;
    while i < 10 {
        check i == 5 {
            yield i;
        }
        i = i + 1;
    }
    yield -1;
}

fn main() -> i64 {
    var r1 = simple_yield();           // 42
    var r2 = yield_with_calc();        // 30
    var r3 = early_yield(10);          // 1
    var r4 = early_yield(-5);          // -1
    var r5 = yield_in_loop();          // 5
    
    // Test results
    check r1 == 42 {
        check r2 == 30 {
            check r3 == 1 {
                check r4 == -1 {
                    check r5 == 5 {
                        yield 1;  // All tests passed
                    }
                }
            }
        }
    }
    
    yield 0;  // Tests failed
}
