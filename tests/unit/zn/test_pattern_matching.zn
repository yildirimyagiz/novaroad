// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  NOVA PATTERN MATCHING TEST SUITE                                            ║
// ║  Kapsamlı pattern matching testleri                                          ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use std::io::println;

// ══════════════════════════════════════════════════════════════════════════════
// TEST VERI YAPILARI
// ══════════════════════════════════════════════════════════════════════════════

cases Option<T> {
    Some(T),
    None,
}

cases Result<T, E> {
    Ok(T),
    Err(E),
}

cases Shape {
    Circle { radius: f64 },
    Rectangle { width: f64, height: f64 },
    Triangle { a: f64, b: f64, c: f64 },
}

cases Color {
    RGB(i64, i64, i64),
    HSL(f64, f64, f64),
    Named(String),
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 1: Temel Pattern Matching
// ══════════════════════════════════════════════════════════════════════════════

fn test_basic_match() {
    println("TEST: Temel pattern matching...");
    
    let x = 42;
    
    let result = match x {
        0 => "zero",
        1 => "one",
        42 => "answer",
        _ => "other",
    };
    
    assert(result == "answer", "42 → 'answer' olmalı");
    println("✓ Temel match çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 2: Option Pattern Matching
// ══════════════════════════════════════════════════════════════════════════════

fn test_option_matching() {
    println("TEST: Option pattern matching...");
    
    let some_value: Option<i64> = Option::Some(10);
    let none_value: Option<i64> = Option::None;
    
    // Some pattern
    let result1 = match some_value {
        Option::Some(x) => x * 2,
        Option::None => 0,
    };
    assert(result1 == 20, "Some(10) → 20 olmalı");
    
    // None pattern
    let result2 = match none_value {
        Option::Some(x) => x * 2,
        Option::None => -1,
    };
    assert(result2 == -1, "None → -1 olmalı");
    
    println("✓ Option matching çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 3: Result Pattern Matching
// ══════════════════════════════════════════════════════════════════════════════

fn test_result_matching() {
    println("TEST: Result pattern matching...");
    
    let success: Result<i64, String> = Result::Ok(42);
    let failure: Result<i64, String> = Result::Err("error".into());
    
    // Ok pattern
    let val1 = match success {
        Result::Ok(v) => v,
        Result::Err(_) => 0,
    };
    assert(val1 == 42, "Ok(42) → 42 olmalı");
    
    // Err pattern
    let val2 = match failure {
        Result::Ok(_) => 0,
        Result::Err(msg) => -1,
    };
    assert(val2 == -1, "Err → -1 olmalı");
    
    println("✓ Result matching çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 4: Tuple Pattern Matching
// ══════════════════════════════════════════════════════════════════════════════

fn test_tuple_matching() {
    println("TEST: Tuple pattern matching...");
    
    let point = (3, 4);
    
    let result = match point {
        (0, 0) => "origin",
        (0, _) => "y-axis",
        (_, 0) => "x-axis",
        (x, y) check x == y => "diagonal",
        _ => "general",
    };
    
    assert(result == "general", "(3,4) → 'general' olmalı");
    
    // Destructuring
    let (x, y) = point;
    assert(x == 3 && y == 4, "Tuple destructuring çalışmalı");
    
    println("✓ Tuple matching çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 5: Record/Struct Pattern Matching
// ══════════════════════════════════════════════════════════════════════════════

fn test_record_matching() {
    println("TEST: Record pattern matching...");
    
    let circle = Shape::Circle { radius: 5.0 };
    let rect = Shape::Rectangle { width: 10.0, height: 20.0 };
    
    // Circle pattern
    let area1 = match circle {
        Shape::Circle { radius: r } => 3.14159 * r * r,
        Shape::Rectangle { width: w, height: h } => w * h,
        Shape::Triangle { a, b, c } => 0.0,  // Heron's formula burada
    };
    assert(area1 ~ 78.54, "Circle area ≈ 78.54");
    
    // Rectangle pattern
    let area2 = match rect {
        Shape::Circle { radius: _ } => 0.0,
        Shape::Rectangle { width: w, height: h } => w * h,
        Shape::Triangle { .. } => 0.0,
    };
    assert(area2 == 200.0, "Rectangle area = 200.0");
    
    println("✓ Record matching çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 6: Nested Pattern Matching
// ══════════════════════════════════════════════════════════════════════════════

fn test_nested_matching() {
    println("TEST: Nested pattern matching...");
    
    let nested: Option<Result<i64, String>> = Option::Some(Result::Ok(42));
    
    let value = match nested {
        Option::Some(Result::Ok(v)) => v,
        Option::Some(Result::Err(_)) => -1,
        Option::None => 0,
    };
    
    assert(value == 42, "Nested pattern çalışmalı");
    println("✓ Nested matching çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 7: Array/List Pattern Matching
// ══════════════════════════════════════════════════════════════════════════════

fn test_array_matching() {
    println("TEST: Array pattern matching...");
    
    let list1 = [1, 2, 3, 4];
    let list2 = [10];
    let empty: [i64; 0] = [];
    
    // Head-tail pattern
    let result1 = match list1 {
        [] => "empty",
        [x] => "single",
        [head, ..tail] => "multiple",
    };
    assert(result1 == "multiple", "Array [1,2,3,4] → 'multiple'");
    
    // Single element
    let result2 = match list2 {
        [] => "empty",
        [x] => "single",
        _ => "multiple",
    };
    assert(result2 == "single", "Array [10] → 'single'");
    
    println("✓ Array matching çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 8: Guard Expressions (check patterns)
// ══════════════════════════════════════════════════════════════════════════════

fn test_guard_expressions() {
    println("TEST: Guard expressions...");
    
    let num = 15;
    
    let category = match num {
        x check x < 0 => "negative",
        x check x == 0 => "zero",
        x check x < 10 => "small",
        x check x < 100 => "medium",
        _ => "large",
    };
    
    assert(category == "medium", "15 → 'medium' olmalı");
    
    // Multiple conditions
    let point = (5, 5);
    let quadrant = match point {
        (x, y) check x > 0 && y > 0 => "I",
        (x, y) check x < 0 && y > 0 => "II",
        (x, y) check x < 0 && y < 0 => "III",
        (x, y) check x > 0 && y < 0 => "IV",
        _ => "origin/axis",
    };
    assert(quadrant == "I", "(5,5) birinci kadran");
    
    println("✓ Guard expressions çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 9: Or Patterns (|)
// ══════════════════════════════════════════════════════════════════════════════

fn test_or_patterns() {
    println("TEST: Or patterns...");
    
    let value = 3;
    
    let result = match value {
        1 | 3 | 5 | 7 | 9 => "odd single digit",
        0 | 2 | 4 | 6 | 8 => "even single digit",
        _ => "other",
    };
    
    assert(result == "odd single digit", "3 → 'odd single digit'");
    
    // Color matching
    let color = Color::RGB(255, 0, 0);
    let name = match color {
        Color::RGB(255, 0, 0) | Color::Named("red".into()) => "red",
        Color::RGB(0, 255, 0) | Color::Named("green".into()) => "green",
        Color::RGB(0, 0, 255) | Color::Named("blue".into()) => "blue",
        _ => "other",
    };
    assert(name == "red", "RGB(255,0,0) → 'red'");
    
    println("✓ Or patterns çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 10: Wildcard & Rest Patterns
// ══════════════════════════════════════════════════════════════════════════════

fn test_wildcard_patterns() {
    println("TEST: Wildcard ve rest patterns...");
    
    // Wildcard _
    let x = 42;
    let result = match x {
        0 => "zero",
        _ => "non-zero",
    };
    assert(result == "non-zero", "_ wildcard çalışmalı");
    
    // Rest pattern ..
    let tuple = (1, 2, 3, 4, 5);
    let sum = match tuple {
        (first, ..rest) => first,  // rest = (2,3,4,5)
    };
    assert(sum == 1, "First element = 1");
    
    // Record rest pattern
    let rect = Shape::Rectangle { width: 10.0, height: 20.0 };
    let w = match rect {
        Shape::Rectangle { width, .. } => width,
        _ => 0.0,
    };
    assert(w == 10.0, "Width extraction çalışmalı");
    
    println("✓ Wildcard/rest patterns çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 11: Exhaustiveness Check
// ══════════════════════════════════════════════════════════════════════════════

fn test_exhaustiveness() {
    println("TEST: Exhaustiveness checking...");
    
    // Compiler tüm durumları kontrol etmeli
    let opt: Option<i64> = Option::Some(5);
    
    // Bu match exhaustive (tam)
    let val = match opt {
        Option::Some(x) => x,
        Option::None => 0,
    };
    
    // Eğer None case eksik olsaydı compiler hata vermeli:
    // let incomplete = match opt {
    //     Option::Some(x) => x,
    // };  // COMPILE ERROR: non-exhaustive patterns
    
    println("✓ Exhaustiveness checking çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// MAIN - Tüm Testleri Çalıştır
// ══════════════════════════════════════════════════════════════════════════════

fn main() {
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  NOVA PATTERN MATCHING TEST SUITE                            ║");
    println("╚══════════════════════════════════════════════════════════════╝");
    println("");
    
    test_basic_match();
    test_option_matching();
    test_result_matching();
    test_tuple_matching();
    test_record_matching();
    test_nested_matching();
    test_array_matching();
    test_guard_expressions();
    test_or_patterns();
    test_wildcard_patterns();
    test_exhaustiveness();
    
    println("");
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  ✓ TÜM PATTERN MATCHING TESTLERİ BAŞARILI                    ║");
    println("╚══════════════════════════════════════════════════════════════╝");
}
