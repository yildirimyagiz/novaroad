use std::io::println;

// ══════════════════════════════════════════════════════════════════════════════
// TEST 1: Birimli Literal Parsing
// ══════════════════════════════════════════════════════════════════════════════

fn test_unit_literals() {
    println("TEST: Birimli literal parsing...");
    
    // Kütle birimleri
    let mass_kg: qty<f64, kg> = 5.kg;
    let mass_g: qty<f64, g> = 1000.g;
    let mass_lb: qty<f64, lb> = 2.2.lb;
    
    // Uzunluk birimleri
    let length_m: qty<f64, m> = 10.m;
    let length_cm: qty<f64, cm> = 100.cm;
    let length_km: qty<f64, km> = 0.01.km;
    
    // Zaman birimleri
    let time_s: qty<f64, s> = 60.s;
    let time_min: qty<f64, min> = 1.min;
    let time_h: qty<f64, h> = 0.0166.h;
    
    println("✓ Birimli literaller parse edildi");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 2: Bileşik Birimler
// ══════════════════════════════════════════════════════════════════════════════

fn test_compound_units() {
    println("TEST: Bileşik birimler...");
    
    // Hız: m/s
    let velocity: qty<f64, m/s> = 9.81.m/s;
    
    // İvme: m/s²
    let gravity: qty<f64, m/s²> = 9.81.m/s²;
    
    // Kuvvet: kg·m/s² (Newton)
    let force: qty<f64, kg·m/s²> = 100.kg·m/s²;
    
    // Enerji: kg·m²/s² (Joule)
    let energy: qty<f64, kg·m²/s²> = 500.kg·m²/s²;
    
    // Güç: kg·m²/s³ (Watt)
    let power: qty<f64, kg·m²/s³> = 75.kg·m²/s³;
    
    println("✓ Bileşik birimler doğru parse edildi");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 3: Unicode Birimler
// ══════════════════════════════════════════════════════════════════════════════

fn test_unicode_units() {
    println("TEST: Unicode birimler...");
    
    // Sıcaklık: °C, °F, K
    let temp_celsius: qty<f64, °C> = 25.°C;
    let temp_fahrenheit: qty<f64, °F> = 77.°F;
    let temp_kelvin: qty<f64, K> = 298.15.K;
    
    // Elektriksel birimler
    let resistance: qty<f64, Ω> = 100.Ω;    // Ohm
    let length_angstrom: qty<f64, Å> = 10.Å; // Angstrom
    let current_micro: qty<f64, μA> = 50.μA; // MicroAmpere
    
    println("✓ Unicode birimler destekleniyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 4: Birim Dönüşümü
// ══════════════════════════════════════════════════════════════════════════════

fn test_unit_conversion() {
    println("TEST: Birim dönüşümü...");
    
    // kg → g dönüşümü
    let mass_kg: qty<f64, kg> = 5.kg;
    let mass_g = mass_kg in g;  // 5000.g olmalı
    assert(mass_g == 5000.g, "5kg = 5000g olmalı");
    
    // km → m dönüşümü
    let dist_km: qty<f64, km> = 2.5.km;
    let dist_m = dist_km in m;   // 2500.m olmalı
    assert(dist_m == 2500.m, "2.5km = 2500m olmalı");
    
    // °C → K dönüşümü
    let temp_c: qty<f64, °C> = 25.°C;
    let temp_k = temp_c in K;    // 298.15.K olmalı
    assert(temp_k ~ 298.15.K, "25°C ≈ 298.15K olmalı");
    
    println("✓ Birim dönüşümleri çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 5: Birim Aritmetiği
// ══════════════════════════════════════════════════════════════════════════════

fn test_unit_arithmetic() {
    println("TEST: Birim aritmetiği...");
    
    // Aynı birimde toplama
    let m1: qty<f64, kg> = 5.kg;
    let m2: qty<f64, kg> = 3.kg;
    let total = m1 + m2;
    assert(total == 8.kg, "5kg + 3kg = 8kg olmalı");
    
    // Farklı birimde toplama (otomatik dönüşüm)
    let m3: qty<f64, g> = 1000.g;
    let sum = m1 + m3;  // 5kg + 1000g = 6kg
    assert(sum == 6.kg, "5kg + 1000g = 6kg olmalı");
    
    // Çarpma: kütle × ivme = kuvvet
    let mass: qty<f64, kg> = 10.kg;
    let accel: qty<f64, m/s²> = 9.81.m/s²;
    let force: qty<f64, kg·m/s²> = mass * accel;
    assert(force ~ 98.1.kg·m/s², "F = m × a");
    
    // Bölme: mesafe ÷ zaman = hız
    let distance: qty<f64, m> = 100.m;
    let time: qty<f64, s> = 10.s;
    let speed: qty<f64, m/s> = distance / time;
    assert(speed == 10.m/s, "v = d / t");
    
    println("✓ Birimli aritmetik işlemler doğru");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 6: Birim Ailesi Tanımı
// ══════════════════════════════════════════════════════════════════════════════

fn test_unit_family_definition() {
    println("TEST: Birim ailesi tanımı...");
    
    // Kütle birimi ailesi
    unit Mass = kg | g | lb | oz;
    
    // Uzunluk birimi ailesi
    unit Length = m | cm | km | inch | foot | mile;
    
    // Sıcaklık birimi ailesi
    unit Temperature = K | °C | °F;
    
    // Zaman birimi ailesi
    unit Time = s | min | h | day;
    
    println("✓ Birim aileleri tanımlandı");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 7: Boyut Analizi (Dimensional Analysis)
// ══════════════════════════════════════════════════════════════════════════════

fn test_dimensional_analysis() {
    println("TEST: Boyut analizi...");
    
    // Kuvvet boyutu: [M L T⁻²]
    dims Force = Mass · Length · Time^(-2);
    
    // Enerji boyutu: [M L² T⁻²]
    dims Energy = Mass · Length^2 · Time^(-2);
    
    // Güç boyutu: [M L² T⁻³]
    dims Power = Mass · Length^2 · Time^(-3);
    
    // Hız boyutu: [L T⁻¹]
    dims Velocity = Length · Time^(-1);
    
    println("✓ Boyut analizi tanımları oluşturuldu");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 8: Fizik Hesaplamaları
// ══════════════════════════════════════════════════════════════════════════════

fn test_physics_calculations() {
    println("TEST: Fizik hesaplamaları...");
    
    // Kinetik enerji: KE = 1/2 × m × v²
    let mass: qty<f64, kg> = 2.kg;
    let velocity: qty<f64, m/s> = 10.m/s;
    let kinetic_energy = 0.5 * mass * (velocity ** 2);
    assert(kinetic_energy == 100.kg·m²/s², "KE = 1/2 m v²");
    
    // Potansiyel enerji: PE = m × g × h
    let height: qty<f64, m> = 5.m;
    let g: qty<f64, m/s²> = 9.81.m/s²;
    let potential_energy = mass * g * height;
    assert(potential_energy ~ 98.1.kg·m²/s², "PE = m g h");
    
    // İş-enerji teoremi: W = F × d
    let force: qty<f64, kg·m/s²> = 50.kg·m/s²;
    let distance: qty<f64, m> = 3.m;
    let work = force * distance;
    assert(work == 150.kg·m²/s², "W = F × d");
    
    println("✓ Fizik hesaplamaları doğru");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 9: Elektriksel Birimler
// ══════════════════════════════════════════════════════════════════════════════

fn test_electrical_units() {
    println("TEST: Elektriksel birimler...");
    
    // Ohm yasası: V = I × R
    let current: qty<f64, A> = 2.A;
    let resistance: qty<f64, Ω> = 100.Ω;
    let voltage = current * resistance;
    assert(voltage == 200.V, "V = I × R");
    
    // Güç: P = V × I
    let power = voltage * current;
    assert(power == 400.W, "P = V × I");
    
    // Enerji: E = P × t
    let time: qty<f64, s> = 3600.s;
    let energy = power * time;
    assert(energy == 1440000.J, "E = P × t");
    
    println("✓ Elektriksel hesaplamalar doğru");
}

// ══════════════════════════════════════════════════════════════════════════════
