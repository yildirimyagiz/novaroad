// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  NOVA YIELD/RETURN TEST SUITE                                                ║
// ║  Yield keyword, early returns, control flow                                 ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use std::io::println;

// ══════════════════════════════════════════════════════════════════════════════
// TEST 1: Basic Yield
// ══════════════════════════════════════════════════════════════════════════════

fn simple_yield() -> i64 {
    yield 42;
}

fn test_basic_yield() {
    println("TEST: Basic yield...");
    
    let result = simple_yield();
    assert(result == 42, "Yield 42 dönmeli");
    
    println("✓ Basic yield çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 2: Early Return with Yield
// ══════════════════════════════════════════════════════════════════════════════

fn early_return(x: i64) -> String {
    check x < 0 {
        yield "negative".into();
    }
    check x == 0 {
        yield "zero".into();
    }
    yield "positive".into();
}

fn test_early_return() {
    println("TEST: Early yield with yield...");
    
    assert(early_return(-5) == "negative", "Negative case");
    assert(early_return(0) == "zero", "Zero case");
    assert(early_return(10) == "positive", "Positive case");
    
    println("✓ Early yield çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 3: Yield in Loops
// ══════════════════════════════════════════════════════════════════════════════

fn find_first_even(arr: [i64]) -> Option<i64> {
    var i = 0;
    while i < arr.len() {
        check arr[i] % 2 == 0 {
            yield Option::Some(arr[i]);
        }
        i = i + 1;
    }
    yield Option::None;
}

fn test_yield_in_loops() {
    println("TEST: Yield in loops...");
    
    let data = [1, 3, 7, 8, 9];
    match find_first_even(data) {
        Option::Some(v) => assert(v == 8, "İlk çift sayı 8"),
        Option::None => assert(false, "Çift sayı bulunmalıydı"),
    }
    
    let odd_only = [1, 3, 5, 7];
    match find_first_even(odd_only) {
        Option::Some(_) => assert(false, "Çift sayı olmamalı"),
        Option::None => assert(true, "None dönmeli"),
    }
    
    println("✓ Yield in loops çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 4: Multiple Yields
// ══════════════════════════════════════════════════════════════════════════════

fn categorize(x: i64) -> String {
    check x < 0 { yield "negative".into(); }
    check x == 0 { yield "zero".into(); }
    check x < 10 { yield "small".into(); }
    check x < 100 { yield "medium".into(); }
    yield "large".into();
}

fn test_multiple_yields() {
    println("TEST: Multiple yields...");
    
    assert(categorize(-5) == "negative", "-5 → negative");
    assert(categorize(0) == "zero", "0 → zero");
    assert(categorize(5) == "small", "5 → small");
    assert(categorize(50) == "medium", "50 → medium");
    assert(categorize(500) == "large", "500 → large");
    
    println("✓ Multiple yields çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST 5: Yield with Match
// ══════════════════════════════════════════════════════════════════════════════

cases Status {
    Success,
    Error(String),
    Pending,
}

fn process_status(s: Status) -> i64 {
    match s {
        Status::Success => yield 1,
        Status::Error(_) => yield -1,
        Status::Pending => yield 0,
    }
}

fn test_yield_with_match() {
    println("TEST: Yield with match...");
    
    assert(process_status(Status::Success) == 1, "Success → 1");
    assert(process_status(Status::Error("fail".into())) == -1, "Error → -1");
    assert(process_status(Status::Pending) == 0, "Pending → 0");
    
    println("✓ Yield with match çalışıyor");
}

// ══════════════════════════════════════════════════════════════════════════════
// MAIN
// ══════════════════════════════════════════════════════════════════════════════

fn main() {
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  NOVA YIELD/RETURN TEST SUITE                                ║");
    println("╚══════════════════════════════════════════════════════════════╝");
    println("");
    
    test_basic_yield();
    test_early_return();
    test_yield_in_loops();
    test_multiple_yields();
    test_yield_with_match();
    
    println("");
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║  ✓ TÜM YIELD/RETURN TESTLERİ BAŞARILI                        ║");
    println("╚══════════════════════════════════════════════════════════════╝");
}
