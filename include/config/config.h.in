/**
 * @file config.h
 * @brief Nova compile-time configuration (generated by CMake)
 * @note This is a CMake template file (.in) - clang diagnostics about #cmakedefine are expected and can be ignored
 */

#ifndef NOVA_CONFIG_H
#define NOVA_CONFIG_H

#define NOVA_VERSION_MAJOR @NOVA_VERSION_MAJOR@
#define NOVA_VERSION_MINOR @NOVA_VERSION_MINOR@
#define NOVA_VERSION_PATCH @NOVA_VERSION_PATCH@

/* Architecture */
#cmakedefine NOVA_ARCH "@NOVA_ARCH@"

/* Build options */
#cmakedefine NOVA_BUILD_KERNEL
#cmakedefine NOVA_BUILD_RUNTIME
#cmakedefine NOVA_BUILD_COMPILER
#cmakedefine NOVA_BUILD_AI
#cmakedefine NOVA_ENABLE_LTO
#cmakedefine NOVA_ENABLE_SANITIZERS

/* Platform detection */
#ifdef __linux__
    #define NOVA_PLATFORM_LINUX 1
    #define NOVA_PLATFORM_POSIX 1
    #define NOVA_PLATFORM_NAME "linux"
#elif defined(__APPLE__)
    #define NOVA_PLATFORM_MACOS 1
    #define NOVA_PLATFORM_POSIX 1
    #define NOVA_PLATFORM_NAME "macos"
    #if TARGET_OS_IPHONE || TARGET_IPHONE_SIMULATOR
        #define NOVA_PLATFORM_IOS 1
        #undef NOVA_PLATFORM_NAME
        #define NOVA_PLATFORM_NAME "ios"
    #elif TARGET_OS_MAC
        #define NOVA_PLATFORM_MACOS 1
    #endif
#elif defined(_WIN32) || defined(_WIN64)
    #define NOVA_PLATFORM_WINDOWS 1
    #define NOVA_PLATFORM_NAME "windows"
#elif defined(__ANDROID__)
    #define NOVA_PLATFORM_ANDROID 1
    #define NOVA_PLATFORM_POSIX 1
    #define NOVA_PLATFORM_NAME "android"
#elif defined(__wasm__) || defined(__EMSCRIPTEN__)
    #define NOVA_PLATFORM_WASM 1
    #define NOVA_PLATFORM_WEB 1
    #define NOVA_PLATFORM_NAME "wasm"
#elif defined(__FreeBSD__)
    #define NOVA_PLATFORM_FREEBSD 1
    #define NOVA_PLATFORM_POSIX 1
    #define NOVA_PLATFORM_NAME "freebsd"
#else
    #define NOVA_PLATFORM_UNKNOWN 1
    #define NOVA_PLATFORM_NAME "unknown"
#endif

/* Mobile platforms */
#if defined(NOVA_PLATFORM_IOS) || defined(NOVA_PLATFORM_ANDROID)
    #define NOVA_PLATFORM_MOBILE 1
#endif

/* Desktop platforms */
#if defined(NOVA_PLATFORM_LINUX) || defined(NOVA_PLATFORM_MACOS) || defined(NOVA_PLATFORM_WINDOWS) || defined(NOVA_PLATFORM_FREEBSD)
    #define NOVA_PLATFORM_DESKTOP 1
#endif

/* Web platform */
#if defined(NOVA_PLATFORM_WASM) || defined(NOVA_PLATFORM_WEB)
    #define NOVA_PLATFORM_WEB 1
#endif

/* Compiler detection */
#ifdef __clang__
    #define NOVA_COMPILER_CLANG 1
#elif defined(__GNUC__)
    #define NOVA_COMPILER_GCC 1
#elif defined(_MSC_VER)
    #define NOVA_COMPILER_MSVC 1
#endif

/* Architecture specific */
#if defined(__x86_64__) || defined(_M_X64)
    #define NOVA_ARCH_X86_64 1
#elif defined(__aarch64__) || defined(_M_ARM64)
    #define NOVA_ARCH_AARCH64 1
#elif defined(__riscv) && (__riscv_xlen == 64)
    #define NOVA_ARCH_RISCV64 1
#endif

/* Visibility macros */
#if defined(_WIN32)
    #define NOVA_EXPORT __declspec(dllexport)
    #define NOVA_IMPORT __declspec(dllimport)
#else
    #define NOVA_EXPORT __attribute__((visibility("default")))
    #define NOVA_IMPORT
#endif

#ifdef NOVA_BUILD_SHARED
    #define NOVA_API NOVA_EXPORT
#else
    #define NOVA_API NOVA_IMPORT
#endif

#endif /* NOVA_CONFIG_H */
