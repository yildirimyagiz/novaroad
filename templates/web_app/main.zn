// Nova Web Application Template
// Simple HTTP server with routing

use web::server::Server;
use web::router::Router;
use web::response::Response;

fn handle_home(req: Request) -> Response {
    yield Response::html("
        <h1>Welcome to Nova Web App!</h1>
        <p>Built with Nova Language</p>
    ");
}

fn handle_api(req: Request) -> Response {
    yield Response::json({
        "message": "Hello from Nova API",
        "version": "1.0.0"
    });
}

fn main() -> i32 {
    let var router = Router::new();
    
    router.get("/", handle_home);
    router.get("/api", handle_api);
    
    let server = Server::new("0.0.0.0:8080");
    server.serve(router);
    
    println("🚀 Server running on http://localhost:8080");
    
    yield 0;
}
