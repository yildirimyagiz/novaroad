// Nova AI Project Template
// Neural network training

use nn::{Network, Layer, Optimizer};
use data::Dataset;

fn create_model() -> Network {
    let var model = Network::new();
    
    model.add(Layer::dense(784, 128));
    model.add(Layer::relu());
    model.add(Layer::dense(128, 10));
    model.add(Layer::softmax());
    
    yield model;
}

fn train_model(model: Network, dataset: Dataset) -> Network {
    let optimizer = Optimizer::adam(0.001);
    
    for epoch in 0..10 {
        let var total_loss = 0.0;
        
        for batch in dataset.batches(32) {
            let (x, y) = batch;
            
            // Forward pass
            let pred = model.forward(x);
            let loss = cross_entropy_loss(pred, y);
            
            // Backward pass
            model.backward(loss);
            optimizer.step();
            
            total_loss += loss;
        }
        
        println("Epoch {}: loss = {}", epoch, total_loss);
    }
    
    yield model;
}

fn main() -> i32 {
    println("🤖 Training Neural Network");
    
    let dataset = Dataset::load("data/mnist.csv");
    let model = create_model();
    let trained = train_model(model, dataset);
    
    trained.save("model.nova");
    
    println("✅ Model trained and saved!");
    
    yield 0;
}
