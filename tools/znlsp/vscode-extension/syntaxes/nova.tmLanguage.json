{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Nova",
  "scopeName": "source.nova",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#types" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nova",
          "match": "//.*$"
        },
        {
          "name": "comment.block.nova",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nova",
          "match": "\\b(if|else|for|while|loop|break|continue|return|match|case)\\b"
        },
        {
          "name": "keyword.declaration.nova",
          "match": "\\b(fn|let|const|var|struct|enum|impl|trait|type|use|import|export|module)\\b"
        },
        {
          "name": "keyword.other.nova",
          "match": "\\b(async|await|defer|yield|pub|priv|mut|ref|move|static|extern)\\b"
        },
        {
          "name": "constant.language.nova",
          "match": "\\b(true|false|null|nil|self|Self|super)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nova",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nova",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.nova",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.nova",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.nova",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.hex.nova",
          "match": "\\b0x[0-9a-fA-F_]+\\b"
        },
        {
          "name": "constant.numeric.binary.nova",
          "match": "\\b0b[01_]+\\b"
        },
        {
          "name": "constant.numeric.octal.nova",
          "match": "\\b0o[0-7_]+\\b"
        },
        {
          "name": "constant.numeric.integer.nova",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.nova",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        },
        {
          "name": "support.function.builtin.nova",
          "match": "\\b(println|print|assert|panic|dbg)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.primitive.nova",
          "match": "\\b(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|f32|f64|bool|char|str|String)\\b"
        },
        {
          "name": "storage.type.collection.nova",
          "match": "\\b(Vec|HashMap|HashSet|BTreeMap|BTreeSet|Option|Result)\\b"
        },
        {
          "name": "entity.name.type.nova",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.nova",
          "match": "[+\\-*/%]"
        },
        {
          "name": "keyword.operator.comparison.nova",
          "match": "(==|!=|<|>|<=|>=)"
        },
        {
          "name": "keyword.operator.logical.nova",
          "match": "(&&|\\|\\||!)"
        },
        {
          "name": "keyword.operator.assignment.nova",
          "match": "(=|\\+=|-=|\\*=|/=|%=)"
        },
        {
          "name": "keyword.operator.arrow.nova",
          "match": "(->|=>)"
        }
      ]
    }
  }
}
