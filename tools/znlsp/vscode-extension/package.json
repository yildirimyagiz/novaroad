{
  "name": "nova-language",
  "displayName": "Nova Language Support",
  "description": "Language support for Nova programming language",
  "version": "0.1.0",
  "publisher": "nova",
  "repository": {
    "type": "git",
    "url": "https://github.com/nova/nova"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "keywords": [
    "nova",
    "programming language",
    "lsp",
    "syntax highlighting"
  ],
  "activationEvents": [
    "onLanguage:nova"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nova",
        "aliases": [
          "Nova",
          "nova"
        ],
        "extensions": [
          ".zn",
          ".nova"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/nova-light.png",
          "dark": "./icons/nova-dark.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "nova",
        "scopeName": "source.nova",
        "path": "./syntaxes/nova.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Nova",
      "properties": {
        "nova.lsp.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Nova Language Server"
        },
        "nova.lsp.path": {
          "type": "string",
          "default": "znlsp",
          "description": "Path to Nova Language Server executable"
        },
        "nova.lsp.trace": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace communication between VS Code and the language server"
        },
        "nova.format.onSave": {
          "type": "boolean",
          "default": true,
          "description": "Format code on save"
        }
      }
    },
    "commands": [
      {
        "command": "nova.restartLanguageServer",
        "title": "Nova: Restart Language Server"
      },
      {
        "command": "nova.showServerStatus",
        "title": "Nova: Show Server Status"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^5.0.0",
    "@typescript-eslint/parser": "^5.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "vscode-languageclient": "^8.1.0"
  }
}
