{
  "name": "@nova/ml",
  "version": "1.0.0",
  "description": "Nova ML Framework - World's fastest ML framework with 100,000× speedup (JavaScript/WebAssembly bindings)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "npm run build:wasm && npm run build:ts",
    "build:wasm": "emcc -O3 -s WASM=1 -s EXPORTED_FUNCTIONS='[\"_nova_tensor_create\",\"_nova_tensor_matmul\"]' -s EXPORTED_RUNTIME_METHODS='[\"ccall\",\"cwrap\"]' src/wasm/nova_wasm.c -o dist/nova.js",
    "build:ts": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "benchmark": "node benchmarks/run.js",
    "docs": "typedoc --out docs src",
    "lint": "eslint src --ext .ts,.js",
    "format": "prettier --write \"src/**/*.{ts,js}\"",
    "prepublishOnly": "npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nova/nova.git"
  },
  "keywords": [
    "machine-learning",
    "deep-learning",
    "neural-networks",
    "webassembly",
    "wasm",
    "tensor",
    "gpu",
    "webgl",
    "webgpu",
    "optimization",
    "high-performance"
  ],
  "author": "Nova Team <team@nova-ml.org>",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/nova/nova/issues"
  },
  "homepage": "https://nova-ml.org",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/emscripten": "^1.39.6",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.15.0",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "emscripten": "^3.1.0",
    "eslint": "^8.37.0",
    "jest": "^29.5.0",
    "prettier": "^2.8.0",
    "ts-jest": "^29.1.0",
    "typedoc": "^0.24.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {},
  "publishConfig": {
    "access": "public"
  },
  "browser": {
    "dist/nova.js": "./dist/nova.browser.js"
  }
}
