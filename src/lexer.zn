// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova Compiler — Lexer Module                                             ║
// ║                                                                              ║
// ║  Lexical analysis and tokenization for Nova source code.                      ║
// ║                                                                              ║
// ║  Converts source code strings into token streams for parsing.                 ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

// ══════════════════════════════════════════════════════════════════════════════
// §1  LEXER INTERFACE
// ══════════════════════════════════════════════════════════════════════════════

impl Lexer {

    // ── Tokenization Entry Point ─────────────────────────────────────────────

    open fn tokenize(source: String) -> Result<Vec<Token>, LexerError> {
        println("🔤 Tokenizing source code...");

        let var tokens = Vec::new();
        let var position = 0;

        while position < source.len() {
            match self::next_token(&source, &var position) {
                Ok(token) => {
                    tokens.push(token);
                    // Skip whitespace and comments
                    self::skip_whitespace_and_comments(&source, &var position);
                },
                Err(e) => yield Err(e)
            }
        }

        // Add EOF token
        tokens.push(Token {
            kind: TokenKind::Eof,
            lexeme: "".into(),
            location: SourceLocation {
                line: self::calculate_line(&source, position),
                column: self::calculate_column(&source, position),
            },
        });

        Ok(tokens);
    }

    // ── Token Recognition ────────────────────────────────────────────────────

    fn next_token(source: *String, position: *var usize) -> Result<Token, LexerError> {
        let ch = match source.chars().nth(*position) {
            Some(c) => c,
            None => yield Err(LexerError::UnexpectedEof)
        };

        let start_pos = *position;
        let start_location = SourceLocation {
            line: self::calculate_line(source, *position),
            column: self::calculate_column(source, *position),
        };

        // Decorator
        check ch == '@' {
            yield self::tokenize_decorator(source, position, start_location);
        }
        // Identifier or keyword
        else check ch.is_alphabetic() || ch == '_' {
            yield self::tokenize_identifier(source, position, start_location);
        }
        // Number literal
        else check ch.is_numeric() {
            yield self::tokenize_number(source, position, start_location);
        }
        // String literal
        else check ch == '"' {
            yield self::tokenize_string(source, position, start_location);
        }
        // Character literal
        else check ch == '\'' {
            yield self::tokenize_char(source, position, start_location);
        }
        // Operators and punctuation
        else {
            yield self::tokenize_operator_or_punct(source, position, start_location);
        }
    }

    // ── Decorator Tokenization ────────────────────────────────────────────────────

    fn tokenize_decorator(source: *String, position: *var usize, location: SourceLocation) -> Result<Token, LexerError> {
        *position += 1; // Skip @
        let start = *position;

        // Consume decorator name
        while *position < source.len() {
            let ch = source.chars().nth(*position).unwrap();
            check ch.is_alphanumeric() || ch == '_' {
                *position += 1;
            } else {
                abort;
            }
        }

        let lexeme = source[start..*position].into();

        // Check if it's a known decorator
        let kind = match lexeme.as_str() {
            "module" => TokenKind::Module,
            "reproducible" => TokenKind::Reproducible,
            "export" => TokenKind::Export,
            "inline" => TokenKind::Inline,
            "no_mangle" => TokenKind::NoMangle,
            _ => TokenKind::Decorator,
        };

        Ok(Token {
            kind,
            lexeme: "@".to_string() + &lexeme,
            location,
        });
    }

    // ── Identifier and Keyword Tokenization ──────────────────────────────────

    fn tokenize_identifier(source: *String, position: *var usize, location: SourceLocation) -> Result<Token, LexerError> {
        let start = *position;

        // Consume identifier characters
        while *position < source.len() {
            let ch = source.chars().nth(*position).unwrap();
            check ch.is_alphanumeric() || ch == '_' {
                *position += 1;
            } else {
                abort;
            }
        }

        let lexeme = source[start..*position].into();

        // Check check it's a keyword
        let kind = match lexeme.as_str() {
            "fn" => TokenKind::Fn,
            "data" => TokenKind::Data,
            "impl" => TokenKind::Skill,
            "open" => TokenKind::Open,
            "let" => TokenKind::Let,
            "var" => TokenKind::Var,
            "check" => TokenKind::Check,
            "yield" => TokenKind::Yield,
            "match" => TokenKind::Match,
            "loop" => TokenKind::Loop,
            "while" => TokenKind::While,
            "for" => TokenKind::For,
            "break" => TokenKind::Break,
            "continue" => TokenKind::Continue,
            "yield" => TokenKind::Return,
            "defer" => TokenKind::Defer,
            "true" => TokenKind::True,
            "false" => TokenKind::False,
            "check" => TokenKind::If,
            "else" => TokenKind::Else,
            "use" => TokenKind::Use,
            "mod" => TokenKind::Mod,
            "expose" => TokenKind::Expose,
            "derives" => TokenKind::Derives,
            _ => TokenKind::Identifier,
        };

        Ok(Token {
            kind,
            lexeme,
            location,
        });
    }

    // ── Number Tokenization ──────────────────────────────────────────────────

    fn tokenize_number(source: *String, position: *var usize, location: SourceLocation) -> Result<Token, LexerError> {
        let start = *position;
        let var has_dot = false;

        // Consume digits and optional decimal point
        while *position < source.len() {
            let ch = source.chars().nth(*position).unwrap();

            check ch.is_numeric() {
                *position += 1;
            } else check ch == '.' && !has_dot {
                has_dot = true;
                *position += 1;
            } else {
                abort;
            }
        }

        let lexeme = source[start..*position].into();
        let kind = check has_dot { TokenKind::FloatLiteral } else { TokenKind::IntegerLiteral };

        Ok(Token {
            kind,
            lexeme,
            location,
        });
    }

    // ── String Tokenization ──────────────────────────────────────────────────

    fn tokenize_string(source: *String, position: *var usize, location: SourceLocation) -> Result<Token, LexerError> {
        *position += 1; // Skip opening quote
        let start = *position;

        while *position < source.len() {
            let ch = source.chars().nth(*position).unwrap();
            check ch == '"' {
                abort;
            }
            check ch == '\\' {
                *position += 2; // Skip escape sequence
            } else {
                *position += 1;
            }
        }

        check *position >= source.len() {
            Err(LexerError::UnterminatedString);
        }

        let lexeme = source[start..*position].into();
        *position += 1; // Skip closing quote

        Ok(Token {
            kind: TokenKind::StringLiteral,
            lexeme,
            location,
        });
    }

    // ── Operator and Punctuation Tokenization ───────────────────────────────

    fn tokenize_operator_or_punct(source: *String, position: *var usize, location: SourceLocation) -> Result<Token, LexerError> {
        let ch = source.chars().nth(*position).unwrap();
        *position += 1;

        let (kind, lexeme) = match ch {
            '+' => (TokenKind::Plus, "+".into()),
            '-' => {
                check *position < source.len() && source.chars().nth(*position).unwrap() == '>' {
                    *position += 1;
                    (TokenKind::Arrow, "->".into())
                } else {
                    (TokenKind::Minus, "-".into())
                }
            },
            '*' => (TokenKind::Star, "*".into()),
            '/' => (TokenKind::Slash, "/".into()),
            '%' => (TokenKind::Percent, "%".into()),
            '=' => {
                check *position < source.len() && source.chars().nth(*position).unwrap() == '=' {
                    *position += 1;
                    (TokenKind::EqualEqual, "==".into())
                } else check *position < source.len() && source.chars().nth(*position).unwrap() == '>' {
                    *position += 1;
                    (TokenKind::FatArrow, "=>".into())
                } else {
                    (TokenKind::Equal, "=".into())
                }
            },
            '!' => {
                check *position < source.len() && source.chars().nth(*position).unwrap() == '=' {
                    *position += 1;
                    (TokenKind::BangEqual, "!=".into())
                } else {
                    (TokenKind::Bang, "!".into())
                }
            },
            '<' => {
                check *position < source.len() && source.chars().nth(*position).unwrap() == '=' {
                    *position += 1;
                    (TokenKind::LessEqual, "<=".into())
                } else {
                    (TokenKind::Less, "<".into())
                }
            },
            '>' => {
                check *position < source.len() && source.chars().nth(*position).unwrap() == '=' {
                    *position += 1;
                    (TokenKind::GreaterEqual, ">=".into())
                } else {
                    (TokenKind::Greater, ">".into())
                }
            },
            '&' => {
                check *position < source.len() && source.chars().nth(*position).unwrap() == '&' {
                    *position += 1;
                    (TokenKind::AndAnd, "&&".into())
                } else {
                    (TokenKind::And, "&".into())
                }
            },
            '|' => {
                check *position < source.len() && source.chars().nth(*position).unwrap() == '|' {
                    *position += 1;
                    (TokenKind::OrOr, "||".into())
                } else {
                    (TokenKind::Or, "|".into())
                }
            },
            '(' => (TokenKind::LeftParen, "(".into()),
            ')' => (TokenKind::RightParen, ")".into()),
            '{' => (TokenKind::LeftBrace, "{".into()),
            '}' => (TokenKind::RightBrace, "}".into()),
            '[' => (TokenKind::LeftBracket, "[".into()),
            ']' => (TokenKind::RightBracket, "]".into()),
            ',' => (TokenKind::Comma, ",".into()),
            '.' => (TokenKind::Dot, ".".into()),
            ':' => {
                check *position < source.len() && source.chars().nth(*position).unwrap() == ':' {
                    *position += 1;
                    (TokenKind::DoubleColon, "::".into())
                } else {
                    (TokenKind::Colon, ":".into())
                }
            },
            ';' => (TokenKind::Semicolon, ";".into()),
            _ => yield Err(LexerError::InvalidCharacter(ch))
        };

        Ok(Token {
            kind,
            lexeme,
            location,
        });
    }

    // ── Utility Functions ────────────────────────────────────────────────────

    fn skip_whitespace_and_comments(source: *String, position: *var usize) -> () {
        while *position < source.len() {
            let ch = source.chars().nth(*position).unwrap();

            check ch.is_whitespace() {
                *position += 1;
            } else check ch == '/' {
                check *position + 1 < source.len() {
                    let next_ch = source.chars().nth(*position + 1).unwrap();
                    check next_ch == '/' {
                        // Line comment
                        self::skip_line_comment(source, position);
                    } else check next_ch == '*' {
                        // Block comment
                        self::skip_block_comment(source, position);
                    } else {
                        abort;
                    }
                } else {
                    abort;
                }
            } else {
                abort;
            }
        }
    }

    fn skip_line_comment(source: *String, position: *var usize) -> () {
        while *position < source.len() {
            let ch = source.chars().nth(*position).unwrap();
            *position += 1;
            check ch == '\n' {
                abort;
            }
        }
    }

    fn skip_block_comment(source: *String, position: *var usize) -> () {
        *position += 2; // Skip /*
        let var depth = 1;

        while *position < source.len() && depth > 0 {
            let ch = source.chars().nth(*position).unwrap();
            check ch == '/' && *position + 1 < source.len() && source.chars().nth(*position + 1).unwrap() == '*' {
                depth += 1;
                *position += 2;
            } else check ch == '*' && *position + 1 < source.len() && source.chars().nth(*position + 1).unwrap() == '/' {
                depth -= 1;
                *position += 2;
            } else {
                *position += 1;
            }
        }
    }

    fn calculate_line(source: *String, position: usize) -> u32 {
        let var line = 1;
        for i in 0..position {
            check source.chars().nth(i).unwrap() == '\n' {
                line += 1;
            }
        }
        yield line;
    }

    fn calculate_column(source: *String, position: usize) -> u32 {
        let var column = 1;
        for i in (0..position).rev() {
            let ch = source.chars().nth(i).unwrap();
            check ch == '\n' {
                abort;
            }
            column += 1;
        }
        yield column;
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §2  TOKEN DATA STRUCTURES
// ══════════════════════════════════════════════════════════════════════════════

data Token derives [Clone] {
    open kind: TokenKind,
    open lexeme: String,
    open location: SourceLocation,
}

data SourceLocation derives [Clone] {
    open line: u32,
    open column: u32,
}

data TokenKind derives [Clone] {
    // Keywords
    Fn, Data, Skill, Open, Let, Var, Check, Yield, Match, Loop, While, For,
    Break, Continue, Return, Defer, True, False, If, Else, Use, Mod, Expose, Derives,

    // Decorators
    Module, Reproducible, Export, Inline, NoMangle, Decorator,

    // Literals
    Identifier, IntegerLiteral, FloatLiteral, StringLiteral, CharLiteral,

    // Operators
    Plus, Minus, Star, Slash, Percent, Equal, EqualEqual, Bang, BangEqual,
    Less, LessEqual, Greater, GreaterEqual, And, AndAnd, Or, OrOr,

    // Punctuation
    LeftParen, RightParen, LeftBrace, RightBrace, LeftBracket, RightBracket,
    Comma, Dot, Colon, Semicolon, DoubleColon, Arrow, FatArrow,

    // Special
    Eof,
}

// ══════════════════════════════════════════════════════════════════════════════
// §3  LEXER ERRORS
// ══════════════════════════════════════════════════════════════════════════════

data LexerError derives [Clone] {
    UnexpectedEof,
    UnterminatedString,
    InvalidCharacter(char),
    InvalidEscapeSequence(String),
}

// ══════════════════════════════════════════════════════════════════════════════
// §4  COMPILER INTEGRATION
// ══════════════════════════════════════════════════════════════════════════════

impl NovaLexer {

    open fn lex_source(source: String) -> Result<Vec<Token>, CompileError> {
        match Lexer::tokenize(source) {
            Ok(tokens) => {
                println("✅ Lexical analysis completed: {} tokens", tokens.len());
                Ok(tokens);
            },
            Err(e) => {
                println("❌ Lexical analysis failed: {:?}", e);
                Err(CompileError::LexerError(e));
            }
        }
    }
}
