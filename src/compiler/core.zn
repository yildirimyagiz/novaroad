// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova Compiler — Core AST and Type Definitions                           ║
// ║                                                                              ║
// ║  Fundamental AST nodes, types, and compiler infrastructure.                  ║
// ║                                                                              ║
// ║  This module provides the core data structures used throughout the          ║
// ║  compiler pipeline for representing Nova programs.                          ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

// ══════════════════════════════════════════════════════════════════════════════
// §1  CORE AST DEFINITIONS
// ══════════════════════════════════════════════════════════════════════════════

// ── Program Structure ───────────────────────────────────────────────────────

data Ast derives [Clone] {
    open declarations: Vec<Declaration>,
}

// ── Declarations ────────────────────────────────────────────────────────────

data Declaration derives [Clone] {
    Function(FunctionDecl),
    Data(DataDecl),
    Skill(SkillDecl),
    Module(ModuleDecl),
    Import(ImportDecl),
    Export(ExportDecl),
    Variable(VariableDecl),
    Let(LetDecl),
    Statement(Statement),
}

data DeclarationKind derives [Clone] {
    Function, Data, Skill, Module, Import, Export, Variable, Let, Statement,
}

data FunctionDecl derives [Clone] {
    open name: String,
    open parameters: Vec<FunctionParameter>,
    open return_type: Option<TypeExpr>,
    open body: Statement,
}

data FunctionParameter derives [Clone] {
    open name: String,
    open type_: TypeExpr,
}

data DataDecl derives [Clone] {
    open name: String,
    open derives: Vec<String>, // Trait names
    open fields: Vec<DataField>,
}

data DataField derives [Clone] {
    open name: String,
    open type_: TypeExpr,
}

data SkillDecl derives [Clone] {
    open name: String,
    open functions: Vec<SkillFunction>,
}

data SkillFunction derives [Clone] {
    open name: String,
    open parameters: Vec<FunctionParameter>,
    open return_type: Option<TypeExpr>,
    open is_open: bool,
}

data ModuleDecl derives [Clone] {
    open name: String,
    open declarations: Vec<Declaration>,
}

data ImportDecl derives [Clone] {
    open path: Vec<String>,
    open alias: Option<String>,
}

data ExportDecl derives [Clone] {
    open name: String,
    open alias: Option<String>,
}

data VariableDecl derives [Clone] {
    open name: String,
    open type_: Option<TypeExpr>,
    open initializer: Expression,
}

data LetDecl derives [Clone] {
    open name: String,
    open type_: Option<TypeExpr>,
    open initializer: Expression,
}

// ══════════════════════════════════════════════════════════════════════════════
// §2  STATEMENTS
// ══════════════════════════════════════════════════════════════════════════════

data Statement derives [Clone] {
    Variable(VariableStmt),
    Let(LetStmt),
    Expression(Expression),
    Check(CheckStmt),
    Match(MatchStmt),
    Loop(LoopStmt),
    While(WhileStmt),
    For(ForStmt),
    Yield(Expression),
    Return(Expression),
    Break,
    Continue,
    Defer(Statement),
    Block(BlockStmt),
}

data StatementKind derives [Clone] {
    Variable, Let, Expression, Check, Match, Loop, While, For,
    Yield, Return, Break, Continue, Defer, Block,
}

data VariableStmt derives [Clone] {
    open name: String,
    open type_: Option<TypeExpr>,
    open initializer: Expression,
}

data LetStmt derives [Clone] {
    open name: String,
    open type_: Option<TypeExpr>,
    open initializer: Expression,
}

data CheckStmt derives [Clone] {
    open condition: Expression,
    open then_branch: Box<Statement>,
    open else_branch: Option<Box<Statement>>,
}

data MatchStmt derives [Clone] {
    open expression: Expression,
    open arms: Vec<MatchArm>,
}

data MatchArm derives [Clone] {
    open pattern: Pattern,
    open body: Statement,
}

data LoopStmt derives [Clone] {
    open body: Statement,
}

data WhileStmt derives [Clone] {
    open condition: Expression,
    open body: Statement,
}

data ForStmt derives [Clone] {
    open iterator: String,
    open iterable: Expression,
    open body: Statement,
}

data BlockStmt derives [Clone] {
    open statements: Vec<Statement>,
}

// ══════════════════════════════════════════════════════════════════════════════
// §3  EXPRESSIONS
// ══════════════════════════════════════════════════════════════════════════════

data Expression derives [Clone] {
    Literal(Literal),
    Identifier(Identifier),
    Binary(BinaryExpr),
    Unary(UnaryExpr),
    Call(CallExpr),
    Field(FieldExpr),
    Index(IndexExpr),
    Cast(CastExpr),
    Reference(ReferenceExpr),
    Dereference(DereferenceExpr),
    Array(ArrayExpr),
    Object(ObjectExpr),
    Lambda(LambdaExpr),
    Match(MatchExpr),
    Block(Box<Statement>),
    Assignment(AssignmentExpr),
    Grouped(Box<Expression>),
}

data ExpressionKind derives [Clone] {
    Literal, Identifier, Binary, Unary, Call, Field, Index, Cast,
    Reference, Dereference, Array, Object, Lambda, Match, Block,
    Assignment, Grouped,
}

data Literal derives [Clone] {
    Bool(bool),
    Integer(i64),
    Float(f64),
    String(String),
    Char(char),
}

data Identifier derives [Clone] {
    open name: String,
}

data BinaryExpr derives [Clone] {
    open left: Box<Expression>,
    open operator: BinaryOperator,
    open right: Box<Expression>,
}

data UnaryExpr derives [Clone] {
    open operator: UnaryOperator,
    open operand: Box<Expression>,
}

data CallExpr derives [Clone] {
    open function: String,
    open arguments: Vec<Expression>,
}

data FieldExpr derives [Clone] {
    open object: Box<Expression>,
    open field: String,
}

data IndexExpr derives [Clone] {
    open array: Box<Expression>,
    open index: Box<Expression>,
}

data CastExpr derives [Clone] {
    open expression: Box<Expression>,
    open target_type: TypeExpr,
}

data ReferenceExpr derives [Clone] {
    open expression: Box<Expression>,
}

data DereferenceExpr derives [Clone] {
    open expression: Box<Expression>,
}

data ArrayExpr derives [Clone] {
    open elements: Vec<Expression>,
}

data ObjectExpr derives [Clone] {
    open type_name: String,
    open fields: Vec<ObjectField>,
}

data ObjectField derives [Clone] {
    open name: String,
    open value: Expression,
}

data LambdaExpr derives [Clone] {
    open parameters: Vec<FunctionParameter>,
    open return_type: Option<TypeExpr>,
    open body: Statement,
}

data MatchExpr derives [Clone] {
    open expression: Expression,
    open arms: Vec<MatchArm>,
}

data AssignmentExpr derives [Clone] {
    open target: Box<Expression>,
    open value: Box<Expression>,
}

data BinaryOperator derives [Clone] {
    Add, Subtract, Multiply, Divide, Modulo,
    Equal, NotEqual, Less, LessEqual, Greater, GreaterEqual,
    And, Or,
}

data UnaryOperator derives [Clone] {
    Not, Negate,
}

// ══════════════════════════════════════════════════════════════════════════════
// §4  TYPE EXPRESSIONS
// ══════════════════════════════════════════════════════════════════════════════

data TypeExpr derives [Clone] {
    Primitive(String),     // "i32", "f64", "bool", "str"
    Pointer(Box<TypeExpr>), // *T
    Reference(Box<TypeExpr>), // &T
    Array(Box<TypeExpr>, u64), // [T; N]
    UserDefined(String),   // Custom type name
    Generic(String, Vec<TypeExpr>), // Vec<T>, Option<String>
}

// ══════════════════════════════════════════════════════════════════════════════
// §5  PATTERNS
// ══════════════════════════════════════════════════════════════════════════════

data Pattern derives [Clone] {
    Wildcard,              // _
    Identifier(String),    // x
    Literal(Literal),      // 42, "hello"
    Tuple(Vec<Pattern>),   // (x, y)
    Struct(String, Vec<StructPatternField>), // Point { x, y: 0 }
}

data StructPatternField derives [Clone] {
    open name: String,
    open pattern: Pattern,
}

// ══════════════════════════════════════════════════════════════════════════════
// §6  COMPILER INFRASTRUCTURE
// ══════════════════════════════════════════════════════════════════════════════

// ── Diagnostics ─────────────────────────────────────────────────────────────

data Diagnostic derives [Clone] {
    open level: DiagnosticLevel,
    open message: String,
    open location: SourceLocation,
}

data DiagnosticLevel derives [Clone] {
    Error, Warning, Info,
}

data SourceLocation derives [Clone] {
    open file: String,
    open line: u32,
    open column: u32,
}

// ── Compilation Results ─────────────────────────────────────────────────────

data CompiledProgram derives [Clone] {
    open code: String,
    open symbol_table: SymbolTable,
    open diagnostics: Vec<Diagnostic>,
}

// ── Error Types ─────────────────────────────────────────────────────────────

data CompileError derives [Clone] {
    ParseError(ParseError),
    SemanticError(SemanticError),
    TypeError(TypeError),
    CodegenError(String),
}

data ParseError derives [Clone] {
    UnexpectedToken(Token, String),
    ExpectedExpression,
    ExpectedType,
    ExpectedIdentifier,
    InvalidNumber(String),
    UnmatchedParenthesis,
}

data SemanticError derives [Clone] {
    UndefinedVariable(String),
    TypeMismatch(Type, Type),
    InvalidOperation(String),
    ScopeError(String),
    DuplicateSymbol(String),
}

// ── Forward Declarations for Type System ────────────────────────────────────

data Type derives [Clone, Eq] { /* Defined in semantic/types.zn */ }
data TypeChecker { /* Defined in semantic/types.zn */ }
data SymbolTable { /* Defined in semantic/types.zn */ }

// ══════════════════════════════════════════════════════════════════════════════
// §7  UTILITY FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════

impl AstUtils {

    open fn create_empty_ast() -> Ast {
        Ast {
            declarations: Vec::new(),
        }
    }

    open fn add_declaration(ast: *var Ast, decl: Declaration) -> () {
        ast.declarations.push(decl);
    }

    open fn find_function(ast: *Ast, name: String) -> Option<FunctionDecl> {
        for decl in ast.declarations.iter() {
            check let Declaration::Function(func) = decl {
                check func.name == name {
                    Some(func.clone());
                }
            }
        }
        yield None;
    }
}
