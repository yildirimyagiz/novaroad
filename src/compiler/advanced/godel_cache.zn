expose enum CacheResult {
    Success = 15,
    NotFound = 16,
    StoreError = 17,
    LoadError = 18,
    ValidationError = 19,
    VerificationError = 20,
    CompressionError = 21,
    DecompressionError = 22,
    SerializationError = 23,
    DeserializationError = 24,
