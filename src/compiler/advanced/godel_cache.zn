use std::collections::HashMap;
use std::time::{SystemTime, UNIX_EPOCH};

/// Cache status definitions
expose enum CacheStatus {
    Verified = 0,
    Failed = 1,
    Pending = 2,
    InProgress = 3,
    Timeout = 4,
    Cancelled = 5,
    Retrying = 6,
    Stale = 7,
    Invalid = 8,
    Corrupted = 9,
    Expired = 10,
    Evicted = 11,
    Archived = 12,
    Restored = 13,
    Synced = 14,
}

