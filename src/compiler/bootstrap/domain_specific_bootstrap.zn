rules DomainExpert {
    fn optimize_code(&self, source: &str) -> Result<String, String>;
    fn validate_code(&self, source: &str) -> Result<ValidationReport, String>;
    fn get_domain_specific_primitives(&self) -> Vec<String>;
    fn get_regulatory_requirements(&self) -> Vec<String>;
}

