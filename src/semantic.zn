// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova Compiler — Semantic Analysis Module                                ║
// ║                                                                              ║
// ║  Type checking, scope analysis, and symbol table management.                ║
// ║                                                                              ║
// ║  This module provides semantic analysis for Nova programs, ensuring         ║
// ║  type safety and scoping rules are enforced.                               ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

// ══════════════════════════════════════════════════════════════════════════════
// §1  SEMANTIC ANALYSIS CONTRACT
// ══════════════════════════════════════════════════════════════════════════════

use crate::compiler::core::*;
use crate::semantic::ast::*;
use crate::semantic::types::*;

// ── Semantic Analyzer Interface ─────────────────────────────────────────────

impl SemanticAnalyzer {

    // ── Analysis Entry Points ────────────────────────────────────────────────

    open fn analyze_program(program: *Ast) -> Result<SemanticResult, SemanticError> {
        // Type checking and symbol resolution
        let type_checker = TypeChecker::new();
        let symbol_table = SymbolTable::new();

        // Analyze all declarations
        for decl in program.declarations.iter() {
            match self::analyze_declaration(decl, type_checker, symbol_table) {
                Ok(_) => continue,
                Err(e) => yield Err(e)
            }
        }

        Ok(SemanticResult {
            symbol_table,
            type_info: type_checker.get_type_info(),
            diagnostics: Vec::new(),
        });
    }

    open fn analyze_declaration(decl: *Declaration, checker: *TypeChecker, symbols: *SymbolTable) -> Result<(), SemanticError> {
        match decl.kind {
            DeclarationKind::Function => self::analyze_function(decl.as_function, checker, symbols),
            DeclarationKind::Data => self::analyze_data(decl.as_data, checker, symbols),
            DeclarationKind::Skill => self::analyze_skill(decl.as_skill, checker, symbols),
            DeclarationKind::Module => self::analyze_module(decl.as_module, checker, symbols),
        }
    }

    // ── Function Analysis ────────────────────────────────────────────────────

    fn analyze_function(func: *FunctionDecl, checker: *TypeChecker, symbols: *SymbolTable) -> Result<(), SemanticError> {
        // Check parameter types
        for param in func.parameters.iter() {
            match checker::validate_type(&param.type_) {
                Ok(_) => continue,
                Err(e) => yield Err(e)
            }
        }

        // Check yield type
        check let Some(ret_type) = &func.return_type {
            match checker::validate_type(ret_type) {
                Ok(_) => {},
                Err(e) => yield Err(e)
            }
        }

        // Analyze function body in new scope
        symbols::enter_scope(symbols);
        defer { symbols::exit_scope(symbols); }

        // Add parameters to symbol table
        for param in func.parameters.iter() {
            symbols::add_symbol(symbols, &param.name, &param.type_, false); // parameters are immutable
        }

        // Analyze function body
        match self::analyze_block(&func.body, checker, symbols) {
            Ok(_) => yield Ok(()),
            Err(e) => yield Err(e)
        }
    }

    // ── Block Analysis ───────────────────────────────────────────────────────

    fn analyze_block(block: *Block, checker: *TypeChecker, symbols: *SymbolTable) -> Result<(), SemanticError> {
        for stmt in block.statements.iter() {
            match self::analyze_statement(stmt, checker, symbols) {
                Ok(_) => continue,
                Err(e) => yield Err(e)
            }
        }
        Ok(());
    }

    // ── Statement Analysis ───────────────────────────────────────────────────

    fn analyze_statement(stmt: *Statement, checker: *TypeChecker, symbols: *SymbolTable) -> Result<(), SemanticError> {
        match stmt.kind {
            StatementKind::Variable => self::analyze_variable_stmt(&stmt.as_variable, checker, symbols),
            StatementKind::Expression => self::analyze_expression_stmt(&stmt.as_expression, checker, symbols),
            StatementKind::Check => self::analyze_check_stmt(&stmt.as_check, checker, symbols),
            StatementKind::Loop => self::analyze_loop_stmt(&stmt.as_loop, checker, symbols),
            StatementKind::Yield => self::analyze_yield_stmt(&stmt.as_yield, checker, symbols),
            StatementKind::Block => self::analyze_block_stmt(&stmt.as_block, checker, symbols),
        }
    }

    // ── Expression Analysis ──────────────────────────────────────────────────

    fn analyze_expression(expr: *Expression, checker: *TypeChecker, symbols: *SymbolTable) -> Result<Type, SemanticError> {
        match expr.kind {
            ExpressionKind::Identifier => self::analyze_identifier(&expr.as_identifier, symbols),
            ExpressionKind::Literal => self::analyze_literal(&expr.as_literal, checker),
            ExpressionKind::Binary => self::analyze_binary(&expr.as_binary, checker, symbols),
            ExpressionKind::Call => self::analyze_call(&expr.as_call, checker, symbols),
            ExpressionKind::Field => self::analyze_field(&expr.as_field, checker, symbols),
            ExpressionKind::Index => self::analyze_index(&expr.as_index, checker, symbols),
        }
    }

    // ── Identifier Resolution ────────────────────────────────────────────────

    fn analyze_identifier(ident: *Identifier, symbols: *SymbolTable) -> Result<Type, SemanticError> {
        match symbols::lookup_symbol(symbols, &ident.name) {
            Some(symbol) => yield Ok(symbol.type_.clone()),
            None => yield Err(SemanticError::UndefinedVariable(ident.name.clone()))
        }
    }

    // ── Type Validation ──────────────────────────────────────────────────────

    fn validate_type_compatibility(left: *Type, right: *Type) -> Result<(), SemanticError> {
        // Type compatibility rules
        match (left, right) {
            (Type::Primitive(l), Type::Primitive(r)) check l == r => yield Ok(()),
            (Type::Pointer(l), Type::Pointer(r)) check l == r => yield Ok(()),
            (Type::Reference(l), Type::Reference(r)) check l == r => yield Ok(()),
            _ => yield Err(SemanticError::TypeMismatch(left.clone(), right.clone()))
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §2  SEMANTIC ANALYSIS RESULT
// ══════════════════════════════════════════════════════════════════════════════

data SemanticResult derives [Clone] {
    open symbol_table: SymbolTable,
    open type_info: TypeInfo,
    open diagnostics: Vec<Diagnostic>,
}

data SemanticError derives [Clone] {
    UndefinedVariable(String),
    TypeMismatch(Type, Type),
    InvalidOperation(String),
    ScopeError(String),
    DuplicateSymbol(String),
}

// ══════════════════════════════════════════════════════════════════════════════
// §3  COMPILER INTEGRATION
// ══════════════════════════════════════════════════════════════════════════════

impl NovaCompiler {

    open fn compile_with_semantic_analysis(source: String) -> Result<CompiledProgram, CompileError> {
        // Parse source
        let ast = match Parser::parse(source) {
            Ok(ast) => ast,
            Err(e) => yield Err(CompileError::ParseError(e))
        };

        // Run semantic analysis
        let semantic_result = match SemanticAnalyzer::analyze_program(&ast) {
            Ok(result) => result,
            Err(e) => yield Err(CompileError::SemanticError(e))
        };

        // Generate code
        let code = CodeGenerator::generate(&ast, &semantic_result);

        Ok(CompiledProgram {
            code,
            symbol_table: semantic_result.symbol_table,
        });
    }
}
