fn test_mutability() {
  let x = 5;
  // x = 10; // Bu hata vermeli (immutable)
  
  let var y = 5;
  y = 10; // Bu geçmeli
}

fn test_ownership() {
  cases MyStatus { Active, Inactive }

  let s1 = MyStatus::Active;
  let s2 = s1; // Move: s1 artık geçersiz
  
  // let s3 = s1; // Bu hata vermeli (use of moved variable)
}

fn main() {
  test_mutability();
  test_ownership();
}
