fn print_menu_banner() {
    println("╔══════════════════════════════════════════════════════════╗");
    println("║    Nova Sovereign Unified Engine — v3.0                  ║");
    println("║    Written in Zenith (.zn) — 100% Native Architecture   ║");
    println("╚══════════════════════════════════════════════════════════╝");
    println("");
    println("👉 Please choose application mode:");
    println("  [1] Start high-performance HTTP Web Server");
    println("  [2] Start interactive CLI Client (HTML-free Terminal UI)");
    println("");
}

fn run_client_mode() -> int {
    println("╔══════════════════════════════════════════════════════════╗");
    println("║    Nova Sovereign Interactive CLI Client Engine           ║");
    println("║    Written in Zenith (.zn) — Native CLI (HTML-free)      ║");
    println("╚══════════════════════════════════════════════════════════╝");
    println("");
    
    let running = 1;
    while running == 1 {
        let input_word: str = read_console_input();
        
        check strcmp(input_word, "q") == 0 {
            println("👋 Exiting client. Goodbye!");
            running = 0;
        }
        
        check strcmp(input_word, "q") != 0 {
            check strcmp(input_word, "") != 0 {
                println("🔌 Connecting to Zenith HTTP server on http://localhost:9500...");
                
                let socket_fd = nova_net_socket_create(2, 1, 0); // AF_INET = 2, SOCK_STREAM = 1
                check socket_fd < 0 {
                    println("❌ Error: Could not create client socket.");
                }
                
                check socket_fd >= 0 {
                    let conn_res = nova_net_socket_connect(socket_fd, "127.0.0.1", 9500);
                    check conn_res < 0 {
                        println("❌ Error: Could not connect to localhost:9500. Is the server running?");
                    }
                    
                    check conn_res >= 0 {
                        println("📤 Sending GET request for word analysis...");
                        
                        // Construct HTTP Request
                        let request_str: str = "GET /?word=" + input_word + " HTTP/1.1\nHost: 127.0.0.1:9500\nConnection: close\n\n";
                        
                        let bytes_sent = nova_net_socket_write(socket_fd, request_str, strlen(request_str));
                        check bytes_sent < 0 {
                            println("❌ Error: Failed to send request to server.");
                        }
                        
                        check bytes_sent >= 0 {
                            println("📥 Receiving response from native server...");
                            
                            // Read Response
                            let response_buf: str = malloc(4096);
                            memset(response_buf, 0, 4096);
                            
                            let bytes_read = nova_net_socket_read(socket_fd, response_buf, 4095);
                            check bytes_read < 0 {
                                println("❌ Error: Failed to read response from server.");
                            }
                            
                            check bytes_read >= 0 {
                                // Extract JSON body safely using helper FFI
                                let body_ptr: str = get_http_body(response_buf);
                                check strcmp(body_ptr, "") != 0 {
                                    println("");
                                    println("✨ --- SOVEREIGN ANALYSIS RESULT ---");
                                    println(body_ptr);
                                    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
                                }
                            }
                            free(response_buf);
                        }
                    }
                    nova_net_socket_close(socket_fd);
                }
            }
        }
    }
    yield 0;
}

fn run_server_mode() -> int {
    // Load high-performance bilingual dictionary using the absolute path or relative path
    println("🚜 Loading 644,103 words into helper Trie...");
    let dict_loaded = init_linguist("../../compiler/stages/stage7/full_dictionary.data");
    check dict_loaded == 0 {
        // Fallback to absolute path or other variations
        dict_loaded = init_linguist("/Users/os2026/Downloads/novaRoad 2/nova/src/compiler/stages/stage7/full_dictionary.data");
    }
    check dict_loaded == 0 {
        // Fallback to relative path of the build run
        dict_loaded = init_linguist("src/compiler/stages/stage7/full_dictionary.data");
    }
    check dict_loaded == 0 {
        // Fallback to current folder
        dict_loaded = init_linguist("full_dictionary.data");
    }
    
    check dict_loaded > 0 {
        print("  ✅ Successfully loaded ");
        nova_runtime_print_int(dict_loaded);
        println(" words into Trie memory!");
    }
    check dict_loaded == 0 {
        println("  ⚠️ Warning: Could not load full dictionary. Server running in mock mode.");
    }
    
    // Create server socket on port 9500
    let server_fd = nova_net_socket_create(2, 1, 0); // AF_INET = 2, SOCK_STREAM = 1, protocol = 0
    check server_fd < 0 {
        println("❌ Error: Could not create socket.");
        yield 1;
    }
    
    let bind_res = nova_net_socket_bind(server_fd, "0.0.0.0", 9500);
    check bind_res < 0 {
        println("❌ Error: Could not bind to port 9500.");
        yield 1;
    }
    
    let listen_res = nova_net_socket_listen(server_fd, 128);
    check listen_res < 0 {
        println("❌ Error: Could not listen on socket.");
        yield 1;
    }
    
    println("");
    println("🚀 Nova Web Server successfully started on http://localhost:9500");
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    
    let active = 1;
    while active == 1 {
        let client_fd = nova_net_socket_accept(server_fd);
        check client_fd >= 0 {
            let path: str = nova_net_get_request_path(client_fd);
            
            // Extract 'word' parameter
            let query_word: str = nova_net_get_query_param(path, "word");
            
            check strcmp(query_word, "") != 0 {
                // Run Morphological Synthesizer / Suffix Analyzer
                let analysis: str = analyze_morphology(query_word);
                
                check strcmp(analysis, "") == 0 {
                    // Fallback to simple JSON structure if analysis failed
                    analysis = "{\"root\":\"" + query_word + "\",\"translation\":\"Word not found in dictionary.\",\"suffix\":\"None\",\"desc\":\"Unknown structural morphology\",\"type\":\"unknown\",\"synth\":\"Not found\"}";
                }
                
                nova_net_send_http_response(client_fd, 200, "application/json", analysis);
            }
            
            check strcmp(query_word, "") == 0 {
                let html_body: str = get_web_ui_html();
                nova_net_send_http_response(client_fd, 200, "text/html", html_body);
            }
            
            nova_net_socket_close(client_fd);
        }
    }
    yield 0;
}

fn get_web_ui_html() -> str {
    let title: str = "Nova Sovereign Multilingual Translation & Morphological Synthesizer";
    
    let html: str = "<!DOCTYPE html><html lang='en'>";
    html = html + "<head><meta charset='UTF-8'><meta name='viewport' content='width=device-width, initial-scale=1.0'>";
    html = html + "<title>" + title + "</title>";
    html = html + "<link href='https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap' rel='stylesheet'>";
    
    html = html + "<style>";
    html = html + "body { margin: 0; background: linear-gradient(135deg, #090616 0%, #030209 100%); color: #fff; font-family: 'Outfit', sans-serif; display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 100vh; overflow-x: hidden; }";
    html = html + " .glow-container { position: relative; width: 90%; max-width: 800px; padding: 40px; background: rgba(255, 255, 255, 0.02); backdrop-filter: blur(25px); -webkit-backdrop-filter: blur(25px); border: 1px solid rgba(255, 255, 255, 0.05); border-radius: 24px; box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5), inset 0 1px 1px rgba(255, 255, 255, 0.1); text-align: center; margin-bottom: 20px; }";
    html = html + " .glow-container::before { content: ''; position: absolute; top: -2px; left: -2px; right: -2px; bottom: -2px; background: linear-gradient(45deg, #ff007f, #7f00ff, #00f0ff); border-radius: 26px; z-index: -1; opacity: 0.15; filter: blur(10px); }";
    html = html + " h1 { font-size: 2.8rem; font-weight: 800; margin: 0 0 10px 0; background: linear-gradient(45deg, #ff007f, #00f0ff); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }";
    html = html + " p.subtitle { font-size: 1.1rem; color: #a0a0c0; margin-bottom: 30px; }";
    html = html + " .search-box { display: flex; gap: 12px; margin-bottom: 40px; }";
    html = html + " input { flex: 1; padding: 16px 24px; background: rgba(255, 255, 255, 0.04); border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 14px; color: #fff; font-size: 1.1rem; outline: none; transition: all 0.3s ease; }";
    html = html + " input:focus { border-color: #00f0ff; box-shadow: 0 0 15px rgba(0, 240, 255, 0.2); }";
    html = html + " button { padding: 16px 32px; background: linear-gradient(45deg, #7f00ff, #ff007f); border: none; border-radius: 14px; color: #fff; font-size: 1.1rem; font-weight: 600; cursor: pointer; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(127, 0, 255, 0.3); }";
    html = html + " button:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(127, 0, 255, 0.5); }";
    html = html + " .stats { display: flex; justify-content: space-around; margin-top: 20px; border-top: 1px solid rgba(255, 255, 255, 0.05); padding-top: 30px; }";
    html = html + " .stat-item { text-align: center; }";
    html = html + " .stat-val { font-size: 2rem; font-weight: 800; color: #00f0ff; margin-bottom: 5px; }";
    html = html + " .stat-label { font-size: 0.9rem; color: #8080a0; text-transform: uppercase; letter-spacing: 1px; }";
    html = html + " .result-card { background: rgba(255, 255, 255, 0.01); border: 1px dashed rgba(255, 255, 255, 0.1); border-radius: 16px; padding: 25px; margin-top: 30px; display: none; text-align: left; }";
    html = html + " .result-card h3 { margin: 0 0 15px 0; color: #ff007f; font-size: 1.6rem; display: flex; justify-content: space-between; align-items: center; }";
    html = html + " .result-card p { margin: 8px 0; font-size: 1.1rem; line-height: 1.5; }";
    html = html + " .badge { display: inline-block; padding: 6px 12px; background: rgba(0, 240, 255, 0.1); border: 1px solid #00f0ff; color: #00f0ff; border-radius: 20px; font-size: 0.85rem; font-weight: 600; }";
    html = html + " .badge.suffix-badge { background: rgba(255, 0, 127, 0.1); border-color: #ff007f; color: #ff007f; }";
    html = html + " .badge.type-badge { background: rgba(127, 0, 255, 0.1); border-color: #7f00ff; color: #7f00ff; }";
    html = html + " .result-card strong { color: #a0a0c0; font-weight: 400; display: inline-block; width: 150px; }";
    html = html + "</style></head>";
    
    html = html + "<body><div class='glow-container'><h1>NOVA SOVEREIGN</h1><p class='subtitle'>High-Performance Turkish Morphological Synthesis & Multilingual Web Portal</p>";
    html = html + "<div class='search-box'><input type='text' id='wordInput' placeholder='Type a Turkish word (e.g. egemen, bilimsel, evrenler, bilimci)...' onkeydown='if(event.key===\"Enter\") search()'>";
    html = html + "<button onclick='search()'>Analyze</button></div>";
    
    html = html + "<div id='resultCard' class='result-card'><h3 id='resWord'>egemen</h3>";
    html = html + "<p><strong>Dictionary Root:</strong> <span id='resRoot' style='color:#00f0ff; font-weight:600;'>egemen</span></p>";
    html = html + "<p><strong>Root Translation:</strong> <span id='resTrans'>sovereign; dominant</span></p>";
    html = html + "<p><strong>Affixed Suffix:</strong> <span id='resSuffix' class='badge suffix-badge'>None</span></p>";
    html = html + "<p><strong>Structural Analysis:</strong> <span id='resDesc'>Direct match in dictionary</span></p>";
    html = html + "<p><strong>Synthetic Translation:</strong> <span id='resSynth' style='color:#ff007f; font-weight:600; font-size:1.2rem;'>sovereign; dominant</span></p></div>";
    
    html = html + "<div class='stats'><div class='stat-item'><div class='stat-val'>644,103</div><div class='stat-label'>Sovereign Words</div></div>";
    html = html + "<div class='stat-item'><div class='stat-val'>&lt;0.01ms</div><div class='stat-label'>O(L) Latency</div></div>";
    html = html + "<div class='stat-item'><div class='stat-val'>Native C</div><div class='stat-label'>Trie Architecture</div></div></div></div>";
    
    html = html + "<script>";
    html = html + "function search() {";
    html = html + "  const word = document.getElementById('wordInput').value.trim();";
    html = html + "  if (!word) return;";
    html = html + "  fetch('/?word=' + encodeURIComponent(word)).then(r => r.json()).then(data => {";
    html = html + "    document.getElementById('resWord').innerHTML = word + \" <span class='badge type-badge'>\" + data.type.toUpperCase() + \"</span>\";";
    html = html + "    document.getElementById('resRoot').innerText = data.root;";
    html = html + "    document.getElementById('resTrans').innerText = data.translation;";
    html = html + "    document.getElementById('resSuffix').innerText = data.suffix;";
    html = html + "    document.getElementById('resDesc').innerText = data.desc;";
    html = html + "    document.getElementById('resSynth').innerText = data.synth;";
    html = html + "    document.getElementById('resultCard').style.display = 'block';";
    html = html + "  });";
    html = html + "}";
    html = html + "</script></body></html>";
    
    yield html;
}

fn main() -> int {
    let choice: str = get_app_mode_env();
    
    check strcmp(choice, "") == 0 {
        print_menu_banner();
        choice = read_console_input();
    }
    
    check strcmp(choice, "1") == 0 {
        yield run_server_mode();
    }
    
    check strcmp(choice, "2") == 0 {
        yield run_client_mode();
    }
    
    check strcmp(choice, "1") != 0 {
        check strcmp(choice, "2") != 0 {
            println("❌ Invalid choice. Exiting...");
        }
    }
    
    yield 0;
}
