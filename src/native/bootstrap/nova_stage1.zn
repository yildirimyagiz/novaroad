// ============================================================================
// §1  TOKEN TYPES — encoded as integers
// ============================================================================

fn tok_int_lit() -> int { yield 1; }
fn tok_float_lit() -> int { yield 2; }
fn tok_str_lit() -> int { yield 3; }
fn tok_bool_lit() -> int { yield 4; }
fn tok_ident() -> int { yield 5; }
fn tok_kw_fn() -> int { yield 10; }
fn tok_kw_let() -> int { yield 11; }
fn tok_kw_mut() -> int { yield 12; }
fn tok_kw_if() -> int { yield 13; }
fn tok_kw_else() -> int { yield 14; }
fn tok_kw_while() -> int { yield 15; }
fn tok_kw_for() -> int { yield 16; }
fn tok_kw_return() -> int { yield 17; }
fn tok_kw_struct() -> int { yield 18; }
fn tok_kw_impl() -> int { yield 19; }
fn tok_kw_true() -> int { yield 20; }
fn tok_kw_false() -> int { yield 21; }
fn tok_kw_var() -> int { yield 22; }
fn tok_kw_check() -> int { yield 23; }
fn tok_kw_yield() -> int { yield 24; }
fn tok_kw_expose() -> int { yield 25; }
fn tok_kw_data() -> int { yield 26; }
fn tok_kw_cases() -> int { yield 27; }
fn tok_kw_space() -> int { yield 28; }
fn tok_kw_open() -> int { yield 29; }
fn tok_plus() -> int { yield 30; }
fn tok_minus() -> int { yield 31; }
fn tok_star() -> int { yield 32; }
fn tok_slash() -> int { yield 33; }
fn tok_eq() -> int { yield 34; }
fn tok_eq_eq() -> int { yield 35; }
fn tok_bang_eq() -> int { yield 36; }
fn tok_lt() -> int { yield 37; }
fn tok_gt() -> int { yield 38; }
fn tok_lt_eq() -> int { yield 39; }
fn tok_gt_eq() -> int { yield 40; }
fn tok_and_and() -> int { yield 41; }
fn tok_or_or() -> int { yield 42; }
fn tok_bang() -> int { yield 43; }
fn tok_arrow() -> int { yield 44; }
fn tok_dot() -> int { yield 45; }
fn tok_colon() -> int { yield 46; }
fn tok_colon_colon() -> int { yield 47; }
fn tok_semicolon() -> int { yield 48; }
fn tok_comma() -> int { yield 49; }
fn tok_lparen() -> int { yield 50; }
fn tok_rparen() -> int { yield 51; }
fn tok_lbrace() -> int { yield 52; }
fn tok_rbrace() -> int { yield 53; }
fn tok_lbracket() -> int { yield 54; }
fn tok_rbracket() -> int { yield 55; }
fn tok_ampersand() -> int { yield 56; }
fn tok_pipe() -> int { yield 57; }
fn tok_eof() -> int { yield 99; }

// ============================================================================
// §1.5  AST NODE TYPES — encoded as integers
// ============================================================================

fn ast_program() -> int { yield 100; }
fn ast_fn_def() -> int { yield 101; }
fn ast_var_decl() -> int { yield 102; }
fn ast_binary_expr() -> int { yield 103; }
fn ast_ident() -> int { yield 104; }
fn ast_int_lit() -> int { yield 105; }
fn ast_block() -> int { yield 106; }
fn ast_return() -> int { yield 107; }

// ============================================================================
// §2  COMPILER STATE — capacity limits
// ============================================================================

fn get_max_tokens() -> int { yield 65536; }
fn get_max_nodes() -> int { yield 32768; }
fn get_max_output() -> int { yield 1048576; }

// ============================================================================
// §3  CHARACTER CLASSIFICATION
// ============================================================================

fn char_is_alpha(c: int) -> int {
    check c >= 65 { check c <= 90 { yield 1; } }
    check c >= 97 { check c <= 122 { yield 1; } }
    check c == 95 { yield 1; }
    yield 0;
}

fn char_is_digit(c: int) -> int {
    check c >= 48 { check c <= 57 { yield 1; } }
    yield 0;
}

fn char_is_alnum(c: int) -> int {
    let a = char_is_alpha(c);
    let d = char_is_digit(c);
    check a == 1 { yield 1; }
    check d == 1 { yield 1; }
    yield 0;
}

fn char_is_whitespace(c: int) -> int {
    check c == 32 { yield 1; }
    check c == 9  { yield 1; }
    check c == 10 { yield 1; }
    check c == 13 { yield 1; }
    yield 0;
}

// ============================================================================
// §4  LEXER — tokenizes source string into token arrays
// ============================================================================

// Token arrays: parallel arrays for type, start position, length
// tok_types[i], tok_starts[i], tok_lens[i] describe token i
// tok_count holds the total number of tokens

fn lexer_classify_keyword(word: str) -> int {
    check word == "fn" { yield 10; }
    check word == "let" { yield 11; }
    check word == "mut" { yield 12; }
    check word == "if" { yield 13; }
    check word == "else" { yield 14; }
    check word == "while" { yield 15; }
    check word == "for" { yield 16; }
    check word == "return" { yield 17; }
    check word == "struct" { yield 18; }
    check word == "impl" { yield 19; }
    check word == "true" { yield 20; }
    check word == "false" { yield 21; }
    check word == "var" { yield 22; }
    check word == "check" { yield 23; }
    check word == "yield" { yield 24; }
    check word == "expose" { yield 25; }
    check word == "data" { yield 26; }
    check word == "cases" { yield 27; }
    check word == "space" { yield 28; }
    check word == "open" { yield 29; }
    yield 5;
}

