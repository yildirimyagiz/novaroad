// ╔══════════════════════════════════════════════════════════════════════════╗
// ║   Nova Sovereign HTTP Client App — v1.0                                ║
// ║   Written in Zenith (.zn), compiled natively                            ║
// ╚══════════════════════════════════════════════════════════════════════════╝

fn main() -> int {
    println("╔══════════════════════════════════════════════════════════╗");
    println("║    Nova Sovereign HTTP Client Engine v1.0               ║");
    println("║    Written in Zenith (.zn) — Native CLI Client          ║");
    println("╚══════════════════════════════════════════════════════════╝");
    println("");
    
    let running = 1;
    while running == 1 {
        let input_word: str = read_console_input();
        
        check strcmp(input_word, "q") == 0 {
            println("👋 Exiting client. Goodbye!");
            running = 0;
        }
        
        check strcmp(input_word, "q") != 0 {
            check strcmp(input_word, "") != 0 {
                println("🔌 Connecting to Zenith HTTP server on http://localhost:9500...");
                
                let socket_fd = nova_net_socket_create(2, 1, 0); // AF_INET = 2, SOCK_STREAM = 1
                check socket_fd < 0 {
                    println("❌ Error: Could not create client socket.");
                }
                
                check socket_fd >= 0 {
                    let conn_res = nova_net_socket_connect(socket_fd, "127.0.0.1", 9500);
                    check conn_res < 0 {
                        println("❌ Error: Could not connect to localhost:9500. Is the server running?");
                    }
                    
                    check conn_res >= 0 {
                        println("📤 Sending GET request for word analysis...");
                        
                        // Construct HTTP Request
                        let request_str: str = "GET /?word=" + input_word + " HTTP/1.1\nHost: 127.0.0.1:9500\nConnection: close\n\n";
                        
                        let bytes_sent = nova_net_socket_write(socket_fd, request_str, strlen(request_str));
                        check bytes_sent < 0 {
                            println("❌ Error: Failed to send request to server.");
                        }
                        
                        check bytes_sent >= 0 {
                            println("📥 Receiving response from native server...");
                            
                            // Read Response
                            let response_buf: str = malloc(4096);
                            memset(response_buf, 0, 4096);
                            
                            let bytes_read = nova_net_socket_read(socket_fd, response_buf, 4095);
                            check bytes_read < 0 {
                                println("❌ Error: Failed to read response from server.");
                            }
                            
                            check bytes_read >= 0 {
                                // Locate start of JSON body by searching for "\n\n"
                                let body_ptr: str = strstr(response_buf, "\n\n");
                                check strcmp(body_ptr, "") != 0 {
                                    // Move past "\n\n"
                                    body_ptr = advance_pointer(body_ptr, 2);
                                    println("");
                                    println("✨ --- SOVEREIGN ANALYSIS RESULT ---");
                                    println(body_ptr);
                                    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
                                }
                                
                                check strcmp(body_ptr, "") == 0 {
                                    println("⚠️ Warning: No HTTP body found. Full response:");
                                    println(response_buf);
                                }
                            }
                            
                            free(response_buf);
                        }
                    }
                    
                    nova_net_socket_close(socket_fd);
                }
            }
        }
    }
    
    yield 0;
}
