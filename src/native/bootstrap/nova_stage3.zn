fn opt_level_none() -> int { yield 0; }
fn opt_level_basic() -> int { yield 1; }
fn opt_level_aggressive() -> int { yield 2; }
fn opt_level_max() -> int { yield 3; }

// ============================================================================
// §3  BANNER & VERSION
