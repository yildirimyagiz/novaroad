# ═══════════════════════════════════════════════════════════════════════════
# nova Scientific Validation Suite - Makefile
# ═══════════════════════════════════════════════════════════════════════════

CC = gcc
CFLAGS = -O2 -Wall -Wextra -std=c11 -I.
LDFLAGS = -lm

# Platform-specific flags
UNAME_S := $(shell uname -s)
ifeq ($(UNAME_S),Darwin)
    CFLAGS += -D__APPLE__
    # Enable NEON on ARM64 Macs
    ifeq ($(shell uname -m),arm64)
        CFLAGS += -march=armv8-a+simd
    endif
else ifeq ($(UNAME_S),Linux)
    CFLAGS += -D__linux__
    # Enable NEON on ARM64 Linux
    ifeq ($(shell uname -m),aarch64)
        CFLAGS += -march=armv8-a+simd
    endif
endif

# Source files
SRCS = zenith_scientific_validation.c \
       zenith_scientific_validation_matmul.c \
       zenith_scientific_validation_memory.c \
       zenith_scientific_validation_fusion.c \
       zenith_scientific_validation_numerics.c \
       zenith_scientific_validation_attention.c \
       zenith_scientific_validation_datamovement.c \
       zenith_scientific_validation_graph.c \
       zenith_scientific_validation_main.c

OBJS = $(SRCS:.c=.o)

TARGET = zenith_scientific_validation

# ═══════════════════════════════════════════════════════════════════════════
# Build rules
# ═══════════════════════════════════════════════════════════════════════════

all: $(TARGET)

$(TARGET): $(OBJS)
	@echo "🔗 Linking $@..."
	$(CC) $(CFLAGS) -o $@ $(OBJS) $(LDFLAGS)
	@echo "✅ Build complete: $(TARGET)"

%.o: %.c zenith_scientific_validation.h
	@echo "🔨 Compiling $<..."
	$(CC) $(CFLAGS) -c $< -o $@

clean:
	@echo "🧹 Cleaning..."
	rm -f $(OBJS) $(TARGET)
	@echo "✅ Clean complete"

run: $(TARGET)
	@echo "🚀 Running validation suite..."
	@./$(TARGET)

# Build with debug symbols
debug: CFLAGS += -g -O0 -DDEBUG
debug: clean $(TARGET)

# Build with aggressive optimizations
release: CFLAGS += -O3 -march=native -flto
release: clean $(TARGET)

.PHONY: all clean run debug release
