expose data NexusFoundryNAF {
    expose daemon_engine: DaemonSystem,
}

impl NexusFoundryNAF {
    expose fn new() -> NexusFoundryNAF {
        NexusFoundryNAF { daemon_engine: DaemonSystem::new() }
    }

