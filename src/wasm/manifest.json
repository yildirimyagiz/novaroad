  ],
  "screenshots": [
    {
      "src": "/screenshot-desktop.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide"
    },
    {
      "src": "/screenshot-mobile.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow"
    }
  ],
  "shortcuts": [
    {
      "name": "New Compute Session",
      "short_name": "Compute",
      "description": "Start a new compute session",
      "url": "/compute",
      "icons": [
        {
          "src": "/icon-compute-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Model Training",
      "short_name": "Train",
      "description": "Train a machine learning model",
      "url": "/train",
      "icons": [
        {
          "src": "/icon-train-96.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "related_applications": [],
  "prefer_related_applications": false,
  "share_target": {
    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "model",
          "accept": [".nova", ".wasm", ".json"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+nova",
      "url": "/handler?url=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/open",
      "accept": {
        "application/x-nova": [".nova"],
        "application/wasm": [".wasm"]
      }
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  }
}
