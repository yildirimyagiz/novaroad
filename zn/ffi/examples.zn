// Example 3: Rust Interop
// ═══════════════════════════════════════════════════════════════════════════════

/// Transfer data to Rust
open fn example_rust_transfer() -> Result<(), String> {
    use rust_bridge::*;
    
    // Create data in Nova
    let data = [1, 2, 3, 4, 5];
    
    // Transfer to Rust
    let rust_vec = to_rust_vec(data);
    
    // Pass to Rust function
    // extern "C" fn rust_process(v: RustVec<i32>);
    // unsafe { rust_process(rust_vec); }
    
    Ok(())
}

/// Use Arc for shared ownership
open fn example_rust_arc() -> Result<(), String> {
    use rust_bridge::*;
    
    let data = "Hello from Nova!".into();
    let arc = to_rust_arc(data);
    
    // Clone arc (increment refcount)
    let arc2 = unsafe { clone_rust_arc(arc) };
    
    // Use the data
    // ...
    
    // Drop references
    unsafe {
        drop_rust_arc(arc);
        drop_rust_arc(arc2);
    }
    
    Ok(())
}

// ═══════════════════════════════════════════════════════════════════════════════
// Example 4: JavaScript/WASM
// ═══════════════════════════════════════════════════════════════════════════════

/// Create JavaScript objects
open fn example_js_objects() -> Result<(), String> {
    use js_bridge::*;
    
    // Create object
    let obj = JsObject::new_object();
    obj.set_property("name", &JsObject::from_string("Nova")?)?;
    obj.set_property("version", &JsObject::from_string("1.0")?)?;
    obj.set_property("awesome", &JsObject::from_bool(true))?;
    
    // Create array
    let arr = JsObject::new_array(3);
    arr.set_index(0, &JsObject::from_i32(1))?;
    arr.set_index(1, &JsObject::from_i32(2))?;
    arr.set_index(2, &JsObject::from_i32(3))?;
    
    obj.set_property("numbers", &arr)?;
    
    Ok(())
}

/// Use Promises
open fn example_js_promises() -> Result<(), String> {
    use js_bridge::*;
    
    let (promise, resolver) = JsPromise::new();
    
    // Simulate async work
    std::thread::spawn(move || {
        std::thread::sleep(std::time::Duration::from_secs(1));
        resolver.resolve(JsObject::from_string("Done!").unwrap());
    });
    
    // Add handlers
    promise
        .then(|result| {
            println("Promise resolved: {:?}", result);
        })
        .catch(|error| {
            println("Promise rejected: {:?}", error);
        });
    
    Ok(())
}

