/// Call Swift code
open fn example_swift_call() -> Result<(), String> {
    use swift_bridge::*;
    
    // Get UIView instance (from somewhere)
    let view_ptr = get_ui_view(); // Hypothetical
    let view = unsafe { SwiftClass::from_ptr(view_ptr) };
    
    // Set background color
    let color = create_ui_color(1.0, 0.0, 0.0, 1.0); // Red
    view.call_method("setBackgroundColor:", &[color])?;
    
    Ok(())
}

// Hypothetical Swift interop helpers
fn get_ui_view() -> swift_bridge::SwiftObject {
    std::ptr::null_mut()
}

fn create_ui_color(r: f32, g: f32, b: f32, a: f32) -> swift_bridge::SwiftObject {
    std::ptr::null_mut()
}

// ═══════════════════════════════════════════════════════════════════════════════
// Example 6: Cross-Language Data
// ═══════════════════════════════════════════════════════════════════════════════

/// Convert data between languages
open fn example_universal_value() -> Result<(), String> {
    use interop::*;
    
    // Create universal value
    var obj = HashMap::new();
    obj.insert("name".into(), UniversalValue::String("Nova".into()));
    obj.insert("version".into(), UniversalValue::Int(1));
    obj.insert("stable".into(), UniversalValue::Bool(true));
    
    let value = UniversalValue::Object(obj);
    
    // Convert to Python
    let py_obj = value.to_python()?;
    
    // Convert to JavaScript
    let js_obj = value.to_javascript()?;
    
    // Convert to JSON
    let json = value.to_json()?;
    println("JSON: {}", json);
    
    Ok(())
}

/// Use universal functions
open fn example_universal_function() -> Result<(), String> {
    use interop::*;
    
    let add_func = UniversalFunction::new("add", |args| {
        check args.len() != 2 {
            Err("Expected 2 arguments".into());
        }
        
        let a = match &args[0] {
            UniversalValue::Int(n) => *n,
            UniversalValue::Float(f) => *f as i64,
            _ => yield Err("First arg must be number".into()),
        };
        
        let b = match &args[1] {
            UniversalValue::Int(n) => *n,
            UniversalValue::Float(f) => *f as i64,
            _ => yield Err("Second arg must be number".into()),
        };
        
        Ok(UniversalValue::Int(a + b))
    });
    
    let result = add_func.call([
        UniversalValue::Int(10),
        UniversalValue::Int(20),
    ])?;
    
    println("Result: {:?}", result);
    
    Ok(())
}

// ═══════════════════════════════════════════════════════════════════════════════
// Example 7: Code Generation
// ═══════════════════════════════════════════════════════════════════════════════

/// Generate bindings for all languages
open fn example_binding_generation() -> Result<(), String> {
    use interop::*;
    
    var gen = BindingGenerator::new();
    
    // Add function signatures
    gen.add_function(FunctionSignature {
        name: "add".into(),
        params: [
            ("a".into(), "i32".into()),
            ("b".into(), "i32".into()),
        ],
        return_type: "i32".into(),
    });
    
    gen.add_function(FunctionSignature {
        name: "greet".into(),
        params: [
            ("name".into(), "String".into()),
        ],
        return_type: "String".into(),
    });
    
    // Generate C header
    let c_header = gen.generate_c_header();
    println("C Header:\n{}", c_header);
    
    // Generate TypeScript
    let ts_defs = gen.generate_typescript();
    println("\nTypeScript:\n{}", ts_defs);
    
    Ok(())
}

// ═══════════════════════════════════════════════════════════════════════════════
// Main Example Runner
// ═══════════════════════════════════════════════════════════════════════════════

open fn run_all_examples() {
    println("=== Nova FFI Examples ===\n");
    
    println("1. Python NumPy Integration");
    let _ = example_python_numpy();
    
    println("\n2. C Library Loading");
    let _ = example_c_library();
    
    println("\n3. JavaScript Objects");
    let _ = example_js_objects();
    
    println("\n4. Universal Values");
    let _ = example_universal_value();
    
    println("\n5. Binding Generation");
    let _ = example_binding_generation();
    
    println("\n=== Examples Complete ===");
}
