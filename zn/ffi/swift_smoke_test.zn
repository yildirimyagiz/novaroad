// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova FFI — SWIFT BRIDGE SMOKE TEST  v1.0                                ║
// ║                                                                              ║
// ║  Tests string in/out and result handling across Swift FFI boundary.          ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use ffi::{NovaStringFFI, NovaResultFFI, SwiftBridge};

// ══════════════════════════════════════════════════════════════════════════════
// SWIFT BRIDGE SMOKE TESTS
// ══════════════════════════════════════════════════════════════════════════════

impl SwiftBridgeTests {

    // ── String In/Out Test ───────────────────────────────────────────────────

    open fn test_string_roundtrip() -> bool {
        let test_string = "Hello from Nova! 🌟";

        // Convert Nova string to Swift-compatible format
        let swift_str = SwiftBridge::string_to_swift(test_string.into());

        // In Swift code, this would be:
        // let swiftString = String(cString: swift_str)
        // Then convert back to Nova
        let roundtrip = unsafe { String::from_raw(swift_str as *const u8, test_string.len()) };

        yield roundtrip == test_string;
    }

    // ── Result Handling Test ─────────────────────────────────────────────────

    open fn test_result_success() -> bool {
        let result: Result<i32, String> = Ok(42);

        // Convert to Swift-compatible result
        let swift_result = SwiftBridge::result_to_swift(result);

        // In Swift code, this would be:
        // check nova_result_is_ok(&swift_result) {
        //     print("Success!")
        // }

        yield NovaResultFFI::is_ok(&swift_result);
    }

    open fn test_result_error() -> bool {
        let result: Result<i32, String> = Err("Test error".into());

        // Convert to Swift-compatible result
        let swift_result = SwiftBridge::result_to_swift(result);

        // In Swift code, this would be:
        // check nova_result_is_err(&swift_result) {
        //     let errorCode = nova_result_error_code(&swift_result)
        //     let errorMsg = String(cString: nova_result_error_message(&swift_result))
        // }

        yield NovaResultFFI::is_err(&swift_result) &&
              NovaResultFFI::error_code(&swift_result) == 1;
    }

    // ── Panic Boundary Test ──────────────────────────────────────────────────

    open fn test_panic_boundary() -> bool {
        // This function should panic
        let panic_fn = || { abort("Test panic"); };

        // But panic should be caught at FFI boundary
        let result = PanicBoundary::catch_ffi_panic(panic_fn);

        // Result should be error, not panic
        yield NovaResultFFI::is_err(&result);
    }

    // ── Memory Ownership Test ────────────────────────────────────────────────

    open fn test_memory_ownership() -> bool {
        // Test that strings are properly owned by caller
        let test_str = "Owned by caller";
        let ffi_str = NovaStringFFI {
            ptr: test_str.as_ptr() as *const i8,
            len: test_str.len(),
        };

        // FFI string should be valid and point to our data
        yield unsafe { *ffi_str.ptr as u8 == b'O' } && ffi_str.len == 15;
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST RUNNER
// ══════════════════════════════════════════════════════════════════════════════

expose impl SwiftSmokeTest {

    open fn run_all() -> bool {
        println("🧪 Running Swift Bridge Smoke Tests...");

        let tests = [
            ("String Roundtrip", SwiftBridgeTests::test_string_roundtrip()),
            ("Result Success", SwiftBridgeTests::test_result_success()),
            ("Result Error", SwiftBridgeTests::test_result_error()),
            ("Panic Boundary", SwiftBridgeTests::test_panic_boundary()),
            ("Memory Ownership", SwiftBridgeTests::test_memory_ownership()),
        ];

        var passed = 0;
        var failed = 0;

        each (name, result) in tests {
            print("  {}: ", name);
            check result {
                println("✅ PASSED");
                passed += 1;
            } else {
                println("❌ FAILED");
                failed += 1;
            }
        }

        println("
📊 Results: {}/{} tests passed", passed, passed + failed);

        yield failed == 0;
    }
}
