// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova FFI — KOTLIN BRIDGE SMOKE TEST  v1.0                               ║
// ║                                                                              ║
// ║  Tests string in/out and result handling across Kotlin/JNI boundary.         ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use ffi::{NovaStringFFI, NovaResultFFI, KotlinBridge};

// ══════════════════════════════════════════════════════════════════════════════
// KOTLIN BRIDGE SMOKE TESTS
// ══════════════════════════════════════════════════════════════════════════════

impl KotlinBridgeTests {

    // ── String In/Out Test ───────────────────────────────────────────────────

    open fn test_string_roundtrip() -> bool {
        let test_string = "Hello from Nova! 🚀";

        // Convert Nova string to Kotlin-compatible format
        let kotlin_str = KotlinBridge::string_to_kotlin(test_string.into());

        // In Kotlin code, this would be:
        // val kotlinString = kotlin_str.toKString()
        // Then convert back to Nova
        let roundtrip = unsafe { String::from_raw(kotlin_str as *const u8, test_string.len()) };

        yield roundtrip == test_string;
    }

    // ── Result Handling Test ─────────────────────────────────────────────────

    open fn test_result_success() -> bool {
        let result: Result<String, String> = Ok("Success!".into());

        // Convert to Kotlin-compatible result
        let kotlin_result = KotlinBridge::result_to_kotlin(result);

        // In Kotlin code, this would be:
        // check (nova_result_is_ok(kotlin_result)) {
        //     println("Success!")
        // }

        yield NovaResultFFI::is_ok(&kotlin_result);
    }

    open fn test_result_error() -> bool {
        let result: Result<String, String> = Err("Kotlin test error".into());

        // Convert to Kotlin-compatible result
        let kotlin_result = KotlinBridge::result_to_kotlin(result);

        // In Kotlin code, this would be:
        // check (nova_result_is_err(kotlin_result)) {
        //     val errorCode = nova_result_error_code(kotlin_result)
        //     val errorMsg = nova_result_error_message(kotlin_result).toKString()
        // }

        yield NovaResultFFI::is_err(&kotlin_result) &&
              NovaResultFFI::error_code(&kotlin_result) == 1;
    }

    // ── JNI Memory Management Test ───────────────────────────────────────────

    open fn test_jni_memory_management() -> bool {
        // Test that JNI memory management works correctly
        let test_data = "JNI memory test";

        // Simulate JNI string creation
        let jni_str = NovaStringFFI {
            ptr: test_data.as_ptr() as *const i8,
            len: test_data.len(),
        };

        // In JNI, this would be:
        // jstring javaString = env->NewStringUTF(jni_str.ptr);
        // Then properly release with env->ReleaseStringUTFChars()

        // Test that our string data is intact
        yield unsafe { *jni_str.ptr as u8 == b'J' } && jni_str.len == 15;
    }

    // ── Exception Boundary Test ──────────────────────────────────────────────

    open fn test_exception_boundary() -> bool {
        // Test that Nova panics become JNI exceptions
        let panic_fn = || {
            // This would cause a panic in real code
            abort("JNI panic test");
        };

        let result = PanicBoundary::catch_ffi_panic(panic_fn);

        // In JNI, this would be:
        // check (nova_result_is_err(&result)) {
        //     jclass exceptionClass = env->FindClass("java/lang/RuntimeException");
        //     env->ThrowNew(exceptionClass, nova_result_error_message(&result));
        // }

        yield NovaResultFFI::is_err(&result);
    }

    // ── UTF-8 Handling Test ──────────────────────────────────────────────────

    open fn test_utf8_handling() -> bool {
        let unicode_string = "Nova 中文 русский 🌟";

        let kotlin_str = KotlinBridge::string_to_kotlin(unicode_string.into());

        // Test that UTF-8 is preserved
        let roundtrip = unsafe { String::from_raw(kotlin_str as *const u8, unicode_string.len()) };

        yield roundtrip == unicode_string;
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// TEST RUNNER
// ══════════════════════════════════════════════════════════════════════════════

expose impl KotlinSmokeTest {

    open fn run_all() -> bool {
        println("🤖 Running Kotlin/JNI Bridge Smoke Tests...");

        let tests = [
            ("String Roundtrip", KotlinBridgeTests::test_string_roundtrip()),
            ("Result Success", KotlinBridgeTests::test_result_success()),
            ("Result Error", KotlinBridgeTests::test_result_error()),
            ("JNI Memory Mgmt", KotlinBridgeTests::test_jni_memory_management()),
            ("Exception Boundary", KotlinBridgeTests::test_exception_boundary()),
            ("UTF-8 Handling", KotlinBridgeTests::test_utf8_handling()),
        ];

        var passed = 0;
        var failed = 0;

        each (name, result) in tests {
            print("  {}: ", name);
            check result {
                println("✅ PASSED");
                passed += 1;
            } else {
                println("❌ FAILED");
                failed += 1;
            }
        }

        println("
📊 Results: {}/{} tests passed", passed, passed + failed);

        yield failed == 0;
    }
}
