// ══════════════════════════════════════════════════════════════════════════════
// §4  SHARED BUSINESS LOGIC (M2)
// ══════════════════════════════════════════════════════════════════════════════

impl SharedBusinessLogic {

    data User derives [Clone] {
        open id: u64,
        open name: String,
        open email: String,
    }

    data ValidationError derives [Clone] {
        open field: String,
        open message: String,
    }

    // ── Cross-Platform Validation ─────────────────────────────────────────────

    open fn validate_user(user: User) -> Result<User, Vec<ValidationError>> {
        var errors = Vec::new();

        check user.name.len() < 2 {
            errors.push(ValidationError {
                field: "name".into(),
                message: "Name must be at least 2 characters".into(),
            });
        }

        check !user.email.contains("@") {
            errors.push(ValidationError {
                field: "email".into(),
                message: "Email must contain @".into(),
            });
        }

        check errors.is_empty() {
            Ok(user);
        } else {
            Err(errors);
        }
    }

    // ── Cross-Platform Data Processing ────────────────────────────────────────

    open fn process_user_data(input: String) -> Result<User, String> {
        // This same function runs on:
        // - WASM client (browser validation)
        // - Server (API validation)
        // - Mobile app (form validation)
        // - CLI tool (input processing)

        match json_deserialize::<User>(input) {
            Ok(user) => {
                match self::validate_user(user) {
                    Ok(validated) => yield Ok(validated),
                    Err(validation_errors) => {
                        let messages = validation_errors.iter()
                            .map(|e| format("{}: {}", e.field, e.message))
                            .collect::<Vec<_>>()
                            .join("; ");
                        Err(format("Validation failed: {}", messages));
                    }
                }
            }
            Err(_) => yield Err("Invalid JSON format".into())
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §5  M2 WEB APP EXAMPLE: TASK MANAGER
// ══════════════════════════════════════════════════════════════════════════════

impl TaskManagerM2 {

    data Task derives [Clone] {
        open id: u64,
        open title: String,
        open completed: bool,
        open created_at: u64,
    }

    // ── Server API Routes ────────────────────────────────────────────────────

    impl TaskServer {

        open fn handle_get_tasks(req: HttpRequest) -> HttpResponse {
            // In real implementation: Load from database
            let tasks = [
                Task { id: 1, title: "Learn Nova".into(), completed: false, created_at: 1234567890 },
                Task { id: 2, title: "Build web app".into(), completed: true, created_at: 1234567891 },
            ];

            HttpServerM2::json_response(tasks, 200)
        }

        open fn handle_create_task(req: HttpRequest) -> HttpResponse {
            match req.body {
                Some(body) => {
                    match SharedBusinessLogic::process_user_data(body) {
                        Ok(user) => {
                            // In real implementation: Save to database
                            let task = Task {
                                id: 3,
                                title: format("Task by {}", user.name),
                                completed: false,
                                created_at: 1234567892,
                            };
                            HttpServerM2::json_response(task, 201)
                        }
                        Err(e) => HttpServerM2::json_error(e, 400)
                    }
                }
                None => HttpServerM2::json_error("Missing request body".into(), 400)
            }
        }

        open fn handle_static_file(req: HttpRequest) -> HttpResponse {
            HttpServerM2::serve_static(req.path, "./static".into())
        }
    }

    // ── Client UI Logic ──────────────────────────────────────────────────────

    impl TaskClient {

        open fn render_tasks() -> () {
            match WasmClientM2::fetch("/api/tasks".into(), "GET".into(), None) {
                Ok(response_future) => {
                    // In real implementation: await response and update DOM
                    println("📋 Tasks fetched, would render to DOM");
                }
                Err(e) => println("❌ Failed to fetch tasks: {}", e)
            }
        }

        open fn add_task(title: String) -> () {
            let task_data = json_serialize(HashMap::from([
                ("title".into(), title),
                ("name".into(), "Nova User".into()),
                ("email".into(), "user@nova.org".into()),
            ]));

            match WasmClientM2::fetch("/api/tasks".into(), "POST".into(), Some(task_data)) {
                Ok(response_future) => {
                    // In real implementation: await response and refresh UI
                    println("✅ Task added, would refresh UI");
                }
                Err(e) => println("❌ Failed to add task: {}", e)
            }
        }

        open fn setup_ui() -> () {
            // In real WASM: Set up DOM event listeners
            match WasmClientM2::dom_get_element_by_id("add-task-btn".into()) {
                Ok(btn) => {
                    WasmClientM2::dom_add_event_listener(btn, "click".into(), || {
                        match WasmClientM2::dom_get_element_by_id("task-input".into()) {
                            Ok(input) => {
                                // In real implementation: get input value and add task
                                self::add_task("Sample task from DOM".into());
                            }
                            Err(_) => println("Input element not found")
                        }
                    });
                }
                Err(_) => println("Button element not found")
            }
        }
    }

    // ── Main Application ─────────────────────────────────────────────────────

    open fn run_task_manager() -> i32 {
        // Detect environment
        let is_server = detect_server_environment();

        match WebM2Runtime::init_web_m2(is_server) {
            Ok(()) => {
                check is_server {
                    // ── SERVER MODE ───────────────────────────────────────────────────

                    println("🖥️  Running Task Manager Server");

                    let routes = HashMap::from([
                        ("GET /api/tasks".into(), TaskServer::handle_get_tasks as RouteHandler),
                        ("POST /api/tasks".into(), TaskServer::handle_create_task as RouteHandler),
                        ("GET /*".into(), TaskServer::handle_static_file as RouteHandler),
                    ]);

                    match HttpServerM2::http_listen(3000, routes) {
                        Ok(()) => {
                            println("🚀 Server running at http://localhost:3000");
                            // In real implementation: Run event loop
                            Runtime::run_m1(|| 0)
                        }
                        Err(e) => {
                            println("❌ Server failed: {}", e);
                            yield 1;
                        }
                    }
                } else {
                    // ── CLIENT MODE ───────────────────────────────────────────────────

                    println("🌐 Running Task Manager Client");

                    // Setup UI
                    TaskClient::setup_ui();

                    // Initial render
                    TaskClient::render_tasks();

                    // In real WASM: This would be the main browser event loop
                    println("🎨 Client initialized, ready for user interaction");
                    yield 0;
                }
            }
            Err(e) => {
                println("❌ Web runtime init failed: {}", e);
                yield 1;
            }
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §6  M2 PROTOTYPE DEMO
// ══════════════════════════════════════════════════════════════════════════════

impl WebM2Demo {

    open fn demo_web_m2() -> i32 {
        println("🌐 NOVA WEB M2 PROTOTYPE DEMONSTRATION");
        println("   Web Profile: WASM Client + HTTP Server");
        println("   Built on M1 Foundation");
        println();

        // ── Phase 1: Shared Business Logic ─────────────────────────────────────

        println("📊 Phase 1: Testing Shared Business Logic");

        let test_user = SharedBusinessLogic::User {
            id: 1,
            name: "Nova".into(),
            email: "nova@web-lang.org".into(),
        };

        match SharedBusinessLogic::validate_user(test_user) {
            Ok(validated) => println("✅ User validation passed: {}", validated.name),
            Err(errors) => {
                println("❌ Validation failed:");
                each error in errors {
                    println("   {}: {}", error.field, error.message);
                }
            }
        }

        // ── Phase 2: Server Simulation ─────────────────────────────────────────

        println("\n🖥️  Phase 2: HTTP Server Simulation");

        let mock_request = HttpServerM2::HttpRequest {
            method: "GET".into(),
            path: "/api/tasks".into(),
            headers: HashMap::new(),
            body: None,
        };

        let response = TaskManagerM2::TaskServer::handle_get_tasks(mock_request);
        println("📡 Mock API response: HTTP {} - {} bytes", response.status, response.body.len());

        // ── Phase 3: Client Simulation ─────────────────────────────────────────

        println("\n🌐 Phase 3: WASM Client Simulation");

        // Simulate DOM operations
        match WasmClientM2::dom_get_element_by_id("test-element".into()) {
            Ok(_) => println("✅ DOM element found"),
            Err(e) => println("ℹ️  DOM API: {}", e),
        }

        // Simulate HTTP client
        match WasmClientM2::fetch("/api/test".into(), "GET".into(), None) {
            Ok(_) => println("✅ HTTP fetch initiated"),
            Err(e) => println("ℹ️  HTTP client: {}", e),
        }

        // ── Phase 4: End-to-End Flow ──────────────────────────────────────────

        println("\n🔄 Phase 4: End-to-End Flow Simulation");

        let user_input = json_serialize(SharedBusinessLogic::User {
            id: 2,
            name: "Web".into(),
            email: "web@nova.org".into(),
        });

        match SharedBusinessLogic::process_user_data(user_input) {
            Ok(user) => {
                println("✅ End-to-end validation: {} <{}>", user.name, user.email);

                // Simulate creating a task with this user data
                let task_response = TaskManagerM2::TaskServer::handle_create_task(
                    HttpServerM2::HttpRequest {
                        method: "POST".into(),
                        path: "/api/tasks".into(),
                        headers: HashMap::new(),
                        body: Some(json_serialize(user)),
                    }
                );

                println("✅ Task creation response: HTTP {}", task_response.status);
            }
            Err(e) => println("❌ End-to-end flow failed: {}", e)
        }

        // ── Phase 5: Summary ──────────────────────────────────────────────────

        println("\n🎯 M2 WEB PROTOTYPE RESULTS:");
        println("   ✅ Shared business logic validation");
        println("   ✅ HTTP server API simulation");
        println("   ✅ WASM client DOM simulation");
        println("   ✅ End-to-end data flow");
        println("   ✅ Type safety across client/server boundary");
        println();
        println("🚀 READY FOR:");
        println("   Real WASM compilation + JS interop");
        println("   Native HTTP server implementation");
        println("   Fullstack task manager application");
        println("   WebSocket real-time features");

        yield 0;
    }
}

