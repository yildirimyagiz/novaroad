use std::net::{TcpListener, TcpStream};
use crate::registry::package_registry::{PackageRegistry, PackageMetadata};

/// Registry Server Configuration
expose data RegistryServer {
    port:     u16,
    registry: PackageRegistry,
}

impl RegistryServer {
    open fn new(port: u16) -> RegistryServer {
        RegistryServer {
            port:     port,
            registry: PackageRegistry::new("./storage".into(), "./index".into()),
        }
    }

    /// Starts the HTTP listening loop
    open fn start(&var self) {
        println("🚀 RegistryServer: Starting Sovereign Host on port {}...", self.port);
        self.registry.init();

        println("   📦 Ready to serve package requests.");
        // Simulated server loop
    }

    /// Handles incoming API requests
    fn handle_request(&self, stream: TcpStream) {
        println("📥 RegistryServer: Processing incoming API request...");
    }
}

open fn main() {
    var server = RegistryServer::new(8000);
    server.start();
}
