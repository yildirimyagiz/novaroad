// 📱 Nova Mobile Library — v10.0
// High-level constructs for building autonomous, cross-platform mobile applications.
// Bridges UIKit (iOS), Android View (Android), and Aurora (Nova native renderer).
//
// Syntax: open space / open use

open space app;
open space ui;
open space sensors;
open space storage;

open use app::{MobileApp, AppDelegate, AppState, AppTheme, Screen, NavigationBar, BarItem, BackgroundTask};
open use ui::{MobileView, ViewKind, Style, Dimension, EdgeInsets, Color, Alignment, ImageSource, PlatformSelector};
open use sensors::{SensorManager, SensorData, SensorType, Vector3, Location, AmbientLight, BarometerReading};
open use storage::{MobileStorage, StorageKind, StorageError, MobileDatabase};

open fn init() {
    println("📱 Nova Mobile Library v10.0: Cross-Platform, Intent-First, Native Performance.");
    println("  ├── UI Engine: Aurora Renderer");
    println("  ├── Sensors:   9-DoF IMU + GPS + Baro Fusion");
    println("  ├── Storage:   Preferences / SQLite / KeyChain (AES-256)");
    println("  └── Lifecycle: Full AppDelegate + Background Task Management");
}
