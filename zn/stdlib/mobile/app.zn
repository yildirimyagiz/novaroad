// 📱 Nova Mobile — Application Engine — v10.0
// Core application lifecycle, navigation, theming, and background task management.
//
// Syntax: data / cases / rules / flow / yield / check / each / match / spawn / @extern

use super::ui::{MobileView, Style};
use super::sensors::SensorManager;
use std::collections::Vec;

// ═══════════════════════════════════════════════════════════════════════════════
// §1  APP CORE
// ═══════════════════════════════════════════════════════════════════════════════

open data MobileApp {
    open name:         String,
    open root:         MobileView,
    open delegate:     Option<Box<dyn AppDelegate>>,
    open nav_stack:    Vec<Screen>,
    open theme:        AppTheme,
    open state:        AppState,
    open bg_tasks:     Vec<BackgroundTask>,
}

open rules AppDelegate {
    fn on_launch(&var self);
    fn on_terminate(&var self);
    fn on_background(&var self);
    fn on_foreground(&var self);
    fn on_memory_warning(&var self);
    fn on_deep_link(&var self, url: &str);
}

open cases AppState {
    NotYetRunning,
    Active,
    Inactive,
    Background,
    Suspended,
}

open data Screen {
    open title:   String,
    open view:    MobileView,
    open nav_bar: Option<NavigationBar>,
}

open data NavigationBar {
    open title:  String,
    open tint:   String, // hex
    open items:  Vec<BarItem>,
}

open data BarItem {
    open label:    String,
    open icon:     Option<String>,
    open on_press: Option<fn()>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// §2  THEMING
// ═══════════════════════════════════════════════════════════════════════════════

open data AppTheme {
    open primary:          String, // hex
    open secondary:        String,
    open background:       String,
    open surface:          String,
    open on_primary:       String, // text on primary
    open on_background:    String,
    open corner_radius:    f32,
    open is_dark:          bool,
}

impl AppTheme {
    open fn nova_dark() -> AppTheme {
        AppTheme {
            primary:       "#6C5CE7".into(),
            secondary:     "#00CEC9".into(),
            background:    "#0F0F1A".into(),
            surface:       "#1A1A2E".into(),
            on_primary:    "#FFFFFF".into(),
            on_background: "#E0E0E0".into(),
            corner_radius: 12.0,
            is_dark:       true,
        };
    }

    open fn nova_light() -> AppTheme {
        AppTheme {
            primary:       "#6C5CE7".into(),
            secondary:     "#00B894".into(),
            background:    "#FAFAFA".into(),
            surface:       "#FFFFFF".into(),
            on_primary:    "#FFFFFF".into(),
            on_background: "#2D3436".into(),
            corner_radius: 12.0,
            is_dark:       false,
        };
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// §3  BACKGROUND TASKS
// ═══════════════════════════════════════════════════════════════════════════════

open data BackgroundTask {
    open id:       String,
    open interval: i64,    // seconds
    open active:   bool,
}

impl BackgroundTask {
    open fn new(id: &str, interval: i64) -> BackgroundTask {
        BackgroundTask {
            id:       id.into(),
            interval: interval,
            active:   false,
        };
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// §4  APP RUNTIME
// ═══════════════════════════════════════════════════════════════════════════════

impl MobileApp {
    open fn new(name: &str, root: MobileView) -> MobileApp {
        MobileApp {
            name:      name.into(),
            root,
            delegate:  None,
            nav_stack: [],
            theme:     AppTheme::nova_dark(),
            state:     AppState::NotYetRunning,
            bg_tasks:  [],
        };
    }

    open fn push_screen(&var self, screen: Screen) {
        self.nav_stack.push(screen);
        @extern("nova_mobile_push_screen", &self.nav_stack);
    }

    open fn pop_screen(&var self) {
        self.nav_stack.pop();
        @extern("nova_mobile_pop_screen", &self.nav_stack);
    }

    open fn register_bg_task(&var self, task: BackgroundTask) {
        @extern("nova_mobile_register_bg_task", &task);
        self.bg_tasks.push(task);
    }

    open fn run(&var self) {
        println(format("📱 Launching app: {} (Theme: {})", self.name,
            check self.theme.is_dark { "Dark" } else { "Light" }));
        
        self.state = AppState::Active;
        
        match &var self.delegate {
            Some(d) => d.on_launch(),
            None    => {}
        }

        @extern("nova_mobile_app_run", &self.root, &self.theme);
    }
}
