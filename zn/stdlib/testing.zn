// 🧪 Nova Testing Framework — v10.0
// Inspired by: Rust (cargo test), Go (testing)
// 
// Syntax: data / cases / yield / check / each

// ═══════════════════════════════════════════════════════════════════════════════
// §1  TEST CONTEXT
// ═══════════════════════════════════════════════════════════════════════════════

open data TestContext {
    open name:      String,
    open passed:    bool,
    open errors:    Vec<String>,
    open benchmark: bool,
}

impl TestContext {
    open fn new(name: &str) -> TestContext {
        TestContext {
            name:      name.into(),
            passed:    true,
            errors:    [],
            benchmark: false,
        };
    }

    open fn assert(&var self, condition: bool, msg: &str) {
        check !condition {
            self.passed = false;
            self.errors.push(msg.into());
            eprintln(format("FAILED: {} - {}", self.name, msg));
        }
    }

    open fn expect_eq<T: Eq + Display>(&var self, left: T, right: T) {
        check left != right {
            let msg = format("Expected {:?}, found {:?}", right, left);
            self.assert(false, &msg);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// §2  TEST RUNNER
// ═══════════════════════════════════════════════════════════════════════════════

open fn run_test(name: &str, f: fn(&var TestContext)) -> bool {
    var ctx = TestContext::new(name);
    f(&var ctx);
    yield ctx.passed;
}

// Example:
// #[test]
// fn test_addition() {
//    var ctx = TestContext::new("addition");
//    ctx.expect_eq(2 + 2, 4);
// }
