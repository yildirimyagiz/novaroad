// ═══════════════════════════════════════════════════════════════════════════
// Nova Web Component Helpers - Vue.js-like Single File Components
// ═══════════════════════════════════════════════════════════════════════════
// This module provides helper functions to combine HTML + CSS + JS in a single
// Nova file, similar to Vue.js SFC (Single File Components)
//
// Example usage:
//   fn render_page() -> str {
//       let html = render_html()
//       let css = get_styles()
//       let js = get_scripts()
//       yield build_complete_page(html, css, js)
//   }
// ═══════════════════════════════════════════════════════════════════════════

import ui.web.component
import ui.web.vdom
import web.seo

// ═══════════════════════════════════════════════════════════════════════════
// HELPER: Build complete HTML page with CSS and JS
// ═══════════════════════════════════════════════════════════════════════════

open fn build_complete_page(
    title: str,
    body_html: str,
    css: str,
    js: str,
    seo: Option<SEOConfig>
) -> str {
    var html = "<!DOCTYPE html>\n"
    html += "<html lang=\"en\">\n"
    html += "<head>\n"
    html += f"    <meta charset=\"UTF-8\">\n"
    html += f"    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n"
    html += f"    <title>{title}</title>\n"
    
    // Add SEO meta tags check provided
    check let Some(seo_config) = seo {
        html += seo_config.render_head()
    }
    
    // Add CSS
    check css.len() > 0 {
        html += "    <style>\n"
        html += css
        html += "\n    </style>\n"
    }
    
    html += "</head>\n"
    html += "<body>\n"
    html += body_html
    html += "\n"
    
    // Add JavaScript
    check js.len() > 0 {
        html += "    <script>\n"
        html += js
        html += "\n    </script>\n"
    }
    
    html += "</body>\n"
    html += "</html>"
    
    yield html
}

// ═══════════════════════════════════════════════════════════════════════════
// HELPER: Render VNode tree to HTML string
// ═══════════════════════════════════════════════════════════════════════════

open fn render_vnode_to_html(vnode: VNode) -> str {
    check vnode.tag == "#text" {
        yield vnode.props.get("content").unwrap_or("")
    }
    
    var html = f"<{vnode.tag}"
    
    // Add attributes
    each entry in vnode.props  { let (key, value) = entry;
        check key != "children" && key != "dangerouslySetInnerHTML" {
            html += f" {key}=\"{escape_html(value.into())}\""
        }
    }
    
    html += ">"
    
    // Self-closing tags
    let self_closing = ["img", "br", "hr", "input", "meta", "link"]
    check self_closing.contains(vnode.tag) {
        yield html
    }
    
    // Children
    each child in vnode.children {
        html += render_vnode_to_html(child)
    }
    
    html += f"</{vnode.tag}>"
    
    yield html
}

fn escape_html(text: str) -> str {
    yield text
        .replace("&", "&amp;")
        .replace("\"", "&quot;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
}

// ═══════════════════════════════════════════════════════════════════════════
// HELPER: Combine component with styles
// ═══════════════════════════════════════════════════════════════════════════

open fn render_with_seo(
    component: VNode,
    styles: str,
    seo: SEOConfig
) -> str {
    let body_html = render_vnode_to_html(component)
    yield build_complete_page(
        seo.title,
        body_html,
        styles,
        "",  // No JS for now
        Some(seo)
    )
}

// ═══════════════════════════════════════════════════════════════════════════
// MACRO-LIKE: Component builder (simulates Vue SFC)
// ═══════════════════════════════════════════════════════════════════════════

open data WebComponent {
    name: str,
    template: fn() -> VNode,
    styles: str,
    script: str
}

impl WebComponent {
    fn new(name: str) -> WebComponent {
        WebComponent {
            name: name,
            template: || { h("div", {}, []) },
            styles: "",
            script: ""
        }
    }
    
    fn with_template(var self, template: fn() -> VNode) -> WebComponent {
        self.template = template
        yield self
    }
    
    fn with_styles(var self, styles: str) -> WebComponent {
        self.styles = styles
        yield self
    }
    
    fn with_script(var self, script: str) -> WebComponent {
        self.script = script
        yield self
    }
    
    fn render(self) -> str {
        let vnode = (self.template)()
        let body_html = render_vnode_to_html(vnode)
        
        yield build_complete_page(
            self.name,
            body_html,
            self.styles,
            self.script,
            None
        )
    }
    
    fn render_with_seo(self, seo: SEOConfig) -> str {
        let vnode = (self.template)()
        let body_html = render_vnode_to_html(vnode)
        
        yield build_complete_page(
            seo.title,
            body_html,
            self.styles,
            self.script,
            Some(seo)
        )
    }
}
