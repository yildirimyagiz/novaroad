// 🚀 Nova Web Framework — v10.0
// Combines best of Fresh.js, Hono, and Next.js with high-performance SSR.
//
// Syntax: data / cases / flow / yield / check / each

use super::http::{Request, Response, Method};
use std::collections::{HashMap, Vec};

// ═══════════════════════════════════════════════════════════════════════════════
// §1  TYPES & MODES
// ═══════════════════════════════════════════════════════════════════════════════

open cases RenderMode {
    SSR, // Server-Side Rendering
    SSG, // Static Site Generation
    ISR, // Incremental Static Regeneration
}

open data Context {
    open req:    Request,
    open res:    Response,
    open params: HashMap<String, String>,
    open state:  HashMap<String, any>,
}

open data Route {
    open method: Method,
    open path:   String,
    open handler: fn(Context) -> Response,
    open mode:   Option<RenderMode>,
}

// ═══════════════════════════════════════════════════════════════════════════════
// §2  APPLICATION ORCHESTRATOR
// ═══════════════════════════════════════════════════════════════════════════════

open data App {
    open routes:     Vec<Route>,
    open middleware: Vec<fn(Context) -> Context>,
    open base_url:   String,
}

impl App {
    open fn new(base_url: &str) -> App {
        App {
            routes:     [],
            middleware: [],
            base_url:   base_url.into(),
        };
    }

    /// Register a GET handler
    open fn get(&var self, path: &str, handler: fn(Context) -> Response) {
        self.routes.push(Route {
            method: Method::GET,
            path:   path.into(),
            handler,
            mode:   None,
        });
    }

    /// Register a POST handler
    open fn post(&var self, path: &str, handler: fn(Context) -> Response) {
        self.routes.push(Route {
            method: Method::POST,
            path:   path.into(),
            handler,
            mode:   None,
        });
    }

    /// SSR Page Registration (Next.js-style)
    open fn page(&var self, path: &str, component: fn(any) -> String) {
        self.routes.push(Route {
            method: Method::GET,
            path:   path.into(),
            handler: |ctx| {
                // In a real impl, this would use ssr::render_page
                Response::ok(component(ctx.state))
            },
            mode: Some(RenderMode::SSR),
        });
    }

    /// Start the server
    open fn listen(&self, port: i32) {
        println(format("🚀 Nova App listening on http://localhost:{}", port));
        // Native runtime call would happen here
    }

}

open fn main() {
    println("🌐 Nova Web Framework — v10.0 Active");
}
