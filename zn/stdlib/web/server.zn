// Nova Web - Async HTTP Server
// "The replacement for FastAPI/Express."
// High-concurrency networking stack.

import std.network.socket

open data Request {
    method: str
    path: str
    headers: map<str, str>,
    body: str
}

open data Response {
    status: u16
    body: str
}

open data WebServer {
    port: u16
    routes: map<str, fn(Request)->Response>
}

impl WebServer {
    fn new() -> WebServer {
        WebServer { port: 8080, routes: {} }
    }

    fn get(var self, path: str, handler: fn(Request)->Response) {
        self.routes["GET:" + path] = handler
    }
    
    fn post(var self, path: str, handler: fn(Request)->Response) {
        self.routes["POST:" + path] = handler
    }

    async fn listen(self, port: u16) {
        std.console.log("🚀 Server flying on port " + port)
        let listener = Socket.bind(port)
        
        loop {
            let conn = listener.accept().await
            // Spawn separate task for each connection (Non-blocking I/O)
            async {
                self.handle_connection(conn)
            }
        }
    }

    fn handle_connection(self, conn: Connection) {
        let raw = conn.read()
        let req = self.parse_http(raw)
        let key = req.method + ":" + req.path
        
        let response = check self.routes.has(key) {
            self.routes[key](req)
        } else {
            Response { status: 404, body: "Not Found in Nova" }
        }
        
        conn.write(self.serialize_response(response))
        conn.close()
    }
    
    // ... Parsing logic omitted
}
