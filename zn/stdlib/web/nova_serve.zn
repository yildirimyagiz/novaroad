// 🚀 Nova-Serve — Sovereign High-Performance Server
// Direct socket-to-component integration for 0ms cold starts.

use net::http;
use web::ssr;
use web::seo;

/// Sovereign Web Server Configuration
open data ServerConfig {
    port:    i16,
    host:    String,
    threads: i16,
}

/// Global Page Registry for ISR and SSG
open data PageRegistry {
    pages: Map<String, ssr::PageConfig>,
}

impl PageRegistry {
    open fn new() -> PageRegistry {
        PageRegistry { pages: Map::new() }
    }

    open fn register(&var self, config: ssr::PageConfig) {
        self.pages.insert(config.path.clone(), config);
    }
}

/// The Orchestrator
open data WebServer {
    config:   ServerConfig,
    registry: PageRegistry,
}

impl WebServer {
    open fn new(port: i16) -> WebServer {
        WebServer {
            config: ServerConfig {
                port:    port,
                host:    "0.0.0.0".into(),
                threads: 8,
            },
            registry: PageRegistry::new(),
        }
    }

    /// Handles incoming HTTP Requests and dispatches to SSR engine
    open fn handle_request(&self, req: http::HttpRequest) -> http::HttpResponse {
        let path = req.path.clone();

        check let Some(config) = self.registry.pages.get(&path) {
            let html = ssr::render_page(config, Map::new());
            yield http::HttpResponse::ok(html);
        }

        http::HttpResponse::not_found("404 Page Not Found".into())
    }

    /// Starts the production-grade sovereign server
    open async fn start(&self) {
        println("🔥 Nova-Serve starting on {}:{}", self.config.host, self.config.port);
        
        // Create HTTP server
        let listener = http::TcpListener::bind(
            format("{}:{}", self.config.host, self.config.port)
        ).await?;
        
        println("✅ Server listening on http://{}:{}", self.config.host, self.config.port);
        
        // Accept connections loop
        loop {
            let (stream, addr) = listener.accept().await?;
            let server_ref = self.clone();
            
            // Spawn task for each connection
            spawn(async move {
                server_ref.handle_connection(stream).await;
            });
        }
    }
    
    /// Handle individual connection
    async fn handle_connection(&self, var stream: http::TcpStream) {
        var buffer = [0; 1024];
        stream.read(&var buffer).await?;
        
        let request_str = String::from_utf8_lossy(&buffer);
        let req = http::parse_request(&request_str);
        
        let response = self.handle_request(req);
        
        stream.write_all(response.as_bytes()).await?;
        stream.flush().await?;
    }
}

open fn main() {
    println("🚀 Nova-Serve Engine — Sovereign v8.0 Active");
}
