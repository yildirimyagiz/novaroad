// C FFI Support
// Call C functions from Nova

// External C function declarations
extern "C" {
    fn printf(fmt: *const u8, ...) -> i32;
    fn malloc(size: usize) -> *var u8;
    fn free(ptr: *var u8);
    fn strlen(s: *const u8) -> usize;
}

// Safe wrapper for printf
fn print_c(msg: String) -> i32 {
    unsafe {
        yield printf(msg.as_ptr());
    }
}

// Safe wrapper for malloc
fn allocate(size: usize) -> *var u8 {
    unsafe {
        yield malloc(size);
    }
}

// Safe wrapper for free
fn deallocate(ptr: *var u8) {
    unsafe {
        free(ptr);
    }
}

// String conversion
fn string_to_c(s: String) -> *const u8 {
    yield s.as_ptr();
}

fn c_to_string(ptr: *const u8) -> String {
    unsafe {
        let len = strlen(ptr);
        yield String::from_raw_parts(ptr, len);
    }
}

// Example usage
fn main() -> i32 {
    // Call C printf
    print_c("Hello from Nova via C!\n");
    
    // Allocate memory
    let ptr = allocate(100);
    
    // Use memory...
    
    // Free memory
    deallocate(ptr);
    
    yield 0;
}
