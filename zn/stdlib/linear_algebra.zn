// 🧮 Nova Linear Algebra — v10.0
// Matrix and vector operations with performance optimization
// + Nova Magic: SIMD acceleration, GPU support

@module("linear::algebra")
@reproducible
@export
@inline

use std::collections::{HashMap, Vec};
use std::sync::Arc;
use std::result::Result;

// ═══════════════════════════════════════════════════════════════════════════
// §1  LINEAR ALGEBRA CORE TYPES
// ═══════════════════════════════════════════════════════════════════════════

/// Linear algebra error
open cases LinalgError {
    DimensionMismatch(String),
    SingularMatrix,
    NonSquareMatrix,
    InvalidIndex,
    NumericalError(String),
    InsufficientMemory,
}

impl LinalgError {
    open fn to_string(&self) -> String {
        match self {
            LinalgError::DimensionMismatch(msg) => format!("Dimension mismatch: {}", msg),
            LinalgError::SingularMatrix => "Singular matrix (non-invertible)".into(),
            LinalgError::NonSquareMatrix => "Matrix must be square".into(),
            LinalgError::InvalidIndex => "Invalid matrix index".into(),
            LinalgError::NumericalError(msg) => format!("Numerical error: {}", msg),
            LinalgError::InsufficientMemory => "Insufficient memory".into(),
        }
    }
}

/// Linear algebra result
open type LinalgResult<T> = Result<T, LinalgError>;

/// Vector
open data Vector {
    data: Vec<f64>,
    size: usize,
}

impl Vector {
    open fn new(size: usize) -> Vector {
        return Vector {
            data: vec![0.0; size],
            size: size,
        };
    }
    
    open fn from_data(data: Vec<f64>) -> Vector {
        let size = data.len();
        return Vector {
            data: data,
            size: size,
        };
    }
    
    open fn zeros(size: usize) -> Vector {
        return Vector::new(size);
    }
    
    open fn ones(size: usize) -> Vector {
        return Vector {
            data: vec![1.0; size],
            size: size,
        };
    }
    
    open fn random(size: usize) -> Vector {
        let mut data = Vec::with_capacity(size);
        for _ in 0..size {
            data.push(rand::random::<f64>() * 2.0 - 1.0);
        }
        return Vector::from_data(data);
    }
    
    open fn get(&self, index: usize) -> LinalgResult<f64> {
        if index < self.size {
            return Ok(self.data[index]);
        } else {
            return Err(LinalgError::InvalidIndex);
        }
    }
    
    open fn set(&mut self, index: usize, value: f64) -> LinalgResult<()> {
        if index < self.size {
            self.data[index] = value;
            return Ok(());
        } else {
            return Err(LinalgError::InvalidIndex);
        }
    }
    
    open fn len(&self) -> usize {
        return self.size;
    }
    
    open fn is_empty(&self) -> bool {
        return self.size == 0;
    }
    
    open fn norm(&self) -> f64 {
        let mut sum = 0.0;
        for &value in &self.data {
            sum += value * value;
        }
        return sum.sqrt();
    }
    
    open fn norm_squared(&self) -> f64 {
        let mut sum = 0.0;
        for &value in &self.data {
            sum += value * value;
        }
        return sum;
    }
    
    open fn normalize(&self) -> LinalgResult<Vector> {
        let norm = self.norm();
        if norm > 1e-10 {
            let mut result = Vector::new(self.size);
            for i in 0..self.size {
                result.data[i] = self.data[i] / norm;
            }
            return Ok(result);
        } else {
            return Err(LinalgError::NumericalError("Cannot normalize zero vector".into()));
        }
    }
    
    open fn dot(&self, other: &Vector) -> LinalgResult<f64> {
        if self.size != other.size {
            return Err(LinalgError::DimensionMismatch("Vector sizes must match".into()));
        }
        
        let mut result = 0.0;
        for i in 0..self.size {
            result += self.data[i] * other.data[i];
        }
        return Ok(result);
    }
    
    open fn add(&self, other: &Vector) -> LinalgResult<Vector> {
        if self.size != other.size {
            return Err(LinalgError::DimensionMismatch("Vector sizes must match".into()));
        }
        
        let mut result = Vector::new(self.size);
        for i in 0..self.size {
            result.data[i] = self.data[i] + other.data[i];
        }
        return Ok(result);
    }
    
    open fn sub(&self, other: &Vector) -> LinalgResult<Vector> {
        if self.size != other.size {
            return Err(LinalgError::DimensionMismatch("Vector sizes must match".into()));
        }
        
        let mut result = Vector::new(self.size);
        for i in 0..self.size {
            result.data[i] = self.data[i] - other.data[i];
        }
        return Ok(result);
    }
    
    open fn scale(&self, scalar: f64) -> Vector {
        let mut result = Vector::new(self.size);
        for i in 0..self.size {
            result.data[i] = self.data[i] * scalar;
        }
        return result;
    }
    
    open fn cross(&self, other: &Vector) -> LinalgResult<Vector> {
        if self.size != 3 || other.size != 3 {
            return Err(LinalgError::DimensionMismatch("Cross product requires 3D vectors".into()));
        }
        
        let mut result = Vector::new(3);
        result.data[0] = self.data[1] * other.data[2] - self.data[2] * other.data[1];
        result.data[1] = self.data[2] * other.data[0] - self.data[0] * other.data[2];
        result.data[2] = self.data[0] * other.data[1] - self.data[1] * other.data[0];
        
        return Ok(result);
    }
    
    open fn angle(&self, other: &Vector) -> LinalgResult<f64> {
        let dot_product = self.dot(other)?;
        let norm_product = self.norm() * other.norm();
        
        if norm_product > 1e-10 {
            let cos_angle = (dot_product / norm_product).max(-1.0).min(1.0);
            return Ok(cos_angle.acos());
        } else {
            return Err(LinalgError::NumericalError("Cannot compute angle with zero vector".into()));
        }
    }
    
    open fn project(&self, onto: &Vector) -> LinalgResult<Vector> {
        let onto_norm_squared = onto.norm_squared();
        if onto_norm_squared > 1e-10 {
            let dot_product = self.dot(onto)?;
            let scalar = dot_product / onto_norm_squared;
            return Ok(onto.scale(scalar));
        } else {
            return Err(LinalgError::NumericalError("Cannot project onto zero vector".into()));
        }
    }
    
    open fn to_string(&self) -> String {
        let mut result = String::from("[");
        for i in 0..self.size {
            if i > 0 {
                result.push_str(", ");
            }
            result.push_str(&format!("{:.6}", self.data[i]));
        }
        result.push_str("]");
        return result;
    }
}

/// Matrix
open data Matrix {
    data: Vec<f64>,
    rows: usize,
    cols: usize,
}

impl Matrix {
    open fn new(rows: usize, cols: usize) -> Matrix {
        return Matrix {
            data: vec![0.0; rows * cols],
            rows: rows,
            cols: cols,
        };
    }
    
    open fn from_data(rows: usize, cols: usize, data: Vec<f64>) -> Matrix {
        if data.len() != rows * cols {
            panic!("Data size must match rows * cols");
        }
        return Matrix {
            data: data,
            rows: rows,
            cols: cols,
        };
    }
    
    open fn zeros(rows: usize, cols: usize) -> Matrix {
        return Matrix::new(rows, cols);
    }
    
    open fn ones(rows: usize, cols: usize) -> Matrix {
        return Matrix {
            data: vec![1.0; rows * cols],
            rows: rows,
            cols: cols,
        };
    }
    
    open fn identity(size: usize) -> Matrix {
        let mut matrix = Matrix::zeros(size, size);
        for i in 0..size {
            matrix.data[i * size + i] = 1.0;
        }
        return matrix;
    }
    
    open fn random(rows: usize, cols: usize) -> Matrix {
        let mut data = Vec::with_capacity(rows * cols);
        for _ in 0..(rows * cols) {
            data.push(rand::random::<f64>() * 2.0 - 1.0);
        }
        return Matrix::from_data(rows, cols, data);
    }
    
    open fn get(&self, row: usize, col: usize) -> LinalgResult<f64> {
        if row < self.rows && col < self.cols {
            return Ok(self.data[row * self.cols + col]);
        } else {
            return Err(LinalgError::InvalidIndex);
        }
    }
    
    open fn set(&mut self, row: usize, col: usize, value: f64) -> LinalgResult<()> {
        if row < self.rows && col < self.cols {
            self.data[row * self.cols + col] = value;
            return Ok(());
        } else {
            return Err(LinalgError::InvalidIndex);
        }
    }
    
    open fn rows(&self) -> usize {
        return self.rows;
    }
    
    open fn cols(&self) -> usize {
        return self.cols;
    }
    
    open fn size(&self) -> (usize, usize) {
        return (self.rows, self.cols);
    }
    
    open fn is_square(&self) -> bool {
        return self.rows == self.cols;
    }
    
    open fn transpose(&self) -> Matrix {
        let mut result = Matrix::new(self.cols, self.rows);
        for i in 0..self.rows {
            for j in 0..self.cols {
                result.data[j * self.rows + i] = self.data[i * self.cols + j];
            }
        }
        return result;
    }
    
    open fn add(&self, other: &Matrix) -> LinalgResult<Matrix> {
        if self.rows != other.rows || self.cols != other.cols {
            return Err(LinalgError::DimensionMismatch("Matrix dimensions must match".into()));
        }
        
        let mut result = Matrix::new(self.rows, self.cols);
        for i in 0..(self.rows * self.cols) {
            result.data[i] = self.data[i] + other.data[i];
        }
        return Ok(result);
    }
    
    open fn sub(&self, other: &Matrix) -> LinalgResult<Matrix> {
        if self.rows != other.rows || self.cols != other.cols {
            return Err(LinalgError::DimensionMismatch("Matrix dimensions must match".into()));
        }
        
        let mut result = Matrix::new(self.rows, self.cols);
        for i in 0..(self.rows * self.cols) {
            result.data[i] = self.data[i] - other.data[i];
        }
        return Ok(result);
    }
    
    open fn scale(&self, scalar: f64) -> Matrix {
        let mut result = Matrix::new(self.rows, self.cols);
        for i in 0..(self.rows * self.cols) {
            result.data[i] = self.data[i] * scalar;
        }
        return result;
    }
    
    open fn multiply(&self, other: &Matrix) -> LinalgResult<Matrix> {
        if self.cols != other.rows {
            return Err(LinalgError::DimensionMismatch("Matrix dimensions incompatible".into()));
        }
        
        let mut result = Matrix::new(self.rows, other.cols);
        
        for i in 0..self.rows {
            for j in 0..other.cols {
                let mut sum = 0.0;
                for k in 0..self.cols {
                    sum += self.data[i * self.cols + k] * other.data[k * other.cols + j];
                }
                result.data[i * other.cols + j] = sum;
            }
        }
        
        return Ok(result);
    }
    
    open fn multiply_vector(&self, vector: &Vector) -> LinalgResult<Vector> {
        if self.cols != vector.size {
            return Err(LinalgError::DimensionMismatch("Matrix columns must match vector size".into()));
        }
        
        let mut result = Vector::new(self.rows);
        for i in 0..self.rows {
            let mut sum = 0.0;
            for j in 0..self.cols {
                sum += self.data[i * self.cols + j] * vector.data[j];
            }
            result.data[i] = sum;
        }
        
        return Ok(result);
    }
    
    open fn determinant(&self) -> LinalgResult<f64> {
        if !self.is_square() {
            return Err(LinalgError::NonSquareMatrix);
        }
        
        return self.determinant_recursive();
    }
    
    fn determinant_recursive(&self) -> LinalgResult<f64> {
        if self.rows == 1 {
            return Ok(self.data[0]);
        }
        
        if self.rows == 2 {
            return Ok(self.data[0] * self.data[3] - self.data[1] * self.data[2]);
        }
        
        let mut det = 0.0;
        for j in 0..self.cols {
            let cofactor = self.cofactor(0, j)?;
            det += self.data[j] * cofactor;
        }
        
        return Ok(det);
    }
    
    open fn cofactor(&self, row: usize, col: usize) -> LinalgResult<f64> {
        let minor = self.minor(row, col)?;
        let sign = if (row + col) % 2 == 0 { 1.0 } else { -1.0 };
        return Ok(sign * minor.determinant()?);
    }
    
    open fn minor(&self, row: usize, col: usize) -> LinalgResult<Matrix> {
        if row >= self.rows || col >= self.cols {
            return Err(LinalgError::InvalidIndex);
        }
        
        let mut result = Matrix::new(self.rows - 1, self.cols - 1);
        let mut result_index = 0;
        
        for i in 0..self.rows {
            for j in 0..self.cols {
                if i != row && j != col {
                    result.data[result_index] = self.data[i * self.cols + j];
                    result_index += 1;
                }
            }
        }
        
        return Ok(result);
    }
    
    open fn inverse(&self) -> LinalgResult<Matrix> {
        if !self.is_square() {
            return Err(LinalgError::NonSquareMatrix);
        }
        
        let det = self.determinant()?;
        if det.abs() < 1e-10 {
            return Err(LinalgError::SingularMatrix);
        }
        
        let size = self.rows;
        let mut result = Matrix::new(size, size);
        
        for i in 0..size {
            for j in 0..size {
                let cofactor = self.cofactor(i, j)?;
                result.data[j * size + i] = cofactor / det; // Transpose the cofactor matrix
            }
        }
        
        return Ok(result);
    }
    
    open fn trace(&self) -> LinalgResult<f64> {
        if !self.is_square() {
            return Err(LinalgError::NonSquareMatrix);
        }
        
        let mut sum = 0.0;
        for i in 0..self.rows {
            sum += self.data[i * self.cols + i];
        }
        return Ok(sum);
    }
    
    open fn norm(&self) -> f64 {
        let mut sum = 0.0;
        for &value in &self.data {
            sum += value * value;
        }
        return sum.sqrt();
    }
    
    open fn frobenius_norm(&self) -> f64 {
        return self.norm();
    }
    
    open fn rank(&self) -> usize {
        // Simplified rank computation using Gaussian elimination
        let mut working = self.clone();
        let mut rank = 0;
        let mut row = 0;
        let mut col = 0;
        
        while row < working.rows && col < working.cols {
            // Find pivot
            let mut pivot_row = row;
            for i in (row + 1)..working.rows {
                if working.data[i * working.cols + col].abs() > 
                   working.data[pivot_row * working.cols + col].abs() {
                    pivot_row = i;
                }
            }
            
            if working.data[pivot_row * working.cols + col].abs() > 1e-10 {
                // Swap rows
                if pivot_row != row {
                    for j in col..working.cols {
                        let temp = working.data[row * working.cols + j];
                        working.data[row * working.cols + j] = working.data[pivot_row * working.cols + j];
                        working.data[pivot_row * working.cols + j] = temp;
                    }
                }
                
                // Eliminate column
                let pivot = working.data[row * working.cols + col];
                for i in (row + 1)..working.rows {
                    let factor = working.data[i * working.cols + col] / pivot;
                    for j in col..working.cols {
                        working.data[i * working.cols + j] -= factor * working.data[row * working.cols + j];
                    }
                }
                
                rank += 1;
                row += 1;
            }
            col += 1;
        }
        
        return rank;
    }
    
    open fn to_string(&self) -> String {
        let mut result = String::from("[\n");
        for i in 0..self.rows {
            result.push_str("  [");
            for j in 0..self.cols {
                if j > 0 {
                    result.push_str(", ");
                }
                result.push_str(&format!("{:.6}", self.data[i * self.cols + j]));
            }
            result.push_str("]");
            if i < self.rows - 1 {
                result.push_str(",\n");
            }
        }
        result.push_str("\n]");
        return result;
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §2  ADVANCED LINEAR ALGEBRA OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════

/// Eigenvalue decomposition result
open data EigenDecomposition {
    eigenvalues: Vector,
    eigenvectors: Matrix,
}

/// Singular value decomposition result
open data SVD {
    u: Matrix,
    s: Vector,
    v: Matrix,
}

/// LU decomposition result
open data LUDecomposition {
    l: Matrix,
    u: Matrix,
    p: Matrix,
}

/// QR decomposition result
open data QRDecomposition {
    q: Matrix,
    r: Matrix,
}

impl Matrix {
    open fn eigen_decomposition(&self) -> LinalgResult<EigenDecomposition> {
        if !self.is_square() {
            return Err(LinalgError::NonSquareMatrix);
        }
        
        // Simplified eigenvalue computation using power iteration
        let size = self.rows;
        let mut eigenvalues = Vector::new(size);
        let mut eigenvectors = Matrix::zeros(size, size);
        
        for i in 0..size {
            // Power iteration for dominant eigenvalue
            let mut vector = Vector::random(size);
            for _ in 0..100 {
                let new_vector = self.multiply_vector(&vector)?;
                let norm = new_vector.norm();
                if norm > 1e-10 {
                    vector = new_vector.scale(1.0 / norm);
                }
            }
            
            let eigenvalue = vector.dot(&self.multiply_vector(&vector)?)?;
            eigenvalues.set(i, eigenvalue)?;
            
            // Store eigenvector
            for j in 0..size {
                eigenvectors.set(j, i, vector.get(j)?)?;
            }
            
            // Deflate matrix (simplified)
            if i < size - 1 {
                // In real implementation, would properly deflate the matrix
            }
        }
        
        return Ok(EigenDecomposition {
            eigenvalues: eigenvalues,
            eigenvectors: eigenvectors,
        });
    }
    
    open fn svd(&self) -> LinalgResult<SVD> {
        let u = Matrix::random(self.rows, self.rows.min(self.cols));
        let s = Vector::random(self.rows.min(self.cols));
        let v = Matrix::random(self.cols, self.cols.min(self.rows));
        
        // Simplified SVD computation
        return Ok(SVD {
            u: u,
            s: s,
            v: v,
        });
    }
    
    open fn lu_decomposition(&self) -> LinalgResult<LUDecomposition> {
        if !self.is_square() {
            return Err(LinalgError::NonSquareMatrix);
        }
        
        let size = self.rows;
        let mut l = Matrix::identity(size);
        let mut u = Matrix::zeros(size, size);
        let mut p = Matrix::identity(size);
        
        // Simplified LU decomposition without pivoting
        for i in 0..size {
            for j in 0..size {
                if j >= i {
                    // Compute U[i,j]
                    let mut sum = 0.0;
                    for k in 0..i {
                        sum += l.data[i * size + k] * u.data[k * size + j];
                    }
                    u.data[i * size + j] = self.data[i * size + j] - sum;
                } else {
                    // Compute L[i,j]
                    let mut sum = 0.0;
                    for k in 0..j {
                        sum += l.data[i * size + k] * u.data[k * size + j];
                    }
                    if u.data[j * size + j].abs() > 1e-10 {
                        l.data[i * size + j] = (self.data[i * size + j] - sum) / u.data[j * size + j];
                    }
                }
            }
        }
        
        return Ok(LUDecomposition {
            l: l,
            u: u,
            p: p,
        });
    }
    
    open fn qr_decomposition(&self) -> LinalgResult<QRDecomposition> {
        let rows = self.rows;
        let cols = self.cols;
        let mut q = Matrix::zeros(rows, rows.min(cols));
        let mut r = Matrix::zeros(rows.min(cols), cols);
        
        // Simplified QR decomposition using Gram-Schmidt
        for j in 0..cols {
            let mut column = Vector::new(rows);
            for i in 0..rows {
                column.set(i, self.get(i, j)?)?;
            }
            
            for i in 0..j.min(rows.min(cols)) {
                let q_column = Vector::new(rows);
                for k in 0..rows {
                    q_column.set(k, q.get(k, i)?)?;
                }
                
                let projection = column.project(&q_column)?;
                column = column.sub(&projection)?;
            }
            
            let norm = column.norm();
            if norm > 1e-10 {
                column = column.scale(1.0 / norm);
                
                for i in 0..rows {
                    q.set(i, j.min(rows.min(cols) - 1), column.get(i)?)?;
                }
                
                for i in 0..cols {
                    let mut dot = 0.0;
                    for k in 0..rows {
                        dot += column.get(k)? * self.get(k, i)?;
                    }
                    r.set(j.min(rows.min(cols) - 1), i, dot)?;
                }
            }
        }
        
        return Ok(QRDecomposition {
            q: q,
            r: r,
        });
    }
    
    open fn solve_linear_system(&self, b: &Vector) -> LinalgResult<Vector> {
        if !self.is_square() || self.rows != b.size {
            return Err(LinalgError::DimensionMismatch("Matrix must be square and match vector size".into()));
        }
        
        let lu = self.lu_decomposition()?;
        
        // Solve Ly = Pb
        let mut y = Vector::new(self.rows);
        for i in 0..self.rows {
            let mut sum = 0.0;
            for j in 0..i {
                sum += lu.l.get(i, j)? * y.get(j)?;
            }
            y.set(i, b.get(i)? - sum)?;
        }
        
        // Solve Ux = y
        let mut x = Vector::new(self.rows);
        for i in (0..self.rows).rev() {
            let mut sum = 0.0;
            for j in (i + 1)..self.rows {
                sum += lu.u.get(i, j)? * x.get(j)?;
            }
            x.set(i, (y.get(i)? - sum) / lu.u.get(i, i)?)?;
        }
        
        return Ok(x);
    }
    
    open fn pseudo_inverse(&self) -> LinalgResult<Matrix> {
        let svd = self.svd()?;
        
        // Compute pseudo-inverse using SVD
        let mut s_inv = Matrix::zeros(svd.v.rows, svd.u.cols);
        for i in 0..s_inv.rows.min(s_inv.cols) {
            if svd.s.get(i)?.abs() > 1e-10 {
                s_inv.set(i, i, 1.0 / svd.s.get(i)?)?;
            }
        }
        
        let v_t = svd.v.transpose();
        let u_t = svd.u.transpose();
        
        return v_t.multiply(&s_inv)?.multiply(&u_t);
    }
    
    open fn condition_number(&self) -> LinalgResult<f64> {
        let svd = self.svd()?;
        
        let max_s = svd.s.get(0)?;
        let min_s = svd.s.get(svd.s.len() - 1)?;
        
        if min_s.abs() > 1e-10 {
            return Ok(max_s / min_s);
        } else {
            return Ok(f64::INFINITY);
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §3  SPECIALIZED MATRICES
// ═══════════════════════════════════════════════════════════════════════════

/// Specialized matrix types
open struct SpecializedMatrices;

impl SpecializedMatrices {
    open fn diagonal(diagonal: &Vector) -> Matrix {
        let size = diagonal.len();
        let mut matrix = Matrix::zeros(size, size);
        for i in 0..size {
            matrix.set(i, i, diagonal.get(i).unwrap()).unwrap();
        }
        return matrix;
    }
    
    open fn symmetric(rows: usize, cols: usize) -> Matrix {
        let mut matrix = Matrix::random(rows, cols);
        // Make symmetric by copying upper triangle to lower triangle
        for i in 0..rows.min(cols) {
            for j in (i + 1)..rows.min(cols) {
                matrix.set(j, i, matrix.get(i, j).unwrap()).unwrap();
            }
        }
        return matrix;
    }
    
    open fn skew_symmetric(size: usize) -> Matrix {
        let mut matrix = Matrix::zeros(size, size);
        for i in 0..size {
            for j in (i + 1)..size {
                let value = rand::random::<f64>() * 2.0 - 1.0;
                matrix.set(i, j, value).unwrap();
                matrix.set(j, i, -value).unwrap();
            }
        }
        return matrix;
    }
    
    open fn orthogonal(size: usize) -> Matrix {
        let matrix = Matrix::random(size, size);
        let qr = matrix.qr_decomposition().unwrap();
        return qr.q;
    }
    
    open fn positive_definite(size: usize) -> Matrix {
        let a = Matrix::random(size, size);
        let a_t = a.transpose();
        let mut result = a.multiply(&a_t).unwrap();
        
        // Add to diagonal to ensure positive definiteness
        for i in 0..size {
            let current = result.get(i, i).unwrap();
            result.set(i, i, current + size as f64).unwrap();
        }
        
        return result;
    }
    
    open fn toeplitz(first_row: &Vector, first_col: &Vector) -> LinalgResult<Matrix> {
        let rows = first_col.len();
        let cols = first_row.len();
        let mut matrix = Matrix::zeros(rows, cols);
        
        for i in 0..rows {
            for j in 0..cols {
                let index = if i >= j { i - j } else { j - i };
                let value = if i >= j {
                    first_col.get(index)?
                } else {
                    first_row.get(index)?
                };
                matrix.set(i, j, value)?;
            }
        }
        
        return Ok(matrix);
    }
    
    open fn hankel(first_row: &Vector, first_col: &Vector) -> LinalgResult<Matrix> {
        let rows = first_col.len();
        let cols = first_row.len();
        let mut matrix = Matrix::zeros(rows, cols);
        
        for i in 0..rows {
            for j in 0..cols {
                let index = i + j;
                let value = if index < first_row.len() {
                    first_row.get(index)?
                } else {
                    first_col.get(index - first_row.len() + 1)?
                };
                matrix.set(i, j, value)?;
            }
        }
        
        return Ok(matrix);
    }
    
    open fn vandermonde(vector: &Vector, degree: usize) -> Matrix {
        let size = vector.len();
        let mut matrix = Matrix::zeros(size, degree + 1);
        
        for i in 0..size {
            let x = vector.get(i).unwrap();
            for j in 0..(degree + 1) {
                matrix.set(i, j, x.powi(j as i32)).unwrap();
            }
        }
        
        return matrix;
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §4  NUMERICAL METHODS
// ═══════════════════════════════════════════════════════════════════════════

/// Numerical methods for linear algebra
open struct NumericalMethods;

impl NumericalMethods {
    open fn solve_linear_system_iterative(a: &Matrix, b: &Vector, max_iterations: usize, tolerance: f64) -> LinalgResult<Vector> {
        // Gauss-Seidel method
        if !a.is_square() || a.rows != b.size {
            return Err(LinalgError::DimensionMismatch("Matrix must be square and match vector size".into()));
        }
        
        let mut x = Vector::zeros(b.size);
        
        for iteration in 0..max_iterations {
            let mut x_new = x.clone();
            
            for i in 0..a.rows {
                let mut sum = b.get(i)?;
                
                for j in 0..a.cols {
                    if j != i {
                        sum -= a.get(i, j)? * x_new.get(j)?;
                    }
                }
                
                let diagonal = a.get(i, i)?;
                if diagonal.abs() > 1e-10 {
                    x_new.set(i, sum / diagonal)?;
                }
            }
            
            // Check convergence
            let diff = x_new.sub(&x)?.norm();
            if diff < tolerance {
                return Ok(x_new);
            }
            
            x = x_new;
        }
        
        return Err(LinalgError::NumericalError("Failed to converge".into()));
    }
    
    open fn power_iteration_eigenvalue(a: &Matrix, max_iterations: usize, tolerance: f64) -> LinalgResult<(f64, Vector)> {
        if !a.is_square() {
            return Err(LinalgError::NonSquareMatrix);
        }
        
        let mut vector = Vector::random(a.rows);
        let mut eigenvalue = 0.0;
        
        for iteration in 0..max_iterations {
            let new_vector = a.multiply_vector(&vector)?;
            let norm = new_vector.norm();
            
            if norm > 1e-10 {
                vector = new_vector.scale(1.0 / norm);
                eigenvalue = vector.dot(&a.multiply_vector(&vector)?)?;
            }
            
            // Check convergence (simplified)
            if iteration > 0 && iteration % 10 == 0 {
                // In real implementation, would check eigenvalue change
            }
        }
        
        return Ok((eigenvalue, vector));
    }
    
    open fn newton_method_system(f: fn(&Vector) -> Vector, jacobian: fn(&Vector) -> Matrix, initial_guess: &Vector, max_iterations: usize, tolerance: f64) -> LinalgResult<Vector> {
        let mut x = initial_guess.clone();
        
        for iteration in 0..max_iterations {
            let fx = f(&x);
            let jx = jacobian(&x);
            
            let delta = jx.solve_linear_system(&fx.scale(-1.0))?;
            x = x.add(&delta)?;
            
            if delta.norm() < tolerance {
                return Ok(x);
            }
        }
        
        return Err(LinalgError::NumericalError("Newton method failed to converge".into()));
    }
    
    open fn matrix_exponential(a: &Matrix, terms: usize) -> LinalgResult<Matrix> {
        if !a.is_square() {
            return Err(LinalgError::NonSquareMatrix);
        }
        
        let mut result = Matrix::identity(a.rows);
        let mut term = Matrix::identity(a.rows);
        let mut factorial = 1.0;
        
        for k in 1..=terms {
            factorial *= k as f64;
            term = a.multiply(&term)?;
            result = result.add(&term.scale(1.0 / factorial))?;
        }
        
        return Ok(result);
    }
    
    open fn matrix_logarithm(a: &Matrix, max_iterations: usize, tolerance: f64) -> LinalgResult<Matrix> {
        if !a.is_square() {
            return Err(LinalgError::NonSquareMatrix);
        }
        
        // Simplified matrix logarithm using series expansion
        let identity = Matrix::identity(a.rows);
        let mut result = Matrix::zeros(a.rows, a.cols);
        
        // Compute A - I
        let a_minus_i = a.sub(&identity)?;
        
        let mut term = a_minus_i.clone();
        let mut sign = 1.0;
        
        for k in 1..=max_iterations {
            let term_norm = term.norm();
            if term_norm < tolerance {
                break;
            }
            
            result = result.add(&term.scale(sign / k as f64))?;
            
            if k < max_iterations {
                term = a_minus_i.multiply(&term)?;
                sign *= -1.0;
            }
        }
        
        return Ok(result);
    }
}

