@module("ml::machine_learning")
@reproducible
@export
@inline

use std::collections::{HashMap, Vec};
use std::sync::Arc;
use std::result::Result;
use super::linear_algebra::{Vector, Matrix};

// ═══════════════════════════════════════════════════════════════════════════
// §1  ML CORE TYPES
// ═══════════════════════════════════════════════════════════════════════════

/// ML error
open cases MLError {
    InvalidArchitecture(String),
    InvalidInput(String),
    TrainingFailed(String),
    ConvergenceFailed,
    InvalidModel(String),
    InsufficientData,
    NumericalInstability,
    GPUError(String),
}

impl MLError {
    open fn to_string(&self) -> String {
        match self {
            MLError::InvalidArchitecture(msg) => format!("Invalid architecture: {}", msg),
            MLError::InvalidInput(msg) => format!("Invalid input: {}", msg),
            MLError::TrainingFailed(msg) => format!("Training failed: {}", msg),
            MLError::ConvergenceFailed => "Failed to converge".into(),
            MLError::InvalidModel(msg) => format!("Invalid model: {}", msg),
            MLError::InsufficientData => "Insufficient training data".into(),
            MLError::NumericalInstability => "Numerical instability detected".into(),
            MLError::GPUError(msg) => format!("GPU error: {}", msg),
        }
    }
}

/// ML result
open type MLResult<T> = Result<T, MLError>;

/// Activation function
open cases ActivationFunction {
    ReLU,
    Sigmoid,
    Tanh,
    Softmax,
    LeakyReLU(f64),
    ELU(f64),
    Swish,
    GELU,
}

impl ActivationFunction {
    open fn compute(&self, x: f64) -> f64 {
        match self {
            ActivationFunction::ReLU => x.max(0.0),
            ActivationFunction::Sigmoid => 1.0 / (1.0 + (-x).exp()),
            ActivationFunction::Tanh => x.tanh(),
            ActivationFunction::Softmax => panic!("Softmax computed on vector"),
            ActivationFunction::LeakyReLU(alpha) => if x > 0.0 { x } else { alpha * x },
            ActivationFunction::ELU(alpha) => if x > 0.0 { x } else { alpha * (x.exp() - 1.0) },
            ActivationFunction::Swish => x / (1.0 + (-x).exp()),
            ActivationFunction::GELU => 0.5 * x * (1.0 + (0.7978845608 * (x + 0.044715 * x.powi(3))).tanh()),
        }
    }
    
    open fn derivative(&self, x: f64) -> f64 {
        match self {
            ActivationFunction::ReLU => if x > 0.0 { 1.0 } else { 0.0 },
            ActivationFunction::Sigmoid => {
                let s = self.compute(x);
                s * (1.0 - s)
            }
            ActivationFunction::Tanh => 1.0 - x.tanh().powi(2),
            ActivationFunction::Softmax => panic!("Softmax derivative computed on vector"),
            ActivationFunction::LeakyReLU(alpha) => if x > 0.0 { 1.0 } else { *alpha },
            ActivationFunction::ELU(alpha) => if x > 0.0 { 1.0 } else { alpha * x.exp() },
            ActivationFunction::Swish => {
                let sig = 1.0 / (1.0 + (-x).exp());
                sig + x * sig * (1.0 - sig)
            }
            ActivationFunction::GELU => {
                let x_cubed = x.powi(3);
                let tanh_arg = 0.7978845608 * (x + 0.044715 * x_cubed);
                let tanh_val = tanh_arg.tanh();
                0.5 * (1.0 + tanh_val) + 0.5 * x * (1.0 - tanh_val.powi(2)) * 0.7978845608 * (1.0 + 0.134145 * x_cubed)
            }
        }
    }
    
    open fn compute_vector(&self, input: &Vector) -> Vector {
        match self {
            ActivationFunction::Softmax => {
                let max_val = input.data.iter().fold(f64::NEG_INFINITY, |a, &b| a.max(b));
                let exp_values: Vec<f64> = input.data.iter()
                    .map(|&x| (x - max_val).exp())
                    .collect();
                let sum: f64 = exp_values.iter().sum();
                let softmax_values: Vec<f64> = exp_values.iter()
                    .map(|&x| x / sum)
                    .collect();
                return Vector::from_data(softmax_values);
            }
            _ => {
                let result: Vec<f64> = input.data.iter()
                    .map(|&x| self.compute(x))
                    .collect();
                return Vector::from_data(result);
            }
        }
    }
}

/// Loss function
open cases LossFunction {
    MeanSquaredError,
    MeanAbsoluteError,
    BinaryCrossEntropy,
    CategoricalCrossEntropy,
    HingeLoss,
    HuberLoss(f64),
}

impl LossFunction {
    open fn compute(&self, predictions: &Vector, targets: &Vector) -> MLResult<f64> {
        if predictions.len() != targets.len() {
            return Err(MLError::InvalidInput("Prediction and target sizes must match".into()));
        }
        
        let mut loss = 0.0;
        
        match self {
            LossFunction::MeanSquaredError => {
                for i in 0..predictions.len() {
                    let diff = predictions.get(i)? - targets.get(i)?;
                    loss += diff * diff;
                }
                loss /= predictions.len() as f64;
            }
            LossFunction::MeanAbsoluteError => {
                for i in 0..predictions.len() {
                    loss += (predictions.get(i)? - targets.get(i)?).abs();
                }
                loss /= predictions.len() as f64;
            }
            LossFunction::BinaryCrossEntropy => {
                for i in 0..predictions.len() {
                    let pred = predictions.get(i)?.clamp(1e-15, 1.0 - 1e-15);
                    let target = targets.get(i)?;
                    loss += -target * pred.ln() - (1.0 - target) * (1.0 - pred).ln();
                }
                loss /= predictions.len() as f64;
            }
            LossFunction::CategoricalCrossEntropy => {
                for i in 0..predictions.len() {
                    let pred = predictions.get(i)?.clamp(1e-15, 1.0 - 1e-15);
                    let target = targets.get(i)?;
                    if target > 0.0 {
                        loss += -target * pred.ln();
                    }
                }
            }
            LossFunction::HingeLoss => {
                for i in 0..predictions.len() {
                    let pred = predictions.get(i)?;
                    let target = targets.get(i)?;
                    loss += (1.0 - target * pred).max(0.0);
                }
                loss /= predictions.len() as f64;
            }
            LossFunction::HuberLoss(delta) => {
                for i in 0..predictions.len() {
                    let diff = predictions.get(i)? - targets.get(i)?;
                    if diff.abs() <= *delta {
                        loss += 0.5 * diff * diff;
                    } else {
                        loss += *delta * (diff.abs() - 0.5 * *delta);
                    }
                }
                loss /= predictions.len() as f64;
            }
        }
        
        return Ok(loss);
    }
    
    open fn gradient(&self, predictions: &Vector, targets: &Vector) -> MLResult<Vector> {
        if predictions.len() != targets.len() {
            return Err(MLError::InvalidInput("Prediction and target sizes must match".into()));
        }
        
        let mut gradient = Vector::zeros(predictions.len());
        
        match self {
            LossFunction::MeanSquaredError => {
                for i in 0..predictions.len() {
                    let diff = predictions.get(i)? - targets.get(i)?;
                    gradient.set(i, 2.0 * diff / predictions.len() as f64)?;
                }
            }
            LossFunction::MeanAbsoluteError => {
                for i in 0..predictions.len() {
                    let diff = predictions.get(i)? - targets.get(i)?;
                    let sign = if diff > 0.0 { 1.0 } else { -1.0 };
                    gradient.set(i, sign / predictions.len() as f64)?;
                }
            }
            LossFunction::BinaryCrossEntropy => {
                for i in 0..predictions.len() {
                    let pred = predictions.get(i)?.clamp(1e-15, 1.0 - 1e-15);
                    let target = targets.get(i)?;
                    gradient.set(i, (pred - target) / predictions.len() as f64)?;
                }
            }
            LossFunction::CategoricalCrossEntropy => {
                for i in 0..predictions.len() {
                    let pred = predictions.get(i)?.clamp(1e-15, 1.0 - 1e-15);
                    let target = targets.get(i)?;
                    gradient.set(i, (pred - target) / predictions.len() as f64)?;
                }
            }
            LossFunction::HingeLoss => {
                for i in 0..predictions.len() {
                    let pred = predictions.get(i)?;
                    let target = targets.get(i)?;
                    if 1.0 - target * pred > 0.0 {
                        gradient.set(i, -target / predictions.len() as f64)?;
                    }
                }
            }
            LossFunction::HuberLoss(delta) => {
                for i in 0..predictions.len() {
                    let diff = predictions.get(i)? - targets.get(i)?;
                    if diff.abs() <= *delta {
                        gradient.set(i, diff / predictions.len() as f64)?;
                    } else {
                        let sign = if diff > 0.0 { 1.0 } else { -1.0 };
                        gradient.set(i, sign * *delta / predictions.len() as f64)?;
                    }
                }
            }
        }
        
        return Ok(gradient);
    }
}

/// Optimization algorithm
open cases Optimizer {
    SGD { learning_rate: f64, momentum: Option<f64> },
    Adam { learning_rate: f64, beta1: f64, beta2: f64, epsilon: f64 },
    RMSprop { learning_rate: f64, alpha: f64, epsilon: f64 },
    AdaGrad { learning_rate: f64, epsilon: f64 },
    AdaDelta { learning_rate: f64, rho: f64, epsilon: f64 },
}

// ═══════════════════════════════════════════════════════════════════════════
// §2  NEURAL NETWORK LAYERS
// ═══════════════════════════════════════════════════════════════════════════

/// Neural network layer
open trait Layer {
    fn forward(&mut self, input: &Vector) -> MLResult<Vector>;
    fn backward(&mut self, gradient: &Vector) -> MLResult<Vector>;
    fn get_parameters(&self) -> Vec<f64>;
    fn set_parameters(&mut self, parameters: &[f64]) -> MLResult<()>;
    fn get_gradients(&self) -> Vec<f64>;
    fn get_output_size(&self) -> usize;
}

/// Dense (fully connected) layer
open data DenseLayer {
    input_size: usize,
    output_size: usize,
    weights: Matrix,
    bias: Vector,
    weights_gradient: Matrix,
    bias_gradient: Vector,
    activation: ActivationFunction,
    last_input: Option<Vector>,
    last_output: Option<Vector>,
}

impl DenseLayer {
    open fn new(input_size: usize, output_size: usize, activation: ActivationFunction) -> DenseLayer {
        let weights = Matrix::random(input_size, output_size);
        let bias = Vector::random(output_size);
        
        return DenseLayer {
            input_size: input_size,
            output_size: output_size,
            weights: weights,
            bias: bias,
            weights_gradient: Matrix::zeros(input_size, output_size),
            bias_gradient: Vector::zeros(output_size),
            activation: activation,
            last_input: None,
            last_output: None,
        };
    }
    
    fn initialize_weights(&mut self) {
        // Xavier initialization
        let scale = (2.0 / (self.input_size + self.output_size) as f64).sqrt();
        for i in 0..self.input_size {
            for j in 0..self.output_size {
                let value = (rand::random::<f64>() - 0.5) * 2.0 * scale;
                self.weights.set(i, j, value).unwrap();
            }
        }
        
        for i in 0..self.output_size {
            self.bias.set(i, 0.0).unwrap();
        }
    }
}

impl Layer for DenseLayer {
    open fn forward(&mut self, input: &Vector) -> MLResult<Vector> {
        if input.len() != self.input_size {
            return Err(MLError::InvalidInput("Input size mismatch".into()));
        }
        
        let linear_output = self.weights.multiply_vector(input)?;
        let mut output = linear_output.add(&self.bias)?;
        
        output = self.activation.compute_vector(&output);
        
        self.last_input = Some(input.clone());
        self.last_output = Some(output.clone());
        
        return Ok(output);
    }
    
    open fn backward(&mut self, gradient: &Vector) -> MLResult<Vector> {
        let output = self.last_input.as_ref().ok_or(MLError::InvalidInput("No forward pass recorded".into()))?;
        
        // Compute activation gradient
        let mut activation_gradient = Vector::zeros(self.output_size);
        for i in 0..self.output_size {
            let linear_output = self.weights.multiply_vector(output)?.get(i)? + self.bias.get(i)?;
            activation_gradient.set(i, self.activation.derivative(linear_output) * gradient.get(i)?)?;
        }
        
        // Compute bias gradient
        self.bias_gradient = activation_gradient.clone();
        
        // Compute weights gradient
        for i in 0..self.input_size {
            for j in 0..self.output_size {
                let gradient_value = output.get(i)? * activation_gradient.get(j)?;
                self.weights_gradient.set(i, j, gradient_value)?;
            }
        }
        
        // Compute input gradient
        let input_gradient = self.weights.transpose().multiply_vector(&activation_gradient)?;
        
        return Ok(input_gradient);
    }
    
    open fn get_parameters(&self) -> Vec<f64> {
        let mut parameters = Vec::with_capacity(self.input_size * self.output_size + self.output_size);
        
        for i in 0..self.input_size {
            for j in 0..self.output_size {
                parameters.push(self.weights.get(i, j).unwrap());
            }
        }
        
        for i in 0..self.output_size {
            parameters.push(self.bias.get(i).unwrap());
        }
        
        return parameters;
    }
    
    open fn set_parameters(&mut self, parameters: &[f64]) -> MLResult<()> {
        let expected_size = self.input_size * self.output_size + self.output_size;
        if parameters.len() != expected_size {
            return Err(MLError::InvalidModel("Parameter count mismatch".into()));
        }
        
        let mut index = 0;
        
        for i in 0..self.input_size {
            for j in 0..self.output_size {
                self.weights.set(i, j, parameters[index])?;
                index += 1;
            }
        }
        
        for i in 0..self.output_size {
            self.bias.set(i, parameters[index])?;
            index += 1;
        }
        
        return Ok(());
    }
    
    open fn get_gradients(&self) -> Vec<f64> {
        let mut gradients = Vec::with_capacity(self.input_size * self.output_size + self.output_size);
        
        for i in 0..self.input_size {
            for j in 0..self.output_size {
                gradients.push(self.weights_gradient.get(i, j).unwrap());
            }
        }
        
        for i in 0..self.output_size {
            gradients.push(self.bias_gradient.get(i).unwrap());
        }
        
        return gradients;
    }
    
    open fn get_output_size(&self) -> usize {
        return self.output_size;
    }
}

/// Convolutional layer
open data ConvLayer {
    input_channels: usize,
    output_channels: usize,
    kernel_size: usize,
    stride: usize,
    padding: usize,
    kernels: Vec<Matrix>,
    bias: Vector,
    kernel_gradients: Vec<Matrix>,
    bias_gradient: Vector,
    activation: ActivationFunction,
    last_input: Option<Vec<Matrix>>,
    last_output: Option<Vec<Matrix>>,
}

impl ConvLayer {
    open fn new(input_channels: usize, output_channels: usize, kernel_size: usize, 
                stride: usize, padding: usize, activation: ActivationFunction) -> ConvLayer {
        let mut kernels = Vec::with_capacity(output_channels * input_channels);
        let mut kernel_gradients = Vec::with_capacity(output_channels * input_channels);
        
        for _ in 0..(output_channels * input_channels) {
            kernels.push(Matrix::random(kernel_size, kernel_size));
            kernel_gradients.push(Matrix::zeros(kernel_size, kernel_size));
        }
        
        return ConvLayer {
            input_channels: input_channels,
            output_channels: output_channels,
            kernel_size: kernel_size,
            stride: stride,
            padding: padding,
            kernels: kernels,
            bias: Vector::random(output_channels),
            kernel_gradients: kernel_gradients,
            bias_gradient: Vector::zeros(output_channels),
            activation: activation,
            last_input: None,
            last_output: None,
        };
    }
    
    fn convolve_2d(&self, input: &Matrix, kernel: &Matrix) -> Matrix {
        let input_rows = input.rows();
        let input_cols = input.cols();
        let kernel_size = kernel.rows();
        let output_rows = (input_rows - kernel_size + 2 * self.padding) / self.stride + 1;
        let output_cols = (input_cols - kernel_size + 2 * self.padding) / self.stride + 1;
        
        let mut output = Matrix::zeros(output_rows, output_cols);
        
        for i in 0..output_rows {
            for j in 0..output_cols {
                let mut sum = 0.0;
                for ki in 0..kernel_size {
                    for kj in 0..kernel_size {
                        let input_i = i * self.stride + ki - self.padding;
                        let input_j = j * self.stride + kj - self.padding;
                        
                        if input_i >= 0 && input_i < input_rows && input_j >= 0 && input_j < input_cols {
                            sum += input.get(input_i, input_j).unwrap() * kernel.get(ki, kj).unwrap();
                        }
                    }
                }
                output.set(i, j, sum).unwrap();
            }
        }
        
        return output;
    }
}

impl Layer for ConvLayer {
    open fn forward(&mut self, input: &Vector) -> MLResult<Vector> {
        // Simplified conv layer - in real implementation would handle proper tensor operations
        let input_size = input.len();
        let output_size = self.output_channels * ((input_size / self.input_channels - self.kernel_size + 2 * self.padding) / self.stride + 1).pow(2);
        
        let mut output = Vector::zeros(output_size);
        
        // Simplified convolution computation
        for oc in 0..self.output_channels {
            for ic in 0..self.input_channels {
                let kernel_index = oc * self.input_channels + ic;
                let kernel = &self.kernels[kernel_index];
                
                // Simplified convolution operation
                for i in 0..output_size {
                    let input_val = input.get(ic * (input_size / self.input_channels) + i % (input_size / self.input_channels)).unwrap();
                    let kernel_val = kernel.get(i % self.kernel_size, i % self.kernel_size).unwrap();
                    output.set(oc * (output_size / self.output_channels) + i, 
                              output.get(i).unwrap() + input_val * kernel_val)?;
                }
            }
            
            // Add bias and apply activation
            for i in 0..(output_size / self.output_channels) {
                let idx = oc * (output_size / self.output_channels) + i;
                let val = output.get(idx).unwrap() + self.bias.get(oc).unwrap();
                output.set(idx, self.activation.compute(val))?;
            }
        }
        
        return Ok(output);
    }
    
    open fn backward(&mut self, gradient: &Vector) -> MLResult<Vector> {
        // Simplified backward pass
        let input_size = gradient.len();
        let mut input_gradient = Vector::zeros(input_size);
        
        // Compute gradients (simplified)
        for i in 0..input_size {
            input_gradient.set(i, gradient.get(i).unwrap())?;
        }
        
        return Ok(input_gradient);
    }
    
    open fn get_parameters(&self) -> Vec<f64> {
        let mut parameters = Vec::new();
        
        for kernel in &self.kernels {
            for i in 0..kernel.rows() {
                for j in 0..kernel.cols() {
                    parameters.push(kernel.get(i, j).unwrap());
                }
            }
        }
        
        for i in 0..self.output_channels {
            parameters.push(self.bias.get(i).unwrap());
        }
        
        return parameters;
    }
    
    open fn set_parameters(&mut self, parameters: &[f64]) -> MLResult<()> {
        let mut index = 0;
        
        for kernel in &mut self.kernels {
            for i in 0..kernel.rows() {
                for j in 0..kernel.cols() {
                    kernel.set(i, j, parameters[index])?;
                    index += 1;
                }
            }
        }
        
        for i in 0..self.output_channels {
            self.bias.set(i, parameters[index])?;
            index += 1;
        }
        
        return Ok(());
    }
    
    open fn get_gradients(&self) -> Vec<f64> {
        let mut gradients = Vec::new();
        
        for kernel_gradient in &self.kernel_gradients {
            for i in 0..kernel_gradient.rows() {
                for j in 0..kernel_gradient.cols() {
                    gradients.push(kernel_gradient.get(i, j).unwrap());
                }
            }
        }
        
        for i in 0..self.output_channels {
            gradients.push(self.bias_gradient.get(i).unwrap());
        }
        
        return gradients;
    }
    
    open fn get_output_size(&self) -> usize {
        return self.output_channels * 100; // Simplified output size
    }
}

/// Dropout layer
open data DropoutLayer {
    input_size: usize,
    dropout_rate: f64,
    training: bool,
    mask: Vec<bool>,
}

impl DropoutLayer {
    open fn new(input_size: usize, dropout_rate: f64) -> DropoutLayer {
        return DropoutLayer {
            input_size: input_size,
            dropout_rate: dropout_rate,
            training: true,
            mask: vec![true; input_size],
        };
    }
    
    open fn set_training_mode(&mut self, training: bool) {
        self.training = training;
    }
}

impl Layer for DropoutLayer {
    open fn forward(&mut self, input: &Vector) -> MLResult<Vector> {
        if self.training {
            let mut output = Vector::zeros(input.len());
            self.mask.clear();
            
            for i in 0..input.len() {
                if rand::random::<f64>() > self.dropout_rate {
                    self.mask.push(true);
                    output.set(i, input.get(i)? / (1.0 - self.dropout_rate))?;
                } else {
                    self.mask.push(false);
                    output.set(i, 0.0)?;
                }
            }
            
            return Ok(output);
        } else {
            return Ok(input.clone());
        }
    }
    
    open fn backward(&mut self, gradient: &Vector) -> MLResult<Vector> {
        let mut input_gradient = Vector::zeros(gradient.len());
        
        for i in 0..gradient.len() {
            if self.mask[i] {
                input_gradient.set(i, gradient.get(i)?)?;
            } else {
                input_gradient.set(i, 0.0)?;
            }
        }
        
        return Ok(input_gradient);
    }
    
    open fn get_parameters(&self) -> Vec<f64> {
        return Vec::new();
    }
    
    open fn set_parameters(&mut self, _parameters: &[f64]) -> MLResult<()> {
        return Ok(());
    }
    
    open fn get_gradients(&self) -> Vec<f64> {
        return Vec::new();
    }
    
    open fn get_output_size(&self) -> usize {
        return self.input_size;
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §3  NEURAL NETWORK MODEL
// ═══════════════════════════════════════════════════════════════════════════

/// Neural network
open data NeuralNetwork {
    layers: Vec<Box<dyn Layer>>,
    optimizer: Optimizer,
    loss_function: LossFunction,
    training: bool,
}

impl NeuralNetwork {
    open fn new() -> NeuralNetwork {
        return NeuralNetwork {
            layers: Vec::new(),
            optimizer: Optimizer::SGD { learning_rate: 0.01, momentum: None },
            loss_function: LossFunction::MeanSquaredError,
            training: true,
        };
    }
    
    open fn add_layer(&mut self, layer: Box<dyn Layer>) {
        self.layers.push(layer);
    }
    
    open fn set_optimizer(&mut self, optimizer: Optimizer) {
        self.optimizer = optimizer;
    }
    
    open fn set_loss_function(&mut self, loss_function: LossFunction) {
        self.loss_function = loss_function;
    }
    
    open fn set_training_mode(&mut self, training: bool) {
        self.training = training;
        for layer in &mut self.layers {
            // Set training mode for layers that support it (like Dropout)
            if let Some(dropout_layer) = layer.as_any().downcast_mut::<DropoutLayer>() {
                dropout_layer.set_training_mode(training);
            }
        }
    }
    
    open fn forward(&mut self, input: &Vector) -> MLResult<Vector> {
        let mut current_input = input.clone();
        
        for layer in &mut self.layers {
            current_input = layer.forward(&current_input)?;
        }
        
        return Ok(current_input);
    }
    
    open fn predict(&mut self, input: &Vector) -> MLResult<Vector> {
        let original_training = self.training;
        self.set_training_mode(false);
        
        let prediction = self.forward(input)?;
        
        self.set_training_mode(original_training);
        
        return Ok(prediction);
    }
    
    open fn backward(&mut self, gradient: &Vector) -> MLResult<Vector> {
        let mut current_gradient = gradient.clone();
        
        for layer in self.layers.iter_mut().rev() {
            current_gradient = layer.backward(&current_gradient)?;
        }
        
        return Ok(current_gradient);
    }
    
    open fn compute_loss(&self, predictions: &Vector, targets: &Vector) -> MLResult<f64> {
        return self.loss_function.compute(predictions, targets);
    }
    
    open fn train_step(&mut self, input: &Vector, target: &Vector) -> MLResult<f64> {
        // Forward pass
        let predictions = self.forward(input)?;
        
        // Compute loss
        let loss = self.compute_loss(&predictions, target)?;
        
        // Backward pass
        let gradient = self.loss_function.gradient(&predictions, target)?;
        self.backward(&gradient)?;
        
        // Update parameters
        self.update_parameters()?;
        
        return Ok(loss);
    }
    
    open fn train_batch(&mut self, inputs: &[Vector], targets: &[Vector]) -> MLResult<f64> {
        if inputs.len() != targets.len() {
            return Err(MLError::InvalidInput("Inputs and targets must have same length".into()));
        }
        
        let mut total_loss = 0.0;
        
        for (input, target) in inputs.iter().zip(targets.iter()) {
            let loss = self.train_step(input, target)?;
            total_loss += loss;
        }
        
        return Ok(total_loss / inputs.len() as f64);
    }
    
    open fn train(&mut self, inputs: &[Vector], targets: &[Vector], epochs: usize, batch_size: usize) -> MLResult<Vec<f64>> {
        let mut losses = Vec::with_capacity(epochs);
        let dataset_size = inputs.len();
        
        for epoch in 0..epochs {
            let mut epoch_loss = 0.0;
            let mut batches_processed = 0;
            
            // Process in batches
            for batch_start in (0..dataset_size).step_by(batch_size) {
                let batch_end = (batch_start + batch_size).min(dataset_size);
                let batch_inputs = &inputs[batch_start..batch_end];
                let batch_targets = &targets[batch_start..batch_end];
                
                let batch_loss = self.train_batch(batch_inputs, batch_targets)?;
                epoch_loss += batch_loss;
                batches_processed += 1;
            }
            
            let avg_loss = epoch_loss / batches_processed as f64;
            losses.push(avg_loss);
            
            // Print progress
            if epoch % 10 == 0 || epoch == epochs - 1 {
                println!("Epoch {}/{} - Loss: {:.6}", epoch + 1, epochs, avg_loss);
            }
        }
        
        return Ok(losses);
    }
    
    open fn evaluate(&mut self, inputs: &[Vector], targets: &[Vector]) -> MLResult<f64> {
        let mut total_loss = 0.0;
        
        for (input, target) in inputs.iter().zip(targets.iter()) {
            let predictions = self.predict(input)?;
            let loss = self.compute_loss(&predictions, target)?;
            total_loss += loss;
        }
        
        return Ok(total_loss / inputs.len() as f64);
    }
    
    open fn save(&self, path: &str) -> MLResult<()> {
        // Save model architecture and parameters
        let mut model_data = Vec::new();
        
        // Save layer information
        for layer in &self.layers {
            let parameters = layer.get_parameters();
            model_data.push(parameters.len() as u32);
            model_data.extend_from_slice(&parameters);
        }
        
        // In real implementation, would save to file
        println!("Model saved to {} ({} bytes)", path, model_data.len());
        
        return Ok(());
    }
    
    open fn load(&mut self, path: &str) -> MLResult<()> {
        // Load model architecture and parameters
        // In real implementation, would load from file
        
        println!("Model loaded from {}", path);
        
        return Ok(());
    }
    
    fn update_parameters(&mut self) -> MLResult<()> {
        match &self.optimizer {
            Optimizer::SGD { learning_rate, momentum } => {
                for layer in &mut self.layers {
                    let gradients = layer.get_gradients();
                    let mut parameters = layer.get_parameters();
                    
                    for i in 0..parameters.len() {
                        parameters[i] -= learning_rate * gradients[i];
                    }
                    
                    layer.set_parameters(&parameters)?;
                }
            }
            Optimizer::Adam { learning_rate, beta1, beta2, epsilon } => {
                // Simplified Adam update
                for layer in &mut self.layers {
                    let gradients = layer.get_gradients();
                    let mut parameters = layer.get_parameters();
                    
                    for i in 0..parameters.len() {
                        parameters[i] -= learning_rate * gradients[i];
                    }
                    
                    layer.set_parameters(&parameters)?;
                }
            }
            _ => {
                // Other optimizers would have their specific update rules
                for layer in &mut self.layers {
                    let gradients = layer.get_gradients();
                    let mut parameters = layer.get_parameters();
                    
                    for i in 0..parameters.len() {
                        parameters[i] -= 0.01 * gradients[i]; // Default learning rate
                    }
                    
                    layer.set_parameters(&parameters)?;
                }
            }
        }
        
        return Ok(());
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §4  TRAINING UTILITIES
// ═══════════════════════════════════════════════════════════════════════════

/// Training data
open data TrainingData {
    inputs: Vec<Vector>,
    targets: Vec<Vector>,
}

impl TrainingData {
    open fn new() -> TrainingData {
        return TrainingData {
            inputs: Vec::new(),
            targets: Vec::new(),
        };
    }
    
    open fn add_sample(&mut self, input: Vector, target: Vector) {
        self.inputs.push(input);
        self.targets.push(target);
    }
    
    open fn shuffle(&mut self) {
        let mut indices: Vec<usize> = (0..self.inputs.len()).collect();
        
        for i in (1..indices.len()).rev() {
            let j = rand::random::<usize>() % (i + 1);
            indices.swap(i, j);
        }
        
        let shuffled_inputs: Vec<Vector> = indices.iter().map(|&i| self.inputs[i].clone()).collect();
        let shuffled_targets: Vec<Vector> = indices.iter().map(|&i| self.targets[i].clone()).collect();
        
        self.inputs = shuffled_inputs;
        self.targets = shuffled_targets;
    }
    
    open fn split(&self, train_ratio: f64) -> (TrainingData, TrainingData) {
        let train_size = (self.inputs.len() as f64 * train_ratio) as usize;
        
        let mut train_data = TrainingData::new();
        let mut test_data = TrainingData::new();
        
        for i in 0..self.inputs.len() {
            if i < train_size {
                train_data.add_sample(self.inputs[i].clone(), self.targets[i].clone());
            } else {
                test_data.add_sample(self.inputs[i].clone(), self.targets[i].clone());
            }
        }
        
        return (train_data, test_data);
    }
    
    open fn len(&self) -> usize {
        return self.inputs.len();
    }
    
    open fn is_empty(&self) -> bool {
        return self.inputs.is_empty();
    }
}

/// Data preprocessing
open struct DataPreprocessor;

impl DataPreprocessor {
    open fn normalize(data: &mut [Vector]) -> MLResult<()> {
        if data.is_empty() {
            return Ok(());
        }
        
        let feature_size = data[0].len();
        
        for feature_idx in 0..feature_size {
            let mut min_val = f64::INFINITY;
            let mut max_val = f64::NEG_INFINITY;
            
            // Find min and max
            for sample in data {
                let val = sample.get(feature_idx)?;
                min_val = min_val.min(val);
                max_val = max_val.max(val);
            }
            
            // Normalize
            let range = max_val - min_val;
            if range > 1e-10 {
                for sample in data {
                    let val = sample.get(feature_idx)?;
                    let normalized = (val - min_val) / range;
                    sample.set(feature_idx, normalized)?;
                }
            }
        }
        
        return Ok(());
    }
    
    open fn standardize(data: &mut [Vector]) -> MLResult<()> {
        if data.is_empty() {
            return Ok(());
        }
        
        let feature_size = data[0].len();
        
        for feature_idx in 0..feature_size {
            let mut sum = 0.0;
            let mut sum_squared = 0.0;
            
            // Calculate mean and variance
            for sample in data {
                let val = sample.get(feature_idx)?;
                sum += val;
                sum_squared += val * val;
            }
            
            let mean = sum / data.len() as f64;
            let variance = (sum_squared / data.len() as f64) - mean * mean;
            let std_dev = variance.sqrt();
            
            // Standardize
            if std_dev > 1e-10 {
                for sample in data {
                    let val = sample.get(feature_idx)?;
                    let standardized = (val - mean) / std_dev;
                    sample.set(feature_idx, standardized)?;
                }
            }
        }
        
        return Ok(());
    }
    
    open fn one_hot_encode(labels: &[usize], num_classes: usize) -> MLResult<Vec<Vector>> {
        let mut one_hot_vectors = Vec::with_capacity(labels.len());
        
        for &label in labels {
            if label >= num_classes {
                return Err(MLError::InvalidInput("Label exceeds number of classes".into()));
            }
            
            let mut one_hot = Vector::zeros(num_classes);
            one_hot.set(label, 1.0)?;
            one_hot_vectors.push(one_hot);
        }
        
        return Ok(one_hot_vectors);
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §5  MODEL BUILDER
// ═══════════════════════════════════════════════════════════════════════════

/// Neural network builder
open data NeuralNetworkBuilder {
    network: NeuralNetwork,
}

impl NeuralNetworkBuilder {
    open fn new() -> NeuralNetworkBuilder {
        return NeuralNetworkBuilder {
            network: NeuralNetwork::new(),
        };
    }
    
    open fn dense(mut self, input_size: usize, output_size: usize, activation: ActivationFunction) -> NeuralNetworkBuilder {
        let layer = DenseLayer::new(input_size, output_size, activation);
        self.network.add_layer(Box::new(layer));
        return self;
    }
    
    open fn conv(mut self, input_channels: usize, output_channels: usize, 
                kernel_size: usize, stride: usize, padding: usize, 
                activation: ActivationFunction) -> NeuralNetworkBuilder {
        let layer = ConvLayer::new(input_channels, output_channels, kernel_size, stride, padding, activation);
        self.network.add_layer(Box::new(layer));
        return self;
    }
    
    open fn dropout(mut self, input_size: usize, dropout_rate: f64) -> NeuralNetworkBuilder {
        let layer = DropoutLayer::new(input_size, dropout_rate);
        self.network.add_layer(Box::new(layer));
        return self;
    }
    
    open fn optimizer(mut self, optimizer: Optimizer) -> NeuralNetworkBuilder {
        self.network.set_optimizer(optimizer);
        return self;
    }
    
    open fn loss(mut self, loss_function: LossFunction) -> NeuralNetworkBuilder {
        self.network.set_loss_function(loss_function);
        return self;
    }
    
    open fn build(self) -> NeuralNetwork {
        return self.network;
    }
}

