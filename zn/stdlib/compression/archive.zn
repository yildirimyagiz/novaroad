// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Archive Formats - Tar, Zip                                                 ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Tar archive
open data TarArchive {
    entries: Vec<TarEntry>,
}

open data TarEntry {
    path: String,
    data: Vec<u8>,
    mode: u32,
}

impl TarArchive {
    /// Create from files
    open fn create(entries: Vec<TarEntry>) -> TarArchive {
        TarArchive { entries }
    }
    
    /// Write to bytes
    open fn to_bytes(&self) -> Vec<u8> {
        extern "C" {
            fn nova_tar_create(
                entries: *const u8,
                entry_count: usize,
                output: *var *var u8,
                output_len: *var usize
            ) -> bool;
        }
        
        // Serialize and create tar
        Vec::new()
    }
    
    /// Read from bytes
    open fn from_bytes(data: &[u8]) -> Result<TarArchive, String> {
        extern "C" {
            fn nova_tar_extract(
                data: *const u8,
                data_len: usize,
                entries: *var *var u8,
                entry_count: *var usize
            ) -> bool;
        }
        
        Ok(TarArchive { entries: Vec::new() })
    }
}

/// Zip archive
open data ZipArchive {
    entries: Vec<ZipEntry>,
}

open data ZipEntry {
    path: String,
    data: Vec<u8>,
    compressed: bool,
}

impl ZipArchive {
    /// Create zip
    open fn create(entries: Vec<ZipEntry>) -> ZipArchive {
        ZipArchive { entries }
    }
    
    /// Write to bytes
    open fn to_bytes(&self) -> Vec<u8> {
        extern "C" {
            fn nova_zip_create(
                entries: *const u8,
                entry_count: usize,
                output: *var *var u8,
                output_len: *var usize
            ) -> bool;
        }
        
        Vec::new()
    }
    
    /// Read from bytes
    open fn from_bytes(data: &[u8]) -> Result<ZipArchive, String> {
        extern "C" {
            fn nova_zip_extract(
                data: *const u8,
                data_len: usize,
                entries: *var *var u8,
                entry_count: *var usize
            ) -> bool;
        }
        
        Ok(ZipArchive { entries: Vec::new() })
    }
}
