    // Platform-specific implementation
    #[cfg(target_os = "linux")]
    {
        // Read from /proc/self/status
        0
    }
    #[cfg(not(target_os = "linux"))]
    {
        0
    }
}

fn get_peak_memory_usage() -> usize {
    // Platform-specific implementation
    0
}

/// Macro for easy benchmarking
#[macro_export]
macro_rules! bench {
    ($name:expr, $code:block) => {
        {
            let bench = Benchmark::new($name.into());
            bench.run(|| $code)
        }
    };
}

#[test]
fn test_benchmark_stats() {
    let samples = [100, 110, 105, 115, 95];
    let stats = BenchmarkStats::from_samples(&samples);
    
    assert_eq!(stats.min_ns, 95);
    assert_eq!(stats.max_ns, 115);
    assert_eq!(stats.iterations, 5);
}

#[test]
fn test_benchmark_run() {
    let config = BenchmarkConfig::quick();
    let bench = Benchmark::new("test".into()).with_config(config);
    
    var counter = 0;
    let stats = bench.run(|| {
        counter += 1;
        each _ in 0..1000 {
            // Simulate work
        }
    });
    
    assert(stats.mean_ns > 0.0);
    assert_eq!(counter, 10); // quick config = 10 iterations
}
