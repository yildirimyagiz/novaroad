    // Run selected examples
    pick 0 {
        0 => {
            example_image_classification().unwrap();
            example_resnet_transfer().unwrap();
            example_gpt_training().unwrap();
            example_gpt_inference().unwrap();
            example_unet_segmentation().unwrap();
            example_manual_loop().unwrap();
        }
        _ => println("Select an example to run"),
    }
}
