// ── Sub-modules ──────────────────────────────────────────────────────────────
open native
open tensor
open nn
open optim
open models

// ── Core Re-exports ──────────────────────────────────────────────────────────
open tensor::Tensor       as Tensor;
open tensor::Shape        as Shape;
open tensor::DType        as DType;
open tensor::Device       as Device;
open tensor::Storage      as Storage;
open tensor::NoGradGuard  as NoGradGuard;

// ── nn Re-exports ────────────────────────────────────────────────────────────
open nn::Module           as Module;
open nn::Parameter        as Parameter;
open nn::Linear           as Linear;
open nn::Conv2d           as Conv2d;
open nn::Conv1d           as Conv1d;
open nn::MaxPool2d        as MaxPool2d;
open nn::AdaptiveAvgPool2d as AdaptiveAvgPool2d;
open nn::BatchNorm2d      as BatchNorm2d;
open nn::LayerNorm        as LayerNorm;
open nn::GroupNorm        as GroupNorm;
open nn::Dropout          as Dropout;
open nn::Embedding        as Embedding;
open nn::MultiheadAttention as MultiheadAttention;
open nn::Sequential       as Sequential;
open nn::ReLU             as ReLU;
open nn::GELU             as GELU;
open nn::SiLU             as SiLU;
open nn::Sigmoid          as Sigmoid;
open nn::Tanh             as Tanh;
open nn::Softmax          as Softmax;
open nn::Mish             as Mish;
open nn::LeakyReLU        as LeakyReLU;

// ── optim Re-exports ─────────────────────────────────────────────────────────
open optim::Optimizer         as Optimizer;
open optim::Scheduler         as Scheduler;
open optim::StepLR            as StepLR;
open optim::CosineAnnealingLR as CosineAnnealingLR;
open optim::WarmupScheduler   as WarmupScheduler;
open optim::CrossEntropyLoss  as CrossEntropyLoss;
open optim::MSELoss           as MSELoss;
open optim::MAELoss           as MAELoss;
open optim::BCEWithLogitsLoss as BCEWithLogitsLoss;
open optim::HuberLoss         as HuberLoss;
open optim::KLDivLoss         as KLDivLoss;
open optim::TripletMarginLoss as TripletMarginLoss;
open optim::FocalLoss         as FocalLoss;
open optim::Reduction         as Reduction;
open optim::MetricAccumulator as MetricAccumulator;
open optim::DataLoader        as DataLoader;
open optim::TrainConfig       as TrainConfig;
open optim::Trainer           as Trainer;
open optim::accuracy          as accuracy;
open optim::top_k_accuracy    as top_k_accuracy;

// ── models Re-exports ────────────────────────────────────────────────────────
open models::ResidualBlock    as ResidualBlock;
open models::ResNet           as ResNet;
open models::TransformerBlock as TransformerBlock;
open models::GPT              as GPT;
open models::GptConfig        as GptConfig;
open models::UNet             as UNet;
open models::UNetBlock        as UNetBlock;
