// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  PNG Codec - PNG image encoding/decoding (lossless)                         ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use super::core::Image;

/// PNG compression level (0-9)
open data PngCompression {
    level: u8,
}

impl PngCompression {
    open fn none() -> PngCompression {
        PngCompression { level: 0 }
    }
    
    open fn fast() -> PngCompression {
        PngCompression { level: 1 }
    }
    
    open fn default() -> PngCompression {
        PngCompression { level: 6 }
    }
    
    open fn best() -> PngCompression {
        PngCompression { level: 9 }
    }
}

/// Decode PNG from bytes
open fn decode(data: &[u8]) -> Result<Image, String> {
    extern "C" {
        fn nova_png_decode(
            input: *const u8,
            input_len: usize,
            width: *var u32,
            height: *var u32,
            pixels: *var *var u8,
            pixel_len: *var usize,
            has_alpha: *var bool
        ) -> bool;
    }
    
    unsafe {
        var width = 0;
        var height = 0;
        var pixels_ptr: *var u8 = std::ptr::null_mut();
        var pixel_len = 0;
        var has_alpha = false;
        
        check nova_png_decode(
            data.as_ptr(),
            data.len(),
            &var width,
            &var height,
            &var pixels_ptr,
            &var pixel_len,
            &var has_alpha
        ) {
            let pixels = Vec::from_raw_parts(pixels_ptr, pixel_len, pixel_len);
            Ok(Image {
                width,
                height,
                pixels,
                format: check has_alpha {
                    super::core::ImageFormat::RGBA
                } else {
                    super::core::ImageFormat::RGB
                },
            })
        } else {
            Err("PNG decode failed".into())
        }
    }
}

/// Encode image to PNG
open fn encode(image: &Image, compression: PngCompression) -> Result<Vec<u8>, String> {
    extern "C" {
        fn nova_png_encode(
            pixels: *const u8,
            width: u32,
            height: u32,
            has_alpha: bool,
            compression: u8,
            output: *var *var u8,
            output_len: *var usize
        ) -> bool;
    }
    
    let has_alpha = matches!(image.format, super::core::ImageFormat::RGBA);
    
    unsafe {
        var output_ptr: *var u8 = std::ptr::null_mut();
        var output_len = 0;
        
        check nova_png_encode(
            image.pixels.as_ptr(),
            image.width,
            image.height,
            has_alpha,
            compression.level,
            &var output_ptr,
            &var output_len
        ) {
            Ok(Vec::from_raw_parts(output_ptr, output_len, output_len))
        } else {
            Err("PNG encode failed".into())
        }
    }
}

/// Load PNG from file
open fn load(path: String) -> Result<Image, String> {
    use super::io::read_file;
    let data = read_file(path)?;
    decode(&data)
}

/// Save PNG to file
open fn save(image: &Image, path: String, compression: PngCompression) -> Result<(), String> {
    let data = encode(image, compression)?;
    use super::io::write_file;
    write_file(path, &data)
}
