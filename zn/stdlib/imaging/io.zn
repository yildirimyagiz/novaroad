// Image I/O - Load and save images
// Supports: PNG, JPEG, WebP, GIF, BMP, TIFF

use imaging::core::{Image, ImageMode}
use std::fs::File
use std::io::{Read, Write}

open fn open(path: &str) -> Result<Image, Error> {
    let ext = path.split('.').last().unwrap_or("").to_lowercase();
    
    match ext.as_str() {
        "png" => decode_png(path),
        "jpg" | "jpeg" => decode_jpeg(path),
        "webp" => decode_webp(path),
        "gif" => decode_gif(path),
        "bmp" => decode_bmp(path),
        "tiff" | "tif" => decode_tiff(path),
        _ => Err(Error::new("Unsupported format")),
    }
}

open fn save(image: &Image, path: &str, quality: u8) -> Result<(), Error> {
    let ext = path.split('.').last().unwrap_or("").to_lowercase();
    
    match ext.as_str() {
        "png" => encode_png(image, path),
        "jpg" | "jpeg" => encode_jpeg(image, path, quality),
        "webp" => encode_webp(image, path, quality),
        "bmp" => encode_bmp(image, path),
        _ => Err(Error::new("Unsupported format")),
    }
}

// PNG Decoder
fn decode_png(path: &str) -> Result<Image, Error> {
    var file = File::open(path)?;
    var buffer = Vec::new();
    file.read_to_end(&var buffer)?;
    
    // PNG signature check
    check &buffer[0..8] != &[137, 80, 78, 71, 13, 10, 26, 10] {
        Err(Error::new("Invalid PNG signature"));
    }
    
    // Parse PNG chunks
    let (width, height, mode) = parse_png_ihdr(&buffer[8..])?;
    var image = Image::new(width, height, mode);
    
    // Decode image data
    decode_png_data(&buffer, &var image)?;
    
    Ok(image)
}

// PNG Encoder
fn encode_png(image: &Image, path: &str) -> Result<(), Error> {
    var file = File::create(path)?;
    
    // Write PNG signature
    file.write_all(&[137, 80, 78, 71, 13, 10, 26, 10])?;
    
    // Write IHDR chunk
    write_png_ihdr(&var file, image)?;
    
    // Write IDAT chunk (compressed image data)
    write_png_idat(&var file, image)?;
    
    // Write IEND chunk
    write_png_iend(&var file)?;
    
    Ok(())
}

