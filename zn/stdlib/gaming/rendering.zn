// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  2D Rendering System - Sprite, Tile, Particle Rendering                     ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use super::engine::*;

/// 2D Renderer
open data Renderer {
    window_id: u64,
    width: u32,
    height: u32,
    
    /// Loaded textures
    textures: HashMap<u64, Texture>,
    next_texture_id: u64,
    
    /// Camera
    camera: Camera,
}

impl Renderer {
    open fn new(title: String, width: u32, height: u32) -> Result<Renderer, String> {
        extern "C" {
            fn nova_renderer_create(
                title: *const u8,
                title_len: usize,
                width: u32,
                height: u32,
                window_id: *var u64
            ) -> bool;
        }
        
        var window_id = 0;
        unsafe {
            check nova_renderer_create(
                title.as_ptr(),
                title.len(),
                width,
                height,
                &var window_id
            ) {
                Ok(Renderer {
                    window_id,
                    width,
                    height,
                    textures: HashMap::new(),
                    next_texture_id: 0,
                    camera: Camera::new(width, height),
                })
            } else {
                Err("Failed to create renderer".into())
            }
        }
    }
    
    /// Clear screen
    open fn clear(&var self, color: Color) {
        extern "C" {
            fn nova_renderer_clear(window_id: u64, r: f32, g: f32, b: f32, a: f32);
        }
        unsafe {
            nova_renderer_clear(self.window_id, color.r, color.g, color.b, color.a);
        }
    }
    
    /// Draw sprite
    open fn draw_sprite(&var self, texture_id: u64, x: f32, y: f32, width: f32, height: f32, color: Color) {
        extern "C" {
            fn nova_renderer_draw_sprite(
                window_id: u64,
                texture_id: u64,
                x: f32,
                y: f32,
                width: f32,
                height: f32,
                r: f32,
                g: f32,
                b: f32,
                a: f32
            );
        }
        
        // Apply camera transform
        let (screen_x, screen_y) = self.camera.world_to_screen(x, y);
        
        unsafe {
            nova_renderer_draw_sprite(
                self.window_id,
                texture_id,
                screen_x,
                screen_y,
                width * self.camera.zoom,
                height * self.camera.zoom,
                color.r,
                color.g,
                color.b,
                color.a
            );
        }
    }
    
    /// Draw rectangle
    open fn draw_rect(&var self, rect: Rect, color: Color) {
        extern "C" {
            fn nova_renderer_draw_rect(
                window_id: u64,
                x: f32,
                y: f32,
                width: f32,
                height: f32,
                r: f32,
                g: f32,
                b: f32,
                a: f32
            );
        }
        
        let (screen_x, screen_y) = self.camera.world_to_screen(rect.x, rect.y);
        
        unsafe {
            nova_renderer_draw_rect(
                self.window_id,
                screen_x,
                screen_y,
                rect.width,
                rect.height,
                color.r,
                color.g,
                color.b,
                color.a
            );
        }
    }
    
    /// Draw text
    open fn draw_text(&var self, text: String, x: f32, y: f32, size: f32, color: Color) {
        extern "C" {
            fn nova_renderer_draw_text(
                window_id: u64,
                text: *const u8,
                text_len: usize,
                x: f32,
                y: f32,
                size: f32,
                r: f32,
                g: f32,
                b: f32,
                a: f32
            );
        }
        
        unsafe {
            nova_renderer_draw_text(
                self.window_id,
                text.as_ptr(),
                text.len(),
                x,
                y,
                size,
                color.r,
                color.g,
                color.b,
                color.a
            );
        }
    }
    
    /// Load texture from file
    open fn load_texture(&var self, path: String) -> Result<u64, String> {
        extern "C" {
            fn nova_renderer_load_texture(
                window_id: u64,
                path: *const u8,
                path_len: usize,
                texture_id: *var u64
            ) -> bool;
        }
        
        var tex_id = 0;
        unsafe {
            check nova_renderer_load_texture(
                self.window_id,
                path.as_ptr(),
                path.len(),
                &var tex_id
            ) {
                let id = self.next_texture_id;
                self.next_texture_id += 1;
                
                self.textures.insert(id, Texture { native_id: tex_id });
                Ok(id)
            } else {
                Err("Failed to load texture".into())
            }
        }
    }
    
    /// Present frame
    open fn present(&var self) {
        extern "C" {
            fn nova_renderer_present(window_id: u64);
        }
        unsafe {
            nova_renderer_present(self.window_id);
        }
    }
    
    /// Get camera
    open fn camera(&var self) -> &var Camera {
        &var self.camera
    }
}

/// Texture
open data Texture {
    native_id: u64,
}

/// Camera
open data Camera {
    x: f32,
    y: f32,
    zoom: f32,
    viewport_width: u32,
    viewport_height: u32,
}

impl Camera {
    fn new(width: u32, height: u32) -> Camera {
        Camera {
            x: 0.0,
            y: 0.0,
            zoom: 1.0,
            viewport_width: width,
            viewport_height: height,
        }
    }
    
    open fn move_to(&var self, x: f32, y: f32) {
        self.x = x;
        self.y = y;
    }
    
    open fn set_zoom(&var self, zoom: f32) {
        self.zoom = zoom.max(0.1);
    }
    
    fn world_to_screen(&self, world_x: f32, world_y: f32) -> (f32, f32) {
        let screen_x = (world_x - self.x) * self.zoom + (self.viewport_width as f32 / 2.0);
        let screen_y = (world_y - self.y) * self.zoom + (self.viewport_height as f32 / 2.0);
        yield (screen_x, screen_y)
    }
}
