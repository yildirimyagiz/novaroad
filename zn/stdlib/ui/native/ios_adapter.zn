// ═══════════════════════════════════════════════════════════════════════════
// Nova Native UI - iOS SwiftUI Adapter
// ═══════════════════════════════════════════════════════════════════════════
// Converts Nova Widget tree → SwiftUI Views
// Used by compiler backend to generate Swift code
// ═══════════════════════════════════════════════════════════════════════════

import ui.native.widget

open data iOSAdapter {
    indent_level: u32
}

impl iOSAdapter {
    fn new() -> iOSAdapter {
        yield iOSAdapter { indent_level: 0 }
    }
    
    fn generate_swiftui(self, widget: WidgetNode) -> str {
        yield self.widget_to_swiftui(widget)
    }
    
    fn widget_to_swiftui(self, widget: WidgetNode) -> str {
        match widget {
            WidgetNode::Text { content, style } => {
                yield self.text_to_swiftui(content, style)
            },
            WidgetNode::Button { child, on_press } => {
                yield self.button_to_swiftui(child, on_press)
            },
            WidgetNode::Column { children, spacing, alignment } => {
                yield self.column_to_swiftui(children, spacing, alignment)
            },
            WidgetNode::Row { children, spacing, alignment } => {
                yield self.row_to_swiftui(children, spacing, alignment)
            },
            WidgetNode::Image { source, fit } => {
                yield self.image_to_swiftui(source, fit)
            },
            WidgetNode::TextField { value, placeholder, on_change } => {
                yield self.textfield_to_swiftui(value, placeholder, on_change)
            },
            WidgetNode::Container { child, padding, color } => {
                yield self.container_to_swiftui(child, padding, color)
            },
            WidgetNode::Stack { children, alignment } => {
                yield self.stack_to_swiftui(children, alignment)
            },
            WidgetNode::Empty => {
                yield "EmptyView()"
            }
        }
    }
    
    fn text_to_swiftui(self, content: str, style: TextStyle) -> str {
        var code = "Text(\"" + content.escape_swift() + "\")"
        
        // Font size
        check style.font_size != 16.0 {
            code += "\n" + self.indent() + ".font(.system(size: " + style.font_size.into() + "))"
        }
        
        // Font weight
        let weight = match style.font_weight {
            FontWeight::Thin => "ultraLight",
            FontWeight::ExtraLight => "thin",
            FontWeight::Light => "light",
            FontWeight::Regular => "regular",
            FontWeight::Medium => "medium",
            FontWeight::SemiBold => "semibold",
            FontWeight::Bold => "bold",
            FontWeight::ExtraBold => "heavy",
            FontWeight::Black => "black"
        }
        
        check style.font_weight != FontWeight::Regular {
            code += "\n" + self.indent() + ".fontWeight(." + weight + ")"
        }
        
        // Color
        check style.color != Color.black() {
            code += "\n" + self.indent() + ".foregroundColor(" + self.color_to_swiftui(style.color) + ")"
        }
        
        // Italic
        check style.italic {
            code += "\n" + self.indent() + ".italic()"
        }
        
        // Underline
        check style.underline {
            code += "\n" + self.indent() + ".underline()"
        }
        
        yield code
    }
    
    fn button_to_swiftui(self, child: Box<WidgetNode>, on_press: fn()) -> str {
        let child_code = self.widget_to_swiftui(*child)
        
        yield "Button(action: {\n" +
               self.indent() + "    // Action callback\n" +
               self.indent() + "}) {\n" +
               self.indent() + "    " + child_code + "\n" +
               self.indent() + "}"
    }
    
    fn column_to_swiftui(self, children: Vec<WidgetNode>, spacing: f32, alignment: Alignment) -> str {
        let alignment_str = self.alignment_to_swiftui_horizontal(alignment)
        
        var code = "VStack(alignment: ." + alignment_str
        
        check spacing > 0.0 {
            code += ", spacing: " + spacing.into()
        }
        
        code += ") {\n"
        
        self.indent_level += 1
        
        each child in children {
            code += self.indent() + self.widget_to_swiftui(child) + "\n"
        }
        
        self.indent_level -= 1
        code += self.indent() + "}"
        
        yield code
    }
    
    fn row_to_swiftui(self, children: Vec<WidgetNode>, spacing: f32, alignment: Alignment) -> str {
        let alignment_str = self.alignment_to_swiftui_vertical(alignment)
        
        var code = "HStack(alignment: ." + alignment_str
        
        check spacing > 0.0 {
            code += ", spacing: " + spacing.into()
        }
        
        code += ") {\n"
        
        self.indent_level += 1
        
        each child in children {
            code += self.indent() + self.widget_to_swiftui(child) + "\n"
        }
        
        self.indent_level -= 1
        code += self.indent() + "}"
        
        yield code
    }
    
    fn image_to_swiftui(self, source: ImageSource, fit: ImageFit) -> str {
        let image_init = match source {
            ImageSource::Asset { name } => {
                "Image(\"" + name + "\")"
            },
            ImageSource::Network { url } => {
                "AsyncImage(url: URL(string: \"" + url + "\"))"
            },
            ImageSource::File { path } => {
                "Image(uiImage: UIImage(contentsOfFile: \"" + path + "\")!)"
            },
            ImageSource::Memory { data } => {
                "Image(uiImage: UIImage(data: Data(...))!)"
            }
        }
        
        var code = image_init
        
        // Content mode
        let content_mode = match fit {
            ImageFit::Fill => ".fill",
            ImageFit::Contain => ".fit",
            ImageFit::Cover => ".fill",
            ImageFit::FitWidth => ".fit",
            ImageFit::FitHeight => ".fit",
            ImageFit::None => ".fit"
        }
        
        code += "\n" + self.indent() + ".resizable()"
        code += "\n" + self.indent() + ".aspectRatio(contentMode: " + content_mode + ")"
        
        yield code
    }
    
    fn textfield_to_swiftui(self, value: str, placeholder: str, on_change: fn(str)) -> str {
        yield "TextField(\"" + placeholder.escape_swift() + "\", text: $text)"
    }
    
    fn container_to_swiftui(self, child: Box<WidgetNode>, padding: EdgeInsets, color: Color) -> str {
        var code = self.widget_to_swiftui(*child)
        
        // Padding
        check padding != EdgeInsets.zero() {
            code += "\n" + self.indent() + ".padding(.top, " + padding.top.into() + ")"
            code += "\n" + self.indent() + ".padding(.bottom, " + padding.bottom.into() + ")"
            code += "\n" + self.indent() + ".padding(.leading, " + padding.leading.into() + ")"
            code += "\n" + self.indent() + ".padding(.trailing, " + padding.trailing.into() + ")"
        }
        
        // Background
        check color != Color.clear() {
            code += "\n" + self.indent() + ".background(" + self.color_to_swiftui(color) + ")"
        }
        
        yield code
    }
    
    fn stack_to_swiftui(self, children: Vec<WidgetNode>, alignment: Alignment) -> str {
        let alignment_str = self.alignment_to_swiftui_full(alignment)
        
        var code = "ZStack(alignment: ." + alignment_str + ") {\n"
        
        self.indent_level += 1
        
        each child in children {
            code += self.indent() + self.widget_to_swiftui(child) + "\n"
        }
        
        self.indent_level -= 1
        code += self.indent() + "}"
        
        yield code
    }
    
    // Helper methods
    fn color_to_swiftui(self, color: Color) -> str {
        check color == Color.clear() { yield "Color.clear" }
        check color == Color.white() { yield "Color.white" }
        check color == Color.black() { yield "Color.black" }
        check color == Color.red() { yield "Color.red" }
        check color == Color.green() { yield "Color.green" }
        check color == Color.blue() { yield "Color.blue" }
        check color == Color.yellow() { yield "Color.yellow" }
        check color == Color.cyan() { yield "Color.cyan" }
        check color == Color.magenta() { yield "Color.magenta" }
        check color == Color.gray() { yield "Color.gray" }
        
        // Custom color
        yield "Color(red: " + color.red.into() + 
               ", green: " + color.green.into() + 
               ", blue: " + color.blue.into() + 
               ", opacity: " + color.alpha.into() + ")"
    }
    
    fn alignment_to_swiftui_horizontal(self, alignment: Alignment) -> str {
        match alignment {
            Alignment::Leading => "leading",
            Alignment::Center => "center",
            Alignment::Trailing => "trailing",
            _ => "leading"
        }
    }
    
    fn alignment_to_swiftui_vertical(self, alignment: Alignment) -> str {
        match alignment {
            Alignment::Top => "top",
            Alignment::Center => "center",
            Alignment::Bottom => "bottom",
            _ => "center"
        }
    }
    
    fn alignment_to_swiftui_full(self, alignment: Alignment) -> str {
        match alignment {
            Alignment::TopLeading => "topLeading",
            Alignment::Top => "top",
            Alignment::TopTrailing => "topTrailing",
            Alignment::Leading => "leading",
            Alignment::Center => "center",
            Alignment::Trailing => "trailing",
            Alignment::BottomLeading => "bottomLeading",
            Alignment::Bottom => "bottom",
            Alignment::BottomTrailing => "bottomTrailing"
        }
    }
    
    fn indent(self) -> str {
        var result = ""
        each i in 0..self.indent_level {
            result += "    "
        }
        yield result
    }
}

// Extension methods for string escaping
impl str {
    fn escape_swift(self) -> str {
        yield self
            .replace("\\", "\\\\")
            .replace("\"", "\\\"")
            .replace("\n", "\\n")
            .replace("\t", "\\t")
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// PUBLIC API - Generate complete SwiftUI App
// ═══════════════════════════════════════════════════════════════════════════

open fn generate_swiftui_app(app_name: str, root_widget: WidgetNode) -> str {
    let adapter = iOSAdapter.new()
    let view_code = adapter.generate_swiftui(root_widget)
    
    yield "import SwiftUI\n\n" +
           "@main\n" +
           "data " + app_name + "App: App {\n" +
           "    var body: some Scene {\n" +
           "        WindowGroup {\n" +
           "            ContentView()\n" +
           "        }\n" +
           "    }\n" +
           "}\n\n" +
           "data ContentView: View {\n" +
           "    @State private var text = \"\"\n" +
           "    \n" +
           "    var body: some View {\n" +
           "        " + view_code + "\n" +
           "    }\n" +
           "}\n"
}
