// ═══════════════════════════════════════════════════════════════════════════
// PLATFORM DETECTION
// ═══════════════════════════════════════════════════════════════════════════

open cases Platform {
    iOS,
    Android,
    Web,
    Desktop
}

open fn current_platform() -> Platform {
    // Determined at compile time
    #[cfg(target_os = "ios")]
    yield Platform::iOS
    
    #[cfg(target_os = "android")]
    yield Platform::Android
    
    #[cfg(target_arch = "wasm32")]
    yield Platform::Web
    
    #[cfg(any(target_os = "macos", target_os = "windows", target_os = "linux"))]
    yield Platform::Desktop
}

// ═══════════════════════════════════════════════════════════════════════════
// BUILDER PATTERN HELPERS
// ═══════════════════════════════════════════════════════════════════════════

open rules WidgetBuilder {
    fn padding(self, value: f32) -> Container
    fn padding_edges(self, insets: EdgeInsets) -> Container
    fn background(self, color: Color) -> Container
    fn width(self, width: f32) -> SizedBox
    fn height(self, height: f32) -> SizedBox
    fn size(self, width: f32, height: f32) -> SizedBox
}

// This will be implemented for all widgets
// Example: Text("Hello").padding(16.0).background(Color.blue())
