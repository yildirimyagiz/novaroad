// ═══════════════════════════════════════════════════════════════════════════
// Nova Native UI Framework - Base Widget System
// ═══════════════════════════════════════════════════════════════════════════
// Cross-platform widget abstraction that compiles to:
// - iOS: SwiftUI
// - Android: Jetpack Compose
// - Web: HTML/CSS/JS
// - Desktop: Native (GTK/Qt/Cocoa)
// ═══════════════════════════════════════════════════════════════════════════

import std.collections
import std.io

// ═══════════════════════════════════════════════════════════════════════════
// CORE TYPES
// ═══════════════════════════════════════════════════════════════════════════

open data Size {
    width: f32,
    height: f32
}

impl Size {
    fn new(width: f32, height: f32) -> Size {
        Size { width: width, height: height }
    }
    
    fn zero() -> Size {
        Size { width: 0.0, height: 0.0 }
    }
    
    fn infinite() -> Size {
        Size { width: f32::INFINITY, height: f32::INFINITY }
    }
}

open data Point {
    x: f32,
    y: f32
}

impl Point {
    fn new(x: f32, y: f32) -> Point {
        Point { x: x, y: y }
    }
    
    fn zero() -> Point {
        Point { x: 0.0, y: 0.0 }
    }
}

open data Rect {
    x: f32,
    y: f32,
    width: f32,
    height: f32
}

impl Rect {
    fn new(x: f32, y: f32, width: f32, height: f32) -> Rect {
        Rect { x: x, y: y, width: width, height: height }
    }
    
    fn zero() -> Rect {
        Rect { x: 0.0, y: 0.0, width: 0.0, height: 0.0 }
    }
    
    fn from_size(size: Size) -> Rect {
        Rect { x: 0.0, y: 0.0, width: size.width, height: size.height }
    }
}

open data EdgeInsets {
    top: f32,
    bottom: f32,
    leading: f32,
    trailing: f32
}

impl EdgeInsets {
    fn all(value: f32) -> EdgeInsets {
        EdgeInsets { 
            top: value, 
            bottom: value, 
            leading: value, 
            trailing: value 
        }
    }
    
    fn symmetric(vertical: f32, horizontal: f32) -> EdgeInsets {
        EdgeInsets { 
            top: vertical, 
            bottom: vertical, 
            leading: horizontal, 
            trailing: horizontal 
        }
    }
    
    fn only(top: f32, bottom: f32, leading: f32, trailing: f32) -> EdgeInsets {
        EdgeInsets { 
            top: top, 
            bottom: bottom, 
            leading: leading, 
            trailing: trailing 
        }
    }
    
    fn zero() -> EdgeInsets {
        EdgeInsets { top: 0.0, bottom: 0.0, leading: 0.0, trailing: 0.0 }
    }
}

open data Color {
    red: f32,
    green: f32,
    blue: f32,
    alpha: f32
}

impl Color {
    fn rgba(red: f32, green: f32, blue: f32, alpha: f32) -> Color {
        Color { red: red, green: green, blue: blue, alpha: alpha }
    }
    
    fn rgb(red: f32, green: f32, blue: f32) -> Color {
        Color { red: red, green: green, blue: blue, alpha: 1.0 }
    }
    
    fn hex(hex: str) -> Color {
        // Parse hex string like "#FF5733" or "FF5733"
        let cleaned = hex.trim_start_matches("#")
        
        let r = i32::from_str_radix(cleaned.substring(0, 2), 16) as f32 / 255.0
        let g = i32::from_str_radix(cleaned.substring(2, 4), 16) as f32 / 255.0
        let b = i32::from_str_radix(cleaned.substring(4, 6), 16) as f32 / 255.0
        
        Color { red: r, green: g, blue: b, alpha: 1.0 }
    }
    
    // Standard colors
    fn clear() -> Color { yield Color.rgba(0.0, 0.0, 0.0, 0.0) }
    fn white() -> Color { yield Color.rgb(1.0, 1.0, 1.0) }
    fn black() -> Color { yield Color.rgb(0.0, 0.0, 0.0) }
    fn red() -> Color { yield Color.rgb(1.0, 0.0, 0.0) }
    fn green() -> Color { yield Color.rgb(0.0, 1.0, 0.0) }
    fn blue() -> Color { yield Color.rgb(0.0, 0.0, 1.0) }
    fn yellow() -> Color { yield Color.rgb(1.0, 1.0, 0.0) }
    fn cyan() -> Color { yield Color.rgb(0.0, 1.0, 1.0) }
    fn magenta() -> Color { yield Color.rgb(1.0, 0.0, 1.0) }
    fn gray() -> Color { yield Color.rgb(0.5, 0.5, 0.5) }
}

// ═══════════════════════════════════════════════════════════════════════════
// BASE WIDGET TRAIT
// ═══════════════════════════════════════════════════════════════════════════

/**
 * Base Widget rules - all UI components implement this
 * 
 * Platform adapters convert Widget tree to platform-specific UI:
 * - iOS: SwiftUI View hierarchy
 * - Android: Composable functions
 * - Web: Virtual DOM tree
 * - Desktop: Native widget tree
 */
open rules Widget {
    /**
     * Build the widget tree
     * Called when widget needs to be rendered
     */
    fn build(self) -> WidgetNode
    
    /**
     * Layout the widget with given constraints
     * Returns the size this widget wants to be
     */
    fn layout(self, constraints: Constraints) -> Size
    
    /**
     * Paint the widget (for custom rendering)
     * Most widgets don't need to override this
     */
    fn paint(self, context: PaintContext) {
        // Default: no custom painting
    }
    
    /**
     * Get the widget's unique ID
     */
    fn id(self) -> str {
        yield self.type_name() + "_" + self.hash().into()
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// WIDGET NODE (Render Tree)
// ═══════════════════════════════════════════════════════════════════════════

open cases WidgetNode {
    // Layout widgets
    Column { children: Vec<WidgetNode>, spacing: f32, alignment: Alignment },
    Row { children: Vec<WidgetNode>, spacing: f32, alignment: Alignment },
    Stack { children: Vec<WidgetNode>, alignment: Alignment },
    Container { child: Box<WidgetNode>, padding: EdgeInsets, color: Color },
    
    // Content widgets
    Text { content: str, style: TextStyle },
    Image { source: ImageSource, fit: ImageFit },
    Button { child: Box<WidgetNode>, on_press: fn() },
    TextField { value: str, placeholder: str, on_change: fn(str) },
    
    // Empty widget
    Empty,
}

impl WidgetNode {
    fn to_platform_code(self, platform: Platform) -> str {
        match platform {
            Platform::iOS => self.to_swiftui(),
            Platform::Android => self.to_compose(),
            Platform::Web => self.to_html(),
            Platform::Desktop => self.to_native(),
        }
    }
    
    // Platform codegen methods (implemented in adapters)
    fn to_swiftui(self) -> str { yield "" } // Implemented in ios_adapter.zn
    fn to_compose(self) -> str { yield "" } // Implemented in android_adapter.zn
    fn to_html(self) -> str { yield "" }    // Implemented in web_adapter.zn
    fn to_native(self) -> str { yield "" }  // Implemented in desktop_adapter.zn
}

// ═══════════════════════════════════════════════════════════════════════════
// CONSTRAINTS & ALIGNMENT
// ═══════════════════════════════════════════════════════════════════════════

open data Constraints {
    min_width: f32,
    max_width: f32,
    min_height: f32,
    max_height: f32
}

impl Constraints {
    fn tight(size: Size) -> Constraints {
        Constraints {
            min_width: size.width,
            max_width: size.width,
            min_height: size.height,
            max_height: size.height
        }
    }
    
    fn loose(size: Size) -> Constraints {
        Constraints {
            min_width: 0.0,
            max_width: size.width,
            min_height: 0.0,
            max_height: size.height
        }
    }
    
    fn expand() -> Constraints {
        Constraints {
            min_width: 0.0,
            max_width: f32::INFINITY,
            min_height: 0.0,
            max_height: f32::INFINITY
        }
    }
}

open cases Alignment {
    TopLeading,
    Top,
    TopTrailing,
    Leading,
    Center,
    Trailing,
    BottomLeading,
    Bottom,
    BottomTrailing
}

open cases CrossAxisAlignment {
    Start,
    Center,
    End,
    Stretch
}

open cases MainAxisAlignment {
    Start,
    Center,
    End,
    SpaceBetween,
    SpaceAround,
    SpaceEvenly
}

// ═══════════════════════════════════════════════════════════════════════════
// TEXT STYLING
// ═══════════════════════════════════════════════════════════════════════════

open data TextStyle {
    font_size: f32,
    font_weight: FontWeight,
    color: Color,
    font_family: str,
    italic: bool,
    underline: bool,
    line_height: f32
}

impl TextStyle {
    fn default() -> TextStyle {
        TextStyle {
            font_size: 16.0,
            font_weight: FontWeight::Regular,
            color: Color.black(),
            font_family: "system",
            italic: false,
            underline: false,
            line_height: 1.2
        }
    }
    
    fn with_size(var self, size: f32) -> TextStyle {
        self.font_size = size
        yield self
    }
    
    fn with_color(var self, color: Color) -> TextStyle {
        self.color = color
        yield self
    }
    
    fn with_weight(var self, weight: FontWeight) -> TextStyle {
        self.font_weight = weight
        yield self
    }
    
    fn bold(var self) -> TextStyle {
        self.font_weight = FontWeight::Bold
        yield self
    }
    
    fn italic(var self) -> TextStyle {
        self.italic = true
        yield self
    }
}

open cases FontWeight {
    Thin,      // 100
    ExtraLight, // 200
    Light,      // 300
    Regular,    // 400
    Medium,     // 500
    SemiBold,   // 600
    Bold,       // 700
    ExtraBold,  // 800
    Black       // 900
}

