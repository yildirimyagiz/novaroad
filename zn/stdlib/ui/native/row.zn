// ═══════════════════════════════════════════════════════════════════════════
// Nova Native UI - Row Widget (Horizontal Layout)
// ═══════════════════════════════════════════════════════════════════════════
// Cross-platform horizontal stacking
// iOS → SwiftUI HStack
// Android → Compose Row
// Web → <div style="flex-direction: row">
// Desktop → Horizontal box layout
// ═══════════════════════════════════════════════════════════════════════════

import ui.native.widget

open data Row {
    children: Vec<Box<dyn Widget>>,
    spacing: f32,
    main_axis_alignment: MainAxisAlignment,
    cross_axis_alignment: CrossAxisAlignment
}

impl Row {
    fn new(children: Vec<Box<dyn Widget>>) -> Row {
        Row {
            children: children,
            spacing: 0.0,
            main_axis_alignment: MainAxisAlignment::Start,
            cross_axis_alignment: CrossAxisAlignment::Start
        }
    }
    
    fn empty() -> Row {
        Row {
            children: Vec.new(),
            spacing: 0.0,
            main_axis_alignment: MainAxisAlignment::Start,
            cross_axis_alignment: CrossAxisAlignment::Start
        }
    }
    
    // Builder methods
    fn spacing(var self, spacing: f32) -> Row {
        self.spacing = spacing
        yield self
    }
    
    fn main_axis_alignment(var self, alignment: MainAxisAlignment) -> Row {
        self.main_axis_alignment = alignment
        yield self
    }
    
    fn cross_axis_alignment(var self, alignment: CrossAxisAlignment) -> Row {
        self.cross_axis_alignment = alignment
        yield self
    }
    
    fn center(var self) -> Row {
        self.main_axis_alignment = MainAxisAlignment::Center
        self.cross_axis_alignment = CrossAxisAlignment::Center
        yield self
    }
    
    fn add(var self, child: Box<dyn Widget>) -> Row {
        self.children.push(child)
        yield self
    }
}

impl Widget for Row {
    fn build(self) -> WidgetNode {
        var child_nodes = Vec.new()
        
        each child in self.children {
            child_nodes.push(child.build())
        }
        
        yield WidgetNode::Row {
            children: child_nodes,
            spacing: self.spacing,
            alignment: self.cross_axis_alignment_to_alignment()
        }
    }
    
    fn layout(self, constraints: Constraints) -> Size {
        var total_width = 0.0
        var max_height = 0.0
        let child_count = self.children.len()
        
        each entry in self.children.iter().enumerate()  { let (i, child) = entry;
            let child_size = child.layout(constraints)
            
            total_width += child_size.width
            max_height = max_height.max(child_size.height)
            
            // Add spacing between children (not after last)
            check i < child_count - 1 {
                total_width += self.spacing
            }
        }
        
        yield Size.new(total_width, max_height)
    }
}

impl Row {
    fn cross_axis_alignment_to_alignment(self) -> Alignment {
        match self.cross_axis_alignment {
            CrossAxisAlignment::Start => Alignment::Top,
            CrossAxisAlignment::Center => Alignment::Center,
            CrossAxisAlignment::End => Alignment::Bottom,
            CrossAxisAlignment::Stretch => Alignment::Top, // Stretch handled separately
        }
    }
}
