// ═══════════════════════════════════════════════════════════════════════════
// Nova Native UI Framework - Module Index
// ═══════════════════════════════════════════════════════════════════════════
// Cross-platform UI framework that compiles to native code
// ═══════════════════════════════════════════════════════════════════════════

// Core types and traits
open use widget::*

// Widgets
open use text::Text
open use button::Button
open use column::Column
open use row::Row
open use image::Image
open use textfield::TextField

// Platform adapters
open use ios_adapter::*
open use android_adapter::*
open use web_adapter::*
open use desktop_adapter::*

// ═══════════════════════════════════════════════════════════════════════════
// Convenience API - Build apps easily
// ═══════════════════════════════════════════════════════════════════════════

open fn build_app(name: str, root: fn() -> WidgetNode) -> App {
    yield App.new(name, root())
}

open data App {
    name: str,
    root: WidgetNode,
    theme: Theme
}

impl App {
    fn new(name: str, root: WidgetNode) -> App {
        App {
            name: name,
            root: root,
            theme: Theme.default()
        }
    }
    
    fn with_theme(var self, theme: Theme) -> App {
        self.theme = theme
        yield self
    }
    
    fn run(self) {
        let platform = current_platform()
        
        match platform {
            Platform::iOS => self.run_ios(),
            Platform::Android => self.run_android(),
            Platform::Web => self.run_web(),
            Platform::Desktop => self.run_desktop()
        }
    }
    
    fn run_ios(self) {
        let swift_code = generate_swiftui_app(self.name, self.root)
        // Compiler will handle the rest
    }
    
    fn run_android(self) {
        let kotlin_code = generate_compose_app("com.nova.app", self.name, self.root)
        // Compiler will handle the rest
    }
    
    fn run_web(self) {
        let html = generate_web_app(self.name, self.root)
        // Compiler will handle the rest
    }
    
    fn run_desktop(self) {
        let platform = detect_desktop_platform()
        let code = generate_desktop_app(platform, self.name, self.root)
        // Compiler will handle the rest
    }
}

fn detect_desktop_platform() -> DesktopPlatform {
    #[cfg(target_os = "macos")]
    yield DesktopPlatform::MacOS
    
    #[cfg(target_os = "windows")]
    yield DesktopPlatform::Windows
    
    #[cfg(target_os = "linux")]
    yield DesktopPlatform::Linux
}

open data Theme {
    primary_color: Color,
    secondary_color: Color,
    background_color: Color,
    surface_color: Color,
    error_color: Color,
    text_color: Color,
    font_family: str
}

impl Theme {
    fn default() -> Theme {
        Theme {
            primary_color: Color.hex("#007AFF"),
            secondary_color: Color.hex("#5856D6"),
            background_color: Color.white(),
            surface_color: Color.hex("#F2F2F7"),
            error_color: Color.hex("#FF3B30"),
            text_color: Color.black(),
            font_family: "system"
        }
    }
    
    fn dark() -> Theme {
        Theme {
            primary_color: Color.hex("#0A84FF"),
            secondary_color: Color.hex("#5E5CE6"),
            background_color: Color.black(),
            surface_color: Color.hex("#1C1C1E"),
            error_color: Color.hex("#FF453A"),
            text_color: Color.white(),
            font_family: "system"
        }
    }
}

