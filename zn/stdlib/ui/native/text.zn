// ═══════════════════════════════════════════════════════════════════════════
// Nova Native UI - Text Widget
// ═══════════════════════════════════════════════════════════════════════════
// Cross-platform text display
// iOS → SwiftUI Text
// Android → Compose Text
// Web → <span> or <p>
// Desktop → Native label
// ═══════════════════════════════════════════════════════════════════════════

import ui.native.widget

open data Text {
    content: str,
    style: TextStyle
}

impl Text {
    fn new(content: str) -> Text {
        Text {
            content: content,
            style: TextStyle.default()
        }
    }
    
    fn with_style(content: str, style: TextStyle) -> Text {
        Text {
            content: content,
            style: style
        }
    }
    
    // Builder methods
    fn font_size(var self, size: f32) -> Text {
        self.style.font_size = size
        yield self
    }
    
    fn color(var self, color: Color) -> Text {
        self.style.color = color
        yield self
    }
    
    fn bold(var self) -> Text {
        self.style.font_weight = FontWeight::Bold
        yield self
    }
    
    fn italic(var self) -> Text {
        self.style.italic = true
        yield self
    }
    
    fn underline(var self) -> Text {
        self.style.underline = true
        yield self
    }
    
    fn weight(var self, weight: FontWeight) -> Text {
        self.style.font_weight = weight
        yield self
    }
    
    fn family(var self, family: str) -> Text {
        self.style.font_family = family
        yield self
    }
}

impl Widget for Text {
    fn build(self) -> WidgetNode {
        yield WidgetNode::Text {
            content: self.content,
            style: self.style
        }
    }
    
    fn layout(self, constraints: Constraints) -> Size {
        // Calculate text size based on content and style
        // This will be platform-specific
        let estimated_width = self.content.len() as f32 * self.style.font_size * 0.6
        let height = self.style.font_size * self.style.line_height
        
        yield Size.new(
            estimated_width.min(constraints.max_width),
            height
        )
    }
}
