// ═══════════════════════════════════════════════════════════════════════════
// ZenFlow Widgets - Checkbox
// ═══════════════════════════════════════════════════════════════════════════

import ui.zenflow.core

open fn checkbox(label: str, default_value: bool) -> bool {
    let widget_id = generate_widget_id("checkbox", label)
    let value = CURRENT_SESSION.get(widget_id + "_value", default_value)
    
    emit_component("checkbox", {
        "id": widget_id,
        "label": label,
        "value": value
    })
    
    yield value
}

open fn toggle(label: str, default_value: bool) -> bool {
    let widget_id = generate_widget_id("toggle", label)
    let value = CURRENT_SESSION.get(widget_id + "_value", default_value)
    
    emit_component("toggle", {
        "id": widget_id,
        "label": label,
        "value": value
    })
    
    yield value
}
