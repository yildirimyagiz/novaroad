// ═══════════════════════════════════════════════════════════════════════════
// ZenFlow Widgets - Slider
// ═══════════════════════════════════════════════════════════════════════════

import ui.zenflow.core

open fn slider(label: str, min_val: f64, max_val: f64, default_val: f64, step: f64) -> f64 {
    let widget_id = generate_widget_id("slider", label)
    let value = CURRENT_SESSION.get(widget_id + "_value", default_val)
    
    emit_component("slider", {
        "id": widget_id,
        "label": label,
        "min": min_val,
        "max": max_val,
        "value": value,
        "step": step
    })
    
    yield value
}

open fn range_slider(label: str, min_val: f64, max_val: f64, default_range: (f64, f64)) -> (f64, f64) {
    let widget_id = generate_widget_id("range_slider", label)
    let range = CURRENT_SESSION.get(widget_id + "_range", default_range)
    
    emit_component("range_slider", {
        "id": widget_id,
        "label": label,
        "min": min_val,
        "max": max_val,
        "range": range
    })
    
    yield range
}
