// ═══════════════════════════════════════════════════════════════════════════
// ZenFlow Layout - Flexbox Layouts
// ═══════════════════════════════════════════════════════════════════════════

import ui.zenflow.core

open fn horizontal(gap: f32, align: str, content: fn()) {
    emit_component("flex", {
        "direction": "row",
        "gap": gap,
        "align": align
    })
    content()
    emit_component("flex_end", {})
}

open fn vertical(gap: f32, align: str, content: fn()) {
    emit_component("flex", {
        "direction": "column",
        "gap": gap,
        "align": align
    })
    content()
    emit_component("flex_end", {})
}

open fn spacer() {
    emit_component("spacer", {
        "flex": 1
    })
}

open fn divider() {
    emit_component("divider", {
        "color": "#e0e0e0",
        "thickness": 1
    })
}
