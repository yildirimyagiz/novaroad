// ═══════════════════════════════════════════════════════════════════════════
// ZenFlow Layout - Container & Spacing
// ═══════════════════════════════════════════════════════════════════════════

import ui.zenflow.core

open fn container(content: fn()) {
    emit_component("container", {
        "padding": "1rem",
        "max_width": "1200px"
    })
    content()
    emit_component("container_end", {})
}

open fn columns(count: u32, content: fn()) {
    emit_component("columns", {
        "count": count,
        "gap": "1rem"
    })
    content()
    emit_component("columns_end", {})
}

open fn column(content: fn()) {
    emit_component("column", {})
    content()
    emit_component("column_end", {})
}

open fn sidebar(content: fn()) {
    emit_component("sidebar", {
        "width": "300px",
        "collapsible": true
    })
    content()
    emit_component("sidebar_end", {})
}

open fn expander(label: str, expanded: bool, content: fn()) {
    let widget_id = generate_widget_id("expander", label)
    let is_expanded = CURRENT_SESSION.get(widget_id + "_expanded", expanded)
    
    emit_component("expander", {
        "id": widget_id,
        "label": label,
        "expanded": is_expanded
    })
    
    check is_expanded {
        content()
    }
    
    emit_component("expander_end", {})
}

open fn card(title: str, content: fn()) {
    emit_component("card", {
        "title": title,
        "elevation": 2
    })
    content()
    emit_component("card_end", {})
}
