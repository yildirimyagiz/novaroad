// ZenFlow Charts - Heatmap
// ═══════════════════════════════════════════════════════════════════════════

import ui.zenflow.core

open fn heatmap(data: list<list<f64>>, x_labels: list<str>, y_labels: list<str>, title: str) {
    emit_component("heatmap", {
        "data": data,
        "x_labels": x_labels,
        "y_labels": y_labels,
        "title": title,
        "color_scheme": "viridis",
        "show_values": true
    })
}

open fn correlation_matrix(data: map<str, list<f64>>, title: str) {
    // Calculate correlation matrix
    let corr = calculate_correlation(data)
    
    emit_component("heatmap", {
        "data": corr,
        "x_labels": data.keys(),
        "y_labels": data.keys(),
        "title": title,
        "color_scheme": "RdBu",
        "show_values": true,
        "symmetric": true
    })
}

fn calculate_correlation(data: map<str, list<f64>>) -> list<list<f64>> {
    // Simplified correlation calculation
    // Real implementation would use proper statistics
    yield [[]]
}
