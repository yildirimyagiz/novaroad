// ═══════════════════════════════════════════════════════════════════════════
// ZenFlow Charts - Line Chart
// ═══════════════════════════════════════════════════════════════════════════

import ui.zenflow.core

open fn line_chart(data: map<str, list<f64>>, title: str, x_label: str, y_label: str) {
    emit_component("line_chart", {
        "data": data,
        "title": title,
        "x_label": x_label,
        "y_label": y_label,
        "smooth": true,
        "show_points": true,
        "show_legend": true
    })
}

open fn area_chart(data: map<str, list<f64>>, title: str, stacked: bool) {
    emit_component("area_chart", {
        "data": data,
        "title": title,
        "stacked": stacked,
        "show_legend": true
    })
}

open fn multi_line_chart(series: list<map<str, any>>, title: str) {
    emit_component("multi_line_chart", {
        "series": series,
        "title": title,
        "show_legend": true,
        "interactive": true
    })
}
