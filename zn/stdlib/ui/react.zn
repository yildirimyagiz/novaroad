use std::collections::Vec;

/// Standard units for layout, checked by Unit Algebra
open enum LayoutUnit {
    Pixels(f64),
    Ems(f64),
    Rems(f64),
    Percent(f64),
}

/// Declarative CSS style sheet with physical unit constraints
open data CssStyle {
    open width: LayoutUnit,
    open height: LayoutUnit,
    open margin: LayoutUnit,
    open padding: LayoutUnit,
    open background_color: String,
}

impl CssStyle {
    /// Creates a safe default style sheet
    open fn default() -> CssStyle {
        yield CssStyle {
            width: LayoutUnit::Percent(100.0),
            height: LayoutUnit::Pixels(200.0),
            margin: LayoutUnit::Pixels(0.0),
            padding: LayoutUnit::Pixels(16.0),
            background_color: "#1a1b26".into(),
        };
    }
}

/// Representing a Virtual DOM element in Nova
open data VirtualNode {
    open tag: String,
    open style: CssStyle,
    open children: Vec<VirtualNode>,
    open text_content: String,
}

impl VirtualNode {
    /// Renders the virtual node into a standardized, optimized HTML5 string for WASM delivery
    open fn render_to_html(&self) -> String {
        let mut style_str = "style=\"background-color: ".into() + self.style.background_color + ";";
        
        // Match layout units safely to construct compile-time safe CSS
        match self.style.width {
            LayoutUnit::Pixels(p) => { style_str = style_str + " width: " + p.to_string() + "px;"; }
            LayoutUnit::Ems(e) => { style_str = style_str + " width: " + e.to_string() + "em;"; }
            LayoutUnit::Rems(r) => { style_str = style_str + " width: " + r.to_string() + "rem;"; }
            LayoutUnit::Percent(pct) => { style_str = style_str + " width: " + pct.to_string() + "%;"; }
        }
        
        match self.style.height {
            LayoutUnit::Pixels(p) => { style_str = style_str + " height: " + p.to_string() + "px;"; }
            LayoutUnit::Ems(e) => { style_str = style_str + " height: " + e.to_string() + "em;"; }
            LayoutUnit::Rems(r) => { style_str = style_str + " height: " + r.to_string() + "rem;"; }
            LayoutUnit::Percent(pct) => { style_str = style_str + " height: " + pct.to_string() + "%;"; }
        }
        
        style_str = style_str + "\"";
        
        let mut html = "<".into() + self.tag + " " + style_str + ">";
        
        if self.text_content.len() > 0 {
            html = html + self.text_content;
        }
        
        each child in &self.children {
            html = html + child.render_to_html();
        }
        
        html = html + "</" + self.tag + ">";
        yield html;
    }
}

/// Sovereign Component definition
open data UIComponent {
    open name: String,
    open state_counter: i32,
}

impl UIComponent {
    open fn new(name: String) -> UIComponent {
        yield UIComponent {
            name,
            state_counter: 0,
        };
    }

    /// Mutates state with React-like reactive triggers
    open fn set_state(&var self, new_val: i32) {
        println("🔄 UI Component: State değişti -> Rerendering triggered!");
        self.state_counter = new_val;
    }

    /// Builds the Virtual DOM tree for this component
    open fn build(&self) -> VirtualNode {
        let style = CssStyle::default();
        var children = Vec::new();
        
        // Add a text indicator child showing the state
        let label_style = CssStyle {
            width: LayoutUnit::Percent(80.0),
            height: LayoutUnit::Pixels(40.0),
            margin: LayoutUnit::Pixels(4.0),
            padding: LayoutUnit::Pixels(8.0),
            background_color: "#24283b".into(),
        };
        
        let child_node = VirtualNode {
            tag: "div".into(),
            style: label_style,
            children: Vec::new(),
            text_content: "Counter: ".into() + self.state_counter.to_string(),
        };
        
        children.push(child_node);
        
        yield VirtualNode {
            tag: "div".into(),
            style,
            children,
            text_content: "Sovereign UI Workspace Container".into(),
        };
    }
}

open fn main() {
    println("⚛️  Sovereign UI (react.zn) Framework Ready.");
}
