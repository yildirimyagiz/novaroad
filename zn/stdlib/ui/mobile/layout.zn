/// Padding wrapper
open data Padding {
    child: Box<dyn View>,
    padding: EdgeInsets,
}

impl Padding {
    open fn new(child: Box<dyn View>, padding: EdgeInsets) -> Padding {
        Padding { child, padding }
    }
    
    open fn all(child: Box<dyn View>, value: f64) -> Padding {
        Padding::new(child, EdgeInsets::all(value))
    }
}

impl View for Padding {
    fn build(&self, ctx: BuildContext) -> Element {
        Element {
            id: ElementId { id: generate_id() },
            kind: ElementKind::Container,
            children: [self.child.build(ctx)],
            props: HashMap::from([
                ("paddingTop".into(), Property::Number(self.padding.top)),
                ("paddingRight".into(), Property::Number(self.padding.right)),
                ("paddingBottom".into(), Property::Number(self.padding.bottom)),
                ("paddingLeft".into(), Property::Number(self.padding.left)),
            ]),
        }
    }
    
    fn update(&var self, msg: Message) {}
}

/// Alignment
open cases Alignment {
    Start,
    Center,
    End,
    Stretch,
}

/// Spacer - flexible space
open data Spacer;

impl View for Spacer {
    fn build(&self, ctx: BuildContext) -> Element {
        Element {
            id: ElementId { id: generate_id() },
            kind: ElementKind::Container,
            children: Vec::new(),
            props: HashMap::from([
                ("flex".into(), Property::Number(1.0)),
            ]),
        }
    }
    
    fn update(&var self, msg: Message) {}
}

fn generate_id() -> u64 {
    static var COUNTER: u64 = 0;
    unsafe {
        COUNTER += 1;
        COUNTER
    }
}
