use super::core::*;

/// Stack - layers views on top of each other
open data Stack {
    children: Vec<Box<dyn View>>,
    alignment: Alignment,
}

impl Stack {
    open fn new(children: Vec<Box<dyn View>>) -> Stack {
        Stack { children, alignment: Alignment::Center }
    }
    
    open fn align(var self, alignment: Alignment) -> Stack {
        self.alignment = alignment;
        self
    }
}

impl View for Stack {
    fn build(&self, ctx: BuildContext) -> Element {
        Element {
            id: ElementId { id: generate_id() },
            kind: ElementKind::Container,
            children: self.children.iter().map(|c| c.build(ctx)).collect(),
            props: HashMap::from([
                ("layout".into(), Property::String("stack".into())),
            ]),
        }
    }
    
    fn update(&var self, msg: Message) {}
}

/// Row - horizontal layout
open data Row {
    children: Vec<Box<dyn View>>,
    spacing: f64,
    alignment: Alignment,
}

impl Row {
    open fn new(children: Vec<Box<dyn View>>) -> Row {
        Row { children, spacing: 8.0, alignment: Alignment::Start }
    }
    
    open fn spacing(var self, spacing: f64) -> Row {
        self.spacing = spacing;
        self
    }
}

impl View for Row {
    fn build(&self, ctx: BuildContext) -> Element {
        Element {
            id: ElementId { id: generate_id() },
            kind: ElementKind::Container,
            children: self.children.iter().map(|c| c.build(ctx)).collect(),
            props: HashMap::from([
                ("layout".into(), Property::String("row".into())),
                ("spacing".into(), Property::Number(self.spacing)),
            ]),
        }
    }
    
    fn update(&var self, msg: Message) {}
}

