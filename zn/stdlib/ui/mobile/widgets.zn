use super::core::*;
use super::layout::*;

/// Text widget
open data Text {
    content: String,
    style: TextStyle,
}

open data TextStyle {
    font_size: f64,
    color: Color,
    weight: FontWeight,
    alignment: TextAlignment,
}

open cases FontWeight {
    Regular,
    Bold,
    Light,
}

open cases TextAlignment {
    Left,
    Center,
    Right,
}

impl Text {
    open fn new(content: String) -> Text {
        Text {
            content,
            style: TextStyle::default(),
        }
    }
    
    open fn font_size(var self, size: f64) -> Text {
        self.style.font_size = size;
        self
    }
    
    open fn color(var self, color: Color) -> Text {
        self.style.color = color;
        self
    }
    
    open fn bold(var self) -> Text {
        self.style.weight = FontWeight::Bold;
        self
    }
}

impl TextStyle {
    open fn default() -> TextStyle {
        TextStyle {
            font_size: 16.0,
            color: Color::black(),
            weight: FontWeight::Regular,
            alignment: TextAlignment::Left,
        }
    }
}

impl View for Text {
    fn build(&self, ctx: BuildContext) -> Element {
        Element {
            id: ElementId { id: generate_id() },
            kind: ElementKind::Native(NativeElement {
                platform: ctx.platform,
                native_type: match ctx.platform {
                    Platform::iOS => "UILabel".into(),
                    Platform::Android => "android.widget.TextView".into(),
                    _ => "text".into(),
                },
                native_handle: 0,
            }),
            children: Vec::new(),
            props: HashMap::from([
                ("text".into(), Property::String(self.content.clone())),
                ("fontSize".into(), Property::Number(self.style.font_size)),
                ("color".into(), Property::Color(self.style.color)),
            ]),
        }
    }
    
    fn update(&var self, msg: Message) {
        // Text is usually stateless
    }
}

/// Button widget
open data Button {
    label: String,
    on_tap: Option<Box<dyn Fn()>>,
    style: ButtonStyle,
}

open data ButtonStyle {
    background: Color,
    foreground: Color,
    padding: EdgeInsets,
    corner_radius: f64,
}

impl Button {
    open fn new(label: String) -> Button {
        Button {
            label,
            on_tap: None,
            style: ButtonStyle::default(),
        }
    }
    
    open fn on_tap(var self, handler: Box<dyn Fn()>) -> Button {
        self.on_tap = Some(handler);
        self
    }
    
    open fn background(var self, color: Color) -> Button {
        self.style.background = color;
        self
    }
}

impl ButtonStyle {
    open fn default() -> ButtonStyle {
        ButtonStyle {
            background: Color::blue(),
            foreground: Color::white(),
            padding: EdgeInsets::all(12.0),
            corner_radius: 8.0,
        }
    }
}

impl View for Button {
    fn build(&self, ctx: BuildContext) -> Element {
        Element {
            id: ElementId { id: generate_id() },
            kind: ElementKind::Native(NativeElement {
                platform: ctx.platform,
                native_type: match ctx.platform {
                    Platform::iOS => "UIButton".into(),
                    Platform::Android => "android.widget.Button".into(),
                    _ => "button".into(),
                },
                native_handle: 0,
            }),
            children: Vec::new(),
            props: HashMap::from([
                ("text".into(), Property::String(self.label.clone())),
                ("background".into(), Property::Color(self.style.background)),
                ("foreground".into(), Property::Color(self.style.foreground)),
                ("cornerRadius".into(), Property::Number(self.style.corner_radius)),
            ]),
        }
    }
    
    fn update(&var self, msg: Message) {
        match msg {
            Message::Tap(_) => {
                check let Some(ref handler) = self.on_tap {
                    handler();
                }
            }
            _ => {}
        }
    }
}

/// TextField widget
open data TextField {
    placeholder: String,
    value: ViewState<String>,
    on_change: Option<Box<dyn Fn(String)>>,
}

impl TextField {
    open fn new(placeholder: String) -> TextField {
        TextField {
            placeholder,
            value: ViewState::new(String::new()),
            on_change: None,
        }
    }
    
    open fn on_change(var self, handler: Box<dyn Fn(String)>) -> TextField {
        self.on_change = Some(handler);
        self
    }
}

impl View for TextField {
    fn build(&self, ctx: BuildContext) -> Element {
        Element {
            id: ElementId { id: generate_id() },
            kind: ElementKind::Native(NativeElement {
                platform: ctx.platform,
                native_type: match ctx.platform {
                    Platform::iOS => "UITextField".into(),
                    Platform::Android => "android.widget.EditText".into(),
                    _ => "input".into(),
                },
                native_handle: 0,
            }),
            children: Vec::new(),
            props: HashMap::from([
                ("placeholder".into(), Property::String(self.placeholder.clone())),
                ("value".into(), Property::String(self.value.get().clone())),
            ]),
        }
    }
    
    fn update(&var self, msg: Message) {
        match msg {
            Message::Input(text) => {
                self.value.set(text.clone());
                check let Some(ref handler) = self.on_change {
                    handler(text);
                }
            }
            _ => {}
        }
    }
}

/// Image widget
open data Image {
    source: ImageSource,
    content_mode: ContentMode,
}

open cases ImageSource {
    Network(String),
    Asset(String),
    File(String),
}

open cases ContentMode {
    Fill,
    Fit,
    Stretch,
}

impl Image {
    open fn network(url: String) -> Image {
        Image {
            source: ImageSource::Network(url),
            content_mode: ContentMode::Fit,
        }
    }
    
    open fn asset(name: String) -> Image {
        Image {
            source: ImageSource::Asset(name),
            content_mode: ContentMode::Fit,
        }
    }
}

impl View for Image {
    fn build(&self, ctx: BuildContext) -> Element {
        Element {
            id: ElementId { id: generate_id() },
            kind: ElementKind::Native(NativeElement {
                platform: ctx.platform,
                native_type: match ctx.platform {
                    Platform::iOS => "UIImageView".into(),
                    Platform::Android => "android.widget.ImageView".into(),
                    _ => "img".into(),
                },
                native_handle: 0,
            }),
            children: Vec::new(),
            props: HashMap::new(),
        }
    }
    
    fn update(&var self, msg: Message) {}
}

/// Helper to generate unique IDs
fn generate_id() -> u64 {
    // In real implementation, use atomic counter or UUID
    static var COUNTER: u64 = 0;
    unsafe {
        COUNTER += 1;
        COUNTER
    }
}
