// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Mobile UI Core - Base Types and Protocols                                  ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Main View rules - all UI components implement this
open rules View {
    fn build(&self, ctx: BuildContext) -> Element;
    fn update(&var self, msg: Message);
}

/// Build context passed to view builders
open data BuildContext {
    platform: Platform,
    screen_size: Size,
    theme: Theme,
    safe_area: EdgeInsets,
}

/// UI Element (rendered component)
open data Element {
    id: ElementId,
    kind: ElementKind,
    children: Vec<Element>,
    props: HashMap<String, Property>,
}

open cases ElementKind {
    Native(NativeElement),
    Custom(CustomElement),
    Container,
}

/// Native platform element
open data NativeElement {
    platform: Platform,
    native_type: String, // "UIButton", "android.widget.Button", etc.
    native_handle: u64,  // Platform-specific handle
}

/// Custom element
open data CustomElement {
    render: Box<dyn Fn() -> Vec<Element>>,
}

/// Element ID for identity/diffing
open data ElementId {
    id: u64,
}

/// Message for updates
open cases Message {
    Tap(Point),
    Input(String),
    Custom(String, Vec<u8>),
}

/// Platform detection
open cases Platform {
    iOS,
    Android,
    Web,
    Desktop,
}

/// Size
open data Size {
    width: f64,
    height: f64,
}

/// Point
open data Point {
    x: f64,
    y: f64,
}

/// Edge insets (padding/margins)
open data EdgeInsets {
    top: f64,
    right: f64,
    bottom: f64,
    left: f64,
}

impl EdgeInsets {
    open fn all(value: f64) -> EdgeInsets {
        EdgeInsets { top: value, right: value, bottom: value, left: value }
    }
    
    open fn symmetric(vertical: f64, horizontal: f64) -> EdgeInsets {
        EdgeInsets { top: vertical, right: horizontal, bottom: vertical, left: horizontal }
    }
}

/// Theme
open data Theme {
    primary_color: Color,
    background_color: Color,
    text_color: Color,
    font_size: f64,
}

/// Color
open data Color {
    r: f64,
    g: f64,
    b: f64,
    a: f64,
}

impl Color {
    open fn rgb(r: f64, g: f64, b: f64) -> Color {
        Color { r, g, b, a: 1.0 }
    }
    
    open fn rgba(r: f64, g: f64, b: f64, a: f64) -> Color {
        Color { r, g, b, a }
    }
    
    open fn black() -> Color { Color::rgb(0.0, 0.0, 0.0) }
    open fn white() -> Color { Color::rgb(1.0, 1.0, 1.0) }
    open fn red() -> Color { Color::rgb(1.0, 0.0, 0.0) }
    open fn blue() -> Color { Color::rgb(0.0, 0.0, 1.0) }
}

/// Property (for element props)
open cases Property {
    String(String),
    Number(f64),
    Bool(bool),
    Color(Color),
}

/// View state management
open data ViewState<T> {
    value: T,
    listeners: Vec<Box<dyn Fn(&T)>>,
}

impl<T: Clone> ViewState<T> {
    open fn new(initial: T) -> ViewState<T> {
        ViewState {
            value: initial,
            listeners: Vec::new(),
        }
    }
    
    open fn get(&self) -> &T {
        &self.value
    }
    
    open fn set(&var self, new_value: T) {
        self.value = new_value;
        each listener in &self.listeners {
            listener(&self.value);
        }
    }
    
    open fn subscribe(&var self, listener: Box<dyn Fn(&T)>) {
        self.listeners.push(listener);
    }
}

impl Copy for Platform {}
impl Clone for Platform {
    fn clone(&self) -> Platform { *self }
}

impl Copy for Size {}
impl Clone for Size {
    fn clone(&self) -> Size { *self }
}

impl Copy for Point {}
impl Clone for Point {
    fn clone(&self) -> Point { *self }
}

impl Copy for Color {}
impl Clone for Color {
    fn clone(&self) -> Color { *self }
}
