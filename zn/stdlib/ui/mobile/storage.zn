// ║  Persistent Storage - UserDefaults, SQLite, File Storage                    ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// User defaults (key-value storage)
open data UserDefaults;

impl UserDefaults {
    /// Get string value
    open fn get_string(key: String) -> Option<String> {
        extern "C" {
            fn nova_storage_get_string(
                key: *const u8,
                key_len: usize,
                value: *var *var u8,
                value_len: *var usize
            ) -> bool;
        }
        
        unsafe {
            var value_ptr: *var u8 = std::ptr::null_mut();
            var value_len = 0;
            
            check nova_storage_get_string(key.as_ptr(), key.len(), &var value_ptr, &var value_len) {
                Some(String::from_raw_parts(value_ptr, value_len, value_len))
            } else {
                None
            }
        }
    }
    
    /// Set string value
    open fn set_string(key: String, value: String) {
        extern "C" {
            fn nova_storage_set_string(
                key: *const u8,
                key_len: usize,
                value: *const u8,
                value_len: usize
            );
        }
        
        unsafe {
            nova_storage_set_string(
                key.as_ptr(),
                key.len(),
                value.as_ptr(),
                value.len()
            );
        }
    }
    
    /// Get integer value
    open fn get_int(key: String) -> Option<i64> {
        extern "C" {
            fn nova_storage_get_int(key: *const u8, key_len: usize, value: *var i64) -> bool;
        }
        
        var value = 0;
        unsafe {
            check nova_storage_get_int(key.as_ptr(), key.len(), &var value) {
                Some(value)
            } else {
                None
            }
        }
    }
    
    /// Set integer value
    open fn set_int(key: String, value: i64) {
        extern "C" {
            fn nova_storage_set_int(key: *const u8, key_len: usize, value: i64);
        }
        
        unsafe {
            nova_storage_set_int(key.as_ptr(), key.len(), value);
        }
    }
    
    /// Get boolean value
    open fn get_bool(key: String) -> Option<bool> {
        extern "C" {
            fn nova_storage_get_bool(key: *const u8, key_len: usize, value: *var bool) -> bool;
        }
        
        var value = false;
        unsafe {
            check nova_storage_get_bool(key.as_ptr(), key.len(), &var value) {
                Some(value)
            } else {
                None
            }
        }
    }
    
    /// Set boolean value
    open fn set_bool(key: String, value: bool) {
        extern "C" {
            fn nova_storage_set_bool(key: *const u8, key_len: usize, value: bool);
        }
        
        unsafe {
            nova_storage_set_bool(key.as_ptr(), key.len(), value);
        }
    }
    
    /// Remove key
    open fn remove(key: String) {
        extern "C" {
            fn nova_storage_remove(key: *const u8, key_len: usize);
        }
        
        unsafe {
            nova_storage_remove(key.as_ptr(), key.len());
        }
    }
    
    /// Clear all
    open fn clear() {
        extern "C" {
            fn nova_storage_clear();
        }
        
        unsafe {
            nova_storage_clear();
        }
    }
}

/// Local SQLite database
open data LocalDatabase {
    connection_id: u64,
}

impl LocalDatabase {
    /// Open database
    open fn open(name: String) -> Result<LocalDatabase, String> {
        extern "C" {
            fn nova_local_db_open(name: *const u8, name_len: usize, conn_id: *var u64) -> bool;
        }
        
        var conn_id = 0;
        unsafe {
            check nova_local_db_open(name.as_ptr(), name.len(), &var conn_id) {
                Ok(LocalDatabase { connection_id: conn_id })
            } else {
                Err("Failed to open database".into())
            }
        }
    }
    
    /// Execute query
    open fn query(&self, sql: String) -> Result<Vec<HashMap<String, String>>, String> {
        // Similar to sqlite implementation
        Ok(Vec::new())
    }
    
    /// Execute statement
    open fn execute(&self, sql: String) -> Result<u64, String> {
        extern "C" {
            fn nova_local_db_execute(
                conn_id: u64,
                sql: *const u8,
                sql_len: usize,
                affected: *var u64
            ) -> bool;
        }
        
        var affected = 0;
        unsafe {
            check nova_local_db_execute(self.connection_id, sql.as_ptr(), sql.len(), &var affected) {
                Ok(affected)
            } else {
                Err("Execute failed".into())
            }
        }
    }
}

/// File storage
open data FileStorage;

impl FileStorage {
    /// Get documents directory
    open fn documents_dir() -> String {
        extern "C" {
            fn nova_storage_documents_dir(path: *var *var u8, path_len: *var usize);
        }
        
        unsafe {
            var path_ptr: *var u8 = std::ptr::null_mut();
            var path_len = 0;
            nova_storage_documents_dir(&var path_ptr, &var path_len);
            String::from_raw_parts(path_ptr, path_len, path_len)
        }
    }
    
    /// Get cache directory
    open fn cache_dir() -> String {
        extern "C" {
            fn nova_storage_cache_dir(path: *var *var u8, path_len: *var usize);
        }
        
        unsafe {
            var path_ptr: *var u8 = std::ptr::null_mut();
            var path_len = 0;
            nova_storage_cache_dir(&var path_ptr, &var path_len);
            String::from_raw_parts(path_ptr, path_len, path_len)
        }
    }
    
    /// Save file
    open fn save(path: String, data: &[u8]) -> Result<(), String> {
        extern "C" {
            fn nova_storage_save_file(
                path: *const u8,
                path_len: usize,
                data: *const u8,
                data_len: usize
            ) -> bool;
        }
        
        unsafe {
            check nova_storage_save_file(path.as_ptr(), path.len(), data.as_ptr(), data.len()) {
                Ok(())
            } else {
                Err("Save failed".into())
            }
        }
    }
    
    /// Load file
    open fn load(path: String) -> Result<Vec<u8>, String> {
        extern "C" {
            fn nova_storage_load_file(
                path: *const u8,
                path_len: usize,
                data: *var *var u8,
                data_len: *var usize
            ) -> bool;
        }
        
        unsafe {
            var data_ptr: *var u8 = std::ptr::null_mut();
            var data_len = 0;
            
            check nova_storage_load_file(path.as_ptr(), path.len(), &var data_ptr, &var data_len) {
                Ok(Vec::from_raw_parts(data_ptr, data_len, data_len))
            } else {
                Err("Load failed".into())
            }
        }
    }
}
