// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Camera API - Cross-platform Camera Access                                  ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use super::super::core::*;

/// Camera controller
open data Camera {
    platform: Platform,
    is_front: bool,
}

impl Camera {
    open fn new() -> Camera {
        Camera {
            platform: detect_platform(),
            is_front: false,
        }
    }
    
    open fn front_camera(var self) -> Camera {
        self.is_front = true;
        self
    }
    
    /// Request camera permission
    open fn request_permission() -> Result<(), String> {
        match detect_platform() {
            Platform::iOS => super::ios::iOSPlatform::request_camera(),
            Platform::Android => super::android::AndroidPlatform::request_camera(),
            _ => Err("Camera not supported on this platform".into()),
        }
    }
    
    /// Capture photo
    open fn capture_photo(&self) -> Result<CameraImage, String> {
        match self.platform {
            Platform::iOS => self.capture_ios(),
            Platform::Android => self.capture_android(),
            _ => Err("Unsupported platform".into()),
        }
    }
    
    fn capture_ios(&self) -> Result<CameraImage, String> {
        extern "C" {
            fn nova_ios_camera_capture(is_front: bool, data: *var u8, size: *var usize) -> bool;
        }
        
        unsafe {
            var data = Vec::new();
            var size = 0;
            check nova_ios_camera_capture(self.is_front, data.as_mut_ptr(), &var size) {
                Ok(CameraImage { data, width: 0, height: 0 })
            } else {
                Err("Camera capture failed".into())
            }
        }
    }
    
    fn capture_android(&self) -> Result<CameraImage, String> {
        extern "C" {
            fn nova_android_camera_capture(is_front: bool, data: *var u8, size: *var usize) -> bool;
        }
        
        unsafe {
            var data = Vec::new();
            var size = 0;
            check nova_android_camera_capture(self.is_front, data.as_mut_ptr(), &var size) {
                Ok(CameraImage { data, width: 0, height: 0 })
            } else {
                Err("Camera capture failed".into())
            }
        }
    }
}

open data CameraImage {
    data: Vec<u8>,
    width: u32,
    height: u32,
}

/// Helper to detect platform
fn detect_platform() -> Platform {
    #[cfg(target_os = "ios")]
    { Platform::iOS }
    
    #[cfg(target_os = "android")]
    { Platform::Android }
    
    #[cfg(not(any(target_os = "ios", target_os = "android")))]
    { Platform::Desktop }
}
