// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Gesture System - Swipe, Pinch, Pan, Long Press                             ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use super::core::*;

/// Gesture recognizer
open data GestureRecognizer {
    gestures: Vec<GestureType>,
    on_gesture: Box<dyn Fn(Gesture)>,
}

open cases GestureType {
    Tap,
    DoubleTap,
    LongPress,
    Swipe(SwipeDirection),
    Pan,
    Pinch,
    Rotate,
}

open cases SwipeDirection {
    Up,
    Down,
    Left,
    Right,
}

open data Gesture {
    kind: GestureType,
    location: Point,
    velocity: Option<Vec2>,
    scale: Option<f64>,
    rotation: Option<f64>,
}

impl GestureRecognizer {
    open fn new(on_gesture: Box<dyn Fn(Gesture)>) -> GestureRecognizer {
        GestureRecognizer {
            gestures: Vec::new(),
            on_gesture,
        }
    }
    
    open fn add_tap(var self) -> GestureRecognizer {
        self.gestures.push(GestureType::Tap);
        self
    }
    
    open fn add_swipe(var self, direction: SwipeDirection) -> GestureRecognizer {
        self.gestures.push(GestureType::Swipe(direction));
        self
    }
    
    open fn add_pinch(var self) -> GestureRecognizer {
        self.gestures.push(GestureType::Pinch);
        self
    }
    
    open fn add_pan(var self) -> GestureRecognizer {
        self.gestures.push(GestureType::Pan);
        self
    }
}

/// Swipeable widget
open data Swipeable {
    child: Box<dyn View>,
    on_swipe: Box<dyn Fn(SwipeDirection)>,
}

impl Swipeable {
    open fn new(child: Box<dyn View>, on_swipe: Box<dyn Fn(SwipeDirection)>) -> Swipeable {
        Swipeable { child, on_swipe }
    }
}

impl View for Swipeable {
    fn build(&self, ctx: BuildContext) -> Element {
        Element {
            id: ElementId { id: generate_id() },
            kind: ElementKind::Container,
            children: [self.child.build(ctx)],
            props: HashMap::from([
                ("gesture".into(), Property::String("swipe".into())),
            ]),
        }
    }
    
    fn update(&var self, msg: Message) {}
}

fn generate_id() -> u64 {
    static var COUNTER: u64 = 0;
    unsafe {
        COUNTER += 1;
        COUNTER
    }
}
