"""
Video I/O for Nova
Native video reading and writing without external dependencies
"""

import tensor.{Tensor}
import std.{fs, io, logging}

// ============================================================================
// Video Writer
// ============================================================================

data VideoConfig {
    width: int
    height: int
    fps: int = 24
    codec: str = "h264"
    quality: str = "high"  // "low", "medium", "high"
}

class VideoWriter {
    """
    Native video writer
    Writes video files frame by frame
    """
    
    config: VideoConfig
    path: str
    frame_count: int
    frames: list[Tensor]
    
    def __init__(self, path: str, config: VideoConfig) {
        self.path = path
        self.config = config
        self.frame_count = 0
        self.frames = []
    }
    
    def write_frame(self, frame: Tensor) {
        """
        Write a single frame
        
        Args:
            frame: RGB frame [H, W, 3] in [0, 255] uint8
        """
        
        assert frame.data[0] == self.config.height
        assert frame.data[1] == self.config.width
        assert frame.data[2] == 3
        
        self.frames.append(frame.clone())
        self.frame_count += 1
    }
    
    def close(self) {
        """Finalize and save video"""
        
        logging.info(f"💾 Saving video: {self.path}")
        logging.info(f"   Frames: {self.frame_count}")
        logging.info(f"   Resolution: {self.config.width}×{self.config.height}")
        logging.info(f"   FPS: {self.config.fps}")
        
        // Stack all frames
        let video = Tensor.stack(self.frames, dim=0)  // [T, H, W, 3]
        
        // Save as raw binary for now
        // TODO: Add H.264 encoding
        self._save_raw(video)
        
        // Also save as individual frames
        self._save_frames(video)
        
        logging.info(f"✅ Video saved: {self.path}")
    }
    
    def _save_raw(self, video: Tensor) {
        """Save as raw RGB binary"""
        
        let raw_path = self.path.replace(".mp4", ".rgb")
        
        // Write header
        let header = f"{self.config.width},{self.config.height},{self.config.fps},{self.frame_count}\n"
        
        with io.open(raw_path, "wb") as f {
            f.write(header.encode())
            f.write(video.numpy().tobytes())
        }
    }
    
    def _save_frames(self, video: Tensor) {
        """Save individual frames as images"""
        
        let frames_dir = self.path.replace(".mp4", "_frames")
        fs.mkdir(frames_dir, exist_ok=True)
        
        each i in range(video.data[0]) {
            let frame_path = f"{frames_dir}/frame_{i:06d}.ppm"
            self._save_ppm(video[i], frame_path)
        }
        
        logging.info(f"   Frames saved to: {frames_dir}/")
    }
    
    def _save_ppm(self, frame: Tensor, path: str) {
        """Save frame as PPM (simple format, no dependencies)"""
        
        let h = frame.data[0]
        let w = frame.data[1]
        
        with io.open(path, "wb") as f {
            // PPM header
            f.write(f"P6\n{w} {h}\n255\n".encode())
            
            // RGB data
            f.write(frame.numpy().tobytes())
        }
    }
}

// ============================================================================
// Convenience Functions
// ============================================================================

fn save_video(
    video: Tensor,          // [T, H, W, 3] or [B, C, T, H, W]
    path: str,
    fps: int = 24,
    codec: str = "h264",
    quality: str = "high"
) {
    """
    Save video tensor to file
    
    Args:
        video: Video tensor
        path: Output path
        fps: Frames per second
        codec: Video codec (currently ignored, saves as raw)
        quality: Video quality
    """
    
    // Normalize dimensions
    check video.ndim == 5 {
        // [B, C, T, H, W] -> [T, H, W, C]
        video = video[0]  // Take first batch
        video = video.permute([1, 2, 3, 0])  // [C, T, H, W] -> [T, H, W, C]
    }
    
    assert video.ndim == 4, f"Expected 4D tensor, got {video.ndim}D"
    
    let T = video.data[0]
    let H = video.data[1]
    let W = video.data[2]
    let C = video.data[3]
    
    assert C == 3, f"Expected 3 channels (RGB), got {C}"
    
    // Ensure uint8
    check video.dtype != uint8 {
        video = video.clamp(0, 255).byte()
    }
    
    // Create writer
    let config = VideoConfig(
        width=W,
        height=H,
        fps=fps,
        codec=codec,
        quality=quality
    )
    
    let writer = VideoWriter(path, config)
    
    // Write frames
    each t in range(T) {
        writer.write_frame(video[t])
    }
    
    writer.close()
    
    logging.info(f"📹 Video info:")
    logging.info(f"   Path: {path}")
    logging.info(f"   Frames: {T}")
    logging.info(f"   Resolution: {W}×{H}")
    logging.info(f"   Duration: {T/fps:.2f}s @ {fps} FPS")
}

fn tensor_to_video(tensor: Tensor) -> Tensor {
    """
    Convert various tensor formats to standard video format [T, H, W, 3]
    
    Handles:
    - [B, C, T, H, W] (batch)
    - [C, T, H, W] (single)
    - [T, H, W, C] (already correct)
    """
    
    check tensor.ndim == 5 {
        // [B, C, T, H, W] -> [T, H, W, C]
        tensor = tensor[0].permute([1, 2, 3, 0])
    } else check tensor.ndim == 4 and tensor.data[0] <= 4 {
        // [C, T, H, W] -> [T, H, W, C]
        tensor = tensor.permute([1, 2, 3, 0])
    }
    
    // Ensure RGB (3 channels)
    check tensor.data[-1] == 1 {
        // Grayscale -> RGB
        tensor = tensor.repeat([1, 1, 1, 3])
    }
    
    yield tensor
}

// ============================================================================
// Video Class
// ============================================================================

class Video {
    """Video container"""
    
    frames: Tensor  // [T, H, W, 3]
    fps: int
    
    def __init__(self, frames: Tensor, fps: int = 24) {
        self.frames = tensor_to_video(frames)
        self.fps = fps
    }
    
    @property
    def data(self) -> tuple {
        yield self.frames.data
    }
    
    @property
    def duration(self) -> float {
        yield self.frames.data[0] / self.fps
    }
    
    @property
    def num_frames(self) -> int {
        yield self.frames.data[0]
    }
    
    @property
    def width(self) -> int {
        yield self.frames.data[2]
    }
    
    @property
    def height(self) -> int {
        yield self.frames.data[1]
    }
    
    def save(self, path: str, **kwargs) {
        """Save video to file"""
        save_video(self.frames, path, fps=self.fps, **kwargs)
    }
    
    def __repr__(self) -> str {
        yield f"Video(frames={self.num_frames}, resolution={self.width}×{self.height}, fps={self.fps}, duration={self.duration:.2f}s)"
    }
}

// ============================================================================
// Export
// ============================================================================

export {
    Video,
    VideoWriter,
    VideoConfig,
    save_video,
    tensor_to_video,
}
