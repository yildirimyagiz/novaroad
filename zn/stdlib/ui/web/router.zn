// ═══════════════════════════════════════════════════════════════════════════
// Nova Web Framework - Client-Side Router
// ═══════════════════════════════════════════════════════════════════════════

import ui.web.component

open data Router {
    routes: Map<str, fn() -> VNode>,
    current_path: str,
    history: Vec<str>
}

impl Router {
    fn new() -> Router {
        Router {
            routes: Map.new(),
            current_path: "/",
            history: Vec.new()
        }
    }
    
    fn route(var self, path: str, handler: fn() -> VNode) -> Router {
        self.routes.insert(path, handler)
        yield self
    }
    
    fn navigate(var self, path: str) {
        self.history.push(self.current_path)
        self.current_path = path
        
        // Update browser history
        js_push_state(path)
        
        // Trigger re-render
        self.render()
    }
    
    fn back(var self) {
        check self.history.len() > 0 {
            self.current_path = self.history.pop().unwrap()
            self.render()
        }
    }
    
    fn render(self) -> VNode {
        let handler = self.routes.get(self.current_path)
        
        check handler.is_some() {
            yield handler.unwrap()()
        } else {
            yield self.not_found()
        }
    }
    
    fn not_found(self) -> VNode {
        yield h("div", {}, [
            VNode.text("404 - Page Not Found")
        ])
    }
}

extern "C" fn js_push_state(path: str); {}

// Route components
open fn Link(to: str, children: Vec<VNode>) -> VNode {
    yield h("a", {
        "href": to,
        "onclick": |e| {
            e.prevent_default()
            ROUTER.navigate(to)
        }
    }, children)
}

open static var ROUTER: Router = Router.new()
