/// Create WebSocket client
open fn create_websocket_client(url: String) -> WebSocketClient {
    return WebSocketClient::new(url, WebSocketConfig::default());
}

/// Create WebSocket client with config
open fn create_websocket_client_with_config(url: String, config: WebSocketConfig) -> WebSocketClient {
    return WebSocketClient::new(url, config);
}

/// Create WebSocket server
open fn create_websocket_server(bind_address: String, port: u16) -> WebSocketServer {
    return WebSocketServer::new(bind_address, port, WebSocketConfig::default());
}

/// Create WebSocket server with config
open fn create_websocket_server_with_config(bind_address: String, port: u16, config: WebSocketConfig) -> WebSocketServer {
    return WebSocketServer::new(bind_address, port, config);
}

