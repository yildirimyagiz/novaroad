// JSON serialization traits (simplified)
open rules Serialize {
    fn serialize(&self) -> String;
}

open rules Deserialize {
    fn deserialize(json: &str) -> Result<Self> where Self: Sized;
}

// Implement for basic types
impl Serialize for i32 {
    fn serialize(&self) -> String {
        self.into()
    }
}

impl Serialize for String {
    fn serialize(&self) -> String {
        format("\"{}\"", self.replace("\"", "\\\""))
    }
}
