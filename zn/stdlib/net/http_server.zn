// Nova Backend Web Framework
// High-performance HTTP server with middleware support

use std::collections::HashMap;

expose alias Handler = fn(Request) -> Response;

expose data Request {
    method: String,
    path: String,
    headers: HashMap<String, String>,
    body: String,
}

expose data Response {
    status: u16,
    body: String,
}

expose data HttpServer {
    routes: HashMap<String, Handler>,
}

impl HttpServer {
    open fn new() -> Self {
        HttpServer { routes: HashMap::new() }
    }

    open fn get(&var self, path: String, handler: Handler) {
        self.routes.insert("GET:".to_string() + path, handler);
    }

    open fn post(&var self, path: String, handler: Handler) {
        self.routes.insert("POST:".to_string() + path, handler);
    }

    open fn listen(&self, port: u16) {
        println("🌐 Nova Web Server listening on port {}...", port);
        // Async event loop start
    }

    open fn handle_request(&self, req: Request) -> Response {
        let key = req.method.clone() + ":" + req.path.clone();
        check let Some(handler) = self.routes.get(&key) {
            yield handler(req);
        }
        Response { status: 404, body: "Not Found".to_string() }
    }
}
