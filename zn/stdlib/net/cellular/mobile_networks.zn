// ============================================================================
// Tests & Examples
// ============================================================================

#[test]
fn test_5g_systems() {
    let fr1 = CellularSystem::five_g_fr1();
    let fr2 = CellularSystem::five_g_fr2();
    
    println("5G FR1 (Sub-6 GHz):");
    println("  Max DL: {:.0} Gbps", fr1.max_downlink_gbps);
    println("  Latency: {:.0} ms", fr1.latency_ms);
    println("  Mobility: {:.0} km/h", fr1.mobility_support_kmh);
    
    println("\n5G FR2 (mmWave):");
    println("  Max DL: {:.0} Gbps", fr2.max_downlink_gbps);
    println("  Latency: {:.0} ms", fr2.latency_ms);
    println("  Mobility: {:.0} km/h", fr2.mobility_support_kmh);
    
    assert(fr2.max_downlink_gbps > fr1.max_downlink_gbps);
}

#[test]
fn test_6g() {
    let six_g = CellularSystem::six_g();
    
    println("6G (2030 target):");
    println("  Max DL: {:.0} Gbps", six_g.max_downlink_gbps);
    println("  Latency: {:.1} ms", six_g.latency_ms);
    println("  Features: {}", six_g.features.len());
    
    assert_eq!(six_g.max_downlink_gbps, 1000.0);  // 1 Tbps
}

#[test]
fn test_massive_mimo() {
    let mimo = MassiveMIMO::new(128, 16);
    
    let se = mimo.spectral_efficiency(20.0);  // 20 dB SNR
    let ee_gain = mimo.energy_efficiency_gain();
    
    println("Massive MIMO (128x16):");
    println("  Spectral efficiency: {:.1} bps/Hz", se);
    println("  Energy efficiency gain: {:.1}x", ee_gain);
    
    assert(se > 10.0);
}

#[test]
fn test_turkey_5g() {
    let turkey = turkey_5g_2026();
    
    println("Türkiye 5G Deployment:");
    println("  Launch: {}", turkey.launch_date);
    println("  Operators: {}", turkey.operators.len());
    println("  Coverage: {:.0}% population", turkey.population_coverage);
    println("  Cities: {}", turkey.coverage_cities.len());
    
    let total_bs: u32 = turkey.operators.iter().map(|o| o.base_stations).sum();
    println("  Total base stations: {}", total_bs);
    
    assert_eq!(turkey.launch_date, "1 Nisan 2026");
}
