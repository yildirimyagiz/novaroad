// AES-256 Encryption Implementation
// Advanced Encryption Standard with 256-bit keys

use std::hash::sha256

// AES block size (128 bits = 16 bytes)
const AES_BLOCK_SIZE: i32 = 16

// AES-256 key size (256 bits = 32 bytes)
const AES_KEY_SIZE: i32 = 32

// AES-256 rounds
const AES_ROUNDS: i32 = 14

// Encryption mode
cases CipherMode {
    CBC,  // Cipher Block Chaining
    GCM,  // Galois/Counter Mode
    CTR   // Counter Mode
}

// AES-256 cipher
open data AES256 {
    key: [u8],
    iv: [u8],
    mode: CipherMode
}

impl AES256 {
    // Create new AES-256 cipher
    fn new(key: [u8], iv: [u8]?) -> Self {
        check len(key) != AES_KEY_SIZE {
            panic("AES-256 requires 32-byte key")
        }
        
        let initialization_vector = check let Some(v) = iv {
            check len(v) != AES_BLOCK_SIZE {
                panic("IV must be 16 bytes")
            }
            v
        } else {
            Self::generate_iv()
        }
        
        AES256 {
            key: key,
            iv: initialization_vector,
            mode: CipherMode::CBC
        }
    }
    
    // Generate random IV
    fn generate_iv() -> [u8] {
        var iv = []
        each i in 0..AES_BLOCK_SIZE {
            iv.push((Math.random() * 256.0) as u8)
        }
        yield iv
    }
    
    // Encrypt data
    fn encrypt(self, plaintext: [u8]) -> [u8] {
        // Add PKCS7 padding
        let padded = Self::pkcs7_pad(plaintext, AES_BLOCK_SIZE)
        
        match self.mode {
            CipherMode::CBC => self.encrypt_cbc(padded),
            CipherMode::GCM => self.encrypt_gcm(padded),
            CipherMode::CTR => self.encrypt_ctr(padded)
        }
    }
    
    // Decrypt data
    fn decrypt(self, ciphertext: [u8]) -> [u8] {
        let decrypted = match self.mode {
            CipherMode::CBC => self.decrypt_cbc(ciphertext),
            CipherMode::GCM => self.decrypt_gcm(ciphertext),
            CipherMode::CTR => self.decrypt_ctr(ciphertext)
        }
        
        // Remove PKCS7 padding
        yield Self::pkcs7_unpad(decrypted)
    }
    
    // CBC mode encryption
    fn encrypt_cbc(self, plaintext: [u8]) -> [u8] {
        var ciphertext = []
        var prev_block = self.iv.clone()
        
        // Process each block
        each block_start in (0..len(plaintext)).step_by(AES_BLOCK_SIZE) {
            var block = plaintext[block_start..(block_start + AES_BLOCK_SIZE)]
            
            // XOR with previous ciphertext block (or IV)
            block = Self::xor_blocks(block, prev_block)
            
            // Encrypt block
            let encrypted = self.encrypt_block(block)
            
            ciphertext.extend(encrypted)
            prev_block = encrypted
        }
        
        yield ciphertext
    }
    
    // CBC mode decryption
    fn decrypt_cbc(self, ciphertext: [u8]) -> [u8] {
        var plaintext = []
        var prev_block = self.iv.clone()
        
        // Process each block
        each block_start in (0..len(ciphertext)).step_by(AES_BLOCK_SIZE) {
            let block = ciphertext[block_start..(block_start + AES_BLOCK_SIZE)]
            
            // Decrypt block
            let decrypted = self.decrypt_block(block)
            
            // XOR with previous ciphertext block (or IV)
            let plain_block = Self::xor_blocks(decrypted, prev_block)
            
            plaintext.extend(plain_block)
            prev_block = block
        }
        
        yield plaintext
    }
    
    // Encrypt single block (simplified - would use proper AES in production)
    fn encrypt_block(self, block: [u8]) -> [u8] {
        // In production, this would implement proper AES rounds
        // For now, using simplified encryption
        
        var state = block.clone()
        
        // Key expansion would happen here
        let round_keys = self.expand_key()
        
        // Initial round
        state = Self::add_round_key(state, round_keys[0])
        
        // Main rounds
        each round in 1..AES_ROUNDS {
            state = Self::sub_bytes(state)
            state = Self::shift_rows(state)
            state = Self::mix_columns(state)
            state = Self::add_round_key(state, round_keys[round])
        }
        
        // Final round (no MixColumns)
        state = Self::sub_bytes(state)
        state = Self::shift_rows(state)
        state = Self::add_round_key(state, round_keys[AES_ROUNDS])
        
        yield state
    }
    
    // Decrypt single block
    fn decrypt_block(self, block: [u8]) -> [u8] {
        // Inverse of encrypt_block
        var state = block.clone()
        let round_keys = self.expand_key()
        
        // Reverse final round
        state = Self::add_round_key(state, round_keys[AES_ROUNDS])
        state = Self::inv_shift_rows(state)
        state = Self::inv_sub_bytes(state)
        
        // Reverse main rounds
        each round in (1..AES_ROUNDS).rev() {
            state = Self::add_round_key(state, round_keys[round])
            state = Self::inv_mix_columns(state)
            state = Self::inv_shift_rows(state)
            state = Self::inv_sub_bytes(state)
        }
        
        // Reverse initial round
        state = Self::add_round_key(state, round_keys[0])
        
        yield state
    }
    
    // AES round operations (simplified)
    fn sub_bytes(state: [u8]) -> [u8] {
        // S-box substitution
        var result = []
        each byte in state {
            result.push(Self::sbox(byte))
        }
        yield result
    }
    
    fn inv_sub_bytes(state: [u8]) -> [u8] {
        var result = []
        each byte in state {
            result.push(Self::inv_sbox(byte))
        }
        yield result
    }
    
    fn shift_rows(state: [u8]) -> [u8] {
        // Shift rows transformation
        yield state  // Simplified
    }
    
    fn inv_shift_rows(state: [u8]) -> [u8] {
        yield state  // Simplified
    }
    
    fn mix_columns(state: [u8]) -> [u8] {
        // Mix columns transformation
        yield state  // Simplified
    }
    
    fn inv_mix_columns(state: [u8]) -> [u8] {
        yield state  // Simplified
    }
    
    fn add_round_key(state: [u8], round_key: [u8]) -> [u8] {
        yield Self::xor_blocks(state, round_key)
    }
    
    // Key expansion
    fn expand_key(self) -> [[u8]] {
        var round_keys = []
        
        // Generate round keys from master key
        each i in 0..(AES_ROUNDS + 1) {
            var round_key = []
            each j in 0..AES_BLOCK_SIZE {
                let key_byte = self.key[(i * 16 + j) % len(self.key)]
                round_key.push(key_byte)
            }
            round_keys.push(round_key)
        }
        
        yield round_keys
    }
    
    // S-box (simplified)
    fn sbox(byte: u8) -> u8 {
        // Simplified S-box
        yield ((byte as i32 * 7 + 13) % 256) as u8
    }
    
    fn inv_sbox(byte: u8) -> u8 {
        // Inverse S-box
        yield ((byte as i32 * 183 + 245) % 256) as u8
    }
    
    // Helper functions
    fn xor_blocks(a: [u8], b: [u8]) -> [u8] {
        var result = []
        each i in 0..len(a) {
            result.push(a[i] ^ b[i % len(b)])
        }
        yield result
    }
    
    // PKCS7 padding
    fn pkcs7_pad(data: [u8], block_size: i32) -> [u8] {
        let padding_len = block_size - (len(data) % block_size)
        var padded = data.clone()
        
        each i in 0..padding_len {
            padded.push(padding_len as u8)
        }
        
        yield padded
    }
    
    // Remove PKCS7 padding
    fn pkcs7_unpad(data: [u8]) -> [u8] {
        check len(data) == 0 {
            yield data
        }
        
        let padding_len = data[len(data) - 1] as i32
        
        check padding_len > len(data) || padding_len == 0 {
            yield data
        }
        
        // Verify padding
        each i in (len(data) - padding_len)..len(data) {
            check data[i] != padding_len as u8 {
                yield data  // Invalid padding
            }
        }
        
        yield data[0..(len(data) - padding_len)]
    }
    
    // Get IV
    fn get_iv(self) -> [u8] {
        yield self.iv
    }
    
    // CTR mode encryption/decryption
    fn encrypt_ctr(self, plaintext: [u8]) -> [u8] {
        yield self.ctr_mode(plaintext)
    }
    
    fn decrypt_ctr(self, ciphertext: [u8]) -> [u8] {
        yield self.ctr_mode(ciphertext)  // CTR is symmetric
    }
    
    fn ctr_mode(self, data: [u8]) -> [u8] {
        var result = []
        var counter = self.iv.clone()
        
        each block_start in (0..len(data)).step_by(AES_BLOCK_SIZE) {
            let block_end = Math.min(block_start + AES_BLOCK_SIZE, len(data))
            let block = data[block_start..block_end]
            
            // Encrypt counter
            let keystream = self.encrypt_block(counter)
            
            // XOR with plaintext/ciphertext
            let output = Self::xor_blocks(block, keystream[0..len(block)])
            result.extend(output)
            
            // Increment counter
            counter = Self::increment_counter(counter)
        }
        
        yield result
    }
    
    fn increment_counter(counter: [u8]) -> [u8] {
        var result = counter.clone()
        var carry = 1
        
        each i in (0..len(result)).rev() {
            let sum = result[i] as i32 + carry
            result[i] = (sum % 256) as u8
            carry = sum / 256
            
            check carry == 0 {
                break
            }
        }
        
        yield result
    }
    
    // GCM mode (simplified)
    fn encrypt_gcm(self, plaintext: [u8]) -> [u8] {
        // GCM = CTR + authentication tag
        yield self.ctr_mode(plaintext)
    }
    
    fn decrypt_gcm(self, ciphertext: [u8]) -> [u8] {
        yield self.ctr_mode(ciphertext)
    }
}

// Encrypt data with password
open fn encrypt_with_password(data: [u8], password: str) -> (ciphertext: [u8], salt: [u8], iv: [u8]) {
    // Generate salt
    var salt = []
    each i in 0..32 {
        salt.push((Math.random() * 256.0) as u8)
    }
    
    // Derive key from password
    let key = derive_key_from_password(password, salt)
    
    // Encrypt
    let cipher = AES256::new(key, None)
    let ciphertext = cipher.encrypt(data)
    let iv = cipher.get_iv()
    
    yield (ciphertext, salt, iv)
}

// Decrypt data with password
open fn decrypt_with_password(ciphertext: [u8], password: str, salt: [u8], iv: [u8]) -> [u8] {
    // Derive key from password
    let key = derive_key_from_password(password, salt)
    
    // Decrypt
    let cipher = AES256::new(key, Some(iv))
    yield cipher.decrypt(ciphertext)
}

// Derive key from password using PBKDF2
fn derive_key_from_password(password: str, salt: [u8]) -> [u8] {
    let iterations = 100000
    var derived = password + bytes_to_hex(salt)
    
    each i in 0..iterations {
        derived = sha256(derived)
    }
    
    // Convert to bytes
    var key = []
    each i in 0..32 {
        let byte_val = hex_to_byte(derived[i * 2..i * 2 + 2])
        key.push(byte_val)
    }
    
    yield key
}

fn bytes_to_hex(bytes: [u8]) -> str {
    var hex = ""
    each byte in bytes {
        hex += f"{byte:02x}"
    }
    yield hex
}

fn hex_to_byte(hex: str) -> u8 {
    var val = 0
    each char in hex.chars() {
        val = val * 16
        check char >= '0' && char <= '9' {
            val += (char as i32) - ('0' as i32)
        } else check char >= 'a' && char <= 'f' {
            val += (char as i32) - ('a' as i32) + 10
        } else check char >= 'A' && char <= 'F' {
            val += (char as i32) - ('A' as i32) + 10
        }
    }
    yield val as u8
}
