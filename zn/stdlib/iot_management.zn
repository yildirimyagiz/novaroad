// 🌐 Nova IoT Management — v10.0
// IoT device management, protocols, and edge computing
// + Nova Magic: Auto-discovery, edge processing, real-time monitoring

@module("iot::management")
@reproducible
@export
@inline

use std::collections::{HashMap, Vec};
use std::sync::Arc;
use std::result::Result;

// ═══════════════════════════════════════════════════════════════════════════
// §1  IOT CORE TYPES
// ═══════════════════════════════════════════════════════════════════════════

/// IoT error
open cases IoTError {
    DeviceNotFound(String),
    ConnectionError(String),
    ProtocolError(String),
    DataFormatError(String),
    AuthenticationError(String),
    DeviceOffline(String),
    InvalidCommand(String),
    NetworkError(String),
}

impl IoTError {
    open fn to_string(&self) -> String {
        match self {
            IoTError::DeviceNotFound(msg) => format!("Device not found: {}", msg),
            IoTError::ConnectionError(msg) => format!("Connection error: {}", msg),
            IoTError::ProtocolError(msg) => format!("Protocol error: {}", msg),
            IoTError::DataFormatError(msg) => format!("Data format error: {}", msg),
            IoTError::AuthenticationError(msg) => format!("Authentication error: {}", msg),
            IoTError::DeviceOffline(msg) => format!("Device offline: {}", msg),
            IoTError::InvalidCommand(msg) => format!("Invalid command: {}", msg),
            IoTError::NetworkError(msg) => format!("Network error: {}", msg),
        }
    }
}

/// IoT result
open type IoTResult<T> = Result<T, IoTError>;

/// Device type
open cases DeviceType {
    Sensor,
    Actuator,
    Gateway,
    EdgeDevice,
    Camera,
    SmartMeter,
    Thermostat,
    Light,
    Lock,
    Switch,
    Display,
    Speaker,
    Microphone,
    Custom(String),
}

impl DeviceType {
    open fn get_name(&self) -> String {
        match self {
            DeviceType::Sensor => "Sensor".into(),
            DeviceType::Actuator => "Actuator".into(),
            DeviceType::Gateway => "Gateway".into(),
            DeviceType::EdgeDevice => "Edge Device".into(),
            DeviceType::Camera => "Camera".into(),
            DeviceType::SmartMeter => "Smart Meter".into(),
            DeviceType::Thermostat => "Thermostat".into(),
            DeviceType::Light => "Light".into(),
            DeviceType::Lock => "Lock".into(),
            DeviceType::Switch => "Switch".into(),
            DeviceType::Display => "Display".into(),
            DeviceType::Speaker => "Speaker".into(),
            DeviceType::Microphone => "Microphone".into(),
            DeviceType::Custom(name) => name.clone(),
        }
    }
}

/// Device status
open cases DeviceStatus {
    Online,
    Offline,
    Error,
    Maintenance,
    Unknown,
}

impl DeviceStatus {
    open fn is_active(&self) -> bool {
        match self {
            DeviceStatus::Online => true,
            _ => false,
        }
    }
}

/// Protocol type
open cases ProtocolType {
    MQTT,
    CoAP,
    HTTP,
    WebSocket,
    LoRaWAN,
    Zigbee,
    ZWave,
    Bluetooth,
    WiFi,
    Cellular,
    Custom(String),
}

impl ProtocolType {
    open fn get_name(&self) -> String {
        match self {
            ProtocolType::MQTT => "MQTT".into(),
            ProtocolType::CoAP => "CoAP".into(),
            ProtocolType::HTTP => "HTTP".into(),
            ProtocolType::WebSocket => "WebSocket".into(),
            ProtocolType::LoRaWAN => "LoRaWAN".into(),
            ProtocolType::Zigbee => "Zigbee".into(),
            ProtocolType::ZWave => "Z-Wave".into(),
            ProtocolType::Bluetooth => "Bluetooth".into(),
            ProtocolType::WiFi => "WiFi".into(),
            ProtocolType::Cellular => "Cellular".into(),
            ProtocolType::Custom(name) => name.clone(),
        }
    }
}

/// Data type
open cases DataType {
    Temperature,
    Humidity,
    Pressure,
    Light,
    Motion,
    Sound,
    Voltage,
    Current,
    Power,
    Energy,
    Binary,
    String,
    JSON,
    Custom(String),
}

impl DataType {
    open fn get_unit(&self) -> String {
        match self {
            DataType::Temperature => "°C".into(),
            DataType::Humidity => "%".into(),
            DataType::Pressure => "Pa".into(),
            DataType::Light => "lux".into(),
            DataType::Motion => "bool".into(),
            DataType::Sound => "dB".into(),
            DataType::Voltage => "V".into(),
            DataType::Current => "A".into(),
            DataType::Power => "W".into(),
            DataType::Energy => "kWh".into(),
            DataType::Binary => "bool".into(),
            DataType::String => "str".into(),
            DataType::JSON => "json".into(),
            DataType::Custom(_) => "".into(),
        }
    }
}

/// Device data
open data DeviceData {
    device_id: String,
    timestamp: std::time::Instant,
    data_type: DataType,
    value: DataValue,
    quality: f32,
    unit: String,
}

impl DeviceData {
    open fn new(device_id: String, data_type: DataType, value: DataValue) -> DeviceData {
        return DeviceData {
            device_id: device_id,
            timestamp: std::time::Instant::now(),
            data_type: data_type,
            value: value,
            quality: 1.0,
            unit: data_type.get_unit(),
        };
    }
    
    open fn with_quality(mut self, quality: f32) -> DeviceData {
        self.quality = quality;
        return self;
    }
    
    open fn with_timestamp(mut self, timestamp: std::time::Instant) -> DeviceData {
        self.timestamp = timestamp;
        return self;
    }
    
    open fn get_device_id(&self) -> &str {
        return &self.device_id;
    }
    
    open fn get_timestamp(&self) -> std::time::Instant {
        return self.timestamp;
    }
    
    open fn get_data_type(&self) -> DataType {
        return self.data_type.clone();
    }
    
    open fn get_value(&self) -> &DataValue {
        return &self.value;
    }
    
    open fn get_quality(&self) -> f32 {
        return self.quality;
    }
    
    open fn get_unit(&self) -> &str {
        return &self.unit;
    }
}

/// Data value
open cases DataValue {
    Float(f64),
    Integer(i64),
    Boolean(bool),
    String(String),
    Binary(Vec<u8>),
    JSON(serde_json::Value),
}

impl DataValue {
    open fn as_float(&self) -> Option<f64> {
        match self {
            DataValue::Float(f) => Some(*f),
            DataValue::Integer(i) => Some(*i as f64),
            DataValue::Boolean(b) => Some(if *b { 1.0 } else { 0.0 }),
            _ => None,
        }
    }
    
    open fn as_integer(&self) -> Option<i64> {
        match self {
            DataValue::Integer(i) => Some(*i),
            DataValue::Float(f) => Some(*f as i64),
            DataValue::Boolean(b) => Some(if *b { 1 } else { 0 }),
            _ => None,
        }
    }
    
    open fn as_boolean(&self) -> Option<bool> {
        match self {
            DataValue::Boolean(b) => Some(*b),
            DataValue::Integer(i) => Some(*i != 0),
            DataValue::Float(f) => Some(*f != 0.0),
            DataValue::String(s) => Some(!s.is_empty()),
            _ => None,
        }
    }
    
    open fn as_string(&self) -> Option<String> {
        match self {
            DataValue::String(s) => Some(s.clone()),
            DataValue::Float(f) => Some(f.to_string()),
            DataValue::Integer(i) => Some(i.to_string()),
            DataValue::Boolean(b) => Some(b.to_string()),
            DataValue::JSON(j) => Some(j.to_string()),
            _ => None,
        }
    }
    
    open fn as_json(&self) -> Option<serde_json::Value> {
        match self {
            DataValue::JSON(j) => Some(j.clone()),
            _ => None,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §2  IOT DEVICE
// ═══════════════════════════════════════════════════════════════════════════

/// IoT device
open data IoTDevice {
    id: String,
    name: String,
    device_type: DeviceType,
    protocol: ProtocolType,
    status: DeviceStatus,
    address: String,
    port: u16,
    last_seen: std::time::Instant,
    metadata: HashMap<String, String>,
    capabilities: Vec<DeviceCapability>,
    configuration: DeviceConfiguration,
    data_buffer: Vec<DeviceData>,
    max_buffer_size: usize,
}

/// Device capability
open data DeviceCapability {
    data_type: DataType,
    readable: bool,
    writable: bool,
    range: Option<(DataValue, DataValue)>,
    unit: String,
}

impl DeviceCapability {
    open fn new(data_type: DataType, readable: bool, writable: bool) -> DeviceCapability {
        return DeviceCapability {
            data_type: data_type,
            readable: readable,
            writable: writable,
            range: None,
            unit: data_type.get_unit(),
        };
    }
    
    open fn with_range(mut self, min: DataValue, max: DataValue) -> DeviceCapability {
        self.range = Some((min, max));
        return self;
    }
    
    open fn get_data_type(&self) -> DataType {
        return self.data_type.clone();
    }
    
    open fn is_readable(&self) -> bool {
        return self.readable;
    }
    
    open fn is_writable(&self) -> bool {
        return self.writable;
    }
}

/// Device configuration
open data DeviceConfiguration {
    sampling_rate: f32,
    buffer_size: usize,
    timeout: std::time::Duration,
    retry_count: u32,
    authentication: AuthenticationConfig,
    network_config: NetworkConfig,
}

/// Authentication config
open data AuthenticationConfig {
    method: AuthenticationMethod,
    credentials: HashMap<String, String>,
    token: Option<String>,
    expires_at: Option<std::time::Instant>,
}

/// Authentication method
open cases AuthenticationMethod {
    None,
    APIKey,
    Certificate,
    Token,
    UsernamePassword,
}

/// Network config
open data NetworkConfig {
    encryption: bool,
    compression: bool,
    keep_alive: bool,
    qos: u8,
}

impl IoTDevice {
    open fn new(id: String, name: String, device_type: DeviceType, protocol: ProtocolType, address: String, port: u16) -> IoTDevice {
        return IoTDevice {
            id: id,
            name: name,
            device_type: device_type,
            protocol: protocol,
            status: DeviceStatus::Unknown,
            address: address,
            port: port,
            last_seen: std::time::Instant::now(),
            metadata: HashMap::new(),
            capabilities: Vec::new(),
            configuration: DeviceConfiguration {
                sampling_rate: 1.0,
                buffer_size: 1000,
                timeout: std::time::Duration::from_secs(30),
                retry_count: 3,
                authentication: AuthenticationConfig {
                    method: AuthenticationMethod::None,
                    credentials: HashMap::new(),
                    token: None,
                    expires_at: None,
                },
                network_config: NetworkConfig {
                    encryption: false,
                    compression: false,
                    keep_alive: true,
                    qos: 0,
                },
            },
            data_buffer: Vec::new(),
            max_buffer_size: 10000,
        };
    }
    
    open fn add_capability(&mut self, capability: DeviceCapability) {
        self.capabilities.push(capability);
    }
    
    open fn add_metadata(&mut self, key: String, value: String) {
        self.metadata.insert(key, value);
    }
    
    open fn get_capability(&self, data_type: DataType) -> Option<&DeviceCapability> {
        return self.capabilities.iter().find(|cap| cap.get_data_type() == data_type);
    }
    
    open fn get_capabilities(&self) -> &Vec<DeviceCapability> {
        return &self.capabilities;
    }
    
    open fn add_data(&mut self, data: DeviceData) -> IoTResult<()> {
        // Check if device supports this data type
        if let Some(capability) = self.get_capability(data.get_data_type()) {
            if !capability.is_readable() {
                return Err(IoTError::InvalidCommand("Device cannot read this data type".into()));
            }
            
            // Validate range
            if let Some((min, max)) = &capability.range {
                if !self.validate_range(&data.value, min, max) {
                    return Err(IoTError::DataFormatError("Value out of range".into()));
                }
            }
            
            self.data_buffer.push(data);
            
            // Maintain buffer size
            if self.data_buffer.len() > self.max_buffer_size {
                self.data_buffer.remove(0);
            }
            
            self.last_seen = std::time::Instant::now();
            return Ok(());
        }
        
        return Err(IoTError::InvalidCommand("Device does not support this data type".into()));
    }
    
    fn validate_range(&self, value: &DataValue, min: &DataValue, max: &DataValue) -> bool {
        if let (Some(val), Some(min_val), Some(max_val)) = (value.as_float(), min.as_float(), max.as_float()) {
            return val >= min_val && val <= max_val;
        }
        return true;
    }
    
    open fn get_latest_data(&self, data_type: DataType) -> Option<&DeviceData> {
        return self.data_buffer.iter()
            .rev()
            .find(|data| data.get_data_type() == data_type);
    }
    
    open fn get_data_history(&self, data_type: DataType, limit: usize) -> Vec<&DeviceData> {
        return self.data_buffer.iter()
            .rev()
            .filter(|data| data.get_data_type() == data_type)
            .take(limit)
            .collect();
    }
    
    open fn get_all_data(&self) -> &Vec<DeviceData> {
        return &self.data_buffer;
    }
    
    open fn clear_data(&mut self) {
        self.data_buffer.clear();
    }
    
    open fn get_id(&self) -> &str {
        return &self.id;
    }
    
    open fn get_name(&self) -> &str {
        return &self.name;
    }
    
    open fn get_device_type(&self) -> DeviceType {
        return self.device_type.clone();
    }
    
    open fn get_protocol(&self) -> ProtocolType {
        return self.protocol.clone();
    }
    
    open fn get_status(&self) -> DeviceStatus {
        return self.status.clone();
    }
    
    open fn set_status(&mut self, status: DeviceStatus) {
        self.status = status;
    }
    
    open fn get_address(&self) -> &str {
        return &self.address;
    }
    
    open fn get_port(&self) -> u16 {
        return self.port;
    }
    
    open fn is_online(&self) -> bool {
        return self.status.is_active();
    }
    
    open fn get_last_seen(&self) -> std::time::Instant {
        return self.last_seen;
    }
    
    open fn get_metadata(&self) -> &HashMap<String, String> {
        return &self.metadata;
    }
    
    open fn get_configuration(&self) -> &DeviceConfiguration {
        return &self.configuration;
    }
    
    open fn update_configuration(&mut self, config: DeviceConfiguration) {
        self.configuration = config;
    }
    
    open fn get_connection_string(&self) -> String {
        match self.protocol {
            ProtocolType::MQTT => format!("mqtt://{}:{}", self.address, self.port),
            ProtocolType::HTTP => format!("http://{}:{}", self.address, self.port),
            ProtocolType::WebSocket => format!("ws://{}:{}", self.address, self.port),
            ProtocolType::CoAP => format!("coap://{}:{}", self.address, self.port),
            _ => format!("{}:{}", self.address, self.port),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §3  IOT PROTOCOLS
// ═══════════════════════════════════════════════════════════════════════════

/// Protocol trait
pub trait IoTProtocol {
    fn connect(&mut self, device: &IoTDevice) -> IoTResult<()>;
    fn disconnect(&mut self, device: &IoTDevice) -> IoTResult<()>;
    fn send_command(&mut self, device: &IoTDevice, command: &Command) -> IoTResult<CommandResult>;
    fn read_data(&mut self, device: &IoTDevice) -> IoTResult<Vec<DeviceData>>;
    fn subscribe(&mut self, device: &IoTDevice, topics: Vec<String>) -> IoTResult<()>;
    fn unsubscribe(&mut self, device: &IoTDevice, topics: Vec<String>) -> IoTResult<()>;
}

/// Command
open data Command {
    id: String,
    command_type: CommandType,
    parameters: HashMap<String, DataValue>,
    timestamp: std::time::Instant,
}

/// Command type
open cases CommandType {
    Read,
    Write,
    Execute,
    Configure,
    Reset,
    Status,
}

impl Command {
    open fn new(id: String, command_type: CommandType) -> Command {
        return Command {
            id: id,
            command_type: command_type,
            parameters: HashMap::new(),
            timestamp: std::time::Instant::now(),
        };
    }
    
    open fn with_parameter(mut self, key: String, value: DataValue) -> Command {
        self.parameters.insert(key, value);
        return self;
    }
    
    open fn get_id(&self) -> &str {
        return &self.id;
    }
    
    open fn get_command_type(&self) -> CommandType {
        return self.command_type.clone();
    }
    
    open fn get_parameters(&self) -> &HashMap<String, DataValue> {
        return &self.parameters;
    }
    
    open fn get_timestamp(&self) -> std::time::Instant {
        return self.timestamp;
    }
}

/// Command result
open data CommandResult {
    command_id: String,
    success: bool,
    data: Option<DataValue>,
    error: Option<String>,
    timestamp: std::time::Instant,
}

impl CommandResult {
    open fn new(command_id: String, success: bool) -> CommandResult {
        return CommandResult {
            command_id: command_id,
            success: success,
            data: None,
            error: None,
            timestamp: std::time::Instant::now(),
        };
    }
    
    open fn with_data(mut self, data: DataValue) -> CommandResult {
        self.data = Some(data);
        return self;
    }
    
    open fn with_error(mut self, error: String) -> CommandResult {
        self.error = Some(error);
        return self;
    }
    
    open fn get_command_id(&self) -> &str {
        return &self.command_id;
    }
    
    open fn is_success(&self) -> bool {
        return self.success;
    }
    
    open fn get_data(&self) -> Option<&DataValue> {
        return self.data.as_ref();
    }
    
    open fn get_error(&self) -> Option<&str> {
        return self.error.as_ref().map(|s| s.as_str());
    }
}

/// MQTT protocol
open data MQTTProtocol {
    client_id: String,
    broker_address: String,
    port: u16,
    username: Option<String>,
    password: Option<String>,
    connected: bool,
    subscriptions: Vec<String>,
}

impl MQTTProtocol {
    open fn new(client_id: String, broker_address: String, port: u16) -> MQTTProtocol {
        return MQTTProtocol {
            client_id: client_id,
            broker_address: broker_address,
            port: port,
            username: None,
            password: None,
            connected: false,
            subscriptions: Vec::new(),
        };
    }
    
    open fn with_credentials(mut self, username: String, password: String) -> MQTTProtocol {
        self.username = Some(username);
        self.password = Some(password);
        return self;
    }
}

impl IoTProtocol for MQTTProtocol {
    fn connect(&mut self, device: &IoTDevice) -> IoTResult<()> {
        println!("Connecting to MQTT broker: {}:{}", self.broker_address, self.port);
        self.connected = true;
        return Ok(());
    }
    
    fn disconnect(&mut self, _device: &IoTDevice) -> IoTResult<()> {
        println!("Disconnecting from MQTT broker");
        self.connected = false;
        return Ok(());
    }
    
    fn send_command(&mut self, device: &IoTDevice, command: &Command) -> IoTResult<CommandResult> {
        if !self.connected {
            return Err(IoTError::ConnectionError("Not connected to MQTT broker".into()));
        }
        
        let topic = format!("{}/command", device.get_id());
        let payload = serde_json::json!({
            "id": command.get_id(),
            "type": format!("{:?}", command.get_command_type()),
            "parameters": command.get_parameters(),
            "timestamp": command.get_timestamp().duration_since(std::time::UNIX_EPOCH).unwrap().as_secs()
        });
        
        println!("Publishing to topic {}: {}", topic, payload);
        
        // Mock response
        let result = CommandResult::new(command.get_id().into(), true);
        return Ok(result);
    }
    
    fn read_data(&mut self, device: &IoTDevice) -> IoTResult<Vec<DeviceData>> {
        if !self.connected {
            return Err(IoTError::ConnectionError("Not connected to MQTT broker".into()));
        }
        
        // Mock data reading
        let mut data = Vec::new();
        
        for capability in device.get_capabilities() {
            if capability.is_readable() {
                let value = self.generate_mock_data(&capability.get_data_type());
                let device_data = DeviceData::new(device.get_id().into(), capability.get_data_type(), value);
                data.push(device_data);
            }
        }
        
        return Ok(data);
    }
    
    fn subscribe(&mut self, device: &IoTDevice, topics: Vec<String>) -> IoTResult<()> {
        if !self.connected {
            return Err(IoTError::ConnectionError("Not connected to MQTT broker".into()));
        }
        
        for topic in topics {
            let full_topic = format!("{}/{}", device.get_id(), topic);
            println!("Subscribing to topic: {}", full_topic);
            self.subscriptions.push(full_topic);
        }
        
        return Ok(());
    }
    
    fn unsubscribe(&mut self, _device: &IoTDevice, topics: Vec<String>) -> IoTResult<()> {
        if !self.connected {
            return Err(IoTError::ConnectionError("Not connected to MQTT broker".into()));
        }
        
        for topic in topics {
            println!("Unsubscribing from topic: {}", topic);
            self.subscriptions.retain(|t| !t.contains(&topic));
        }
        
        return Ok(());
    }
    
    fn generate_mock_data(&self, data_type: DataType) -> DataValue {
        match data_type {
            DataType::Temperature => DataValue::Float(20.0 + rand::random::<f64>() * 15.0),
            DataType::Humidity => DataValue::Float(30.0 + rand::random::<f64>() * 40.0),
            DataType::Pressure => DataValue::Float(1000.0 + rand::random::<f64>() * 100.0),
            DataType::Light => DataValue::Float(rand::random::<f64>() * 1000.0),
            DataType::Motion => DataValue::Boolean(rand::random::<bool>()),
            DataType::Voltage => DataValue::Float(3.3 + rand::random::<f64>() * 0.5),
            DataType::Current => DataValue::Float(0.1 + rand::random::<f64>() * 2.0),
            DataType::Power => DataValue::Float(0.5 + rand::random::<f64>() * 10.0),
            DataType::Binary => DataValue::Boolean(rand::random::<bool>()),
            DataType::String => DataValue::String("OK".into()),
            _ => DataValue::Float(rand::random::<f64>() * 100.0),
        }
    }
}

/// HTTP protocol
open data HTTPProtocol {
    base_url: String,
    timeout: std::time::Duration,
    headers: HashMap<String, String>,
}

impl HTTPProtocol {
    open fn new(base_url: String) -> HTTPProtocol {
        return HTTPProtocol {
            base_url: base_url,
            timeout: std::time::Duration::from_secs(30),
            headers: HashMap::new(),
        };
    }
    
    open fn with_timeout(mut self, timeout: std::time::Duration) -> HTTPProtocol {
        self.timeout = timeout;
        return self;
    }
    
    open fn with_header(mut self, key: String, value: String) -> HTTPProtocol {
        self.headers.insert(key, value);
        return self;
    }
}

impl IoTProtocol for HTTPProtocol {
    fn connect(&mut self, _device: &IoTDevice) -> IoTResult<()> {
        println!("HTTP protocol ready for base URL: {}", self.base_url);
        return Ok(());
    }
    
    fn disconnect(&mut self, _device: &IoTDevice) -> IoTResult<()> {
        println!("HTTP protocol disconnected");
        return Ok(());
    }
    
    fn send_command(&mut self, device: &IoTDevice, command: &Command) -> IoTResult<CommandResult> {
        let url = format!("{}/devices/{}/command", self.base_url, device.get_id());
        
        println!("Sending HTTP POST to {}: {}", url, serde_json::json!({
            "id": command.get_id(),
            "type": format!("{:?}", command.get_command_type()),
            "parameters": command.get_parameters()
        }));
        
        // Mock response
        let result = CommandResult::new(command.get_id().into(), true);
        return Ok(result);
    }
    
    fn read_data(&mut self, device: &IoTDevice) -> IoTResult<Vec<DeviceData>> {
        let url = format!("{}/devices/{}/data", self.base_url, device.get_id());
        
        println!("Sending HTTP GET to: {}", url);
        
        // Mock data reading
        let mut data = Vec::new();
        
        for capability in device.get_capabilities() {
            if capability.is_readable() {
                let value = DataValue::Float(rand::random::<f64>() * 100.0);
                let device_data = DeviceData::new(device.get_id().into(), capability.get_data_type(), value);
                data.push(device_data);
            }
        }
        
        return Ok(data);
    }
    
    fn subscribe(&mut self, _device: &IoTDevice, _topics: Vec<String>) -> IoTResult<()> {
        println!("HTTP protocol doesn't support subscriptions");
        return Ok(());
    }
    
    fn unsubscribe(&mut self, _device: &IoTDevice, _topics: Vec<String>) -> IoTResult<()> {
        println!("HTTP protocol doesn't support subscriptions");
        return Ok(());
    }
}

/// CoAP protocol
open data CoAPProtocol {
    endpoint: String,
    timeout: std::time::Duration,
}

impl CoAPProtocol {
    open fn new(endpoint: String) -> CoAPProtocol {
        return CoAPProtocol {
            endpoint: endpoint,
            timeout: std::time::Duration::from_secs(10),
        };
    }
}

impl IoTProtocol for CoAPProtocol {
    fn connect(&mut self, _device: &IoTDevice) -> IoTResult<()> {
        println!("CoAP protocol ready for endpoint: {}", self.endpoint);
        return Ok(());
    }
    
    fn disconnect(&mut self, _device: &IoTDevice) -> IoTResult<()> {
        println!("CoAP protocol disconnected");
        return Ok(());
    }
    
    fn send_command(&mut self, device: &IoTDevice, command: &Command) -> IoTResult<CommandResult> {
        let resource = format!("{}/devices/{}/cmd", self.endpoint, device.get_id());
        
        println!("Sending CoAP PUT to {}: {:?}", resource, command.get_command_type());
        
        // Mock response
        let result = CommandResult::new(command.get_id().into(), true);
        return Ok(result);
    }
    
    fn read_data(&mut self, device: &IoTDevice) -> IoTResult<Vec<DeviceData>> {
        let resource = format!("{}/devices/{}/data", self.endpoint, device.get_id());
        
        println!("Sending CoAP GET to: {}", resource);
        
        // Mock data reading
        let mut data = Vec::new();
        
        for capability in device.get_capabilities() {
            if capability.is_readable() {
                let value = DataValue::Float(rand::random::<f64>() * 100.0);
                let device_data = DeviceData::new(device.get_id().into(), capability.get_data_type(), value);
                data.push(device_data);
            }
        }
        
        return Ok(data);
    }
    
    fn subscribe(&mut self, _device: &IoTDevice, _topics: Vec<String>) -> IoTResult<()> {
        println!("CoAP protocol doesn't support subscriptions");
        return Ok(());
    }
    
    fn unsubscribe(&mut self, _device: &IoTDevice, _topics: Vec<String>) -> IoTResult<()> {
        println!("CoAP protocol doesn't support subscriptions");
        return Ok(());
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §4  IOT MANAGER
// ═══════════════════════════════════════════════════════════════════════════

/// IoT manager
open data IoTManager {
    devices: HashMap<String, IoTDevice>,
    protocols: HashMap<ProtocolType, Box<dyn IoTProtocol>>,
    device_discovery: Box<dyn DeviceDiscovery>,
    data_collector: DataCollector,
    rule_engine: RuleEngine,
    alert_manager: AlertManager,
}

impl IoTManager {
    open fn new() -> IoTManager {
        return IoTManager {
            devices: HashMap::new(),
            protocols: HashMap::new(),
            device_discovery: Box::new(NetworkDiscovery::new()),
            data_collector: DataCollector::new(),
            rule_engine: RuleEngine::new(),
            alert_manager: AlertManager::new(),
        };
    }
    
    open fn add_protocol(&mut self, protocol_type: ProtocolType, protocol: Box<dyn IoTProtocol>) {
        self.protocols.insert(protocol_type, protocol);
    }
    
    open fn add_device(&mut self, device: IoTDevice) -> IoTResult<()> {
        let device_id = device.get_id().into();
        
        // Check if device already exists
        if self.devices.contains_key(&device_id) {
            return Err(IoTError::DeviceNotFound(format!("Device {} already exists", device_id)));
        }
        
        // Connect to device
        if let Some(protocol) = self.protocols.get_mut(&device.get_protocol()) {
            protocol.connect(&device)?;
        }
        
        self.devices.insert(device_id, device);
        return Ok(());
    }
    
    open fn remove_device(&mut self, device_id: &str) -> IoTResult<()> {
        if let Some(device) = self.devices.remove(device_id) {
            // Disconnect from device
            if let Some(protocol) = self.protocols.get_mut(&device.get_protocol()) {
                protocol.disconnect(&device)?;
            }
            return Ok(());
        }
        
        return Err(IoTError::DeviceNotFound(format!("Device {} not found", device_id)));
    }
    
    open fn get_device(&self, device_id: &str) -> Option<&IoTDevice> {
        return self.devices.get(device_id);
    }
    
    open fn get_device_mut(&mut self, device_id: &str) -> Option<&mut IoTDevice> {
        return self.devices.get_mut(device_id);
    }
    
    open fn get_devices(&self) -> &HashMap<String, IoTDevice> {
        return &self.devices;
    }
    
    open fn get_devices_by_type(&self, device_type: DeviceType) -> Vec<&IoTDevice> {
        return self.devices.values()
            .filter(|device| device.get_device_type() == device_type)
            .collect();
    }
    
    open fn get_online_devices(&self) -> Vec<&IoTDevice> {
        return self.devices.values()
            .filter(|device| device.is_online())
            .collect();
    }
    
    open fn discover_devices(&mut self) -> IoTResult<Vec<IoTDevice>> {
        return self.device_discovery.discover();
    }
    
    open fn send_command(&mut self, device_id: &str, command: Command) -> IoTResult<CommandResult> {
        if let Some(device) = self.devices.get(device_id) {
            if let Some(protocol) = self.protocols.get_mut(&device.get_protocol()) {
                return protocol.send_command(device, &command);
            }
        }
        
        return Err(IoTError::DeviceNotFound(format!("Device {} not found", device_id)));
    }
    
    open fn read_device_data(&mut self, device_id: &str) -> IoTResult<Vec<DeviceData>> {
        if let Some(device) = self.devices.get_mut(device_id) {
            if let Some(protocol) = self.protocols.get_mut(&device.get_protocol()) {
                let data = protocol.read_data(device)?;
                
                // Add data to device buffer
                for data_item in data {
                    device.add_data(data_item)?;
                }
                
                // Process data through rule engine
                self.rule_engine.process_data(&data);
                
                return Ok(data);
            }
        }
        
        return Err(IoTError::DeviceNotFound(format!("Device {} not found", device_id)));
    }
    
    open fn read_all_device_data(&mut self) -> IoTResult<HashMap<String, Vec<DeviceData>>> {
        let mut all_data = HashMap::new();
        
        for (device_id, device) in &self.devices.clone() {
            if let Ok(data) = self.read_device_data(device_id) {
                all_data.insert(device_id.clone(), data);
            }
        }
        
        return Ok(all_data);
    }
    
    open fn subscribe_device(&mut self, device_id: &str, topics: Vec<String>) -> IoTResult<()> {
        if let Some(device) = self.devices.get(device_id) {
            if let Some(protocol) = self.protocols.get_mut(&device.get_protocol()) {
                return protocol.subscribe(device, topics);
            }
        }
        
        return Err(IoTError::DeviceNotFound(format!("Device {} not found", device_id)));
    }
    
    open fn unsubscribe_device(&mut self, device_id: &str, topics: Vec<String>) -> IoTResult<()> {
        if let Some(device) = self.devices.get(device_id) {
            if let Some(protocol) = self.protocols.get_mut(&device.get_protocol()) {
                return protocol.unsubscribe(device, topics);
            }
        }
        
        return Err(IoTError::DeviceNotFound(format!("Device {} not found", device_id)));
    }
    
    open fn get_device_count(&self) -> usize {
        return self.devices.len();
    }
    
    open fn get_online_device_count(&self) -> usize {
        return self.devices.values().filter(|d| d.is_online()).count();
    }
    
    open fn get_device_count_by_type(&self, device_type: DeviceType) -> usize {
        return self.devices.values()
            .filter(|device| device.get_device_type() == device_type)
            .count();
    }
    
    open fn add_rule(&mut self, rule: Rule) {
        self.rule_engine.add_rule(rule);
    }
    
    open fn get_alerts(&self) -> Vec<&Alert> {
        return self.alert_manager.get_alerts();
    }
    
    open fn clear_alerts(&mut self) {
        self.alert_manager.clear_alerts();
    }
    
    open fn get_statistics(&self) -> IoTStatistics {
        return IoTStatistics {
            total_devices: self.devices.len(),
            online_devices: self.get_online_device_count(),
            devices_by_type: self.get_device_type_counts(),
            total_data_points: self.get_total_data_points(),
            alerts_count: self.alert_manager.get_alerts().len(),
        };
    }
    
    fn get_device_type_counts(&self) -> HashMap<DeviceType, usize> {
        let mut counts = HashMap::new();
        
        for device in self.devices.values() {
            let device_type = device.get_device_type();
            *counts.entry(device_type).or_insert(0) += 1;
        }
        
        return counts;
    }
    
    fn get_total_data_points(&self) -> usize {
        return self.devices.values()
            .map(|device| device.get_all_data().len())
            .sum();
    }
}

/// IoT statistics
open data IoTStatistics {
    total_devices: usize,
    online_devices: usize,
    devices_by_type: HashMap<DeviceType, usize>,
    total_data_points: usize,
    alerts_count: usize,
}

impl IoTStatistics {
    open fn get_total_devices(&self) -> usize {
        return self.total_devices;
    }
    
    open fn get_online_devices(&self) -> usize {
        return self.online_devices;
    }
    
    open fn get_devices_by_type(&self) -> &HashMap<DeviceType, usize> {
        return &self.devices_by_type;
    }
    
    open fn get_total_data_points(&self) -> usize {
        return self.total_data_points;
    }
    
    open fn get_alerts_count(&self) -> usize {
        return self.alerts_count;
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §5  DEVICE DISCOVERY
// ═══════════════════════════════════════════════════════════════════════════

/// Device discovery trait
pub trait DeviceDiscovery {
    fn discover(&mut self) -> IoTResult<Vec<IoTDevice>>;
}

/// Network discovery
open data NetworkDiscovery {
    network_range: String,
    ports: Vec<u16>,
    timeout: std::time::Duration,
}

impl NetworkDiscovery {
    open fn new(network_range: String) -> NetworkDiscovery {
        return NetworkDiscovery {
            network_range: network_range,
            ports: vec![80, 443, 1883, 5683, 8080, 8883],
            timeout: std::time::Duration::from_secs(5),
        };
    }
    
    open fn with_ports(mut self, ports: Vec<u16>) -> NetworkDiscovery {
        self.ports = ports;
        return self;
    }
    
    open fn with_timeout(mut self, timeout: std::time::Duration) -> NetworkDiscovery {
        self.timeout = timeout;
        return self;
    }
}

impl DeviceDiscovery for NetworkDiscovery {
    fn discover(&mut self) -> IoTResult<Vec<IoTDevice>> {
        let mut devices = Vec::new();
        
        // Mock network scan
        for i in 1..=10 {
            let ip = format!("{}.{}.{}.{}", 
                self.network_range.split('.').next().unwrap_or("192"),
                self.network_range.split('.').nth(1).unwrap_or("168"),
                self.network_range.split('.').nth(2).unwrap_or("1"),
                i
            );
            
            for &port in &self.ports {
                // Mock device discovery
                let device = IoTDevice::new(
                    format!("device_{}_{}", i, port),
                    format!("Network Device {}", i),
                    DeviceType::Sensor,
                    ProtocolType::HTTP,
                    ip.clone(),
                    port
                );
                
                // Add some capabilities
                device.add_capability(DeviceCapability::new(DataType::Temperature, true, false));
                device.add_capability(DeviceCapability::new(DataType::Humidity, true, false));
                
                devices.push(device);
            }
        }
        
        return Ok(devices);
    }
}

/// Bluetooth discovery
open data BluetoothDiscovery {
    scan_duration: std::time::Duration,
}

impl BluetoothDiscovery {
    open fn new() -> BluetoothDiscovery {
        return BluetoothDiscovery {
            scan_duration: std::time::Duration::from_secs(10),
        };
    }
    
    open fn with_scan_duration(mut self, duration: std::time::Duration) -> BluetoothDiscovery {
        self.scan_duration = duration;
        return self;
    }
}

impl DeviceDiscovery for BluetoothDiscovery {
    fn discover(&mut self) -> IoTResult<Vec<IoTDevice>> {
        let mut devices = Vec::new();
        
        // Mock Bluetooth scan
        for i in 1..=5 {
            let device = IoTDevice::new(
                format!("bt_device_{}", i),
                format!("Bluetooth Device {}", i),
                DeviceType::Sensor,
                ProtocolType::Bluetooth,
                format!("00:1A:7D:DA:71:13{:02X}", i),
                0
            );
            
            device.add_capability(DeviceCapability::new(DataType::Temperature, true, false));
            device.add_capability(DeviceCapability::new(DataType::Motion, true, false));
            
            devices.push(device);
        }
        
        return Ok(devices);
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §6  DATA COLLECTOR
// ═══════════════════════════════════════════════════════════════════════════

/// Data collector
open data DataCollector {
    collection_interval: std::time::Duration,
    storage: Box<dyn DataStorage>,
    is_running: bool,
}

impl DataCollector {
    open fn new() -> DataCollector {
        return DataCollector {
            collection_interval: std::time::Duration::from_secs(60),
            storage: Box::new(MemoryDataStorage::new()),
            is_running: false,
        };
    }
    
    open fn with_interval(mut self, interval: std::time::Duration) -> DataCollector {
        self.collection_interval = interval;
        return self;
    }
    
    open fn with_storage(mut self, storage: Box<dyn DataStorage>) -> DataCollector {
        self.storage = storage;
        return self;
    }
    
    open fn start_collection(&mut self, iot_manager: &IoTManager) -> IoTResult<()> {
        self.is_running = true;
        
        // In a real implementation, this would run in a separate thread
        self.collection_loop(iot_manager);
        
        return Ok(());
    }
    
    open fn stop_collection(&mut self) {
        self.is_running = false;
    }
    
    fn collection_loop(&mut self, iot_manager: &IoTManager) {
        while self.is_running {
            // Collect data from all devices
            if let Ok(all_data) = iot_manager.read_all_device_data() {
                for (device_id, data) in all_data {
                    for data_item in data {
                        let _ = self.storage.store_data(&device_id, &data_item);
                    }
                }
            }
            
            // Sleep until next collection
            std::thread::sleep(self.collection_interval);
        }
    }
    
    open fn get_data(&self, device_id: &str, from: std::time::Instant, to: std::time::Instant) -> IoTResult<Vec<DeviceData>> {
        return self.storage.retrieve_data(device_id, from, to);
    }
    
    open fn get_latest_data(&self, device_id: &str, limit: usize) -> IoTResult<Vec<DeviceData>> {
        return self.storage.retrieve_latest_data(device_id, limit);
    }
}

/// Data storage trait
pub trait DataStorage {
    fn store_data(&mut self, device_id: &str, data: &DeviceData) -> IoTResult<()>;
    fn retrieve_data(&self, device_id: &str, from: std::time::Instant, to: std::time::Instant) -> IoTResult<Vec<DeviceData>>;
    fn retrieve_latest_data(&self, device_id: &str, limit: usize) -> IoTResult<Vec<DeviceData>>;
}

/// Memory data storage
open data MemoryDataStorage {
    data: HashMap<String, Vec<DeviceData>>,
}

impl MemoryDataStorage {
    open fn new() -> MemoryDataStorage {
        return MemoryDataStorage {
            data: HashMap::new(),
        };
    }
}

impl DataStorage for MemoryDataStorage {
    fn store_data(&mut self, device_id: &str, data: &DeviceData) -> IoTResult<()> {
        let device_data = self.data.entry(device_id.into()).or_insert(Vec::new());
        device_data.push(data.clone());
        
        // Keep only last 10000 records per device
        if device_data.len() > 10000 {
            device_data.remove(0);
        }
        
        return Ok(());
    }
    
    fn retrieve_data(&self, device_id: &str, from: std::time::Instant, to: std::time::Instant) -> IoTResult<Vec<DeviceData>> {
        if let Some(device_data) = self.data.get(device_id) {
            let filtered_data: Vec<DeviceData> = device_data.iter()
                .filter(|data| data.get_timestamp() >= from && data.get_timestamp() <= to)
                .cloned()
                .collect();
            
            return Ok(filtered_data);
        }
        
        return Ok(Vec::new());
    }
    
    fn retrieve_latest_data(&self, device_id: &str, limit: usize) -> IoTResult<Vec<DeviceData>> {
        if let Some(device_data) = self.data.get(device_id) {
            let latest_data: Vec<DeviceData> = device_data.iter()
                .rev()
                .take(limit)
                .cloned()
                .collect();
            
            return Ok(latest_data);
        }
        
        return Ok(Vec::new());
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §7  RULE ENGINE
// ═══════════════════════════════════════════════════════════════════════════

/// Rule engine
open data RuleEngine {
    rules: Vec<Rule>,
    alert_manager: *mut AlertManager,
}

impl RuleEngine {
    open fn new() -> RuleEngine {
        return RuleEngine {
            rules: Vec::new(),
            alert_manager: std::ptr::null_mut(),
        };
    }
    
    open fn with_alert_manager(mut self, alert_manager: *mut AlertManager) -> RuleEngine {
        self.alert_manager = alert_manager;
        return self;
    }
    
    open fn add_rule(&mut self, rule: Rule) {
        self.rules.push(rule);
    }
    
    open fn process_data(&mut self, data: &[DeviceData]) {
        for rule in &mut self.rules {
            rule.evaluate(data, self.alert_manager);
        }
    }
    
    open fn get_rules(&self) -> &Vec<Rule> {
        return &self.rules;
    }
}

/// Rule
open data Rule {
    id: String,
    name: String,
    conditions: Vec<Condition>,
    actions: Vec<Action>,
    enabled: bool,
}

impl Rule {
    open fn new(id: String, name: String) -> Rule {
        return Rule {
            id: id,
            name: name,
            conditions: Vec::new(),
            actions: Vec::new(),
            enabled: true,
        };
    }
    
    open fn with_condition(mut self, condition: Condition) -> Rule {
        self.conditions.push(condition);
        return self;
    }
    
    open fn with_action(mut self, action: Action) -> Rule {
        self.actions.push(action);
        return self;
    }
    
    open fn evaluate(&mut self, data: &[DeviceData], alert_manager: *mut AlertManager) {
        if !self.enabled {
            return;
        }
        
        let mut conditions_met = true;
        
        for condition in &self.conditions {
            if !condition.evaluate(data) {
                conditions_met = false;
                break;
            }
        }
        
        if conditions_met {
            for action in &self.actions {
                action.execute(data, alert_manager);
            }
        }
    }
    
    open fn enable(&mut self) {
        self.enabled = true;
    }
    
    open fn disable(&mut self) {
        self.enabled = false;
    }
    
    open fn is_enabled(&self) -> bool {
        return self.enabled;
    }
}

/// Condition
open data Condition {
    device_id: Option<String>,
    data_type: Option<DataType>,
    operator: ComparisonOperator,
    value: DataValue,
}

/// Comparison operator
open cases ComparisonOperator {
    Equal,
    NotEqual,
    GreaterThan,
    LessThan,
    GreaterThanOrEqual,
    LessThanOrEqual,
    Contains,
}

impl Condition {
    open fn new(operator: ComparisonOperator, value: DataValue) -> Condition {
        return Condition {
            device_id: None,
            data_type: None,
            operator: operator,
            value: value,
        };
    }
    
    open fn for_device(mut self, device_id: String) -> Condition {
        self.device_id = Some(device_id);
        return self;
    }
    
    open fn for_data_type(mut self, data_type: DataType) -> Condition {
        self.data_type = Some(data_type);
        return self;
    }
    
    open fn evaluate(&self, data: &[DeviceData]) -> bool {
        let filtered_data: Vec<&DeviceData> = data.iter()
            .filter(|d| {
                let device_match = self.device_id.as_ref().map_or(true, |id| d.get_device_id() == id);
                let type_match = self.data_type.as_ref().map_or(true, |dt| d.get_data_type() == *dt);
                device_match && type_match
            })
            .collect();
        
        for data_item in filtered_data {
            if self.compare_values(&data_item.get_value(), &self.value) {
                return true;
            }
        }
        
        return false;
    }
    
    fn compare_values(&self, actual: &DataValue, expected: &DataValue) -> bool {
        match self.operator {
            ComparisonOperator::Equal => self.values_equal(actual, expected),
            ComparisonOperator::NotEqual => !self.values_equal(actual, expected),
            ComparisonOperator::GreaterThan => self.values_greater_than(actual, expected),
            ComparisonOperator::LessThan => self.values_less_than(actual, expected),
            ComparisonOperator::GreaterThanOrEqual => self.values_greater_than(actual, expected) || self.values_equal(actual, expected),
            ComparisonOperator::LessThanOrEqual => self.values_less_than(actual, expected) || self.values_equal(actual, expected),
            ComparisonOperator::Contains => self.values_contains(actual, expected),
        }
    }
    
    fn values_equal(&self, a: &DataValue, b: &DataValue) -> bool {
        match (a, b) {
            (DataValue::Float(a), DataValue::Float(b)) => (a - b).abs() < f64::EPSILON,
            (DataValue::Integer(a), DataValue::Integer(b)) => a == b,
            (DataValue::Boolean(a), DataValue::Boolean(b)) => a == b,
            (DataValue::String(a), DataValue::String(b)) => a == b,
            _ => false,
        }
    }
    
    fn values_greater_than(&self, a: &DataValue, b: &DataValue) -> bool {
        match (a, b) {
            (DataValue::Float(a), DataValue::Float(b)) => a > b,
            (DataValue::Integer(a), DataValue::Integer(b)) => a > b,
            _ => false,
        }
    }
    
    fn values_less_than(&self, a: &DataValue, b: &DataValue) -> bool {
        match (a, b) {
            (DataValue::Float(a), DataValue::Float(b)) => a < b,
            (DataValue::Integer(a), DataValue::Integer(b)) => a < b,
            _ => false,
        }
    }
    
    fn values_contains(&self, a: &DataValue, b: &DataValue) -> bool {
        match (a, b) {
            (DataValue::String(a), DataValue::String(b)) => a.contains(b),
            _ => false,
        }
    }
}

/// Action
open data Action {
    action_type: ActionType,
    parameters: HashMap<String, DataValue>,
}

/// Action type
open cases ActionType {
    Alert,
    Email,
    SMS,
    Webhook,
    ExecuteCommand,
    Log,
}

impl Action {
    open fn new(action_type: ActionType) -> Action {
        return Action {
            action_type: action_type,
            parameters: HashMap::new(),
        };
    }
    
    open fn with_parameter(mut self, key: String, value: DataValue) -> Action {
        self.parameters.insert(key, value);
        return self;
    }
    
    open fn execute(&self, data: &[DeviceData], alert_manager: *mut AlertManager) {
        match self.action_type {
            ActionType::Alert => {
                if let Some(message) = self.parameters.get("message") {
                    if let Some(msg_str) = message.as_string() {
                        let alert = Alert::new(
                            format!("Rule Alert: {}", msg_str),
                            AlertSeverity::Warning,
                            data.to_vec()
                        );
                        
                        unsafe {
                            (*alert_manager).add_alert(alert);
                        }
                    }
                }
            }
            ActionType::Log => {
                println!("Rule Action: {:?}", data);
            }
            ActionType::ExecuteCommand => {
                // Mock command execution
                println!("Executing command: {:?}", self.parameters);
            }
            _ => {
                println!("Action type not implemented: {:?}", self.action_type);
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §8  ALERT MANAGER
// ═══════════════════════════════════════════════════════════════════════════

/// Alert manager
open data AlertManager {
    alerts: Vec<Alert>,
    max_alerts: usize,
}

impl AlertManager {
    open fn new() -> AlertManager {
        return AlertManager {
            alerts: Vec::new(),
            max_alerts: 10000,
        };
    }
    
    open fn with_max_alerts(mut self, max_alerts: usize) -> AlertManager {
        self.max_alerts = max_alerts;
        return self;
    }
    
    open fn add_alert(&mut self, alert: Alert) {
        self.alerts.push(alert);
        
        // Maintain max alert count
        if self.alerts.len() > self.max_alerts {
            self.alerts.remove(0);
        }
    }
    
    open fn get_alerts(&self) -> Vec<&Alert> {
        return self.alerts.iter().collect();
    }
    
    open fn get_alerts_by_severity(&self, severity: AlertSeverity) -> Vec<&Alert> {
        return self.alerts.iter()
            .filter(|alert| alert.get_severity() == severity)
            .collect();
    }
    
    open fn get_alerts_by_device(&self, device_id: &str) -> Vec<&Alert> {
        return self.alerts.iter()
            .filter(|alert| alert.get_device_id() == Some(device_id))
            .collect();
    }
    
    open fn clear_alerts(&mut self) {
        self.alerts.clear();
    }
    
    open fn clear_alerts_by_severity(&mut self, severity: AlertSeverity) {
        self.alerts.retain(|alert| alert.get_severity() != severity);
    }
    
    open fn clear_alerts_by_device(&mut self, device_id: &str) {
        self.alerts.retain(|alert| alert.get_device_id() != Some(device_id));
    }
    
    open fn get_alert_count(&self) -> usize {
        return self.alerts.len();
    }
}

/// Alert
open data Alert {
    id: String,
    message: String,
    severity: AlertSeverity,
    timestamp: std::time::Instant,
    device_id: Option<String>,
    data: Vec<DeviceData>,
}

/// Alert severity
open cases AlertSeverity {
    Info,
    Warning,
    Error,
    Critical,
}

impl Alert {
    open fn new(message: String, severity: AlertSeverity, data: Vec<DeviceData>) -> Alert {
        let device_id = data.first().map(|d| d.get_device_id().into());
        
        return Alert {
            id: format!("alert_{}", rand::random::<u64>()),
            message: message,
            severity: severity,
            timestamp: std::time::Instant::now(),
            device_id: device_id,
            data: data,
        };
    }
    
    open fn get_id(&self) -> &str {
        return &self.id;
    }
    
    open fn get_message(&self) -> &str {
        return &self.message;
    }
    
    open fn get_severity(&self) -> AlertSeverity {
        return self.severity.clone();
    }
    
    open fn get_timestamp(&self) -> std::time::Instant {
        return self.timestamp;
    }
    
    open fn get_device_id(&self) -> Option<&str> {
        return self.device_id.as_ref().map(|s| s.as_str());
    }
    
    open fn get_data(&self) -> &Vec<DeviceData> {
        return &self.data;
    }
}

