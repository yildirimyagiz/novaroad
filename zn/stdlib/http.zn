    return HttpServer::new(HttpServerConfig {
        bind_address: bind_address,
        port: port,
        max_connections: 1000,
        request_timeout: Duration::from_secs(30),
        enable_compression: true,
        enable_logging: true,
        tls_config: None,
    });
}

