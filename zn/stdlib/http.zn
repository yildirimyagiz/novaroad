    return HttpClient::new(HttpClientConfig {
        timeout: Duration::from_secs(30),
        max_redirects: 5,
        user_agent: "Nova-HTTP/1.0".into(),
        enable_cookies: true,
        verify_ssl: true,
        proxy: None,
