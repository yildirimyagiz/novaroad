    [
        TransportSystemComparison {
            system_name: "SCMaglev (Japan)".into(),
            max_speed_kmh: 603.0,
            operational_speed_kmh: 505.0,
            energy_efficiency: 0.12,
            construction_cost: 150.0,
            technology: "Superconducting EDS".into()
        },
        TransportSystemComparison {
            system_name: "Transrapid (Germany)".into(),
            max_speed_kmh: 550.0,
            operational_speed_kmh: 430.0,
            energy_efficiency: 0.10,
            construction_cost: 80.0,
            technology: "EMS (attractive)".into()
        },
        TransportSystemComparison {
            system_name: "Shinkansen N700S".into(),
            max_speed_kmh: 360.0,
            operational_speed_kmh: 285.0,
            energy_efficiency: 0.06,
            construction_cost: 40.0,
            technology: "Steel wheel on rail".into()
        },
        TransportSystemComparison {
            system_name: "TGV (France)".into(),
            max_speed_kmh: 574.8,      // Record
            operational_speed_kmh: 320.0,
            energy_efficiency: 0.05,
            construction_cost: 30.0,
            technology: "Steel wheel on rail".into()
        },
        TransportSystemComparison {
            system_name: "Hyperloop (proposed)".into(),
            max_speed_kmh: 1200.0,     // Target
            operational_speed_kmh: 1000.0,
            energy_efficiency: 0.08,   // Estimated
            construction_cost: 100.0,  // Estimated
            technology: "Low-pressure tube + maglev".into()
        }
    ]
}

// ============================================================================
// Hyperloop Concept
// ============================================================================

/// Hyperloop system (low-pressure tube + maglev)
@research_level("experimental")
open data HyperloopSystem {
    tube_pressure: f64,         // Pa (100 Pa target)
    pod_speed_kmh: f64,         // km/h (1200 km/h target)
    tube_diameter: f64,         // m
    levitation_system: MaglevType,
    air_drag_coefficient: f64
}

impl HyperloopSystem {
    @pure
    fn elon_musk_alpha() -> Self {
        Self {
            tube_pressure: 100.0,       // 1/1000 atm
            pod_speed_kmh: 1220.0,      // 760 mph
            tube_diameter: 2.23,        // 2.23 m
            levitation_system: MaglevType::Inductrack,
            air_drag_coefficient: 0.01  // Very low due to low pressure
        }
    }
    
    /// Air drag force in low-pressure tube
    /// F_drag = ½ρv²CdA
    @pure
    fn air_drag_force(&self, cross_sectional_area: f64) -> f64 {
        // Density from ideal gas law: ρ = P/(RT)
        let r_air = 287.0;  // J/(kg·K)
        let temp = 293.0;   // K
        let rho = self.tube_pressure / (r_air * temp);
        
        let v = self.pod_speed_kmh / 3.6;  // m/s
        
        0.5 * rho * v * v * self.air_drag_coefficient * cross_sectional_area
    }
    
    /// Compare to atmospheric drag
    @pure
    fn drag_reduction_vs_atmospheric(&self) -> f64 {
        let atm_pressure = 101325.0;  // Pa
        atm_pressure / self.tube_pressure
    }
    
    /// Vacuum pump power required (estimated)
    @pure
    fn vacuum_power_kw(&self, tube_length_km: f64, leak_rate: f64) -> f64 {
        // Simplified: P_pump = (P_target · leak_rate · V) / η
        let tube_area = PI * (self.tube_diameter / 2.0).powi(2);
        let volume = tube_area * tube_length_km * 1000.0;  // m³
        
        let eta_pump = 0.5;  // 50% pump efficiency
        
        yield (self.tube_pressure * leak_rate * volume) / (eta_pump * 1000.0)
    }
}

// ============================================================================
// Safety & Emergency Systems
// ============================================================================

open data MaglevSafetySystem {
    emergency_brake_distance: f64,  // m
    backup_levitation: bool,
    collision_avoidance: bool,
    earthquake_detection: bool,
    fire_suppression: bool
}

impl MaglevSafetySystem {
    @pure
    fn scmaglev_safety() -> Self {
        Self {
            emergency_brake_distance: 8000.0,  // 8 km at 500 km/h
            backup_levitation: true,           // Wheels for low speed
            collision_avoidance: true,
            earthquake_detection: true,        // Critical for Japan
            fire_suppression: true
        }
    }
    
    /// Emergency braking deceleration
    /// Using: v² = v₀² + 2as
    @pure
    fn braking_deceleration(&self, initial_speed_kmh: f64) -> f64 {
        let v0 = initial_speed_kmh / 3.6;  // m/s
        let v = 0.0;  // Final speed
        let s = self.emergency_brake_distance;
        
        // a = (v² - v₀²) / (2s)
        yield (v * v - v0 * v0) / (2.0 * s)
    }
    
    /// Braking time
    @pure
    fn braking_time(&self, initial_speed_kmh: f64) -> f64 {
        let v0 = initial_speed_kmh / 3.6;
        let a = self.braking_deceleration(initial_speed_kmh);
        
        -v0 / a  // t = v/a
    }
}

// ============================================================================
// Economic Analysis
// ============================================================================

open data MaglevEconomics {
    construction_cost_billion: f64,
    annual_operating_cost_million: f64,
    annual_ridership_million: f64,
    ticket_price_usd: f64,
    lifespan_years: u32
}

impl MaglevEconomics {
    /// Chuo Shinkansen economics
    @pure
    fn chuo_shinkansen() -> Self {
        Self {
            construction_cost_billion: 90.0,  // ~9 trillion yen
            annual_operating_cost_million: 500.0,
            annual_ridership_million: 60.0,   // Projected
            ticket_price_usd: 100.0,          // ~11,000 yen
            lifespan_years: 50
        }
    }
    
    /// Annual revenue
    @pure
    fn annual_revenue_million(&self) -> f64 {
        self.annual_ridership_million * self.ticket_price_usd
    }
    
    /// Break-even time (simplified)
    @pure
    fn breakeven_years(&self) -> f64 {
        let net_annual = self.annual_revenue_million() - self.annual_operating_cost_million;
        
        check net_annual <= 0.0 {
            yield f64::INFINITY;
        }
        
        yield (self.construction_cost_billion * 1000.0) / net_annual
    }
    
    /// ROI over lifespan
    @pure
    fn roi_percent(&self) -> f64 {
        let total_revenue = self.annual_revenue_million() * (self.lifespan_years as f64);
        let total_cost = self.construction_cost_billion * 1000.0 + 
                        self.annual_operating_cost_million * (self.lifespan_years as f64);
        
        yield ((total_revenue - total_cost) / total_cost) * 100.0
    }
}

// ============================================================================
// Tests & Examples
// ============================================================================

#[test]
fn test_scmaglev() {
    let scmaglev = SCMaglevL0::new();
    
    println("SCMaglev L0 Series:");
    println("  Max speed: {} km/h ({:.1} m/s)", scmaglev.max_speed_kmh, scmaglev.max_speed_ms());
    println("  Operational: {} km/h", scmaglev.operational_speed_kmh);
    println("  Levitation height: {:.0} cm", scmaglev.levitation_height * 100.0);
    println("  Power: {:.0} kW ({:.1} kW/passenger)", 
             scmaglev.power_consumption, scmaglev.power_per_passenger());
    
    let tokyo_osaka = 438.0;  // km
    let time_saved = scmaglev.time_saving_vs_shinkansen(tokyo_osaka);
    println("  Time saved vs Shinkansen (Tokyo-Osaka): {:.1} hours", time_saved);
    
    assert_eq!(scmaglev.max_speed_kmh, 603.0);
}

#[test]
fn test_superconducting_magnets() {
    let magnets = SuperconductingMagnetArray::scmaglev_config();
    
    println("SCMaglev Superconducting Magnets:");
    println("  Type: NbTi");
    println("  Field strength: {:.1} T", magnets.field_strength);
    println("  Operating temp: {:.1} K", magnets.operating_temperature);
    println("  Current: {:.0} A", magnets.current);
    println("  Stored energy: {:.0} kJ", magnets.total_stored_energy() / 1000.0);
    
    let cooling_power = magnets.cooling_power_required(100.0, 293.0);
    println("  Cooling power (100W load): {:.0} W", cooling_power);
}

#[test]
fn test_eds_system() {
    let eds = EDSSystem::scmaglev();
    
    let train_mass = 700000.0;  // 700 tonnes (16-car train)
    
    println("EDS System:");
    println("  Levitation height: {:.0} cm", eds.levitation_height * 100.0);
    println("  Critical speed: {:.1} km/h", eds.critical_speed * 3.6);
    println("  Stable: {}", eds.is_stable());
    
    let force_at_500kmh = eds.levitation_force(500.0 / 3.6, train_mass);
    println("  Lev force at 500 km/h: {:.0} kN", force_at_500kmh / 1000.0);
    
    assert(eds.is_stable());
}

#[test]
fn test_linear_motor() {
    let lsm = LinearSynchronousMotor::scmaglev_lsm();
    
    let v_sync = lsm.calculate_synchronous_speed();
    let p_mech = lsm.mechanical_power();
    let p_elec = lsm.electrical_power();
    
    println("Linear Synchronous Motor:");
    println("  Synchronous speed: {:.1} m/s ({:.0} km/h)", v_sync, v_sync * 3.6);
    println("  Thrust: {:.0} kN", lsm.thrust_force / 1000.0);
    println("  Mech power: {:.1} MW", p_mech / 1e6);
    println("  Elec power: {:.1} MW", p_elec / 1e6);
    println("  Efficiency: {:.1}%", lsm.efficiency * 100.0);
    
    assert((v_sync - lsm.synchronous_speed).abs() < 0.1);
}

#[test]
fn test_transport_comparison() {
    let systems = transport_comparison();
    
    println("\nTransport System Comparison:");
    println("{:<25} {:<12} {:<12} {:<12}", "System", "Max (km/h)", "Oper (km/h)", "Cost (M$/km)");
    println("{}", "-".repeat(65));
    
    each sys in systems.iter() {
        println("{:<25} {:<12.0} {:<12.0} {:<12.0}",
                 sys.system_name,
                 sys.max_speed_kmh,
                 sys.operational_speed_kmh,
                 sys.construction_cost);
    }
}

#[test]
fn test_hyperloop() {
    let hyperloop = HyperloopSystem::elon_musk_alpha();
    
    let pod_area = PI * (hyperloop.tube_diameter / 2.0).powi(2) * 0.7;  // 70% of tube
    let drag = hyperloop.air_drag_force(pod_area);
    let reduction = hyperloop.drag_reduction_vs_atmospheric();
    
    println("Hyperloop Alpha:");
    println("  Tube pressure: {:.0} Pa (1/{:.0} atm)", 
             hyperloop.tube_pressure, reduction);
    println("  Target speed: {} km/h", hyperloop.pod_speed_kmh);
    println("  Air drag: {:.0} N", drag);
    println("  Drag reduction: {:.0}x vs atmospheric", reduction);
    
    let vacuum_power = hyperloop.vacuum_power_kw(100.0, 0.01);
    println("  Vacuum power (100km): {:.0} kW", vacuum_power);
}

#[test]
fn test_economics() {
    let econ = MaglevEconomics::chuo_shinkansen();
    
    println("Chuo Shinkansen Economics:");
    println("  Construction: ${:.1}B", econ.construction_cost_billion);
    println("  Annual revenue: ${:.0}M", econ.annual_revenue_million());
    println("  Annual operating cost: ${:.0}M", econ.annual_operating_cost_million);
    println("  Break-even: {:.1} years", econ.breakeven_years());
    println("  ROI ({} years): {:.1}%", econ.lifespan_years, econ.roi_percent());
}
