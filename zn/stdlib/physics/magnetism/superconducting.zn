        }
    ]
}

// ============================================================================
// Tests & Examples
// ============================================================================

#[test]
fn test_lhc_dipole() {
    let lhc = SuperconductingMagnet::lhc_dipole();
    
    println("LHC Dipole Magnet:");
    println("  Field: {:.2} T", lhc.field_strength);
    println("  Current: {:.0} A", lhc.operating_current);
    println("  Stored energy: {:.1} MJ", lhc.stored_energy / 1e6);
    println("  Operating temp: {:.1} K", lhc.operating_temp);
    println("  Magnetic pressure: {:.1} MPa", lhc.magnetic_pressure() / 1e6);
    
    let stress = lhc.hoop_stress(0.01);  // 10 mm wall
    println("  Hoop stress: {:.0} MPa", stress / 1e6);
    
    assert(lhc.is_safe_operation());
}

#[test]
fn test_conductor_comparison() {
    let conductors = [
        ("NbTi", ConductorType::NbTi),
        ("Nb3Sn", ConductorType::Nb3Sn),
        ("YBCO", ConductorType::YBCO),
        ("MgB2", ConductorType::MgB2)
    ];
    
    println("\nSuperconductor Comparison:");
    println("{:<10} {:<10} {:<15} {:<15}", "Material", "Tc (K)", "Bc2 @4K (T)", "Jc (A/mm²)");
    println("{}", "-".repeat(55));
    
    each entry in conductors.iter()  { let (name, conductor) = entry;
        println("{:<10} {:<10.1} {:<15.1} {:<15.0}",
                 name,
                 conductor.critical_temperature(),
                 conductor.upper_critical_field_4k(),
                 conductor.critical_current_density());
    }
}

#[test]
fn test_quench_protection() {
    let quench = QuenchProtectionSystem::lhc_system();
    
    let inductance = 100.0;  // H
    let tau = quench.time_constant(inductance);
    
    println("LHC Quench Protection:");
    println("  Detection time: {:.0} ms", quench.detection_time_ms);
    println("  Dump resistor: {:.0} mΩ", quench.dump_resistor_ohms * 1000.0);
    println("  Time constant: {:.0} s", tau);
    println("  Max temperature: {:.0} K", quench.max_temperature);
    
    assert(tau > 1000.0);  // > 1000 s for LHC
}

#[test]
fn test_magnet_training() {
    var training = MagnetTraining::new(16.0);  // Target 16 T
    
    println("Magnet Training:");
    
    each _ in 0..10 {
        training.perform_quench();
        println("  Quench {}: {:.2} T ({:.1}%)", 
                 training.quench_number,
                 training.achieved_field,
                 training.training_progress());
        
        check training.training_complete {
            println("  Training complete!");
            abort;
        }
    }
}

#[test]
fn test_cryogenics() {
    let cryo = MagnetCryogenics::lhc_cryogenics();
    
    let comp_power = cryo.compressor_power(293.0, 0.3);
    let boiloff = cryo.boiloff_rate_liters_per_hour();
    
    println("LHC Cryogenics:");
    println("  Operating temp: {:.1} K", cryo.operating_temp);
    println("  Cooling capacity: {:.0} W", cryo.cooling_capacity);
    println("  Compressor power: {:.0} kW", comp_power / 1000.0);
    println("  Boil-off: {:.1} L/h", boiloff);
}
EOF
echo "✅ Superconducting magnets module completed!"
