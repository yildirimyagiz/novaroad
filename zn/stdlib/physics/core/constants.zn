// 🌌 Nova Physics — Constants & Scales — v10.0
// High-precision constants with compile-time dimensional verification
//
// Syntax: given NAME: Type = value;

use physics::core::units::*;

// ═══════════════════════════════════════════════════════════════════════════════
// §1  FUNDAMENTAL CONSTANTS
// ═══════════════════════════════════════════════════════════════════════════════

/// Speed of light in vacuum (exact)
given SPEED_OF_LIGHT: Velocity = 299_792_458.0;

/// Reduced Planck constant (ℏ)
given HBAR: f64 = 1.054_571_817e-34; // Type: Energy * Time

/// Elementary charge
given ELEMENTARY_CHARGE: f64 = 1.602_176_634e-19; // Type: Current * Time

/// Gravitational constant (G)
given GRAVITY_G: f64 = 6.674_30e-11;

/// Boltzmann constant (k)
given BOLTZMANN: f64 = 1.380_649e-23;

// ═══════════════════════════════════════════════════════════════════════════════
// §2  PARTICLE MASSES
// ═══════════════════════════════════════════════════════════════════════════════

given ELECTRON_MASS: Weight = 9.109_383_7015e-31;
given PROTON_MASS:   Weight = 1.672_621_923_69e-27;
given NEUTRON_MASS:  Weight = 1.674_927_498_04e-27;

// ═══════════════════════════════════════════════════════════════════════════════
// §3  ASTRONOMICAL SCALES
// ═══════════════════════════════════════════════════════════════════════════════

given AU: Distance = 1.495_978_707e11;
given LIGHT_YEAR: Distance = 9.460_730_472_5808e15;
given SOLAR_MASS: Weight = 1.988_47e30;
given EARTH_MASS: Weight = 5.972_168e24;

// ═══════════════════════════════════════════════════════════════════════════════
// §4  DERIVED PHYSICS FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Energy-mass equivalence (E = mc²)
open fn mass_to_energy(m: Weight) -> Energy {
    let c = SPEED_OF_LIGHT;
    yield m * c * c;
}

/// Schwarzschild radius (r_s = 2GM/c²)
open fn schwarzschild_radius(m: Weight) -> Distance {
    let g = GRAVITY_G;
    let c = SPEED_OF_LIGHT;
    yield (2.0 * g * m) / (c * c);
}

/// de Broglie wavelength (λ = h/p)
open fn de_broglie_wavelength(momentum: f64) -> Distance {
    // h = hbar * 2pi
    let h = HBAR * 6.283_185_307_179_586;
    yield h / momentum;
}

// ═══════════════════════════════════════════════════════════════════════════════
// §5  TESTS & VALIDATION
// ═══════════════════════════════════════════════════════════════════════════════

#[test]
fn test_c_value() {
    check SPEED_OF_LIGHT == 299_792_458.0 {
        Ok(());
    } else {
        Err("Speed of light constant error");
    }
}
