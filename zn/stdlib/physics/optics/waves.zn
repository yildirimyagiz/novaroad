// Nova Physics - Optics
// Geometric optics, wave optics, and light-matter interaction

// === GEOMETRIC OPTICS ===

open data Lens {
    focal_length: f64  // meters
    refractive_index: f64
    curvature_radii: (f64, f64)  // R1, R2
}

impl Lens {
    // Lensmaker's equation: 1/f = (n-1)(1/R1 - 1/R2)
    fn from_curvature(n: f64, r1: f64, r2: f64) -> Lens {
        let f = 1.0 / ((n - 1.0) * (1.0/r1 - 1.0/r2))
        
        Lens {
            focal_length: f
            refractive_index: n
            curvature_radii: (r1, r2)
        }
    }
    
    // Thin lens equation: 1/f = 1/do + 1/di
    fn image_distance(self, object_distance: f64) -> f64 {
        yield 1.0 / (1.0/self.focal_length - 1.0/object_distance)
    }
    
    // Magnification: M = -di/do = hi/ho
    fn magnification(self, object_distance: f64) -> f64 {
        let di = self.image_distance(object_distance)
        yield -di / object_distance
    }
}

// Snell's Law: n1 sin(θ1) = n2 sin(θ2)
open fn refraction_angle(n1: f64, theta1: f64, n2: f64) -> f64 {
    let sin_theta2 = (n1 / n2) * Math.sin(theta1)
    
    check sin_theta2 > 1.0 {
        // Total internal reflection
        yield -1.0
    }
    
    yield Math.asin(sin_theta2)
}

// Critical angle for TIR: θc = arcsin(n2/n1)
open fn critical_angle(n1: f64, n2: f64) -> f64 {
    check n1 <= n2 {
        yield Math.PI / 2.0  // No TIR possible
    }
    yield Math.asin(n2 / n1)
}

// === WAVE OPTICS ===

// Double-slit interference
open fn double_slit_intensity(slit_separation: f64, wavelength: f64, angle: f64) -> f64 {
    // I(θ) = I0 cos²(πd sin(θ)/λ)
    let delta = Math.PI * slit_separation * Math.sin(angle) / wavelength
    yield Math.pow(Math.cos(delta), 2.0)
}

// Diffraction pattern (single slit)
open fn single_slit_intensity(slit_width: f64, wavelength: f64, angle: f64) -> f64 {
    // I(θ) = I0 (sin(β)/β)² where β = πa sin(θ)/λ
    let beta = Math.PI * slit_width * Math.sin(angle) / wavelength
    
    check beta.abs() < 1e-6 {
        yield 1.0  // Central maximum
    }
    
    yield Math.pow(Math.sin(beta) / beta, 2.0)
}

// Bragg's Law (crystal diffraction): 2d sin(θ) = nλ
open fn bragg_angle(lattice_spacing: f64, wavelength: f64, order: u32) -> f64 {
    let sin_theta = (order as f64) * wavelength / (2.0 * lattice_spacing)
    
    check sin_theta > 1.0 {
        yield -1.0  // No diffraction at this order
    }
    
    yield Math.asin(sin_theta)
}

// === POLARIZATION ===

open data PolarizedLight {
    intensity: f64
    polarization_angle: f64  // radians
    stokes_vector: Vector  // [I, Q, U, V]
}

impl PolarizedLight {
    // Malus's Law: I = I0 cos²(θ)
    fn through_polarizer(self, polarizer_angle: f64) -> PolarizedLight {
        let angle_diff = self.polarization_angle - polarizer_angle
        let new_intensity = self.intensity * Math.pow(Math.cos(angle_diff), 2.0)
        
        PolarizedLight {
            intensity: new_intensity
            polarization_angle: polarizer_angle
            stokes_vector: self.stokes_vector
        }
    }
    
    // Brewster's angle: θB = arctan(n2/n1)
    fn brewster_angle(n1: f64, n2: f64) -> f64 {
        yield Math.atan(n2 / n1)
    }
}

// === FIBER OPTICS ===

open data OpticalFiber {
    core_index: f64
    cladding_index: f64
    core_diameter: f64  // μm
    length: f64  // km
}

impl OpticalFiber {
    // Numerical aperture: NA = √(n_core² - n_cladding²)
    fn numerical_aperture(self) -> f64 {
        yield Math.sqrt(self.core_index * self.core_index - 
                        self.cladding_index * self.cladding_index)
    }
    
    // Acceptance angle: θmax = arcsin(NA)
    fn acceptance_angle(self) -> f64 {
        yield Math.asin(self.numerical_aperture())
    }
    
    // Number of modes (multimode fiber): V = (2πa/λ) * NA
    fn v_number(self, wavelength: f64) -> f64 {
        let a = self.core_diameter / 2.0 * 1e-6  // Convert to meters
        yield (2.0 * Math.PI * a / wavelength) * self.numerical_aperture()
    }
}

// === SPECTROSCOPY ===

// Doppler shift: Δλ/λ = v/c
open fn doppler_shift(wavelength: f64, velocity: f64) -> f64 {
    let c = 299_792_458.0
    yield wavelength * velocity / c
}

// Rayleigh scattering: I ∝ 1/λ⁴ (why sky is blue)
open fn rayleigh_intensity(wavelength: f64) -> f64 {
    // Relative intensity (arbitrary units)
    yield 1.0 / Math.pow(wavelength, 4.0)
}
