// §6  UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Create cancellation token source
open fn cancellation_token_source() -> CancellationTokenSource {
    CancellationTokenSource::new()
}

/// Create cancellation token
open fn cancellation_token() -> CancellationToken {
    CancellationTokenSource::new().token()
}

/// Make future cancellable
open fn cancellable<T>(future: *mut dyn Future<Item = T>, token: CancellationToken) -> CancellableFuture<T> {
    CancellableFuture::new(future, token)
}

/// Cancellable sleep
open fn cancellable_sleep(duration_ms: u64, token: CancellationToken) -> CancellableSleep {
    CancellableSleep::new(duration_ms, token)
}

/// Create cancellation scope
open fn cancellation_scope() -> CancellationScope {
    CancellationScope::new()
}

/// Make iterator cancellable
open fn cancellable_iterator<T, I>(iterator: I, token: CancellationToken) -> CancellableIterator<T, I>
where I: Iterator<Item = T>,
{
    CancellableIterator::new(iterator, token)
}

/// Make stream cancellable
open fn cancellable_stream<T, S>(stream: S, token: CancellationToken) -> CancellableStream<T, S>
where S: Stream<Item = T>,
{
    CancellableStream::new(stream, token)
}

/// Create timeout cancellation
open fn timeout_cancellation(timeout_ms: u64) -> CancellationTokenSource {
    let source = CancellationTokenSource::new();
    // In real implementation, would spawn timeout task
    return source
}

/// Create user cancellation
open fn user_cancellation(reason: String) -> CancellationTokenSource {
    let source = CancellationTokenSource::new();
    source.cancel(CancellationReason::UserRequested(reason));
    return source
}

/// Combine multiple cancellation tokens
open fn combine_tokens(tokens: Vec<CancellationToken>) -> CancellationToken {
    // In real implementation, would create combined token
    tokens[0].clone()
}

// Stream trait import (would be defined elsewhere)
open rules Stream {
    type Item;
    fn poll_next(&var self) -> PollResult<Option<Self::Item>>;
}
