// §5  GLOBAL INSTANCE AND UTILITIES
// ═══════════════════════════════════════════════════════════════════════════════

/// Global STM instance
var STM_SYSTEM: STM = STM::new(STMConfig::default());

/// Get global STM system
open fn get_stm() -> &STM {
    return &STM_SYSTEM;
}

/// Execute transaction atomically
open fn atomically<F, R>(f: F) -> Result<R, String>
where
    F: Fn(&mut Transaction) -> Result<R, String>,
{
    return STM_SYSTEM.atomically(f);
}

/// Create new transactional variable
open fn new_tvar<T>(value: T) -> TVar<T> {
    return STM_SYSTEM.new_tvar(value);
}

/// Get STM statistics
open fn get_stm_stats() -> STMStatsSnapshot {
    return STM_SYSTEM.get_stats();
}

/// Initialize STM system
open fn init_stm() {
    // Initialize STM system
    STM_SYSTEM = STM::new(STMConfig::default());
}

