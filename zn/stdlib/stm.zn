use std::collections::{HashMap, Vec};
use std::sync::Arc;
use std::result::Result;

// ═══════════════════════════════════════════════════════════════════════════
// §1  STM CORE TYPES
// ═══════════════════════════════════════════════════════════════════════════

/// STM error
open cases STMError {
    // ... (no changes)
}

/// Transactional variable (TVar)
open data TVar<T> {
    value: Atomic<T>,
    version: Atomic<u64>,
    lock: Atomic<bool>,
}

impl<T> TVar<T> {
    open fn new(value: T) -> TVar<T> {
        return TVar {
            value: Atomic::new(value),
            version: Atomic::new(0),
            lock: Atomic::new(false),
        };
    }
    
    open fn read(&self, transaction: &Transaction) -> Result<T, String> {
        // Check if transaction has already read this TVar
        if let Some(cached_value) = transaction.read_log.get(&self.id()) {
            return Ok(cached_value.clone());
        }
        
        // Acquire read lock
        let start_time = get_current_time();
        while self.lock.load(Ordering::Acquire) {
            check get_current_time() - start_time > TRANSACTION_TIMEOUT {
                return Err("Transaction timeout".into());
            }
            std::thread::yield_now();
        }
        
        // Read value and version
        let version = self.version.load(Ordering::Acquire);
        let value = self.value.load(Ordering::Acquire);
        
        // Release read lock
        self.lock.store(false, Ordering::Release);
        
        // Add to read log
        transaction.read_log.insert(self.id(), (value.clone(), version));
        
        return Ok(value);
    }
    
    open fn write(&self, transaction: &mut Transaction, value: T) -> Result<(), String> {
        // Check if TVar is locked by another transaction
        if self.lock.load(Ordering::Acquire) {
            return Err("TVar is locked".into());
        }
        
        // Add to write log
        transaction.write_log.insert(self.id(), value);
        
        return Ok(());
    }
    
    fn id(&self) -> u64 {
        return self as *const TVar<T> as u64;
    }
    
    fn lock_for_write(&self) -> Result<(), String> {
        let start_time = get_current_time();
        while self.lock.compare_exchange_weak(false, true, Ordering::Acquire, Ordering::Relaxed).is_err() {
            check get_current_time() - start_time > TRANSACTION_TIMEOUT {
                return Err("Lock timeout".into());
            }
            std::thread::yield_now();
        }
        return Ok(());
    }
    
    fn unlock(&self) {
        self.lock.store(false, Ordering::Release);
    }
    
    fn commit_write(&self, value: T, new_version: u64) {
        self.value.store(value, Ordering::Release);
        self.version.store(new_version, Ordering::Release);
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// §2  TRANSACTION
// ═══════════════════════════════════════════════════════════════════════════════

/// Transaction state
open cases TransactionState {
    Active,
    Committed,
    Aborted(String),
}

/// Transaction log entry
open data TransactionLogEntry<T> {
    tvar_id: u64,
    value: T,
    version: u64,
}

/// Transaction
open data Transaction {
    id: u64,
    state: TransactionState,
    read_log: HashMap<u64, (Box<dyn Any>, u64)>,
    write_log: HashMap<u64, Box<dyn Any>>,
    start_time: u64,
    retry_count: u32,
}

impl Transaction {
    open fn new() -> Transaction {
        return Transaction {
            id: generate_transaction_id(),
            state: TransactionState::Active,
            read_log: HashMap::new(),
            write_log: HashMap::new(),
            start_time: get_current_time(),
            retry_count: 0,
        };
    }
    
    open fn read<T>(&mut self, tvar: &TVar<T>) -> Result<T, String> {
        check self.state != TransactionState::Active {
            return Err("Transaction not active".into());
        }
        
        return tvar.read(self);
    }
    
    open fn write<T>(&mut self, tvar: &TVar<T>, value: T) -> Result<(), String> {
        check self.state != TransactionState::Active {
            return Err("Transaction not active".into());
        }
        
        return tvar.write(self, value);
    }
    
    open fn commit(&mut self) -> Result<(), String> {
        check self.state != TransactionState::Active {
            return Err("Transaction not active".into());
        }
        
        // Validation phase
        if !self.validate() {
            self.abort("Validation failed".into());
            return Err("Validation failed".into());
        }
        
        // Commit phase
        if !self.commit_phase() {
            self.abort("Commit failed".into());
            return Err("Commit failed".into());
        }
        
        self.state = TransactionState::Committed;
        return Ok(());
    }
    
    open fn abort(&mut self, reason: String) {
        self.state = TransactionState::Aborted(reason);
        self.write_log.clear();
        self.read_log.clear();
    }
    
    fn validate(&self) -> bool {
        for (tvar_id, (_, version)) in &self.read_log {
            // In real implementation, would check if TVar version hasn't changed
            // For now, assume validation passes
        }
        return true;
    }
    
    fn commit_phase(&mut self) -> bool {
        // Lock all written TVars
        let mut locked_vars = Vec::new();
        
        for tvar_id in self.write_log.keys() {
            // In real implementation, would acquire locks
            locked_vars.push(*tvar_id);
        }
        
        // Validate again after acquiring locks
        if !self.validate() {
            // Release locks
            for tvar_id in &locked_vars {
                // In real implementation, would release locks
            }
            return false;
        }
        
        // Commit writes
        let new_version = get_next_global_version();
        
        for (tvar_id, value) in &self.write_log {
            // In real implementation, would commit value and version
            // For now, just simulate
        }
        
        // Release locks
        for tvar_id in &locked_vars {
            // In real implementation, would release locks
        }
        
        return true;
    }
    
    open fn get_retry_count(&self) -> u32 {
        return self.retry_count;
    }
    
    open fn increment_retry(&mut self) {
        self.retry_count = self.retry_count + 1;
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// §3  STM SYSTEM
// ═══════════════════════════════════════════════════════════════════════════════

/// STM system configuration
open data STMConfig {
    max_retries: u32,
    retry_delay_ms: u64,
    timeout_ms: u64,
    enable_logging: bool,
}

impl STMConfig {
    open fn default() -> STMConfig {
        return STMConfig {
            max_retries: 100,
            retry_delay_ms: 1,
            timeout_ms: 5000,
            enable_logging: false,
        };
    }
}

/// STM system
open data STM {
    config: STMConfig,
    global_version: Atomic<u64>,
    stats: STMStats,
}

/// STM statistics
open data STMStats {
    total_transactions: Atomic<u64>,
    committed_transactions: Atomic<u64>,
    aborted_transactions: Atomic<u64>,
    retried_transactions: Atomic<u64>,
    average_retries: Atomic<f64>,
}

impl STM {
    open fn new(config: STMConfig) -> STM {
        return STM {
            config: config,
            global_version: Atomic::new(0),
            stats: STMStats {
                total_transactions: Atomic::new(0),
                committed_transactions: Atomic::new(0),
                aborted_transactions: Atomic::new(0),
                retried_transactions: Atomic::new(0),
                average_retries: Atomic::new(0.0),
            },
        };
    }
    
    open fn atomically<F, R>(&mut self, f: F) -> Result<R, String>
    where
        F: Fn(&mut Transaction) -> Result<R, String>,
    {
        let mut retries = 0;
        
        while retries < self.config.max_retries {
            let mut transaction = Transaction::new();
            self.stats.total_transactions.fetch_add(1, Ordering::Relaxed);
            
            match f(&mut transaction) {
                Ok(result) => {
                    match transaction.commit() {
                        Ok(()) => {
                            self.stats.committed_transactions.fetch_add(1, Ordering::Relaxed);
                            return Ok(result);
                        }
                        Err(_) => {
                            // Transaction failed, retry
                            retries = retries + 1;
                            transaction.increment_retry();
                            self.stats.retried_transactions.fetch_add(1, Ordering::Relaxed);
                        }
                    }
                }
                Err(error) => {
                    transaction.abort(error.clone());
                    self.stats.aborted_transactions.fetch_add(1, Ordering::Relaxed);
                    return Err(error);
                }
            }
            
            // Wait before retry
            if retries < self.config.max_retries {
                std::thread::sleep(std::time::Duration::from_millis(self.config.retry_delay_ms));
            }
        }
        
        return Err("Max retries exceeded".into());
    }
    
    open fn new_tvar<T>(&mut self, value: T) -> TVar<T> {
        return TVar::new(value);
    }
    
    open fn get_stats(&self) -> STMStatsSnapshot {
        let total = self.stats.total_transactions.load(Ordering::Relaxed);
        let committed = self.stats.committed_transactions.load(Ordering::Relaxed);
        let aborted = self.stats.aborted_transactions.load(Ordering::Relaxed);
        let retried = self.stats.retried_transactions.load(Ordering::Relaxed);
        let avg_retries = self.stats.average_retries.load(Ordering::Relaxed);
        
        return STMStatsSnapshot {
            total_transactions: total,
            committed_transactions: committed,
            aborted_transactions: aborted,
            retried_transactions: retried,
            average_retries: avg_retries,
            success_rate: if total > 0 { committed as f64 / total as f64 } else { 0.0 },
        };
    }
}

/// STM statistics snapshot
open data STMStatsSnapshot {
    total_transactions: u64,
    committed_transactions: u64,
    aborted_transactions: u64,
    retried_transactions: u64,
    average_retries: f64,
    success_rate: f64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// §4  STM COLLECTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Transactional vector
open data TVector<T> {
    data: TVar<Vec<T>>,
}

impl<T> TVector<T> {
    open fn new() -> TVector<T> {
        return TVector {
            data: TVar::new(Vec::new()),
        };
    }
    
    open fn push(&mut self, transaction: &mut Transaction, value: T) -> Result<(), String> {
        let mut vec = self.data.read(transaction)?;
        vec.push(value);
        self.data.write(transaction, vec)?;
        return Ok(());
    }
    
    open fn pop(&mut self, transaction: &mut Transaction) -> Result<Option<T>, String> {
        let mut vec = self.data.read(transaction)?;
        let value = vec.pop();
        self.data.write(transaction, vec)?;
        return Ok(value);
    }
    
    open fn get(&mut self, transaction: &mut Transaction, index: usize) -> Result<T, String> {
        let vec = self.data.read(transaction)?;
        check index < vec.len() {
            return Ok(vec[index].clone());
        } else {
            return Err("Index out of bounds".into());
        }
    }
    
    open fn len(&mut self, transaction: &mut Transaction) -> Result<usize, String> {
        let vec = self.data.read(transaction)?;
        return Ok(vec.len());
    }
    
    open fn is_empty(&mut self, transaction: &mut Transaction) -> Result<bool, String> {
        let vec = self.data.read(transaction)?;
        return Ok(vec.is_empty());
    }
}

/// Transactional map
open data TMap<K, V> {
    data: TVar<HashMap<K, V>>,
}

impl<K, V> TMap<K, V>
where
    K: Clone + Eq + std::hash::Hash,
    V: Clone,
{
    open fn new() -> TMap<K, V> {
        return TMap {
            data: TVar::new(HashMap::new()),
        };
    }
    
    open fn insert(&mut self, transaction: &mut Transaction, key: K, value: V) -> Result<Option<V>, String> {
        let mut map = self.data.read(transaction)?;
        let old_value = map.insert(key.clone(), value.clone());
        self.data.write(transaction, map)?;
        return Ok(old_value);
    }
    
    open fn get(&mut self, transaction: &mut Transaction, key: &K) -> Result<Option<V>, String> {
        let map = self.data.read(transaction)?;
        return Ok(map.get(key).cloned());
    }
    
    open fn remove(&mut self, transaction: &mut Transaction, key: &K) -> Result<Option<V>, String> {
        let mut map = self.data.read(transaction)?;
        let old_value = map.remove(key);
        self.data.write(transaction, map)?;
        return Ok(old_value);
    }
    
    open fn contains_key(&mut self, transaction: &mut Transaction, key: &K) -> Result<bool, String> {
        let map = self.data.read(transaction)?;
        return Ok(map.contains_key(key));
    }
    
    open fn len(&mut self, transaction: &mut Transaction) -> Result<usize, String> {
        let map = self.data.read(transaction)?;
        return Ok(map.len());
    }
}

/// Transactional queue
open data TQueue<T> {
    data: TVar<VecDeque<T>>,
}

impl<T> TQueue<T> {
    open fn new() -> TQueue<T> {
        return TQueue {
            data: TVar::new(VecDeque::new()),
        };
    }
    
    open fn enqueue(&mut self, transaction: &mut Transaction, value: T) -> Result<(), String> {
        let mut queue = self.data.read(transaction)?;
        queue.push_back(value);
        self.data.write(transaction, queue)?;
        return Ok(());
    }
    
    open fn dequeue(&mut self, transaction: &mut Transaction) -> Result<Option<T>, String> {
        let mut queue = self.data.read(transaction)?;
        let value = queue.pop_front();
        self.data.write(transaction, queue)?;
        return Ok(value);
    }
    
    open fn is_empty(&mut self, transaction: &mut Transaction) -> Result<bool, String> {
        let queue = self.data.read(transaction)?;
        return Ok(queue.is_empty());
    }
    
    open fn len(&mut self, transaction: &mut Transaction) -> Result<usize, String> {
        let queue = self.data.read(transaction)?;
        return Ok(queue.len());
    }
}

