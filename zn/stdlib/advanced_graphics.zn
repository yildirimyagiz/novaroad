/// Format string helper
fn format(template: &str, args: ...) -> String {
    // Simplified formatting
    return template.into();
}

/// Additional helper for orthographic matrix
impl Mat4 {
    open fn orthographic(left: f32, right: f32, bottom: f32, top: f32, near: f32, far: f32) -> Mat4 {
        return Mat4 {
            m: [
                2.0 / (right - left), 0.0, 0.0, 0.0,
                0.0, 2.0 / (top - bottom), 0.0, 0.0,
                0.0, 0.0, -2.0 / (far - near), 0.0,
                -(right + left) / (right - left), -(top + bottom) / (top - bottom), -(far + near) / (far - near), 1.0,
            ],
        };
    }
}

/// Float extensions
trait FloatExt {
    fn to_radians(self) -> Self;
    fn to_degrees(self) -> Self;
}

impl FloatExt for f32 {
    fn to_radians(self) -> Self {
        self * std::f32::consts::PI / 180.0
    }
    
    fn to_degrees(self) -> Self {
        self * 180.0 / std::f32::consts::PI
    }
}
