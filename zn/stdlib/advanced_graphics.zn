        light.intensity = intensity;
        light.range = range;
        light.spot_angle = angle;
        light.spot_penumbra = penumbra;
        return light;
    }
    
    open fn get_transform(&self) -> &Transform {
        return &self.transform;
    }
    
    open fn get_transform_mut(&mut self) -> &mut Transform {
        return &mut self.transform;
    }
}

/// Light type
open cases LightType {
    Directional,
    Point,
    Spot,
    Ambient,
}

/// Environment
open data Environment {
    ambient_color: Color,
    ambient_intensity: f32,
    fog_color: Color,
    fog_density: f32,
    fog_start: f32,
