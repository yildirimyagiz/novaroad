// §7  FRAMEBUFFERS
// ═══════════════════════════════════════════════════════════════════════════

/// Framebuffer
open data Framebuffer {
    id: u32,
    width: u32,
    height: u32,
    color_attachments: Vec<Texture>,
    depth_attachment: Option<Texture>,
    stencil_attachment: Option<Texture>,
}

impl Framebuffer {
    open fn new(width: u32, height: u32, color_attachments: Vec<Texture>, depth_attachment: Option<Texture>) -> GraphicsResult<Framebuffer> {
        let id = rand::random::<u32>();
        
        return Ok(Framebuffer {
            id: id,
            width: width,
            height: height,
            color_attachments: color_attachments,
            depth_attachment: depth_attachment,
            stencil_attachment: None,
        });
    }
    
    open fn bind(&self) {
        println!("Binding framebuffer {} ({}x{})", self.id, self.width, self.height);
    }
    
    open fn unbind(&self) {
        println!("Unbinding framebuffer {}", self.id);
    }
    
    open fn get_color_attachment(&self, index: usize) -> Option<&Texture> {
        return self.color_attachments.get(index);
    }
    
    open fn get_depth_attachment(&self) -> Option<&Texture> {
        return self.depth_attachment.as_ref();
    }
    
    open fn is_complete(&self) -> bool {
        return !self.color_attachments.is_empty();
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §8  3D SCENE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════

/// Scene
open data Scene {
    nodes: Vec<SceneNode>,
    cameras: HashMap<String, Camera>,
    lights: Vec<Light>,
    environment: Environment,
}

impl Scene {
    open fn new() -> Scene {
        return Scene {
            nodes: Vec::new(),
            cameras: HashMap::new(),
            lights: Vec::new(),
            environment: Environment::new(),
        };
    }
    
    open fn add_node(&mut self, node: SceneNode) {
        self.nodes.push(node);
    }
    
    open fn add_camera(&mut self, name: String, camera: Camera) {
        self.cameras.insert(name, camera);
    }
    
    open fn add_light(&mut self, light: Light) {
        self.lights.push(light);
    }
    
    open fn get_camera(&self, name: &str) -> Option<&Camera> {
        return self.cameras.get(name);
    }
    
    open fn update(&mut self, delta_time: f32) {
        for node in &mut self.nodes {
            node.update(delta_time);
        }
    }
    
    open fn render(&self, pipeline: &mut RenderPipeline, camera_name: &str) -> GraphicsResult<()> {
        if let Some(camera) = self.get_camera(camera_name) {
            // Set camera uniforms
            if let Some(shader_name) = &pipeline.current_shader {
                if let Some(shader) = pipeline.shaders.get(shader_name) {
                    shader.set_uniform_matrix4("view", &camera.get_view_matrix())?;
                    shader.set_uniform_matrix4("projection", &camera.get_projection_matrix())?;
                }
            }
            
            // Render all nodes
            for node in &self.nodes {
                node.render(pipeline)?;
            }
        }
        
        return Ok(());
    }
}

/// Scene node
open data SceneNode {
    name: String,
    transform: Transform,
    mesh: Option<Mesh>,
    material: Option<Material>,
    children: Vec<SceneNode>,
    visible: bool,
}

impl SceneNode {
    open fn new(name: String) -> SceneNode {
        return SceneNode {
            name: name,
            transform: Transform::new(),
            mesh: None,
            material: None,
            children: Vec::new(),
            visible: true,
        };
    }
    
    open fn with_mesh(mut self, mesh: Mesh) -> SceneNode {
        self.mesh = Some(mesh);
        return self;
    }
    
    open fn with_material(mut self, material: Material) -> SceneNode {
        self.material = Some(material);
        return self;
    }
    
    open fn add_child(&mut self, child: SceneNode) {
        self.children.push(child);
    }
    
    open fn update(&mut self, delta_time: f32) {
        self.transform.update(delta_time);
        
        for child in &mut self.children {
            child.update(delta_time);
        }
    }
    
    open fn render(&self, pipeline: &mut RenderPipeline) -> GraphicsResult<()> {
        if !self.visible {
            return Ok(());
        }
        
        // Set model matrix
        if let Some(shader_name) = &pipeline.current_shader {
            if let Some(shader) = pipeline.shaders.get(shader_name) {
                shader.set_uniform_matrix4("model", &self.transform.get_matrix())?;
            }
        }
        
        // Render mesh if present
        if let (Some(mesh), Some(material)) = (&self.mesh, &self.material) {
            material.apply(pipeline)?;
            mesh.render(pipeline)?;
        }
        
        // Render children
        for child in &self.children {
            child.render(pipeline)?;
        }
        
        return Ok(());
    }
    
    open fn get_transform(&self) -> &Transform {
        return &self.transform;
    }
    
    open fn get_transform_mut(&mut self) -> &mut Transform {
        return &mut self.transform;
    }
}

/// Transform
open data Transform {
    position: Vec3,
    rotation: Vec3,
    scale: Vec3,
    matrix: Mat4,
    is_dirty: bool,
}

impl Transform {
    open fn new() -> Transform {
        return Transform {
            position: Vec3::zero(),
            rotation: Vec3::zero(),
            scale: Vec3::one(),
            matrix: Mat4::identity(),
            is_dirty: true,
        };
    }
    
    open fn set_position(&mut self, position: Vec3) {
        self.position = position;
        self.is_dirty = true;
    }
    
    open fn set_rotation(&mut self, rotation: Vec3) {
        self.rotation = rotation;
        self.is_dirty = true;
    }
    
    open fn set_scale(&mut self, scale: Vec3) {
        self.scale = scale;
        self.is_dirty = true;
    }
    
    open fn translate(&mut self, translation: Vec3) {
        self.position = self.position.add(&translation);
        self.is_dirty = true;
    }
    
    open fn rotate(&mut self, rotation: Vec3) {
        self.rotation = self.rotation.add(&rotation);
        self.is_dirty = true;
    }
    
    open fn scale_by(&mut self, scale: Vec3) {
        self.scale = Vec3::new(
            self.scale.x * scale.x,
            self.scale.y * scale.y,
            self.scale.z * scale.z,
        );
        self.is_dirty = true;
    }
    
    open fn update(&mut self, _delta_time: f32) {
        if self.is_dirty {
            self.recalculate_matrix();
            self.is_dirty = false;
        }
    }
    
    open fn get_matrix(&self) -> &Mat4 {
        return &self.matrix;
    }
    
    fn recalculate_matrix(&mut self) {
        let translation_matrix = Mat4::translation(self.position.x, self.position.y, self.position.z);
        let rotation_x = Mat4::rotation_x(self.rotation.x);
        let rotation_y = Mat4::rotation_y(self.rotation.y);
        let rotation_z = Mat4::rotation_z(self.rotation.z);
        let scale_matrix = Mat4::scale(self.scale.x, self.scale.y, self.scale.z);
        
        let rotation_matrix = rotation_z.mul(&rotation_y).mul(&rotation_x);
        self.matrix = translation_matrix.mul(&rotation_matrix).mul(&scale_matrix);
    }
}

/// Camera
open data Camera {
    camera_type: CameraType,
    transform: Transform,
    fov: f32,
    aspect_ratio: f32,
    near_plane: f32,
    far_plane: f32,
    orthographic_size: f32,
}

impl Camera {
    open fn new(camera_type: CameraType) -> Camera {
        return Camera {
            camera_type: camera_type,
            transform: Transform::new(),
            fov: 45.0_f32.to_radians(),
            aspect_ratio: 16.0 / 9.0,
            near_plane: 0.1,
            far_plane: 1000.0,
            orthographic_size: 5.0,
        };
    }
    
    open fn perspective(fov: f32, aspect_ratio: f32, near_plane: f32, far_plane: f32) -> Camera {
        let mut camera = Camera::new(CameraType::Perspective);
        camera.fov = fov;
        camera.aspect_ratio = aspect_ratio;
        camera.near_plane = near_plane;
        camera.far_plane = far_plane;
        return camera;
    }
    
    open fn orthographic(size: f32, aspect_ratio: f32, near_plane: f32, far_plane: f32) -> Camera {
        let mut camera = Camera::new(CameraType::Orthographic);
        camera.orthographic_size = size;
        camera.aspect_ratio = aspect_ratio;
        camera.near_plane = near_plane;
        camera.far_plane = far_plane;
        return camera;
    }
    
    open fn get_view_matrix(&self) -> Mat4 {
        let position = self.transform.position;
        let forward = self.transform.transform_vector(&Vec3::forward());
        let up = self.transform.transform_vector(&Vec3::up());
        
        return Mat4::look_at(position, position.add(&forward), up);
    }
    
    open fn get_projection_matrix(&self) -> Mat4 {
        match self.camera_type {
            CameraType::Perspective => {
                Mat4::perspective(self.fov, self.aspect_ratio, self.near_plane, self.far_plane)
            }
            CameraType::Orthographic => {
                let left = -self.orthographic_size * self.aspect_ratio;
                let right = self.orthographic_size * self.aspect_ratio;
                let bottom = -self.orthographic_size;
                let top = self.orthographic_size;
                
                Mat4::orthographic(left, right, bottom, top, self.near_plane, self.far_plane)
            }
        }
    }
    
    open fn get_transform(&self) -> &Transform {
        return &self.transform;
    }
    
    open fn get_transform_mut(&mut self) -> &mut Transform {
        return &mut self.transform;
    }
}

/// Camera type
open cases CameraType {
    Perspective,
    Orthographic,
}

/// Light
open data Light {
    light_type: LightType,
    color: Color,
    intensity: f32,
