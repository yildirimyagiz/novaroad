// ═══════════════════════════════════════════════════════════════════════════
// §9  MESHES AND MATERIALS
// ═══════════════════════════════════════════════════════════════════════════

/// Mesh
open data Mesh {
    vertices: Vec<Vertex>,
    indices: Vec<u32>,
    vertex_buffer: Option<Buffer>,
    index_buffer: Option<Buffer>,
    vertex_array: Option<VertexArray>,
}

impl Mesh {
    open fn new(vertices: Vec<Vertex>, indices: Vec<u32>) -> Mesh {
        return Mesh {
            vertices: vertices,
            indices: indices,
            vertex_buffer: None,
            index_buffer: None,
            vertex_array: None,
        };
    }
    
    open fn create_plane(size: f32) -> Mesh {
        let half_size = size / 2.0;
        
        let vertices = vec![
            Vertex::new(Vec3::new(-half_size, 0.0, -half_size), Vec2::new(0.0, 0.0), Vec3::new(0.0, 1.0, 0.0)),
            Vertex::new(Vec3::new(half_size, 0.0, -half_size), Vec2::new(1.0, 0.0), Vec3::new(0.0, 1.0, 0.0)),
            Vertex::new(Vec3::new(half_size, 0.0, half_size), Vec2::new(1.0, 1.0), Vec3::new(0.0, 1.0, 0.0)),
            Vertex::new(Vec3::new(-half_size, 0.0, half_size), Vec2::new(0.0, 1.0), Vec3::new(0.0, 1.0, 0.0)),
        ];
        
        let indices = vec![0, 1, 2, 0, 2, 3];
        
        return Mesh::new(vertices, indices);
    }
    
    open fn create_cube(size: f32) -> Mesh {
        let half_size = size / 2.0;
        
        let vertices = vec![
            // Front face
            Vertex::new(Vec3::new(-half_size, -half_size, half_size), Vec2::new(0.0, 0.0), Vec3::new(0.0, 0.0, 1.0)),
            Vertex::new(Vec3::new(half_size, -half_size, half_size), Vec2::new(1.0, 0.0), Vec3::new(0.0, 0.0, 1.0)),
            Vertex::new(Vec3::new(half_size, half_size, half_size), Vec2::new(1.0, 1.0), Vec3::new(0.0, 0.0, 1.0)),
            Vertex::new(Vec3::new(-half_size, half_size, half_size), Vec2::new(0.0, 1.0), Vec3::new(0.0, 0.0, 1.0)),
            
            // Back face
            Vertex::new(Vec3::new(-half_size, -half_size, -half_size), Vec2::new(1.0, 0.0), Vec3::new(0.0, 0.0, -1.0)),
            Vertex::new(Vec3::new(-half_size, half_size, -half_size), Vec2::new(1.0, 1.0), Vec3::new(0.0, 0.0, -1.0)),
            Vertex::new(Vec3::new(half_size, half_size, -half_size), Vec2::new(0.0, 1.0), Vec3::new(0.0, 0.0, -1.0)),
            Vertex::new(Vec3::new(half_size, -half_size, -half_size), Vec2::new(0.0, 0.0), Vec3::new(0.0, 0.0, -1.0)),
            
            // Top face
            Vertex::new(Vec3::new(-half_size, half_size, -half_size), Vec2::new(0.0, 1.0), Vec3::new(0.0, 1.0, 0.0)),
            Vertex::new(Vec3::new(-half_size, half_size, half_size), Vec2::new(0.0, 0.0), Vec3::new(0.0, 1.0, 0.0)),
            Vertex::new(Vec3::new(half_size, half_size, half_size), Vec2::new(1.0, 0.0), Vec3::new(0.0, 1.0, 0.0)),
            Vertex::new(Vec3::new(half_size, half_size, -half_size), Vec2::new(1.0, 1.0), Vec3::new(0.0, 1.0, 0.0)),
            
            // Bottom face
            Vertex::new(Vec3::new(-half_size, -half_size, -half_size), Vec2::new(0.0, 0.0), Vec3::new(0.0, -1.0, 0.0)),
            Vertex::new(Vec3::new(half_size, -half_size, -half_size), Vec2::new(1.0, 0.0), Vec3::new(0.0, -1.0, 0.0)),
            Vertex::new(Vec3::new(half_size, -half_size, half_size), Vec2::new(1.0, 1.0), Vec3::new(0.0, -1.0, 0.0)),
            Vertex::new(Vec3::new(-half_size, -half_size, half_size), Vec2::new(0.0, 1.0), Vec3::new(0.0, -1.0, 0.0)),
            
            // Right face
            Vertex::new(Vec3::new(half_size, -half_size, -half_size), Vec2::new(1.0, 0.0), Vec3::new(1.0, 0.0, 0.0)),
            Vertex::new(Vec3::new(half_size, half_size, -half_size), Vec2::new(1.0, 1.0), Vec3::new(1.0, 0.0, 0.0)),
            Vertex::new(Vec3::new(half_size, half_size, half_size), Vec2::new(0.0, 1.0), Vec3::new(1.0, 0.0, 0.0)),
            Vertex::new(Vec3::new(half_size, -half_size, half_size), Vec2::new(0.0, 0.0), Vec3::new(1.0, 0.0, 0.0)),
            
            // Left face
            Vertex::new(Vec3::new(-half_size, -half_size, -half_size), Vec2::new(0.0, 0.0), Vec3::new(-1.0, 0.0, 0.0)),
            Vertex::new(Vec3::new(-half_size, -half_size, half_size), Vec2::new(1.0, 0.0), Vec3::new(-1.0, 0.0, 0.0)),
            Vertex::new(Vec3::new(-half_size, half_size, half_size), Vec2::new(1.0, 1.0), Vec3::new(-1.0, 0.0, 0.0)),
            Vertex::new(Vec3::new(-half_size, half_size, -half_size), Vec2::new(0.0, 1.0), Vec3::new(-1.0, 0.0, 0.0)),
        ];
        
        let indices = vec![
            0, 1, 2, 0, 2, 3,       // Front
            4, 5, 6, 4, 6, 7,       // Back
            8, 9, 10, 8, 10, 11,    // Top
            12, 13, 14, 12, 14, 15, // Bottom
            16, 17, 18, 16, 18, 19, // Right
            20, 21, 22, 20, 22, 23, // Left
        ];
        
        return Mesh::new(vertices, indices);
    }
    
    open fn create_sphere(radius: f32, segments: u32) -> Mesh {
        let mut vertices = Vec::new();
        let mut indices = Vec::new();
        
        // Generate vertices
        for y in 0..=segments {
            let v = y as f32 / segments as f32;
            let phi = v * std::f32::consts::PI;
            
            for x in 0..=segments {
                let u = x as f32 / segments as f32;
                let theta = u * 2.0 * std::f32::consts::PI;
                
                let position = Vec3::new(
                    radius * phi.sin() * theta.cos(),
                    radius * phi.cos(),
                    radius * phi.sin() * theta.sin(),
                );
                
                let normal = position.normalize();
                let tex_coord = Vec2::new(u, v);
                
                vertices.push(Vertex::new(position, tex_coord, normal));
            }
        }
        
        // Generate indices
        for y in 0..segments {
            for x in 0..segments {
                let a = y * (segments + 1) + x;
                let b = a + 1;
                let c = (y + 1) * (segments + 1) + x;
                let d = c + 1;
                
                indices.push(a);
                indices.push(b);
                indices.push(c);
                indices.push(b);
                indices.push(d);
                indices.push(c);
            }
        }
        
        return Mesh::new(vertices, indices);
    }
    
    open fn upload_to_gpu(&mut self, pipeline: &mut RenderPipeline) -> GraphicsResult<()> {
        // Create vertex buffer
        let vertex_data: Vec<u8> = self.vertices.iter()
            .flat_map(|v| v.to_bytes())
            .collect();
        
        let vertex_buffer = pipeline.create_buffer(
            "mesh_vertex".into(),
            BufferType::ArrayBuffer,
            BufferUsage::StaticDraw,
            Some(vertex_data)
        )?;
        
        // Create index buffer
        let index_data: Vec<u8> = self.indices.iter()
            .flat_map(|i| i.to_le_bytes().to_vec())
            .collect();
        
        let index_buffer = pipeline.create_buffer(
            "mesh_index".into(),
            BufferType::ElementArrayBuffer,
            BufferUsage::StaticDraw,
            Some(index_data)
        )?;
        
        // Create vertex array
        let vertex_array = pipeline.create_vertex_array("mesh_vertex_array".into())?;
        
        self.vertex_buffer = Some(vertex_buffer);
        self.index_buffer = Some(index_buffer);
        self.vertex_array = Some(vertex_array);
        
        return Ok(());
    }
    
    open fn render(&self, pipeline: &mut RenderPipeline) -> GraphicsResult<()> {
        if let (Some(vertex_array), Some(index_buffer)) = (&self.vertex_array, &self.index_buffer) {
            vertex_array.bind();
            index_buffer.bind();
            
            pipeline.draw_elements(
                PrimitiveType::Triangles,
                self.indices.len() as u32,
                IndexType::UnsignedInt,
                0
            )?;
            
            vertex_array.unbind();
            index_buffer.unbind();
        }
        
        return Ok(());
    }
}

/// Vertex
open data Vertex {
    position: Vec3,
    tex_coord: Vec2,
    normal: Vec3,
    tangent: Vec3,
    bitangent: Vec3,
}

impl Vertex {
    open fn new(position: Vec3, tex_coord: Vec2, normal: Vec3) -> Vertex {
        return Vertex {
            position: position,
            tex_coord: tex_coord,
            normal: normal,
            tangent: Vec3::zero(),
            bitangent: Vec3::zero(),
        };
    }
    
    open fn with_tangent(mut self, tangent: Vec3) -> Vertex {
        self.tangent = tangent;
        return self;
    }
    
    open fn with_bitangent(mut self, bitangent: Vec3) -> Vertex {
        self.bitangent = bitangent;
        return self;
    }
    
    open fn to_bytes(&self) -> Vec<u8> {
        let mut bytes = Vec::new();
        
        // Position (3 floats)
        bytes.extend_from_slice(&self.position.x.to_le_bytes());
        bytes.extend_from_slice(&self.position.y.to_le_bytes());
        bytes.extend_from_slice(&self.position.z.to_le_bytes());
        
        // Tex coord (2 floats)
        bytes.extend_from_slice(&self.tex_coord.x.to_le_bytes());
        bytes.extend_from_slice(&self.tex_coord.y.to_le_bytes());
        
        // Normal (3 floats)
        bytes.extend_from_slice(&self.normal.x.to_le_bytes());
        bytes.extend_from_slice(&self.normal.y.to_le_bytes());
        bytes.extend_from_slice(&self.normal.z.to_le_bytes());
        
        // Tangent (3 floats)
        bytes.extend_from_slice(&self.tangent.x.to_le_bytes());
        bytes.extend_from_slice(&self.tangent.y.to_le_bytes());
        bytes.extend_from_slice(&self.tangent.z.to_le_bytes());
        
        // Bitangent (3 floats)
        bytes.extend_from_slice(&self.bitangent.x.to_le_bytes());
        bytes.extend_from_slice(&self.bitangent.y.to_le_bytes());
        bytes.extend_from_slice(&self.bitangent.z.to_le_bytes());
        
        return bytes;
    }
}

/// Material
open data Material {
    name: String,
    albedo: Color,
    metallic: f32,
    roughness: f32,
    ao: f32,
    albedo_texture: Option<Texture>,
    normal_texture: Option<Texture>,
    metallic_texture: Option<Texture>,
    roughness_texture: Option<Texture>,
    ao_texture: Option<Texture>,
    shader: Option<Shader>,
}

impl Material {
    open fn new(name: String) -> Material {
        return Material {
            name: name,
            albedo: Color::white(),
            metallic: 0.0,
            roughness: 1.0,
            ao: 1.0,
            albedo_texture: None,
            normal_texture: None,
            metallic_texture: None,
            roughness_texture: None,
            ao_texture: None,
            shader: None,
        };
    }
    
    open fn with_albedo(mut self, albedo: Color) -> Material {
        self.albedo = albedo;
        return self;
    }
    
    open fn with_metallic(mut self, metallic: f32) -> Material {
        self.metallic = metallic;
        return self;
    }
    
    open fn with_roughness(mut self, roughness: f32) -> Material {
        self.roughness = roughness;
        return self;
    }
    
    open fn with_albedo_texture(mut self, texture: Texture) -> Material {
        self.albedo_texture = Some(texture);
        return self;
    }
    
    open fn with_normal_texture(mut self, texture: Texture) -> Material {
        self.normal_texture = Some(texture);
        return self;
    }
    
    open fn with_metallic_texture(mut self, texture: Texture) -> Material {
        self.metallic_texture = Some(texture);
        return self;
    }
    
    open fn with_roughness_texture(mut self, texture: Texture) -> Material {
        self.roughness_texture = Some(texture);
        return self;
    }
    
    open fn with_ao_texture(mut self, texture: Texture) -> Material {
        self.ao_texture = Some(texture);
        return self;
    }
    
    open fn apply(&self, pipeline: &mut RenderPipeline) -> GraphicsResult<()> {
        if let Some(shader_name) = &pipeline.current_shader {
            if let Some(shader) = pipeline.shaders.get(shader_name) {
                // Set material properties
                shader.set_uniform_color("material.albedo", self.albedo)?;
                shader.set_uniform_float("material.metallic", self.metallic)?;
                shader.set_uniform_float("material.roughness", self.roughness)?;
                shader.set_uniform_float("material.ao", self.ao)?;
                
                // Bind textures
                if let Some(ref texture) = self.albedo_texture {
                    texture.bind(0);
                    shader.set_uniform_texture("material.albedoTexture", 0)?;
                }
                
                if let Some(ref texture) = self.normal_texture {
                    texture.bind(1);
                    shader.set_uniform_texture("material.normalTexture", 1)?;
                }
                
                if let Some(ref texture) = self.metallic_texture {
                    texture.bind(2);
                    shader.set_uniform_texture("material.metallicTexture", 2)?;
                }
                
                if let Some(ref texture) = self.roughness_texture {
                    texture.bind(3);
                    shader.set_uniform_texture("material.roughnessTexture", 3)?;
                }
                
                if let Some(ref texture) = self.ao_texture {
                    texture.bind(4);
                    shader.set_uniform_texture("material.aoTexture", 4)?;
                }
            }
        }
        
        return Ok(());
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §10  WEBGL SUPPORT
// ═══════════════════════════════════════════════════════════════════════════

/// WebGL context
open data WebGLContext {
    canvas: String,
    context_type: WebGLContextType,
    is_initialized: bool,
    max_texture_size: u32,
    max_viewport_dims: Vec2,
    vendor: String,
    renderer: String,
}

impl WebGLContext {
    open fn new(canvas: String, context_type: WebGLContextType) -> WebGLContext {
        return WebGLContext {
            canvas: canvas,
            context_type: context_type,
            is_initialized: false,
            max_texture_size: 4096,
            max_viewport_dims: Vec2::new(4096.0, 4096.0),
            vendor: "WebGL Vendor".into(),
            renderer: "WebGL Renderer".into(),
        };
    }
    
    open fn initialize(&mut self) -> GraphicsResult<()> {
        // Initialize WebGL context
        self.is_initialized = true;
        return Ok(());
    }
    
    open fn get_canvas(&self) -> &str {
        return &self.canvas;
    }
    
    open fn get_context_info(&self) -> String {
        return format!("WebGL {} - {} {}", 
            format!("{:?}", self.context_type),
            self.vendor,
            self.renderer
        );
    }
}

/// WebGL context type
open cases WebGLContextType {
    WebGL1,
    WebGL2,
}

/// WebGL renderer
open data WebGLRenderer {
    context: WebGLContext,
    pipeline: RenderPipeline,
}

impl WebGLRenderer {
    open fn new(context: WebGLContext) -> WebGLRenderer {
        let device = GraphicsDevice::new(DeviceType::WebGL);
        let pipeline = RenderPipeline::new(device);
        
        return WebGLRenderer {
            context: context,
            pipeline: pipeline,
        };
    }
    
    open fn initialize(&mut self) -> GraphicsResult<()> {
        self.context.initialize()?;
        return Ok(());
    }
    
    open fn render(&mut self, scene: &Scene, camera_name: &str) -> GraphicsResult<()> {
        self.pipeline.set_viewport(0.0, 0.0, 800.0, 600.0);
        self.pipeline.set_clear_color(Color::black());
        self.pipeline.clear(ClearMask::ColorDepthStencil);
        
        scene.render(&mut self.pipeline, camera_name)?;
        
        self.pipeline.present()?;
        
        return Ok(());
    }
    
    open fn resize(&mut self, width: f32, height: f32) {
        self.pipeline.set_viewport(0.0, 0.0, width, height);
    }
}

