// ═══════════════════════════════════════════════════════════════════════════════
// SIMD TYPES
// ═══════════════════════════════════════════════════════════════════════════════

/**
 * SIMD vector types
 * 
 * Width-generic SIMD operations:
 * - SIMD[DType, width] - Generic SIMD alias
 * - Supports widths: 2, 4, 8, 16, 32, 64
 * - Hardware-agnostic (compiles to best available)
 */

// Base SIMD alias
@intrinsic
data SIMD<T, const WIDTH: usize> {
    data: [T; WIDTH]
    
    // Constructor
    fn new(value: T) -> Self {
        var result = Self { data: [value; WIDTH] };
        result
    }
    
    // Load from array
    fn load(ptr: &[T]) -> Self {
        // Compile to: movups, vldr, etc.
        __simd_load(ptr, WIDTH)
    }
    
    // Store to array
    fn store(self, ptr: &var [T]) {
        // Compile to: movups, vstr, etc.
        __simd_store(self, ptr, WIDTH)
    }
    
    // Splat (broadcast) single value
    fn splat(value: T) -> Self {
        // Compile to: vdup, _mm_set1_ps, etc.
        Self::new(value)
    }
}

// Type aliases for common widths
alias Vec2<T> = SIMD<T, 2>;
alias Vec4<T> = SIMD<T, 4>;
alias Vec8<T> = SIMD<T, 8>;
alias Vec16<T> = SIMD<T, 16>;

// Float specializations (most common)
alias f32x4 = SIMD<f32, 4>;   // SSE/NEON
alias f32x8 = SIMD<f32, 8>;   // AVX
alias f32x16 = SIMD<f32, 16>; // AVX-512

alias f64x2 = SIMD<f64, 2>;   // SSE/NEON
alias f64x4 = SIMD<f64, 4>;   // AVX
alias f64x8 = SIMD<f64, 8>;   // AVX-512

// Integer specializations
alias i32x4 = SIMD<i32, 4>;
alias i32x8 = SIMD<i32, 8>;
alias i32x16 = SIMD<i32, 16>;

// ═══════════════════════════════════════════════════════════════════════════════
// ARITHMETIC OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

impl<T, const WIDTH: usize> SIMD<T, WIDTH> {
    /**
     * Add two SIMD vectors
     * Compiles to:
     * - x86: _mm_add_ps (SSE), _mm256_add_ps (AVX)
     * - ARM: vadd_f32 (NEON)
     */
    @simd
    fn add(self, other: Self) -> Self {
        __simd_add(self, other)
    }
    
    /**
     * Subtract two SIMD vectors
     */
    @simd
    fn sub(self, other: Self) -> Self {
        __simd_sub(self, other)
    }
    
    /**
     * Multiply two SIMD vectors
     */
    @simd
    fn mul(self, other: Self) -> Self {
        __simd_mul(self, other)
    }
    
    /**
     * Divide two SIMD vectors
     */
    @simd
    fn div(self, other: Self) -> Self {
        __simd_div(self, other)
    }
    
    /**
     * Fused multiply-add: self * a + b
     * Single instruction on modern CPUs!
     */
    @simd
    fn fma(self, a: Self, b: Self) -> Self {
        __simd_fma(self, a, b)
    }
}

// Operator overloading for natural syntax
impl<T, const WIDTH: usize> Add for SIMD<T, WIDTH> {
    fn add(self, other: Self) -> Self {
        self.add(other)
    }
}

impl<T, const WIDTH: usize> Mul for SIMD<T, WIDTH> {
    fn mul(self, other: Self) -> Self {
        self.mul(other)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// COMPARISON OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

impl<T, const WIDTH: usize> SIMD<T, WIDTH> {
    /**
     * Compare equal
     * Returns mask (all bits set check true, 0 check false)
     */
    @simd
    fn eq(self, other: Self) -> Self {
        __simd_eq(self, other)
    }
    
    /**
     * Compare less than
     */
    @simd
    fn lt(self, other: Self) -> Self {
        __simd_lt(self, other)
    }
    
    /**
     * Compare greater than
     */
    @simd
    fn gt(self, other: Self) -> Self {
        __simd_gt(self, other)
    }
    
    /**
     * Select based on mask
     * result[i] = mask[i] ? a[i] : b[i]
     */
    @simd
    fn select(mask: Self, a: Self, b: Self) -> Self {
        __simd_select(mask, a, b)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// REDUCTION OPERATIONS
// ═══════════════════════════════════════════════════════════════════════════════

impl<T, const WIDTH: usize> SIMD<T, WIDTH> {
    /**
     * Horizontal sum (reduce all elements)
     */
    @simd
    fn sum(self) -> T {
        __simd_reduce_add(self)
    }
    
    /**
     * Horizontal product
     */
    @simd
    fn product(self) -> T {
        __simd_reduce_mul(self)
    }
    
    /**
     * Minimum element
     */
    @simd
    fn min(self) -> T {
        __simd_reduce_min(self)
    }
    
    /**
     * Maximum element
     */
    @simd
    fn max(self) -> T {
        __simd_reduce_max(self)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// MATH FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

impl SIMD<f32, 4> {  // f32x4 specialization
    /**
     * Square root (vectorized)
     */
    @simd
    fn sqrt(self) -> Self {
        __simd_sqrt_f32x4(self)
    }
    
    /**
     * Reciprocal square root (fast approximation)
     */
    @simd
    fn rsqrt(self) -> Self {
        __simd_rsqrt_f32x4(self)
    }
    
    /**
     * Absolute value
     */
    @simd
    fn abs(self) -> Self {
        __simd_abs_f32x4(self)
    }
    
    /**
     * Floor
     */
    @simd
    fn floor(self) -> Self {
        __simd_floor_f32x4(self)
    }
    
    /**
     * Ceiling
     */
    @simd
    fn ceil(self) -> Self {
        __simd_ceil_f32x4(self)
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// AUTO-VECTORIZATION HINTS
// ═══════════════════════════════════════════════════════════════════════════════

/**
 * Auto-vectorize a loop
 * Compiler will convert scalar operations to SIMD
 */
@vectorize
fn vector_add(a: &[f32], b: &[f32]) -> Vec<f32> {
    var result = Vec::with_capacity(a.len());
    
    // Compiler auto-vectorizes this loop!
    each i in 0..a.len() {
        result.push(a[i] + b[i]);
    }
    
    result
}

/**
 * Explicit SIMD for maximum performance
 */
fn vector_add_simd(a: &[f32], b: &[f32]) -> Vec<f32> {
    var result = Vec::with_capacity(a.len());
    let chunks = a.len() / 4;
    
    // Process 4 elements at a time
    each i in 0..chunks {
        let va = f32x4::load(&a[i*4..(i+1)*4]);
        let vb = f32x4::load(&b[i*4..(i+1)*4]);
        let vr = va + vb;  // SIMD add!
        vr.store(&var result[i*4..(i+1)*4]);
    }
    
    // Handle remainder
    each i in (chunks*4)..a.len() {
        result.push(a[i] + b[i]);
    }
    
    result
}

// ═══════════════════════════════════════════════════════════════════════════════
// HARDWARE DETECTION
// ═══════════════════════════════════════════════════════════════════════════════

/**
 * Detect available SIMD features at runtime
 */
data SimdFeatures {
    sse: bool,
    sse2: bool,
    sse3: bool,
    ssse3: bool,
    sse4_1: bool,
    sse4_2: bool,
    avx: bool,
    avx2: bool,
    avx512f: bool,
    neon: bool,
    sve: bool,
}

fn detect_simd_features() -> SimdFeatures {
    #[cfg(target_arch = "x86_64")]
    {
        SimdFeatures {
            sse: __has_sse(),
            sse2: __has_sse2(),
            sse3: __has_sse3(),
            ssse3: __has_ssse3(),
            sse4_1: __has_sse4_1(),
            sse4_2: __has_sse4_2(),
            avx: __has_avx(),
            avx2: __has_avx2(),
            avx512f: __has_avx512f(),
            neon: false,
            sve: false,
        }
    }
    
    #[cfg(target_arch = "aarch64")]
    {
        SimdFeatures {
            sse: false,
            sse2: false,
            sse3: false,
            ssse3: false,
            sse4_1: false,
            sse4_2: false,
            avx: false,
            avx2: false,
            avx512f: false,
            neon: __has_neon(),
            sve: __has_sve(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// EXAMPLES
// ═══════════════════════════════════════════════════════════════════════════════

/**
 * Example: Dot product using SIMD
 */
fn dot_product_simd(a: &[f32], b: &[f32]) -> f32 {
    assert(a.len() == b.len());
    
    var sum = f32x4::splat(0.0);
    let chunks = a.len() / 4;
    
    // SIMD loop
    each i in 0..chunks {
        let va = f32x4::load(&a[i*4..(i+1)*4]);
        let vb = f32x4::load(&b[i*4..(i+1)*4]);
        sum = sum.fma(va, vb);  // sum += va * vb
    }
    
    var result = sum.sum();
    
    // Handle remainder
    each i in (chunks*4)..a.len() {
        result += a[i] * b[i];
    }
    
    result
}

/**
 * Example: Matrix multiplication with SIMD
 */
fn matmul_simd(a: &[f32], b: &[f32], n: usize) -> Vec<f32> {
    var c = [0.0; n * n];
    
    each i in 0..n {
        each j in 0..n {
            var sum = f32x4::splat(0.0);
            let chunks = n / 4;
            
            // SIMD inner loop
            each k in 0..chunks {
                let va = f32x4::load(&a[i*n + k*4..i*n + (k+1)*4]);
                let vb = f32x4::load(&b[k*4*n + j..]);  // Strided load
                sum = sum.fma(va, vb);
            }
            
            c[i*n + j] = sum.sum();
            
            // Remainder
            each k in (chunks*4)..n {
                c[i*n + j] += a[i*n + k] * b[k*n + j];
            }
        }
    }
    
    c
}

/**
 * Example: Image processing with SIMD
 */
fn blur_image_simd(pixels: &var [u8], width: usize, height: usize) {
    // Process 16 pixels at a time
    let chunks = (width * height) / 16;
    
    each i in 0..chunks {
        let offset = i * 16;
        
        // Load 16 pixels
        let v = i32x16::load(&pixels[offset..offset+16]);
        
        // Simple blur: average with neighbors
        let left = i32x16::load(&pixels[offset-1..offset+15]);
        let right = i32x16::load(&pixels[offset+1..offset+17]);
        
        let blurred = (v + left + right) / i32x16::splat(3);
        
        blurred.store(&var pixels[offset..offset+16]);
    }
}
