// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  WebSocket - Real-time bidirectional communication                          ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// WebSocket connection
open data WebSocket {
    connection_id: u64,
}

impl WebSocket {
    /// Connect to WebSocket server
    open fn connect(url: String) -> Result<WebSocket, String> {
        extern "C" {
            fn nova_ws_connect(url: *const u8, url_len: usize, conn_id: *var u64) -> bool;
        }
        
        var conn_id = 0;
        unsafe {
            check nova_ws_connect(url.as_ptr(), url.len(), &var conn_id) {
                Ok(WebSocket { connection_id: conn_id })
            } else {
                Err("WebSocket connection failed".into())
            }
        }
    }
    
    /// Send text message
    open fn send_text(&self, message: String) -> Result<(), String> {
        extern "C" {
            fn nova_ws_send_text(
                conn_id: u64,
                message: *const u8,
                message_len: usize
            ) -> bool;
        }
        
        unsafe {
            check nova_ws_send_text(self.connection_id, message.as_ptr(), message.len()) {
                Ok(())
            } else {
                Err("Send failed".into())
            }
        }
    }
    
    /// Send binary message
    open fn send_binary(&self, data: &[u8]) -> Result<(), String> {
        extern "C" {
            fn nova_ws_send_binary(
                conn_id: u64,
                data: *const u8,
                data_len: usize
            ) -> bool;
        }
        
        unsafe {
            check nova_ws_send_binary(self.connection_id, data.as_ptr(), data.len()) {
                Ok(())
            } else {
                Err("Send failed".into())
            }
        }
    }
    
    /// Receive message (blocking)
    open fn receive(&self) -> Result<WebSocketMessage, String> {
        extern "C" {
            fn nova_ws_receive(
                conn_id: u64,
                data: *var *var u8,
                data_len: *var usize,
                is_binary: *var bool
            ) -> bool;
        }
        
        unsafe {
            var data_ptr: *var u8 = std::ptr::null_mut();
            var data_len = 0;
            var is_binary = false;
            
            check nova_ws_receive(self.connection_id, &var data_ptr, &var data_len, &var is_binary) {
                let data = Vec::from_raw_parts(data_ptr, data_len, data_len);
                
                check is_binary {
                    Ok(WebSocketMessage::Binary(data))
                } else {
                    Ok(WebSocketMessage::Text(String::from_utf8_lossy(&data).into()))
                }
            } else {
                Err("Receive failed".into())
            }
        }
    }
    
    /// Close connection
    open fn close(self) {
        extern "C" {
            fn nova_ws_close(conn_id: u64);
        }
        
        unsafe {
            nova_ws_close(self.connection_id);
        }
    }
}

open cases WebSocketMessage {
    Text(String),
    Binary(Vec<u8>),
}
