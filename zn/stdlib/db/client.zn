// DB client rules & ORM types

open data Row {
    columns: Vec<String>,
    values: Vec<String>,
}

open data ResultSet {
    rows: Vec<Row>,
}

open rules DbClient {
    fn connect(url: String) -> Self;
    fn query(self, sql: String) -> ResultSet;
    fn execute(self, sql: String) -> i64;
    fn close(self);
}
