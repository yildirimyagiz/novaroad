            purpose: "Materials Design".into(),
            steps: [
                WorkflowStep {
                    id: "property_analysis".into(),
                    name: "Property Analysis".into(),
                    description: "Analyze required material properties".into(),
                    technologies_used: ["Matminer".into()],
                    inputs: ["requirements".into()],
                    outputs: ["property_targets".into()],
                    estimated_time: 180.0,
                    success_criteria: "Properties defined".into(),
                },
                WorkflowStep {
                    id: "candidate_generation".into(),
                    name: "Candidate Generation".into(),
                    description: "Generate candidate material structures".into(),
                    technologies_used: ["FAIRChem".into(), "Elements AI".into()],
                    inputs: ["property_targets".into()],
                    outputs: ["material_candidates".into()],
                    estimated_time: 1200.0,
                    success_criteria: "Candidates generated".into(),
                },
                WorkflowStep {
                    id: "property_prediction".into(),
                    name: "Property Prediction".into(),
                    description: "Predict properties of candidate materials".into(),
                    technologies_used: ["FAIRChem".into(), "Matminer".into()],
                    inputs: ["material_candidates".into()],
                    outputs: ["predicted_properties".into()],
                    estimated_time: 900.0,
                    success_criteria: "Properties predicted".into(),
                },
            ],
            decision_points: [],
            quality_checks: [],
            resource_requirements: ResourceRequirements {
                gpu_hours: 12.0,
                cpu_hours: 8.0,
                memory_gb: 64.0,
                storage_gb: 500.0,
            },
        }
    }
}

