use std::collections::{HashMap, Vec};
use std::sync::Arc;

/// Nova Chemistry Repository Registry
open data ChemistryRepoRegistry {
    computational_chemistry: ComputationalChemistryRepos,
    quantum_chemistry: QuantumChemistryRepos,
    materials_ai: MaterialsAIRepos,
    synthetic_biology: SyntheticBiologyRepos,
    metabolic_engineering: MetabolicEngineeringRepos,
    bioprocess_simulation: BioprocessSimulationRepos,
    systems_biology: SystemsBiologyRepos,
    cheminformatics: CheminformaticsRepos,
}

impl ChemistryRepoRegistry {
    fn new() -> ChemistryRepoRegistry {
        println("🔬⚡🦠 Initializing Nova Chemistry Repository Registry - Complete Integration");
        println("========================================================================");

        ChemistryRepoRegistry {
            computational_chemistry: ComputationalChemistryRepos::new(),
            quantum_chemistry: QuantumChemistryRepos::new(),
            materials_ai: MaterialsAIRepos::new(),
            synthetic_biology: SyntheticBiologyRepos::new(),
            metabolic_engineering: MetabolicEngineeringRepos::new(),
            bioprocess_simulation: BioprocessSimulationRepos::new(),
            systems_biology: SystemsBiologyRepos::new(),
            cheminformatics: CheminformaticsRepos::new(),
        }
    }

    /// Get all integrated repositories
    fn get_all_repos(&self) -> Vec<Repository> {
        var all_repos = Vec::new();

        all_repos.extend(self.computational_chemistry.get_repos());
        all_repos.extend(self.quantum_chemistry.get_repos());
        all_repos.extend(self.materials_ai.get_repos());
        all_repos.extend(self.synthetic_biology.get_repos());
        all_repos.extend(self.metabolic_engineering.get_repos());
        all_repos.extend(self.bioprocess_simulation.get_repos());
        all_repos.extend(self.systems_biology.get_repos());
        all_repos.extend(self.cheminformatics.get_repos());

        all_repos
    }

    /// Search repositories by keyword
    fn search_repos(&self, keyword: &str) -> Vec<Repository> {
        self.get_all_repos().into_iter()
            .filter(|repo| {
                repo.name.to_lowercase().contains(&keyword.to_lowercase()) ||
                repo.description.to_lowercase().contains(&keyword.to_lowercase()) ||
                repo.tags.iter().any(|tag| tag.to_lowercase().contains(&keyword.to_lowercase()))
            })
            .collect()
    }

    /// Get repositories by category
    fn get_repos_by_category(&self, category: &str) -> Vec<Repository> {
        self.get_all_repos().into_iter()
            .filter(|repo| repo.category == category)
            .collect()
    }

    /// Check integration status
    fn get_integration_status(&self) -> IntegrationStatus {
        let total_repos = self.get_all_repos().len();
        let integrated_count = self.get_all_repos().iter()
            .filter(|repo| repo.nova_integration.status == "integrated")
            .count();

        IntegrationStatus {
            total_repositories: total_repos,
            integrated_count,
            integration_percentage: (integrated_count as f64 / total_repos as f64) * 100.0,
            categories_covered: self.get_category_coverage(),
        }
    }

    fn get_category_coverage(&self) -> HashMap<String, usize> {
        var coverage = HashMap::new();

        each repo in self.get_all_repos() {
            *coverage.entry(repo.category.clone()).or_insert(0) += 1;
        }

        coverage
    }
}

/// Computational Chemistry Repositories (DeepChem, RDKit, etc.)
open data ComputationalChemistryRepos {
