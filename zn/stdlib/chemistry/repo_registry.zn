// Supporting data structures

#[derive(Clone)]
open data Repository {
    name: String,
    owner: String,
    url: String,
    description: String,
    language: String,
    stars: usize,
    category: String,
    tags: Vec<String>,
    nova_integration: NovaIntegration,
    key_features: Vec<String>,
    dependencies: Vec<String>,
}

#[derive(Clone)]
open data NovaIntegration {
    status: String, // "integrated", "planned", "in-progress"
    module_path: String,
    api_endpoints: Vec<String>,
    last_updated: String,
}

#[derive(Clone)]
open data IntegrationStatus {
    total_repositories: usize,
    integrated_count: usize,
    integration_percentage: f64,
    categories_covered: HashMap<String, usize>,
}

/// Main registry functions
open fn get_chemistry_repo_registry() -> ChemistryRepoRegistry {
    ChemistryRepoRegistry::new()
}

open fn search_chemistry_repos(keyword: &str) -> Vec<Repository> {
    let registry = get_chemistry_repo_registry();
    registry.search_repos(keyword)
}

open fn get_repos_by_category(category: &str) -> Vec<Repository> {
    let registry = get_chemistry_repo_registry();
    registry.get_repos_by_category(category)
}

open fn display_integration_status() {
    let registry = get_chemistry_repo_registry();
    let status = registry.get_integration_status();

    println("🔬 NOVA CHEMISTRY REPOSITORY INTEGRATION STATUS");
    println("===============================================");
    println("📊 Total Repositories: {}", status.total_repositories);
    println("✅ Integrated: {} ({:.1}%)", status.integrated_count, status.integration_percentage);
    println("📂 Categories Covered:");

    each entry in &status.categories_covered  { let (category, count) = entry;
        println("  • {}: {} repos", category, count);
    }

    println("");
    println("🎯 INTEGRATED TECHNOLOGIES:");
    let integrated_repos = registry.get_all_repos().into_iter()
        .filter(|repo| repo.nova_integration.status == "integrated")
        .collect::<Vec<_>>();

    each repo in integrated_repos {
        println("  ✅ {} - {}", repo.name, repo.description);
    }

    println("");
    println("🚧 PLANNED INTEGRATIONS:");
    let planned_repos = registry.get_all_repos().into_iter()
        .filter(|repo| repo.nova_integration.status == "planned")
        .collect::<Vec<_>>();

    each repo in planned_repos {
        println("  📋 {} - {}", repo.name, repo.description);
    }
}

/// Demonstration of full repository registry
open fn demonstrate_repo_registry() {
    println("🗂️⚡🔬 NOVA CHEMISTRY REPO REGISTRY DEMONSTRATION");
    println("=================================================");

    let registry = get_chemistry_repo_registry();

    // Show integration status
    display_integration_status();

    println("");
    println("🔍 SEARCH EXAMPLES:");

    // Search for CO2 related repos
    let co2_repos = registry.search_repos("CO2");
    println("  📈 CO2-related repos: {}", co2_repos.len());
    each repo in co2_repos.iter().take(3) {
        println("    • {} ({})", repo.name, repo.category);
    }

    // Search for machine learning repos
    let ml_repos = registry.search_repos("machine-learning");
    println("  🤖 ML-related repos: {}", ml_repos.len());
    each repo in ml_repos.iter().take(3) {
        println("    • {} ({})", repo.name, repo.category);
    }

    println("");
    println("📂 CATEGORY BREAKDOWN:");
    let categories = [
        "Computational Chemistry",
        "Quantum Chemistry",
        "Materials AI",
        "Synthetic Biology",
        "Metabolic Engineering",
    ];

    each category in categories {
        let repos_in_category = registry.get_repos_by_category(category);
        println("  • {}: {} repos", category, repos_in_category.len());
    }

    println("");
    println("🎉 TOTAL REPOSITORY REGISTRY: {} technologies integrated!");
    println("   🌐 All major chemistry repositories now accessible through Nova!");
}
