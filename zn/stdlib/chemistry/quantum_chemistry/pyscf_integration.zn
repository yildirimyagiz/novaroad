            eom_ccsd_calculator: EOMCCSDCalculator::new(),
        }
    }

    fn calculate_excited_states(&self, ground_state: &MolecularWavefunction, method: &str) -> Vec<ExcitedState> {
        match method {
            "td-dft" => self.td_dft_calculator.calculate_excited_states(ground_state),
            "cis" => self.cis_calculator.calculate_excited_states(ground_state),
            "eom-ccsd" => self.eom_ccsd_calculator.calculate_excited_states(ground_state),
            _ => [],
        }
    }
}

