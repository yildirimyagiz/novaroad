/// Main PennyLane integration function
open fn pennylane_quantum_chemistry_analysis(molecule: MolecularSystem) -> QuantumMolecularAnalysis {
    let pennylane = PennyLaneIntegration::new();
    pennylane.analyze_molecule_quantum(&molecule)
}

/// Example usage and demonstration
open fn demonstrate_pennylane_integration() {
    println("⚛️🧬🔬 NOVA PennyLane Quantum Chemistry Integration Demo");
    println("======================================================");

    // Create a simple H2 molecule
    let h2_molecule = MolecularSystem {
        atoms: [
            Atom { atomic_number: 1, position: (-0.7, 0.0, 0.0), symbol: "H".into() },
            Atom { atomic_number: 1, position: (0.7, 0.0, 0.0), symbol: "H".into() },
        ],
        geometry: MolecularGeometry {
            coordinates: [(-0.7, 0.0, 0.0), (0.7, 0.0, 0.0)],
            bonds: [(0, 1, 1.4)],
        },
        charge: 0,
        multiplicity: 1,
    };

    let pennylane = PennyLaneIntegration::new();
    let analysis = pennylane.analyze_molecule_quantum(&h2_molecule);

    println("🔬 Quantum analysis of H2 molecule:");
    println("  ⚛️ Ground state energy: {:.6f} Hartree", analysis.ground_state_energy);
    println("  🧬 HOMO-LUMO gap: {:.3f} eV", analysis.molecular_orbitals.homo_lumo_gap);
    println("  📊 Total electrons: {:.1f}", analysis.electron_density.total_electrons);

    println("  🎯 Quantum advantage metrics:");
    println("    • Speedup factor: {:.1f}x", analysis.quantum_advantage_metrics.speedup_factor);
    println("    • NISQ compatibility: {:.1f}%", analysis.quantum_advantage_metrics.nisq_compatibility_score * 100.0);

    println("  💻 Computational resources:");
    println("    • Qubits required: {}", analysis.computational_resources.qubits_required);
    println("    • Circuit depth: {}", analysis.computational_resources.circuit_depth);
    println("    • Estimated runtime: {:.2f} ms", analysis.computational_resources.estimated_runtime * 1000.0);

    // Simulate a simple reaction
    let h2_analysis = pennylane.analyze_molecule_quantum(&h2_molecule);

    println("\n⚛️ Reaction simulation demo:");
    println("  📈 Ground state energy: {:.6f} Hartree", h2_analysis.ground_state_energy);
    println("  🔬 Spectroscopic data available: {} excitation energies", h2_analysis.spectroscopic_properties.excitation_energies.len());

    println("\n🎉 PennyLane quantum chemistry integration successfully demonstrated!");
    println("   ⚛️ VQE, QPE, quantum algorithms all active!");
    println("   🧬 Molecular simulations on quantum computers ready!");
}
