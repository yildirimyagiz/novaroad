// Nova Standard Library - Core Module
// Essential functions and utilities

// Math functions
fn abs(x: int) -> int {
    check x < 0 {
        yield -x
    }
    yield x
}

fn min(a: int, b: int) -> int {
    check a < b {
        yield a
    }
    yield b
}

fn max(a: int, b: int) -> int {
    check a > b {
        yield a
    }
    yield b
}

fn pow(base: int, exp: int) -> int {
    let result = 1
    let i = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    yield result
}

// Advanced math functions (simplified - would use math library in real implementation)
fn sqrt(x: int) -> int {
    // Newton-Raphson method for square root
    check x < 0 {
        yield -1 // Error: negative input
    }
    check x == 0 {
        yield 0
    }
    
    let guess = x
    let prev = 0
    while guess != prev {
        prev = guess
        guess = (guess + x / guess) / 2
    }
    yield guess
}

fn log(x: int) -> int {
    // Natural logarithm (simplified)
    check x <= 0 {
        yield -1 // Error: non-positive input
    }
    
    // Taylor series approximation for ln(x)
    let result = 0
    let term = x - 1
    let i = 1
    while i < 10 {
        result = result + term / i
        term = term * (x - 1) * -1
        i = i + 1
    }
    yield result
}

fn exp(x: int) -> int {
    // Exponential function (simplified)
    let result = 1
    let term = 1
    let i = 1
    while i < 10 {
        term = term * x / i
        result = result + term
        i = i + 1
    }
    yield result
}

fn sin(x: int) -> int {
    // Sine function (simplified Taylor series)
    let result = 0
    let term = x
    let sign = 1
    let i = 1
    while i < 10 {
        result = result + sign * term
        term = term * x * x / ((2 * i) * (2 * i + 1))
        sign = sign * -1
        i = i + 1
    }
    yield result
}

fn cos(x: int) -> int {
    // Cosine function (simplified Taylor series)
    let result = 0
    let term = 1
    let sign = 1
    let i = 0
    while i < 10 {
        result = result + sign * term
        term = term * x * x / ((2 * i + 1) * (2 * i + 2))
        sign = sign * -1
        i = i + 1
    }
    yield result
}

fn tan(x: int) -> int {
    // Tangent function (simplified)
    let s = sin(x)
    let c = cos(x)
    check c == 0 {
        yield 0 // Error: division by zero
    }
    yield s / c
}

// Array utilities
fn sum_array(arr: int, size: int) -> int {
    let total = 0
    let i = 0
    while i < size {
        // FIX: Access array element at index i, not just i
        total = total + arr[i]
        i = i + 1
    }
    yield total
}

fn array_max(arr: int, size: int) -> int {
    let max_val = arr[0]
    let i = 1
    while i < size {
        // FIX: Compare array element at index i, not i itself
        check arr[i] > max_val {
            max_val = arr[i]
        }
        i = i + 1
    }
    yield max_val
}

// String utilities
fn strlen(s: int) -> int {
    // Count characters until null terminator
    let count = 0
    while s[count] != 0 {
        count = count + 1
    }
    yield count
}

fn strcmp(s1: int, s2: int) -> int {
    let i = 0
    while s1[i] != 0 && s2[i] != 0 {
        check s1[i] != s2[i] {
            yield s1[i] - s2[i]
        }
        i = i + 1
    }
    yield s1[i] - s2[i]
}

fn strcpy(dest: int, src: int) -> int {
    let i = 0
    while src[i] != 0 {
        dest[i] = src[i]
        i = i + 1
    }
    dest[i] = 0
    yield dest
}

fn strcat(dest: int, src: int) -> int {
    let dest_len = strlen(dest)
    let i = 0
    while src[i] != 0 {
        dest[dest_len + i] = src[i]
        i = i + 1
    }
    dest[dest_len + i] = 0
    yield dest
}

fn strncpy(dest: int, src: int, n: int) -> int {
    let i = 0
    while i < n && src[i] != 0 {
        dest[i] = src[i]
        i = i + 1
    }
    while i < n {
        dest[i] = 0
        i = i + 1
    }
    yield dest
}

// Algorithms
fn fibonacci(n: int) -> int {
    check n <= 1 {
        yield n
    }
    yield fibonacci(n - 1) + fibonacci(n - 2)
}

fn factorial(n: int) -> int {
    check n <= 1 {
        yield 1
    }
    yield n * factorial(n - 1)
}

fn gcd(a: int, b: int) -> int {
    while b != 0 {
        let temp = b
        b = a % b
        a = temp
    }
    yield a
}

fn is_prime(n: int) -> int {
    check n <= 1 {
        yield 0
    }
    check n <= 3 {
        yield 1
    }
    
    let i = 2
    while i * i <= n {
        check n % i == 0 {
            yield 0
        }
        i = i + 1
    }
    yield 1
}

// Sorting (bubble sort for simplicity)
fn bubble_sort(arr: int, size: int) {
    let i = 0
    while i < size {
        let j = 0
        while j < size - i - 1 {
            // FIX: Swap elements check arr[j] > arr[j+1]
            check arr[j] > arr[j + 1] {
                let temp = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
}

// Binary search
fn binary_search(arr: int, size: int, target: int) -> int {
    let left = 0
    let right = size - 1
    
    while left <= right {
        let mid = (left + right) / 2
        
        // FIX: Compare array element at mid with target
        check arr[mid] == target {
            yield mid
        }
        
        check arr[mid] < target {
            left = mid + 1
        }
        
        check arr[mid] > target {
            right = mid - 1
        }
    }
    
    yield -1
}
