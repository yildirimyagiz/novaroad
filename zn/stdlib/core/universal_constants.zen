    print("  E:                 " + E.to_string())
    print("  PHI (Golden Ratio):" + PHI.to_string())
    print("")
    print("TESLA'S SACRED:")
    print("  3-6-9 Frequency:   " + TESLA_369_FREQUENCY.to_string() + " Hz")
    print("")
    print("PHYSICAL:")
    print("  Planck:            " + PLANCK_CONSTANT.to_string())
    print("  Light Speed:       " + LIGHT_SPEED.to_string() + " m/s")
