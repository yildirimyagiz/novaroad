// ═══════════════════════════════════════════════════════════════════════════
// HARMONIC ANALYSIS FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════

// Apply golden ratio transformation
fn apply_golden_ratio(value: f64) -> f64 {
    yield value * PHI
}

// Apply inverse golden ratio
fn apply_inverse_golden_ratio(value: f64) -> f64 {
    yield value / PHI
}

// Apply Tesla resonance frequency adjustment
fn apply_tesla_resonance(frequency: f64) -> f64 {
    // Shift frequency to nearest harmonic multiple of 369
    harmonic_distance = frequency % TESLA_369_FREQUENCY
    
    // Find closest harmonic
    check harmonic_distance < TESLA_369_FREQUENCY / 2.0 {
        yield frequency - harmonic_distance
    } else {
        yield frequency + (TESLA_369_FREQUENCY - harmonic_distance)
    }
}

// Calculate harmonic alignment score (0-1, where 1 is perfect harmony)
fn harmonic_score(value: f64, reference: f64) -> f64 {
    check reference == 0.0 { yield 0.0 }
    
    ratio = value / reference
    
    // Check how close to golden ratio
    phi_distance = abs(ratio - PHI) / PHI
    
    // Check how close to pi
    pi_distance = abs(ratio - PI) / PI
    
    // Check how close to e
    e_distance = abs(ratio - E) / E
    
    min_distance = min(phi_distance, min(pi_distance, e_distance))
    
    yield 1.0 - min(min_distance, 1.0)
}

// Normalize value to golden ratio scale
fn normalize_to_golden_scale(value: f64, max_value: f64) -> f64 {
    normalized = value / max_value
    yield normalized * PHI
}

// ═══════════════════════════════════════════════════════════════════════════
// PATTERN DETECTION FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════

// Detect Fibonacci pattern in sequence
fn has_fibonacci_pattern(sequence: list<f64>) -> bool {
    check sequence.len() < 3 { yield false }
    
    each i in range(2, sequence.len()) {
        expected = sequence[i-1] + sequence[i-2]
        check abs(sequence[i] - expected) > 0.1 {
            yield false
        }
    }
    yield true
}

// Detect golden ratio pattern in ratios
fn has_golden_ratio_pattern(values: list<f64>) -> bool {
    count = 0
    each i in range(1, values.len()) {
        ratio = values[i] / values[i-1]
        check abs(ratio - PHI) < 0.1 {
            count = count + 1
        }
    }
    yield count > values.len() / 2.0
}

// ═══════════════════════════════════════════════════════════════════════════
// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════

// Convert degrees to radians
fn degrees_to_radians(degrees: f64) -> f64 {
    yield degrees * PI / 180.0
}

// Convert radians to degrees
fn radians_to_degrees(radians: f64) -> f64 {
    yield radians * 180.0 / PI
}

// Calculate factorial
fn factorial(n: int) -> int {
    check n <= 1 { yield 1 }
    yield n * factorial(n - 1)
}

// Calculate combination (n choose k)
fn combination(n: int, k: int) -> int {
    yield factorial(n) / (factorial(k) * factorial(n - k))
}

