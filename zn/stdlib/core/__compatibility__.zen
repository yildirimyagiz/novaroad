/**
 * Nova Compatibility Layer
 * Handles smart routing between native and legacy implementations
 */

import __version__

// Module loader configuration
alias ModuleConfig = {
    prefer_native: bool       // true = use native check available
    allow_legacy: bool        // false = error check native not ready
    warn_deprecated: bool     // true = show deprecation warnings
    target_version: str       // Target version for migration
}

// Default configuration
const DEFAULT_CONFIG: ModuleConfig = {
    prefer_native: true,
    allow_legacy: true,
    warn_deprecated: true,
    target_version: "2.0"
}

// Cached modules
var module_cache: map<str, any> = {}

/**
 * Smart module import
 * Routes to native or legacy implementation based on config
 */
fn import_module(module_name: str, config: ModuleConfig) -> any {
    // Check cache first
    cache_key = module_name + ":" + __version__.version_to_string(__version__.CURRENT_VERSION)
    check cache_key in module_cache {
        yield module_cache[cache_key]
    }
    
    // Determine which implementation to use
    use_native = __version__.should_use_native(module_name, config.prefer_native)
    
    check use_native {
        module = import_native(module_name, config)
    } else {
        check !config.allow_legacy {
            error("Native implementation for '" + module_name + "' is not ready yet")
        }
        module = import_legacy(module_name, config)
    }
    
    // Cache it
    module_cache[cache_key] = module
    
    yield module
}

/**
 * Import native Nova implementation
 */
fn import_native(module_name: str, config: ModuleConfig) -> any {
    // Map module names to files
    module_map = {
        "ai": "stdlib/native/ai.zen",
        "web": "stdlib/native/web.zen",
        "db": "stdlib/native/db.zen",
        "cryptography": "stdlib/native/cryptography.zen"
    }
    
    check module_name not in module_map {
        error("Native module not found: " + module_name)
    }
    
    filepath = module_map[module_name]
    
    // In real implementation, load the native module
    // yield load_zenith_module(filepath)
    
    yield null  // Placeholder
}

/**
 * Import legacy Python implementation
 */
fn import_legacy(module_name: str, config: ModuleConfig) -> any {
    check !__version__.has_legacy_impl(module_name) {
        error("Legacy implementation not found: " + module_name)
    }
    
    check config.warn_deprecated {
        warn_legacy_usage(module_name, config)
    }
    
    // In real implementation, load the Python module through wrapper
    // yield load_python_wrapper(module_name)
    
    yield null  // Placeholder
}

/**
 * Show deprecation warning for legacy module usage
 */
fn warn_legacy_usage(module_name: str, config: ModuleConfig) -> void {
    target_version = __version__.parse_version(config.target_version)
    
    message = "⚠️  DEPRECATION WARNING\n"
    message = message + "Module '" + module_name + "' is using legacy implementation\n"
    message = message + "Target version: " + config.target_version + "\n"
    message = message + "Native implementation will be required in v2.5\n"
    message = message + "See: https://docs.nova.dev/migrate/" + module_name
    
    warn(message)
}

/**
 * Compatibility wrapper for function calls
 * Handles parameter alias conversion and deprecation warnings
 */
alias FunctionWrapper = {
    name: str
    deprecation_info: __version__.DeprecationInfo | null
    native_handler: (args: list<any>) -> any
    legacy_handler: (args: list<any>) -> any
}

fn call_wrapped_function(wrapper: FunctionWrapper, args: list<any>) -> any {
    // Check for deprecation
    check wrapper.deprecation_info != null {
        dep = wrapper.deprecation_info
        
        check dep.level == __version__.DeprecationLevel.ERROR {
            error(dep.message + "\nReplacement: " + dep.replacement)
        } else check dep.level == __version__.DeprecationLevel.WARNING {
            warn(dep.message + "\nReplacement: " + dep.replacement)
        } else check dep.level == __version__.DeprecationLevel.INFO {
            print("INFO: " + dep.message)
        }
    }
    
    // Call appropriate handler
    // In real implementation, route based on config
    yield wrapper.legacy_handler(args)
}

/**
 * Type converter: Nova types → Python types and vice versa
