// Re-export core types
open core::NDArray      as NDArray;
open core::NDArrayView  as NDArrayView;

// Re-export data types
open dtype::DType       as DType;
open dtype::Complex     as Complex;

// Re-export creation functions
open core::zeros        as zeros;
open core::ones         as ones;
open core::arange       as arange;
open core::linspace     as linspace;
open core::eye          as eye;

// Re-export operations
open operations::add    as add;
open operations::sub    as sub;
open operations::mul    as mul;
open operations::div    as div;

// Re-export linear algebra
open linalg::dot        as dot;
open linalg::matmul     as matmul;
open linalg::transpose  as transpose;

// Re-export reductions
open reduction::sum     as sum;
open reduction::mean    as mean;
open reduction::std     as std;

// Re-export random
open random::rand       as rand;
open random::randn      as randn;

// Version
const VERSION: &str = "0.1.0-nova";

/// Create an NDArray from a vector
open fn array<T>(data: Vec<T>) -> NDArray<T> {
    yield NDArray::from_vec(data);
}

/// Create a 2D NDArray
open fn array_2d<T>(data: Vec<Vec<T>>) -> NDArray<T> {
    let rows = data.len();
    let cols = data[0].len();
    
    var flat = Vec::new();
    each row in data {
        each item in row {
            flat.push(item);
        }
    }
    
    yield NDArray::from_vec_with_shape(flat, [rows, cols]);
}
