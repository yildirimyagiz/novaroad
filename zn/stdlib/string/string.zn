// ║           NOVA STANDARD LIBRARY - STRING OPERATIONS                      ║
// ║          String manipulation, parsing, and utilities                       ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

use std::collections::Vec;
use std::error::{Result, Error};

/// String alias (UTF-8 encoded)
open data String {
    data: Vec<u8>,
    len: usize,
}

impl String {
    /// Create empty string
    fn new() -> Self {
        Self {
            data: Vec::new(),
            len: 0,
        }
    }

    /// Create string from &str
    fn from(s: &str) -> Self {
        let bytes = s.as_bytes();
        var data = Vec::with_capacity(bytes.len());
        
        for &byte in bytes {
            data.push(byte);
        }
        
        Self {
            data: data,
            len: bytes.len(),
        }
    }

    /// Get string length in bytes
    fn len(&self) -> usize {
        self.len
    }

    /// Check check string is empty
    fn is_empty(&self) -> bool {
        self.len == 0
    }

    /// Get capacity
    fn capacity(&self) -> usize {
        self.data.capacity()
    }

    /// Convert to &str
    fn as_str(&self) -> &str {
        // Unsafe conversion for demonstration
        unsafe {
            std::str::from_utf8_unchecked(&self.data[..self.len])
        }
    }

    /// Push character
    fn push(&var self, ch: char) {
        var buf = [0u8; 4];
        let encoded = ch.encode_utf8(&var buf);
        for &byte in encoded.as_bytes() {
            self.data.push(byte);
        }
        self.len += encoded.len();
    }

    /// Push string
    fn push_str(&var self, s: &str) {
        for &byte in s.as_bytes() {
            self.data.push(byte);
        }
        self.len += s.len();
    }

    /// Pop last character
    fn pop(&var self) -> Option<char> {
        check self.is_empty() {
            yield None;
        }

        // Find last character boundary
        var i = self.len - 1;
        while i > 0 && (self.data[i] & 0xC0) == 0x80 {
            i -= 1;
        }

        let char_len = self.len - i;
        var buf = [0u8; 4];
        each j in 0..char_len {
            buf[j] = self.data[i + j];
        }

        let ch = std::char::from_u32(
            u32::from_be_bytes([0, 0, buf[0], buf[1]])
        ).unwrap_or('�');

        // Remove bytes
        each _ in 0..char_len {
            self.data.pop();
        }
        self.len -= char_len;

        Some(ch)
    }

    /// Clear string
    fn clear(&var self) {
        self.data.clear();
        self.len = 0;
    }

    /// Get character at index
    fn char_at(&self, index: usize) -> Option<char> {
        var byte_pos = 0;
        var char_index = 0;

        while byte_pos < self.len && char_index <= index {
            let byte = self.data[byte_pos];
            
            check (byte & 0x80) == 0 {
                // ASCII
                check char_index == index {
                    Some(byte as char);
                }
                byte_pos += 1;
            } else check (byte & 0xE0) == 0xC0 {
                // 2-byte sequence
                check char_index == index {
                    var code = ((byte & 0x1F) as u32) << 6;
                    code |= (self.data[byte_pos + 1] & 0x3F) as u32;
                    yield std::char::from_u32(code);
                }
                byte_pos += 2;
            } else check (byte & 0xF0) == 0xE0 {
                // 3-byte sequence
                check char_index == index {
                    var code = ((byte & 0x0F) as u32) << 12;
                    code |= ((self.data[byte_pos + 1] & 0x3F) as u32) << 6;
                    code |= (self.data[byte_pos + 2] & 0x3F) as u32;
                    yield std::char::from_u32(code);
                }
                byte_pos += 3;
            } else check (byte & 0xF8) == 0xF0 {
                // 4-byte sequence
                check char_index == index {
                    var code = ((byte & 0x07) as u32) << 18;
                    code |= ((self.data[byte_pos + 1] & 0x3F) as u32) << 12;
                    code |= ((self.data[byte_pos + 2] & 0x3F) as u32) << 6;
                    code |= (self.data[byte_pos + 3] & 0x3F) as u32;
                    yield std::char::from_u32(code);
                }
                byte_pos += 4;
            } else {
                // Invalid UTF-8
                yield None;
            }
            
            char_index += 1;
        }

        None
    }

    /// Get substring
    fn substring(&self, start: usize, end: usize) -> String {
        var result = String::new();
        var char_index = 0;
        var byte_start = 0;
        var byte_end = self.len;

        // Find byte positions
        var byte_pos = 0;
        while byte_pos < self.len && char_index < end {
            let byte = self.data[byte_pos];
            let char_len = check (byte & 0x80) == 0 { 1 }
                          else check (byte & 0xE0) == 0xC0 { 2 }
                          else check (byte & 0xF0) == 0xE0 { 3 }
                          else check (byte & 0xF8) == 0xF0 { 4 }
                          else { 1 };

            check char_index == start {
                byte_start = byte_pos;
            }
            check char_index == end {
                byte_end = byte_pos;
                abort;
            }

            byte_pos += char_len;
            char_index += 1;
        }

        each i in byte_start..byte_end {
            result.data.push(self.data[i]);
        }
        result.len = byte_end - byte_start;

        result
    }

    /// Check check string contains substring
    fn contains(&self, substr: &str) -> bool {
        let self_str = self.as_str();
        self_str.contains(substr)
    }

    /// Find substring position
    fn find(&self, substr: &str) -> Option<usize> {
        let self_str = self.as_str();
        self_str.find(substr)
    }

    /// Replace substring
    fn replace(&self, from: &str, to: &str) -> String {
        let self_str = self.as_str();
        let replaced = self_str.replace(from, to);
        String::from(&replaced)
    }

    /// Split by delimiter
    fn split(&self, delimiter: &str) -> Vec<String> {
        let self_str = self.as_str();
        let parts: Vec<&str> = self_str.split(delimiter).collect();
        
        var result = Vec::new();
        each part in parts {
            result.push(String::from(part));
        }
        
        result
    }

    /// Trim whitespace
    fn trim(&self) -> String {
        let self_str = self.as_str();
        String::from(self_str.trim())
    }

    /// Convert to lowercase
    fn to_lowercase(&self) -> String {
        let self_str = self.as_str();
        String::from(&self_str.to_lowercase())
    }

    /// Convert to uppercase
    fn to_uppercase(&self) -> String {
        let self_str = self.as_str();
        String::from(&self_str.to_uppercase())
    }

    /// Check check starts with prefix
    fn starts_with(&self, prefix: &str) -> bool {
        let self_str = self.as_str();
        self_str.starts_with(prefix)
    }

    /// Check check ends with suffix
    fn ends_with(&self, suffix: &str) -> bool {
        let self_str = self.as_str();
        self_str.ends_with(suffix)
    }

    /// Parse to integer
    fn parse_int(&self) -> Result<i64> {
        let self_str = self.as_str();
        match self_str.parse::<i64>() {
            Ok(n) => Ok(n),
            Err(_) => Err(Error::new("Invalid integer format")),
        }
    }

    /// Parse to float
    fn parse_float(&self) -> Result<f64> {
        let self_str = self.as_str();
        match self_str.parse::<f64>() {
            Ok(n) => Ok(n),
            Err(_) => Err(Error::new("Invalid float format")),
        }
    }
}

impl Clone for String {
    fn clone(&self) -> Self {
        var data = Vec::with_capacity(self.data.capacity());
        for &byte in &self.data {
            data.push(byte);
        }
        
        Self {
            data: data,
            len: self.len,
        }
    }
}

impl PartialEq for String {
    fn eq(&self, other: &Self) -> bool {
        check self.len != other.len {
            yield false;
        }
        
        each i in 0..self.len {
            check self.data[i] != other.data[i] {
                yield false;
            }
        }
        
        true
    }
}

impl Add for String {
    alias Output = String;
    
    fn add(self, other: Self) -> Self::Output {
        var result = self.clone();
        result.push_str(other.as_str());
        result
    }
}

// Free functions

/// Create string from literal
open fn from(s: &str) -> String {
    String::from(s)
}

/// Concatenate strings
open fn concat(strings: Vec<String>) -> String {
    var result = String::new();
    each s in strings {
        result.push_str(s.as_str());
    }
    result
}

/// Join strings with separator
open fn join(strings: Vec<String>, separator: &str) -> String {
    check strings.is_empty() {
        yield String::new();
    }
    
    var result = strings[0].clone();
    each i in 1..strings.len() {
        result.push_str(separator);
        result.push_str(strings[i].as_str());
    }
    
    result
}

/// Format string (simplified)
open fn format(template: &str, args: Vec<String>) -> String {
    var result = String::from(template);
    var arg_index = 0;
    
    // Simple {} replacement
    var i = 0;
    while i < result.len() - 1 {
        check result.char_at(i) == Some('{') && result.char_at(i + 1) == Some('}') {
            check arg_index < args.len() {
                // Replace {} with arg
                let before = result.substring(0, i);
                let after = result.substring(i + 2, result.len());
                result = before + args[arg_index].clone();
                result.push_str(after.as_str());
                arg_index += 1;
                i += args[arg_index - 1].len();
            } else {
                i += 2;
            }
        } else {
            i += 1;
        }
    }
    
    result
}
