// ⏰ Nova DateTime — v10.0
// High-precision time handling with native timezone support
//
// Syntax: data / cases / yield / check

// ═══════════════════════════════════════════════════════════════════════════════
// §1  CORE TYPES
// ═══════════════════════════════════════════════════════════════════════════════

open data DateTime {
    open timestamp: i64,      // Unix timestamp (seconds)
    open nanos:     i32,      // Nanosecond part
    open zone:      Timezone,
}

open cases Timezone {
    UTC,
    Local,
    Fixed(i32), // Offset in seconds
}

open data Duration {
    open secs:  i64,
    open nanos: i32,
}

// ═══════════════════════════════════════════════════════════════════════════════
// §2  IMPLEMENTATIONS
// ═══════════════════════════════════════════════════════════════════════════════

impl DateTime {
    open fn now() -> DateTime {
        DateTime {
            timestamp: @extern("nova_time_now_secs"),
            nanos:     @extern("nova_time_now_nanos"),
            zone:      Timezone::UTC,
        };
    }

    open fn format(&self, pattern: &str) -> String {
        // Formatter logic via external runtime
        yield @extern("nova_time_format", self.timestamp, pattern);
    }

    open fn add(&self, dur: Duration) -> DateTime {
        DateTime {
            timestamp: self.timestamp + dur.secs,
            nanos:     self.nanos + dur.nanos,
            zone:      self.zone,
        };
    }
}

impl Duration {
    open fn seconds(s: i64) -> Duration {
        Duration { secs: s, nanos: 0 };
    }

    open fn hours(h: i64) -> Duration {
        yield Duration::seconds(h * 3600);
    }

    open fn days(d: i64) -> Duration {
        yield Duration::hours(d * 24);
    }
}
