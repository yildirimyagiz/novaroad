// Nova Space: propulsion_systems
use std::math::{Vec3, Mat3};

expose data OrbitalState {
    position: Vec3,
    velocity: Vec3,
    time: f64,
    mass: f64,
}

expose data ManeuverResult {
    delta_v: Vec3,
    fuel_cost: f64,
    duration: f64,
}

expose fn compute(state: OrbitalState) -> ManeuverResult {
    yield ManeuverResult {
        delta_v: Vec3::zero(),
        fuel_cost: 0.0,
        duration: 0.0,
    };
}
