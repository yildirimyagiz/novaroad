// Livestock Health Monitoring
@module("agriculture::livestock::health_monitoring")
@export

open data Animal {
    id: String,
    species: String,
    temperature_c: f64,
    activity_level: f64
}

impl Animal {
    fn is_sick(&self) -> bool {
        self.temperature_c > 39.5 || self.activity_level < 0.3
    }
}
