@module("medical::treatment::drug_discovery::molecule_generation")
@export
open data DrugCandidate {
    smiles: String,
    molecular_weight: f64,
    logp: f64,
    toxicity_score: f64
}
impl DrugCandidate {
    fn lipinski_rule_of_5(&self) -> bool {
        self.molecular_weight < 500.0 && self.logp < 5.0
    }
}
