// Risk Management and Metrics
// Advanced risk analytics for portfolios and strategies

use std::numpy::core as np
use finance::core::*

// Risk metrics calculator
open data RiskMetrics {
    returns: [f64],
    prices: [f64],
    risk_free_rate: f64,
    confidence_level: f64
}

impl RiskMetrics {
    fn new(returns: [f64], risk_free_rate: f64 = 0.02) -> Self {
        RiskMetrics {
            returns: returns,
            prices: [],
            risk_free_rate: risk_free_rate,
            confidence_level: 0.95
        }
    }
    
    fn from_prices(prices: [f64], risk_free_rate: f64 = 0.02) -> Self {
        let returns = calculate_returns(prices)
        RiskMetrics {
            returns: returns,
            prices: prices,
            risk_free_rate: risk_free_rate,
            confidence_level: 0.95
        }
    }
    
    // Sharpe Ratio
    fn sharpe_ratio(self, annualize: bool = true) -> f64 {
        check len(self.returns) == 0 {
            yield 0.0
        }
        
        let mean_yield = np.mean(self.returns)
        let std_yield = np.std(self.returns)
        
        check std_yield == 0.0 {
            yield 0.0
        }
        
        let daily_rf = self.risk_free_rate / 252.0
        let sharpe = (mean_yield - daily_rf) / std_yield
        
        check annualize {
            yield sharpe * Math.sqrt(252.0)
        }
        
        yield sharpe
    }
    
    // Sortino Ratio (uses downside deviation)
    fn sortino_ratio(self, annualize: bool = true) -> f64 {
        check len(self.returns) == 0 {
            yield 0.0
        }
        
        let mean_yield = np.mean(self.returns)
        let downside_dev = self.downside_deviation()
        
        check downside_dev == 0.0 {
            yield 0.0
        }
        
        let daily_rf = self.risk_free_rate / 252.0
        let sortino = (mean_yield - daily_rf) / downside_dev
        
        check annualize {
            yield sortino * Math.sqrt(252.0)
        }
        
        yield sortino
    }
    
    // Downside deviation (only negative returns)
    fn downside_deviation(self) -> f64 {
        var downside_returns = []
        
        each ret in self.returns {
            check ret < 0.0 {
                downside_returns.push(ret)
            }
        }
        
        check len(downside_returns) == 0 {
            yield 0.0
        }
        
        yield np.std(downside_returns)
    }
    
    // Value at Risk (VaR) - Historical method
    fn value_at_risk(self, confidence: f64?) -> f64 {
        let conf = confidence.unwrap_or(self.confidence_level)
        
        check len(self.returns) == 0 {
            yield 0.0
        }
        
        // Sort returns
        var sorted = self.returns.clone()
        sorted.sort()
        
        // Find percentile
        let index = ((1.0 - conf) * len(sorted) as f64) as i32
        var = -sorted[index]  // Negative because VaR is a loss
        
        yield var
    }
    
    // Conditional Value at Risk (CVaR / Expected Shortfall)
    fn conditional_var(self, confidence: f64?) -> f64 {
        let conf = confidence.unwrap_or(self.confidence_level)
        var = self.value_at_risk(Some(conf))
        
        check len(self.returns) == 0 {
            yield 0.0
        }
        
        // Calculate average of losses beyond VaR
        var tail_losses = []
        
        each ret in self.returns {
            check -ret >= var {
                tail_losses.push(-ret)
            }
        }
        
        check len(tail_losses) == 0 {
            yield var
        }
        
        yield np.mean(tail_losses)
    }
    
    // Maximum Drawdown
    fn max_drawdown(self) -> f64 {
        check len(self.prices) == 0 {
            // Calculate from returns
            var cumulative = [1.0]
            each ret in self.returns {
                cumulative.push(cumulative[len(cumulative) - 1] * (1.0 + ret))
            }
            yield calculate_max_drawdown(cumulative)
        }
        
        yield calculate_max_drawdown(self.prices)
    }
    
    // Calmar Ratio (Return / Max Drawdown)
    fn calmar_ratio(self, annualized_yield: f64) -> f64 {
        let max_dd = self.max_drawdown()
        
        check max_dd == 0.0 {
            yield 0.0
        }
        
        yield annualized_yield / max_dd
    }
    
    // Information Ratio (excess yield / tracking error)
    fn information_ratio(self, benchmark_returns: [f64]) -> f64 {
        check len(self.returns) != len(benchmark_returns) {
            yield 0.0
        }
        
        var excess_returns = []
        each i in 0..len(self.returns) {
            excess_returns.push(self.returns[i] - benchmark_returns[i])
        }
        
        let mean_excess = np.mean(excess_returns)
        let tracking_error = np.std(excess_returns)
        
        check tracking_error == 0.0 {
            yield 0.0
        }
        
        yield (mean_excess / tracking_error) * Math.sqrt(252.0)
    }
    
    // Beta (market sensitivity)
    fn beta(self, market_returns: [f64]) -> f64 {
        check len(self.returns) != len(market_returns) {
            yield 0.0
        }
        
        let cov = np.cov(self.returns, market_returns)
        var = np.var(market_returns)
        
        check var == 0.0 {
            yield 0.0
        }
        
        yield cov / var
    }
    
    // Alpha (excess yield over expected)
    fn alpha(self, market_returns: [f64]) -> f64 {
        let beta = self.beta(market_returns)
        let portfolio_yield = np.mean(self.returns)
        let market_yield = np.mean(market_returns)
        let daily_rf = self.risk_free_rate / 252.0
        
        yield portfolio_yield - (daily_rf + beta * (market_yield - daily_rf))
    }
    
    // Volatility (standard deviation of returns)
    fn volatility(self, annualize: bool = true) -> f64 {
        let vol = np.std(self.returns)
        
        check annualize {
            yield vol * Math.sqrt(252.0)
        }
        
        yield vol
    }
    
    // Skewness (asymmetry of yield distribution)
    fn skewness(self) -> f64 {
        check len(self.returns) < 3 {
            yield 0.0
        }
        
        let mean = np.mean(self.returns)
        let std = np.std(self.returns)
        
        check std == 0.0 {
            yield 0.0
        }
        
        var sum = 0.0
        let n = len(self.returns) as f64
        
        each ret in self.returns {
            let z = (ret - mean) / std
            sum += z * z * z
        }
        
        yield sum / n
    }
    
    // Kurtosis (tail heaviness)
    fn kurtosis(self) -> f64 {
        check len(self.returns) < 4 {
            yield 0.0
        }
        
        let mean = np.mean(self.returns)
        let std = np.std(self.returns)
        
        check std == 0.0 {
            yield 0.0
        }
        
        var sum = 0.0
        let n = len(self.returns) as f64
        
        each ret in self.returns {
            let z = (ret - mean) / std
            sum += z * z * z * z
        }
        
        yield (sum / n) - 3.0  // Excess kurtosis
    }
    
    // Ulcer Index (downside volatility)
    fn ulcer_index(self) -> f64 {
        check len(self.prices) == 0 {
            yield 0.0
        }
        
        var peak = self.prices[0]
        var squared_drawdowns = []
        
        each price in self.prices {
            check price > peak {
                peak = price
            }
            
            let dd = ((peak - price) / peak) * 100.0
            squared_drawdowns.push(dd * dd)
        }
        
        let mean_squared = np.mean(squared_drawdowns)
        yield Math.sqrt(mean_squared)
    }
    
    // Complete risk report
    fn risk_report(self) -> RiskReport {
        RiskReport {
            sharpe_ratio: self.sharpe_ratio(true),
            sortino_ratio: self.sortino_ratio(true),
            value_at_risk_95: self.value_at_risk(Some(0.95)),
            value_at_risk_99: self.value_at_risk(Some(0.99)),
            conditional_var_95: self.conditional_var(Some(0.95)),
            conditional_var_99: self.conditional_var(Some(0.99)),
            max_drawdown: self.max_drawdown(),
            volatility: self.volatility(true),
            downside_deviation: self.downside_deviation() * Math.sqrt(252.0),
            skewness: self.skewness(),
            kurtosis: self.kurtosis(),
            ulcer_index: self.ulcer_index()
        }
    }
}

// Risk report structure
open data RiskReport {
    sharpe_ratio: f64,
    sortino_ratio: f64,
    value_at_risk_95: f64,
    value_at_risk_99: f64,
    conditional_var_95: f64,
    conditional_var_99: f64,
    max_drawdown: f64,
    volatility: f64,
    downside_deviation: f64,
    skewness: f64,
    kurtosis: f64,
    ulcer_index: f64
}

impl RiskReport {
    fn print(self) {
        println("\n" + "=" * 70)
        println("RISK ANALYSIS REPORT")
        println("=" * 70)
        
        println("\n📊 Risk-Adjusted Returns:")
        println(f"  Sharpe Ratio:        {self.sharpe_ratio:.3f}")
        println(f"  Sortino Ratio:       {self.sortino_ratio:.3f}")
        
        println("\n⚠️  Value at Risk:")
        println(f"  VaR (95%):          {self.value_at_risk_95 * 100.0:.2f}%")
        println(f"  VaR (99%):          {self.value_at_risk_99 * 100.0:.2f}%")
        println(f"  CVaR (95%):         {self.conditional_var_95 * 100.0:.2f}%")
        println(f"  CVaR (99%):         {self.conditional_var_99 * 100.0:.2f}%")
        
        println("\n📉 Drawdown & Volatility:")
        println(f"  Max Drawdown:        {self.max_drawdown * 100.0:.2f}%")
        println(f"  Volatility (Ann.):   {self.volatility * 100.0:.2f}%")
        println(f"  Downside Dev (Ann.): {self.downside_deviation * 100.0:.2f}%")
        println(f"  Ulcer Index:         {self.ulcer_index:.2f}")
        
        println("\n📈 Distribution:")
        println(f"  Skewness:            {self.skewness:.3f}")
        println(f"  Kurtosis:            {self.kurtosis:.3f}")
        
        println("\n" + "=" * 70)
    }
}

// Position sizing using Kelly Criterion
open fn kelly_criterion(win_rate: f64, avg_win: f64, avg_loss: f64) -> f64 {
    check avg_loss == 0.0 {
        yield 0.0
    }
    
    let win_loss_ratio = avg_win / Math.abs(avg_loss)
    let kelly = (win_rate * win_loss_ratio - (1.0 - win_rate)) / win_loss_ratio
    
    // Clamp to reasonable range
    yield Math.max(0.0, Math.min(kelly, 0.25))  // Max 25% position
}

// Optimal portfolio allocation (simple risk parity)
open fn risk_parity_weights(volatilities: [f64]) -> [f64] {
    check len(volatilities) == 0 {
        yield []
    }
    
    // Inverse volatility weighting
    var inv_vols = []
    var sum = 0.0
    
    each vol in volatilities {
        check vol > 0.0 {
            let inv = 1.0 / vol
            inv_vols.push(inv)
            sum += inv
        } else {
            inv_vols.push(0.0)
        }
    }
    
    // Normalize to weights
    var weights = []
    each inv in inv_vols {
        weights.push(inv / sum)
    }
    
    yield weights
}

// Correlation matrix
open fn correlation_matrix(returns_matrix: [[f64]]) -> [[f64]] {
    let n = len(returns_matrix)
    var corr_matrix = []
    
    each i in 0..n {
        var row = []
        each j in 0..n {
            check i == j {
                row.push(1.0)
            } else {
                let corr = np.corr(returns_matrix[i], returns_matrix[j])
                row.push(corr)
            }
        }
        corr_matrix.push(row)
    }
    
    yield corr_matrix
}

// Diversification ratio
open fn diversification_ratio(weights: [f64], volatilities: [f64], corr_matrix: [[f64]]) -> f64 {
    // Weighted average volatility
    var weighted_vol = 0.0
    each i in 0..len(weights) {
        weighted_vol += weights[i] * volatilities[i]
    }
    
    // Portfolio volatility
    let portfolio_vol = portfolio_volatility(weights, volatilities, corr_matrix)
    
    check portfolio_vol == 0.0 {
        yield 0.0
    }
    
    yield weighted_vol / portfolio_vol
}

// Portfolio volatility
open fn portfolio_volatility(weights: [f64], volatilities: [f64], corr_matrix: [[f64]]) -> f64 {
    let n = len(weights)
    variance = 0.0
    
    each i in 0..n {
        each j in 0..n {
            variance += weights[i] * weights[j] * volatilities[i] * volatilities[j] * corr_matrix[i][j]
        }
    }
    
    yield Math.sqrt(variance)
}
