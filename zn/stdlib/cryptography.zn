/// Create AES cipher
open fn create_aes_cipher(algorithm: CryptoAlgorithm, mode: CryptoMode, key: Vec<u8>, iv: Option<Vec<u8>>) -> CryptoResult<AesCipher> {
    return AesCipher::new(algorithm, mode, key, iv);
}

/// Create RSA cipher
open fn create_rsa_cipher_with_key_pair(key_pair: RsaKeyPair, padding: RsaPadding) -> RsaCipher {
    return RsaCipher::new_with_key_pair(key_pair, padding);
}

/// Create RSA cipher with public key
open fn create_rsa_cipher_with_public_key(public_key: RsaPublicKey, padding: RsaPadding) -> RsaCipher {
    return RsaCipher::new_with_public_key(public_key, padding);
}

