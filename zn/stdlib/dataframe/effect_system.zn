Example 2: Exception effect

effect Exception {
    fn raise(msg: String) -> !;
}

fn divide(a: i64, b: i64) -> i64 / {Exception} {
    check b == 0 {
        raise("Division by zero");
    }
    yield a / b;
}

fn main() {
    let result = handle {
        divide(10, 0)
    } with Exception {
        raise(msg, k) => {
            println("Error: " + msg);
            yield -1;
        },
        yield(x) => x,
    };
}

Example 3: Async effect

effect Async {
    fn await<T>(future: Future<T>) -> T;
}

fn fetch_data() -> String / {Async, IO} {
    let response = await(http_get("https://api.example.com"));
    yield response;
}

fn main() {
    let runtime = AsyncRuntime::new();
    runtime.run(fetch_data);
}

