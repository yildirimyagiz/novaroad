// ║  Nova DataFrame Examples                                                 ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

use dataframe::{DataFrame, Series, read_csv, merge, JoinType};
use std::collections::HashMap;
use dtype::{Nullable, NullValue, DType};
use core::RangeIndex;

/// Example 1: Basic DataFrame creation and operations
fn example_basic() {
    println("=== Example 1: Basic DataFrame ===");
    
    let prices = Series::new([100.0, 150.0, 120.0, 180.0, 200.0])
        .with_name("price".into());
    
    println("Price statistics:");
    println("  Mean: {}", prices.mean());
    println("  Sum: {}", prices.sum());
    println("  Min: {:?}", prices.min());
    println("  Max: {:?}", prices.max());
    println("  Std: {}", prices.std());
    
    var data: HashMap<String, Vec<String>> = HashMap::new();
    data.insert("product".into(), ["Apple".into(), "Banana".into(), "Orange".into(), "Grape".into(), "Mango".into()]);
    data.insert("price".into(), ["100.0".into(), "150.0".into(), "120.0".into(), "180.0".into(), "200.0".into()]);
    data.insert("quantity".into(), ["50".into(), "30".into(), "40".into(), "25".into(), "35".into()]);
    
    let df = DataFrame::from_columns(data);
    df.info();
}

/// Example 2: Reading and writing CSV
fn example_csv_io() {
    println("\n=== Example 2: CSV I/O ===");
    
    match read_csv("data/sales.csv") {
        Ok(df) => {
            println("Loaded DataFrame with data: {:?}", df.data());
            df.info();
            df.to_csv("data/sales_copy.csv").unwrap();
        }
        Err(e) => println("Error reading CSV: {}", e),
    }
}

/// Example 3: GroupBy operations
fn example_groupby() {
    println("\n=== Example 3: GroupBy ===");
    
    var data: HashMap<String, Vec<String>> = HashMap::new();
    data.insert("region".into(), ["North".into(), "South".into(), "North".into(), "South".into(), "North".into()]);
    data.insert("product".into(), ["A".into(), "B".into(), "A".into(), "B".into(), "B".into()]);
    data.insert("sales".into(), ["100.0".into(), "150.0".into(), "120.0".into(), "180.0".into(), "200.0".into()]);
    
    let df = DataFrame::from_columns(data);
    
    let grouped = df.groupby(["region".into()]);
    let result = grouped.sum();
    
    println("Sales by region:");
    result.info();
}

/// Example 4: Merge/Join operations
fn example_merge() {
    println("\n=== Example 4: Merge/Join ===");
    
    var customers: HashMap<String, Vec<String>> = HashMap::new();
    customers.insert("customer_id".into(), ["1".into(), "2".into(), "3".into(), "4".into()]);
    customers.insert("name".into(), ["Alice".into(), "Bob".into(), "Charlie".into(), "Diana".into()]);
    let df_customers = DataFrame::from_columns(customers);
    
    var orders: HashMap<String, Vec<String>> = HashMap::new();
    orders.insert("order_id".into(), ["101".into(), "102".into(), "103".into()]);
    orders.insert("customer_id".into(), ["1".into(), "2".into(), "1".into()]);
    orders.insert("amount".into(), ["250.0".into(), "150.0".into(), "300.0".into()]);
    let df_orders = DataFrame::from_columns(orders);
    
    let joined = merge(
        &df_customers,
        &df_orders,
        ["customer_id".into()],
        JoinType::Inner
    );
    
    println("Joined data:");
    joined.info();
}

/// Example 5: Data filtering and selection
fn example_filtering() {
    println("\n=== Example 5: Filtering ===");
    
    let prices = Series::new([100.0, 150.0, 120.0, 180.0, 200.0])
        .with_name("price".into());
    
    let mask = [false, true, false, true, true];
    let filtered = prices.filter(&mask);
    
    println("Filtered prices (> 130):");
    println("  Count: {}", filtered.count());
    println("  Mean: {}", filtered.mean());
}

/// Example 6: Missing data handling
fn example_missing_data() {
    println("\n=== Example 6: Missing Data ===");
    
    let data = [
        Nullable::Value(100.0),
        Nullable::Null(NullValue::NA),
        Nullable::Value(120.0),
        Nullable::Null(NullValue::NA),
        Nullable::Value(200.0),
    ];
    
    let series = Series {
        data,
        index: Box::new(RangeIndex::new(5)),
        name: Some("values".into()),
        dtype: DType::Float64,
    };
    
    println("Original series:");
    println("  Length: {}", series.len());
    println("  Non-null count: {}", series.count());
    println("  Has nulls: {}", series.has_nulls());
    
    let clean = series.dropna();
    println("\nAfter dropna:");
    println("  Length: {}", clean.len());
    println("  Mean: {}", clean.mean());
}

/// Run all examples
open fn run_all_examples() {
    example_basic();
    example_csv_io();
    example_groupby();
    example_merge();
    example_filtering();
    example_missing_data();
    
    println("\n✅ All examples completed!");
}
