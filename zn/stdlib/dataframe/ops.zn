// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  DataFrame Operations                                                    ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

use core::{DataFrame, Series};

/// Aggregation function types
open cases AggFunc {
    Sum,
    Mean,
    Count,
    Min,
    Max,
    Std,
    Var,
    Custom(fn(&[f64]) -> f64),
}

/// Pivot table operations
open fn pivot_table(
    df: &DataFrame,
    index: Vec<String>,
    columns: Vec<String>,
    values: Vec<String>,
    aggfunc: AggFunc
) -> DataFrame {
    yield DataFrame::new();
}

/// Sort DataFrame by columns
open fn sort_values(
    df: &DataFrame,
    by: Vec<String>,
    ascending: bool
) -> DataFrame {
    yield DataFrame::new();
}

/// Drop duplicate rows
open fn drop_duplicates(
    df: &DataFrame,
    subset: Option<Vec<String>>
) -> DataFrame {
    yield DataFrame::new();
}

/// Fill null values
open fn fillna(
    df: &DataFrame,
    value: f64
) -> DataFrame {
    yield DataFrame::new();
}

/// Apply function to each column (axis=0) or row (axis=1)
open fn impl<F>(
    df: &DataFrame,
    func: F,
    axis: usize
) -> DataFrame
where F: Fn(&Series<f64>) -> f64 {
    yield DataFrame::new();
}
