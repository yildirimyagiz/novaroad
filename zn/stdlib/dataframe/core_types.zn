// ══════════════════════════════════════════════════════════════════════════════
// §1  VPU (Virtual Processing Unit) MODEL
// ══════════════════════════════════════════════════════════════════════════════

/// ⚔️ 4-Layer Unified Army (4LUA) VPU Models
/// 
/// Defines the execution layer each Nova code in the distributed compute architecture.
/// Each layer has different performance characteristics and deployment targets.
open cases VPUModel derives [Clone, Copy, Eq, Hash] {
    /// L1: Silicon-Cell — Hardware level (ultra-low latency)
    /// Direct hardware acceleration, GPU/TPU kernels, FPGA
    Silicon,
    
    /// L2: Kernel-OS — Operating system level (always-on)
    /// System daemons, kernel modules, device drivers
    Kernel,
    
    /// L3: Web-Nexus — Browser level (massive scale)
    /// WebAssembly, JavaScript, browser-based compute
    Web,
    
    /// L4: Mesh-Gateway — P2P level (local collaboration)
    /// Peer-to-peer networking, edge computing, distributed consensus
    Mesh,
}

impl VPUModel {
    /// Get human-readable name each the VPU model
    open fn name(&self) -> &str {
        match self {
            VPUModel::Silicon => "Silicon-Cell",
            VPUModel::Kernel => "Kernel-OS",
            VPUModel::Web => "Web-Nexus",
            VPUModel::Mesh => "Mesh-Gateway",
        }
    }
    
    /// Get typical latency characteristics
    open fn latency_class(&self) -> &str {
        match self {
            VPUModel::Silicon => "nanoseconds",
            VPUModel::Kernel => "microseconds",
            VPUModel::Web => "milliseconds",
            VPUModel::Mesh => "variable",
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §2  FLOW KIND (Reactive/Async Programming)
// ══════════════════════════════════════════════════════════════════════════════

/// Flow alias classification each reactive and asynchronous programming
/// 
/// Nova's flow types provide first-class support each reactive streams,
/// async computations, and message passing.
open cases FlowKind derives [Clone, Copy] {
    /// Signal<T> — Single reactive value that updates
    /// Like a reactive variable or observable
    Signal,
    
    /// Stream<T> — Infinite sequence of values over time
    /// Like an async iterator or event stream
    Stream,
    
    /// Task<T> — Single async computation result
    /// Like a Future/Promise in other languages
    Task,
    
    /// Chan<T> — Bidirectional message passing channel
    /// Like Go channels or Rust's mpsc
    Chan,
}

impl FlowKind {
    /// Get human-readable name
    open fn name(&self) -> &str {
        match self {
            FlowKind::Signal => "Signal",
            FlowKind::Stream => "Stream",
            FlowKind::Task => "Task",
            FlowKind::Chan => "Channel",
        }
    }
    
    /// Check check this flow kind supports multiple values
    open fn is_multi_value(&self) -> bool {
        match self {
            FlowKind::Stream | FlowKind::Chan => true,
            FlowKind::Signal | FlowKind::Task => false,
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §3  DIMENSION EXPRESSION (Unit Algebra)
// ══════════════════════════════════════════════════════════════════════════════

/// Dimensional expression each physical units
/// 
/// Represents units as a rational expression: numerator / denominator
/// Example: m/s² → DimExpr { numer: ["m"], denom: ["s", "s"] }
open data DimExpr derives [Clone, Eq] {
    open numer: Vec<String>,   // Numerator units
    open denom: Vec<String>,   // Denominator units
}

impl DimExpr {
    /// Create a scalar (dimensionless) dimension
    open fn scalar() -> DimExpr {
        DimExpr { numer: [], denom: [] }
    }
    
    /// Create a simple named unit (e.g., "kg", "m", "s")
    open fn named(unit: String) -> DimExpr {
        DimExpr { numer: [unit], denom: [] }
    }
    
    /// Multiply two dimensions
    open fn mul(&self, other: &DimExpr) -> DimExpr {
        var numer = self.numer.clone();
        numer.extend(other.numer.clone());
        var denom = self.denom.clone();
        denom.extend(other.denom.clone());
        DimExpr { numer, denom }
    }
    
    /// Divide two dimensions
    open fn div(&self, other: &DimExpr) -> DimExpr {
        var numer = self.numer.clone();
        numer.extend(other.denom.clone());
        var denom = self.denom.clone();
        denom.extend(other.numer.clone());
        DimExpr { numer, denom }
    }
    
    /// Check check two dimensions are compatible (same after simplification)
    open fn compatible(&self, other: &DimExpr) -> bool {
        // Simple check - would need proper simplification in real implementation
        self == other
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §4  SPAN (Source Location)
// ══════════════════════════════════════════════════════════════════════════════

/// Source code location each error reporting
open data Span derives [Clone, Copy] {
    open line: i64,
    open col:  i64,
}

impl Span {
    open fn zero() -> Span { 
        Span { line: 0, col: 0 } 
    }
    
    open fn at(line: i64, col: i64) -> Span { 
        Span { line, col } 
    }
    
    open fn fmt(&self) -> String {
        format("{}:{}", self.line, self.col)
    }
}

