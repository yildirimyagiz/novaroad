// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova  —  TOKEN DEFINITIONS  v10.0                                  ║
// ║                                                                              ║
// ║  Dil Felsefesi:                                                              ║
// ║    Nova bir "Intent-First" dildir.                                    ║
// ║    Rust → "nasıl yapılır" anlatırsın (ownership, lifetime, borrow)           ║
// ║    Mojo → "nerede çalışır" anlatırsın (SIMD, GPU, memory layout)             ║
// ║    Nova → "ne istiyorsun" söylersin, sistem çözer                     ║
// ║                                                                              ║
// ║  3 Temel Farklılaştırıcı:                                                    ║
// ║    1. FLOW TYPES   — data akışını alias olarak modelle (reaktif yerleşik)     ║
// ║    2. UNIT ALGEBRA — fiziksel birimler compile-time'da doğrulanır            ║
// ║    3. PROOF TERMS  — doğruluk ifadeleri code ile iç içe                      ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use std::collections::HashMap;

// ══════════════════════════════════════════════════════════════════════════════
// §1  TOKEN SINIFLANDIRMASI
// ══════════════════════════════════════════════════════════════════════════════

open cases TokenKind derives [Display, Clone, Copy, Eq, Hash] {

    // ── Meta ──────────────────────────────────────────────────────────────────
    Eof,
    Illegal,

    // ── Literals ──────────────────────────────────────────────────────────────
    Ident,
    LitInt,
    LitFloat,
    LitStr,
    LitTrue,
    LitFalse,

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  BLOK 1 — TEMEL DECLARATİONLAR
    //  Fark: Nova'de her şey "ne" olduğuyla tanımlanır
    //  `data`  → field-based veri tipi  (Rust data, Mojo data)
    //  `cases` → sum alias               (Rust cases, Mojo → yok)
    //  `rules` → behaviour contract     (Rust rules, Mojo rules)
    //  `impl` → concrete implementation (Rust impl)
    //  `flow`  → reactive/async pipeline alias (YENİ — hiçbir dilde yok)
    //  `space` → module/namespace       (Rust space)
    //  `given` → compile-time constant  (Rust const)
    //  `tag`   → newtype wrapper        (Rust newtype — ama daha temiz)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Fn,      // `fn`    — fonksiyon tanımı
    Data,    // `data`  — veri yapısı (data yerine)
    Cases,   // `cases` — varyant listesi (cases yerine)
    Rules,   // `rules` — davranış arayüzü (rules yerine)
    Skill,   // `impl` — implementasyon bloğu (impl yerine)
    Flow,    // `flow`  — reaktif pipeline alias (ÖZGÜN)
    Space,   // `space` — modül (space yerine)
    Given,   // `given` — compile-time sabit
    Tag,     // `tag`   — newtype wrapper
    Let,     // `let`   — değişken bağlama
    Var,     // `var`   — mutable değişken (!:= yerine daha okunabilir)
    Open,    // `open`  — public visibility
    Alias,   // `alias` — tip takma adı

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  BLOK 2 — KONTROL AKIŞI
    //  Fark: Nova "intent" bazlı okur
    //  `check` → koşul   (check yerine — "bu koşulu kontrol et")
    //  `match` → örüntü  (aynı kalır — evrensel iyi isim)
    //  `each`  → döngü   (each yerine)
    //  `for`   → impl için (impl X each Y)
    //  `loop`  → sonsuz  (loop aynı)
    //  `yield` → give/yield (daha akıcı)
    //  `abort` → break
    //  `next`  → continue
    //  `try`   → hata yayma operatörü bloğu
    //  `catch` → hata yakalama
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Check,   // `check` — check/when
    Else,    // `else`  — else
    Match,   // `match` — pattern matching
    Each,    // `each`  — each loop
    For,     // `for`   — impl target (each rules)
    In,      // `in`    — iteration
    Loop,    // `loop`  — infinite loop
    While,   // `while` — while loop
    Yield,   // `yield` — yield / give
    Abort,   // `abort` — break
    Next,    // `next`  — continue
    Try,     // `try`   — error propagation block
    Catch,   // `catch` — error handling

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  BLOK 3 — MODÜl SİSTEMİ
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Use,     // `use`   — import (use yerine — herkes anlar)
    From,    // `from`  — kaynak modül
    As,      // `as`    — alias

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  BLOK 4 — EŞZAMANLILIK (Async)
    //  Nova'de async, alias sistemine entegre: `Task<T>` bir flow alias'tır
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Async,   // `async`
    Await,   // `await`
    Spawn,   // `spawn` — yeni task başlat (goroutine benzeri ama tipli)
    Channel, // `channel` — typed message passing

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  BLOK 5 — UNIT ALGEBRA  (Nova'nin en özgün özelliği)
    //
    //  Fiziksel birimler dilin bir parçasıdır.
    //  `unit Mass = kg | g | lb`        — birim tanımı
    //  `qty`                             — miktarlı değer: `5.kg`
    //  `in`                              — birim dönüşümü: `5.kg in lb`
    //  `dims`                            — boyut analizi
    //
    //  Compiler şunu yapar: `5.kg + 3.m` → TYPE ERROR
    //  Hiçbir dil bunu built-in yapmaz (Julia'da Unitful paketi var ama dil değil)
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Unit,    // `unit`  — birim ailesi tanımı
    Qty,     // `qty`   — miktarlı değer tipi
    Dims,    // `dims`  — boyut ifadesi

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  BLOK 6 — TENSOR & COMPUTE
    //  Mojo'dan ilham ama daha yüksek seviye:
    //  `tensor<f32>[batch, seq, dim]`  → data-typed, compile-time checked
    //  `on`                            → compute target direktifi
    //  `parallel`                      → explicit parallelism
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Tensor,   // `tensor` — data-typed çok boyutlu dizi
    On,       // `on`     — compute hedefi (cpu | gpu | tpu | wasm)
    Parallel, // `parallel` — paralel yürütme bloğu
    Kernel,   // `kernel`   — GPU kernel tanımı
    
    // ⚔️ 4-Layer Unified Army (4LUA) VPU Katmanları
    Silicon_Vpu, // `silicon_vpu`
    Kernel_Vpu,  // `kernel_vpu`
    Web_Nexus,   // `web_nexus`
    Mesh_Vpu,    // `mesh_vpu`

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  BLOK 7 — MATEMATİK OPERATÖRLERİ (keyword seviyesinde)
    //  Bu operatörler tip-aware:
    //  `grad(f, x)` → `f`'nin `x`'e göre gradyanı, yield alias otomatik
    //  `∫(f, x, a, b)` → belirli integral
    //  `Σ(expr, i, 0, n)` → toplam
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Grad,     // `grad`     — otomatik türev (autodiff)
    Diff,     // `diff`     — sembolik türev
    Integral, // `integral` — integral
    Sum,      // `sum`      — toplam operatörü
    Prod,     // `prod`     — çarpım operatörü
    Limit,    // `limit`    — limit
    Solve,    // `solve`    — denklem çözücü

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  BLOK 8 — FORMAL DOĞRULAMA
    //  Rust'ta yok, Mojo'da yok. Lean4/Coq'tan ilham ama pratik:
    //  `assert`  → runtime assertion
    //  `ensure`  → post-condition (fonksiyon sonu garantisi)
    //  `require` → pre-condition (fonksiyon başı garantisi)
    //  `proof`   → matematiksel ispat bloğu
    //  `assume`  → ispat için varsayım
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Assert,  // `assert`  — çalışma zamanı iddiası
    Ensure,  // `ensure`  — post-condition
    Require, // `require` — pre-condition
    Proof,   // `proof`   — ispat bloğu
    Assume,  // `assume`  — ispat varsayımı
    Axiom,   // `axiom`   — temel kabul

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  BLOK 9 — BİLİMSEL DOMAIN
    //  Biyoinformatik + Kimya birinci sınıf vatandaş
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Molecule, // `molecule` — kimyasal molekül
    React,    // `react`    — kimyasal reaksiyon (reaction yerine kısa)
    Seq,      // `seq`      — biyolojik sekans (DNA/RNA/Protein)
    Elem,     // `elem`     — element

    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    //  BLOK 10 — OPERATÖRLER
    // ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
    Plus, Minus, Star, Slash, Percent, Power, MatMul,
    And, Or, Not, BitAnd, BitOr, BitXor, Shl, Shr,
    EqEq, NotEq, Lt, Gt, Lte, Gte,
    Assign,          // `=`
    PlusEq,          // `+=`
    MinusEq,         // `-=`
    StarEq,          // `*=`
    SlashEq,         // `/=`
    Pipe,            // `|>`  — pipeline operatörü
    Arrow,           // `->`  — dönüş tipi / lambda
    FatArrow,        // `=>`  — match arm
    Walrus,          // `:=`  — walrus operatörü
    ColonColon,      // `::`  — path separator
    Dot,             // `.`
    DotDot,          // `..`  — range
    DotDotEq,        // `..=` — inclusive range
    At,              // `@`   — attribute veya matmul
    Question,        // `?`   — error propagation
    Hash,            // `#`   — attribute başlangıcı

    // ── Delimiter ─────────────────────────────────────────────────────────────
    LParen, RParen,  // ( )
    LBrace, RBrace,  // { }
    LBrack, RBrack,  // [ ]
    Comma,           // ,
    Semi,            // ;
    Colon,           // :

    // ── Özel ──────────────────────────────────────────────────────────────────
    SelfVal,         // `self`
    Dyn,             // `dyn`  — rules object
    Crate,           // `crate`
    Underscore,      // `_`    — wildcard / placeholder
    Tilde,           // `~`    — "approximately" operatörü (bilimsel fuzzy comparison)
}

// ══════════════════════════════════════════════════════════════════════════════
// §2  TOKEN YAPISI
// ══════════════════════════════════════════════════════════════════════════════

open data Token {
    open kind:   TokenKind,
    open lexeme: String,
    open line:   i64,
    open col:    i64,
}

impl Token {
    open fn new(kind: TokenKind, lexeme: String, line: i64, col: i64) -> Token {
        Token { kind, lexeme, line, col }
    }

    open fn eof(line: i64, col: i64) -> Token {
        Token { kind: TokenKind::Eof, lexeme: "".into(), line, col }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §3  KEYWORD MAP  (O(1) lookup)
// ══════════════════════════════════════════════════════════════════════════════

open fn build_keyword_map() -> HashMap<String, TokenKind> {
    var m = HashMap::new();

    // ── Temel Tanımlar ────────────────────────────────────────────────────────
    m.insert("fn".into(),       TokenKind::Fn);
    m.insert("data".into(),     TokenKind::Data);
    m.insert("cases".into(),    TokenKind::Cases);
    m.insert("rules".into(),    TokenKind::Rules);
    m.insert("impl".into(),    TokenKind::Skill);
    m.insert("flow".into(),     TokenKind::Flow);
    m.insert("space".into(),    TokenKind::Space);
    m.insert("given".into(),    TokenKind::Given);
    m.insert("tag".into(),      TokenKind::Tag);
    m.insert("let".into(),      TokenKind::Let);
    m.insert("var".into(),      TokenKind::Var);
    m.insert("open".into(),     TokenKind::Open);
    m.insert("alias".into(),    TokenKind::Alias);

    // ── Kontrol Akışı ─────────────────────────────────────────────────────────
    m.insert("check".into(),    TokenKind::Check);
    m.insert("else".into(),     TokenKind::Else);
    m.insert("match".into(),    TokenKind::Match);
    m.insert("each".into(),     TokenKind::Each);
    m.insert("for".into(),      TokenKind::For);
    m.insert("in".into(),       TokenKind::In);
    m.insert("loop".into(),     TokenKind::Loop);
    m.insert("while".into(),    TokenKind::While);
    m.insert("yield".into(),    TokenKind::Yield);
    m.insert("abort".into(),    TokenKind::Abort);
    m.insert("next".into(),     TokenKind::Next);
    m.insert("try".into(),      TokenKind::Try);
    m.insert("catch".into(),    TokenKind::Catch);

    // ── Modül Sistemi ─────────────────────────────────────────────────────────
    m.insert("use".into(),      TokenKind::Use);
    m.insert("from".into(),     TokenKind::From);
    m.insert("as".into(),       TokenKind::As);

    // ── Eşzamanlılık ──────────────────────────────────────────────────────────
    m.insert("async".into(),    TokenKind::Async);
    m.insert("await".into(),    TokenKind::Await);
    m.insert("spawn".into(),    TokenKind::Spawn);
    m.insert("channel".into(),  TokenKind::Channel);

    // ── Unit Algebra ──────────────────────────────────────────────────────────
    m.insert("unit".into(),     TokenKind::Unit);
    m.insert("qty".into(),      TokenKind::Qty);
    m.insert("dims".into(),     TokenKind::Dims);

    // ── Hesaplama ─────────────────────────────────────────────────────────────
    m.insert("tensor".into(),   TokenKind::Tensor);
    m.insert("on".into(),       TokenKind::On);
    m.insert("parallel".into(), TokenKind::Parallel);
    m.insert("kernel".into(),   TokenKind::Kernel);
    
    // 🏹 4LUA VPU Katmanları
    m.insert("silicon_vpu".into(), TokenKind::Silicon_Vpu);
    m.insert("kernel_vpu".into(),  TokenKind::Kernel_Vpu);
    m.insert("web_nexus".into(),   TokenKind::Web_Nexus);
    m.insert("mesh_vpu".into(),    TokenKind::Mesh_Vpu);

    // ── Matematik ─────────────────────────────────────────────────────────────
    m.insert("grad".into(),     TokenKind::Grad);
    m.insert("diff".into(),     TokenKind::Diff);
    m.insert("integral".into(), TokenKind::Integral);
    m.insert("sum".into(),      TokenKind::Sum);
    m.insert("prod".into(),     TokenKind::Prod);
    m.insert("limit".into(),    TokenKind::Limit);
    m.insert("solve".into(),    TokenKind::Solve);

    // ── Formal Doğrulama ──────────────────────────────────────────────────────
    m.insert("assert".into(),   TokenKind::Assert);
    m.insert("ensure".into(),   TokenKind::Ensure);
    m.insert("require".into(),  TokenKind::Require);
    m.insert("proof".into(),    TokenKind::Proof);
    m.insert("assume".into(),   TokenKind::Assume);
    m.insert("axiom".into(),    TokenKind::Axiom);

    // ── Bilimsel Domain ───────────────────────────────────────────────────────
    m.insert("molecule".into(), TokenKind::Molecule);
    m.insert("react".into(),    TokenKind::React);
    m.insert("seq".into(),      TokenKind::Seq);
    m.insert("elem".into(),     TokenKind::Elem);

    // ── Sabitler ──────────────────────────────────────────────────────────────
    m.insert("true".into(),     TokenKind::LitTrue);
    m.insert("false".into(),    TokenKind::LitFalse);
    m.insert("self".into(),     TokenKind::SelfVal);
    m.insert("dyn".into(),      TokenKind::Dyn);
    m.insert("crate".into(),    TokenKind::Crate);
    m.insert("_".into(),        TokenKind::Underscore);

    m
}
