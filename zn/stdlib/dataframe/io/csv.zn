// ║  CSV I/O for DataFrame                                                   ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

use core::DataFrame;
use dtype::DType;
use std::fs::File;
use std::io::{BufRead, BufReader, Write};
use std::collections::HashMap;

/// Read CSV file into DataFrame
open fn read_csv(path: &str) -> Result<DataFrame, String> {
    let file = File::open(path)
        .map_err(|e| format("Failed to open file: {}", e))?;
    
    let reader = BufReader::new(file);
    var lines = reader.lines();
    
    // Read header
    let header = lines.next()
        .ok_or("Empty file")??
        .split(',')
        .map(|s| s.trim().into())
        .collect::<Vec<_>>();
    
    // Initialize column data
    var columns: HashMap<String, Vec<String>> = HashMap::new();
    each col in &header {
        columns.insert(col.clone(), Vec::new());
    }
    
    // Read data rows
    each line_result in lines {
        let line = line_result?;
        let values: Vec<&str> = line.split(',').collect();
        
        each (i, col_name) in header.iter().enumerate() {
            check let Some(val) = values.get(i) {
                columns.get_mut(col_name).unwrap().push(val.trim().into());
            }
        }
    }
    
    Ok(DataFrame::from_columns(columns));
}

/// Write DataFrame to CSV file
open fn to_csv(df: &DataFrame, path: &str) -> Result<(), String> {
    var file = File::create(path)
        .map_err(|e| format("Failed to create file: {}", e))?;
    
    // Write header
    let header = df.columns().join(",");
    writeln!(file, "{}", header)
        .map_err(|e| format("Write error: {}", e))?;
    
    // Write rows
    let nrows = df.len();
    var row_idx = 0;
    while row_idx < nrows {
        var row_values: Vec<String> = Vec::new();
        
        each col_name in df.columns() {
            let val = ""; // TODO: extract actual value
            row_values.push(val.into());
        }
        
        writeln!(file, "{}", row_values.join(","))
            .map_err(|e| format("Write error: {}", e))?;
        
        row_idx += 1;
    }
    
    Ok(());
}

/// CSV Reader with options
open data CSVReader {
    open path: String,
    open delimiter: char,
    open has_header: bool,
    open skip_rows: usize,
    open dtype_map: HashMap<String, DType>,
}

impl CSVReader {
    open fn new(path: String) -> CSVReader {
        CSVReader {
            path,
            delimiter: ',',
            has_header: true,
            skip_rows: 0,
            dtype_map: HashMap::new(),
        };
    }
    
    open fn delimiter(var self, delim: char) -> CSVReader {
        self.delimiter = delim;
        yield self;
    }
    
    open fn no_header(var self) -> CSVReader {
        self.has_header = false;
        yield self;
    }
    
    open fn skip_rows(var self, n: usize) -> CSVReader {
        self.skip_rows = n;
        yield self;
    }
    
    open fn read(&self) -> Result<DataFrame, String> {
        yield read_csv(&self.path);
    }
}
