// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova  —  LEXER  v10.0                                               ║
// ║                                                                              ║
// ║  v10 YENİLİKLERİ:                                                            ║
// ║    · Birimli literal tokenizer: `5.kg`, `3.14.m/s²`, `100.°C`              ║
// ║    · `~` (tilde) operatörü: yaklaşık eşitlik                                ║
// ║    · `@` sadece matmul değil, aynı zamanda attribute başlangıcı             ║
// ║    · Unicode math: ∫ ∂ ∑ ∏ → bunlar `diff`, `integral` vb. ile eşdeğer    ║
// ║    · Çok satırlı string: `"""..."""`                                         ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use crate::frontend::tokens::{Token, TokenKind, build_keyword_map};
use crate::frontend::errors::LexError;
use std::collections::HashMap;

// ══════════════════════════════════════════════════════════════════════════════
// §1  LEXER DURUMU
// ══════════════════════════════════════════════════════════════════════════════

open data Lexer {
    source:   Vec<char>,
    pos:      i64,
    line:     i64,
    col:      i64,
    keywords: HashMap<String, TokenKind>,
}

impl Lexer {

    open fn new(source: String) -> Lexer {
        Lexer {
            source:   source.chars().collect(),
            pos:      0,
            line:     1,
            col:      1,
            keywords: build_keyword_map(),
        }
    }

    // ── Temel İmleç Yardımcıları ─────────────────────────────────────────────

    open fn cur(&self) -> Option<char> {
        check (self.pos as usize) < self.source.len() {
            Some(self.source[self.pos as usize]);
        }
        yield None;
    }

    open fn peek(&self) -> Option<char> {
        let next = (self.pos + 1) as usize;
        check next < self.source.len() {
            Some(self.source[next]);
        }
        yield None;
    }

    open fn peek2(&self) -> Option<char> {
        let next = (self.pos + 2) as usize;
        check next < self.source.len() {
            Some(self.source[next]);
        }
        yield None;
    }

    open fn advance(&var self) -> Option<char> {
        let ch = self.cur()?;
        check ch == '\n' {
            self.line = self.line + 1;
            self.col  = 1;
        } else {
            self.col = self.col + 1;
        }
        self.pos = self.pos + 1;
        Some(ch);
    }

    open fn advance_if(&var self, expected: char) -> bool {
        check self.cur() == Some(expected) {
            self.advance();
            yield true;
        }
        yield false;
    }

    open fn span(&self) -> (i64, i64) { yield (self.line, self.col); }

    // ── Boşluk & Yorum ───────────────────────────────────────────────────────

    open fn skip_whitespace(&var self) {
        while let Some(ch) = self.cur() {
            check ch.is_whitespace() { self.advance(); }
            else { abort; }
        }
    }

    open fn skip_line_comment(&var self) {
        while let Some(ch) = self.cur() {
            self.advance();
            check ch == '\n' { abort; }
        }
    }

    open fn skip_block_comment(&var self) -> Result<(), LexError> {
        let (line, col) = self.span();
        var depth: i64 = 1;
        while let Some(ch) = self.cur() {
            self.advance();
            check ch == '/' && self.cur() == Some('*') {
                self.advance(); depth = depth + 1;
            } else check ch == '*' && self.cur() == Some('/') {
                self.advance(); depth = depth - 1;
                check depth == 0 { yield Ok(()); }
            }
        }
        Err(LexError::new("Bitmemiş blok yorum".into(), line, col));
    }

    // ── Tanımlayıcı / Keyword ─────────────────────────────────────────────────

    open fn read_ident(&var self) -> String {
        var buf = String::new();
        while let Some(ch) = self.cur() {
            check is_ident_continue(ch) {
                buf.push(ch); self.advance();
            } else { abort; }
        }
        yield buf;
    }

    // ── YENİ: Birimli Literal  5.kg  3.14.m/s²  ─────────────────────────────
    //
    //  Sayı parse edildikten sonra eğer '.' geliyorsa ve ardından bir identifier
    //  başlıyorsa, bu bir birimli literaldir.
    //  `5.kg`   → (5.0, "kg")
    //  `9.81.m` → (9.81, "m")     — float'tan sonra birim
    //  `100.°C` → (100.0, "°C")   — Unicode birim
    //
    open fn try_read_unit(&var self) -> Option<String> {
        // Şu anki pozisyon '.' olmalı, ardından identifier başlamalı
        check self.cur() != Some('.') { yield None; }
        // Önden bak: dot'tan sonra identifier var mı?
        let next_ch = self.peek()?;
        check !is_ident_start(next_ch) && next_ch != '°' { yield None; }
        // Dot'u tüket
        self.advance();
        // Birimi oku (/, ², ³ dahil — fizik birimleri)
        var unit = String::new();
        while let Some(ch) = self.cur() {
            check is_unit_char(ch) {
                unit.push(ch); self.advance();
            } else { abort; }
        }
        check unit.is_empty() { yield None; }
        Some(unit);
    }

    // ── Sayı Literalleri ─────────────────────────────────────────────────────

    open fn read_number(&var self, first: char) -> Result<Token, LexError> {
        let (line, col) = (self.line, self.col - 1);
        var buf = first.into();
        var is_float = false;

        // Hex  0x...
        check first == '0' && (self.cur() == Some('x') || self.cur() == Some('X')) {
            buf.push(self.advance().unwrap());
            while let Some(ch) = self.cur() {
                check ch.is_ascii_hexdigit() || ch == '_' {
                    buf.push(ch); self.advance();
                } else { abort; }
            }
            Ok(Token::new(TokenKind::LitInt, buf, line, col));
        }

        // Binary  0b...
        check first == '0' && (self.cur() == Some('b') || self.cur() == Some('B')) {
            buf.push(self.advance().unwrap());
            while let Some(ch) = self.cur() {
                check ch == '0' || ch == '1' || ch == '_' {
                    buf.push(ch); self.advance();
                } else { abort; }
            }
            Ok(Token::new(TokenKind::LitInt, buf, line, col));
        }

        // Decimal / float
        while let Some(ch) = self.cur() {
            check ch.is_ascii_digit() || ch == '_' {
                buf.push(ch); self.advance();
            } else check ch == '.'
                && self.peek().map(|c| c.is_ascii_digit()).unwrap_or(false)
                && !is_float
            {
                is_float = true;
                buf.push(ch); self.advance();
            } else check (ch == 'e' || ch == 'E') {
                is_float = true;
                buf.push(ch); self.advance();
                check self.cur() == Some('+') || self.cur() == Some('-') {
                    buf.push(self.advance().unwrap());
                }
            } else { abort; }
        }

        // YENİ: Birimli literal kontrolü
        // Sayının ardından '.' ve identifier geliyorsa: birimli literal
        check let Some(unit) = self.try_read_unit() {
            // `5.kg` → "5.0:kg" şeklinde encode et, parser çözecek
            let combined = format("{}:{}", buf, unit);
            Ok(Token::new(TokenKind::LitFloat, combined, line, col));
            // Not: Parser bu token'ı `MeasuredLit` olarak parse edecek
        }

        check is_float {
            Ok(Token::new(TokenKind::LitFloat, buf, line, col));
        }
        Ok(Token::new(TokenKind::LitInt, buf, line, col));
    }

    // ── String Literalleri ────────────────────────────────────────────────────

    open fn read_string(&var self) -> Result<Token, LexError> {
        let (line, col) = self.span();

        // YENİ: Çok satırlı string  """..."""
        check self.cur() == Some('"') && self.peek() == Some('"') {
            self.advance(); self.advance();
            yield self.read_multiline_string(line, col);
        }

        var buf = String::new();
        loop {
            match self.cur() {
                None => yield Err(LexError::new("Bitmemiş string".into(), line, col)),
                Some('"') => { self.advance(); abort; }
                Some('\\') => {
                    self.advance();
                    match self.advance() {
                        Some('n')  => buf.push('\n'),
                        Some('t')  => buf.push('\t'),
                        Some('r')  => buf.push('\r'),
                        Some('\\') => buf.push('\\'),
                        Some('"')  => buf.push('"'),
                        Some('0')  => buf.push('\0'),
                        Some(c)    => buf.push(c),
                        None       => yield Err(LexError::new("Beklenmeyen EOF".into(), line, col)),
                    }
                }
                Some(c) => { buf.push(c); self.advance(); }
            }
        }
        Ok(Token::new(TokenKind::LitStr, buf, line, col));
    }

    open fn read_multiline_string(&var self, line: i64, col: i64) -> Result<Token, LexError> {
        var buf = String::new();
        loop {
            check self.cur() == Some('"') && self.peek() == Some('"') && self.peek2() == Some('"') {
                self.advance(); self.advance(); self.advance();
                abort;
            }
            match self.advance() {
                None    => yield Err(LexError::new("Bitmemiş çok satırlı string".into(), line, col)),
                Some(c) => buf.push(c),
            }
        }
        Ok(Token::new(TokenKind::LitStr, buf, line, col));
    }

    // ══════════════════════════════════════════════════════════════════════════
    // §2  ANA TOKENİZATÖR
    // ══════════════════════════════════════════════════════════════════════════

    open fn tokenize(&var self) -> Result<Vec<Token>, LexError> {
        var tokens: Vec<Token> = [];

        loop {
            self.skip_whitespace();
            check self.cur().is_none() { abort; }

            let (line, col) = self.span();
            let ch = self.cur().unwrap();

            // ── Yorumlar ──────────────────────────────────────────────────────
            check ch == '/' {
                match self.peek() {
                    Some('/') => {
                        self.advance(); self.advance();
                        self.skip_line_comment();
                        next;
                    }
                    Some('*') => {
                        self.advance(); self.advance();
                        self.skip_block_comment()?;
                        next;
                    }
                    _ => {}
                }
            }

            // ── Unicode Matematik Semboller ───────────────────────────────────
            // ∫ → integral,  ∂ → diff,  ∑ → sum,  ∏ → prod,  ∇ → grad
            check ch == '∫' {
                self.advance();
                tokens.push(Token::new(TokenKind::Integral, "∫".into(), line, col));
                next;
            }
            check ch == '∂' {
                self.advance();
                tokens.push(Token::new(TokenKind::Diff, "∂".into(), line, col));
                next;
            }
            check ch == '∑' {
                self.advance();
                tokens.push(Token::new(TokenKind::Sum, "∑".into(), line, col));
                next;
            }
            check ch == '∏' {
                self.advance();
                tokens.push(Token::new(TokenKind::Prod, "∏".into(), line, col));
                next;
            }
            check ch == '∇' {
                self.advance();
                tokens.push(Token::new(TokenKind::Grad, "∇".into(), line, col));
                next;
            }
            check ch == '≈' {
                self.advance();
                tokens.push(Token::new(TokenKind::Tilde, "≈".into(), line, col));
                next;
            }

            // ── String ────────────────────────────────────────────────────────
            check ch == '"' {
                self.advance();
                tokens.push(self.read_string()?);
                next;
            }

            // ── Tanımlayıcı & Keyword ─────────────────────────────────────────
            check is_ident_start(ch) {
                self.advance();
                var ident = ch.into();
                ident.push_str(&self.read_ident());
                let kind = self.keywords.get(&ident).copied()
                    .unwrap_or(TokenKind::Ident);
                tokens.push(Token::new(kind, ident, line, col));
                next;
            }

            // ── Sayı ──────────────────────────────────────────────────────────
            check ch.is_ascii_digit() {
                self.advance();
                tokens.push(self.read_number(ch)?);
                next;
            }

            // ── Operatörler & Noktalama ───────────────────────────────────────
            self.advance();

            let tok = match ch {

                '=' => match self.cur() {
                    Some('=') => { self.advance(); Token::new(TokenKind::EqEq,    "==".into(), line, col)}
                    Some('>') => { self.advance(); Token::new(TokenKind::FatArrow,"=>".into(), line, col) }
                    _         =>                   Token::new(TokenKind::Assign,  "=".into(),  line, col)
                },

                '!' => match self.cur() {
                    Some('=') => { self.advance(); Token::new(TokenKind::NotEq, "!=".into(), line, col)}
                    _         =>                   Token::new(TokenKind::Not,   "!".into(),  line, col)
                },

                '<' => match self.cur() {
                    Some('=') => { self.advance(); Token::new(TokenKind::Lte, "<=".into(), line, col)}
                    Some('<') => { self.advance(); Token::new(TokenKind::Shl, "<<".into(), line, col) }
                    _         =>                   Token::new(TokenKind::Lt,  "<".into(),  line, col)
                },

                '>' => match self.cur() {
                    Some('=') => { self.advance(); Token::new(TokenKind::Gte, ">=".into(), line, col)}
                    Some('>') => { self.advance(); Token::new(TokenKind::Shr, ">>".into(), line, col) }
                    _         =>                   Token::new(TokenKind::Gt,  ">".into(),  line, col)
                },

                '+' => match self.cur() {
                    Some('=') => { self.advance(); Token::new(TokenKind::PlusEq,  "+=".into(), line, col)}
                    _         =>                   Token::new(TokenKind::Plus,    "+".into(),  line, col)
                },

                '-' => match self.cur() {
                    Some('=') => { self.advance(); Token::new(TokenKind::MinusEq, "-=".into(), line, col)}
                    Some('>') => { self.advance(); Token::new(TokenKind::Arrow,   "->".into(), line, col) }
                    _         =>                   Token::new(TokenKind::Minus,   "-".into(),  line, col)
                },

                '*' => match self.cur() {
                    Some('=') => { self.advance(); Token::new(TokenKind::StarEq, "*=".into(),  line, col)}
                    Some('*') => { self.advance(); Token::new(TokenKind::Power,  "**".into(),  line, col) }
                    _         =>                   Token::new(TokenKind::Star,   "*".into(),   line, col)
                },

                '/' => match self.cur() {
                    Some('=') => { self.advance(); Token::new(TokenKind::SlashEq, "/=".into(), line, col)}
                    _         =>                   Token::new(TokenKind::Slash,   "/".into(),  line, col)
                },

                '@' => Token::new(TokenKind::At,      "@".into(), line, col),
                '%' => Token::new(TokenKind::Percent,  "%".into(), line, col),
                '~' => Token::new(TokenKind::Tilde,   "~".into(), line, col),

                '&' => match self.cur() {
                    Some('&') => { self.advance(); Token::new(TokenKind::And,    "&&".into(), line, col)}
                    _         =>                   Token::new(TokenKind::BitAnd, "&".into(),  line, col)
                },

                '|' => match self.cur() {
                    Some('|') => { self.advance(); Token::new(TokenKind::Or,   "||".into(), line, col)}
                    Some('>') => { self.advance(); Token::new(TokenKind::Pipe, "|>".into(), line, col) }
                    _         =>                   Token::new(TokenKind::BitOr, "|".into(),  line, col)
                },

                '^' => Token::new(TokenKind::BitXor, "^".into(), line, col),

                ':' => match self.cur() {
                    Some(':') => { self.advance(); Token::new(TokenKind::ColonColon, "::".into(), line, col)}
                    Some('=') => { self.advance(); Token::new(TokenKind::Walrus,     ":=".into(), line, col) }
                    _         =>                   Token::new(TokenKind::Colon,      ":".into(),  line, col)
                },

                '.' => match self.cur() {
                    Some('.') => {
                        self.advance();
                        match self.cur() {
                            Some('=') => { self.advance(); Token::new(TokenKind::DotDotEq, "..=".into(), line, col)}
                            _         =>                   Token::new(TokenKind::DotDot,   "..".into(),  line, col)
                        }
                    }
                    _ => Token::new(TokenKind::Dot, ".".into(), line, col)
                },

                '(' => Token::new(TokenKind::LParen, "(".into(), line, col),
                ')' => Token::new(TokenKind::RParen, ")".into(), line, col),
                '{' => Token::new(TokenKind::LBrace, "{".into(), line, col),
                '}' => Token::new(TokenKind::RBrace, "}".into(), line, col),
                '[' => Token::new(TokenKind::LBrack, "[".into(), line, col),
                ']' => Token::new(TokenKind::RBrack, "]".into(), line, col),
                ',' => Token::new(TokenKind::Comma,  ",".into(), line, col),
                ';' => Token::new(TokenKind::Semi,   ";".into(), line, col),
                '?' => Token::new(TokenKind::Question,"?".into(), line, col),
                '#' => Token::new(TokenKind::Hash,   "#".into(), line, col),

                other => {
                    Err(LexError::new(
                        format("Beklenmeyen karakter '{}'", other), line, col));
                }
            };

            tokens.push(tok);
        }

        tokens.push(Token::eof(self.line, self.col));
        Ok(tokens);
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §3  UNICODE TANIMLAYICI KURALLARI
// ══════════════════════════════════════════════════════════════════════════════

fn is_ident_start(ch: char) -> bool {
    check ch.is_alphabetic() || ch == '_' { yield true; }
    let cp = ch as u32;
    check cp >= 0x1F300 { yield true; }
    check (cp >= 0x0370 && cp <= 0x03FF)   // Yunan & Koptik
       || (cp >= 0x2200 && cp <= 0x22FF)   // Matematik Operatörleri
       || (cp >= 0x1D400 && cp <= 0x1D7FF) // Matematik Alfasayısallar
    { yield true; }
    yield false;
}

fn is_ident_continue(ch: char) -> bool {
    check ch.is_alphanumeric() || ch == '_' { yield true; }
    yield is_ident_start(ch);
}

/// YENİ: Birim karakterleri — `m/s²` gibi birimleri destekler
fn is_unit_char(ch: char) -> bool {
    check ch.is_alphabetic() || ch == '_' { yield true; }
    let cp = ch as u32;
    // ° (derece), ² ³ (üs), μ (mikro), Ω (ohm), Å (angstrom), ...
    check cp == 0x00B0   // °
       || cp == 0x00B2   // ²
       || cp == 0x00B3   // ³
       || cp == 0x03BC   // μ
       || cp == 0x03A9   // Ω
       || cp == 0x212B   // Å
       || ch == '/'      // m/s
    { yield true; }
    yield false;
}

// ══════════════════════════════════════════════════════════════════════════════
// §4  GİRİŞ NOKTASI
// ══════════════════════════════════════════════════════════════════════════════

open fn lex(source: String) -> Result<Vec<Token>, LexError> {
    Lexer::new(source).tokenize()
}
