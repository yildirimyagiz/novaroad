// ══════════════════════════════════════════════════════════════════════════════
// §1  TYPE-LEVEL VALUES
// ══════════════════════════════════════════════════════════════════════════════

/// Type-level natural numbers (Peano style)
open cases Nat {
    Zero,
    Succ(Box<Nat>),
}

// Example:
// alias N0 = Nat::Zero;
// alias N1 = Nat::Succ(Box::new(N0));
// alias N2 = Nat::Succ(Box::new(N1));

/// Type-level boolean
open cases Bool {
    True,
    False,
}

/// Type-level list
open cases TypeList<T> {
    Nil,
    Cons(T, Box<TypeList<T>>),
}

// ══════════════════════════════════════════════════════════════════════════════
// §2  TYPE FAMILIES (Type-level functions)
// ══════════════════════════════════════════════════════════════════════════════

/// Type family declaration
open data TypeFamily {
    open name: String,
    open params: Vec<String>,
    open result_kind: Kind,
    open equations: Vec<TypeEquation>,
}

/// Type equation (pattern matching on types)
open data TypeEquation {
    open lhs_patterns: Vec<TypePattern>,
    open rhs: TypeExpr,
}

open cases TypePattern {
    Wildcard,
    Var(String),
    Constructor(String, Vec<TypePattern>),
    Literal(TypeLevelValue),
}

// Example:
// alias family Add(n: Nat, m: Nat) -> Nat {
//     Add(Zero, m) = m,
//     Add(Succ(n), m) = Succ(Add(n, m)),
// }

// alias family If(b: Bool, t: Type, f: Type) -> Type {
//     If(True, t, _) = t,
//     If(False, _, f) = f,
// }

