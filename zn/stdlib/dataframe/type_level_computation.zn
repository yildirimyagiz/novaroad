// ══════════════════════════════════════════════════════════════════════════════
// §4  SIZED TYPES (Length-indexed)
// ══════════════════════════════════════════════════════════════════════════════

/// Vector with compile-time known length
open data Vec<T, const N: usize> {
    open data: [T; N],
}

impl Vec<T, const N: usize> {
    /// Create vector (length checked at compile time)
    open fn new(elements: [T; N]) -> Vec<T, N> {
        Vec { data: elements };
    }
    
    /// Append vectors (lengths add up)
    open fn append<const M: usize>(self, other: Vec<T, M>) -> Vec<T, N + M> {
        // TODO: Implementation
        unimplemented!()
    }
    
    /// Safe indexing (index < N checked at compile time)
    open fn get<const I: usize>(self) -> T
        require I < N
    {
        yield self.data[I];
    }
}

// Example:
// let v1: Vec<i64, 3> = Vec::new([1, 2, 3]);
// let v2: Vec<i64, 2> = Vec::new([4, 5]);
// let v3: Vec<i64, 5> = v1.append(v2);  // Length = 3 + 2 = 5

// ══════════════════════════════════════════════════════════════════════════════
// §5  REFINEMENT TYPES
// ══════════════════════════════════════════════════════════════════════════════

/// Type with runtime predicate
open data RefinedType {
    open base: TypeExpr,
    open predicate: Expr,  // Boolean predicate
    open proof: Option<ProofTerm>,  // Optional proof
}

// Example:
// alias Positive = { x: i64 | x > 0 };
// alias NonEmpty<T> = { v: Vec<T> | v.len() > 0 };
// alias Sorted<T> = { v: Vec<T> | is_sorted(v) };

/// Create refined alias value (with runtime check)
open fn refine<T>(value: T, pred: fn(T) -> bool) -> Result<Refined<T>, String> {
    check pred(value) {
        Ok(Refined { value });
    } else {
        Err("Refinement predicate failed".into());
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §6  PHANTOM TYPES (Zero-sized alias parameters)
// ══════════════════════════════════════════════════════════════════════════════

/// Phantom alias marker (each alias-level state machines)
open data PhantomData<T> {
    // Zero-sized
}

// Example: File state machine
open cases FileState {
    Closed,
    Opened,
}

open data File<S: FileState> {
    open handle: i64,
    open _phantom: PhantomData<S>,
}

impl File<Closed> {
    open fn open(path: String) -> File<Opened> {
        // Open file, yield File in Opened state
        unimplemented!()
    }
}

impl File<Opened> {
    open fn read(&self) -> String {
        // Can only read when file is open
        unimplemented!()
    }
    
    open fn close(self) -> File<Closed> {
        // Close file, transition to Closed state
        unimplemented!()
    }
}

// Usage:
// let f = File::open("data.txt");  // File<Opened>
// let data = f.read();              // OK
// let f = f.close();                // File<Closed>
// // let data = f.read();           // ERROR: File is closed!

// ══════════════════════════════════════════════════════════════════════════════
// §7  DEPENDENT PAIRS (Σ-types)
// ══════════════════════════════════════════════════════════════════════════════

/// Dependent pair: (x: A, B(x))
open data Sigma<A, B> {
    open fst: A,
    open snd: B,  // Type depends on fst
}

// Example:
// alias LengthVec = Sigma<usize, fn(n) -> Vec<i64, n>>;
// let v: LengthVec = (3, [1, 2, 3]);

