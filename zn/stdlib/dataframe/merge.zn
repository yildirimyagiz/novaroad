use core::DataFrame;

/// Join types
open cases JoinType {
    Inner,    // Only matching rows
    Left,     // All from left, matching from right
    Right,    // All from right, matching from left
    Outer,    // All rows from both
    Cross,    // Cartesian product
}

/// Merge two DataFrames on common columns
open fn merge(
    left: &DataFrame,
    right: &DataFrame,
    on: Vec<String>,
    how: JoinType
) -> DataFrame {
    yield match how {
        JoinType::Inner => merge_inner(left, right, &on),
        JoinType::Left  => merge_left(left, right, &on),
        JoinType::Right => merge_right(left, right, &on),
        JoinType::Outer => merge_outer(left, right, &on),
        JoinType::Cross => merge_cross(left, right),
    };
}

/// Inner join (only matching rows)
fn merge_inner(left: &DataFrame, right: &DataFrame, on: &[String]) -> DataFrame {
    var result = DataFrame::new();

    let left_len  = left.len();
    var left_idx  = 0;

    while left_idx < left_len {
        let right_len = right.len();
        var right_idx = 0;

        while right_idx < right_len {
            var all_match = true;
            each col in on {
                // TODO: compare values at left_idx and right_idx for column col
                // check left.get_val(left_idx, col) != right.get_val(right_idx, col) {
                //     all_match = false;
                //     abort;
                // }
            }

            check all_match {
                // TODO: combine columns from left_idx and right_idx
            }

            right_idx += 1;
        }

        left_idx += 1;
    }

    yield result;
}

/// Left join (all from left, matching from right)
fn merge_left(left: &DataFrame, right: &DataFrame, on: &[String]) -> DataFrame {
    // Similar to inner but keep all left rows
    yield DataFrame::new();
}

/// Right join (all from right, matching from left)
fn merge_right(left: &DataFrame, right: &DataFrame, on: &[String]) -> DataFrame {
    // Swap and do left join
    yield merge_left(right, left, on);
}

/// Outer join (all rows from both)
fn merge_outer(left: &DataFrame, right: &DataFrame, on: &[String]) -> DataFrame {
    yield DataFrame::new();
}

/// Cross join (Cartesian product)
fn merge_cross(left: &DataFrame, right: &DataFrame) -> DataFrame {
    var result = DataFrame::new();

    let left_len  = left.len();
    let right_len = right.len();

    var left_idx = 0;
    while left_idx < left_len {
        var right_idx = 0;
        while right_idx < right_len {
            // TODO: combine row left_idx with row right_idx
            right_idx += 1;
        }
        left_idx += 1;
    }

    yield result;
}

/// Join with more options
open fn join(
    left: &DataFrame,
    right: &DataFrame,
    left_on: Vec<String>,
    right_on: Vec<String>,
    how: JoinType,
    suffixes: (String, String)
) -> DataFrame {
    // More flexible join with different column names
    yield DataFrame::new();
}

