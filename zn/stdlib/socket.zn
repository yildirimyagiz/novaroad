// ═══════════════════════════════════════════════════════════════════════════════
// §7  EXTERNAL DECLARATIONS
// ═══════════════════════════════════════════════════════════════════════════════

extern "C" fn create_socket(socket_type: SocketType, family: ProtocolFamily) -> Result<i32, String>;
extern "C" fn bind_socket(fd: i32, addr: &SocketAddress) -> i32;
extern "C" fn listen_socket(fd: i32, backlog: i32) -> i32;
extern "C" fn connect_socket(fd: i32, addr: &SocketAddress) -> i32;
extern "C" fn accept_socket(fd: i32) -> Result<(i32, SocketAddress), String>;
extern "C" fn send_socket(fd: i32, data: &[u8]) -> isize;
extern "C" fn recv_socket(fd: i32, buffer: &mut [u8]) -> isize;
extern "C" fn sendto_socket(fd: i32, data: &[u8], addr: &SocketAddress) -> isize;
extern "C" fn recvfrom_socket(fd: i32, buffer: &mut [u8]) -> (isize, SocketAddress);
extern "C" fn shutdown_socket(fd: i32, how: ShutdownMode) -> i32;
extern "C" fn close_socket(fd: i32) -> i32;
extern "C" fn set_socket_option(fd: i32, option: &SocketOption) -> i32;
extern "C" fn get_socket_option(fd: i32, option: &SocketOption) -> Result<SocketOption, String>;
extern "C" fn join_multicast_group(fd: i32, group: &IpAddress) -> i32;
extern "C" fn leave_multicast_group(fd: i32, group: &IpAddress) -> i32;
extern "C" fn get_last_error() -> String;

