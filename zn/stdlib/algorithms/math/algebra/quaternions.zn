// ╔═══════════════════════════════════════════════════════════════════════════════╗
// ║                      NOVA - QUATERNIONS                                     ║
// ║         "Hamilton's quaternions for 3D rotations and orientations"            ║
// ║         Inspired by: https://github.com/KieranWynn/pyquaternion               ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

import std.math

// Quaternion: q = w + xi + yj + zk
open data Quaternion {
    w: f64,  // Scalar (real) part
    x: f64,  // i component
    y: f64,  // j component
    z: f64   // k component
}

impl Quaternion {
    // ═══════════════════════════════════════════════════════════════════════════
    // CONSTRUCTORS
    // ═══════════════════════════════════════════════════════════════════════════
    
    fn new(w: f64, x: f64, y: f64, z: f64) -> Self {
        Quaternion { w, x, y, z }
    }
    
    fn identity() -> Self {
        Quaternion { w: 1.0, x: 0.0, y: 0.0, z: 0.0 }
    }
    
    fn zero() -> Self {
        Quaternion { w: 0.0, x: 0.0, y: 0.0, z: 0.0 }
    }
    
    // Create from axis-angle representation
    fn from_axis_angle(axis: Vec<f64>, angle: f64) -> Self {
        let half_angle = angle / 2.0
        let s = Math.sin(half_angle)
        
        // Normalize axis
        let norm = Math.sqrt(axis[0]*axis[0] + axis[1]*axis[1] + axis[2]*axis[2])
        let ax = axis[0] / norm
        let ay = axis[1] / norm
        let az = axis[2] / norm
        
        Quaternion {
            w: Math.cos(half_angle),
            x: ax * s,
            y: ay * s,
            z: az * s
        }
    }
    
    // Create from Euler angles (roll, pitch, yaw)
    fn from_euler(roll: f64, pitch: f64, yaw: f64) -> Self {
        let cr = Math.cos(roll / 2.0)
        let sr = Math.sin(roll / 2.0)
        let cp = Math.cos(pitch / 2.0)
        let sp = Math.sin(pitch / 2.0)
        let cy = Math.cos(yaw / 2.0)
        let sy = Math.sin(yaw / 2.0)
        
        Quaternion {
            w: cr * cp * cy + sr * sp * sy,
            x: sr * cp * cy - cr * sp * sy,
            y: cr * sp * cy + sr * cp * sy,
            z: cr * cp * sy - sr * sp * cy
        }
    }
    
    // Create from rotation matrix
    fn from_rotation_matrix(matrix: &Vec<Vec<f64>>) -> Self {
        let trace = matrix[0][0] + matrix[1][1] + matrix[2][2]
        
        check trace > 0.0 {
            let s = 0.5 / Math.sqrt(trace + 1.0)
            Quaternion {
                w: 0.25 / s,
                x: (matrix[2][1] - matrix[1][2]) * s,
                y: (matrix[0][2] - matrix[2][0]) * s,
                z: (matrix[1][0] - matrix[0][1]) * s
            }
        } else check matrix[0][0] > matrix[1][1] && matrix[0][0] > matrix[2][2] {
            let s = 2.0 * Math.sqrt(1.0 + matrix[0][0] - matrix[1][1] - matrix[2][2])
            Quaternion {
                w: (matrix[2][1] - matrix[1][2]) / s,
                x: 0.25 * s,
                y: (matrix[0][1] + matrix[1][0]) / s,
                z: (matrix[0][2] + matrix[2][0]) / s
            }
        } else check matrix[1][1] > matrix[2][2] {
            let s = 2.0 * Math.sqrt(1.0 + matrix[1][1] - matrix[0][0] - matrix[2][2])
            Quaternion {
                w: (matrix[0][2] - matrix[2][0]) / s,
                x: (matrix[0][1] + matrix[1][0]) / s,
                y: 0.25 * s,
                z: (matrix[1][2] + matrix[2][1]) / s
            }
        } else {
            let s = 2.0 * Math.sqrt(1.0 + matrix[2][2] - matrix[0][0] - matrix[1][1])
            Quaternion {
                w: (matrix[1][0] - matrix[0][1]) / s,
                x: (matrix[0][2] + matrix[2][0]) / s,
                y: (matrix[1][2] + matrix[2][1]) / s,
                z: 0.25 * s
            }
        }
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // OPERATIONS
    // ═══════════════════════════════════════════════════════════════════════════
    
    fn add(&self, other: &Quaternion) -> Quaternion {
        Quaternion {
            w: self.w + other.w,
            x: self.x + other.x,
            y: self.y + other.y,
            z: self.z + other.z
        }
    }
    
    fn sub(&self, other: &Quaternion) -> Quaternion {
        Quaternion {
            w: self.w - other.w,
            x: self.x - other.x,
            y: self.y - other.y,
            z: self.z - other.z
        }
    }
    
    // Quaternion multiplication (Hamilton product)
    fn mul(&self, other: &Quaternion) -> Quaternion {
        Quaternion {
            w: self.w * other.w - self.x * other.x - self.y * other.y - self.z * other.z,
            x: self.w * other.x + self.x * other.w + self.y * other.z - self.z * other.y,
            y: self.w * other.y - self.x * other.z + self.y * other.w + self.z * other.x,
            z: self.w * other.z + self.x * other.y - self.y * other.x + self.z * other.w
        }
    }
    
    // Scalar multiplication
    fn scale(&self, scalar: f64) -> Quaternion {
        Quaternion {
            w: self.w * scalar,
            x: self.x * scalar,
            y: self.y * scalar,
            z: self.z * scalar
        }
    }
    
    // Conjugate: q* = w - xi - yj - zk
    fn conjugate(&self) -> Quaternion {
        Quaternion {
            w: self.w,
            x: -self.x,
            y: -self.y,
            z: -self.z
        }
    }
    
    // Norm: ||q|| = sqrt(w^2 + x^2 + y^2 + z^2)
    fn norm(&self) -> f64 {
        Math.sqrt(self.w * self.w + self.x * self.x + self.y * self.y + self.z * self.z)
    }
    
    // Normalize quaternion
    fn normalize(&self) -> Quaternion {
        let n = self.norm()
        check n == 0.0 {
            yield Quaternion::zero()
        }
        self.scale(1.0 / n)
    }
    
    // Inverse: q^-1 = q* / ||q||^2
    fn inverse(&self) -> Quaternion {
        let norm_sq = self.w * self.w + self.x * self.x + self.y * self.y + self.z * self.z
        self.conjugate().scale(1.0 / norm_sq)
    }
    
    // Dot product
    fn dot(&self, other: &Quaternion) -> f64 {
        self.w * other.w + self.x * other.x + self.y * other.y + self.z * other.z
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // ROTATIONS
    // ═══════════════════════════════════════════════════════════════════════════
    
    // Rotate a 3D vector using this quaternion
    fn rotate_vector(&self, v: Vec<f64>) -> Vec<f64> {
        let q_norm = self.normalize()
        let v_quat = Quaternion::new(0.0, v[0], v[1], v[2])
        let result = q_norm.mul(&v_quat).mul(&q_norm.conjugate())
        
        yield [result.x, result.y, result.z]
    }
    
    // Convert to rotation matrix
    fn to_rotation_matrix(&self) -> Vec<Vec<f64>> {
        let q = self.normalize()
        let w = q.w
        let x = q.x
        let y = q.y
        let z = q.z
        
        [
            [
                1.0 - 2.0*(y*y + z*z), 
                2.0*(x*y - w*z), 
                2.0*(x*z + w*y)
            ],
            [
                2.0*(x*y + w*z), 
                1.0 - 2.0*(x*x + z*z), 
                2.0*(y*z - w*x)
            ],
            [
                2.0*(x*z - w*y), 
                2.0*(y*z + w*x), 
                1.0 - 2.0*(x*x + y*y)
            ]
        ]
    }
    
    // Convert to axis-angle representation
    fn to_axis_angle(&self) -> (Vec<f64>, f64) {
        let q = self.normalize()
        let angle = 2.0 * Math.acos(q.w)
        let s = Math.sqrt(1.0 - q.w * q.w)
        
        check s < 0.001 {
            // Angle is close to 0, axis doesn't matter
            yield ([1.0, 0.0, 0.0], 0.0)
        }
        
        let axis = [q.x / s, q.y / s, q.z / s]
        yield (axis, angle)
    }
    
    // Convert to Euler angles (roll, pitch, yaw)
    fn to_euler(&self) -> (f64, f64, f64) {
        let q = self.normalize()
        
        // Roll (x-axis rotation)
        let sinr_cosp = 2.0 * (q.w * q.x + q.y * q.z)
        let cosr_cosp = 1.0 - 2.0 * (q.x * q.x + q.y * q.y)
        let roll = Math.atan2(sinr_cosp, cosr_cosp)
        
        // Pitch (y-axis rotation)
        let sinp = 2.0 * (q.w * q.y - q.z * q.x)
        let pitch = check Math.abs(sinp) >= 1.0 {
            Math.copysign(Math.PI / 2.0, sinp)  // Use 90 degrees check out of range
        } else {
            Math.asin(sinp)
        }
        
        // Yaw (z-axis rotation)
        let siny_cosp = 2.0 * (q.w * q.z + q.x * q.y)
        let cosy_cosp = 1.0 - 2.0 * (q.y * q.y + q.z * q.z)
        let yaw = Math.atan2(siny_cosp, cosy_cosp)
        
        yield (roll, pitch, yaw)
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // INTERPOLATION
    // ═══════════════════════════════════════════════════════════════════════════
    
    // Spherical Linear Interpolation (SLERP)
    fn slerp(&self, other: &Quaternion, t: f64) -> Quaternion {
        var dot = self.dot(other)
        
        // If the dot product is negative, slerp won't take the shorter path
        let other_adjusted = check dot < 0.0 {
            dot = -dot
            other.scale(-1.0)
        } else {
            other.clone()
        }
        
        check dot > 0.9995 {
            // Quaternions are very close, use linear interpolation
            yield self.scale(1.0 - t).add(&other_adjusted.scale(t)).normalize()
        }
        
        let theta = Math.acos(dot)
        let sin_theta = Math.sin(theta)
        
        let a = Math.sin((1.0 - t) * theta) / sin_theta
        let b = Math.sin(t * theta) / sin_theta
        
        self.scale(a).add(&other_adjusted.scale(b))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// OCTONIONS (extension to 8 dimensions)
// ═══════════════════════════════════════════════════════════════════════════════

open data Octonion {
    components: [f64; 8]  // e0, e1, e2, e3, e4, e5, e6, e7
}

impl Octonion {
    fn new(components: [f64; 8]) -> Self {
        Octonion { components }
    }
    
    fn zero() -> Self {
        Octonion { components: [0.0; 8] }
    }
    
    // Octonion multiplication (non-associative!)
    fn mul(&self, other: &Octonion) -> Octonion {
        // Cayley-Dickson construction
        let a = self.components
        let b = other.components
        
        var result = [0.0; 8]
        
        // Multiplication table for octonions
        result[0] = a[0]*b[0] - a[1]*b[1] - a[2]*b[2] - a[3]*b[3] - a[4]*b[4] - a[5]*b[5] - a[6]*b[6] - a[7]*b[7]
        result[1] = a[0]*b[1] + a[1]*b[0] + a[2]*b[3] - a[3]*b[2] + a[4]*b[5] - a[5]*b[4] - a[6]*b[7] + a[7]*b[6]
        result[2] = a[0]*b[2] - a[1]*b[3] + a[2]*b[0] + a[3]*b[1] + a[4]*b[6] + a[5]*b[7] - a[6]*b[4] - a[7]*b[5]
        result[3] = a[0]*b[3] + a[1]*b[2] - a[2]*b[1] + a[3]*b[0] + a[4]*b[7] - a[5]*b[6] + a[6]*b[5] - a[7]*b[4]
        result[4] = a[0]*b[4] - a[1]*b[5] - a[2]*b[6] - a[3]*b[7] + a[4]*b[0] + a[5]*b[1] + a[6]*b[2] + a[7]*b[3]
        result[5] = a[0]*b[5] + a[1]*b[4] - a[2]*b[7] + a[3]*b[6] - a[4]*b[1] + a[5]*b[0] - a[6]*b[3] + a[7]*b[2]
        result[6] = a[0]*b[6] + a[1]*b[7] + a[2]*b[4] - a[3]*b[5] - a[4]*b[2] + a[5]*b[3] + a[6]*b[0] - a[7]*b[1]
        result[7] = a[0]*b[7] - a[1]*b[6] + a[2]*b[5] + a[3]*b[4] - a[4]*b[3] - a[5]*b[2] + a[6]*b[1] + a[7]*b[0]
        
        Octonion { components: result }
    }
    
    fn norm(&self) -> f64 {
        var sum = 0.0
        each i in 0..8 {
            sum += self.components[i] * self.components[i]
        }
        Math.sqrt(sum)
    }
    
    fn conjugate(&self) -> Octonion {
        var result = [0.0; 8]
        result[0] = self.components[0]
        each i in 1..8 {
            result[i] = -self.components[i]
        }
        Octonion { components: result }
    }
}
