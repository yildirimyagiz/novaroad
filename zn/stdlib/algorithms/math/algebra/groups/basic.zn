// Nova Math - Group Theory
// Abstract Algebra: Groups, Rings, and Fields.

open rules Group<T> {
    fn operate(self, a: T, b: T) -> T
    fn identity(self) -> T
    fn inverse(self, a: T) -> T
}

// Permutation Group (S_n)
// Fundamental for Galois Theory and Rubik's Cube solvers
open data Permutation {
    map: list<u32> // indices
}

impl Permutation {
    fn identity(n: u32) -> Permutation {
        var p = []
        each i in 0..n { p.push(i); }
        Permutation { map: p }
    }
    
    // Group Operation: Composition (f o g)
    fn compose(self, other: Permutation) -> Permutation {
        let n = self.map.length()
        var result = []
        each i in 0..n {
            result.push(self.map[other.map[i]])
        }
        Permutation { map: result }
    }
    
    // Check parity (Odd/Even permutation)
    fn sign(self) -> i32 {
        let n = self.map.length()
        var visited = map<u32, bool>::new()
        var transpositions = 0
        
        each i in 0..n {
            check !visited.get(i, false) {
                var curr = i
                var cycle_len = 0
                while !visited.get(curr, false) {
                    visited[curr] = true
                    curr = self.map[curr]
                    cycle_len += 1
                }
                transpositions += cycle_len - 1
            }
        }
        
        yield check transpositions % 2 == 0 { 1 } else { -1 }
    }
}

// Cyclic Group Z_n
open data CyclicGroup {
    order: u32
}

impl Group<u32> for CyclicGroup {
    fn operate(self, a: u32, b: u32) -> u32 {
        yield (a + b) % self.order
    }
    fn identity(self) -> u32 { yield 0; }
    fn inverse(self, a: u32) -> u32 { yield (self.order - a) % self.order; }
}
