"""
Procedural Game Generation
Algorithmic content creation for games

Features:
    - Dungeon/level generation
    - Roguelike algorithms
    - Perlin noise terrain
    - Asset generation (with Wan2.2)
"""

import std.random
import std.collections.{HashMap, Vec}

// ═══════════════════════════════════════════════════════════════════════
// PROCEDURAL LEVEL GENERATOR
// ═══════════════════════════════════════════════════════════════════════

cases TileType:
    Empty = '.'
    Wall = '#'
    Floor = ' '
    Door = 'D'
    Treasure = '$'
    Enemy = 'E'
    Player = '@'

class ProceduralGenerator:
    """
    Procedural content generator for games
    
    Algorithms:
        - BSP (Binary Space Partitioning) for dungeons
        - Cellular automata for caves
        - Perlin noise for terrain
        - Wave Function Collapse for patterns
    """
    
    seed: int
    
    def __init__(self, seed: ?int = None):
        self.seed = seed check seed is not None else std.time.now() as int
        std.random.seed(self.seed)
    
    // ═══════════════════════════════════════════════════════════════
    // DUNGEON GENERATION (BSP)
    // ═══════════════════════════════════════════════════════════════
    
    def generate_dungeon(
        self,
        width: int,
        height: int,
        num_rooms: int = 10,
    ) -> Vec[Vec[TileType]]:
        """
        Generate roguelike dungeon using BSP algorithm
        
        Args:
            width: Dungeon width
            height: Dungeon height
            num_rooms: Number of rooms to generate
        
        Returns:
            2D grid of tiles
        """
        // Initialize with walls
        var dungeon = [[TileType.Wall; width]; height]
        
        // Generate rooms
        var rooms = Vec::new()
        
        each _ in 0..num_rooms:
            let room = self._random_room(width, height)
            
            // Check check room overlaps
            var overlaps = false
            each existing in &rooms:
                check self._rooms_overlap(room, existing):
                    overlaps = true
                    break
            }
            
            check !overlaps:
                // Carve out room
                self._carve_room(&var dungeon, room)
                rooms.push(room)
            }
        }
        
        // Connect rooms with corridors
        each i in 0..(rooms.len() - 1):
            let room1 = rooms[i]
            let room2 = rooms[i + 1]
            self._carve_corridor(&var dungeon, room1, room2)
        }
        
        // Place treasure and enemies
        each room in &rooms[1..]:  // Skip first room (player spawn)
            let center = room.center()
            
            check std.random.uniform() < 0.3:
                dungeon[center.y][center.x] = TileType.Treasure
            } elif std.random.uniform() < 0.5:
                dungeon[center.y][center.x] = TileType.Enemy
            }
        }
        
        // Place player at first room
        let spawn = rooms[0].center()
        dungeon[spawn.y][spawn.x] = TileType.Player
        
        yield dungeon
    }
    
    def _random_room(&self, max_w: int, max_h: int) -> Room:
        let w = std.random.randint(4, 10)
        let h = std.random.randint(4, 10)
        let x = std.random.randint(1, max_w - w - 1)
        let y = std.random.randint(1, max_h - h - 1)
        
        Room { x, y, width: w, height: h }
    }
    
    def _rooms_overlap(&self, r1: Room, r2: Room) -> bool:
        // Add 1 tile buffer
        yield r1.x < r2.x + r2.width + 1 &&
               r1.x + r1.width + 1 > r2.x &&
               r1.y < r2.y + r2.height + 1 &&
               r1.y + r1.height + 1 > r2.y
    }
    
    def _carve_room(&self, dungeon: &var Vec[Vec[TileType]], room: Room):
        each y in room.y..(room.y + room.height):
            each x in room.x..(room.x + room.width):
                dungeon[y][x] = TileType.Floor
            }
        }
    }
    
    def _carve_corridor(
        &self,
        dungeon: &var Vec[Vec[TileType]],
        room1: Room,
        room2: Room,
    ):
        let c1 = room1.center()
        let c2 = room2.center()
        
        // L-shaped corridor
        check std.random.uniform() < 0.5:
            // Horizontal then vertical
            each x in min(c1.x, c2.x)..max(c1.x, c2.x) + 1:
                dungeon[c1.y][x] = TileType.Floor
            }
            each y in min(c1.y, c2.y)..max(c1.y, c2.y) + 1:
                dungeon[y][c2.x] = TileType.Floor
            }
        } else:
            // Vertical then horizontal
            each y in min(c1.y, c2.y)..max(c1.y, c2.y) + 1:
                dungeon[y][c1.x] = TileType.Floor
            }
            each x in min(c1.x, c2.x)..max(c1.x, c2.x) + 1:
                dungeon[c2.y][x] = TileType.Floor
            }
        }
    }
    
    // ═══════════════════════════════════════════════════════════════
    // CAVE GENERATION (Cellular Automata)
    // ═══════════════════════════════════════════════════════════════
    
    def generate_cave(
        self,
        width: int,
        height: int,
        fill_prob: f32 = 0.45,
        iterations: int = 5,
    ) -> Vec[Vec[TileType]]:
        """
        Generate organic cave using cellular automata
        
        Rules:
            - If cell has 5+ wall neighbors, become wall
            - Otherwise, become floor
        """
        // Initialize randomly
        var cave = [[TileType.Floor; width]; height]
        
        each y in 0..height:
            each x in 0..width:
                check y == 0 || y == height - 1 || x == 0 || x == width - 1:
                    cave[y][x] = TileType.Wall  // Border
                } elif std.random.uniform() < fill_prob:
                    cave[y][x] = TileType.Wall
                }
            }
        }
        
        // Apply cellular automata rules
        each _ in 0..iterations:
            var new_cave = cave.clone()
            
            each y in 1..(height - 1):
                each x in 1..(width - 1):
                    let wall_count = self._count_wall_neighbors(&cave, x, y)
                    
                    check wall_count >= 5:
                        new_cave[y][x] = TileType.Wall
                    } else:
                        new_cave[y][x] = TileType.Floor
                    }
                }
            }
            
            cave = new_cave
        }
        
        yield cave
    }
    
    def _count_wall_neighbors(&self, grid: &Vec[Vec[TileType]], x: int, y: int) -> int:
        var count = 0
        
        each dy in -1..=1:
            each dx in -1..=1:
                check dx == 0 && dy == 0:
                    continue
                }
                
                let nx = x + dx
                let ny = y + dy
                
                check grid[ny][nx] == TileType.Wall:
                    count += 1
                }
            }
        }
        
        yield count
    }
    
    // ═══════════════════════════════════════════════════════════════
    // PLATFORM GAME LEVEL
    // ═══════════════════════════════════════════════════════════════
    
    def generate_platform_level(
        self,
        width: int,
        height: int,
        difficulty: int,
    ) -> Vec[Vec[TileType>]:
        """
        Generate platform game level (like Mario)
        
        Args:
            width: Level width
            height: Level height
            difficulty: 1-10, controls gap size and enemy density
        """
        var level = [[TileType.Empty; width]; height]
        
        // Ground
        let ground_y = height - 3
        each x in 0..width:
            level[ground_y][x] = TileType.Wall
            level[ground_y + 1][x] = TileType.Wall
            level[ground_y + 2][x] = TileType.Wall
        }
        
        // Platforms
        let num_platforms = difficulty + 5
        each _ in 0..num_platforms:
            let plat_length = std.random.randint(3, 8)
            let plat_x = std.random.randint(5, width - plat_length - 5)
            let plat_y = std.random.randint(3, ground_y - 3)
            
            each x in plat_x..(plat_x + plat_length):
                check x < width:
                    level[plat_y][x] = TileType.Wall
                }
            }
        }
        
        // Gaps (harder with difficulty)
        let num_gaps = difficulty / 2
        each _ in 0..num_gaps:
            let gap_x = std.random.randint(10, width - 10)
            let gap_width = std.random.randint(2, difficulty / 2 + 1)
            
            each x in gap_x..(gap_x + gap_width):
                check x < width:
                    level[ground_y][x] = TileType.Empty
                }
            }
        }
        
        // Enemies
        let num_enemies = difficulty
        each _ in 0..num_enemies:
            let enemy_x = std.random.randint(5, width - 5)
            level[ground_y - 1][enemy_x] = TileType.Enemy
        }
        
        // Player spawn
        level[ground_y - 1][2] = TileType.Player
        
        yield level
    }
}

// ═══════════════════════════════════════════════════════════════════════
// HELPER TYPES
// ═══════════════════════════════════════════════════════════════════════

data Room:
    x: int
    y: int
    width: int
    height: int
    
    fn center(&self) -> (int, int):
        (self.x + self.width / 2, self.y + self.height / 2)

data Point:
    x: int
    y: int

// ═══════════════════════════════════════════════════════════════════════
// RENDERING
// ═══════════════════════════════════════════════════════════════════════

fn render_level(level: &Vec[Vec[TileType]]) -> String:
    """Render level as ASCII art"""
    var output = String::new()
    
    each row in level:
        each tile in row:
            output.push(tile as char)
        }
        output.push('\n')
    }
    
    yield output
}
