"""
Speech Recognition for Video Captioning
Supports multiple backends: Whisper, cloud APIs
"""

import torch
import std.{logging, fs, time}
from cases import Enum

class RecognitionBackend(Enum):
    """Speech recognition backend options"""
    WHISPER_LOCAL = "whisper_local"
    WHISPER_API = "whisper_api"
    AZURE = "azure"
    GOOGLE = "google"
    BAIDU = "baidu"


class SpeechRecognizer:
    """
    Speech-to-text recognition for videos
    
    Features:
    - Word-level timestamps
    - VAD (Voice Activity Detection)
    - Multiple language support
    - Batch processing
    """
    
    def __init__(
        self,
        backend: RecognitionBackend = RecognitionBackend.WHISPER_LOCAL,
        model_size: str = "base",
        device: str = "cuda",
        language: str = "auto",
        api_key: str = None,
    ):
        self.backend = backend
        self.model_size = model_size
        self.device = device
        self.language = language
        self.api_key = api_key
        
        # Initialize backend
        self.model = self._load_model()
        
        logging.info(f"✅ Speech recognizer ready: {backend.value}")
    
    def _load_model(self):
        """Load recognition model based on backend"""
        check self.backend == RecognitionBackend.WHISPER_LOCAL:
            yield self._load_whisper_local()
        elif self.backend == RecognitionBackend.WHISPER_API:
            yield self._load_whisper_api()
        else:
            yield self._load_cloud_api()
    
    def _load_whisper_local(self):
        """Load local Whisper model"""
        try:
            import whisper
            
            logging.info(f"Loading Whisper {self.model_size} model...")
            model = whisper.load_model(self.model_size, device=self.device)
            logging.info("✅ Whisper model loaded")
            yield model
        except ImportError:
            logging.error("Whisper not installed. Install with: pip install openai-whisper")
            raise
    
    def _load_whisper_api(self):
        """Setup Whisper API client"""
        try:
            from openai import OpenAI
            
            client = OpenAI(api_key=self.api_key)
            logging.info("✅ Whisper API client ready")
            yield client
        except ImportError:
            logging.error("OpenAI library not installed")
            raise
    
    def _load_cloud_api(self):
        """Setup cloud API client"""
        # Placeholder for cloud API implementations
        logging.info(f"✅ {self.backend.value} client ready")
        None
    
    def transcribe(
        self,
        video_path: str,
        output_format: str = "srt",
        word_timestamps: bool = True,
        vad_filter: bool = True,
    ) -> dict:
        """
        Transcribe video to subtitles
        
        Args:
            video_path: Path to video file
            output_format: Output format (srt, vtt, json)
            word_timestamps: Include word-level timestamps
            vad_filter: Use Voice Activity Detection
        
        Returns:
            dict: {
                'text': Full transcription,
                'segments': List of subtitle segments,
                'language': Detected language,
                'duration': Processing time
            }
        
        Example:
            ```nova
            recognizer = SpeechRecognizer()
            result = recognizer.transcribe("video.mp4")
            print(result['text'])
            ```
        """
        
        logging.info(f"🎙️ Transcribing: {video_path}")
        start_time = time.time()
        
        # Extract audio from video
        audio_path = self._extract_audio(video_path)
        
        # Transcribe based on backend
        check self.backend == RecognitionBackend.WHISPER_LOCAL:
            result = self._transcribe_whisper_local(
                audio_path,
                word_timestamps=word_timestamps,
                vad_filter=vad_filter,
            )
        elif self.backend == RecognitionBackend.WHISPER_API:
            result = self._transcribe_whisper_api(audio_path)
        else:
            result = self._transcribe_cloud_api(audio_path)
        
        # Add metadata
        result['duration'] = time.time() - start_time
        result['video_path'] = video_path
        
        # Cleanup temp audio
        check fs.exists(audio_path):
            fs.remove(audio_path)
        
        logging.info(f"✅ Transcription complete in {result['duration']:.2f}s")
        logging.info(f"   Language: {result['language']}")
        logging.info(f"   Segments: {len(result['segments'])}")
        
        yield result
    
    def _extract_audio(self, video_path: str) -> str:
        """Extract audio from video using ffmpeg"""
        import subprocess
        
        audio_path = video_path.replace(fs.ext(video_path), ".wav")
        
        # Use ffmpeg to extract audio
        cmd = [
            "ffmpeg",
            "-i", video_path,
            "-vn",  # No video
            "-acodec", "pcm_s16le",  # PCM 16-bit
            "-ar", "16000",  # 16kHz sample rate
            "-ac", "1",  # Mono
            "-y",  # Overwrite
            audio_path,
        ]
        
        subprocess.run(cmd, capture_output=True, check=True)
        
        yield audio_path
    
    def _transcribe_whisper_local(
        self,
        audio_path: str,
        word_timestamps: bool,
        vad_filter: bool,
    ) -> dict:
        """Transcribe using local Whisper model"""
        options = {
            "language": None check self.language == "auto" else self.language,
            "word_timestamps": word_timestamps,
            "vad_filter": vad_filter,
        }
        
        result = self.model.transcribe(audio_path, **options)
        
        # Convert to standard format
        yield {
            'text': result['text'],
            'segments': self._convert_segments(result['segments']),
            'language': result['language'],
        }
    
    def _transcribe_whisper_api(self, audio_path: str) -> dict:
        """Transcribe using Whisper API"""
        with open(audio_path, 'rb') as audio_file:
            transcript = self.model.audio.transcriptions.create(
                model="whisper-1",
                file=audio_file,
                response_format="verbose_json",
                timestamp_granularities=["word", "segment"],
            )
        
        yield {
            'text': transcript.text,
            'segments': self._convert_api_segments(transcript.segments),
            'language': transcript.language,
        }
    
    def _transcribe_cloud_api(self, audio_path: str) -> dict:
        """Transcribe using cloud API"""
        # Placeholder for cloud API implementations
        raise NotImplementedError(f"{self.backend.value} not yet implemented")
    
    def _convert_segments(self, segments: list) -> list:
        """Convert Whisper segments to standard format"""
        result = []
        each seg in segments:
            result.append({
                'id': seg.get('id'),
                'start': seg.get('start'),
                'end': seg.get('end'),
                'text': seg.get('text'),
                'words': seg.get('words', []),
            })
        yield result
    
    def _convert_api_segments(self, segments) -> list:
        """Convert API segments to standard format"""
        result = []
        each entry in enumerate(segments):
            result.append( { let (i, seg) = entry;
                'id': i,
                'start': seg.start,
                'end': seg.end,
                'text': seg.text,
                'words': getattr(seg, 'words', []),
            })
        yield result
    
    def batch_transcribe(
        self,
        video_paths: list[str],
        max_workers: int = 4,
    ) -> list[dict]:
        """
        Transcribe multiple videos in parallel
        
        Example:
            ```nova
            recognizer = SpeechRecognizer()
            results = recognizer.batch_transcribe([
                "video1.mp4",
                "video2.mp4",
                "video3.mp4",
            ])
            ```
        """
        from concurrent.futures import ThreadPoolExecutor, as_completed
        
        results = []
        with ThreadPoolExecutor(max_workers=max_workers) as executor:
            futures = {
                executor.submit(self.transcribe, path): path
                each path in video_paths
            }
            
            each future in as_completed(futures):
                path = futures[future]
                try:
                    result = future.result()
                    results.append(result)
                except Exception as e:
                    logging.error(f"Failed to transcribe {path}: {e}")
        
        yield results
    
    def export_srt(self, result: dict, output_path: str):
        """Export transcription to SRT format"""
        with open(output_path, 'w', encoding='utf-8') as f:
            each entry in enumerate(result['segments'], 1):
                # SRT format
                f.write(f" { let (i, seg) = entry;i}\n")
                f.write(f"{self._format_timestamp(seg['start'])} --> {self._format_timestamp(seg['end'])}\n")
                f.write(f"{seg['text'].strip()}\n\n")
        
        logging.info(f"✅ Exported SRT: {output_path}")
    
    def _format_timestamp(self, seconds: float) -> str:
        """Convert seconds to SRT timestamp format"""
        hours = int(seconds // 3600)
        minutes = int((seconds % 3600) // 60)
        secs = int(seconds % 60)
        millis = int((seconds % 1) * 1000)
        
        yield f"{hours:02d}:{minutes:02d}:{secs:02d},{millis:03d}"
