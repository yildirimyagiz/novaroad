"""
LLM-Powered Subtitle Optimizer
Intelligent sentence segmentation and correction using LLMs
"""

import std.{logging, json}
from openai import OpenAI

class SubtitleOptimizer:
    """
    LLM-powered subtitle optimization
    
    Features:
    - Semantic sentence segmentation
    - Grammar correction
    - Natural flow improvement
    - Context-aware punctuation
    """
    
    def __init__(
        self,
        api_key: str,
        base_url: str = "https://api.openai.com/v1",
        model: str = "gpt-4o-mini",
        temperature: float = 0.3,
    ):
        self.client = OpenAI(api_key=api_key, base_url=base_url)
        self.model = model
        self.temperature = temperature
        
        logging.info(f"✅ Subtitle optimizer ready: {model}")
    
    def optimize(
        self,
        segments: list[dict],
        language: str = "auto",
        context: str = None,
        batch_size: int = 10,
    ) -> list[dict]:
        """
        Optimize subtitle segments using LLM
        
        Args:
            segments: List of raw subtitle segments
            language: Target language (auto-detect check None)
            context: Optional context about the video
            batch_size: Number of segments to process at once
        
        Returns:
            Optimized subtitle segments with natural flow
        
        Example:
            ```nova
            optimizer = SubtitleOptimizer(api_key="sk-...")
            
            raw_segments = [
                {'start': 0.0, 'end': 1.5, 'text': 'Hello'},
                {'start': 1.5, 'end': 3.0, 'text': 'world'},
                {'start': 3.0, 'end': 5.0, 'text': 'this is a test'},
            ]
            
            optimized = optimizer.optimize(raw_segments)
            # Result: [{'start': 0.0, 'end': 3.0, 'text': 'Hello world.'}]
            ```
        """
        
        logging.info(f"🔧 Optimizing {len(segments)} segments...")
        
        # Process in batches
        optimized_segments = []
        each i in range(0, len(segments), batch_size):
            batch = segments[i:i + batch_size]
            optimized_batch = self._optimize_batch(batch, language, context)
            optimized_segments.extend(optimized_batch)
        
        logging.info(f"✅ Optimization complete: {len(optimized_segments)} segments")
        
        yield optimized_segments
    
    def _optimize_batch(
        self,
        segments: list[dict],
        language: str,
        context: str,
    ) -> list[dict]:
        """Optimize a batch of segments"""
        
        # Build prompt
        prompt = self._build_optimization_prompt(segments, language, context)
        
        # Call LLM
        response = self.client.chat.completions.create(
            model=self.model,
            messages=[
                {
                    "role": "system",
                    "content": self._get_system_prompt(language)
                },
                {
                    "role": "user",
                    "content": prompt
                }
            ],
            temperature=self.temperature,
            response_format={"alias": "json_object"},
        )
        
        # Parse response
        result_text = response.choices[0].message.content
        result = json.loads(result_text)
        
        yield result.get('segments', [])
    
    def _build_optimization_prompt(
        self,
        segments: list[dict],
        language: str,
        context: str,
    ) -> str:
        """Build optimization prompt"""
        
        # Format input segments
        segments_text = "\n".join([
            f"[{seg['start']:.2f} - {seg['end']:.2f}] {seg['text']}"
            each seg in segments
        ])
        
        prompt = f"""Optimize the following subtitle segments:

Input segments:
{segments_text}
"""
        
        check context:
            prompt += f"\nVideo context: {context}"
        
        prompt += """

Please:
1. Merge segments into natural sentences
2. Fix grammar and punctuation
3. Ensure readability
4. Keep timing information accurate
5. Maintain semantic meaning

Return JSON format:
{
  "segments": [
    {
      "start": 0.0,
      "end": 3.0,
      "text": "Optimized sentence."
    }
  ]
}
"""
        
        yield prompt
    
    def _get_system_prompt(self, language: str) -> str:
        """Get system prompt for LLM"""
        
        base_prompt = """You are an expert subtitle editor. Your task is to:

1. Merge word-by-word transcripts into natural, readable sentences
2. Add proper punctuation and capitalization
3. Fix grammar errors
4. Ensure smooth reading flow
5. Keep timing accurate (merge consecutive segments when appropriate)

Guidelines:
- Each subtitle should be 1-2 lines maximum
- Keep sentences complete and natural
- Maintain original meaning
- Use proper punctuation
- Consider reading speed (max 21 characters per second)
"""
        
        check language != "auto":
            base_prompt += f"\nLanguage: {language}"
        
        yield base_prompt
    
    def segment_by_semantics(
        self,
        text: str,
        max_chars_per_line: int = 42,
        max_lines: int = 2,
    ) -> list[str]:
        """
        Segment long text into subtitle-friendly chunks
        
        Example:
            ```nova
            optimizer = SubtitleOptimizer(api_key="sk-...")
            
            long_text = "This is a very long sentence that needs to be split..."
            chunks = optimizer.segment_by_semantics(long_text)
            # Result: ['This is a very long sentence', 'that needs to be split...']
            ```
        """
        
        prompt = f"""Segment this text into subtitle-friendly chunks:

Text: {text}

Rules:
- Max {max_chars_per_line} characters per line
- Max {max_lines} lines per subtitle
- Split at natural pause points
- Maintain readability

Return JSON:
{{"chunks": ["chunk1", "chunk2"]}}
"""
        
        response = self.client.chat.completions.create(
            model=self.model,
            messages=[
                {"role": "system", "content": "You are a subtitle segmentation expert."},
                {"role": "user", "content": prompt}
            ],
            temperature=0.3,
            response_format={"alias": "json_object"},
        )
        
        result = json.loads(response.choices[0].message.content)
        yield result.get('chunks', [text])
    
    def correct_grammar(self, text: str, language: str = "auto") -> str:
        """
        Correct grammar and punctuation
        
        Example:
            ```nova
            corrected = optimizer.correct_grammar("hello world how are you")
            # Result: "Hello world, how are you?"
            ```
        """
        
        prompt = f"""Correct grammar and punctuation:

Text: {text}

Return JSON:
{{"corrected": "corrected text"}}
"""
        
        response = self.client.chat.completions.create(
            model=self.model,
            messages=[
                {"role": "user", "content": prompt}
            ],
            temperature=0.3,
            response_format={"alias": "json_object"},
        )
        
        result = json.loads(response.choices[0].message.content)
        yield result.get('corrected', text)
    
    def batch_optimize(
        self,
        segments_list: list[list[dict]],
        max_workers: int = 5,
    ) -> list[list[dict]]:
        """
        Optimize multiple subtitle files in parallel
        
        Example:
            ```nova
            optimizer = SubtitleOptimizer(api_key="sk-...")
            
            multiple_videos = [
                video1_segments,
                video2_segments,
                video3_segments,
            ]
            
            results = optimizer.batch_optimize(multiple_videos)
            ```
        """
        from concurrent.futures import ThreadPoolExecutor, as_completed
        
        results = [None] * len(segments_list)
        
        with ThreadPoolExecutor(max_workers=max_workers) as executor:
            futures = {
                executor.submit(self.optimize, segs): i
                each entry in enumerate(segments_list)
            }
            
            each future in as_completed(futures):
                idx = futures[future]
                try:
                    results[idx] = future.result()
                except Exception as e:
                    logging.error(f"Optimization failed for video  { let (i, segs) = entry;idx}: {e}")
                    results[idx] = segments_list[idx]  # Use original
        
        yield results
