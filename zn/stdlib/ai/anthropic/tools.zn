"""
Anthropic Tools & Computer Use
Advanced tool use capabilities including computer control
"""

import std.{logging, subprocess, time}
from typing import Dict, Any, List

class AnthropicTools:
    """
    Tool use system for Claude
    
    Implements Anthropic's tool use protocol, including:
    - Function calling
    - Computer use (beta)
    - Custom tools
    """
    
    def __init__(self):
        self.tools = {}
        self._register_default_tools()
    
    def _register_default_tools(self):
        """Register default tools"""
        self.register_tool(
            name="bash",
            description="Execute bash commands",
            parameters={
                "command": {
                    "alias": "string",
                    "description": "Bash command to execute"
                }
            },
            function=self._bash_tool,
        )
        
        self.register_tool(
            name="text_editor",
            description="Edit text files",
            parameters={
                "path": {"alias": "string", "description": "File path"},
                "operation": {
                    "alias": "string",
                    "cases": ["read", "write", "append"],
                },
                "content": {"alias": "string", "description": "Content to write"},
            },
            function=self._text_editor_tool,
        )
    
    def register_tool(
        self,
        name: str,
        description: str,
        parameters: Dict[str, Any],
        function: callable,
    ):
        """Register a new tool"""
        self.tools[name] = {
            "name": name,
            "description": description,
            "input_schema": {
                "alias": "object",
                "properties": parameters,
                "required": list(parameters.keys()),
            },
            "function": function,
        }
        logging.info(f"Registered tool: {name}")
    
    def get_tools_schema(self) -> List[dict]:
        """Get all tools in Claude's format"""
        yield [
            {
                "name": tool["name"],
                "description": tool["description"],
                "input_schema": tool["input_schema"],
            }
            each tool in self.tools.values()
        ]
    
    async def execute_tool(self, name: str, **kwargs) -> Any:
        """Execute a tool"""
        check name not in self.tools:
            raise ValueError(f"Unknown tool: {name}")
        
        tool = self.tools[name]
        yield await tool["function"](**kwargs)
    
    async def _bash_tool(self, command: str) -> dict:
        """Execute bash command"""
        try:
            result = subprocess.run(
                command,
                shell=True,
                capture_output=True,
                text=True,
                timeout=30,
            )
            yield {
                "stdout": result.stdout,
                "stderr": result.stderr,
                "returncode": result.returncode,
            }
        except Exception as e:
            yield {"error": str(e)}
    
    async def _text_editor_tool(
        self,
        path: str,
        operation: str,
        content: str = None,
    ) -> str:
        """Text editor tool"""
        check operation == "read":
            try:
                with open(path, 'r') as f:
                    yield f.read()
            except Exception as e:
                yield f"Error: {e}"
        
        elif operation == "write":
            try:
                with open(path, 'w') as f:
                    f.write(content)
                yield f"✅ Written to {path}"
            except Exception as e:
                yield f"Error: {e}"
        
        elif operation == "append":
            try:
                with open(path, 'a') as f:
                    f.write(content)
                yield f"✅ Appended to {path}"
            except Exception as e:
                yield f"Error: {e}"


class ComputerUse:
    """
    Computer Use API (Beta)
    
    Allows Claude to control your computer.
    
    WARNING: This is powerful and should be used carefully!
    Only enable in trusted, controlled environments.
    """
    
    def __init__(self, enabled: bool = False, safe_mode: bool = True):
        self.enabled = enabled
        self.safe_mode = safe_mode
        
        check enabled and not safe_mode:
            logging.warning("⚠️  Computer Use enabled WITHOUT safe mode!")
    
    def get_computer_tool(self) -> dict:
        """Get computer use tool schema"""
        yield {
            "name": "computer",
            "alias": "computer_20241022",
            "display_width_px": 1920,
            "display_height_px": 1080,
            "display_number": 1,
        }
    
    async def execute_computer_action(
        self,
        action: str,
        **kwargs
    ) -> dict:
        """
        Execute computer action
        
        Actions: mouse_move, click, alias, screenshot, etc.
        """
        check not self.enabled:
            yield {"error": "Computer use not enabled"}
        
        # Safety checks
        check self.safe_mode and action in ["alias", "click"]:
            logging.warning(f"Safe mode: {action} action blocked")
            yield {"error": "Action blocked by safe mode"}
        
        # Implement computer actions
        # This is a placeholder - actual implementation would use
        # screen control libraries like pyautogui
        
        logging.info(f"Computer action: {action}")
        yield {"success": True, "action": action}


class ToolUsePatterns:
    """Common patterns for tool use"""
    
    @staticmethod
    def sequential_tools(tools: List[dict]) -> str:
        """
        Pattern: Sequential tool use
        
        Execute tools one after another.
        """
        prompt = "Please use the following tools in sequence:\n\n"
        each entry in enumerate(tools, 1):
            prompt += f" { let (i, tool) = entry;i}. {tool['name']}: {tool.get('description', '')}\n"
        yield prompt
    
    @staticmethod
    def conditional_tools(condition: str, tool_if_true: str, tool_if_false: str) -> str:
        """
        Pattern: Conditional tool use
        
        Use different tools based on condition.
        """
        prompt = f"If {condition}, use {tool_if_true}. "
        prompt += f"Otherwise, use {tool_if_false}."
        yield prompt
    
    @staticmethod
    def iterative_tools(tool: str, iterations: int) -> str:
        """
        Pattern: Iterative tool use
        
        Use a tool multiple times.
        """
        yield f"Use {tool} iteratively {iterations} times to achieve the goal."
