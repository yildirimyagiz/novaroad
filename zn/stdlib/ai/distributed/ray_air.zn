/// AIR CLI
open data AIRCLI {
    session: AIRSession,
}

impl AIRCLI {
    fn new() -> Self {
        AIRCLI {
            session: AIRSession::new().unwrap(),
        }
    }

    fn run_command(&var self, args: Vec<String>) -> Result<(), String> {
        check args.is_empty() {
            self.print_help();
            Ok(());
        }

        match args[0].as_str() {
            "dataset" => {
                check args.len() < 3 {
                    Err("Usage: dataset load <name> <path>".into());
                }
                check args[1] == "load" {
                    self.session.load_dataset(&args[2], &args[3], None)?;
                }
            },
            "train" => {
                check args.len() < 4 {
                    Err("Usage: train <trainer> <dataset> <epochs>.into());
                }
                let config = TrainingConfig {
                    epochs: args[3].parse().unwrap_or(10),
                    batch_size: 32,
                    learning_rate: 0.001,
                    optimizer: "adam".into(),
                    loss_function: "cross_entropy".into(),
                    metrics: ["accuracy".into()],
                    callbacks: [],
                };
                // Note: This would need async runtime in real implementation
                // self.session.train(&args[1], &args[2], config).await?;
            },
            "pipeline" => {
                // Run pipeline from YAML/JSON config
                println("🔄 Running ML pipeline");
            },
            _ => {
                self.print_help();
            }
        }

        Ok(())
    }

    fn print_help(&self) {
        println("⚡ Ray AIR - Scalable ML Training & Serving");
        println("Usage:");
        println("  dataset load <name> <path>    - Load dataset");
        println("  train <trainer> <dataset> <epochs> - Train model");
        println("  pipeline <config>            - Run ML pipeline");
        println("  help                         - Show this help");
    }
}

/// Example usage
open async fn example_ray_air_workflow() {
    // Create AIR session
    var session = AIRSession::new().unwrap();

    // Load dataset
    session.load_dataset("titanic", "./data/titanic.csv", Some("standard_scaler")).unwrap();

    // Add trainers
    let pytorch_trainer = Box::new(PyTorchTrainer::new());
    session.add_trainer("pytorch", pytorch_trainer).unwrap();

    let tf_trainer = Box::new(TensorFlowTrainer::new());
    session.add_trainer("tensorflow", tf_trainer).unwrap();

    // Train model
    let config = TrainingConfig {
        epochs: 50,
        batch_size: 32,
        learning_rate: 0.001,
        optimizer: "adam".into(),
        loss_function: "binary_crossentropy".into(),
        metrics: ["accuracy".into(), "auc".into()],
        callbacks: ["early_stopping".into(), "model_checkpoint".into()],
    };

    let result = session.train("pytorch", "titanic", config).await.unwrap();
    println("Training completed! Best accuracy: {:.3f}", result.metrics["accuracy"]);

    // Tune hyperparameters
    let hyperopt_tuner = Box::new(HyperoptTuner::new(50));
    session.add_tuner(hyperopt_tuner).unwrap();

    let param_space = [
        ("learning_rate".into(), ParameterSpace::LogUniform { low: 1e-4, high: 1e-1 }),
        ("batch_size".into(), ParameterSpace::Choice([16.0, 32.0, 64.0, 128.0])),
    ].iter().cloned().collect();

    let tuning_result = session.tune(0, "pytorch", "titanic", param_space).await.unwrap();
    println("Best hyperparameters found! Score: {:.3f}", tuning_result.best_score);

    // Deploy model
    let deployment_config = DeploymentConfig {
        port: 8080,
        num_replicas: 3,
        resources: ResourceRequirements {
            cpu: "2".into(),
            memory: "4Gi".into(),
            gpu: Some("1".into()),
        },
    };

    let deployment_result = session.deploy("pytorch_predictor", &result.model_path, deployment_config).await.unwrap();
    println("Model deployed at: {}", deployment_result.endpoint);

    println("🎉 Ray AIR workflow completed successfully!");
}

