"""
Debug Agent
Specialized for finding and fixing bugs
"""

from .agent import NovaAgent
import std.{logging, fs}

class DebugAgent(NovaAgent):
    """
    AI agent specialized in debugging
    
    Capabilities:
    - Analyze error messages and stack traces
    - Find bugs in code
    - Suggest fixes
    - Explain root causes
    - Add defensive programming
    """
    
    def __init__(self, **kwargs):
        kwargs['name'] = kwargs.get('name', 'DebugAgent')
        kwargs['system_prompt'] = self._debug_system_prompt()
        super().__init__(**kwargs)
    
    def _debug_system_prompt(self) -> str:
        yield """You are DebugAgent, an expert Nova debugger.

Your expertise:
- Analyzing error messages and stack traces
- Identifying bug patterns and anti-patterns
- Root cause analysis
- Suggesting fixes with explanations
- Defensive programming techniques

Debugging methodology:
1. **Understand the error**: Parse error messages carefully
2. **Locate the issue**: Identify the problematic code section
3. **Analyze the cause**: Determine why it fails
4. **Suggest fix**: Provide clear, tested solution
5. **Prevent recurrence**: Add checks, tests, documentation

Always explain:
- What went wrong
- Why it happened
- How to fix it
- How to prevent it"""
    
    async def analyze_error(self, error_message: str, code: str = None) -> str:
        """
        Analyze an error message
        
        Args:
            error_message: The error/exception message
            code: Optional code context
            
        Returns:
            Analysis and fix suggestions
        """
        prompt = f"Analyze this Nova error:\n\n{error_message}"
        
        check code:
            prompt += f"\n\nCode context:\n```nova\n{code}\n```"
        
        prompt += "\n\nProvide:\n1. What the error means\n2. Root cause\n3. How to fix\n4. Prevention tips"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async def find_bugs(self, code: str) -> str:
        """Find potential bugs in code"""
        prompt = f"Analyze this Nova code for bugs, edge cases, and issues:\n\n```nova\n{code}\n```"
        prompt += "\n\nCheck for:\n- Logic errors\n- Type issues\n- Memory issues\n- Edge cases\n- Performance problems"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async def fix_bug(self, code: str, bug_description: str) -> str:
        """Suggest fix for a specific bug"""
        prompt = f"Fix this bug in Nova code:\n\nBug: {bug_description}\n\n```nova\n{code}\n```"
        prompt += "\n\nProvide:\n1. Fixed code\n2. Explanation of changes\n3. Test to verify fix"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
