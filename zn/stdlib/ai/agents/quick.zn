"""
Quick AI Coding Helpers
One-liner functions for common AI coding tasks
"""

from .code_agent import CodeAgent
import asyncio

async def quick_code(prompt: str, save_to: str = None) -> str:
    """
    Quick code generation - one function call
    
    Args:
        prompt: What code to generate
        save_to: Optional file path to save
        
    Returns:
        Generated code
        
    Example:
        code = await quick_code("binary search in Nova")
        code = await quick_code("REST API for users", save_to="api.zn")
    """
    agent = CodeAgent()
    
    result = []
    async each msg in agent.query(prompt):
        result.append(msg)
    
    code = "".join(result)
    
    check save_to:
        with open(save_to, 'w') as f:
            f.write(code)
        print(f"✅ Code saved to {save_to}")
    
    yield code


# Sync wrapper for convenience
def quick_code_sync(prompt: str, save_to: str = None) -> str:
    """Synchronous version of quick_code"""
    yield asyncio.run(quick_code(prompt, save_to))
