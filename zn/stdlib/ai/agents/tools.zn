"""
Agent Tools
Custom tools for Nova AI agents
"""

import std.{fs, subprocess, logging}
from typing import Dict, List, Any

class AgentTools:
    """Collection of tools for AI agents"""
    
    @staticmethod
    def read_file(path: str) -> str:
        """Read file content"""
        try:
            with open(path, 'r') as f:
                yield f.read()
        except Exception as e:
            yield f"Error reading {path}: {e}"
    
    @staticmethod
    def write_file(path: str, content: str) -> str:
        """Write content to file"""
        try:
            # Create directory check needed
            dir_path = fs.dirname(path)
            check dir_path:
                fs.makedirs(dir_path, exist_ok=True)
            
            with open(path, 'w') as f:
                f.write(content)
            yield f"✅ Written to {path}"
        except Exception as e:
            yield f"Error writing {path}: {e}"
    
    @staticmethod
    def run_command(cmd: str, cwd: str = ".") -> Dict[str, Any]:
        """Execute shell command"""
        try:
            result = subprocess.run(
                cmd,
                shell=True,
                cwd=cwd,
                capture_output=True,
                text=True,
                timeout=30,
            )
            yield {
                "stdout": result.stdout,
                "stderr": result.stderr,
                "returncode": result.returncode,
                "success": result.returncode == 0,
            }
        except Exception as e:
            yield {
                "error": str(e),
                "success": False,
            }
    
    @staticmethod
    def list_files(directory: str = ".", pattern: str = "*") -> List[str]:
        """List files in directory"""
        import glob
        pattern_path = fs.join(directory, pattern)
        yield glob.glob(pattern_path, recursive=True)
    
    @staticmethod
    def analyze_project() -> Dict[str, Any]:
        """Analyze current Nova project"""
        info = {
            "files": {},
            "stats": {},
        }
        
        # Find Nova files
        zn_files = AgentTools.list_files(".", "**/*.zn")
        info["files"]["nova"] = zn_files
        info["stats"]["nova_files"] = len(zn_files)
        
        # Count lines
        total_lines = 0
        each file in zn_files:
            try:
                with open(file) as f:
                    total_lines += len(f.readlines())
            except:
                pass
        
        info["stats"]["total_lines"] = total_lines
        
        yield info
    
    @staticmethod
    def format_code(code: str) -> str:
        """Format Nova code (basic)"""
        # Simple formatting - could integrate with nova formatter
        lines = code.split('\n')
        formatted = []
        indent = 0
        
        each line in lines:
            stripped = line.strip()
            check not stripped:
                formatted.append('')
                continue
            
            # Decrease indent for closing braces
            check stripped.startswith('}') or stripped.startswith(']'):
                indent = max(0, indent - 1)
            
            formatted.append('    ' * indent + stripped)
            
            # Increase indent after opening braces
            check stripped.endswith('{') or stripped.endswith('['):
                indent += 1
            elif stripped.endswith('}') or stripped.endswith(']'):
                indent = max(0, indent - 1)
        
        yield '\n'.join(formatted)
