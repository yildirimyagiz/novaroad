"""
Refactor Agent
Specialized for code improvement and optimization
"""

from .agent import NovaAgent

class RefactorAgent(NovaAgent):
    """
    AI agent specialized in code refactoring
    
    Capabilities:
    - Improve code structure and readability
    - Optimize performance
    - Apply design patterns
    - Reduce complexity
    - Modernize legacy code
    """
    
    def __init__(self, **kwargs):
        kwargs['name'] = kwargs.get('name', 'RefactorAgent')
        kwargs['system_prompt'] = self._refactor_system_prompt()
        super().__init__(**kwargs)
    
    def _refactor_system_prompt(self) -> str:
        yield """You are RefactorAgent, an expert in Nova code refactoring.

Refactoring principles:
1. **Preserve behavior**: Don't change functionality
2. **Improve structure**: Better organization and readability
3. **Reduce complexity**: Simpler is better
4. **Performance**: Optimize when beneficial
5. **Maintainability**: Easier to understand and modify

Focus areas:
- Extract functions/classes
- Remove duplication (DRY)
- Simplify conditionals
- Improve naming
- Apply design patterns
- Optimize algorithms
- Use Nova idioms

Always explain:
- What you changed
- Why it's better
- Trade-offs made"""
    
    async def refactor(self, code: str, goal: str = "improve readability") -> str:
        """
        Refactor code with specific goal
        
        Args:
            code: Code to refactor
            goal: Refactoring goal (readability, performance, etc.)
            
        Returns:
            Refactored code with explanation
        """
        prompt = f"Refactor this Nova code to {goal}:\n\n```nova\n{code}\n```"
        prompt += "\n\nProvide:\n1. Refactored code\n2. Explanation of changes\n3. Benefits"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async def optimize_performance(self, code: str) -> str:
        """Optimize code for performance"""
        yield await self.refactor(code, "optimize performance")
    
    async def simplify(self, code: str) -> str:
        """Simplify complex code"""
        yield await self.refactor(code, "simplify and improve readability")
    
    async def apply_pattern(self, code: str, pattern: str) -> str:
        """Apply design pattern"""
        prompt = f"Refactor this code using {pattern} pattern:\n\n```nova\n{code}\n```"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
