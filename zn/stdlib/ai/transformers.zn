data T5Model {}
impl T5Model {
    fn from_config(config: TransformerConfig, weights: Map<str, Tensor<f32>>) -> TransformerModel {
        TransformerModel {
            config: config,
            embeddings: EmbeddingLayer::new(config.vocab_size, config.hidden_size, 
                                           config.max_position_embeddings, 1, 0.1),
            encoder_layers: [],
            decoder_layers: [],
            device: Device::CPU
        };
    }
}
