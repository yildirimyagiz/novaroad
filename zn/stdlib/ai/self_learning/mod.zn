open space core;
open space weight_generator;
open space meta_learner;
open space continuous_pipeline;
open space nas;
open space goodhart_protection;
open space self_critique;
open space formal_core;
open space integrated_system;

open use core::*;
open use weight_generator::*;
open use meta_learner::*;
open use continuous_pipeline::*;
open use nas::*;
open use goodhart_protection::*;
open use self_critique::*;
open use formal_core::*;
open use integrated_system::*;

// ═══════════════════════════════════════════════════════════════════════════════
// §1  TYPES
// ═══════════════════════════════════════════════════════════════════════════════

open cases ModelSize {
    Tiny,    // ~30M params
    Small,   // ~120M params
    Medium,  // ~350M params
    Large,   // ~800M params
}

open data ModelConfig {
    open n_layers:   i64,
    open d_model:    i64,
    open n_heads:    i64,
    open vocab_size: i64,
}

// ═══════════════════════════════════════════════════════════════════════════════
// §2  QUICK START ENGINE
// ═══════════════════════════════════════════════════════════════════════════════

open fn create_self_learning_model(name: &str, size: ModelSize) -> SelfLearningSystem {
    let config = match size {
        ModelSize::Tiny => ModelConfig {
            n_layers:   6,
            d_model:    384,
            n_heads:    6,
            vocab_size: 50257,
        },
        ModelSize::Small => ModelConfig {
            n_layers:   12,
            d_model:    768,
            n_heads:    12,
            vocab_size: 50257,
        },
        ModelSize::Medium => ModelConfig {
            n_layers:   24,
            d_model:    1024,
            n_heads:    16,
            vocab_size: 50257,
        },
        ModelSize::Large => ModelConfig {
            n_layers:   36,
            d_model:    1280,
            n_heads:    20,
            vocab_size: 50257,
        },
    };
    
    yield SelfLearningSystem::new(config);
}
