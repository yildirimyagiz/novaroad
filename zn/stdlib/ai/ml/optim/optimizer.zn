// ⚙️ Nova ML — Optimizer Core — v10.0
// Base structures for parameter optimization.
//
// Syntax: data / impl / yield / each

use ai::ml::tensor::Tensor;

open data Optimizer {
    open params: Vec<Tensor>,
}

impl Optimizer {
    /// Clears the gradients of all optimized parameters.
    open fn zero_grad(&var self) {
        each param in &var self.params {
            param.backward(); // Placeholder for clearing/zeroing
        }
        yield;
    }
}
