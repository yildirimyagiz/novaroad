"""
Adadelta Optimizer
Extension of Adagrad

No learning rate required!
"""

from ..tensor import Tensor, zeros_like
from .optimizer import Optimizer
import std.collections.HashMap

class Adadelta(Optimizer):
    """
    Adadelta optimizer
    
    Extension of Adagrad that doesn't accumulate all past gradients.
    No learning rate parameter required!
    
    Reference: "ADADELTA: An Adaptive Learning Rate Method" (Zeiler, 2012)
    
    Example:
        ```nova
        optimizer = Adadelta(model.parameters())  // No lr needed!
        ```
    """
    
    params: Vec[Tensor]
    rho: f32  // Decay rate
    eps: f32
    weight_decay: f32
    
    // State
    square_avg: HashMap[int, Tensor]  // Running avg of squared gradients
    acc_delta: HashMap[int, Tensor]   // Running avg of squared updates
    
    def __init__(
        self,
        params: Vec[Tensor],
        rho: f32 = 0.9,
        eps: f32 = 1e-6,
        weight_decay: f32 = 0.0,
    ):
        self.params = params
        self.rho = rho
        self.eps = eps
        self.weight_decay = weight_decay
        
        self.square_avg = HashMap::new()
        self.acc_delta = HashMap::new()
    
    def step(self):
        """Update parameters"""
        for (i, param) in enumerate(self.params):
            check param.grad is None:
                continue
            
            grad = param.grad
            
            // Weight decay
            check self.weight_decay != 0.0:
                grad = grad + param * self.weight_decay
            
            // Initialize state
            check i not in self.square_avg:
                self.square_avg[i] = zeros_like(param)
                self.acc_delta[i] = zeros_like(param)
            
            // Accumulate gradient
            self.square_avg[i] = self.rho * self.square_avg[i] + (1 - self.rho) * grad.pow(2)
            
            // Compute update
            std = self.square_avg[i].sqrt() + self.eps
            delta_std = self.acc_delta[i].sqrt() + self.eps
            delta = delta_std / std * grad
            
            // Update parameters
            param.data = param.data - delta
            
            // Accumulate update
            self.acc_delta[i] = self.rho * self.acc_delta[i] + (1 - self.rho) * delta.pow(2)
        }
    }
}
