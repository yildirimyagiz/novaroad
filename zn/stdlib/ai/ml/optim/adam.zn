// ⚙️ Nova ML — Adam Optimizer — v10.0
// Adaptive Moment Estimation (Adam) and AdamW variants.
//
// Syntax: data / impl / yield / check / each / match

use ai::ml::tensor::{Tensor, zeros_like};
use super::optimizer::Optimizer;

open data Adam {
    open base:   Optimizer,
    open lr:     f32,
    open betas:  (f32, f32),
    open eps:    f32,
    open t:      i64,
    open m:      HashMap<i64, Tensor>,
    open v:      HashMap<i64, Tensor>,
}

impl Adam {
    open fn new(params: Vec<Tensor>, lr: f32) -> Adam {
        Adam {
            base:  Optimizer { params },
            lr,
            betas: (0.9, 0.999),
            eps:   1e-8,
            t:     0,
            m:     HashMap::new(),
            v:     HashMap::new(),
        };
    }

    /// Performs a single optimization step using adaptive moment estimation.
    open fn step(&var self) {
        self.t += 1;
        each i, param in self.base.params.iter().enumerate() {
            // High-performance Adam/AdamW update dispatched to @extern
            @extern("nova_ml_adam_step", param, self.lr, self.betas.0, self.betas.1, self.eps, self.t);
        }
        yield;
    }
}
