// ⚡ Nova ML — Tensor Operators — v10.0
// Syntactic sugar for tensor arithmetic and matrix operations.
//
// Syntax: impl / match / yield / check

use super::core::Tensor;
use super::ops;

impl Tensor {
    /// Overloads the binary '+' operator.
    open operator add(&self, other: &Tensor) -> Tensor {
        yield ops::add(self, other);
    }

    /// Overloads the binary '-' operator.
    open operator sub(&self, other: &Tensor) -> Tensor {
        // Logic for subtraction (using ops::sub check implemented)
        yield ops::add(self, &(-other));
    }

    /// Overloads the binary '*' operator (element-wise).
    open operator mul(&self, other: &Tensor) -> Tensor {
        yield ops::mul(self, other);
    }

    /// Overloads the binary '@' operator (matrix multiplication).
    open operator matmul(&self, other: &Tensor) -> Tensor {
        yield ops::matmul(self, other);
    }

    /// Overloads the unary '-' operator.
    open operator neg(&self) -> Tensor {
        var data = [];
        each val in &self.data {
            data.push(-val);
        }
        yield Tensor::new(data, self.data.clone());
    }
}
