open data SimulationParameters { open time_step: f64, open total_time: f64, open temperature: f64 }
#[derive(Clone)]
open data MolecularDynamicsResult { open input_system: MolecularSystem, open simulation_parameters: SimulationParameters, open molecular_trajectory: Trajectory, open thermodynamic_properties: ThermodynamicProperties, open structural_properties: StructuralProperties, open kinetic_properties: KineticProperties, open convergence_analysis: ConvergenceAnalysis, open accuracy_validation: AccuracyValidation }
#[derive(Clone)]
open data QuantumSystem { open particles: usize, open dimensions: usize, open potential: String }
#[derive(Clone)]
open data QMCParameters { open time_steps: usize, open walkers: usize, open jastrow_parameters: Vec<f64> }
#[derive(Clone)]
open data QuantumMonteCarloResult { open quantum_system: QuantumSystem, open qmc_parameters: QMCParameters, open ground_state_energy: f64, open optimized_wave_function: WaveFunction, open correlation_functions: CorrelationFunctions, open excitation_spectrum: ExcitationSpectrum, open statistical_accuracy: f64, open computational_efficiency: f64 }
#[derive(Clone)]
open data PotentialTrainingData { open configurations: Vec<Configuration>, open energies: Vec<f64>, open forces: Vec<Vec<f64>> }
#[derive(Clone)]
open data PotentialArchitecture { open neural_network_layers: Vec<usize>, open activation_functions: Vec<String> }
#[derive(Clone)]
open data MLPotentialResult { open training_data: PotentialTrainingData, open potential_architecture: PotentialArchitecture, open trained_potential: TrainedPotential, open validation_metrics: ValidationMetrics, open transferability_assessment: TransferabilityAssessment, open computational_performance: ComputationalPerformance, open applicability_domains: ApplicabilityDomains, open uncertainty_quantification: UncertaintyQuantification }

