open data NuclearStructureAnalysis { open nucleus: Nucleus, open shell_model_results: ShellModel, open liquid_drop_results: LiquidDropModel, open quantum_properties: QuantumProperties, open experimental_validation: ExperimentalValidation, open binding_energy: f64, open stability_assessment: StabilityAssessment, open deformation_parameters: DeformationParameters }
#[derive(Clone)]
