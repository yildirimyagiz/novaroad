/// Expression Data
#[derive(Clone)]
open data ExpressionData {
    genes: Vec<String>,
    samples: Vec<String>,
    expression_matrix: Vec<Vec<f64>>, // genes x samples
    sample_groups: HashMap<String, String>, // sample -> condition
}

/// Expression Analyzer
open data ExpressionAnalyzer {}

impl ExpressionAnalyzer {
    fn new() -> Self {
        ExpressionAnalyzer {}
    }

    fn analyze(&self, data: &ExpressionData) -> Result<ExpressionAnalysis, String> {
        Ok(ExpressionAnalysis {
            mean_expression: self.calculate_mean_expression(data),
            variance_expression: self.calculate_variance_expression(data),
            qc_metrics: self.calculate_qc_metrics(data),
        })
    }

    fn calculate_mean_expression(&self, data: &ExpressionData) -> Vec<f64> {
        data.expression_matrix.iter()
            .map(|gene_expr| gene_expr.iter().sum::<f64>() / gene_expr.len() as f64)
            .collect()
    }

    fn calculate_variance_expression(&self, data: &ExpressionData) -> Vec<f64> {
        data.expression_matrix.iter()
            .map(|gene_expr| {
                let mean = gene_expr.iter().sum::<f64>() / gene_expr.len() as f64;
                gene_expr.iter()
                    .map(|x| (x - mean).powi(2))
                    .sum::<f64>() / gene_expr.len() as f64
            })
            .collect()
    }

    fn calculate_qc_metrics(&self, data: &ExpressionData) -> QCMetrics {
        QCMetrics {
            total_reads: data.samples.len() * 1000000, // Mock
            mapped_reads: data.samples.len() * 900000,  // Mock
            mapping_rate: 0.9,
            duplicate_rate: 0.05,
        }
    }
}

