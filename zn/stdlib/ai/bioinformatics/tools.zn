/// Peptide Analyzer
open data PeptideAnalyzer {}

impl PeptideAnalyzer {
    fn new() -> Self {
        PeptideAnalyzer {}
    }

    fn analyze_peptide(&self, peptide: &str) -> Result<PeptideAnalysis, String> {
        Ok(PeptideAnalysis {
            sequence: peptide.into(),
            length: peptide.len(),
            molecular_weight: self.calculate_mw(peptide),
            isoelectric_point: self.calculate_pi(peptide),
            hydrophobicity: self.calculate_hydrophobicity(peptide),
        })
    }

    fn calculate_mw(&self, peptide: &str) -> f64 {
        // Simplified molecular weight calculation
        peptide.chars().map(|aa| match aa {
            'A' => 89.0,
            'R' => 174.0,
            'N' => 132.0,
            'D' => 133.0,
            'C' => 121.0,
            'Q' => 146.0,
            'E' => 147.0,
            'G' => 75.0,
            'H' => 155.0,
            'I' => 131.0,
            'L' => 131.0,
            'K' => 146.0,
            'M' => 149.0,
            'F' => 165.0,
            'P' => 115.0,
            'S' => 105.0,
            'T' => 119.0,
            'W' => 204.0,
            'Y' => 181.0,
            'V' => 117.0,
            _ => 110.0, // Average
        }).sum::<f64>() + 18.0 // Add water
    }

    fn calculate_pi(&self, peptide: &str) -> f64 {
        // Simplified isoelectric point calculation
        7.0 // Neutral
    }

    fn calculate_hydrophobicity(&self, peptide: &str) -> f64 {
        // Simplified hydrophobicity calculation
        peptide.chars().map(|aa| match aa {
            'I' | 'V' | 'L' | 'F' | 'C' | 'M' | 'A' => 1.0,
            'G' | 'T' | 'S' | 'W' | 'Y' | 'P' | 'H' => 0.0,
            'E' | 'Q' | 'D' | 'N' | 'K' | 'R' => -1.0,
            _ => 0.0,
        }).sum::<f64>() / peptide.len() as f64
    }
}

