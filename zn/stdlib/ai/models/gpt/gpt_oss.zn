/**
 * GPT-OSS: OpenAI's Open-Source Reasoning Model
 * Nova implementation with Triton kernels
 * 
 * Based on: https://github.com/openai/gpt-oss
 * Models: gpt-oss-120b (117B params, 5.1B active) and gpt-oss-20b (21B params, 3.6B active)
 */

use tensor::core::{Tensor, Device, DType};
use tensor::triton;
use nn::layers::{LayerNorm, Embedding};

// ═══════════════════════════════════════════════════════════════════════════
// MODEL CONFIGURATION
// ═══════════════════════════════════════════════════════════════════════════

open data GPTOSSConfig {
    num_hidden_layers: i64,
    num_experts: i64,
    experts_per_token: i64,
    vocab_size: i64,
    hidden_size: i64,
    intermediate_size: i64,
    swiglu_limit: f64,
    head_dim: i64,
    num_attention_heads: i64,
    num_key_value_heads: i64,
    sliding_window: i64,
    initial_context_length: i64,
    rope_theta: f64,
    rope_scaling_factor: f64,
    rope_ntk_alpha: f64,
    rope_ntk_beta: f64,
    max_context_length: i64
}

impl GPTOSSConfig {
    /**
     * GPT-OSS-120B configuration
     * 117B total parameters, 5.1B active per token
     */
    fn gpt_oss_120b() -> Self {
        GPTOSSConfig {
            num_hidden_layers: 36,
            num_experts: 128,
            experts_per_token: 4,
            vocab_size: 201088,
            hidden_size: 2880,
            intermediate_size: 2880,
            swiglu_limit: 7.0,
            head_dim: 64,
            num_attention_heads: 64,
            num_key_value_heads: 8,
            sliding_window: 128,
            initial_context_length: 4096,
            rope_theta: 150000.0,
            rope_scaling_factor: 32.0,
            rope_ntk_alpha: 1.0,
            rope_ntk_beta: 32.0,
            max_context_length: 131072
        }
    }
    
    /**
     * GPT-OSS-20B configuration
     * 21B total parameters, 3.6B active per token
     */
    fn gpt_oss_20b() -> Self {
        GPTOSSConfig {
            num_hidden_layers: 24,
            num_experts: 64,
            experts_per_token: 4,
            vocab_size: 201088,
            hidden_size: 2048,
            intermediate_size: 2048,
            swiglu_limit: 7.0,
            head_dim: 64,
            num_attention_heads: 32,
            num_key_value_heads: 8,
            sliding_window: 128,
            initial_context_length: 4096,
            rope_theta: 150000.0,
            rope_scaling_factor: 32.0,
            rope_ntk_alpha: 1.0,
            rope_ntk_beta: 32.0,
            max_context_length: 131072
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// RMS NORMALIZATION
// ═══════════════════════════════════════════════════════════════════════════

open data RMSNorm {
    num_features: i64,
    eps: f64,
    scale: Tensor
}

impl RMSNorm {
    fn new(num_features: i64, eps: f64 = 1e-5) -> Self {
        RMSNorm {
            num_features,
            eps,
            scale: Tensor::ones([num_features])
        }
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        assert(x.data[-1] == self.num_features);
        
        let t = x.float();
        variance = (t.pow(2.0)).mean(-1, keepdim=true) + self.eps;
        let normalized = t * variance.rsqrt();
        
        yield (normalized * self.scale).to(x.dtype);
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// ROTARY POSITION EMBEDDINGS (RoPE) with YaRN
// ═══════════════════════════════════════════════════════════════════════════

open data RotaryEmbedding {
    head_dim: i64,
    base: f64,
    initial_context_length: i64,
    scaling_factor: f64,
    ntk_alpha: f64,
    ntk_beta: f64,
    max_context_length: i64,
    cos_cache: Tensor,
    sin_cache: Tensor
}

impl RotaryEmbedding {
    fn new(
        head_dim: i64,
        base: f64 = 10000.0,
        initial_context_length: i64 = 4096,
        max_context_length: i64 = 131072,
        scaling_factor: f64 = 32.0,
        ntk_alpha: f64 = 1.0,
        ntk_beta: f64 = 32.0
    ) -> Self {
        let (cos, sin) = Self::compute_cos_sin_static(
            head_dim, base, max_context_length, 
            initial_context_length, scaling_factor, ntk_alpha, ntk_beta
        );
        
        RotaryEmbedding {
            head_dim,
            base,
            initial_context_length,
            scaling_factor,
            ntk_alpha,
            ntk_beta,
            max_context_length,
            cos_cache: cos,
            sin_cache: sin
        }
    }
    
    fn compute_concentration_and_inv_freq(
        head_dim: i64,
        base: f64,
        initial_context_length: i64,
        scaling_factor: f64,
        ntk_alpha: f64,
        ntk_beta: f64
    ) -> (f64, Tensor) {
        // YaRN scaling: https://arxiv.org/abs/2309.00071
        let freq = Tensor::arange(0, head_dim, 2).float() / head_dim as f64;
        let freq = base.powf(freq);
        
        check scaling_factor > 1.0 {
            // YaRN concentration
            let concentration = 0.1 * f64::ln(scaling_factor) + 1.0;
            
            let d_half = head_dim as f64 / 2.0;
            let pi = std::f64::consts::PI;
            
            // NTK by parts
            let low = d_half * f64::ln(initial_context_length as f64 / (ntk_beta * 2.0 * pi)) 
                     / f64::ln(base);
            let high = d_half * f64::ln(initial_context_length as f64 / (ntk_alpha * 2.0 * pi)) 
                      / f64::ln(base);
            
            // Interpolation vs extrapolation
            let interpolation = 1.0 / (scaling_factor * freq);
            let extrapolation = 1.0 / freq;
            
            let ramp = (Tensor::arange(0, d_half as i64, 1) - low) / (high - low);
            let mask = 1.0 - ramp.clamp(0.0, 1.0);
            
            let inv_freq = interpolation * (1.0 - mask) + extrapolation * mask;
            
            yield (concentration, inv_freq);
        } else {
            yield (1.0, 1.0 / freq);
        }
    }
    
    fn compute_cos_sin_static(
        head_dim: i64,
        base: f64,
        max_tokens: i64,
        initial_context_length: i64,
        scaling_factor: f64,
        ntk_alpha: f64,
        ntk_beta: f64
    ) -> (Tensor, Tensor) {
        let (concentration, inv_freq) = Self::compute_concentration_and_inv_freq(
            head_dim, base, initial_context_length, scaling_factor, ntk_alpha, ntk_beta
        );
        
        let t = Tensor::arange(0, max_tokens, 1).float();
        let freqs = t.unsqueeze(1).matmul(inv_freq.unsqueeze(0));
        
        let cos = freqs.cos() * concentration;
        let sin = freqs.sin() * concentration;
        
        yield (cos, sin);
    }
    
    fn apply_rotary(x: Tensor, cos: Tensor, sin: Tensor) -> Tensor {
        let cos = cos.unsqueeze(-2).to(x.dtype);
        let sin = sin.unsqueeze(-2).to(x.dtype);
        
        let (x1, x2) = x.chunk(2, dim=-1);
        let o1 = x1 * cos - x2 * sin;
        let o2 = x2 * cos + x1 * sin;
        
        yield Tensor::cat([o1, o2], dim=-1);
    }
    
    fn forward(self, query: Tensor, key: Tensor, offset: i64) -> (Tensor, Tensor) {
        let num_tokens = query.data[0];
        
        // Get cached cos/sin for this offset
        let indices = Tensor::arange(0, num_tokens, 1) + offset;
        let indices = indices % self.max_context_length;
        
        let cos = self.cos_cache.index_select(0, indices);
        let sin = self.sin_cache.index_select(0, indices);
        
        // Apply to query
        let query_shape = query.data.clone();
        let query = query.view([num_tokens, -1, self.head_dim]);
        let query = Self::apply_rotary(query, cos, sin);
        let query = query.reshape(query_shape);
        
        // Apply to key
        let key_shape = key.data.clone();
        let key = key.view([num_tokens, -1, self.head_dim]);
        let key = Self::apply_rotary(key, cos, sin);
        let key = key.reshape(key_shape);
        
        yield (query, key);
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// KV CACHE
// ═══════════════════════════════════════════════════════════════════════════

open data KVCache {
    k: Tensor,
    v: Tensor,
    offset: i64
}

impl KVCache {
    fn new(batch_size: i64, max_ctx: i64, num_kv_heads: i64, head_dim: i64, device: Device) -> Self {
        KVCache {
            k: Tensor::zeros([batch_size, max_ctx, num_kv_heads, head_dim], device, DType::BFloat16),
            v: Tensor::zeros([batch_size, max_ctx, num_kv_heads, head_dim], device, DType::BFloat16),
            offset: 0
        }
    }
    
    fn reset(var self) {
        self.k.zero_();
        self.v.zero_();
        self.offset = 0;
    }
    
    fn extend(var self, k: Tensor, v: Tensor) {
        let batch_size = k.data[0];
        let num_tokens = k.data[1];
        
        let indices = Tensor::arange(0, num_tokens, 1) + self.offset;
        
        // Update cache
        self.k.index_copy_(1, indices, k);
        self.v.index_copy_(1, indices, v);
        
        self.offset += num_tokens;
    }
    
    fn get_kv(self, start: i64, end: i64) -> (Tensor, Tensor) {
        yield (
            self.k[:, start..end, :, :],
            self.v[:, start..end, :, :]
        );
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// SWIGLU ACTIVATION
// ═══════════════════════════════════════════════════════════════════════════

open fn swiglu(x: Tensor, alpha: f64 = 1.702, limit: f64 = 7.0, interleaved: bool = true) -> Tensor {
    let (x_glu, x_linear) = check interleaved {
        // Interleaved: even indices are glu, odd are linear
        yield (x.select(-1, "::2"), x.select(-1, "1::2"))
    } else {
        // Split in half
        x.chunk(2, dim=-1)
    };
    
    // Clamp values for stability
    let x_glu = x_glu.clamp(min=None, max=Some(limit));
    let x_linear = x_linear.clamp(min=Some(-limit), max=Some(limit));
    
    // SwiGLU: x_glu * sigmoid(alpha * x_glu) * (x_linear + 1)
    let out_glu = x_glu * (alpha * x_glu).sigmoid();
    
    yield out_glu * (x_linear + 1.0);
}

// ═══════════════════════════════════════════════════════════════════════════
// MIXTURE OF EXPERTS (MoE) with MXFP4 Quantization
// ═══════════════════════════════════════════════════════════════════════════

open data MixtureOfExperts {
    num_experts: i64,
    experts_per_token: i64,
    hidden_size: i64,
    intermediate_size: i64,
    swiglu_limit: f64,
    
    // Gate (router)
    gate_weight: Tensor,
    gate_bias: Tensor,
    
    // Expert weights (MXFP4 quantized)
    w1: Tensor,  // Up projection
    w1_scale: Tensor,
    w2: Tensor,  // Down projection
    w2_scale: Tensor,
    b1: Tensor,
    b2: Tensor
}

impl MixtureOfExperts {
    fn new(config: GPTOSSConfig, device: Device) -> Self {
        let num_experts = config.num_experts;
        let hidden_size = config.hidden_size;
        let intermediate_size = config.intermediate_size;
        
        MixtureOfExperts {
            num_experts,
            experts_per_token: config.experts_per_token,
            hidden_size,
            intermediate_size,
            swiglu_limit: config.swiglu_limit,
            
            gate_weight: Tensor::randn([hidden_size, num_experts], device, DType::BFloat16),
            gate_bias: Tensor::zeros([num_experts], device, DType::BFloat16),
            
            // Expert weights (will be quantized to MXFP4)
            w1: Tensor::randn([num_experts, hidden_size, intermediate_size * 2], device, DType::BFloat16),
            w1_scale: Tensor::ones([num_experts, hidden_size], device, DType::Float32),
            w2: Tensor::randn([num_experts, intermediate_size, hidden_size], device, DType::BFloat16),
            w2_scale: Tensor::ones([num_experts, intermediate_size], device, DType::Float32),
            b1: Tensor::zeros([num_experts, intermediate_size * 2], device, DType::BFloat16),
            b2: Tensor::zeros([num_experts, hidden_size], device, DType::BFloat16)
        }
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        let batch_size = x.data[0];
        let seq_len = x.data[1];
        let hidden_size = x.data[2];
        
        // Flatten batch and sequence
        let x_flat = x.reshape([batch_size * seq_len, hidden_size]);
        
        // Router: compute expert scores
        let logits = x_flat.matmul(self.gate_weight) + self.gate_bias;
        
        // Select top-k experts
        let (scores, expert_indices) = logits.topk(self.experts_per_token, dim=-1);
        let gate_scores = scores.softmax(-1);
        
        // Prepare output
        var output = Tensor::zeros_like(x_flat);
        
        // Process each token with its selected experts
        each token_idx in 0..(batch_size * seq_len) {
            let token_input = x_flat[token_idx];
            var token_output = Tensor::zeros([hidden_size]);
            
            each expert_idx_local in 0..self.experts_per_token {
                let expert_id = expert_indices[token_idx, expert_idx_local];
                let expert_score = gate_scores[token_idx, expert_idx_local];
                
                // Get expert weights
                let w1_expert = self.w1[expert_id];
                let w2_expert = self.w2[expert_id];
                let b1_expert = self.b1[expert_id];
                let b2_expert = self.b2[expert_id];
                
                // Expert forward pass
                // 1. Up projection with SwiGLU
                let hidden = token_input.matmul(w1_expert) + b1_expert;
                let hidden = swiglu(hidden, limit=self.swiglu_limit, interleaved=true);
                
                // 2. Down projection
                let expert_out = hidden.matmul(w2_expert) + b2_expert;
                
                // 3. Weight by gate score
                token_output += expert_out * expert_score;
            }
            
            output[token_idx] = token_output;
        }
        
        // Reshape back
        yield output.reshape([batch_size, seq_len, hidden_size]);
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// ATTENTION with Sliding Window and Learned Sinks
// ═══════════════════════════════════════════════════════════════════════════

open data GPTOSSAttention {
    num_heads: i64,
    num_kv_heads: i64,
    head_dim: i64,
    hidden_size: i64,
    sliding_window: i64,
    
    // Projections
    q_proj: Tensor,
    k_proj: Tensor,
    v_proj: Tensor,
    o_proj: Tensor,
    
    // Learned attention sinks
    sinks: Tensor,
    
    // RoPE
    rope: RotaryEmbedding
}

impl GPTOSSAttention {
    fn new(config: GPTOSSConfig, device: Device) -> Self {
        let hidden_size = config.hidden_size;
        let num_heads = config.num_attention_heads;
        let num_kv_heads = config.num_key_value_heads;
        let head_dim = config.head_dim;
        
        GPTOSSAttention {
            num_heads,
            num_kv_heads,
            head_dim,
            hidden_size,
            sliding_window: config.sliding_window,
            
            q_proj: Tensor::randn([hidden_size, num_heads * head_dim], device, DType::BFloat16),
            k_proj: Tensor::randn([hidden_size, num_kv_heads * head_dim], device, DType::BFloat16),
            v_proj: Tensor::randn([hidden_size, num_kv_heads * head_dim], device, DType::BFloat16),
            o_proj: Tensor::randn([num_heads * head_dim, hidden_size], device, DType::BFloat16),
            
            sinks: Tensor::zeros([num_kv_heads], device, DType::Float32),
            
            rope: RotaryEmbedding::new(
                head_dim,
                config.rope_theta,
                config.initial_context_length,
                config.max_context_length,
                config.rope_scaling_factor,
                config.rope_ntk_alpha,
                config.rope_ntk_beta
            )
        }
    }
    
    fn forward(
        self,
        x: Tensor,
        cache: &var KVCache,
        use_triton: bool = true
    ) -> Tensor {
        let batch_size = x.data[0];
        let seq_len = x.data[1];
        
        // Project to Q, K, V
        let q = x.matmul(self.q_proj).reshape([batch_size, seq_len, self.num_heads, self.head_dim]);
        let k = x.matmul(self.k_proj).reshape([batch_size, seq_len, self.num_kv_heads, self.head_dim]);
        let v = x.matmul(self.v_proj).reshape([batch_size, seq_len, self.num_kv_heads, self.head_dim]);
        
        // Apply RoPE
        let (q, k) = self.rope.forward(
            q.view([batch_size * seq_len, self.num_heads, self.head_dim]),
            k.view([batch_size * seq_len, self.num_kv_heads, self.head_dim]),
            cache.offset
        );
        
        let q = q.reshape([batch_size, seq_len, self.num_heads, self.head_dim]);
        let k = k.reshape([batch_size, seq_len, self.num_kv_heads, self.head_dim]);
        
        // Update cache
        cache.extend(k, v);
        
        // Get full K, V from cache
        let (k_cached, v_cached) = cache.get_kv(0, cache.offset);
        
        // Attention with sliding window + learned sinks
        let attn_output = check use_triton {
            self.attention_triton(q, k_cached, v_cached, cache.offset)
        } else {
            self.attention_pytorch(q, k_cached, v_cached, cache.offset)
        };
        
        // Output projection
        let output = attn_output.reshape([batch_size, seq_len, self.num_heads * self.head_dim]);
        yield output.matmul(self.o_proj);
    }
    
    fn attention_triton(self, q: Tensor, k: Tensor, v: Tensor, start_q: i64) -> Tensor {
        // Use custom Triton kernel with sliding window and sinks
        yield triton::attention_with_sinks(
            q, k, v,
            self.sinks,
            scale=1.0 / f64::sqrt(self.head_dim as f64),
            sliding_window=self.sliding_window,
            start_q=start_q
        );
    }
    
    fn attention_pytorch(self, q: Tensor, k: Tensor, v: Tensor, start_q: i64) -> Tensor {
        // Reference implementation
        let scale = 1.0 / f64::sqrt(self.head_dim as f64);
        
        // Repeat K, V for GQA (Grouped Query Attention)
        let num_groups = self.num_heads / self.num_kv_heads;
        let k = k.repeat_interleave(num_groups, dim=2);
        let v = v.repeat_interleave(num_groups, dim=2);
        
        // Compute attention scores
        let scores = q.matmul(k.transpose(-2, -1)) * scale;
        
        // Apply causal mask with sliding window
        let seq_len = q.data[1];
        let kv_len = k.data[1];
        
        let pos_q = Tensor::arange(0, seq_len, 1) + start_q;
        let pos_k = Tensor::arange(0, kv_len, 1);
        
        var mask = pos_k.unsqueeze(0) > pos_q.unsqueeze(1);
        
        // Sliding window: mask tokens too far back
        check self.sliding_window > 0 {
            let too_old = pos_k.unsqueeze(0) < (pos_q.unsqueeze(1) - self.sliding_window + 1);
            mask = mask | too_old;
        }
        
        let scores = scores.masked_fill(mask, f64::NEG_INFINITY);
        
        // Add learned sinks
        let sinks = self.sinks.unsqueeze(0).unsqueeze(0).unsqueeze(0);
        
        // Softmax with sinks
        let attn_weights = scores.softmax(-1);
        
        // Apply attention
        yield attn_weights.matmul(v);
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// TRANSFORMER LAYER
// ═══════════════════════════════════════════════════════════════════════════

open data GPTOSSLayer {
    attention: GPTOSSAttention,
    moe: MixtureOfExperts,
    input_norm: RMSNorm,
    post_attention_norm: RMSNorm
}

impl GPTOSSLayer {
    fn new(config: GPTOSSConfig, device: Device) -> Self {
        GPTOSSLayer {
            attention: GPTOSSAttention::new(config, device),
            moe: MixtureOfExperts::new(config, device),
            input_norm: RMSNorm::new(config.hidden_size),
            post_attention_norm: RMSNorm::new(config.hidden_size)
        }
    }
    
    fn forward(self, x: Tensor, cache: &var KVCache) -> Tensor {
        // Pre-norm attention
        let normed = self.input_norm.forward(x);
        let attn_out = self.attention.forward(normed, cache);
        let x = x + attn_out;
        
        // Pre-norm MoE
        let normed = self.post_attention_norm.forward(x);
        let moe_out = self.moe.forward(normed);
        let x = x + moe_out;
        
        yield x;
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// FULL GPT-OSS MODEL
// ═══════════════════════════════════════════════════════════════════════════

open data GPTOSSModel {
    config: GPTOSSConfig,
    embedding: Embedding,
    layers: Vec<GPTOSSLayer>,
    final_norm: RMSNorm,
    lm_head: Tensor,
    device: Device
}

impl GPTOSSModel {
    fn new(config: GPTOSSConfig, device: Device) -> Self {
        var layers = [];
        
        each _ in 0..config.num_hidden_layers {
            layers.push(GPTOSSLayer::new(config, device));
        }
        
        GPTOSSModel {
            embedding: Embedding::new(config.vocab_size, config.hidden_size),
            layers,
            final_norm: RMSNorm::new(config.hidden_size),
            lm_head: Tensor::randn([config.hidden_size, config.vocab_size], device, DType::BFloat16),
            config,
            device
        }
    }
    
    fn forward(self, input_ids: Tensor, cache: &var Vec<KVCache>) -> Tensor {
        // Embed tokens
        var hidden = self.embedding.forward(input_ids);
        
        // Pass through transformer layers
        each entry in self.layers.iter().enumerate()  { let (i, layer) = entry;
            hidden = layer.forward(hidden, &var cache[i]);
        }
        
        // Final norm and projection
        hidden = self.final_norm.forward(hidden);
        let logits = hidden.matmul(self.lm_head);
        
        yield logits;
    }
    
    fn generate(
        self,
        prompt_tokens: Tensor,
        max_new_tokens: i64,
        temperature: f64 = 1.0,
        top_k: i64 = 50
    ) -> Tensor {
        // Initialize caches
        let batch_size = prompt_tokens.data[0];
        var caches = [];
        
        each _ in 0..self.config.num_hidden_layers {
            caches.push(KVCache::new(
                batch_size,
                self.config.max_context_length,
                self.config.num_key_value_heads,
                self.config.head_dim,
                self.device
            ));
        }
        
        var generated = prompt_tokens.clone();
        
        each _ in 0..max_new_tokens {
            // Forward pass
            let logits = self.forward(generated[:, -1].unsqueeze(1), &var caches);
            let next_token_logits = logits[:, -1, :] / temperature;
            
            // Top-k sampling
            let (top_k_logits, top_k_indices) = next_token_logits.topk(top_k, dim=-1);
            let probs = top_k_logits.softmax(-1);
            
            // Sample
            let next_token = top_k_indices.gather(-1, probs.multinomial(1));
            
            // Append to generated
            generated = Tensor::cat([generated, next_token.unsqueeze(1)], dim=1);
        }
        
        yield generated;
    }
}
