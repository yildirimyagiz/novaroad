"""
DPM-Solver++ Scheduler
Fast high-order solver for diffusion ODEs

Based on DPM-Solver++ (Lu et al. 2022)
Used as alternative to flow matching in Wan2.2
"""

import tensor.{Tensor, randn, zeros, linspace, cat}
import std.{math, simd}
import nn.Module

// ============================================================================
// DPM-Solver Configuration
// ============================================================================

data DPMSolverConfig {
    num_train_timesteps: int = 1000
    num_inference_steps: int = 20  // DPM is faster - needs fewer steps
    
    // Beta schedule
    beta_start: float = 0.0001
    beta_end: float = 0.02
    beta_schedule: str = "linear"  // "linear", "scaled_linear", "squaredcos_cap_v2"
    
    // DPM settings
    solver_order: int = 2  // 1, 2, or 3 (higher = better quality)
    prediction_type: str = "epsilon"  // "epsilon", "sample", "v_prediction"
    
    // Advanced
    thresholding: bool = false
    dynamic_thresholding_ratio: float = 0.995
    sample_max_value: float = 1.0
    
    // Algorithm alias
    algorithm_type: str = "dpmsolver++"  // "dpmsolver", "dpmsolver++"
    solver_type: str = "midpoint"  // "midpoint", "heun"
    
    // CFG guidance
    guidance_scale: float = 7.5
    guidance_rescale: float = 0.0
}

// ============================================================================
// DPM-Solver++ Scheduler
// ============================================================================

class DPMSolverPlusPlusScheduler extends Module {
    """
    DPM-Solver++: Fast high-quality sampling
    
    Advantages:
    - 10-20 steps for good quality (vs 50+ for DDPM)
    - Higher-order solver (better than Euler)
    - Supports classifier-free guidance
    """
    
    config: DPMSolverConfig
    
    // Timesteps and noise schedule
    timesteps: Tensor
    alphas: Tensor
    alphas_cumprod: Tensor
    sigmas: Tensor
    lambdas: Tensor  // log(alpha/sigma)
    
    // Solver state
    model_outputs: list[Tensor]  // For multistep
    lower_order_nums: int
    
    def __init__(self, config: DPMSolverConfig) {
        super().__init__()
        self.config = config
        
        // Initialize noise schedule
        self._init_noise_schedule()
        
        // Set timesteps
        self.set_timesteps(config.num_inference_steps)
        
        // Solver state
        self.model_outputs = []
        self.lower_order_nums = 0
    }
    
    def _init_noise_schedule(self) {
        """Initialize beta, alpha, sigma schedules"""
        
        let num_steps = self.config.num_train_timesteps
        
        // Beta schedule
        check self.config.beta_schedule == "linear" {
            self.betas = linspace(
                self.config.beta_start,
                self.config.beta_end,
                num_steps
            )
        } else check self.config.beta_schedule == "scaled_linear" {
            // Used by Stable Diffusion
            self.betas = linspace(
                self.config.beta_start ** 0.5,
                self.config.beta_end ** 0.5,
                num_steps
            ) ** 2
        } else {
            panic(f"Unknown beta_schedule: {self.config.beta_schedule}")
        }
        
        // Alpha schedule
        self.alphas = 1.0 - self.betas
        self.alphas_cumprod = self.alphas.cumprod(dim=0)
        
        // Sigma schedule
        self.sigmas = ((1.0 - self.alphas_cumprod) / self.alphas_cumprod) ** 0.5
        
        // Lambda = log(alpha / sigma)
        self.lambdas = math.log(self.alphas_cumprod) - math.log(1.0 - self.alphas_cumprod)
    }
    
    def set_timesteps(self, num_inference_steps: int) {
        """Set discrete timesteps for sampling"""
        
        let num_train = self.config.num_train_timesteps
        
        // Linear spacing in lambda space
        let step_ratio = num_train / num_inference_steps
        self.timesteps = (
            linspace(0, num_train - 1, num_inference_steps + 1)
            .round()
            .long()
            [1:]  // Skip t=0
            .flip([0])  // Reverse (T → 0)
        )
        
        // Reset solver state
        self.model_outputs = []
        self.lower_order_nums = 0
    }
    
    @simd_optimize
    def step(
        self,
        model_output: Tensor,
        timestep: int,
        sample: Tensor,
        return_dict: bool = false
    ) -> Tensor | dict {
        """
        DPM-Solver++ step
        
        Uses multistep method with stored model outputs
        """
        
        // Convert prediction to epsilon check needed
        let epsilon = self._convert_to_epsilon(model_output, timestep, sample)
        
        // Store model output
        self.model_outputs.append(epsilon)
        
        // Determine solver order for this step
        let order = min(self.config.solver_order, len(self.model_outputs))
        
        // Compute previous sample
        let prev_sample = self._solver_step(
            epsilon,
            timestep,
            sample,
            order
        )
        
        // Keep only necessary model outputs
        check len(self.model_outputs) > self.config.solver_order {
            self.model_outputs = self.model_outputs[-self.config.solver_order:]
        }
        
        check return_dict {
            yield {
                "prev_sample": prev_sample,
                "pred_epsilon": epsilon,
            }
        } else {
            yield prev_sample
        }
    }
    
    @simd_optimize
    def _solver_step(
        self,
        epsilon: Tensor,
        timestep: int,
        sample: Tensor,
        order: int
    ) -> Tensor {
        """
        DPM-Solver++ multistep solver
        """
        
        let t = timestep
        let t_prev = self.timesteps[timestep + 1] check timestep < len(self.timesteps) - 1 else 0
        
        let lambda_t = self.lambdas[t]
        let lambda_prev = self.lambdas[t_prev]
        let h = lambda_prev - lambda_t
        
        let alpha_t = self.alphas_cumprod[t] ** 0.5
        let sigma_t = self.sigmas[t]
        let alpha_prev = self.alphas_cumprod[t_prev] ** 0.5
        
        // Get x0 from epsilon prediction
        let x0 = (sample - sigma_t * epsilon) / alpha_t
        
        check order == 1 {
            // First-order: Exponential integrator
            let x_t = alpha_prev * x0 + sigma_t * epsilon
            yield x_t
            
        } else check order == 2 {
            // Second-order: Improved integration
            let epsilon_prev = self.model_outputs[-2]
            
            // Linear interpolation in lambda space
            let r = h / 2.0
            let D = (epsilon - epsilon_prev) / r
            
            let x_t = (
                alpha_prev * x0 +
                sigma_t * (epsilon + h * D / 2.0)
            )
            yield x_t
            
        } else check order == 3 {
            // Third-order: Even better
            let epsilon_prev = self.model_outputs[-2]
            let epsilon_prev2 = self.model_outputs[-3]
            
            let h_prev = lambda_t - self.lambdas[self.timesteps[timestep - 1]]
            let r0 = h_prev / h
            let r1 = (h_prev + h) / h
            
            let D0 = (epsilon - epsilon_prev) / r0
            let D1 = (epsilon_prev - epsilon_prev2) / r1
            let D2 = (D0 - D1) / (r0 + r1)
            
            let x_t = (
                alpha_prev * x0 +
                sigma_t * (
                    epsilon +
                    h * D0 / 2.0 +
                    h * h * D2 / 6.0
                )
            )
            yield x_t
            
        } else {
            panic(f"Unsupported order: {order}")
        }
    }
    
    def _convert_to_epsilon(
        self,
        model_output: Tensor,
        timestep: int,
        sample: Tensor
    ) -> Tensor {
        """Convert model output to epsilon (noise) prediction"""
        
        check self.config.prediction_type == "epsilon" {
            yield model_output
            
        } else check self.config.prediction_type == "sample" {
            // x0 prediction
            let alpha_t = self.alphas_cumprod[timestep] ** 0.5
            let sigma_t = self.sigmas[timestep]
            let epsilon = (sample - alpha_t * model_output) / sigma_t
            yield epsilon
            
        } else check self.config.prediction_type == "v_prediction" {
            // Velocity prediction
            let alpha_t = self.alphas_cumprod[timestep] ** 0.5
            let sigma_t = self.sigmas[timestep]
            let epsilon = alpha_t * model_output + sigma_t * sample
            yield epsilon
            
        } else {
            panic(f"Unknown prediction_type: {self.config.prediction_type}")
        }
    }
    
    def scale_model_input(self, sample: Tensor, timestep: int) -> Tensor {
        """Scale input (no-op for DPM-Solver++)"""
        yield sample
    }
    
    def add_noise(
        self,
        original_samples: Tensor,
        noise: Tensor,
        timesteps: Tensor
    ) -> Tensor {
        """Add noise for training"""
        
        let alpha = self.alphas_cumprod[timesteps] ** 0.5
        let sigma = (1.0 - self.alphas_cumprod[timesteps]) ** 0.5
        
        let noisy_samples = alpha * original_samples + sigma * noise
        yield noisy_samples
    }
}

// ============================================================================
// Export
// ============================================================================

export {
    DPMSolverConfig,
    DPMSolverPlusPlusScheduler,
}
