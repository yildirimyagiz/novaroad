/// Example usage of Nova Finance AI
open fn example_world_leading_finance() {
    // Create world-leading finance AI
    let finance_ai = NovaFinanceAI::new();

    // Create investor profile
    let investor = InvestorProfile {
        id: "investor_001".into(),
        risk_tolerance: RiskTolerance::Moderate,
        investment_goals: [InvestmentGoal {
            goal_type: "Retirement".into(),
            target_amount: 1_000_000.0,
            target_date: std::time::SystemTime::now() + std::time::Duration::from_secs(365 * 24 * 3600 * 20),
            priority: 1,
        }],
        time_horizon: TimeHorizon::LongTerm,
        current_portfolio: None,
        behavioral_data: BehavioralData {
            loss_aversion_score: 0.7,
            recency_bias_score: 0.4,
            overconfidence_score: 0.3,
        },
    };

    // Get market data
    let market_data = MarketData {
        timestamp: std::time::SystemTime::now(),
        prices: [
            ("AAPL".into(), 150.0),
            ("GOOGL".into(), 2800.0),
            ("MSFT".into(), 300.0),
        ].iter().cloned().collect(),
        volumes: HashMap::new(),
        volatility_surface: HashMap::new(),
        correlations: [],
    };

    // Optimize portfolio with world-leading algorithms
    let constraints = PortfolioConstraints {
        max_weight_per_asset: 0.3,
        min_weight_per_asset: 0.01,
        max_sector_exposure: 0.4,
        min_liquidity_ratio: 0.1,
        max_volatility_target: 0.15,
        benchmark_index: "SPY".into(),
    };

    let optimized_portfolio = finance_ai.optimize_portfolio(investor, market_data, constraints);
    println("🎯 Portfolio Optimization Results:");
    println("Expected Return: {:.2f}%", optimized_portfolio.expected_yield * 100.0);
    println("Expected Volatility: {:.2f}%", optimized_portfolio.expected_volatility * 100.0);
    println("Sharpe Ratio: {:.3f}", optimized_portfolio.sharpe_ratio);

    // Execute algorithmic trade
    let strategy = TradingStrategy {
        name: "Momentum Strategy".into(),
        strategy_type: StrategyType::Momentum,
        parameters: [("lookback_period".into(), 20.0)].iter().cloned().collect(),
        time_horizon: TimeHorizon::Daily,
        risk_limits: RiskLimits {
            max_position_size: 0.1,
            max_drawdown: 0.05,
            max_leverage: 1.0,
            stop_loss_threshold: 0.02,
        },
    };

    let market_conditions = MarketConditions {
        volatility_index: 18.5,
        liquidity_measures: HashMap::new(),
        order_book_depth: HashMap::new(),
        market_regime: MarketRegime::Bull,
    };

    let execution = finance_ai.execute_algorithmic_trade(strategy, market_conditions);
    println("⚡ Algorithmic Trading Results:");
    println("Signals Generated: {}", execution.execution_signals.len());
    println("Realized P&L: ${:.2f}", execution.realized_pnl);
    println("Execution Quality: {:.2f}%", execution.execution_quality.overall_score * 100.0);

    // Detect fraud with world-leading accuracy
    let transaction = Transaction {
        id: "txn_123".into(),
        amount: 5000.0,
        merchant: "Unknown Online Store".into(),
        timestamp: std::time::SystemTime::now(),
        location: "Unusual Location".into(),
        device_info: DeviceInfo {
            device_id: "unknown_device".into(),
            ip_address: "192.168.1.100".into(),
            user_agent: "Suspicious Browser".into(),
        },
    };

    let historical_transactions = []; // Would contain historical data
    let fraud_result = finance_ai.detect_fraud(transaction, historical_transactions);
    println("🔍 Fraud Detection Results:");
    println("Fraud Score: {:.3f}", fraud_result.fraud_score);
    println("Risk Category: {:?}", fraud_result.risk_category);
    println("False Positive Rate: {:.2f}%", fraud_result.false_positive_probability * 100.0);

    // Score credit with alternative data
    let applicant = CreditApplicant {
        id: "applicant_001".into(),
        credit_history: CreditHistory {
            credit_score: Some(720.0),
            payment_history: [],
            outstanding_debt: 5000.0,
            credit_utilization: 0.3,
        },
        employment_info: EmploymentInfo {
            employer: "Tech Corp".into(),
            job_title: "Software Engineer".into(),
            employment_length: 36,
            income: 120000.0,
        },
        income_stability_factor: 0.9,
        debt_to_income_ratio: 0.15,
    };

    let alternative_data = AlternativeData {
        social_media_activity: SocialMediaData {
            connections_count: 500,
            activity_score: 0.8,
            professional_network: 200,
        },
        utility_payments: UtilityPaymentData {
            on_time_payment_rate: 0.98,
            average_payment_delay: 0.5,
        },
        rental_history: RentalHistory {
            rental_payment_score: 0.95,
            landlord_references: 3,
        },
        ecommerce_behavior: EcommerceBehavior {
            purchase_frequency: 12.0,
            return_rate: 0.02,
            preferred_payment_methods: ["Credit Card".into()],
        },
    };

    let credit_score = finance_ai.score_credit(applicant, alternative_data);
    println("📊 Credit Scoring Results:");
    println("Final Score: {:.0f}", credit_score.final_score);
    println("Risk Grade: {:?}", credit_score.risk_grade);
    println("Approval Probability: {:.1f}%", credit_score.approval_probability * 100.0);

    println("🎉 Nova Finance AI - World Leading Financial Intelligence!");
}
