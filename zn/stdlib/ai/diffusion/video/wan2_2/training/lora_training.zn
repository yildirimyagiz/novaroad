"""
WAN 2.2 LoRA Training
Efficient fine-tuning for consumer GPUs (RTX 4090, etc.)
"""

import std.{logging, fs}
from .trainer import WanTrainer
from .config import WanTrainingConfig

def train_lora(
    # Model
    model_name: str = "Wan-AI/Wan2.2-T2V-A14B",
    model_type: str = "t2v",
    
    # Dataset
    dataset_path: str,
    metadata_path: str,
    
    # Video settings
    height: int = 480,
    width: int = 832,
    num_frames: int = 81,
    
    # LoRA hyperparameters
    lora_rank: int = 32,
    lora_alpha: int = 32,
    lora_dropout: float = 0.1,
    lora_target_modules: list[str] = ["q", "k", "v", "o", "ffn.0", "ffn.2"],
    
    # Training
    learning_rate: float = 1e-4,
    batch_size: int = 1,
    gradient_accumulation_steps: int = 4,
    num_epochs: int = 5,
    
    # Output
    output_dir: str = "./outputs/wan2_lora",
    
    # Advanced
    use_8bit_adam: bool = True,
    mixed_precision: str = "bf16",
):
    """
    Train WAN 2.2 with LoRA
    
    Example:
        ```nova
        import ai.diffusion.video.wan2_2.training as wan_train
        
        wan_train.train_lora(
            dataset_path="./data/my_videos",
            metadata_path="./data/metadata.csv",
            num_epochs=10,
            output_dir="./outputs/my_lora_model",
        )
        ```
    
    Args:
        model_name: HuggingFace model name or local path
        model_type: Model alias (t2v, i2v, ti2v)
        dataset_path: Path to video dataset directory
        metadata_path: Path to metadata CSV file
        height: Video height
        width: Video width
        num_frames: Number of frames per video
        lora_rank: LoRA rank (higher = more capacity, more memory)
        lora_alpha: LoRA alpha scaling factor
        lora_dropout: LoRA dropout rate
        lora_target_modules: Which modules to impl LoRA to
        learning_rate: Learning rate
        batch_size: Batch size per GPU
        gradient_accumulation_steps: Gradient accumulation steps
        num_epochs: Number of training epochs
        output_dir: Output directory for checkpoints
        use_8bit_adam: Use 8-bit AdamW optimizer (saves memory)
        mixed_precision: Mixed precision training (fp16, bf16, fp32)
    """
    
    logging.info("╔══════════════════════════════════════════════════════════════╗")
    logging.info("║          WAN 2.2 LoRA Training - Nova Edition             ║")
    logging.info("╚══════════════════════════════════════════════════════════════╝")
    logging.info("")
    
    # Create config
    config = WanTrainingConfig(
        model_name=model_name,
        model_type=model_type,
        training_mode="lora",
        dataset_path=dataset_path,
        metadata_path=metadata_path,
        height=height,
        width=width,
        num_frames=num_frames,
        learning_rate=learning_rate,
        batch_size=batch_size,
        gradient_accumulation_steps=gradient_accumulation_steps,
        num_epochs=num_epochs,
        lora_rank=lora_rank,
        lora_alpha=lora_alpha,
        lora_dropout=lora_dropout,
        lora_target_modules=lora_target_modules,
        output_dir=output_dir,
        use_8bit_adam=use_8bit_adam,
        mixed_precision=mixed_precision,
    )
    
    # Create trainer
    trainer = WanTrainer(config)
    
    # Start training
    trainer.train()
    
    logging.info("")
    logging.info("✅ LoRA training completed!")
    logging.info(f"📁 Model saved to: {output_dir}")
    logging.info("")
    logging.info("To use your trained LoRA:")
    logging.info("```nova")
    logging.info("import ai.diffusion.video.wan2_2 as wan")
    logging.info("")
    logging.info("generator = wan.WanT2V(")
    logging.info(f'    model="{model_name}",')
    logging.info(f'    lora_path="{output_dir}/best_model",')
    logging.info(")")
    logging.info("")
    logging.info('video = generator.generate("your prompt here")')
    logging.info("```")
    
    yield trainer


def quick_lora_train(
    dataset_path: str,
    metadata_path: str,
    output_dir: str = "./outputs/wan2_lora_quick",
    num_epochs: int = 3,
):
    """
    Quick LoRA training with sensible defaults
    Perfect for testing and prototyping
    
    Example:
        ```nova
        import ai.diffusion.video.wan2_2.training as wan_train
        
        wan_train.quick_lora_train(
            dataset_path="./data/my_videos",
            metadata_path="./data/metadata.csv",
        )
        ```
    """
    yield train_lora(
        dataset_path=dataset_path,
        metadata_path=metadata_path,
        output_dir=output_dir,
        num_epochs=num_epochs,
        learning_rate=1e-4,
        lora_rank=32,
        batch_size=1,
        gradient_accumulation_steps=4,
    )
