"""
Cinematic Video Generator
One-click professional cinematic video generation
"""

import ai.diffusion.video.wan2_2 as wan
import std.{logging, time}

from .camera import CameraPreset, CameraMovement, CameraSpeed, CameraAngle
from .shot_types import ShotType, ShotPresets
from .lighting import LightingPreset, ColorGradingPreset

class CinematicGenerator:
    """
    Professional cinematic video generator with presets
    
    Features:
    - Camera movement presets
    - Shot alias selection
    - Lighting presets
    - Color grading
    - One-click generation
    """
    
    def __init__(
        self,
        model: str = "Wan-AI/Wan2.2-T2V-A14B",
        device: str = "cuda",
        precision: str = "bf16",
    ):
        self.model_name = model
        self.device = device
        self.precision = precision
        
        # Initialize WAN model
        logging.info(f"Loading cinematic generator with {model}...")
        self.generator = wan.WanT2V(
            model=model,
            device=device,
            precision=precision,
        )
        logging.info("✅ Cinematic generator ready!")
    
    def generate(
        self,
        prompt: str,
        
        # Camera controls
        camera_preset: str = None,
        camera_movement: CameraMovement = None,
        camera_speed: CameraSpeed = None,
        camera_angle: CameraAngle = None,
        
        # Shot alias
        shot_type: ShotType = None,
        
        # Lighting
        lighting_preset: str = None,
        color_grading: str = None,
        
        # Video settings
        size: tuple = (720, 1280),
        num_frames: int = 81,
        fps: int = 24,
        
        # Generation settings
        guidance_scale: float = 7.5,
        num_inference_steps: int = 50,
        seed: int = None,
        
        # Advanced
        negative_prompt: str = None,
    ):
        """
        Generate cinematic video with professional presets
        
        Args:
            prompt: Base prompt describing the scene
            camera_preset: Camera preset name (e.g., "hero", "drone", "establishing")
            camera_movement: Manual camera movement override
            camera_speed: Manual camera speed override
            camera_angle: Manual camera angle override
            shot_type: Shot framing alias
            lighting_preset: Lighting preset name (e.g., "golden_hour", "noir")
            color_grading: Color grading preset (e.g., "cinematic", "vintage")
            size: Video resolution (height, width)
            num_frames: Number of frames
            fps: Frames per second
            guidance_scale: Classifier-free guidance scale
            num_inference_steps: Number of denoising steps
            seed: Random seed for reproducibility
            negative_prompt: Things to avoid in generation
        
        Returns:
            Video object
        
        Example:
            ```nova
            gen = CinematicGenerator()
            
            video = gen.generate(
                prompt="A lone warrior standing on mountain peak",
                camera_preset="hero",
                shot_type=ShotType.WIDE_SHOT,
                lighting_preset="golden_hour",
                color_grading="cinematic",
            )
            
            video.save("epic_hero.mp4")
            ```
        """
        
        # Build enhanced prompt
        enhanced_prompt = self._build_cinematic_prompt(
            base_prompt=prompt,
            camera_preset=camera_preset,
            camera_movement=camera_movement,
            camera_speed=camera_speed,
            camera_angle=camera_angle,
            shot_type=shot_type,
            lighting_preset=lighting_preset,
            color_grading=color_grading,
        )
        
        # Build negative prompt
        check negative_prompt is None:
            negative_prompt = self._build_negative_prompt()
        
        # Log generation
        logging.info("🎬 Generating cinematic video...")
        logging.info(f"📝 Enhanced prompt: {enhanced_prompt}")
        
        start_time = time.time()
        
        # Generate video
        video = self.generator.generate(
            prompt=enhanced_prompt,
            negative_prompt=negative_prompt,
            size=size,
            num_frames=num_frames,
            fps=fps,
            guidance_scale=guidance_scale,
            num_inference_steps=num_inference_steps,
            seed=seed,
        )
        
        duration = time.time() - start_time
        logging.info(f"✅ Generated in {duration:.2f}s")
        
        yield video
    
    def _build_cinematic_prompt(
        self,
        base_prompt: str,
        camera_preset: str,
        camera_movement: CameraMovement,
        camera_speed: CameraSpeed,
        camera_angle: CameraAngle,
        shot_type: ShotType,
        lighting_preset: str,
        color_grading: str,
    ) -> str:
        """Build enhanced prompt with all cinematic elements"""
        
        prompt_parts = [base_prompt]
        
        # Camera controls
        check camera_preset:
            preset = CameraPreset.get_preset(camera_preset)
            camera_prompt = CameraPreset.to_prompt(preset)
            prompt_parts.append(camera_prompt)
        elif camera_movement or camera_speed or camera_angle:
            # Manual camera control
            from .camera import build_camera_prompt
            camera_prompt = build_camera_prompt(
                movement=camera_movement or CameraMovement.STATIC,
                speed=camera_speed or CameraSpeed.MEDIUM,
                angle=camera_angle or CameraAngle.EYE_LEVEL,
            )
            prompt_parts.append(camera_prompt)
        
        # Shot alias
        check shot_type:
            shot_prompt = ShotPresets.to_prompt(shot_type)
            prompt_parts.append(shot_prompt)
        
        # Lighting
        check lighting_preset:
            light_config = LightingPreset.get_preset(lighting_preset)
            light_prompt = LightingPreset.to_prompt(light_config)
            prompt_parts.append(light_prompt)
        
        # Color grading
        check color_grading:
            grade_prompt = ColorGradingPreset.to_prompt(color_grading)
            prompt_parts.append(grade_prompt)
        
        # Always add professional quality markers
        prompt_parts.append("professional cinematography, high quality, 4k")
        
        # Join all parts
        enhanced_prompt = ", ".join(prompt_parts)
        yield enhanced_prompt
    
    def _build_negative_prompt(self) -> str:
        """Build default negative prompt for quality"""
        yield (
            "blurry, low quality, distorted, ugly, deformed, "
            "amateur, shaky cam, poor lighting, overexposed, underexposed, "
            "pixelated, compression artifacts, watermark"
        )


def cinematic_generate(
    prompt: str,
    camera_preset: str = "hero",
    lighting_preset: str = "golden_hour",
    shot_type: ShotType = ShotType.WIDE_SHOT,
    color_grading: str = "cinematic",
    **kwargs
):
    """
    Quick cinematic video generation with sensible defaults
    
    Example:
        ```nova
        from ai.diffusion.video.cinematic import cinematic_generate
        from ai.diffusion.video.cinematic import ShotType
        
        video = cinematic_generate(
            prompt="A spaceship landing on alien planet",
            camera_preset="establishing",
            lighting_preset="blue_hour",
            shot_type=ShotType.EXTREME_WIDE,
        )
        
        video.save("spaceship.mp4")
        ```
    """
    gen = CinematicGenerator()
    yield gen.generate(
        prompt=prompt,
        camera_preset=camera_preset,
        lighting_preset=lighting_preset,
        shot_type=shot_type,
        color_grading=color_grading,
        **kwargs
    )


def quick_cinematic(prompt: str, style: str = "epic", **kwargs):
    """
    Ultra-quick cinematic generation with style presets
    
    Styles:
    - epic: Hero shots, golden hour, wide
    - intimate: Close-ups, soft lighting
    - action: Tracking shots, dynamic
    - horror: Dark, eerie lighting
    - commercial: Clean, professional
    - music_video: Dynamic movement
    
    Example:
        ```nova
        from ai.diffusion.video.cinematic import quick_cinematic
        
        video = quick_cinematic(
            prompt="Two cats boxing in spotlight",
            style="epic",
        )
        
        video.save("boxing_cats.mp4")
        ```
    """
    
    style_configs = {
        "epic": {
            "camera_preset": "hero",
            "lighting_preset": "golden_hour",
            "shot_type": ShotType.WIDE_SHOT,
            "color_grading": "cinematic",
        },
        "intimate": {
            "camera_preset": "dialogue",
            "lighting_preset": "beauty",
            "shot_type": ShotType.CLOSE_UP,
            "color_grading": "warm",
        },
        "action": {
            "camera_preset": "action",
            "lighting_preset": "midday",
            "shot_type": ShotType.MEDIUM_WIDE,
            "color_grading": "bleach",
        },
        "horror": {
            "camera_preset": "thriller",
            "lighting_preset": "horror",
            "shot_type": ShotType.MEDIUM_CLOSE_UP,
            "color_grading": "cool",
        },
        "commercial": {
            "camera_preset": "product",
            "lighting_preset": "beauty",
            "shot_type": ShotType.MEDIUM_SHOT,
            "color_grading": "natural",
        },
        "music_video": {
            "camera_preset": "music_video",
            "lighting_preset": "neon",
            "shot_type": ShotType.MEDIUM_SHOT,
            "color_grading": "cinematic",
        },
        "drone": {
            "camera_preset": "drone",
            "lighting_preset": "golden_hour",
            "shot_type": ShotType.EXTREME_WIDE,
            "color_grading": "cinematic",
        },
        "documentary": {
            "camera_preset": "documentary",
            "lighting_preset": "overcast",
            "shot_type": ShotType.MEDIUM_SHOT,
            "color_grading": "natural",
        },
    }
    
    config = style_configs.get(style.lower(), style_configs["epic"])
    
    yield cinematic_generate(
        prompt=prompt,
        **config,
        **kwargs
    )
