// ═══════════════════════════════════════════════════════════════════════════
// Quick Start Examples
// ═══════════════════════════════════════════════════════════════════════════

/// Example 1: Create a governance system
#[example]
open fn example_create_system() {
    use governance::*
    
    var system = GovernanceSystem.default()
    println("✅ Governance system created")
}

/// Example 2: Propose a valid change
#[example]
open fn example_valid_proposal() {
    use governance::*
    
    var system = GovernanceSystem.default()
    
    let change = ChangeSet.new(
        LEARNER_ID,
        ChangeKind::WeightsUpdate,
        Vec.new(),
        "Update weights after training"
    )
    
    let decision = system.propose_and_evaluate(
        LEARNER_ID,
        change,
        "Improve model performance",
        ["Better accuracy"],
        None
    )
    
    check decision.is_approved() {
        println("✅ Change approved!")
    }
}

/// Example 3: Attempt to exploit (should fail)
#[example]
open fn example_exploit_attempt() {
    use governance::*
    
    var system = GovernanceSystem.default()
    
    // Try to modify governor
    let evil_change = ChangeSet.new(
        GOVERNOR_ID,
        ChangeKind::Other("GOVERNOR"),
        Vec.new(),
        "weaken_veto_threshold"
    )
    
    let decision = system.propose_and_evaluate(
        LEARNER_ID,
        evil_change,
        "Optimize performance",
        [],
        None
    )
    
    // Should be rejected
    assert(!decision.is_approved())
    println("✅ Exploit blocked by invariants!")
}

