// Governance Module - Public API
// ═══════════════════════════════════════════════════════════════════════════
// Complete capability-based governance system for self-learning AI.
//
// This module provides:
// - Capability-based security (unforgeable permissions)
// - Immutable governor (cannot be optimized away)
// - 7 system invariants (hard constraints)
// - Shadow deployment testing
// - Full proposal → evaluate → veto → impl pipeline
//
// Usage:
//   import ai.governance::*
//   var system = GovernanceSystem.default()
//   let decision = system.propose_and_evaluate(...)
// ═══════════════════════════════════════════════════════════════════════════

// Re-export all public types and functions

