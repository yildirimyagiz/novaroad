    GOVERNOR_ID,
    LEARNER_ID,
    META_LEARNER_ID,
    ARCHITECT_ID,
    EVALUATOR_ID,
    ADVERSARY_ID,
    METRIC_ROTATION_ID,
    
    // Helper functions
    format_decision,
    format_proposal
}

