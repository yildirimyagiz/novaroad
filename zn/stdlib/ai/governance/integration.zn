// ═══════════════════════════════════════════════════════════════════════════
// Example Usage
// ═══════════════════════════════════════════════════════════════════════════

#[example]
fn complete_system_example() {
    let config = ModelConfig {
        n_layers: 12,
        d_model: 768,
        n_heads: 12,
        vocab_size: 50257
    }
    
    var system = CompleteGodelSystem.new(config)
    
    // Propose a change with FULL protection
    let change = ChangeSet.new(
        LEARNER_ID,
        ChangeKind::WeightsUpdate,
        Vec.new(),
        "update_after_training"
    )
    
    let decision = system.propose_with_full_protection(
        LEARNER_ID,
        change,
        "Improve model after training epoch"
    )
    
    check decision.is_approved() {
        println("\n🎉 Change approved with full protection!")
    } else {
        println("\n⛔ Change rejected by protection layers")
    }
}
