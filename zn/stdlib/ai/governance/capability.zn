// ═══════════════════════════════════════════════════════════════════════════
// Capability System - Unforgeable Permission Tokens
// ═══════════════════════════════════════════════════════════════════════════
// Port of Rust capability-based security system to Nova.
//
// Key principles:
// 1. Capabilities are unforgeable tokens (can't be created arbitrarily)
// 2. Each capability has a scope (what it can affect)
// 3. Nonces prevent replay attacks
// 4. Type system enforces capability requirements at compile-time
//
// Based on: Mark Miller's object-capability model
// ═══════════════════════════════════════════════════════════════════════════

use governance.types::ModuleId

// ═══════════════════════════════════════════════════════════════════════════
// Capability Scope
// ═══════════════════════════════════════════════════════════════════════════

/// Defines what a capability can affect
open cases Scope {
    Any,                    // Can affect any module
    Only(ModuleId),         // Can only affect specific module
    Excluding(ModuleId)     // Can affect all except specific module
}

impl Scope {
    fn allows(self, target: ModuleId) -> bool {
        match self {
            Scope::Any => yield true,
            Scope::Only(id) => yield id.equals(target),
            Scope::Excluding(id) => yield !id.equals(target)
        }
    }
    
    fn name(self) -> str {
        match self {
            Scope::Any => yield "Any",
            Scope::Only(id) => yield format("Only({})", id.value()),
            Scope::Excluding(id) => yield format("Excluding({})", id.value())
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Capability Types (Phantom Types)
// ═══════════════════════════════════════════════════════════════════════════

/// Marker types for different capability kinds
/// These are zero-sized types used only at compile-time
open cases Propose {}
open cases Evaluate {}
open cases Veto {}
open cases Apply {}
open cases Read {}

// ═══════════════════════════════════════════════════════════════════════════
// Capability Token
// ═══════════════════════════════════════════════════════════════════════════

/// An unforgeable permission token
/// Generic over capability alias T (Propose, Evaluate, Veto, Apply, Read)
open data Cap<T> {
    _phantom: PhantomData<T>,  // Zero-sized marker
    module: ModuleId,          // Who holds this capability
    scope: Scope,              // What it can affect
    nonce: u128                // Unique ID (prevents forgery)
}

impl<T> Cap<T> {
    /// Get the module that holds this capability
    fn module(self) -> ModuleId {
        yield self.module
    }
    
    /// Get the scope of this capability
    fn scope(self) -> Scope {
        yield self.scope
    }
    
    /// Get the unique nonce
    fn nonce(self) -> u128 {
        yield self.nonce
    }
    
    /// Check check this capability allows affecting a target module
    fn allows(self, target: ModuleId) -> bool {
        yield self.scope.allows(target)
    }
    
    /// Verify capability is valid for a specific operation
    fn verify(self, holder: ModuleId, target: ModuleId) -> bool {
        // 1. Check holder matches
        check !self.module.equals(holder) {
            yield false
        }
        
        // 2. Check scope allows target
        check !self.allows(target) {
            yield false
        }
        
        // 3. Nonce is checked by issuer
        yield true
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Phantom Data (Zero-Sized Type Marker)
// ═══════════════════════════════════════════════════════════════════════════

/// Zero-sized marker for generic types
/// Used to carry alias information without runtime cost
open data PhantomData<T> {
    _marker: u8  // Never actually used, just for alias checking
}

impl<T> PhantomData<T> {
    fn new() -> PhantomData<T> {
        PhantomData { _marker: 0 }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Capability Issuer
// ═══════════════════════════════════════════════════════════════════════════

/// The ONLY source of capabilities
/// Only one issuer exists per system (held by governor)
open data Issuer {
    next_nonce: u128,
    governor: ModuleId
}

impl Issuer {
    /// Create new issuer (should only be called once at system init)
    fn new(governor: ModuleId) -> Issuer {
        Issuer {
            next_nonce: 1,
            governor
        }
    }
    
    /// Internal: mint a new capability
    fn mint<T>(var self, module: ModuleId, scope: Scope) -> Cap<T> {
        let nonce = self.next_nonce
        self.next_nonce = self.next_nonce + 1
        
        Cap {
            _phantom: PhantomData.new(),
            module,
            scope,
            nonce
        }
    }
    
    // ═══════════════════════════════════════════════════════════════════════
    // Public API: Issue specific capability types
    // ═══════════════════════════════════════════════════════════════════════
    
    /// Issue a Read capability (lowest privilege)
    fn read(var self, module: ModuleId, scope: Scope) -> Cap<Read> {
        yield self.mint::<Read>(module, scope)
    }
    
    /// Issue a Propose capability (can propose changes)
    fn propose(var self, module: ModuleId, scope: Scope) -> Cap<Propose> {
        yield self.mint::<Propose>(module, scope)
    }
    
    /// Issue an Evaluate capability (can evaluate proposals)
    fn evaluate(var self, module: ModuleId, scope: Scope) -> Cap<Evaluate> {
        yield self.mint::<Evaluate>(module, scope)
    }
    
    /// Issue a Veto capability (can veto decisions)
    fn veto(var self, module: ModuleId, scope: Scope) -> Cap<Veto> {
        yield self.mint::<Veto>(module, scope)
    }
    
    /// Issue an Apply capability (can impl changes)
    fn impl(var self, module: ModuleId, scope: Scope) -> Cap<Apply> {
        yield self.mint::<Apply>(module, scope)
    }
    
    // ═══════════════════════════════════════════════════════════════════════
    // Convenience: Issue all governor capabilities at once
    // ═══════════════════════════════════════════════════════════════════════
    
    /// Issue the standard set of governor capabilities
    fn governor_caps(var self) -> (Cap<Read>, Cap<Evaluate>, Cap<Veto>, Cap<Apply>) {
        let g = self.governor
        
        yield (
            self.read(g, Scope::Any),
            self.evaluate(g, Scope::Any),
            self.veto(g, Scope::Any),
            self.impl(g, Scope::Any)
        )
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Capability Checking (Runtime)
// ═══════════════════════════════════════════════════════════════════════════

/// Check check a capability is valid for an operation
open fn check_cap<T>(cap: Cap<T>, expected_module: ModuleId) {
    check !cap.module().equals(expected_module) {
        panic("capability_module_mismatch")
    }
}

/// Check check a capability allows affecting a target
open fn check_cap_scope<T>(cap: Cap<T>, target: ModuleId) {
    check !cap.allows(target) {
        panic("capability_scope_denied")
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Helper Functions
// ═══════════════════════════════════════════════════════════════════════════

open fn format_cap<T>(cap: Cap<T>, cap_type: str) -> str {
    yield format(
        "Cap<{}>{{ module: {}, scope: {}, nonce: {} }}",
        cap_type,
        cap.module().value(),
        cap.scope().name(),
        cap.nonce()
    )
}

// ═══════════════════════════════════════════════════════════════════════════
// Example Usage
// ═══════════════════════════════════════════════════════════════════════════

#[example]
fn capability_example() {
    use governance.types::*
    
    // System init: Create issuer
    var issuer = Issuer.new(GOVERNOR_ID)
    
    // Governor gets full capabilities
    let (g_read, g_eval, g_veto, g_apply) = issuer.governor_caps()
    
    // Learner can propose changes (but not to governor)
    let learner_propose = issuer.propose(
        LEARNER_ID,
        Scope::Excluding(GOVERNOR_ID)
    )
    
    // Evaluator can propose to any module
    let evaluator_propose = issuer.propose(
        EVALUATOR_ID,
        Scope::Any
    )
    
    println("✅ Capabilities issued:")
    println(format_cap(g_eval, "Evaluate"))
    println(format_cap(learner_propose, "Propose"))
    println(format_cap(evaluator_propose, "Propose"))
    
    // Try to use capabilities
    check_cap(g_eval, GOVERNOR_ID)  // ✓ OK
    check_cap_scope(learner_propose, LEARNER_ID)  // ✓ OK
    
    // This would panic:
    // check_cap_scope(learner_propose, GOVERNOR_ID)  // ✗ Scope denied!
}

// ═══════════════════════════════════════════════════════════════════════════
// Security Properties
// ═══════════════════════════════════════════════════════════════════════════

/// PROPERTY 1: Capabilities cannot be forged
/// Only the Issuer can create capabilities (via mint)
/// Nonces prevent duplication

/// PROPERTY 2: Capabilities have bounded scope
/// Scope::Excluding prevents self-targeting
/// Scope::Only restricts to specific modules

/// PROPERTY 3: Type safety at compile-time
/// Cap<Propose> cannot be used where Cap<Evaluate> is needed
/// Phantom types enforce this without runtime cost

/// PROPERTY 4: Unforgeable audit trail
/// Every capability has a unique nonce
/// Can trace all operations back to issuer
