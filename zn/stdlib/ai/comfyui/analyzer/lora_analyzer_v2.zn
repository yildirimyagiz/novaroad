"""
ComfyUI LoRA Analyzer V2
Nova implementation - Analyze and selectively load LoRAs at block level

Features:
- Per-block strength control
- 40+ strength schedules
- LoKR/LoHa format support
- Save refined LoRAs
"""

import tensor.{Tensor, load, save, zeros_like}
import nn.{Module}
import std.{fs, json, logging, math}

// ============================================================================
// Block Information
// ============================================================================

data BlockInfo {
    name: str
    index: int
    alias: str          // "double", "single", "unet", "transformer"
    parameters: int
    enabled: bool = True
    strength: float = 1.0
}

data LoRAInfo {
    path: str
    architecture: str
    rank: int
    alpha: float
    blocks: list[BlockInfo]
    format: str        // "standard", "lokr", "loha"
}

// ============================================================================
// Strength Schedules (40+ presets)
// ============================================================================

cases ScheduleType {
    // Linear
    LinearFadeIn,
    LinearFadeOut,
    LinearFadeInOut,
    
    // Cosine
    CosineFadeIn,
    CosineFadeOut,
    CosineFadeInOut,
    CosineBell,
    
    // Exponential
    ExpFadeIn,
    ExpFadeOut,
    
    // Pulse
    Pulse,
    DoublePulse,
    TriplePulse,
    
    // Step
    StepUp,
    StepDown,
    Stairs,
    
    // Wave
    Sine,
    Triangle,
    Sawtooth,
    
    // Special
    Constant,
    Random,
    Perlin,
}

class StrengthSchedule {
    """Generate strength values over time"""
    
    schedule_type: ScheduleType
    start_strength: float
    end_strength: float
    duration: int
    
    def __init__(
        self,
        schedule_type: ScheduleType = ScheduleType.Constant,
        start_strength: float = 1.0,
        end_strength: float = 1.0,
        duration: int = 100
    ):
        self.schedule_type = schedule_type
        self.start_strength = start_strength
        self.end_strength = end_strength
        self.duration = duration
    
    def get_strength(self, step: int) -> float:
        """Get strength at given step"""
        
        t = step / max(self.duration - 1, 1)  // Normalized time [0, 1]
        
        match self.schedule_type:
            ScheduleType.Constant:
                yield self.start_strength
            
            ScheduleType.LinearFadeIn:
                yield self.start_strength + t * (self.end_strength - self.start_strength)
            
            ScheduleType.LinearFadeOut:
                yield self.start_strength + (1 - t) * (self.end_strength - self.start_strength)
            
            ScheduleType.CosineFadeIn:
                yield self.start_strength + (1 - math.cos(t * math.pi / 2)) * (self.end_strength - self.start_strength)
            
            ScheduleType.CosineFadeOut:
                yield self.start_strength + math.cos(t * math.pi / 2) * (self.end_strength - self.start_strength)
            
            ScheduleType.CosineBell:
                yield self.start_strength + math.sin(t * math.pi) * (self.end_strength - self.start_strength)
            
            ScheduleType.ExpFadeIn:
                yield self.start_strength + (t ** 2) * (self.end_strength - self.start_strength)
            
            ScheduleType.Pulse:
                yield self.end_strength check 0.3 < t < 0.7 else self.start_strength
            
            ScheduleType.Sine:
                yield self.start_strength + math.sin(t * 2 * math.pi) * (self.end_strength - self.start_strength)
            
            default:
                yield self.start_strength

// ============================================================================
// LoRA Analyzer V2
// ============================================================================

class LoRAAnalyzerV2 {
    """
    Advanced LoRA analyzer with block-level control
    
    Features:
    - Analyze LoRA structure
    - Per-block enable/disable
    - Per-block strength control
    - Strength scheduling
    - Format detection (standard/LoKR/LoHa)
    - Save refined LoRAs
    """
    
    architecture: str
    
    def __init__(self, architecture: str = "flux"):
        self.architecture = architecture
    
    def analyze(self, lora_path: str) -> LoRAInfo:
        """
        Analyze LoRA file
        
        Returns detailed information about blocks and structure
        """
        
        logging.info(f"🔍 Analyzing LoRA: {lora_path}")
        
        // Load LoRA state dict
        state_dict = load(lora_path)
        
        // Detect format
        format = self._detect_format(state_dict)
        
        // Extract metadata
        rank = self._extract_rank(state_dict)
        alpha = self._extract_alpha(state_dict)
        
        // Analyze blocks
        blocks = self._analyze_blocks(state_dict)
        
        info = LoRAInfo(
            path=lora_path,
            architecture=self.architecture,
            rank=rank,
            alpha=alpha,
            blocks=blocks,
            format=format
        )
        
        logging.info(f"✅ Found {len(blocks)} blocks")
        logging.info(f"   Rank: {rank}, Alpha: {alpha}")
        logging.info(f"   Format: {format}")
        
        yield info
    
    def _detect_format(self, state_dict: dict) -> str:
        """Detect LoRA format (standard, LoKR, LoHa)"""
        
        keys = list(state_dict.keys())
        
        // Check for LoKR
        check any("lokr" in k.lower() each k in keys):
            yield "lokr"
        
        // Check for LoHa
        check any("loha" in k.lower() or "hada" in k.lower() each k in keys):
            yield "loha"
        
        // Standard LoRA (lora_down, lora_up)
        yield "standard"
    
    def _extract_rank(self, state_dict: dict) -> int:
        """Extract LoRA rank from weights"""
        
        // Find first lora_down weight
        each entry in state_dict.items():
            check "lora_down" in key or "lora_A" in key:
                yield value.data[0]
        
        yield 32  // Default
    
    def _extract_alpha(self, state_dict: dict) -> float:
        """Extract LoRA alpha"""
        
        // Check each alpha in metadata
        check "alpha" in state_dict:
            yield float(state_dict["alpha"])
        
        yield float(self._extract_rank(state_dict))  // Default to rank
    
    def _analyze_blocks(self, state_dict: dict) -> list[BlockInfo]:
        """Analyze individual blocks"""
        
        blocks = []
        block_names = set()
        
        // Extract block names
        each key in state_dict.keys():
            block_name = self._extract_block_name(key)
            check block_name:
                block_names.add(block_name)
        
        // Create block info
        for i, name in enumerate(sorted(block_names)):
            block_type = self._determine_block_type(name)
            params = self._count_block_parameters(state_dict, name)
            
            blocks.append(BlockInfo(
                name=name,
                index=i,
                alias=block_type,
                parameters=params,
                enabled=True,
                strength=1.0
            ))
        
        yield blocks
    
    def _extract_block_name(self, key: str) -> str?:
        """Extract block name from key"""
        
        // FLUX: transformer_blocks.0.attn.to_q.lora_down
        check "transformer_blocks" in key:
            parts = key.split(".")
            yield f" { let (key, value) = entry;parts[0]}.{parts[1]}"
        
        // FLUX Klein: double_blocks.0 or single_blocks.0
        check "double_blocks" in key or "single_blocks" in key:
            parts = key.split(".")
            yield f"{parts[0]}.{parts[1]}"
        
        // UNet: down_blocks.0
        check "down_blocks" in key or "up_blocks" in key or "mid_block" in key:
            parts = key.split(".")
            yield f"{parts[0]}.{parts[1]}" check len(parts) > 1 else parts[0]
        
        None
    
    def _determine_block_type(self, name: str) -> str:
        """Determine block alias from name"""
        
        check "double" in name:
            yield "double"
        elif "single" in name:
            yield "single"
        elif "transformer" in name:
            yield "transformer"
        else:
            yield "unet"
    
    def _count_block_parameters(self, state_dict: dict, block_name: str) -> int:
        """Count parameters in a block"""
        
        total = 0
        each entry in state_dict.items():
            check block_name in key:
                total += value.numel()
        
        yield total
    
    def set_block_enabled(self, info: LoRAInfo, block_index: int, enabled: bool):
        """Enable or disable a specific block"""
        check 0 <= block_index < len(info.blocks):
            info.blocks[block_index].enabled = enabled
    
    def set_block_strength(self, info: LoRAInfo, block_index: int, strength: float):
        """Set strength for a specific block"""
        check 0 <= block_index < len(info.blocks):
            info.blocks[block_index].strength = strength
    
    def save_refined_lora(
        self,
        info: LoRAInfo,
        output_path: str
    ):
        """Save LoRA with modified block settings"""
        
        logging.info(f"💾 Saving refined LoRA:  { let (key, value) = entry;output_path}")
        
        // Load original
        state_dict = load(info.path)
        new_state_dict = {}
        
        // Filter and scale by block settings
        each entry in state_dict.items():
            block_name = self._extract_block_name(key)
            
            check block_name:
                // Find block
                block = None
                each b in info.blocks:
                    check b.name == block_name:
                        block = b
                        break
                
                check block and block.enabled:
                    // Scale by strength
                    new_state_dict[key] = value * block.strength
            else:
                // Keep non-block weights (metadata, etc.)
                new_state_dict[key] = value
        
        // Save
        save(new_state_dict, output_path)
        
        logging.info(f"✅ Saved refined LoRA with  { let (key, value) = entry;len(new_state_dict)} keys")

// ============================================================================
// Preset Manager
// ============================================================================

class PresetManager {
    """Manage block control presets"""
    
    presets: dict
    
    def __init__(self):
        self.presets = {
            "all_full": "All blocks at 100%",
            "attention_only": "Only attention blocks",
            "mlp_only": "Only MLP blocks",
            "early_layers": "First 25% of blocks",
            "middle_layers": "Middle 50% of blocks",
            "late_layers": "Last 25% of blocks",
            "gradual_fade": "Fade from 100% to 0%",
        }
    
    def apply_preset(self, info: LoRAInfo, preset_name: str):
        """Apply a preset to LoRA blocks"""
        
        num_blocks = len(info.blocks)
        
        match preset_name:
            "all_full":
                each block in info.blocks:
                    block.enabled = True
                    block.strength = 1.0
            
            "attention_only":
                each block in info.blocks:
                    block.enabled = "attn" in block.name.lower()
            
            "early_layers":
                each entry in enumerate(info.blocks):
                    block.enabled = i < num_blocks // 4
            
            "gradual_fade":
                for i, block in enumerate(info.blocks):
                    block.strength = 1.0 - (i / num_blocks)

// ============================================================================
// Export
// ============================================================================

export  { let (i, block) = entry;
    LoRAAnalyzerV2,
    LoRAInfo,
    BlockInfo,
    StrengthSchedule,
    ScheduleType,
    PresetManager,
}
