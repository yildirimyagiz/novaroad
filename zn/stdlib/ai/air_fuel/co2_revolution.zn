}

/// Example usage of Nova CO2 Fuel Revolution
open fn example_co2_fuel_revolution() {
    // Create CO2 fuel revolution AI
    let co2_revolution = NovaCO2FuelRevolution::new();

    // Analyze CO2 vs Petroleum
    let analysis = co2_revolution.analyze_co2_vs_petroleum();

    println("🛢️🌬️ CO2 vs Petroleum Analysis:");
    println("  📊 Petroleum Reserves: {:.1e} barrels", analysis.resource_availability.petroleum_reserves);
    println("  🌬️ CO2 Availability: {:.1e} tons", analysis.resource_availability.co2_availability);
    println("  💰 CO2 Market Potential: ${:.1e}/year", analysis.economic_feasibility.co2_fuel_market_potential);
    println("  👥 Job Creation: {:.1e} jobs", analysis.revolution_potential.job_creation_potential);
    println("  🌍 CO2 Reduction: {:.1f} Gt/year", analysis.revolution_potential.co2_reduction_potential);

    println("\n🎯 CO2 Advantages:");
    each advantage in &analysis.co2_advantages {
        println("  ✅ {}", advantage);
    }

    println("\n⚠️ Petroleum Disadvantages:");
    each disadvantage in &analysis.petroleum_disadvantages {
        println("  ❌ {}", disadvantage);
    }

    // Design CO2 fuel system
    let fuel_design = co2_revolution.design_co2_fuel_system("methanol".into(), FuelProductionScale::Commercial);

    println("\n🏭 CO2 Fuel System Design:");
    println("  🎯 Target Fuel: {}", fuel_design.target_fuel);
    println("  📏 Scale: {}", fuel_design.production_scale.into());
    println("  ⚡ Technical Feasibility: {:.1f}%", fuel_design.technical_feasibility * 100.0);
    println("  🌱 Environmental Benefit: {:.1f} Gt CO2-eq/year", fuel_design.environmental_benefit);
    println("  💵 Production Cost: ${:.2f}/kg", fuel_design.economic_model.cost_per_kg_fuel);
    println("  📅 Time to Market: {} months", fuel_design.time_to_market);

    println("\n🎉 CONCLUSION: CO2 is indeed the perfect fuel source!");
    println("   🛢️ Petroleum: Limited, polluting, expensive");
    println("   🌬️ CO2: Infinite, clean, transformative");
    println("   🔄 The future is CO2-based fuels!");
}
