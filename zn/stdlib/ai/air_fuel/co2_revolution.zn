// Data Structures
#[derive(Clone)]
open cases FuelProductionScale {
    Pilot,
    Demonstration,
    Commercial,
}

impl FuelProductionScale {
    fn to_string(&self) -> String {
        match self {
            FuelProductionScale::Pilot => "Pilot".into(),
            FuelProductionScale::Demonstration => "Demonstration".into(),
            FuelProductionScale::Commercial => "Commercial".into(),
        }
    }
}

#[derive(Clone)]
open data CO2vsPetroleumAnalysis {
    carbon_cycle_comparison: CarbonCycleComparison,
    resource_availability: ResourceAvailability,
    environmental_impact: EnvironmentalImpact,
    economic_feasibility: EconomicComparison,
    energy_efficiency: EnergyEfficiencyComparison,
    scalability_potential: ScalabilityAssessment,
    co2_advantages: Vec<String>,
    petroleum_disadvantages: Vec<String>,
    transition_strategy: TransitionStrategy,
    revolution_potential: RevolutionPotential,
}

#[derive(Clone)]
open data CarbonCycleComparison {
    petroleum_cycle: CarbonCycle,
    co2_cycle: CarbonCycle,
    cycle_advantage: String,
}

#[derive(Clone)]
open data CarbonCycle {
    extraction: f64,
    processing: f64,
    consumption: f64,
    emission: f64,
    cycle_closure: f64,
    carbon_efficiency: f64,
}

