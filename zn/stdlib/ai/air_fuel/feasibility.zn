// Data Structures
#[derive(Clone)]
open data ComprehensiveFeasibilityReport {
    technical_feasibility: TechnicalAnalysis,
    economic_feasibility: EconomicAnalysis,
    infrastructure_feasibility: InfrastructureAnalysis,
    environmental_feasibility: EnvironmentalAnalysis,
    social_feasibility: SocialAnalysis,
    risk_assessment: RiskAssessment,
    implementation_roadmap: ImplementationRoadmap,
    overall_feasibility_score: f64,
    feasibility_rating: String,
    go_no_go_recommendation: String,
    critical_success_factors: Vec<String>,
    potential_show_stoppers: Vec<String>,
}

#[derive(Clone)]
open data FeasibilityWeights {
    technical: f64,
    economic: f64,
    infrastructure: f64,
    environmental: f64,
    social: f64,
}

#[derive(Clone)]
open data TechnicalAnalysis {
    technology_readiness_level: usize,
    proven_technologies: Vec<String>,
    emerging_technologies: Vec<String>,
    technical_challenges: Vec<String>,
    feasibility_score: f64,
    time_to_technical_maturity: usize,
    r_d_investment_needed: f64,
}

#[derive(Clone)]
open data EconomicAnalysis {
    current_production_cost: f64,
    target_competitive_cost: f64,
    capital_investment_required: f64,
    operational_cost_breakdown: HashMap<String, f64>,
    revenue_projections: Vec<(usize, f64)>,
    break_even_analysis: BreakEvenAnalysis,
    feasibility_score: f64,
    cost_reduction_roadmap: Vec<String>,
}

#[derive(Clone)]
open data BreakEvenAnalysis {
    break_even_year: usize,
    cumulative_investment: f64,
    annual_revenue_at_break_even: f64,
}

#[derive(Clone)]
open data InfrastructureAnalysis {
    existing_infrastructure_utilization: f64,
    new_infrastructure_required: Vec<String>,
    infrastructure_cost_estimate: f64,
    development_timeline: usize,
    integration_challenges: Vec<String>,
    feasibility_score: f64,
    retrofit_vs_new_build: RetrofitAnalysis,
}

#[derive(Clone)]
open data RetrofitAnalysis {
    retrofit_percentage: f64,
    new_build_percentage: f64,
    cost_savings_from_retrofit: f64,
}

#[derive(Clone)]
open data EnvironmentalAnalysis {
    carbon_dioxide_equivalent_balance: f64,
    lifecycle_emissions_comparison: LifecycleComparison,
    water_usage_assessment: WaterUsage,
    land_use_requirements: LandUse,
    ecosystem_services_value: f64,
