    co_location_opportunities: Vec<String>,
}

#[derive(Clone)]
open data SocialAnalysis {
    public_opinion_survey: PublicOpinion,
    employment_impact: EmploymentImpact,
    community_benefits: Vec<String>,
    equity_considerations: EquityConsiderations,
    feasibility_score: f64,
    social_impact_assessment: SocialImpact,
}

