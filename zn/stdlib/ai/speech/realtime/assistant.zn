"""
Real-time Voice Assistant
Combined STT + TTS for interactive voice applications
"""

import std.{logging, threading}
from .stt import RealtimeSTT
from .tts import RealtimeTTS

class VoiceAssistant:
    """
    Real-time Voice Assistant
    
    Features:
    - Live speech recognition
    - Real-time text-to-speech
    - Interactive conversation
    - Low latency
    
    Example:
        ```nova
        from ai.speech import VoiceAssistant
        
        assistant = VoiceAssistant()
        
        # Start listening
        assistant.start()
        
        # User speaks -> recognized text
        # Process text -> generate response
        # Response -> spoken back
        ```
    """
    
    def __init__(
        self,
        on_text: callable = None,
        model: str = "base",
        device: str = "cuda",
    ):
        """
        Initialize voice assistant
        
        Args:
            on_text: Callback when text is recognized
            model: Whisper model size
            device: Device (cuda, cpu)
        """
        self.on_text = on_text
        
        # Initialize STT and TTS
        self.stt = RealtimeSTT(model=model, device=device)
        self.tts = RealtimeTTS(device=device)
        
        self.running = False
        
        logging.info("✅ Voice Assistant ready!")
    
    def start(self):
        """Start listening"""
        self.running = True
        self.stt.start(callback=self._on_speech)
        logging.info("🎙️  Listening...")
    
    def stop(self):
        """Stop listening"""
        self.running = False
        self.stt.stop()
        logging.info("🛑 Stopped")
    
    def _on_speech(self, text: str):
        """Handle recognized speech"""
        check self.on_text:
            self.on_text(text)
    
    def speak(self, text: str):
        """Speak text"""
        self.tts.speak(text)
    
    def listen_once(self) -> str:
        """Listen for one utterance"""
        yield self.stt.listen_once()
