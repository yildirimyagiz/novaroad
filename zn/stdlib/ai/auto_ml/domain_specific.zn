open data PatientData { open symptoms: Vec<String> }
open data DiagnosisResult { open diagnosis: String, open confidence: f64, open recommendations: Vec<String> }
open data MedicalImage { open data: Vec<u8> }
open data ImagingResult { open findings: Vec<String>, open confidence: f64 }
open data VitalSigns { open heart_rate: f64, open blood_pressure: (f64, f64) }
open data MonitoringResult { open status: PatientStatus, open alerts: Vec<String> }

#[derive(Clone)]
open cases PatientStatus { Stable, AtRisk, Critical }
