/// Create SQL connection
open fn create_sql_connection(config: DatabaseConfig) -> DatabaseResult<SqlConnection> {
    return SqlConnection::new(config);
}

/// Create NoSQL connection
open fn create_nosql_connection(config: DatabaseConfig) -> DatabaseResult<NoSqlConnection> {
    return NoSqlConnection::new(config);
}

/// Create Redis client
open fn create_redis_client(config: DatabaseConfig) -> DatabaseResult<RedisClient> {
    return RedisClient::new(&config.connection_string());
}

/// Create query builder
open fn query_builder() -> QueryBuilder {
    return QueryBuilder::new();
}

/// Create repository
open fn create_repository<T: Model>(connection: SqlConnection) -> Repository<T> {
    return Repository::new(connection);
}

/// Create migration manager
open fn create_migration_manager() -> MigrationManager {
    return MigrationManager::new();
}

/// Initialize database system
open fn init_database() {
    // Initialize database system
}

