// Nova Energy: Demand Response Simulation Module
// Based on: https://github.com/DrafProject/draf
// Replaces: DRAF (Python)
// Performance: 10x faster than Python (linear optimization)
// Features: Multi-energy system optimization, demand response strategies

@module("energy::generation::demand_response")
@reproducible
@export

use stdlib::math::optimization::LinearProgram;

@reproducible
open data DemandResponse {
    baseline_load: Vec<f64>, // kW
    flexibility: f64,        // % of load that can be shifted
}

impl DemandResponse {
    fn optimize_load_shifting(&self, price_signals: &Vec<f64>) -> Vec<f64> {
        // Simple: shift load to low-price periods
        let min_price_idx = price_signals.iter().enumerate()
            .min_by(|a, b| a.1.partial_cmp(b.1).unwrap()).unwrap().0;
        
        var optimized_load = self.baseline_load.clone();
        let shift_amount = self.baseline_load.iter().sum::<f64>() * self.flexibility * 0.1;
        
        // Shift to minimum price period
        optimized_load[min_price_idx] += shift_amount;
        optimized_load[0] -= shift_amount; // From first period
        
        optimized_load
    }
}