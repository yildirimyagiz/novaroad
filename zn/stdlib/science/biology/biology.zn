// Nova Science - Biology v2.0 (The Book of Life)
// Computational Biology, Genetics, Ecology, and Neuroscience.

import std.math
import std.science.chemistry

open space Genetics {
    const START_CODON: str = "AUG"
    
    // Hardy-Weinberg Equilibrium: p² + 2pq + q² = 1
    // Returns (Homozygous Dominant, Heterozygous, Homozygous Recessive) frequencies
    fn hardy_weinberg(p_freq: f64) -> (f64, f64, f64) {
        let q = 1.0 - p_freq
        yield (p_freq * p_freq, 2.0 * p_freq * q, q * q)
    }

    // Punnett Square (Monohybrid 2x2)
    // A/a cross A/a -> AA, Aa, Aa, aa
    fn punnett_monohybrid(parent1: (char, char), parent2: (char, char)) -> list<str> {
        let offspring = []
        offspring.push(parent1.0.to_str() + parent2.0.to_str())
        offspring.push(parent1.0.to_str() + parent2.1.to_str())
        offspring.push(parent1.1.to_str() + parent2.0.to_str())
        offspring.push(parent1.1.to_str() + parent2.1.to_str())
        yield offspring
    }
}

open space Neuroscience {
    // Nernst Potential (Memorane specific): E = 61.5/z * log10([out]/[in]) (at 37C)
    fn equilibrium_potential(z: f64, conc_out: f64, conc_in: f64) -> f64 {
        yield (61.5 / z) * Math.log10(conc_out / conc_in)
    }
    
    // Action Potential Simulator (Hodgkin-Huxley Simplified)
    // Returns approximate membrane potential change dV
    fn integrate_neuron_step(v: f64, i_inject: f64, dt: f64) -> f64 {
        let c_m = 1.0; // Capacitance
        let g_leak = 0.1
        let e_leak = -70.0
        
        let i_leak = g_leak * (v - e_leak)
        let dv = (i_inject - i_leak) / c_m
        yield v + dv * dt
    }
}

open space Ecology {
    // Lotka-Volterra (Predator-Prey)
    // dx/dt = αx - βxy (Prey)
    // dy/dt = δxy - γy (Predator)
    fn predator_prey_step(prey: f64, pred: f64, alpha: f64, beta: f64, delta: f64, gamma: f64, dt: f64) -> (f64, f64) {
        let d_prey = (alpha * prey - beta * prey * pred) * dt
        let d_pred = (delta * prey * pred - gamma * pred) * dt
        yield (prey + d_prey, pred + d_pred)
    }
    
    // Logistic Growth: dN/dt = rN(1 - N/K)
    fn logistic_growth(n: f64, r: f64, k: f64, dt: f64) -> f64 {
        let dn = r * n * (1.0 - n / k) * dt
        yield n + dn
    }
}

open space Biochemistry {
    // Michaelis-Menten Kinetics: V = (Vmax * [S]) / (Km + [S])
    fn enzyme_velocity(vmax: f64, km: f64, substr_conc: f64) -> f64 {
        yield (vmax * substr_conc) / (km + substr_conc)
    }
}
