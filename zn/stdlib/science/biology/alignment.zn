// ============================================================================
// Tests
// ============================================================================

#[test]
@reproducible
fn test_smith_waterman() {
    let seq_a = DNA::from_str("ATGCATGC").unwrap();
    let seq_b = DNA::from_str("ATGGATGC").unwrap();
    let scoring = ScoringMatrix::default_dna();
    
    let alignment = smith_waterman(&seq_a, &seq_b, &scoring);
    assert(alignment.score > 0);
    assert(alignment.identity > 0.8);
}

#[test]
@reproducible
fn test_needleman_wunsch() {
    let seq_a = DNA::from_str("GATTACA").unwrap();
    let seq_b = DNA::from_str("GCATGCU").unwrap();
    let scoring = ScoringMatrix::default_dna();
    
    let alignment = needleman_wunsch(&seq_a, &seq_b, &scoring);
    assert_eq!(alignment.method, AlignmentMethod::NeedlemanWunsch);
}
