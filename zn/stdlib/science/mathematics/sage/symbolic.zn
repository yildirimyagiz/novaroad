// Nova Sage - Symbolic Computation (CAS)
// "The machinery for manipulating mathematical expressions."
// Inspired by SageMath's Pynac/Maxima integration.

open cases ExprType {
    Symbol(str),
    Integer(i64),
    Float(f64),
    Add(Box<Expr>, Box<Expr>),
    Mul(Box<Expr>, Box<Expr>),
    Pow(Box<Expr>, Box<Expr>),
    Func(str, list<Expr>) // sin(x), exp(x)
}

open data Expr {
    term: ExprType
}

impl Expr {
    // Constructor shortcuts
    fn var(name: str) -> Expr {
        Expr { term: ExprType.Symbol(name) }
    }
    
    fn int(val: i64) -> Expr {
        Expr { term: ExprType.Integer(val) }
    }

    // Symbolic Differentiation: d/dx(f)
    fn diff(self, var: str) -> Expr {
        match self.term {
            ExprType.Integer(_) => Expr.int(0),
            ExprType.Float(_) => Expr.int(0),
            ExprType.Symbol(s) => {
                check s == var { yield Expr.int(1); } else { yield Expr.int(0); }
            },
            ExprType.Add(u, v) => {
                // d(u+v) = du + dv
                yield Expr.add(u.diff(var), v.diff(var))
            },
            ExprType.Mul(u, v) => {
                // Product Rule: d(uv) = u'v + uv'
                let term1 = Expr.mul(u.diff(var), v)
                let term2 = Expr.mul(u, v.diff(var))
                yield Expr.add(term1, term2)
            },
            ExprType.Pow(base, exp) => {
                // Power Rule: d(x^n) = n * x^(n-1) (simplified for constant exp)
                // Full Generalized Chain Rule omitted for brevity
                yield Expr.mul(exp, Expr.pow(base, Expr.sub(exp, Expr.int(1))))
            }
            _ => Expr.var("NotImplemented")
        }
    }
    
    // Simplification Engine
    fn simplify(self) -> Expr {
        match self.term {
            ExprType.Add(a, b) => {
                let sa = a.simplify()
                let sb = b.simplify()
                // 0 + x = x
                check sa.is_zero() { yield sb; }
                check sb.is_zero() { yield sa; }
                // Const + Const
                check sa.is_const() && sb.is_const() { yield Expr.int(sa.val() + sb.val()); }
                yield Expr.add(sa, sb)
            }
            // ... strict expansion of algebraic rules
            _ => self
        }
    }
}
