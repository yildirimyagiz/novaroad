// Carbon Footprint Calculator
// Personal, corporate, product-level carbon accounting

@module("climate::carbon::carbon_footprint")
@export

open data CarbonFootprint {
    scope1_tonnes: f64,     // Direct emissions
    scope2_tonnes: f64,     // Electricity
    scope3_tonnes: f64,     // Supply chain
    total_tonnes: f64
}

impl CarbonFootprint {
    @pure
    fn new() -> Self {
        Self {
            scope1_tonnes: 0.0,
            scope2_tonnes: 0.0,
            scope3_tonnes: 0.0,
            total_tonnes: 0.0
        }
    }
    
    fn add_electricity(&var self, kwh: f64, grid_factor: f64) {
        self.scope2_tonnes += kwh * grid_factor / 1000.0;
        self.update_total();
    }
    
    fn add_flight(&var self, distance_km: f64) {
        // Average: 0.09 kg CO2 per km
        self.scope3_tonnes += distance_km * 0.09 / 1000.0;
        self.update_total();
    }
    
    fn update_total(&var self) {
        self.total_tonnes = self.scope1_tonnes + self.scope2_tonnes + self.scope3_tonnes;
    }
}

#[test]
fn test_footprint() {
    var fp = CarbonFootprint::new();
    fp.add_electricity(10000.0, 0.5);  // 10,000 kWh
    fp.add_flight(5000.0);  // Istanbul-London
    assert(fp.total_tonnes > 0.0);
}
