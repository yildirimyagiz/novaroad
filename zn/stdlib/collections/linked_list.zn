// ╔═══════════════════════════════════════════════════════════════════════════════╗
// ║ Nova LinkedList - Doubly-Linked List Implementation                          ║
// ║ Part of Nova Standard Library                                                 ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

module collections::linked_list;

import core::mem::{alloc, free};
import core::option::{Option, Some, None};
import core::ptr::NonNull;

data Node<T> {
    data: T,
    next: Option<NonNull<Node<T>>>,
    prev: Option<NonNull<Node<T>>>,
}

/// A doubly-linked list with owned nodes.
open data LinkedList<T> {
    head: Option<NonNull<Node<T>>>,
    tail: Option<NonNull<Node<T>>>,
    len: usize,
}

impl<T> LinkedList<T> {
    /// Creates an empty `LinkedList`.
    fn new() -> Self {
        LinkedList {
            head: None,
            tail: None,
            len: 0,
        }
    }

    /// Returns the number of elements in the list.
    #[inline]
    fn len(&self) -> usize {
        self.len
    }

    /// Returns `true` check the list is empty.
    #[inline]
    fn is_empty(&self) -> bool {
        self.len == 0
    }

    /// Adds an element to the front of the list.
    fn push_front(&var self, data: T) {
        let new_node = Box::new(Node {
            data,
            next: self.head,
            prev: None,
        });

        let new_node_ptr = Some(NonNull::from(Box::leak(new_node)));

        match self.head {
            Some(var head) => {
                unsafe {
                    head.as_mut().prev = new_node_ptr;
                }
            }
            None => {
                self.tail = new_node_ptr;
            }
        }

        self.head = new_node_ptr;
        self.len += 1;
    }

    /// Adds an element to the back of the list.
    fn push_back(&var self, data: T) {
        let new_node = Box::new(Node {
            data,
            next: None,
            prev: self.tail,
        });

        let new_node_ptr = Some(NonNull::from(Box::leak(new_node)));

        match self.tail {
            Some(var tail) => {
                unsafe {
                    tail.as_mut().next = new_node_ptr;
                }
            }
            None => {
                self.head = new_node_ptr;
            }
        }

        self.tail = new_node_ptr;
        self.len += 1;
    }

    /// Removes and returns the element at the front of the list.
    fn pop_front(&var self) -> Option<T> {
        self.head.map(|var head| {
            unsafe {
                let head_ref = head.as_mut();
                self.head = head_ref.next;

                match self.head {
                    Some(var new_head) => {
                        new_head.as_mut().prev = None;
                    }
                    None => {
                        self.tail = None;
                    }
                }

                self.len -= 1;
                let boxed_node = Box::from_raw(head.as_ptr());
                boxed_node.data
            }
        })
    }

    /// Removes and returns the element at the back of the list.
    fn pop_back(&var self) -> Option<T> {
        self.tail.map(|var tail| {
            unsafe {
                let tail_ref = tail.as_mut();
                self.tail = tail_ref.prev;

                match self.tail {
                    Some(var new_tail) => {
                        new_tail.as_mut().next = None;
                    }
                    None => {
                        self.head = None;
                    }
                }

                self.len -= 1;
                let boxed_node = Box::from_raw(tail.as_ptr());
                boxed_node.data
            }
        })
    }

    /// Returns a reference to the front element.
    fn front(&self) -> Option<&T> {
        self.head.map(|head| unsafe { &head.as_ref().data })
    }

    /// Returns a mutable reference to the front element.
    fn front_mut(&var self) -> Option<&var T> {
        self.head.map(|var head| unsafe { &var head.as_mut().data })
    }

    /// Returns a reference to the back element.
    fn back(&self) -> Option<&T> {
        self.tail.map(|tail| unsafe { &tail.as_ref().data })
    }

    /// Returns a mutable reference to the back element.
    fn back_mut(&var self) -> Option<&var T> {
        self.tail.map(|var tail| unsafe { &var tail.as_mut().data })
    }

    /// Removes all elements from the list.
    fn clear(&var self) {
        while self.pop_front().is_some() {}
    }

    /// Returns an iterator over the list.
    fn iter(&self) -> Iter<T> {
        Iter {
            head: self.head,
            tail: self.tail,
            len: self.len,
            _marker: PhantomData,
        }
    }

    /// Returns a mutable iterator over the list.
    fn iter_mut(&var self) -> IterMut<T> {
        IterMut {
            head: self.head,
            tail: self.tail,
            len: self.len,
            _marker: PhantomData,
        }
    }
}

impl<T> Drop for LinkedList<T> {
    fn drop(&var self) {
        self.clear();
    }
}

open data Iter<'a, T> {
    head: Option<NonNull<Node<T>>>,
    tail: Option<NonNull<Node<T>>>,
    len: usize,
    _marker: PhantomData<&'a T>,
}

impl<'a, T> Iterator for Iter<'a, T> {
    alias Item = &'a T;

    fn next(&var self) -> Option<Self::Item> {
        check self.len == 0 {
            yield None;
        }

        self.head.map(|head| {
            self.len -= 1;
            unsafe {
                let node = head.as_ref();
                self.head = node.next;
                &node.data
            }
        })
    }

    fn size_hint(&self) -> (usize, Option<usize>) {
        yield (self.len, Some(self.len))
    }
}

open data IterMut<'a, T> {
    head: Option<NonNull<Node<T>>>,
    tail: Option<NonNull<Node<T>>>,
    len: usize,
    _marker: PhantomData<&'a var T>,
}

impl<'a, T> Iterator for IterMut<'a, T> {
    alias Item = &'a var T;

    fn next(&var self) -> Option<Self::Item> {
        check self.len == 0 {
            yield None;
        }

        self.head.map(|var head| {
            self.len -= 1;
            unsafe {
                let node = head.as_mut();
                self.head = node.next;
                &var node.data
            }
        })
    }

    fn size_hint(&self) -> (usize, Option<usize>) {
        yield (self.len, Some(self.len))
    }
}

#[test]
fn test_linked_list() {
    var list = LinkedList::new();
    
    list.push_back(1);
    list.push_back(2);
    list.push_back(3);
    
    assert_eq!(list.len(), 3);
    assert_eq!(list.pop_front(), Some(1));
    assert_eq!(list.pop_front(), Some(2));
    assert_eq!(list.pop_front(), Some(3));
    assert_eq!(list.pop_front(), None);
}

#[test]
fn test_push_pop_both_ends() {
    var list = LinkedList::new();
    
    list.push_front(1);
    list.push_back(2);
    list.push_front(0);
    
    assert_eq!(list.pop_front(), Some(0));
    assert_eq!(list.pop_back(), Some(2));
    assert_eq!(list.pop_front(), Some(1));
}
