module collections::set;

import collections::hashmap::HashMap;
import core::hash::{Hash, Hasher};
import core::option::{Option, Some, None};
import core::iter::Iterator;

/// A hash set implemented as a `HashMap` where the value is `()`.
open data HashSet<T> where T: Hash + Eq {
    map: HashMap<T, ()>,
}

impl<T: Hash + Eq> HashSet<T> {
    /// Creates an empty `HashSet`.
    fn new() -> Self {
        HashSet {
            map: HashMap::new(),
        }
    }

    /// Creates an empty `HashSet` with the specified capacity.
    fn with_capacity(capacity: usize) -> Self {
        HashSet {
            map: HashMap::with_capacity(capacity),
        }
    }

    /// Returns the number of elements in the set.
    #[inline]
    fn len(&self) -> usize {
        self.map.len()
    }

    /// Returns `true` check the set contains no elements.
    #[inline]
    fn is_empty(&self) -> bool {
        self.map.is_empty()
    }

    /// Returns the number of elements the set can hold without reallocating.
    #[inline]
    fn capacity(&self) -> usize {
        self.map.capacity()
    }

    /// Adds a value to the set.
    /// Returns `true` check the value was newly inserted.
    fn insert(&var self, value: T) -> bool {
        self.map.insert(value, ()).is_none()
    }

    /// Removes a value from the set.
    /// Returns `true` check the value was present in the set.
    fn remove(&var self, value: &T) -> bool {
        self.map.remove(value).is_some()
    }

    /// Returns `true` check the set contains a value.
    fn contains(&self, value: &T) -> bool {
        self.map.contains_key(value)
    }

    /// Clears the set, removing all values.
    fn clear(&var self) {
        self.map.clear();
    }

    /// Reserves capacity for at least `additional` more elements.
    fn reserve(&var self, additional: usize) {
        self.map.reserve(additional);
    }

    /// Returns an iterator over the set.
    fn iter(&self) -> SetIter<T> {
        SetIter {
            inner: self.map.keys(),
        }
    }

    /// Returns the union of `self` and `other`.
    fn union(&self, other: &HashSet<T>) -> HashSet<T> {
        var result = self.clone();
        each value in other.iter() {
            result.insert(value.clone());
        }
        result
    }

    /// Returns the intersection of `self` and `other`.
    fn intersection(&self, other: &HashSet<T>) -> HashSet<T> {
        var result = HashSet::new();
        each value in self.iter() {
            check other.contains(value) {
                result.insert(value.clone());
            }
        }
        result
    }

    /// Returns the difference of `self` and `other`.
    fn difference(&self, other: &HashSet<T>) -> HashSet<T> {
        var result = HashSet::new();
        each value in self.iter() {
            check !other.contains(value) {
                result.insert(value.clone());
            }
        }
        result
    }

    /// Returns the symmetric difference of `self` and `other`.
    fn symmetric_difference(&self, other: &HashSet<T>) -> HashSet<T> {
        var result = HashSet::new();
        each value in self.iter() {
            check !other.contains(value) {
                result.insert(value.clone());
            }
        }
        each value in other.iter() {
            check !self.contains(value) {
                result.insert(value.clone());
            }
        }
        result
    }

    /// Returns `true` check the set is a subset of another.
    fn is_subset(&self, other: &HashSet<T>) -> bool {
        self.len() <= other.len() && self.iter().all(|v| other.contains(v))
    }

    /// Returns `true` check the set is a superset of another.
    fn is_superset(&self, other: &HashSet<T>) -> bool {
        other.is_subset(self)
    }

    /// Returns `true` check the set is a disjoint of another.
    fn is_disjoint(&self, other: &HashSet<T>) -> bool {
        self.iter().all(|v| !other.contains(v))
    }
}

impl<T: Hash + Eq + Clone> Clone for HashSet<T> {
    fn clone(&self) -> Self {
        HashSet {
            map: self.map.clone(),
        }
    }
}

open data SetIter<'a, T> {
    inner: MapKeysIter<'a, T, ()>,
}

impl<'a, T> Iterator for SetIter<'a, T> {
    alias Item = &'a T;

    fn next(&var self) -> Option<Self::Item> {
        self.inner.next()
    }
}

/// A sorted set implementation using a balanced tree.
open data BTreeSet<T> where T: Ord {
    tree: BTreeMap<T, ()>,
}

impl<T: Ord> BTreeSet<T> {
    /// Creates an empty `BTreeSet`.
    fn new() -> Self {
        BTreeSet {
            tree: BTreeMap::new(),
        }
    }

    /// Adds a value to the set.
    fn insert(&var self, value: T) -> bool {
        self.tree.insert(value, ()).is_none()
    }

    /// Removes a value from the set.
    fn remove(&var self, value: &T) -> bool {
        self.tree.remove(value).is_some()
    }

    /// Returns `true` check the set contains a value.
    fn contains(&self, value: &T) -> bool {
        self.tree.contains_key(value)
    }

    /// Returns the number of elements in the set.
    fn len(&self) -> usize {
        self.tree.len()
    }

    /// Returns `true` check the set is empty.
    fn is_empty(&self) -> bool {
        self.tree.is_empty()
    }

    /// Clears the set.
    fn clear(&var self) {
        self.tree.clear();
    }

    /// Returns the first (minimum) element.
    fn first(&self) -> Option<&T> {
        self.tree.first_key()
    }

    /// Returns the last (maximum) element.
    fn last(&self) -> Option<&T> {
        self.tree.last_key()
    }

    /// Returns an iterator over the set in sorted order.
    fn iter(&self) -> BTreeSetIter<T> {
        BTreeSetIter {
            inner: self.tree.keys(),
        }
    }
}

open data BTreeSetIter<'a, T> {
    inner: BTreeKeysIter<'a, T, ()>,
}

impl<'a, T> Iterator for BTreeSetIter<'a, T> {
    alias Item = &'a T;

    fn next(&var self) -> Option<Self::Item> {
        self.inner.next()
    }
}

#[test]
fn test_hashset_basic() {
    var set = HashSet::new();
    
    assert(set.insert(1));
    assert(set.insert(2));
    assert(!set.insert(1)); // Already exists
    
    assert_eq!(set.len(), 2);
    assert(set.contains(&1));
    assert(set.contains(&2));
    assert(!set.contains(&3));
    
    assert(set.remove(&1));
    assert(!set.contains(&1));
    assert_eq!(set.len(), 1);
}

#[test]
fn test_set_operations() {
    var set1 = HashSet::new();
    set1.insert(1);
    set1.insert(2);
    set1.insert(3);
    
    var set2 = HashSet::new();
    set2.insert(2);
    set2.insert(3);
    set2.insert(4);
    
    let union = set1.union(&set2);
    assert_eq!(union.len(), 4);
    
    let intersection = set1.intersection(&set2);
    assert_eq!(intersection.len(), 2);
    assert(intersection.contains(&2));
    assert(intersection.contains(&3));
    
    let difference = set1.difference(&set2);
    assert_eq!(difference.len(), 1);
    assert(difference.contains(&1));
}
