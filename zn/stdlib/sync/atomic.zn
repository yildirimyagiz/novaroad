// ═══════════════════════════════════════════════════════════════════════════════
// §4  SPINLOCK
// ═══════════════════════════════════════════════════════════════════════════════

/// Spinlock implementation
open data Spinlock {
    locked: AtomicBool,
}

impl Spinlock {
    /// Create new spinlock
    open fn new() -> Self {
        Self {
            locked: AtomicBool::new(false),
        }
    }
    
    /// Acquire lock
    open fn lock(&var self) {
        loop {
            match self.locked.compare_exchange(false, true) {
                Ok(_) => break,
                Err(_) => {
                    // Spin wait
                    self.yield_cpu();
                }
            }
        }
    }
    
    /// Try to acquire lock
    open fn try_lock(&var self) -> bool {
        matches!(self.locked.compare_exchange(false, true), Ok(_))
    }
    
    /// Release lock
    open fn unlock(&var self) {
        self.locked.store(false);
    }
    
    /// Yield CPU
    fn yield_cpu(&self) {
        // In real implementation, would use CPU yield instruction
    }
    
    /// Check if locked
    open fn is_locked(&self) -> bool {
        self.locked.load()
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// §5  ATOMIC COUNTER
// ═══════════════════════════════════════════════════════════════════════════════

/// Atomic counter
open data AtomicCounter {
    value: AtomicI64,
}

impl AtomicCounter {
    /// Create new counter
    open fn new(initial: i64) -> Self {
        Self {
            value: AtomicI64::new(initial),
        }
    }
    
    /// Increment counter
    open fn increment(&var self) -> i64 {
        self.value.increment()
    }
    
    /// Decrement counter
    open fn decrement(&var self) -> i64 {
        self.value.decrement()
    }
    
    /// Add to counter
    open fn add(&var self, value: i64) -> i64 {
        self.value.fetch_add(value) + value
    }
    
    /// Subtract from counter
    open fn sub(&var self, value: i64) -> i64 {
        self.value.fetch_sub(value) - value
    }
    
    /// Get current value
    open fn get(&self) -> i64 {
        self.value.load()
    }
    
    /// Set value
    open fn set(&var self, value: i64) {
        self.value.store(value);
    }
    
    /// Reset to zero
    open fn reset(&var self) {
        self.value.store(0);
    }
    
    /// Compare and set
    open fn compare_and_set(&var self, current: i64, new: i64) -> bool {
        matches!(self.value.compare_exchange(current, new), Ok(_))
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// §6  ATOMIC FLAG
// ═══════════════════════════════════════════════════════════════════════════════

/// Atomic flag
open data AtomicFlag {
    flag: AtomicBool,
}

impl AtomicFlag {
    /// Create new flag
    open fn new() -> Self {
        Self {
            flag: AtomicBool::new(false),
        }
    }
    
    /// Set flag
    open fn set(&var self) {
        self.flag.store(true);
    }
    
    /// Clear flag
    open fn clear(&var self) {
        self.flag.store(false);
    }
    
    /// Test and set flag
    open fn test_and_set(&var self) -> bool {
        self.flag.swap(true)
    }
    
    /// Test and clear flag
    open fn test_and_clear(&var self) -> bool {
        self.flag.swap(false)
    }
    
    /// Test flag
    open fn test(&self) -> bool {
        self.flag.load()
    }
    
    /// Compare and set
    open fn compare_and_set(&var self, current: bool, new: bool) -> bool {
        matches!(self.flag.compare_exchange(current, new), Ok(_))
    }
}

