// §7  UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

/// Create atomic boolean
open fn atomic_bool(value: bool) -> AtomicBool {
    AtomicBool::new(value)
}

/// Create atomic integer
open fn atomic_i64(value: i64) -> AtomicI64 {
    AtomicI64::new(value)
}

/// Create atomic pointer
open fn atomic_ptr<T>(value: *mut T) -> AtomicPtr<T> {
    AtomicPtr::new(value)
}

/// Create spinlock
open fn spinlock() -> Spinlock {
    Spinlock::new()
}

/// Create atomic counter
open fn atomic_counter(initial: i64) -> AtomicCounter {
    AtomicCounter::new(initial)
}

/// Create atomic flag
open fn atomic_flag() -> AtomicFlag {
    AtomicFlag::new()
}

/// Memory fence
open fn memory_fence(ordering: Ordering) {
    match ordering {
        Ordering::Acquire => MemoryBarrier::acquire(),
        Ordering::Release => MemoryBarrier::release(),
        Ordering::AcqRel => MemoryBarrier::acq_rel(),
        Ordering::SeqCst => MemoryBarrier::full(),
        Ordering::Relaxed => {
            // No barrier needed
        }
    }
}

/// Compiler fence
open fn compiler_fence(ordering: Ordering) {
    // In real implementation, would prevent compiler reordering
    match ordering {
        Ordering::Acquire | Ordering::AcqRel | Ordering::SeqCst => {
            // Prevent compiler from moving loads/stores past this point
        }
        Ordering::Release => {
            // Prevent compiler from moving loads/stores before this point
        }
        Ordering::Relaxed => {
            // No compiler barrier needed
        }
    }
}

/// Atomic load with memory ordering
open fn atomic_load<T: AtomicOps>(atomic: &T, ordering: Ordering) -> T::Value {
    memory_fence(ordering);
    let value = atomic.load();
    memory_fence(ordering);
    value
}

/// Atomic store with memory ordering
open fn atomic_store<T: AtomicOps>(atomic: &var T, value: T::Value, ordering: Ordering) {
    memory_fence(ordering);
    atomic.store(value);
    memory_fence(ordering);
}

/// Atomic swap with memory ordering
open fn atomic_swap<T: AtomicOps>(atomic: &var T, value: T::Value, ordering: Ordering) -> T::Value {
    memory_fence(ordering);
    let old = atomic.swap(value);
    memory_fence(ordering);
    old
}

/// Atomic compare and swap with memory ordering
open fn atomic_compare_exchange<T: AtomicOps>(atomic: &var T, current: T::Value, new: T::Value, ordering: Ordering) -> Result<T::Value, T::Value> {
    memory_fence(ordering);
    let result = atomic.compare_exchange(current, new);
    memory_fence(ordering);
    result
}
