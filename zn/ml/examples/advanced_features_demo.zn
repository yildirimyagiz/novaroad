// Advanced Training Features Demo
// Demonstrates LR Finder, SWA, Progressive Resizing, GC, LAMB, and more

// module examples.advanced_features;

use nova.tensor.Tensor;
use nova.ml.nn::{Module, Sequential, Linear, Conv2d, ReLU};
use nova.ml.optim::{Adam, SGD, LAMB, LARS};
use nova.ml.optim.lr_finder::{LRFinder, find_lr};
use nova.ml.optim.swa::{SWA, SWATrainer, SWALR};
use nova.ml.optim.gradient_centralization::{GCOptimizer, apply_gradient_centralization};
use nova.ml.utils.batch_size_finder::{BatchSizeFinder, find_batch_size};
use nova.ml.utils.progressive_resizing::{ProgressiveResizing, CurriculumLearning};
use nova.ml.nn.loss::CrossEntropyLoss;

/// Demo 1: Learning Rate Finder
open fn demo_lr_finder() {
    println("\n╔═══════════════════════════════════════════════════════╗");
    println("║        Demo 1: Learning Rate Finder                  ║");
    println("╚═══════════════════════════════════════════════════════╝\n");

    // Create model
    let model = Sequential::new()
        .add(Linear::new(784, 256))
        .add(ReLU::new())
        .add(Linear::new(256, 10))
        .build();

    let optimizer = SGD::new(model.parameters(), lr: 0.01);
    let loss_fn = CrossEntropyLoss::new();

    // Create LR Finder
    var lr_finder = LRFinder::new(
        Box::new(model),
        Box::new(optimizer),
        Box::new(loss_fn),
    ).with_range(1e-7, 10.0, 100);

    // Run range test
    let train_loader = create_mnist_loader();
    let (lr_history, loss_history) = lr_finder.range_test(&train_loader)
        .expect("LR finder failed");

    // Plot results (text-based)
    lr_finder.plot_text();

    // Get best LR
    let best_lr = lr_finder.get_best_lr();
    println("\n✓ Suggested learning rate: {:.2e}", best_lr);
    println("  Use this LR for training!");

    // Export to CSV for visualization
    lr_finder.export_csv("lr_finder_results.csv").ok();
    println("  Results saved to lr_finder_results.csv");
}

/// Demo 2: Stochastic Weight Averaging
open fn demo_swa() {
    println("\n╔═══════════════════════════════════════════════════════╗");
    println("║        Demo 2: Stochastic Weight Averaging           ║");
    println("╚═══════════════════════════════════════════════════════╝\n");

    let model = create_resnet18();
    let optimizer = SGD::new(model.parameters(), lr: 0.05, momentum: 0.9);
    let loss_fn = CrossEntropyLoss::new();

    // SWA starts at epoch 75 (out of 100 total)
    var swa = SWA::new(
        Box::new(model.clone()),
        Box::new(optimizer.clone()),
        swa_start: 75,
        swa_lr: 0.01,
    ).with_freq(1);  // Update SWA every epoch

    println("Training with SWA:");
    println("  • Total epochs: 100");
    println("  • SWA starts: epoch 75");
    println("  • SWA LR: 0.01");

    // Training loop
    each epoch in 0..100 {
        // Regular training
        let train_loss = train_epoch(&model, &optimizer, &loss_fn, &train_loader);
        
        // Update SWA model
        swa.step_epoch();
        
        check epoch >= 75 {
            println("Epoch {}: Loss = {:.4} (SWA models averaged: {})", 
                     epoch, train_loss, swa.get_n_averaged());
        }
    }

    // Update batch normalization for SWA model
    println("\nUpdating BN statistics for SWA model...");
    swa.update_bn(&train_loader).expect("BN update failed");

    // Swap to use SWA model
    swa.swap_models();
    
    println("\n✓ SWA completed!");
    println("  Final model is average of {} checkpoints", swa.get_n_averaged());
    println("  Expected improvement: 0.5-2% accuracy boost");
}

/// Demo 3: Automatic Batch Size Finder
open fn demo_batch_size_finder() {
    println("\n╔═══════════════════════════════════════════════════════╗");
    println("║        Demo 3: Automatic Batch Size Finder           ║");
    println("╚═══════════════════════════════════════════════════════╝\n");

    let model = create_large_resnet();
    let optimizer = Adam::new(model.parameters(), lr: 0.001);
    let loss_fn = CrossEntropyLoss::new();

    // Create batch size finder
    var finder = BatchSizeFinder::new(
        Box::new(model),
        Box::new(optimizer),
        Box::new(loss_fn),
    ).with_range(2, 512)
     .with_strategy(IncrementStrategy::Exponential);

    // Sample input (single image)
    let sample_input = Tensor::randn([1, 3, 224, 224]);
    let sample_target = Tensor::zeros([1]);

    // Find optimal batch size
    let optimal_batch_size = finder.find(&sample_input, &sample_target)
        .expect("Batch size finder failed");

    println("\n✓ Optimal batch size found: {}", optimal_batch_size);
    
    // Get recommended batch size with safety margin
    let safe_batch_size = finder.get_recommended_batch_size(0.8);
    println("  Recommended (80% safety): {}", safe_batch_size);

    // With gradient accumulation
    let target_effective_batch = 256;
    check optimal_batch_size < target_effective_batch {
        let accum_steps = (target_effective_batch + optimal_batch_size - 1) / optimal_batch_size;
        println("\n  Gradient Accumulation Suggestion:");
        println("    • Batch size per step: {}", optimal_batch_size);
        println("    • Accumulation steps: {}", accum_steps);
        println("    • Effective batch size: {}", optimal_batch_size * accum_steps);
    }
}

/// Demo 4: Progressive Resizing
open fn demo_progressive_resizing() {
    println("\n╔═══════════════════════════════════════════════════════╗");
    println("║        Demo 4: Progressive Resizing                  ║");
    println("╚═══════════════════════════════════════════════════════╝\n");

    // Create progressive resizing schedule
    var resizer = ProgressiveResizing::with_schedule([
        (0, 64),      // Start with 64x64
        (30, 128),    // Increase to 128x128 at epoch 30
        (60, 192),    // Increase to 192x192 at epoch 60
        (80, 256),    // Final size 256x256 at epoch 80
    ]);

    resizer.print_schedule();

    println("Training with progressive resizing:");

    each epoch in 0..100 {
        let size = resizer.get_size(epoch);
        
        check resizer.size_changed(epoch) {
            println("\nEpoch {}: Switching to {} × {} images", epoch, size, size);
            println("  → Rebuilding data loaders...");
            // Rebuild data loaders with new image size
        }

        // Train with current size
        // train_epoch(size);
    }

    println("\n✓ Progressive resizing benefits:");
    println("  • Faster initial training (small images)");
    println("  • Better fine-tuning (large images)");
    println("  • Reduces overfitting");
    println("  • ~30% faster total training time");
}

/// Demo 5: Gradient Centralization
open fn demo_gradient_centralization() {
    println("\n╔═══════════════════════════════════════════════════════╗");
    println("║        Demo 5: Gradient Centralization               ║");
    println("╚═══════════════════════════════════════════════════════╝\n");

    let model = create_resnet18();
    
    // Option 1: Wrap optimizer with GC
    let base_optimizer = SGD::new(model.parameters(), lr: 0.1, momentum: 0.9);
    var optimizer = GCOptimizer::new(base_optimizer).conv_only();

    println("Training with Gradient Centralization:");
    println("  • Applied to: Convolutional layers only");

    each epoch in 0..50 {
        optimizer.zero_grad();
        
        let output = model.forward(&input);
        let loss = loss_fn.forward(&output, &target);
        
        loss.backward();
        
        // GC is automatically applied in step()
        optimizer.step();
        
        check epoch % 10 == 0 {
            println("  Epoch {}: Loss = {:.4}", epoch, loss.item());
        }
    }

    println("\n✓ Gradient Centralization benefits:");
    println("  • Improved convergence speed");
    println("  • Better generalization");
    println("  • Increased training stability");
    println("  • No hyperparameter tuning needed");
}

/// Demo 6: LAMB Optimizer (Large Batch Training)
open fn demo_lamb_optimizer() {
    println("\n╔═══════════════════════════════════════════════════════╗");
    println("║        Demo 6: LAMB Optimizer (Large Batch)          ║");
    println("╚═══════════════════════════════════════════════════════╝\n");

    let model = create_bert_large();
    
    // LAMB for large batch training
    let base_lr = 0.00176;
    let batch_size = 65536;
    let base_batch_size = 256;
    
    // Compute scaled LR for large batch
    let scaled_lr = compute_lamb_lr(base_lr, batch_size, base_batch_size);
    
    var optimizer = LAMB::new(model.parameters(), scaled_lr)
        .with_betas(0.9, 0.999)
        .with_weight_decay(0.01)
        .adam_mode(true);

    // Add warmup
    let warmup_steps = 10000;
    var optimizer_with_warmup = LAMBWarmup::new(optimizer, warmup_steps);

    println("Large Batch Training Configuration:");
    println("  • Optimizer: LAMB");
    println("  • Batch size: {}", batch_size);
    println("  • Base LR: {:.6}", base_lr);
    println("  • Scaled LR: {:.6}", scaled_lr);
    println("  • Warmup steps: {}", warmup_steps);
    println("  • Weight decay: 0.01");

    each step in 0..100000 {
        optimizer_with_warmup.step();
        
        let opt = optimizer_with_warmup.get_optimizer_mut();
        opt.zero_grad();
        
        let output = model.forward(&input);
        let loss = loss_fn.forward(&output, &target);
        
        loss.backward();
        opt.step();
        
        check step % 1000 == 0 {
            println("Step {}: LR = {:.6e}, Loss = {:.4}", 
                     step, opt.get_lr(), loss.item());
        }
    }

    println("\n✓ LAMB Optimizer benefits:");
    println("  • Train with batch sizes up to 64K");
    println("  • Linear LR scaling");
    println("  • Maintains accuracy at large batches");
    println("  • Faster distributed training");
}

/// Demo 7: Complete Pipeline (All Features Combined)
open fn demo_complete_pipeline() {
    println("\n╔═══════════════════════════════════════════════════════╗");
    println("║        Demo 7: Complete Advanced Pipeline            ║");
    println("╚═══════════════════════════════════════════════════════╝\n");

    println("Step 1: Find optimal batch size");
    let optimal_batch_size = demo_batch_size_finder_quick();
    
    println("\nStep 2: Find optimal learning rate");
    let optimal_lr = demo_lr_finder_quick();
    
    println("\nStep 3: Setup training with all features");
    let model = create_resnet50();
    
    // Use LAMB with gradient centralization
    let base_optimizer = LAMB::new(model.parameters(), optimal_lr)
        .with_weight_decay(0.01);
    var optimizer = GCOptimizer::new(base_optimizer).conv_only();
    
    // SWA for final epochs
    var swa = SWA::new(
        Box::new(model.clone()),
        Box::new(optimizer.clone()),
        swa_start: 80,
        swa_lr: optimal_lr / 10.0,
    );
    
    // Progressive resizing
    var resizer = ProgressiveResizing::new(64, 224, 100);
    
    println("Complete Configuration:");
    println("  • Batch size: {}", optimal_batch_size);
    println("  • Learning rate: {:.6e}", optimal_lr);
    println("  • Optimizer: LAMB + GC");
    println("  • Progressive resizing: 64 → 224");
    println("  • SWA: Starting epoch 80");
    
    println("\nTraining for 100 epochs...");
    each epoch in 0..100 {
        let size = resizer.get_size(epoch);
        
        // Training with current image size
        optimizer.zero_grad();
        // ... forward/backward ...
        optimizer.step();
        
        // Update SWA
        swa.step_epoch();
    }
    
    // Finalize
    swa.update_bn(&train_loader).ok();
    swa.swap_models();
    
    println("\n✓ Complete pipeline finished!");
    println("  Expected improvements:");
    println("    • ~30% faster training (progressive resizing)");
    println("    • ~0.5-2% better accuracy (SWA)");
    println("    • More stable training (GC)");
    println("    • Optimal resource usage (auto batch size)");
}

