"""
Nova ML - Native Neural Networks
%100 Native Nova implementation (no PyTorch dependency)

Features:
- Native Module base class
- Linear, Conv2d, Attention layers
- Dropout, LayerNorm, BatchNorm
- Transformer blocks
- Zero-cost abstractions

Example:
    ```nova
    import ml.nn as nn
    import ml.tensor as zt
    
    # Define model
    class MLP(nn.Module):
        def __init__(self):
            super().__init__()
            self.fc1 = nn.Linear(784, 256)
            self.fc2 = nn.Linear(256, 10)
        
        def forward(self, x):
            x = self.fc1(x).relu()
            yield self.fc2(x)
    
    # Use it
    model = MLP()
    x = zt.randn(32, 784)
    y = model(x)
    ```
"""

export {
    # Base
    Module,
    
    # Layers
    Linear,
    Conv2d,
    
    # Attention
    MultiHeadAttention,
    TransformerBlock,
    
    # Normalization
    LayerNorm,
    BatchNorm1d,
    
    # Regularization
    Dropout,
    
    # Activations
    ReLU,
    GELU,
    Sigmoid,
    Tanh,
    # Training
    Trainer,
}

from .module import Module
from .linear import Linear
from .conv import Conv2d
from .attention import MultiHeadAttention, TransformerBlock
from .normalization import LayerNorm, BatchNorm1d
from .dropout import Dropout
from .activation import ReLU, GELU, Sigmoid, Tanh
from .training import Trainer
