#[cfg(feature = "cuda")]
fn cuda_empty_cache() {
    // extern "C" { fn cudaDeviceSynchronize(); fn cudaMemGetInfo(...); }
}

#[cfg(feature = "cuda")]
fn cuda_memory_allocated() -> usize {
    // Query CUDA memory
    0
