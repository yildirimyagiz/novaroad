// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  matlab::engine::engine_error                                               ║
// ║  Mirrors Python: engineerror.py                                             ║
// ║                                                                             ║
// ║  Exception hierarchy:                                                       ║
// ║    EngineError                                                              ║
// ║    ├── MatlabExecutionError   (runtime errors inside MATLAB)                ║
// ║    ├── SyntaxError            (bad MATLAB syntax)                           ║
// ║    ├── RejectedExecutionError (engine busy / already terminated)            ║
// ║    ├── EngineTerminatedError  (engine was killed externally)                ║
// ║    └── CancelledError         (async future was cancelled)                  ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Base error alias for all MATLAB engine failures.
open data EngineError {
    message: str,
}

/// A MATLAB function raised a runtime exception.
/// `matlab_trace` contains the full MATLAB stack trace.
open data MatlabExecutionError {
    message:      str,
    matlab_trace: str,
}

/// The string passed to `eval` contains a MATLAB syntax error.
open data MatlabSyntaxError {
    message:      str,
    matlab_trace: str,
}

/// The engine is busy executing another command, or has already been exited.
open data RejectedExecutionError {
    message: str,
}

/// The MATLAB process crashed or was killed from outside.
open data EngineTerminatedError {
    message: str,
}

/// A `FutureResult` / `FevalFuture` was cancelled before completion.
open data CancelledError {
    message: str,
}

/// Format an EngineError for display.
impl EngineError {
    fn new(message: str) -> EngineError {
        EngineError { message }
    }

    fn display(self) -> str {
        f"EngineError: {self.message}"
    }
}

impl MatlabExecutionError {
    fn new(message: str, matlab_trace: str) -> MatlabExecutionError {
        MatlabExecutionError { message, matlab_trace }
    }

    fn display(self) -> str {
        f"MatlabExecutionError: {self.message}\n  MATLAB traceback:\n{self.matlab_trace}"
    }
}

impl MatlabSyntaxError {
    fn new(message: str, matlab_trace: str) -> MatlabSyntaxError {
        MatlabSyntaxError { message, matlab_trace }
    }

    fn display(self) -> str {
        f"MatlabSyntaxError: {self.message}\n  MATLAB traceback:\n{self.matlab_trace}"
    }
}

impl RejectedExecutionError {
    fn new(message: str) -> RejectedExecutionError {
        RejectedExecutionError { message }
    }

    fn display(self) -> str {
        f"RejectedExecutionError: {self.message}"
    }
}

impl EngineTerminatedError {
    fn new(message: str) -> EngineTerminatedError {
        EngineTerminatedError { message }
    }

    fn display(self) -> str {
        f"EngineTerminatedError: {self.message}"
    }
}

impl CancelledError {
    fn new(message: str) -> CancelledError {
        CancelledError { message }
    }

    fn display(self) -> str {
        f"CancelledError: {self.message}"
    }
}
