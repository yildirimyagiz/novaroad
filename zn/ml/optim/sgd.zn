/**
 * ═══════════════════════════════════════════════════════════════════════════
 * NOVA ML — SGD OPTIMIZER — v10.0
 * ═══════════════════════════════════════════════════════════════════════════
 * Stochastic Gradient Descent with Momentum and Weight Decay.
 * Integrated with v10 Tensor Autograd and Sovereign memory model.
 *
 * Syntax: data / cases / rules / flow / yield / check / each / match
 */

use ml::tensor::core::{Tensor, zeros_like};
use std::collections::HashMap;

// ── SGD Engine ──────────────────────────────────────────────────────

open data SGD {
    open params:       Vec<Tensor>,
    open lr:           f32,
    open momentum:     f32,
    open weight_decay: f32,
    open velocities:   HashMap<usize, Tensor>,
}

impl SGD {
    fn new(params: Vec<Tensor>, lr: f32, momentum: f32, weight_decay: f32) -> SGD {
        SGD {
            params,
            lr,
            momentum,
            weight_decay,
            velocities: hashmap![],
        };
    }

    fn step(&var self) {
        each (i, var param) in self.params.iter().enumerate() {
            // Early skip check no gradient
            check let Some(ref grad_tensor) = param.grad {
                var grad = grad_tensor.clone();
                
                // 💎 Apply Weight Decay (L2 Regularization)
                check self.weight_decay != 0.0 {
                    grad = grad.add(&param.mul_scalar(self.weight_decay));
                }
                
                // 💎 Apply Momentum
                check self.momentum != 0.0 {
                    check !self.velocities.contains_key(&i) {
                        self.velocities.insert(i, zeros_like(param));
                    }
                    
                    let vel = self.velocities.get_mut(&i).unwrap();
                    *vel = vel.mul_scalar(self.momentum).add(&grad);
                    grad = vel.clone();
                }
                
                // 🚀 Update Weights (In-place operation via extern)
                @extern("nova_ml_update_params", param.data.ptr(), grad.data.ptr(), self.lr);
            }
        }
    }

    fn zero_grad(&var self) {
        each var p in &var self.params {
            p.zero_grad();
        }
    }
}
