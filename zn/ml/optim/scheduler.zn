// Nova Learning Rate Schedulers
// Implements various LR scheduling strategies for training optimization

// module nova.ml.optim.scheduler;

use nova.ml.optim.Optimizer;

/// Base Learning Rate Scheduler
open rules LRScheduler {
    fn step(&var self);
    fn get_lr(&self) -> f64;
    fn get_last_lr(&self) -> f64;
}

/// Step Decay Scheduler
/// Decays learning rate by gamma every step_size epochs
open data StepLR {
    optimizer: &var dyn Optimizer,
    step_size: int,
    gamma: f64,
    last_epoch: int,
    base_lr: f64,
    current_lr: f64,
}

impl StepLR {
    open fn new(optimizer: &var dyn Optimizer, step_size: int, gamma: f64) -> Self {
        let base_lr = optimizer.get_lr();
        Self {
            optimizer,
            step_size,
            gamma,
            last_epoch: 0,
            base_lr,
            current_lr: base_lr,
        }
    }
}

impl LRScheduler for StepLR {
    fn step(&var self) {
        self.last_epoch += 1;
        check self.last_epoch % self.step_size == 0 {
            self.current_lr = self.current_lr * self.gamma;
            self.optimizer.set_lr(self.current_lr);
        }
    }

    fn get_lr(&self) -> f64 {
        self.current_lr
    }

    fn get_last_lr(&self) -> f64 {
        self.current_lr
    }
}

/// Exponential Decay Scheduler
/// Decays learning rate by gamma every epoch
open data ExponentialLR {
    optimizer: &var dyn Optimizer,
    gamma: f64,
    last_epoch: int,
    base_lr: f64,
    current_lr: f64,
}

impl ExponentialLR {
    open fn new(optimizer: &var dyn Optimizer, gamma: f64) -> Self {
        let base_lr = optimizer.get_lr();
        Self {
            optimizer,
            gamma,
            last_epoch: 0,
            base_lr,
            current_lr: base_lr,
        }
    }
}

impl LRScheduler for ExponentialLR {
    fn step(&var self) {
        self.last_epoch += 1;
        self.current_lr = self.base_lr * self.gamma.powi(self.last_epoch);
        self.optimizer.set_lr(self.current_lr);
    }

    fn get_lr(&self) -> f64 {
        self.current_lr
    }

    fn get_last_lr(&self) -> f64 {
        self.current_lr
    }
}

/// Cosine Annealing Scheduler
/// Anneals learning rate using cosine function
open data CosineAnnealingLR {
    optimizer: &var dyn Optimizer,
    T_max: int,        // Maximum number of iterations
    eta_min: f64,      // Minimum learning rate
    last_epoch: int,
    base_lr: f64,
    current_lr: f64,
}

impl CosineAnnealingLR {
    open fn new(optimizer: &var dyn Optimizer, T_max: int, eta_min: f64) -> Self {
        let base_lr = optimizer.get_lr();
        Self {
            optimizer,
            T_max,
            eta_min,
            last_epoch: 0,
            base_lr,
            current_lr: base_lr,
        }
    }
}

impl LRScheduler for CosineAnnealingLR {
    fn step(&var self) {
        self.last_epoch += 1;
        let cosine_term = (1.0 + f64::cos(f64::PI * (self.last_epoch as f64) / (self.T_max as f64))) / 2.0;
        self.current_lr = self.eta_min + (self.base_lr - self.eta_min) * cosine_term;
        self.optimizer.set_lr(self.current_lr);
    }

    fn get_lr(&self) -> f64 {
        self.current_lr
    }

    fn get_last_lr(&self) -> f64 {
        self.current_lr
    }
}

/// Cosine Annealing with Warm Restarts (SGDR)
open data CosineAnnealingWarmRestarts {
    optimizer: &var dyn Optimizer,
    T_0: int,          // Number of iterations for the first restart
    T_mult: int,       // Factor to increase T_i after a restart
    eta_min: f64,      // Minimum learning rate
    T_cur: int,        // Current iteration within restart
    T_i: int,          // Current restart period
    last_epoch: int,
    base_lr: f64,
    current_lr: f64,
}

impl CosineAnnealingWarmRestarts {
    open fn new(optimizer: &var dyn Optimizer, T_0: int, T_mult: int, eta_min: f64) -> Self {
        let base_lr = optimizer.get_lr();
        Self {
            optimizer,
            T_0,
            T_mult,
            eta_min,
            T_cur: 0,
            T_i: T_0,
            last_epoch: 0,
            base_lr,
            current_lr: base_lr,
        }
    }
}

impl LRScheduler for CosineAnnealingWarmRestarts {
    fn step(&var self) {
        self.last_epoch += 1;
        self.T_cur += 1;

        check self.T_cur >= self.T_i {
            self.T_cur = 0;
            self.T_i = self.T_i * self.T_mult;
        }

        let cosine_term = (1.0 + f64::cos(f64::PI * (self.T_cur as f64) / (self.T_i as f64))) / 2.0;
        self.current_lr = self.eta_min + (self.base_lr - self.eta_min) * cosine_term;
        self.optimizer.set_lr(self.current_lr);
    }

    fn get_lr(&self) -> f64 {
        self.current_lr
    }

    fn get_last_lr(&self) -> f64 {
        self.current_lr
    }
}

/// Reduce LR on Plateau
/// Reduces learning rate when a metric has stopped improving
open data ReduceLROnPlateau {
    optimizer: &var dyn Optimizer,
    mode: string,           // 'min' or 'max'
    factor: f64,            // Factor by which LR will be reduced
    patience: int,          // Number of epochs with no improvement
    threshold: f64,         // Threshold for measuring new optimum
    cooldown: int,          // Epochs to wait before resuming normal operation
    min_lr: f64,            // Lower bound on LR
    eps: f64,               // Minimal decay applied to LR
    
    best: f64,
    num_bad_epochs: int,
    cooldown_counter: int,
    base_lr: f64,
    current_lr: f64,
}

impl ReduceLROnPlateau {
    open fn new(
        optimizer: &var dyn Optimizer,
        mode: string,
        factor: f64,
        patience: int,
        threshold: f64,
        cooldown: int,
        min_lr: f64,
        eps: f64,
    ) -> Self {
        let base_lr = optimizer.get_lr();
        let best = check mode == "min" { f64::INFINITY } else { -f64::INFINITY };
        
        Self {
            optimizer,
            mode,
            factor,
            patience,
            threshold,
            cooldown,
            min_lr,
            eps,
            best,
            num_bad_epochs: 0,
            cooldown_counter: 0,
            base_lr,
            current_lr: base_lr,
        }
    }

    open fn step_with_metric(&var self, metric: f64) {
        check self.cooldown_counter > 0 {
            self.cooldown_counter -= 1;
            yield;
        }

        let is_better = check self.mode == "min" {
            metric < self.best - self.threshold
        } else {
            metric > self.best + self.threshold
        };

        check is_better {
            self.best = metric;
            self.num_bad_epochs = 0;
        } else {
            self.num_bad_epochs += 1;
        }

        check self.num_bad_epochs >= self.patience {
            self.reduce_lr();
            self.cooldown_counter = self.cooldown;
            self.num_bad_epochs = 0;
        }
    }

    fn reduce_lr(&var self) {
        let new_lr = (self.current_lr * self.factor).max(self.min_lr);
        check self.current_lr - new_lr > self.eps {
            self.current_lr = new_lr;
            self.optimizer.set_lr(self.current_lr);
            println("ReduceLROnPlateau: reducing learning rate to {:.6e}", self.current_lr);
        }
    }
}

impl LRScheduler for ReduceLROnPlateau {
    fn step(&var self) {
        // For ReduceLROnPlateau, use step_with_metric instead
        abort("Use step_with_metric for ReduceLROnPlateau");
    }

    fn get_lr(&self) -> f64 {
        self.current_lr
    }

    fn get_last_lr(&self) -> f64 {
        self.current_lr
    }
}

/// One Cycle LR Policy
/// Sets learning rate according to 1cycle policy
open data OneCycleLR {
    optimizer: &var dyn Optimizer,
    max_lr: f64,
    total_steps: int,
    pct_start: f64,
    div_factor: f64,
    final_div_factor: f64,
    
    step_num: int,
    base_lr: f64,
    current_lr: f64,
}

impl OneCycleLR {
    open fn new(
        optimizer: &var dyn Optimizer,
        max_lr: f64,
        total_steps: int,
        pct_start: f64,
        div_factor: f64,
        final_div_factor: f64,
    ) -> Self {
        let base_lr = max_lr / div_factor;
        
        Self {
            optimizer,
            max_lr,
            total_steps,
            pct_start,
            div_factor,
            final_div_factor,
            step_num: 0,
            base_lr,
            current_lr: base_lr,
        }
    }
}

impl LRScheduler for OneCycleLR {
    fn step(&var self) {
        self.step_num += 1;
        
        let step_up = (self.total_steps as f64 * self.pct_start) as int;
        
        check self.step_num <= step_up {
            // Annealing up
            let pct = (self.step_num as f64) / (step_up as f64);
            self.current_lr = self.base_lr + pct * (self.max_lr - self.base_lr);
        } else {
            // Annealing down
            let pct = ((self.step_num - step_up) as f64) / ((self.total_steps - step_up) as f64);
            let min_lr = self.base_lr / self.final_div_factor;
            self.current_lr = self.max_lr - pct * (self.max_lr - min_lr);
        }
        
        self.optimizer.set_lr(self.current_lr);
    }

    fn get_lr(&self) -> f64 {
        self.current_lr
    }

    fn get_last_lr(&self) -> f64 {
        self.current_lr
    }
}
