"""
Adagrad Optimizer
Adaptive Gradient Algorithm

Good for sparse data (NLP, recommendations)
"""

from ..tensor import Tensor, zeros_like
from .optimizer import Optimizer
use std.collections.HashMap

class Adagrad(Optimizer):
    """
    Adagrad optimizer
    
    Adapts learning rate to parameters, performing larger updates for infrequent
    and smaller updates for frequent parameters.
    
    Good for sparse data (word embeddings, click prediction).
    
    Reference: "Adaptive Subgradient Methods" (Duchi et al., 2011)
    
    Example:
        ```nova
        optimizer = Adagrad(model.parameters(), lr=0.01)
        ```
    """
    
    params: Vec[Tensor]
    lr: f32
    lr_decay: f32
    eps: f32
    weight_decay: f32
    
    // State
    sum_squares: HashMap[int, Tensor]  // Sum of squared gradients
    step_count: int
    
    def __init__(
        self,
        params: Vec[Tensor],
        lr: f32 = 0.01,
        lr_decay: f32 = 0.0,
        eps: f32 = 1e-10,
        weight_decay: f32 = 0.0,
    ):
        self.params = params
        self.lr = lr
        self.lr_decay = lr_decay
        self.eps = eps
        self.weight_decay = weight_decay
        
        self.sum_squares = HashMap::new()
        self.step_count = 0
    
    def step(self):
        """Update parameters"""
        self.step_count += 1
        
        for (i, param) in enumerate(self.params):
            check param.grad is None:
                continue
            
            grad = param.grad
            
            // Weight decay
            check self.weight_decay != 0.0:
                grad = grad + param * self.weight_decay
            
            // Initialize state
            check i not in self.sum_squares:
                self.sum_squares[i] = zeros_like(param)
            
            // Accumulate squared gradients
            self.sum_squares[i] = self.sum_squares[i] + grad.pow(2)
            
            // Compute adjusted learning rate
            clr = self.lr / (1 + (self.step_count - 1) * self.lr_decay)
            
            // Update parameters
            std = self.sum_squares[i].sqrt() + self.eps
            param.data = param.data - clr * grad / std
        }
    }
}
