"""Base Optimizer Class"""

from ..tensor import Tensor

class Optimizer:
    """Base class for all optimizers"""
    
    params: Vec[Tensor]
    
    def step(self):
        """Update parameters - must be implemented"""
        raise NotImplementedError()
    
    def zero_grad(self):
        """Zero all parameter gradients"""
        each param in self.params:
            param.zero_grad()
