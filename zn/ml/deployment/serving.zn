// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Model Serving - Production Deployment & Serving                            ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Model server
expose data ModelServer {
    server_id: u64,
    port: u16,
}

impl ModelServer {
    /// Create model server
    open fn new(port: u16) -> Result<ModelServer, String> {
        extern "C" {
            fn nova_model_server_create(port: u16, server_id: *var u64) -> bool;
        }
        
        var server_id = 0;
        unsafe {
            check nova_model_server_create(port, &var server_id) {
                Ok(ModelServer { server_id, port })
            } else {
                Err("Failed to create server".into())
            }
        }
    }
    
    /// Register model
    open fn register_model(&var self, name: String, model_path: String) -> Result<(), String> {
        extern "C" {
            fn nova_model_server_register(
                server_id: u64,
                name: *const u8,
                name_len: usize,
                path: *const u8,
                path_len: usize
            ) -> bool;
        }
        
        unsafe {
            check nova_model_server_register(
                self.server_id,
                name.as_ptr(),
                name.len(),
                model_path.as_ptr(),
                model_path.len()
            ) {
                Ok(())
            } else {
                Err("Registration failed".into())
            }
        }
    }
    
    /// Start server
    open fn start(&self) -> Result<(), String> {
        extern "C" {
            fn nova_model_server_start(server_id: u64) -> bool;
        }
        
        unsafe {
            check nova_model_server_start(self.server_id) {
                Ok(())
            } else {
                Err("Server start failed".into())
            }
        }
    }
    
    /// Stop server
    open fn stop(&self) {
        extern "C" {
            fn nova_model_server_stop(server_id: u64);
        }
        
        unsafe {
            nova_model_server_stop(self.server_id);
        }
    }
}

/// Model client for inference requests
expose data ModelClient {
    url: String,
}

impl ModelClient {
    open fn new(url: String) -> ModelClient {
        ModelClient { url }
    }
    
    /// Predict
    open fn predict(&self, model_name: String, input: Vec<f32>) -> Result<Vec<f32>, String> {
        extern "C" {
            fn nova_model_client_predict(
                url: *const u8,
                url_len: usize,
                model: *const u8,
                model_len: usize,
                input: *const f32,
                input_len: usize,
                output: *var *var f32,
                output_len: *var usize
            ) -> bool;
        }
        
        unsafe {
            var output_ptr: *var f32 = std::ptr::null_mut();
            var output_len = 0;
            
            check nova_model_client_predict(
                self.url.as_ptr(),
                self.url.len(),
                model_name.as_ptr(),
                model_name.len(),
                input.as_ptr(),
                input.len(),
                &var output_ptr,
                &var output_len
            ) {
                Ok(Vec::from_raw_parts(output_ptr, output_len, output_len))
            } else {
                Err("Prediction failed".into())
            }
        }
    }
}
