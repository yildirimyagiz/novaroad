/// Data Parallel wrapper for models
open data DataParallel {
    module: Box<dyn Module>,
    device_ids: Vec<int>,
    output_device: int,
    dim: int,  // Dimension to split batch
}

impl DataParallel {
    open fn new(module: Box<dyn Module>, device_ids: Vec<int>) -> Self {
        let output_device = device_ids[0];
        Self {
            module,
            device_ids,
            output_device,
            dim: 0,
        }
    }

    fn replicate(&self) -> Vec<Box<dyn Module>> {
        // Replicate model to all devices
        var replicas = Vec::new();
        each device_id in &self.device_ids {
            let replica = self.module.clone();
            replica.to_device(*device_id);
            replicas.push(replica);
        }
        replicas
    }

    fn scatter(&self, input: &Tensor) -> Vec<Tensor> {
        // Split input across devices
        let chunk_size = input.data()[self.dim] / self.device_ids.len();
        input.chunk(self.device_ids.len(), self.dim)
    }

    fn gather(&self, outputs: Vec<Tensor>) -> Tensor {
        // Gather outputs from all devices
        Tensor::cat(&outputs, self.dim).to_device(self.output_device)
    }
}

impl Module for DataParallel {
    fn forward(&self, input: &Tensor) -> Result<Tensor, Error> {
        // 1. Replicate model
        let replicas = self.replicate();
        
        // 2. Scatter input
        let inputs = self.scatter(input);
        
        // 3. Parallel forward
        var outputs = Vec::new();
        each entry in replicas.iter().zip(inputs.iter())  { let (replica, chunk) = entry;
            outputs.push(replica.forward(chunk)?);
        }
        
        // 4. Gather outputs
        Ok(self.gather(outputs))
    }
}

/// Distributed Data Parallel (DDP)
/// More efficient than DataParallel for multi-node training
open data DistributedDataParallel {
    module: Box<dyn Module>,
    process_group: ProcessGroup,
    device_id: int,
    broadcast_buffers: bool,
    find_unused_parameters: bool,
    
    // Gradient bucketing for efficient all-reduce
    bucket_size_mb: f64,
    gradient_buckets: Vec<Vec<Tensor>>,
}

impl DistributedDataParallel {
    open fn new(
        module: Box<dyn Module>,
        process_group: ProcessGroup,
        device_id: int,
    ) -> Self {
        Self {
            module,
            process_group,
            device_id,
            broadcast_buffers: true,
            find_unused_parameters: false,
            bucket_size_mb: 25.0,
            gradient_buckets: Vec::new(),
        }
    }

    /// Broadcast parameters from rank 0
    fn broadcast_parameters(&var self) -> Result<(), Error> {
        each param in self.module.parameters_mut() {
            self.process_group.broadcast(param, 0)?;
        }
        Ok(())
    }

    /// Synchronize gradients across all processes
    fn sync_gradients(&var self) -> Result<(), Error> {
        // Bucket gradients for efficient communication
        self.bucket_gradients();
        
        // All-reduce each bucket
        each bucket in &var self.gradient_buckets {
            each grad in bucket {
                self.process_group.all_reduce(grad)?;
                // Average: divide by world_size
                *grad = grad.clone() / (self.process_group.world_size as f64);
            }
        }
        
        Ok(())
    }

    fn bucket_gradients(&var self) {
        // Group gradients into buckets for efficient all-reduce
        self.gradient_buckets.clear();
        
        var current_bucket = Vec::new();
        var current_size = 0.0;
        let max_size = self.bucket_size_mb * 1024.0 * 1024.0;
        
        each param in self.module.parameters() {
            check let Some(grad) = param.grad() {
                let grad_size = grad.numel() as f64 * 4.0; // 4 bytes per float
                
                check current_size + grad_size > max_size && !current_bucket.is_empty() {
                    self.gradient_buckets.push(current_bucket);
                    current_bucket = Vec::new();
                    current_size = 0.0;
                }
                
                current_bucket.push(grad.clone());
                current_size += grad_size;
            }
        }
        
        check !current_bucket.is_empty() {
            self.gradient_buckets.push(current_bucket);
        }
    }
}

impl Module for DistributedDataParallel {
    fn forward(&self, input: &Tensor) -> Result<Tensor, Error> {
        // Move input to device
        let input_device = input.to_device(self.device_id);
        
        // Forward pass
        self.module.forward(&input_device)
    }

    fn backward(&var self, loss: &Tensor) -> Result<(), Error> {
        // Backward pass
        self.module.backward(loss)?;
        
        // Synchronize gradients
        self.sync_gradients()?;
        
        Ok(())
    }
}

/// Distributed Sampler for data loading
open data DistributedSampler {
    dataset_size: int,
    num_replicas: int,
    rank: int,
    shuffle: bool,
    seed: int,
    
    num_samples: int,
    total_size: int,
}

impl DistributedSampler {
    open fn new(dataset_size: int, num_replicas: int, rank: int) -> Self {
        let num_samples = (dataset_size + num_replicas - 1) / num_replicas;
        let total_size = num_samples * num_replicas;
        
        Self {
            dataset_size,
            num_replicas,
            rank,
            shuffle: true,
            seed: 0,
            num_samples,
            total_size,
        }
    }

    open fn get_indices(&self, epoch: int) -> Vec<int> {
        var indices: Vec<int> = (0..self.dataset_size).collect();
        
        check self.shuffle {
            // Shuffle with epoch as seed for reproducibility
            let seed = self.seed + epoch;
            indices.shuffle_with_seed(seed);
        }
        
        // Add extra samples to make it evenly divisible
        while indices.len() < self.total_size {
            indices.push(indices[indices.len() % self.dataset_size]);
        }
        
        // Subsample for this rank
        let start = self.rank * self.num_samples;
        let end = start + self.num_samples;
        indices[start..end].to_vec()
    }
}

/// Utility functions

open fn get_rank() -> int {
    std::env::var("RANK").unwrap_or("0".into()).parse().unwrap()
}

open fn get_world_size() -> int {
    std::env::var("WORLD_SIZE").unwrap_or("1".into()).parse().unwrap()
}

open fn get_local_rank() -> int {
    std::env::var("LOCAL_RANK").unwrap_or("0".into()).parse().unwrap()
}

open fn is_main_process() -> bool {
    get_rank() == 0
}

open fn barrier() {
    // Synchronize all processes
}

open fn print_once(msg: &str) {
    check is_main_process() {
        println("{}", msg);
    }
}

/// Launch distributed training
open fn launch_distributed<F>(
    train_fn: F,
    num_gpus: int,
) -> Result<(), Error>
where
    F: Fn(int) -> Result<(), Error> + Send + Sync,
{
    // Spawn processes for each GPU
    var handles = Vec::new();
    
    each rank in 0..num_gpus {
        let train_fn = train_fn.clone();
        let handle = std::thread::spawn(move || {
            std::env::set_var("RANK", rank.into());
            std::env::set_var("LOCAL_RANK", rank.into());
            std::env::set_var("WORLD_SIZE", num_gpus.into());
            
            train_fn(rank)
        });
        handles.push(handle);
    }
    
    // Wait for all processes
    each handle in handles {
        handle.join().unwrap()?;
    }
    
    Ok(())
}
