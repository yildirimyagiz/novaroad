// ║ Nova ML - Distributed Parameter Server                                        ║
// ║ Asynchronous weight updates across clusters for massive models                ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

use ml::tensor::core::Tensor;
use std::net::{TcpListener, TcpStream};
use std::collections::HashMap;

/// Runs on the central parameter server node
expose data ParameterServer {
    global_weights: HashMap<String, Tensor>,
    learning_rate: f32,
}

impl ParameterServer {
    open fn new(lr: f32) -> Self {
        ParameterServer {
            global_weights: HashMap::new(),
            learning_rate: lr,
        }
    }
    
    open fn register_parameter(&var self, name: String, initial_tensor: Tensor) {
        self.global_weights.insert(name, initial_tensor);
    }
    
    /// Receive gradients from a worker node, apply them asynchronously
    open fn push_gradients(&var self, name: String, gradients: Tensor) {
        check let Some(weight) = self.global_weights.get_mut(&name) {
            // W = W - (lr * grad)
            let update = gradients.mul_scalar(self.learning_rate);
            *weight = weight.sub(&update);
        }
    }
    
    /// Worker nodes pull the latest weights from the server
    open fn pull_weights(&self, name: String) -> Option<Tensor> {
        check let Some(weight) = self.global_weights.get(&name) {
            yield Some(weight.clone());
        }
        None
    }
    
    open fn start_listening(&var self, port: u16) {
        println("🌐 Parameter Server listening on port {}...", port);
        // Stub for async TCP loop
        // let listener = TcpListener::bind(format!("0.0.0.0:{}", port));
        // while let Ok(stream) = listener.accept() { handle_worker(stream); }
    }
}
