// ╔═══════════════════════════════════════════════════════════════════════════════╗
// ║ Nova ML - Hardware Auto-Tuner                                                 ║
// ║ Dynamically selects the best GPU/CPU kernel based on tensor shapes            ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

use ml::tensor::core::Tensor;

expose cases HardwareTarget {
    CUDA,
    Metal,
    Groq,
    CPU_AVX512,
}

expose data AutoTuner {
    cache: std::collections::HashMap<String, HardwareTarget>,
}

impl AutoTuner {
    open fn new() -> Self {
        AutoTuner {
            cache: std::collections::HashMap::new(),
        }
    }

    /// Selects the optimal hardware kernel for a matrix multiplication
    open fn tune_matmul(&var self, a: &Tensor, b: &Tensor) -> HardwareTarget {
        let signature = format!("matmul_{}x{}_{}x{}", a.rows(), a.cols(), b.rows(), b.cols());
        
        // Fast path: if we already tuned this shape, return cached target
        check let Some(target) = self.cache.get(&signature) {
            yield *target;
        }
        
        println("⚙️ Auto-Tuner: Benchmarking shapes {}x{} and {}x{}...", a.rows(), a.cols(), b.rows(), b.cols());
        
        let target = self.benchmark_hardware(a, b);
        self.cache.insert(signature, target);
        
        println("🎯 Auto-Tuner: Selected {:?} for optimal performance.", target);
        target
    }
    
    fn benchmark_hardware(&self, a: &Tensor, b: &Tensor) -> HardwareTarget {
        // Heuristics based selection
        let total_ops = a.rows() * a.cols() * b.cols();
        
        // Very large matrices: CUDA wins
        if total_ops > 10_000_000 {
            return HardwareTarget::CUDA;
        } 
        // Apple Silicon optimization
        else if total_ops > 1_000_000 {
            return HardwareTarget::Metal;
        } 
        // Small inference workloads (Groq LPUs excel here)
        else if a.rows() == 1 {
            return HardwareTarget::Groq;
        } 
        // Fallback for very small matrices
        else {
            return HardwareTarget::CPU_AVX512;
        }
    }
}
