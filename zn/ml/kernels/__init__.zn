"""
Nova ML GPU Kernels
High-performance CUDA/Metal kernels for ML operations

Features:
- Custom matmul (CUTLASS-style)
- FlashAttention
- Fused kernels
- Memory-efficient operations
"""

export {
    // CUDA kernels
    cuda_matmul,
    cuda_conv2d,
    cuda_flash_attention,
    
    // Metal kernels  
    metal_matmul,
    metal_conv2d,
    
    // Fused kernels
    fused_linear_relu,
    fused_layer_norm,
}

from .cuda.matmul import cuda_matmul
from .cuda.conv import cuda_conv2d
from .cuda.attention import cuda_flash_attention
from .metal.matmul import metal_matmul
