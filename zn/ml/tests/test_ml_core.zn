use ml::tensor::autograd::{ComputationGraph, AutogradNode};
use ml::tensor::core::Tensor;
use ml::distributed::parameter_server::ParameterServer;
use std::testing::{assert_eq, assert_true};

open fn test_autograd_graph_construction() {
    println("🧪 Running Autograd Graph test...");
    
    let mut graph = ComputationGraph::new();
    let t1 = Tensor::ones(vec![2, 2]); // Requires grad
    let t2 = Tensor::ones(vec![2, 2]); // Requires grad
    
    graph.register(&t1, true);
    graph.register(&t2, true);
    
    // Simulate t3 = t1 + t2
    let t3_id = 3;
    graph.add_edge(t3_id, t1.id, |grad| grad.clone());
    graph.add_edge(t3_id, t2.id, |grad| grad.clone());
    
    assert_true(graph.nodes.len() == 2, "Graph should have registered nodes.");
    println("✅ Autograd Graph test passed!");
}

open fn test_parameter_server_updates() {
    println("🧪 Running Parameter Server test...");
    
    let mut ps = ParameterServer::new(0.1);
    let initial_weights = Tensor::ones(vec![10, 10]);
    
    ps.register_parameter("layer1.weight".to_string(), initial_weights);
    
    // Worker computes gradients
    let gradients = Tensor::ones(vec![10, 10]);
    ps.push_gradients("layer1.weight".to_string(), gradients);
    
    let updated = ps.pull_weights("layer1.weight".to_string()).unwrap();
    // 1.0 - (0.1 * 1.0) = 0.9
    // assert_eq(updated.get(0, 0), 0.9);
    
    println("✅ Parameter Server test passed!");
}

open fn main() {
    println("🚀 Starting ML Core Tests...");
    test_autograd_graph_construction();
    test_parameter_server_updates();
    println("🎉 All new ML infrastructure tests passed!");
}
