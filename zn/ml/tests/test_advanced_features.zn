// Tests for Advanced Training Features
// Tests for LR Finder, SWA, Batch Size Finder, Progressive Resizing, GC, LAMB

// module tests.advanced_features;

use nova.tensor.Tensor;
use nova.ml.optim.lr_finder::LRFinder;
use nova.ml.optim.swa::SWA;
use nova.ml.optim.lamb::LAMB;
use nova.ml.optim.gradient_centralization::GCOptimizer;
use nova.ml.utils.batch_size_finder::BatchSizeFinder;
use nova.ml.utils.progressive_resizing::ProgressiveResizing;

#[test]
fn test_lr_finder() {
    println("Testing LR Finder...");

    let model = create_test_model();
    let optimizer = SGD::new(model.parameters(), lr: 0.01);
    let loss_fn = CrossEntropyLoss::new();

    var finder = LRFinder::new(
        Box::new(model),
        Box::new(optimizer),
        Box::new(loss_fn),
    ).with_range(1e-5, 1.0, 20);

    let train_loader = create_dummy_loader();
    let result = finder.range_test(&train_loader);
    
    assert(result.is_ok());
    
    let best_lr = finder.get_best_lr();
    assert(best_lr > 0.0);
    assert(best_lr < 1.0);

    println("✓ LR Finder test passed");
}

#[test]
fn test_swa() {
    println("Testing SWA...");

    let model = create_test_model();
    let optimizer = SGD::new(model.parameters(), lr: 0.1);

    var swa = SWA::new(
        Box::new(model),
        Box::new(optimizer),
        swa_start: 5,
        swa_lr: 0.01,
    );

    // Simulate training
    each epoch in 0..10 {
        swa.step_epoch();
    }

    assert_eq!(swa.get_n_averaged(), 5);

    println("✓ SWA test passed");
}

#[test]
fn test_batch_size_finder() {
    println("Testing Batch Size Finder...");

    let model = create_test_model();
    let optimizer = Adam::new(model.parameters(), lr: 0.001);
    let loss_fn = CrossEntropyLoss::new();

    var finder = BatchSizeFinder::new(
        Box::new(model),
        Box::new(optimizer),
        Box::new(loss_fn),
    ).with_range(2, 64);

    let sample_input = Tensor::randn([1, 10]);
    let sample_target = Tensor::zeros([1]);

    let result = finder.find(&sample_input, &sample_target);
    assert(result.is_ok());

    let optimal_bs = finder.get_optimal_batch_size();
    assert(optimal_bs >= 2);

    println("✓ Batch Size Finder test passed");
}

#[test]
fn test_progressive_resizing() {
    println("Testing Progressive Resizing...");

    var resizer = ProgressiveResizing::with_schedule([
        (0, 64),
        (10, 128),
        (20, 256),
    ]);

    assert_eq!(resizer.get_size(0), 64);
    assert_eq!(resizer.get_size(5), 64);
    assert_eq!(resizer.get_size(10), 128);
    assert_eq!(resizer.get_size(20), 256);

    assert(resizer.size_changed(10));
    assert(!resizer.size_changed(11));

    println("✓ Progressive Resizing test passed");
}

#[test]
fn test_gradient_centralization() {
    println("Testing Gradient Centralization...");

    let model = create_test_model();
    let base_optimizer = SGD::new(model.parameters(), lr: 0.1);
    var optimizer = GCOptimizer::new(base_optimizer);

    optimizer.zero_grad();
    // Simulate backward
    optimizer.step();

    println("✓ Gradient Centralization test passed");
}

#[test]
fn test_lamb_optimizer() {
    println("Testing LAMB Optimizer...");

    let params = [Tensor::randn([10, 10])];
    var optimizer = LAMB::new(params, lr: 0.001)
        .with_weight_decay(0.01);

    optimizer.zero_grad();
    optimizer.step();

    assert(optimizer.get_lr() > 0.0);

    println("✓ LAMB Optimizer test passed");
}

fn create_test_model() -> impl Module {
    Sequential::new()
        .add(Linear::new(10, 20))
        .add(ReLU::new())
        .add(Linear::new(20, 5))
        .build()
}

fn create_dummy_loader() -> impl Iterator<Item = (Tensor, Tensor)> {
    std::iter::empty()
}

open fn main() {
    println("Running Advanced Features Tests...\n");
    
    test_lr_finder();
    test_swa();
    test_batch_size_finder();
    test_progressive_resizing();
    test_gradient_centralization();
    test_lamb_optimizer();
    
    println("\n✓ All tests passed!");
}
