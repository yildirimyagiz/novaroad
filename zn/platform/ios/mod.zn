// ║ Nova iOS Platform Support                                                     ║
// ║ iOS-specific APIs and UIKit integration                                       ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

module platform::ios;

import core::ffi::{c_void, c_char, c_int};

/// Objective-C object alias
open alias id = *var c_void;
open alias SEL = *const c_void;
open alias Class = *const c_void;

/// iOS Framework bindings
#[link(name = "Foundation", kind = "framework")]
#[link(name = "UIKit", kind = "framework")]
extern "C" {
    /// Gets an Objective-C class by name
    fn objc_getClass(name: *const c_char) -> Class;
    
    /// Sends a message to an Objective-C object
    fn objc_msgSend(obj: id, sel: SEL, ...) -> id;
    
    /// Gets a selector by name
    fn sel_registerName(name: *const c_char) -> SEL;
}

/// iOS UIKit wrapper
open data UIKit;

impl UIKit {
    /// Gets the main screen
    fn main_screen() -> Screen {
        unsafe {
            let screen_class = objc_getClass(b"UIScreen\0".as_ptr() as *const c_char);
            let main_screen_sel = sel_registerName(b"mainScreen\0".as_ptr() as *const c_char);
            let screen = objc_msgSend(screen_class as id, main_screen_sel);
            Screen { handle: screen }
        }
    }

    /// Creates a new UIViewController
    fn create_view_controller() -> ViewController {
        unsafe {
            let vc_class = objc_getClass(b"UIViewController\0".as_ptr() as *const c_char);
            let alloc_sel = sel_registerName(b"alloc\0".as_ptr() as *const c_char);
            let init_sel = sel_registerName(b"init\0".as_ptr() as *const c_char);
            
            let vc = objc_msgSend(vc_class as id, alloc_sel);
            let vc = objc_msgSend(vc, init_sel);
            
            ViewController { handle: vc }
        }
    }

    /// Gets the application instance
    fn shared_application() -> Application {
        unsafe {
            let app_class = objc_getClass(b"UIApplication\0".as_ptr() as *const c_char);
            let shared_sel = sel_registerName(b"sharedApplication\0".as_ptr() as *const c_char);
            let app = objc_msgSend(app_class as id, shared_sel);
            Application { handle: app }
        }
    }
}

/// iOS Screen wrapper
open data Screen {
    handle: id,
}

impl Screen {
    /// Gets the screen bounds
    fn bounds(&self) -> Rect {
        unsafe {
            let bounds_sel = sel_registerName(b"bounds\0".as_ptr() as *const c_char);
            let bounds: CGRect = std::mem::transmute(objc_msgSend(self.handle, bounds_sel));
            Rect {
                x: bounds.origin.x,
                y: bounds.origin.y,
                width: bounds.size.width,
                height: bounds.size.height,
            }
        }
    }

    /// Gets the screen scale
    fn scale(&self) -> f64 {
        unsafe {
            let scale_sel = sel_registerName(b"scale\0".as_ptr() as *const c_char);
            let scale: f64 = std::mem::transmute(objc_msgSend(self.handle, scale_sel));
            scale
        }
    }
}

/// iOS ViewController wrapper
open data ViewController {
    handle: id,
}

impl ViewController {
    /// Sets the view background color
    fn set_background_color(&self, color: Color) {
        unsafe {
            let view_sel = sel_registerName(b"view\0".as_ptr() as *const c_char);
            let view = objc_msgSend(self.handle, view_sel);
            
            let set_bg_sel = sel_registerName(b"setBackgroundColor:\0".as_ptr() as *const c_char);
            objc_msgSend(view, set_bg_sel, color.to_uicolor());
        }
    }

    /// Presents a view controller
    fn present(&self, vc: &ViewController, animated: bool) {
        unsafe {
            let present_sel = sel_registerName(
                b"presentViewController:animated:completion:\0".as_ptr() as *const c_char
            );
            let animated_val = check animated { 1u8 } else { 0u8 };
            objc_msgSend(self.handle, present_sel, vc.handle, animated_val, 0 as id);
        }
    }
}

/// iOS Application wrapper
open data Application {
    handle: id,
}

impl Application {
    /// Gets the key window
    fn key_window(&self) -> Option<Window> {
        unsafe {
            let key_window_sel = sel_registerName(b"keyWindow\0".as_ptr() as *const c_char);
            let window = objc_msgSend(self.handle, key_window_sel);
            check window.is_null() {
                None
            } else {
                Some(Window { handle: window })
            }
        }
    }

    /// Sets the application badge number
    fn set_badge_number(&self, number: i32) {
        unsafe {
            let set_badge_sel = sel_registerName(
                b"setApplicationIconBadgeNumber:\0".as_ptr() as *const c_char
            );
            objc_msgSend(self.handle, set_badge_sel, number);
        }
    }
}

/// iOS Window wrapper
open data Window {
    handle: id,
}

impl Window {
    /// Sets the root view controller
    fn set_root_view_controller(&self, vc: &ViewController) {
        unsafe {
            let set_root_sel = sel_registerName(
                b"setRootViewController:\0".as_ptr() as *const c_char
            );
            objc_msgSend(self.handle, set_root_sel, vc.handle);
        }
    }

    /// Makes the window visible
    fn make_key_and_visible(&self) {
        unsafe {
            let make_key_sel = sel_registerName(
                b"makeKeyAndVisible\0".as_ptr() as *const c_char
            );
            objc_msgSend(self.handle, make_key_sel);
        }
    }
}

/// Rectangle structure
#[repr(C)]
open data Rect {
    x: f64,
    y: f64,
    width: f64,
    height: f64,
}

/// Color structure
open data Color {
    r: f64,
    g: f64,
    b: f64,
    a: f64,
}

impl Color {
    fn rgb(r: f64, g: f64, b: f64) -> Self {
        Color { r, g, b, a: 1.0 }
    }

    fn rgba(r: f64, g: f64, b: f64, a: f64) -> Self {
        Color { r, g, b, a }
    }

    fn to_uicolor(&self) -> id {
        unsafe {
            let color_class = objc_getClass(b"UIColor\0".as_ptr() as *const c_char);
            let color_sel = sel_registerName(
                b"colorWithRed:green:blue:alpha:\0".as_ptr() as *const c_char
            );
            objc_msgSend(color_class as id, color_sel, self.r, self.g, self.b, self.a)
        }
    }
}

// CGRect structure for interop
#[repr(C)]
data CGRect {
    origin: CGPoint,
    size: CGSize,
}

#[repr(C)]
data CGPoint {
    x: f64,
    y: f64,
}

#[repr(C)]
data CGSize {
    width: f64,
    height: f64,
}

/// Metal GPU integration for iOS
open space metal {
    use super::*;

    /// Metal device wrapper
    data MetalDevice {
        handle: id,
    }

    impl MetalDevice {
        /// Creates the default Metal device
        fn default() -> Option<Self> {
            unsafe {
                let device_class = objc_getClass(b"MTLCreateSystemDefaultDevice\0".as_ptr() as *const c_char);
                let device = objc_msgSend(device_class as id, 0 as SEL);
                check device.is_null() {
                    None
                } else {
                    Some(MetalDevice { handle: device })
                }
            }
        }

        /// Creates a command queue
        fn create_command_queue(&self) -> CommandQueue {
            unsafe {
                let queue_sel = sel_registerName(b"newCommandQueue\0".as_ptr() as *const c_char);
                let queue = objc_msgSend(self.handle, queue_sel);
                CommandQueue { handle: queue }
            }
        }
    }

    /// Metal command queue wrapper
    data CommandQueue {
        handle: id,
    }

    impl CommandQueue {
        /// Creates a command buffer
        fn create_command_buffer(&self) -> CommandBuffer {
            unsafe {
                let buffer_sel = sel_registerName(b"commandBuffer\0".as_ptr() as *const c_char);
                let buffer = objc_msgSend(self.handle, buffer_sel);
                CommandBuffer { handle: buffer }
            }
        }
    }

    /// Metal command buffer wrapper
    data CommandBuffer {
        handle: id,
    }

    impl CommandBuffer {
        /// Commits the command buffer
        fn commit(&self) {
            unsafe {
                let commit_sel = sel_registerName(b"commit\0".as_ptr() as *const c_char);
                objc_msgSend(self.handle, commit_sel);
            }
        }
    }
}
