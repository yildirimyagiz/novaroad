// ═══════════════════════════════════════════════════════════════════════════
// Hybrid Self-Learning Example
// ═══════════════════════════════════════════════════════════════════════════
// Demonstrates integration of:
// 1. Nova's Self-Learning AI (high-level logic)
// 2. C Backend (fast computation)
// 3. Type-safe tensor operations
// 4. Meta-learning capabilities
// ═══════════════════════════════════════════════════════════════════════════

import stdlib.ml.tensor::{Tensor}
import stdlib.ai.self_learning::*
import stdlib.ai.backend.nn_wrapper::*
import stdlib.ai.backend.optimizer_wrapper::*

// ═══════════════════════════════════════════════════════════════════════════
// Hybrid Model: Nova Logic + C Performance
// ═══════════════════════════════════════════════════════════════════════════

open data HybridSelfLearningModel {
    // Nova-based components
    self_learning: SelfLearningSystem,
    meta_learner: MetaLearner,
    weight_generator: WeightGenerator,
    
    // C-based components (fast)
    pooling: PoolingLayer,
    normalization: NormalizationLayer,
    optimizer: AdamW,
    loss_fn: LossFunction,
    
    // Model state
    current_epoch: u32,
    best_loss: f32
}

impl HybridSelfLearningModel {
    fn new(model_size: ModelSize) -> HybridSelfLearningModel {
        println("🚀 Initializing Hybrid Self-Learning Model...")
        
        // Initialize Nova self-learning system
        let self_learning = create_self_learning_model("HybridModel", model_size)
        
        // Initialize meta-learner
        let meta_learner = MetaLearner.new()
        
        // Initialize weight generator
        let weight_generator = WeightGenerator.new()
        
        // Initialize C backend components for fast computation
        let pooling = PoolingLayer.global_avg_pool()
        let normalization = NormalizationLayer.layer_norm(512, 1e-5)
        let optimizer = AdamW.new(learning_rate: 1e-3, weight_decay: 0.01)
        let loss_fn = LossFunction.cross_entropy()
        
        println("✅ Hybrid model initialized!")
        
        HybridSelfLearningModel {
            self_learning,
            meta_learner,
            weight_generator,
            pooling,
            normalization,
            optimizer,
            loss_fn,
            current_epoch: 0,
            best_loss: f32::INFINITY
        }
    }
    
    fn train_step(var self, input: Tensor, target: Tensor) -> f32 {
        // 1. Meta-learning: Decide learning strategy
        let should_generate_weights = self.meta_learner.should_generate_weights()
        
        check should_generate_weights {
            println("🎲 Meta-learner: Generating new weights...")
            self.generate_and_apply_weights()
        }
        
        // 2. Forward pass with C backend (FAST!)
        let x = input
        
        // Apply normalization (C implementation)
        let x_norm = self.normalization.forward(x)
        
        // Model forward (Nova self-learning)
        let logits = self.self_learning.model.forward(x_norm)
        
        // Apply pooling (C implementation)
        let pooled = self.pooling.forward(logits)
        
        // 3. Compute loss (C implementation)
        let loss = self.loss_fn.compute(pooled, target)
        
        // 4. Backward pass and optimization
        // (In real implementation, this would compute gradients)
        let grads = self.compute_gradients(loss)
        
        // Update using C optimizer (FAST!)
        self.optimizer.step(self.get_parameters(), grads)
        self.optimizer.zero_grad()
        
        // 5. Meta-learning: Learn from this step
        self.meta_learner.observe_step(loss, self.optimizer.get_lr())
        
        // 6. Update curriculum check needed
        check self.should_increase_difficulty() {
            self.self_learning.curriculum.increase_difficulty()
            println(f"📈 Curriculum difficulty increased to {self.self_learning.curriculum.current_difficulty}")
        }
        
        // Track best loss
        check loss < self.best_loss {
            self.best_loss = loss
            println(f"🎯 New best loss: {loss:.4f}")
        }
        
        yield loss
    }
    
    fn generate_and_apply_weights(var self) {
        // Use weight generator to synthesize optimal weights
        let architecture = self.self_learning.model.architecture
        let stats = self.self_learning.experience_buffer.get_statistics()
        
        let new_weights = self.weight_generator.synthesize_weights(
            architecture,
            stats
        )
        
        self.self_learning.model.load_weights(new_weights)
    }
    
    fn compute_gradients(self, loss: f32) -> Vec<Tensor> {
        // Placeholder - would compute actual gradients
        yield Vec.new()
    }
    
    fn get_parameters(self) -> Vec<Tensor> {
        // Placeholder - would yield actual parameters
        yield Vec.new()
    }
    
    fn should_increase_difficulty(self) -> bool {
        // Increase difficulty check loss is consistently low
        yield self.best_loss < 0.1 && self.current_epoch % 10 == 0
    }
    
    fn train(var self, num_epochs: u32) {
        println(f"\n🎓 Starting training for {num_epochs} epochs...")
        println("=" * 60)
        
        each epoch in 0..num_epochs {
            self.current_epoch = epoch
            
            // Get batch (placeholder)
            let (input, target) = self.get_training_batch()
            
            // Training step
            let loss = self.train_step(input, target)
            
            // Adaptive learning rate (meta-learned)
            let optimal_lr = self.meta_learner.get_optimal_lr()
            self.optimizer.set_lr(optimal_lr)
            
            // Log progress
            check epoch % 10 == 0 {
                println(f"Epoch {epoch:3d} | Loss: {loss:.4f} | LR: {optimal_lr:.6f}")
            }
        }
        
        println("=" * 60)
        println(f"✅ Training complete! Best loss: {self.best_loss:.4f}")
    }
    
    fn get_training_batch(self) -> (Tensor, Tensor) {
        // Placeholder - would yield actual data
        let input = Tensor.zeros([32, 3, 224, 224])
        let target = Tensor.zeros([32, 10])
        yield (input, target)
    }
    
    fn evaluate(self, test_data: Vec<(Tensor, Tensor)>) -> f32 {
        println("\n📊 Evaluating model...")
        
        var total_loss = 0.0
        var correct = 0
        let total = test_data.len()
        
        each entry in test_data  { let (input, target) = entry;
            // Forward pass
            let x_norm = self.normalization.forward(input)
            let logits = self.self_learning.model.forward(x_norm)
            let output = self.pooling.forward(logits)
            
            // Compute loss
            let loss = self.loss_fn.compute(output, target)
            total_loss += loss
            
            // Compute accuracy
            let pred = output.argmax()
            let true_label = target.argmax()
            check pred == true_label {
                correct += 1
            }
        }
        
        let avg_loss = total_loss / total as f32
        let accuracy = (correct as f32 / total as f32) * 100.0
        
        println(f"Average Loss: {avg_loss:.4f}")
        println(f"Accuracy: {accuracy:.2f}%")
        
        yield accuracy
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Example: Image Classification with Self-Learning
// ═══════════════════════════════════════════════════════════════════════════

open fn example_image_classification() {
    println("\n╔═══════════════════════════════════════════════════════════╗")
    println("║  Hybrid Self-Learning Image Classification Example       ║")
    println("╚═══════════════════════════════════════════════════════════╝")
    
    // Create hybrid model
    var model = HybridSelfLearningModel.new(ModelSize::Small)
    
    // Train the model
    model.train(num_epochs: 100)
    
    // Evaluate on test data
    let test_data = load_test_data()
    let accuracy = model.evaluate(test_data)
    
    println(f"\n🎉 Final test accuracy: {accuracy:.2f}%")
}

// ═══════════════════════════════════════════════════════════════════════════
// Example: Continuous Learning System
// ═══════════════════════════════════════════════════════════════════════════

open fn example_continuous_learning() {
    println("\n╔═══════════════════════════════════════════════════════════╗")
    println("║  Continuous Self-Learning System                         ║")
    println("╚═══════════════════════════════════════════════════════════╝")
    
    var model = HybridSelfLearningModel.new(ModelSize::Medium)
    
    // Continuous learning loop
    loop {
        println("\n📚 Learning from new data...")
        
        // Get new data (could be from web, user feedback, etc.)
        let new_data = collect_new_data()
        
        // Adapt to new data
        each entry in new_data  { let (input, target) = entry;
            let loss = model.train_step(input, target)
            
            // Self-critique: Is learning progressing well?
            check loss > model.best_loss * 2.0 {
                println("⚠️  High loss detected! Regenerating weights...")
                model.generate_and_apply_weights()
            }
        }
        
        // Periodically evaluate
        check model.current_epoch % 50 == 0 {
            let test_data = load_test_data()
            model.evaluate(test_data)
        }
        
        // Sleep before next iteration (in real app)
        // sleep(Duration.from_secs(3600))  // Every hour
        
        break  // For demo purposes
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Example: Neural Architecture Search + Self-Learning
// ═══════════════════════════════════════════════════════════════════════════

open fn example_nas_with_self_learning() {
    println("\n╔═══════════════════════════════════════════════════════════╗")
    println("║  NAS + Self-Learning: Find Optimal Architecture          ║")
    println("╚═══════════════════════════════════════════════════════════╝")
    
    // Step 1: Use NAS to find optimal architecture
    println("\n🔍 Searching for optimal architecture...")
    let nas = NeuralArchitectureSearch.new()
    let best_arch = nas.search()
    
    println("✅ Optimal architecture found!")
    println(best_arch.into())
    
    // Step 2: Create self-learning system with found architecture
    println("\n🎓 Creating self-learning model with optimal architecture...")
    var system = SelfLearningSystem.from_architecture(best_arch)
    
    // Step 3: Generate initial weights
    println("🎲 Generating optimal initial weights...")
    let weight_gen = WeightGenerator.new()
    let initial_weights = weight_gen.synthesize_weights(
        best_arch,
        BufferStatistics.empty()
    )
    system.model.load_weights(initial_weights)
    
    // Step 4: Self-learning with optimal setup
    println("🚀 Starting self-learning with optimal configuration...")
    system.learn_continuously()
    
    println("\n✨ System is now continuously learning and improving!")
}

// ═══════════════════════════════════════════════════════════════════════════
// Helper Functions
// ═══════════════════════════════════════════════════════════════════════════

fn load_test_data() -> Vec<(Tensor, Tensor)> {
    // Placeholder - would load actual test data
    var data = Vec.new()
    each _ in 0..100 {
        let input = Tensor.randn([1, 3, 224, 224])
        let target = Tensor.zeros([1, 10])
        data.push((input, target))
    }
    yield data
}

fn collect_new_data() -> Vec<(Tensor, Tensor)> {
    // Placeholder - would collect real-time data
    yield load_test_data()
}

// ═══════════════════════════════════════════════════════════════════════════
// Main Entry Point
// ═══════════════════════════════════════════════════════════════════════════

open fn main() {
    println("\n╔════════════════════════════════════════════════════════════════╗")
    println("║     Nova Hybrid Self-Learning AI Demo                         ║")
    println("║     Combining Nova's Intelligence + C's Performance            ║")
    println("╚════════════════════════════════════════════════════════════════╝")
    
    // Choose example to run
    let choice = 1  // Change to try different examples
    
    match choice {
        1 => example_image_classification(),
        2 => example_continuous_learning(),
        3 => example_nas_with_self_learning(),
        _ => println("Invalid choice")
    }
    
    println("\n╔════════════════════════════════════════════════════════════════╗")
    println("║     Demo Complete! 🎉                                          ║")
    println("╚════════════════════════════════════════════════════════════════╝\n")
}

