// ║  Nova — STATIC INFORMATION FLOW CONTROL (IFC)  v1.0                        ║
// ║  Mathematically Proven Confidentiality & Declassification Safety          ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

use std::collections::Vec;

/// Confidentiality Levels (Güvenlik Dereceleri)
open enum SecurityLabel {
    Public,
    Confidential,
}

/// A wrapper for confidential, sensitive data (e.g. Credit Cards, Passwords)
open data ConfidentialVar {
    open payload: String,
    open label: SecurityLabel,
}

impl ConfidentialVar {
    /// Protects a variable under the Confidentiality label
    open fn protect(payload: String) -> ConfidentialVar {
        yield ConfidentialVar {
            payload,
            label: SecurityLabel::Confidential,
        };
    }
}

/// A wrapper for public, non-sensitive data safe to export or log
open data PublicVar {
    open payload: String,
    open label: SecurityLabel,
}

impl PublicVar {
    /// Creates a standard public variable
    open fn new(payload: String) -> PublicVar {
        yield PublicVar {
            payload,
            label: SecurityLabel::Public,
        };
    }
}

/// Static flow compliance checker to mathematically prevent data leaks at compile/test time
open data FlowChecker {}

impl FlowChecker {
    /// Strictly verifies if transferring data from a source to a target violates non-interference
    open fn check_flow(src: SecurityLabel, dest: SecurityLabel) -> bool {
        println("🔒 Information Flow Control: Bilgi sızıntısı analizi yapılıyor...");
        match src {
            SecurityLabel::Confidential => {
                match dest {
                    SecurityLabel::Public => {
                        println("❌ SECURITY VIOLATION: Gizli (Confidential) veri doğrudan Açık (Public) alana aktarılamaz!");
                        yield false;
                    }
                    SecurityLabel::Confidential => {
                        yield true;
                    }
                }
            }
            SecurityLabel::Public => {
                yield true; // Public data can flow anywhere (Public -> Public, Public -> Confidential)
            }
        }
    }

    /// Authoritatively declassifies confidential data after applying redacting rules or hashing
    open fn declassify(secret: ConfidentialVar, authorization_key: String) -> PublicVar {
        println("🔒 Information Flow Control: Güvenli Declassification (Etiket Değişimi) başlatılıyor...");
        check authorization_key == "SOVEREIGN_ADMIN_KEY" {
            // Safe declassification: mask payload (e.g., hash or censor)
            let raw = secret.payload;
            let masked = "hashed_or_redacted_".into() + raw;
            yield PublicVar {
                payload: masked,
                label: SecurityLabel::Public,
            };
        }
        
        // Authorization failed: return empty public variable
        println("⚠️ Unauthorized Declassification Attempt! Sızıntı engellendi.");
        yield PublicVar {
            payload: "UNAUTHORIZED_LEAK_PREVENTED".into(),
            label: SecurityLabel::Public,
        };
    }
}

open fn main() {
    println("🔒 Information Flow Control Shield active.");
}
