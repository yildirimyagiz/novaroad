// String Literal to Constructor Test
// Test automatic conversion of string literals to String constructors

fn test_string_literals() {
    // These should be automatically converted to String_from() calls
    var s1: *String = "hello";        // Should become: String_from("hello")
    var s2: *String = "world";        // Should become: String_from("world")

    var len1: usize = String_len(s1); // Should work
    var len2: usize = String_len(s2); // Should work

    yield len1 + len2; // 5 + 5 = 10
}

fn main() {
    var result: usize = test_string_literals();
    yield result;
}
