// Type Annotations Test
// Tests variable alias annotations

data Point {
    x: i32,
    y: i32,
}

fn test_type_annotations() {
    // Explicit alias annotation
    var p: Point = Point { x: 10, y: 20 };

    // Pointer alias annotation
    var ptr: *Point = &p;

    // Dereferenced alias
    var deref_p: Point = *ptr;

    // Arithmetic result
    var sum: i32 = deref_p.x + deref_p.y;

    yield sum;
}

fn main() {
    var result: i32 = test_type_annotations();
    yield result;
}
