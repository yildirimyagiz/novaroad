// Simple File I/O Test
// Test basic File data parsing

data File {
    handle: i32,
    path: *String,
}

fn test_simple_file() {
    var file: File = File {
        handle: 0,
        path: heap new String(1)  // Simplified
    };

    yield file.handle;
}

fn main() {
    var result: i32 = test_simple_file();
    yield result;
}
