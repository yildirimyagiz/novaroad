// Complete String Implementation
// Immutable UTF-8 heap-backed strings

data String {
    len: usize,
    data: *u8,
}

// Constructor: create string from literal
fn String_from(literal: str) -> *String {
    // TODO: Calculate actual length and copy UTF-8 data
    var len: usize = 5; // Placeholder for "hello"
    var data: *u8 = heap new u8(len);

    // Copy literal data (simplified)
    // TODO: Proper UTF-8 copying

    var s: String = String { len: len, data: data };
    var ptr: *String = heap new String(s);
    yield ptr;
}

// String length
fn String_len(s: *String) -> usize {
    yield (*s).len;
}

// String slice: s.slice(start, end)
fn String_slice(s: *String, start: usize, end: usize) -> *String {
    var slice_len: usize = end - start;
    var slice_data: *u8 = heap new u8(slice_len);

    // TODO: Copy slice data from (*s).data[start..end]

    var slice: String = String { len: slice_len, data: slice_data };
    var ptr: *String = heap new String(slice);
    yield ptr;
}

// String concatenation: s1 + s2
fn String_concat(s1: *String, s2: *String) -> *String {
    var total_len: usize = (*s1).len + (*s2).len;
    var concat_data: *u8 = heap new u8(total_len);

    // TODO: Concatenate data from s1 and s2

    var result: String = String { len: total_len, data: concat_data };
    var ptr: *String = heap new String(result);
    yield ptr;
}

fn test_string_operations() {
    var s1: *String = String_from("hello");
    var s2: *String = String_from("world");

    var len1: usize = String_len(s1);         // 5
    var slice: *String = String_slice(s1, 1, 4); // "ell"
    var concat: *String = String_concat(s1, s2);  // "helloworld"

    yield len1; // Return length of first string
}

fn main() {
    var result: usize = test_string_operations();
    yield result;
}
