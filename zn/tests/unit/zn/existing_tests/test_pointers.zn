// Pointer Syntax Test
// Tests basic pointer operations

data Point {
    x: i32,
    y: i32,
}

fn test_pointers() {
    // Stack allocation
    var p = Point { x: 10, y: 20 };

    // Address-of
    var ptr = &p;

    // Dereference
    var deref_p = *ptr;

    // Field access on dereferenced data
    var sum = deref_p.x + deref_p.y;

    yield sum;
}

fn main() {
    var result = test_pointers();
    yield result;
}
