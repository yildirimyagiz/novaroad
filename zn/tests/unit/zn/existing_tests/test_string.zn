// String Type Implementation
// Heap-backed immutable UTF-8 strings

data String {
    len: i32,
    data: *u8,
}

fn String_from(literal: str) -> *String {
    // Convert string literal to heap-backed String
    // For now, just wrap in data
    var len: i32 = 5; // TODO: actual length calculation
    var data: *u8 = heap new u8(5); // TODO: actual data copy
    
    var s: String = String { len: len, data: data };
    var ptr: *String = heap new String(s);
    yield ptr;
}

fn test_string() {
    var s: *String = String_from("hello");
    yield (*s).len; // Should yield string length
}

fn main() {
    var result: i32 = test_string();
    yield result;
}
