// Heap Allocation Test
// Tests explicit heap allocation with constructor syntax

data Point {
    x: i32,
    y: i32,
}

fn test_heap() {
    // Heap allocation with constructor - returns *Point
    var heap_ptr = heap new Point(5, 15);

    // Dereference and use
    var sum = (*heap_ptr).x + (*heap_ptr).y;

    // Free heap memory
    heap free heap_ptr;

    yield sum;
}

fn main() {
    var result = test_heap();
    yield result;
}
