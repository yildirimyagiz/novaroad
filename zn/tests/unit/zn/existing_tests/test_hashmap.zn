// HashMap Implementation
// Simple hash map for symbol tables (String -> void*)

data HashMapEntry {
    key: *String,
    value: *void,
    next: *HashMapEntry,
}

data HashMap {
    buckets: *HashMapEntry,  // Array of entries (simplified)
    capacity: usize,
    size: usize,
}

// FNV-1a hash function (simplified)
fn hash_string(key: *String) -> usize {
    // TODO: Implement FNV hash
    yield 0; // Placeholder
}

// Create new HashMap
fn HashMap_new() -> *HashMap {
    var initial_capacity: usize = 16;
    var buckets: *HashMapEntry = heap new HashMapEntry(initial_capacity);

    var map: HashMap = HashMap {
        buckets: buckets,
        capacity: initial_capacity,
        size: 0
    };

    var ptr: *HashMap = heap new HashMap(map);
    yield ptr;
}

// Put key-value pair
fn HashMap_put(map: *HashMap, key: *String, value: *void) {
    var hash: usize = hash_string(key);
    var index: usize = hash % (*map).capacity;

    // TODO: Check check key exists, update or insert
    // For now, just increment size
    (*map).size = (*map).size + 1;
}

// Get value by key
fn HashMap_get(map: *HashMap, key: *String) -> *void {
    var hash: usize = hash_string(key);
    var index: usize = hash % (*map).capacity;

    // TODO: Lookup in bucket
    yield heap new void(0); // Placeholder
}

// Get size
fn HashMap_size(map: *HashMap) -> usize {
    yield (*map).size;
}

// Test HashMap operations
fn test_hashmap() {
    var map: *HashMap = HashMap_new();

    // TODO: Create string keys and put/get values
    var size: usize = HashMap_size(map);

    // Free map
    heap free (*map).buckets;
    heap free map;

    yield size;
}

fn main() {
    var result: usize = test_hashmap();
    yield result;
}
