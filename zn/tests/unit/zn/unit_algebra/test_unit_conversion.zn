// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  UNIT ALGEBRA - UNIT CONVERSION TESTS                                    ║
// ║  Test unit conversions within dimension families                         ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

// Test 1: Length Conversions
fn test_length_conversions() -> bool {
    let dist_m: qty<f64, m> = 1000.0.m;
    let dist_km = dist_m in km;
    
    assert(dist_km == 1.0.km);
    
    // Back conversion
    let back_to_m = dist_km in m;
    assert(back_to_m == 1000.0.m);
    
    // Smaller units
    let dist_cm = 100.0.cm;
    let in_meters = dist_cm in m;
    assert(in_meters == 1.0.m);
    
    true
}

// Test 2: Mass Conversions
fn test_mass_conversions() -> bool {
    let mass_kg: qty<f64, kg> = 5.0.kg;
    
    // kg to g
    let mass_g = mass_kg in g;
    assert(mass_g == 5000.0.g);
    
    // kg to mg
    let mass_mg = mass_kg in mg;
    assert(mass_mg == 5_000_000.0.mg);
    
    // g back to kg
    let back_to_kg = mass_g in kg;
    assert(back_to_kg == 5.0.kg);
    
    true
}

// Test 3: Time Conversions
fn test_time_conversions() -> bool {
    let time_s: qty<f64, s> = 3600.0.s;
    
    // Seconds to hours
    let time_h = time_s in h;
    assert(time_h == 1.0.h);
    
    // Seconds to minutes
    let time_m: qty<f64, s> = 120.0.s;
    let in_min = time_m in min;
    assert(in_min == 2.0.min);
    
    // Milliseconds
    let time_ms: qty<f64, ms> = 1000.0.ms;
    let in_sec = time_ms in s;
    assert(in_sec == 1.0.s);
    
    true
}

// Test 4: Area Conversions
fn test_area_conversions() -> bool {
    let area_m2: qty<f64, m²> = 10000.0.m²;
    
    // m² to km²
    let area_km2 = area_m2 in km²;
    assert(area_km2 == 0.01.km²);
    
    // cm² to m²
    let area_cm2: qty<f64, cm²> = 10000.0.cm²;
    let in_m2 = area_cm2 in m²;
    assert(in_m2 == 1.0.m²);
    
    true
}

// Test 5: Volume Conversions
fn test_volume_conversions() -> bool {
    let vol_m3: qty<f64, m³> = 1.0.m³;
    
    // m³ to L (1 m³ = 1000 L)
    let vol_l = vol_m3 in L;
    assert(vol_l == 1000.0.L);
    
    // L to mL
    let vol_l2: qty<f64, L> = 2.0.L;
    let vol_ml = vol_l2 in mL;
    assert(vol_ml == 2000.0.mL);
    
    true
}

// Test 6: Velocity Conversions
fn test_velocity_conversions() -> bool {
    let vel_ms: qty<f64, m/s> = 10.0.m/s;
    
    // m/s to km/h
    let vel_kmh = vel_ms in km/h;
    assert(vel_kmh == 36.0.km/h);
    
    // km/h to m/s
    let vel_kmh2: qty<f64, km/h> = 72.0.km/h;
    let vel_ms2 = vel_kmh2 in m/s;
    assert(vel_ms2 == 20.0.m/s);
    
    true
}

// Test 7: Energy Conversions
fn test_energy_conversions() -> bool {
    let energy_j: qty<f64, J> = 1000.0.J;
    
    // J to kJ
    let energy_kj = energy_j in kJ;
    assert(energy_kj == 1.0.kJ);
    
    // kWh to J (1 kWh = 3,600,000 J)
    let energy_kwh: qty<f64, kWh> = 1.0.kWh;
    let energy_j2 = energy_kwh in J;
    assert(energy_j2 == 3_600_000.0.J);
    
    true
}

// Test 8: Power Conversions
fn test_power_conversions() -> bool {
    let power_w: qty<f64, W> = 1000.0.W;
    
    // W to kW
    let power_kw = power_w in kW;
    assert(power_kw == 1.0.kW);
    
    // kW to MW
    let power_kw2: qty<f64, kW> = 1000.0.kW;
    let power_mw = power_kw2 in MW;
    assert(power_mw == 1.0.MW);
    
    true
}

// Test 9: Pressure Conversions
fn test_pressure_conversions() -> bool {
    let pressure_pa: qty<f64, Pa> = 100000.0.Pa;
    
    // Pa to kPa
    let pressure_kpa = pressure_pa in kPa;
    assert(pressure_kpa == 100.0.kPa);
    
    // Standard atmosphere
    let pressure_atm: qty<f64, atm> = 1.0.atm;
    let pressure_pa2 = pressure_atm in Pa;
    assert(pressure_pa2 > 101000.0.Pa && pressure_pa2 < 102000.0.Pa);
    
    true
}

// Test 10: Temperature Conversions (Special Case)
fn test_temperature_conversions() -> bool {
    // Temperature requires offset conversions, not just scaling
    let temp_c: qty<f64, °C> = 0.0.°C;
    
    // Celsius to Kelvin (0°C = 273.15K)
    let temp_k = temp_c in K;
    assert(temp_k > 273.0.K && temp_k < 274.0.K);
    
    // Celsius to Fahrenheit (0°C = 32°F)
    let temp_f = temp_c in °F;
    assert(temp_f == 32.0.°F);
    
    // Fahrenheit to Celsius (212°F = 100°C)
    let temp_f2: qty<f64, °F> = 212.0.°F;
    let temp_c2 = temp_f2 in °C;
    assert(temp_c2 == 100.0.°C);
    
    true
}

// Test 11: Chained Conversions
fn test_chained_conversions() -> bool {
    let dist: qty<f64, m> = 1000.0.m;
    
    // m -> km -> m
    let result = (dist in km) in m;
    assert(result == 1000.0.m);
    
    // Multiple conversions
    let mass: qty<f64, kg> = 1.0.kg;
    let in_g = mass in g;
    let in_mg = in_g in mg;
    let back = in_mg in kg;
    
    assert(back == 1.0.kg);
    
    true
}

// Test 12: Conversion Precision
fn test_conversion_precision() -> bool {
    let dist: qty<f64, m> = 1.0.m;
    
    // Convert to smaller unit and back
    let in_mm = dist in mm;
    assert(in_mm == 1000.0.mm);
    
    let back = in_mm in m;
    assert(back == 1.0.m);
    
    // Very small differences should be handled correctly
    let precise: qty<f64, m> = 0.001.m;
    let in_mm2 = precise in mm;
    assert(in_mm2 == 1.0.mm);
    
    true
}

// Main test runner
fn main() -> i32 {
    println("🧪 Running Unit Conversion Tests");
    
    let tests = [
        ("Length Conversions", test_length_conversions),
        ("Mass Conversions", test_mass_conversions),
        ("Time Conversions", test_time_conversions),
        ("Area Conversions", test_area_conversions),
        ("Volume Conversions", test_volume_conversions),
        ("Velocity Conversions", test_velocity_conversions),
        ("Energy Conversions", test_energy_conversions),
        ("Power Conversions", test_power_conversions),
        ("Pressure Conversions", test_pressure_conversions),
        ("Temperature Conversions", test_temperature_conversions),
        ("Chained Conversions", test_chained_conversions),
        ("Conversion Precision", test_conversion_precision)
    ];
    
    var passed = 0;
    var failed = 0;
    
    each entry in tests  { let (name, test) = entry;
        print("  Testing: {name}... ");
        check test() {
            println("✅ PASS");
            passed = passed + 1;
        } else {
            println("❌ FAIL");
            failed = failed + 1;
        }
    }
    
    println("");
    println("📊 Results: {passed} passed, {failed} failed");
    
    check failed == 0 { 0 } else { 1 }
}
