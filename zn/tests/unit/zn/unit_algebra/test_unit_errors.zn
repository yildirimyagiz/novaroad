// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  UNIT ALGEBRA - ERROR DETECTION TESTS                                    ║
// ║  Verify compile-time dimensional analysis catches errors                  ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

// These tests verify that the compiler REJECTS invalid dimensional operations
// Most of these should be commented out as they're expected to fail compilation

fn test_dimension_mismatch_addition() -> bool {
    // ERROR: Cannot add mass + length
    // let invalid = 5.0.kg + 3.0.m;  // Should fail at compile time
    
    // Valid: Same dimensions
    let valid = 5.0.kg + 3.0.kg;
    assert(valid == 8.0.kg);
    
    true
}

fn test_dimension_mismatch_subtraction() -> bool {
    // ERROR: Cannot subtract time from mass
    // let invalid = 10.0.kg - 2.0.s;  // Should fail at compile time
    
    // Valid: Same dimensions
    let valid = 10.0.kg - 2.0.kg;
    assert(valid == 8.0.kg);
    
    true
}

fn test_dimension_mismatch_comparison() -> bool {
    // ERROR: Cannot compare incompatible dimensions
    // let invalid = 5.0.kg > 3.0.m;   // Should fail at compile time
    // let invalid2 = 2.0.s == 2.0.kg; // Should fail at compile time
    
    // Valid: Same dimensions
    let valid = 5.0.kg > 3.0.kg;
    assert(valid == true);
    
    true
}

fn test_dimension_mismatch_assignment() -> bool {
    let mass: qty<f64, kg> = 5.0.kg;
    
    // ERROR: Cannot assign length to mass variable
    // mass = 10.0.m;  // Should fail at compile time
    
    // Valid: Correct dimension
    mass = 10.0.kg;
    assert(mass == 10.0.kg);
    
    true
}

fn test_wrong_unit_in_expression() -> bool {
    let velocity: qty<f64, m/s> = 10.0.m/s;
    let time: qty<f64, s> = 2.0.s;
    
    // ERROR: Result should be distance (m), not velocity
    // let distance: qty<f64, m/s> = velocity * time;  // Type error
    
    // Valid: Correct result alias
    let distance: qty<f64, m> = velocity * time;
    assert(distance == 20.0.m);
    
    true
}

fn test_dimensionless_operations() -> bool {
    let ratio = 10.0.m / 5.0.m;  // m/m = dimensionless
    
    // Dimensionless values can be compared with regular numbers
    assert(ratio == 2.0);
    
    // Can multiply dimensionless by qty
    let length: qty<f64, m> = ratio * 3.0.m;
    assert(length == 6.0.m);
    
    true
}

fn test_invalid_conversion() -> bool {
    let mass: qty<f64, kg> = 5.0.kg;
    
    // ERROR: Cannot convert mass to length
    // let length = mass in m;  // Should fail at compile time
    
    // Valid: Convert within same dimension family
    let mass_g = mass in g;
    assert(mass_g == 5000.0.g);
    
    true
}

fn test_mixed_scalar_and_qty() -> bool {
    let mass: qty<f64, kg> = 5.0.kg;
    
    // ERROR: Cannot add plain number to qty
    // let invalid = mass + 3.0;  // Should fail at compile time
    
    // Valid: Multiply by scalar
    let doubled = mass * 2.0;
    assert(doubled == 10.0.kg);
    
    // Valid: Divide by scalar
    let halved = mass / 2.0;
    assert(halved == 2.5.kg);
    
    true
}

fn test_type_annotation_mismatch() -> bool {
    // ERROR: Declared as kg but initialized with m
    // let mass: qty<f64, kg> = 5.0.m;  // Should fail at compile time
    
    // Valid: Matching types
    let mass: qty<f64, kg> = 5.0.kg;
    assert(mass == 5.0.kg);
    
    true
}

fn test_function_parameter_mismatch() -> bool {
    fn calculate_force(mass: qty<f64, kg>, accel: qty<f64, m/s²>) -> qty<f64, N> {
        yield mass * accel;
    }
    
    let m: qty<f64, kg> = 2.0.kg;
    let a: qty<f64, m/s²> = 5.0.m/s²;
    
    // Valid call
    let force = calculate_force(m, a);
    assert(force == 10.0.N);
    
    // ERROR: Wrong argument types
    // let invalid = calculate_force(a, m);  // Should fail (swapped args)
    // let invalid2 = calculate_force(2.0, 5.0);  // Should fail (no units)
    
    true
}

// Main test runner
fn main() -> i32 {
    println("🧪 Running Unit Algebra Error Detection Tests");
    println("Note: Some error cases are commented out (expected to fail compilation)");
    
    let tests = [
        ("Dimension Mismatch: Addition", test_dimension_mismatch_addition),
        ("Dimension Mismatch: Subtraction", test_dimension_mismatch_subtraction),
        ("Dimension Mismatch: Comparison", test_dimension_mismatch_comparison),
        ("Dimension Mismatch: Assignment", test_dimension_mismatch_assignment),
        ("Wrong Unit in Expression", test_wrong_unit_in_expression),
        ("Dimensionless Operations", test_dimensionless_operations),
        ("Invalid Conversion", test_invalid_conversion),
        ("Mixed Scalar and Qty", test_mixed_scalar_and_qty),
        ("Type Annotation Mismatch", test_type_annotation_mismatch),
        ("Function Parameter Mismatch", test_function_parameter_mismatch)
    ];
    
    var passed = 0;
    var failed = 0;
    
    each entry in tests  { let (name, test) = entry;
        print("  Testing: {name}... ");
        check test() {
            println("✅ PASS");
            passed = passed + 1;
        } else {
            println("❌ FAIL");
            failed = failed + 1;
        }
    }
    
    println("");
    println("📊 Results: {passed} passed, {failed} failed");
    
    check failed == 0 { 0 } else { 1 }
}
