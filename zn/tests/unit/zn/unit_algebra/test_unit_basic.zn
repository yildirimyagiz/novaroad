// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  UNIT ALGEBRA - BASIC TESTS                                              ║
// ║  Test fundamental unit algebra features                                   ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

// Test 1: Basic SI Units
fn test_basic_si_units() -> bool {
    let mass: qty<f64, kg> = 5.0.kg;
    let length: qty<f64, m> = 10.0.m;
    let time: qty<f64, s> = 2.0.s;
    
    // Values should be correct
    assert(mass == 5.0.kg);
    assert(length == 10.0.m);
    assert(time == 2.0.s);
    
    true
}

// Test 2: Derived Units
fn test_derived_units() -> bool {
    // Velocity = length / time
    let distance: qty<f64, m> = 100.0.m;
    let time: qty<f64, s> = 10.0.s;
    let velocity: qty<f64, m/s> = distance / time;
    
    assert(velocity == 10.0.m/s);
    
    // Acceleration = velocity / time
    let accel: qty<f64, m/s²> = velocity / time;
    assert(accel == 1.0.m/s²);
    
    true
}

// Test 3: Force Calculation (Newton's Second Law)
fn test_force_calculation() -> bool {
    let mass: qty<f64, kg> = 2.0.kg;
    let accel: qty<f64, m/s²> = 5.0.m/s²;
    
    // F = ma (should be kg·m/s² = N)
    let force: qty<f64, N> = mass * accel;
    
    assert(force == 10.0.N);
    
    true
}

// Test 4: Energy Calculation
fn test_energy_calculation() -> bool {
    let mass: qty<f64, kg> = 2.0.kg;
    let velocity: qty<f64, m/s> = 5.0.m/s;
    
    // KE = 0.5 * m * v²
    let kinetic_energy: qty<f64, J> = 0.5 * mass * velocity * velocity;
    
    assert(kinetic_energy == 25.0.J);
    
    true
}

// Test 5: Power Calculation
fn test_power_calculation() -> bool {
    let energy: qty<f64, J> = 1000.0.J;
    let time: qty<f64, s> = 10.0.s;
    
    // P = E / t (should be J/s = W)
    let power: qty<f64, W> = energy / time;
    
    assert(power == 100.0.W);
    
    true
}

// Test 6: Dimensional Arithmetic (Same Units)
fn test_same_dimension_arithmetic() -> bool {
    let dist1: qty<f64, m> = 10.0.m;
    let dist2: qty<f64, m> = 5.0.m;
    
    // Addition
    let total: qty<f64, m> = dist1 + dist2;
    assert(total == 15.0.m);
    
    // Subtraction
    let diff: qty<f64, m> = dist1 - dist2;
    assert(diff == 5.0.m);
    
    true
}

// Test 7: Comparison Operations
fn test_comparisons() -> bool {
    let mass1: qty<f64, kg> = 10.0.kg;
    let mass2: qty<f64, kg> = 5.0.kg;
    
    assert(mass1 > mass2);
    assert(mass2 < mass1);
    assert(mass1 >= 10.0.kg);
    assert(mass2 <= 5.0.kg);
    assert(mass1 == 10.0.kg);
    assert(mass1 != mass2);
    
    true
}

// Test 8: Unit Prefixes
fn test_unit_prefixes() -> bool {
    let dist_km: qty<f64, km> = 1.0.km;
    let dist_m: qty<f64, m> = 1000.0.m;
    
    // Should be equivalent after conversion
    assert(dist_km == dist_m);
    
    let mass_kg: qty<f64, kg> = 1.0.kg;
    let mass_g: qty<f64, g> = 1000.0.g;
    
    assert(mass_kg == mass_g);
    
    true
}

// Test 9: Zero and Negative Values
fn test_special_values() -> bool {
    let zero_mass: qty<f64, kg> = 0.0.kg;
    let neg_velocity: qty<f64, m/s> = -5.0.m/s;
    
    assert(zero_mass == 0.0.kg);
    assert(neg_velocity < 0.0.m/s);
    
    // Operations with zero
    let mass: qty<f64, kg> = 5.0.kg;
    let zero_force: qty<f64, N> = mass * 0.0.m/s²;
    assert(zero_force == 0.0.N);
    
    true
}

// Test 10: Complex Derived Units
fn test_complex_units() -> bool {
    // Pressure: Force / Area = N/m² = Pa
    let force: qty<f64, N> = 100.0.N;
    let area: qty<f64, m²> = 2.0.m²;
    let pressure: qty<f64, Pa> = force / area;
    
    assert(pressure == 50.0.Pa);
    
    // Frequency: 1/time = Hz
    let period: qty<f64, s> = 0.1.s;
    let frequency: qty<f64, Hz> = 1.0 / period;
    
    assert(frequency == 10.0.Hz);
    
    true
}

// Main test runner
fn main() -> i32 {
    println("🧪 Running Unit Algebra Basic Tests");
    
    let tests = [
        ("Basic SI Units", test_basic_si_units),
        ("Derived Units", test_derived_units),
        ("Force Calculation", test_force_calculation),
        ("Energy Calculation", test_energy_calculation),
        ("Power Calculation", test_power_calculation),
        ("Same Dimension Arithmetic", test_same_dimension_arithmetic),
        ("Comparisons", test_comparisons),
        ("Unit Prefixes", test_unit_prefixes),
        ("Special Values", test_special_values),
        ("Complex Units", test_complex_units)
    ];
    
    var passed = 0;
    var failed = 0;
    
    each entry in tests  { let (name, test) = entry;
        print("  Testing: {name}... ");
        check test() {
            println("✅ PASS");
            passed = passed + 1;
        } else {
            println("❌ FAIL");
            failed = failed + 1;
        }
    }
    
    println("");
    println("📊 Results: {passed} passed, {failed} failed");
    
    check failed == 0 { 0 } else { 1 }
}
