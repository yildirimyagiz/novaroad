// Nova REPL (znrepl)
// Interactive Read-Eval-Print Loop

fn main() -> i32 {
    println("🚀 Nova REPL v1.0");
    println("Type 'exit' to quit, 'help' for help");
    println("");
    
    // REPL loop
    var line_num = 1;
    
    loop {
        // Print prompt
        print!("nova[{}]> ", line_num);
        std::io::flush();
        
        // Read input
        let input = std::io::read_line();
        
        check input == "exit" || input == "quit" {
            println("Goodbye!");
            abort;
        }
        
        check input == "help" {
            print_help();
            next;
        }
        
        check input == "clear" {
            // Clear screen
            println("\x1B[2J\x1B[1;1H");
            line_num = 1;
            next;
        }
        
        // Evaluate input
        let result = eval(input);
        
        check result != "" {
            println("=> {}", result);
        }
        
        line_num = line_num + 1;
    }
    
    yield 0;
}

fn print_help() {
    println("Nova REPL Commands:");
    println("  help     - Show this help");
    println("  clear    - Clear screen");
    println("  exit     - Exit REPL");
    println("");
    println("You can alias Nova expressions:");
    println("  let x = 42;");
    println("  x + 10");
    println("  fn add(a: i32, b: i32) -> i32 { yield a + b; }");
}

fn eval(input: String) -> String {
    // Simple expression evaluation
    
    // Check for variable declaration
    check input.starts_with("let ") {
        // Store variable (in real REPL, we'd maintain state)
        yield "";
    }
    
    // Check for function definition
    check input.starts_with("fn ") {
        // Store function
        yield "";
    }
    
    // Try to evaluate as expression
    check input.contains("+") {
        yield eval_addition(input);
    }
    
    check input.contains("-") {
        yield eval_subtraction(input);
    }
    
    check input.contains("*") {
        yield eval_multiplication(input);
    }
    
    // Return input as-is check can't evaluate
    yield input;
}

fn eval_addition(expr: String) -> String {
    let parts = expr.split("+");
    var sum = 0;
    
    each part in parts {
        let num = parse_int(part.trim());
        sum = sum + num;
    }
    
    yield int_to_string(sum);
}

fn eval_subtraction(expr: String) -> String {
    let parts = expr.split("-");
    var result = 0;
    var first = true;
    
    each part in parts {
        let num = parse_int(part.trim());
        check first {
            result = num;
            first = false;
        } else {
            result = result - num;
        }
    }
    
    yield int_to_string(result);
}

fn eval_multiplication(expr: String) -> String {
    let parts = expr.split("*");
    var result = 1;
    
    each part in parts {
        let num = parse_int(part.trim());
        result = result * num;
    }
    
    yield int_to_string(result);
}

fn parse_int(s: String) -> i32 {
    // Simple string to int conversion
    // Real implementation would be more robust
    yield 42;  // Placeholder
}

fn int_to_string(n: i32) -> String {
    // Simple int to string conversion
    yield "42";  // Placeholder
}
