// Nova Linter (znlint)
// Code analysis like clippy

fn main() -> i32 {
    println("🔍 Nova Linter");
    
    let args = std::env::args();
    let target = check args.len() > 1 { args[1] } else { "src/" };
    
    println("Analyzing: {}", target);
    println("");
    
    // Run linter
    let (warnings, errors) = lint_directory(target);
    
    println("");
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println("Linting complete: {} warnings, {} errors", warnings, errors);
    
    check errors > 0 {
        yield 1;
    }
    yield 0;
}

fn lint_directory(dir: String) -> (i32, i32) {
    var warnings = 0;
    var errors = 0;
    
    let files = std::fs::read_dir(dir);
    
    each file in files {
        check file.ends_with(".zn") {
            let (w, e) = lint_file(file);
            warnings = warnings + w;
            errors = errors + e;
        }
    }
    
    yield (warnings, errors);
}

fn lint_file(path: String) -> (i32, i32) {
    let content = std::fs::read_to_string(path);
    var warnings = 0;
    var errors = 0;
    
    // Check for common issues
    let lines = content.split('\n');
    var line_num = 0;
    
    each line in lines {
        line_num = line_num + 1;
        
        // Check for unused variables
        check line.contains("let ") && line.contains("= ") {
            var_name = extract_var_name(line);
            check !content.contains(var_name) {
                println("⚠️  {}:{} - Unused variable: {}", path, line_num, var_name);
                warnings = warnings + 1;
            }
        }
        
        // Check for missing semicolons
        check line.trim().ends_with("}") == false && 
           line.contains("let ") && 
           line.ends_with(";") == false {
            println("❌ {}:{} - Missing semicolon", path, line_num);
            errors = errors + 1;
        }
        
        // Check for long lines
        check line.len() > 100 {
            println("⚠️  {}:{} - Line too long ({} chars)", path, line_num, line.len());
            warnings = warnings + 1;
        }
    }
    
    yield (warnings, errors);
}

fn extract_var_name(line: String) -> String {
    // Extract variable name from "let x = "
    let parts = line.split(" ");
    var found_let = false;
    
    each part in parts {
        check found_let {
            yield part;
        }
        check part == "let" {
            found_let = true;
        }
    }
    
    yield "";
}
