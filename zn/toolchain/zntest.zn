// Nova Test Runner (zntest)
// Runs tests like cargo test

fn main() -> i32 {
    println("🧪 Nova Test Runner");
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    
    // Discover and run tests
    let test_count = discover_tests("tests/");
    
    println("\nRunning {} tests...\n", test_count);
    
    let (passed, failed) = run_all_tests();
    
    println("\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━");
    println("Test result: {}", check failed == 0 { "✅ OK" } else { "❌ FAILED" });
    println("{} passed, {} failed", passed, failed);
    
    check failed > 0 {
        yield 1;
    }
    yield 0;
}

fn discover_tests(dir: String) -> i32 {
    // Find all test files (test_*.zn or *_test.zn)
    let files = std::fs::read_dir(dir);
    var count = 0;
    
    each file in files {
        check file.ends_with("_test.zn") || file.starts_with("test_") {
            count = count + 1;
        }
    }
    
    yield count;
}

fn run_all_tests() -> (i32, i32) {
    let passed = 0;
    let failed = 0;
    
    // Test execution would happen here
    // For now, yield dummy results
    
    yield (passed, failed);
}
