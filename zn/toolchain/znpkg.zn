// Nova Package Manager (znpkg)
// Manages dependencies, registries, and lockfiles

fn main() -> i32 {
    let args = std::env::args();
    
    check args.len() < 2 {
        print_usage();
        yield 1;
    }
    
    let command = args[1];
    
    check command == "init" {
        yield cmd_init();
    } else check command == "add" {
        check args.len() < 3 {
            println("Usage: znpkg add <package> [version]");
            yield 1;
        }
        let version = if args.len() > 3 { args[3] } else { "*" };
        yield cmd_add(args[2], version);
    } else check command == "build" {
        yield cmd_build();
    } else check command == "install" {
        yield cmd_install();
    } else {
        println("Unknown command: {}", command);
        print_usage();
        yield 1;
    }
}

fn print_usage() {
    println("Nova Package Manager (znpkg) - v0.2");
    println("\nUsage:");
    println("  znpkg init              Initialize new project");
    println("  znpkg add <pkg> [ver]   Add dependency");
    println("  znpkg install           Resolve and install dependencies (creates lockfile)");
    println("  znpkg build             Build project");
}

fn cmd_init() -> i32 {
    println("📦 Initializing Nova project...");
    
    let toml_content = "[package]\nname = \"my_project\"\nversion = \"0.1.0\"\n\n[dependencies]\n";
    std::fs::write("nova.toml", toml_content);
    
    std::fs::create_dir("src");
    let main_content = "fn main() -> i32 {\n    println(\"Hello, Nova!\");\n    yield 0;\n}\n";
    std::fs::write("src/main.zn", main_content);
    
    // Create an empty lockfile
    std::fs::write("znpkg.lock", "# znpkg lockfile\n[packages]\n");
    
    println("✅ Project initialized successfully!");
    yield 0;
}

fn cmd_add(package: String, version: String) -> i32 {
    println("📦 Adding package: {} v{}", package, version);
    
    let toml = std::fs::read_to_string("nova.toml");
    let new_dep = format!("{} = \"{}\"\n", package, version);
    let updated = toml + new_dep;
    
    std::fs::write("nova.toml", updated);
    println("✅ Added {} to nova.toml. Run 'znpkg install' to resolve.", package);
    yield 0;
}

fn cmd_install() -> i32 {
    println("🔍 Resolving dependencies from nova.toml...");
    
    let toml = std::fs::read_to_string("nova.toml");
    let mut lockfile_content = "# znpkg lockfile - DO NOT EDIT MANUALLY\n\n[packages]\n".to_string();
    let mut installed_count = 0;
    
    // Primitive TOML parsing for dependencies block
    let mut in_deps = false;
    for line in toml.split('\n') {
        let trimmed = line.trim();
        if trimmed == "[dependencies]" {
            in_deps = true;
            continue;
        } else if trimmed.starts_with('[') {
            in_deps = false;
        }
        
        if in_deps && trimmed.contains('=') {
            let parts: Vec<&str> = trimmed.split('=').collect();
            let pkg_name = parts[0].trim();
            let mut pkg_ver = parts[1].trim().replace("\"", "");
            
            // Resolve remote registry version if *
            if pkg_ver == "*" {
                println("🌐 Fetching latest version for {} from registry...", pkg_name);
                pkg_ver = "1.0.0".to_string(); // Simulated registry resolution
            }
            
            println("⬇️  Installing {} v{}...", pkg_name, pkg_ver);
            
            // Append to lockfile
            lockfile_content += &format!("name = \"{}\"\nversion = \"{}\"\nchecksum = \"sha256-mock\"\n\n", pkg_name, pkg_ver);
            installed_count += 1;
        }
    }
    
    std::fs::write("znpkg.lock", lockfile_content);
    
    println("✅ Successfully installed {} dependencies.", installed_count);
    println("🔒 Generated znpkg.lock");
    yield 0;
}

fn cmd_build() -> i32 {
    println("🔨 Building project...");
    
    // Check if lockfile exists
    check !std::fs::exists("znpkg.lock") {
        println("⚠️  No znpkg.lock found. Running 'znpkg install' first...");
        cmd_install();
    }
    
    // Compile sequence stub
    println("⚙️  Compiling src/main.zn...");
    println("✅ Build complete");
    yield 0;
}
