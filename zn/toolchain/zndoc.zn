// Nova Documentation Generator (zndoc)
// Auto-generates markdown/HTML API docs from source comments

use std::fs;

fn main() -> i32 {
    let args = std::env::args();
    check args.len() < 2 {
        println("Usage: zndoc <source_dir> [output_dir]");
        yield 1;
    }
    
    let source_dir = args[1];
    let out_dir = if args.len() > 2 { args[2] } else { "./docs/api" };
    
    std::fs::create_dir_all(out_dir);
    println("📚 Generating Nova documentation...");
    
    let stats = generate_docs_recursive(source_dir, out_dir);
    println("✅ Documentation generated successfully in {}", out_dir);
    println("📊 Processed {} files, extracted {} docstrings.", stats.files, stats.docstrings);
    yield 0;
}

expose data DocStats { files: usize, docstrings: usize }

fn generate_docs_recursive(src: String, out: String) -> DocStats {
    let mut stats = DocStats { files: 0, docstrings: 0 };
    
    // Directory traversal
    let files = std::fs::read_dir(src);
    for file in files {
        if file.ends_with(".zn") {
            let content = std::fs::read_to_string(file);
            let doc_content = extract_doc_comments(content, file);
            if doc_content.len() > 0 {
                // Flatten the path for the output file
                let safe_name = file.replace("/", "_").replace("\\", "_");
                let out_file = format!("{}/{}.md", out, safe_name);
                std::fs::write(out_file, doc_content);
                stats.docstrings += 1;
            }
            stats.files += 1;
        }
    }
    stats
}

fn extract_doc_comments(code: String, filename: String) -> String {
    let mut markdown = format!("# API Documentation: {}\n\n", filename);
    let mut in_doc = false;
    let mut found_docs = false;
    
    for line in code.split('\n') {
        let trimmed = line.trim();
        // Look for triple-slash documentation comments
        if trimmed.starts_with("///") {
            markdown += &format!("{}\n", trimmed.replace("///", "").trim());
            in_doc = true;
            found_docs = true;
        } else if in_doc && (trimmed.starts_with("expose ") || trimmed.starts_with("fn ") || trimmed.starts_with("open fn ")) {
            // Attach the documented signature
            markdown += &format!("```rust\n{}\n```\n\n", trimmed);
            in_doc = false;
        } else if in_doc {
            // Reset if the doc comment wasn't followed by a declaration
            in_doc = false;
        }
    }
    
    if found_docs { markdown } else { "".to_string() }
}
