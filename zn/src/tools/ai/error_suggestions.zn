// ============================================================================
// DATA STRUCTURES
// ============================================================================

expose data ErrorSuggestionResult {
    error: Diagnostic,
    analysis: ErrorAnalysis,
    context: ErrorContext,
    suggestions: Vec<ErrorSuggestion>,
    confidence: f64,
    processing_time: u64
}

expose data ErrorAnalysis {
    error_type: String,
    error_category: ErrorCategory,
    severity: ErrorSeverity,
    location: ErrorLocation,
    message: String,
    pattern: ErrorPattern,
    context_analysis: ContextAnalysis,
    root_cause: String,
    related_errors: Vec<Diagnostic>
}

expose data ErrorContext {
    code_context: CodeContextInfo,
    project_context: ProjectContextInfo,
    user_context: UserContextInfo,
    error_location: ErrorLocation,
    surrounding_code: String
}

expose data ErrorSuggestion {
    suggestion_type: SuggestionType,
    title: String,
    description: String,
    code_snippet: Option<String>,
    confidence: f64,
    effort: EffortLevel,
    auto_applicable: bool
}

expose data ErrorPattern {
    error_type: String,
    category: ErrorCategory,
    regex_pattern: String,
    common_causes: Vec<String>
}

expose cases ErrorCategory {
    Type,
    Runtime,
    Syntax,
    Import,
    Unknown
}

expose cases ErrorSeverity {
    Info,
    Low,
    Medium,
    High,
    Critical
}

expose cases SuggestionType {
    Fix,
    Example,
    Explanation,
    Warning
}

expose cases EffortLevel {
    Low,
    Medium,
    High
}

expose data ContextAnalysis {
    function_name: String,
    module_name: String,
    variable_types: HashMap<String, String>,
    imports: Vec<String>,
    scope_depth: u32
}

expose data CodeContextInfo {
    surrounding_code: String,
    function_scope: String,
    variable_scope: HashMap<String, String>,
    type_scope: HashMap<String, String>
}

expose data ProjectContextInfo {
    project_name: String,
    language: String,
    build_system: String,
    dependencies: Vec<String>
}

expose data UserContextInfo {
    skill_level: SkillLevel,
    preferred_fix_style: FixStyle,
    learning_mode: bool
}

expose cases SkillLevel {
    Beginner,
    Intermediate,
    Advanced
}

expose cases FixStyle {
    Explicit,
    Implicit,
    Minimal
}

expose data ErrorLocation {
    file: String,
    line: u32,
    column: u32
}

