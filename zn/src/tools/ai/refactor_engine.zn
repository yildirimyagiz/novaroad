use std::collections::{HashMap, Vec};
use compiler::ast::{TypedAST, Node, Expression};
use compiler::transformer::ASTTransformer;
use ai::inference::AIInferenceEngine;

/// AI Refactor Engine for intelligent code transformation
expose data AIRefactorEngine {
    refactor_analyzer: RefactorAnalyzer,
    transformation_engine: TransformationEngine,
    quality_assessor: QualityAssessor,
    safety_checker: SafetyChecker
}

expose data RefactorAnalyzer {
    code_smell_detector: CodeSmellDetector,
    complexity_analyzer: ComplexityAnalyzer,
    dependency_analyzer: DependencyAnalyzer
}

expose data TransformationEngine {
    refactoring_strategies: Vec<RefactoringStrategy>,
    ast_transformer: ASTTransformer,
    pattern_matcher: RefactorPatternMatcher
}

expose data QualityAssessor {
    metrics_calculator: MetricsCalculator,
    improvement_tracker: ImprovementTracker,
    best_practices_checker: BestPracticesChecker
}

expose data SafetyChecker {
    behavior_preserver: BehaviorPreserver,
    test_runner: TestRunner,
    rollback_manager: RollbackManager
}

impl AIRefactorEngine {
    open fn new() -> AIRefactorEngine {
        AIRefactorEngine {
            refactor_analyzer: RefactorAnalyzer::new(),
            transformation_engine: TransformationEngine::new(),
            quality_assessor: QualityAssessor::new(),
            safety_checker: SafetyChecker::new()
        }
    }
    
    /// Analyze code and suggest refactoring improvements
    open fn analyze_and_refactor(&mut self, ast: &mut TypedAST, config: &RefactorConfig) -> Result<RefactorResult> {
        println("🔧 AI Refactor Engine: Analyzing code for improvements...");
        
        // 1. Analyze current code quality
        let initial_analysis = self.refactor_analyzer.analyze_code(ast)?;
        
        // 2. Identify refactoring opportunities
        let opportunities = self.identify_refactoring_opportunities(&initial_analysis, config)?;
        
        // 3. Generate refactoring plan
        let refactor_plan = self.generate_refactor_plan(&opportunities, config)?;
        
        // 4. Apply safe transformations
        let applied_transformations = self.apply_transformations(ast, &refactor_plan)?;
        
        // 5. Assess quality improvements
        let final_analysis = self.quality_assessor.assess_quality(ast)?;
        let improvements = self.calculate_improvements(&initial_analysis, &final_analysis);
        
        // 6. Verify behavior preservation
        let safety_report = self.safety_checker.verify_behavior(ast, &applied_transformations)?;
        
        let result = RefactorResult {
            initial_analysis,
            final_analysis,
            opportunities,
            applied_transformations,
            improvements,
            safety_report,
            success: safety_report.behavior_preserved && improvements.overall_score > 0.0
        };
        
        println("✅ Refactoring complete - {} transformations applied", applied_transformations.len());
        
        Ok(result)
    }
    
    fn identify_refactoring_opportunities(&mut self, analysis: &CodeAnalysis, config: &RefactorConfig) -> Result<Vec<RefactoringOpportunity>> {
        let mut opportunities = Vec::new();
        
        // 1. Code smell based opportunities
        opportunities.extend(self.identify_code_smell_opportunities(&analysis.code_smells)?);
        
        // 2. Complexity reduction opportunities
        opportunities.extend(self.identify_complexity_opportunities(&analysis.complexity_metrics)?);
        
        // 3. Dependency optimization opportunities
        opportunities.extend(self.identify_dependency_opportunities(&analysis.dependencies)?);
        
        // Sort by impact and effort
        opportunities.sort_by(|a, b| {
            let score_a = a.impact_score / a.effort_score;
            let score_b = b.impact_score / b.effort_score;
            score_b.partial_cmp(&score_a).unwrap()
        });
        
        Ok(opportunities)
    }
    
    fn identify_code_smell_opportunities(&self, code_smells: &[CodeSmell]) -> Result<Vec<RefactoringOpportunity>> {
        let mut opportunities = Vec::new();
        
        each smell in code_smells {
            match smell.smell_type {
                CodeSmellType::LongMethod => {
                    opportunities.push(RefactoringOpportunity {
                        opportunity_type: RefactorType::ExtractMethod,
                        description: format!("Extract method from {} ({} lines)", smell.location, smell.severity),
                        location: smell.location.clone(),
                        impact_score: 0.8,
                        effort_score: 0.4,
                        confidence: 0.9,
                        auto_applicable: true
                    });
                },
                CodeSmellType::DuplicateCode => {
                    opportunities.push(RefactoringOpportunity {
                        opportunity_type: RefactorType::ExtractFunction,
                        description: format!("Extract duplicate code from {}", smell.location),
                        location: smell.location.clone(),
                        impact_score: 0.7,
                        effort_score: 0.3,
                        confidence: 0.85,
                        auto_applicable: true
                    });
                },
                CodeSmellType::LargeClass => {
                    opportunities.push(RefactoringOpportunity {
                        opportunity_type: RefactorType::ExtractClass,
                        description: format!("Extract class from {}", smell.location),
                        location: smell.location.clone(),
                        impact_score: 0.9,
                        effort_score: 0.6,
                        confidence: 0.8,
                        auto_applicable: false
                    });
                }
            }
        }
        
        Ok(opportunities)
    }
    
    fn identify_complexity_opportunities(&self, metrics: &ComplexityMetrics) -> Result<Vec<RefactoringOpportunity>> {
        let mut opportunities = Vec::new();
        
        if metrics.cyclomatic_complexity > 10 {
            opportunities.push(RefactoringOpportunity {
                opportunity_type: RefactorType::SimplifyConditionals,
                description: format!("Reduce cyclomatic complexity from {}", metrics.cyclomatic_complexity),
                location: CodeLocation { file: "unknown".to_string(), line: 0, column: 0 },
                impact_score: 0.7,
                effort_score: 0.5,
                confidence: 0.8,
                auto_applicable: true
            });
        }
        
        if metrics.cognitive_complexity > 15 {
            opportunities.push(RefactoringOpportunity {
                opportunity_type: RefactorType::DecomposeMethod,
                description: format!("Reduce cognitive complexity from {}", metrics.cognitive_complexity),
                location: CodeLocation { file: "unknown".to_string(), line: 0, column: 0 },
                impact_score: 0.8,
                effort_score: 0.6,
                confidence: 0.75,
                auto_applicable: true
            });
        }
        
        Ok(opportunities)
    }
    
    fn identify_dependency_opportunities(&self, dependencies: &[Dependency]) -> Result<Vec<RefactoringOpportunity>> {
        let mut opportunities = Vec::new();
        
        each dep in dependencies {
            if dep.coupling_score > 0.7 {
                opportunities.push(RefactoringOpportunity {
                    opportunity_type: RefactorType::ReduceCoupling,
                    description: format!("Reduce coupling with {}", dep.target),
                    location: dep.location.clone(),
                    impact_score: 0.6,
                    effort_score: 0.5,
                    confidence: 0.7,
                    auto_applicable: false
                });
            }
        }
        
        Ok(opportunities)
    }
    
    fn generate_refactor_plan(&mut self, opportunities: &[RefactoringOpportunity], config: &RefactorConfig) -> Result<RefactorPlan> {
        let mut selected_opportunities = Vec::new();
        let mut total_effort = 0.0;
        
        each opportunity in opportunities {
            if total_effort + opportunity.effort_score <= config.max_effort &&
               opportunity.confidence >= config.min_confidence {
                selected_opportunities.push(opportunity.clone());
                total_effort += opportunity.effort_score;
            }
        }
        
        Ok(RefactorPlan {
            opportunities: selected_opportunities,
            estimated_effort: total_effort,
            estimated_impact: self.calculate_plan_impact(&selected_opportunities),
            safety_measures: self.determine_safety_measures(&selected_opportunities)?
        })
    }
    
    fn calculate_plan_impact(&self, opportunities: &[RefactoringOpportunity]) -> f64 {
        opportunities.iter().map(|o| o.impact_score).sum()
    }
    
    fn determine_safety_measures(&self, opportunities: &[RefactoringOpportunity]) -> Result<Vec<SafetyMeasure>> {
        let mut measures = Vec::new();
        
        each opportunity in opportunities {
            if opportunity.opportunity_type == RefactorType::ExtractMethod {
                measures.push(SafetyMeasure {
                    measure_type: SafetyMeasureType::CreateBackup,
                    description: "Create backup before method extraction".to_string(),
                    automated: true
                });
            }
            
            measures.push(SafetyMeasure {
                measure_type: SafetyMeasureType::RunTests,
                description: "Run tests after transformation".to_string(),
                automated: true
            });
        }
        
        Ok(measures)
    }
    
    fn apply_transformations(&mut self, ast: &mut TypedAST, plan: &RefactorPlan) -> Result<Vec<AppliedTransformation>> {
        let mut applied = Vec::new();
        
        each opportunity in &plan.opportunities {
            match self.transformation_engine.apply_transformation(ast, opportunity) {
                Ok(transformation) => {
                    applied.push(transformation);
                },
                Err(e) => {
                    println("⚠️  Failed to apply transformation: {:?}", e);
                }
            }
        }
        
        Ok(applied)
    }
    
    fn calculate_improvements(&self, initial: &CodeAnalysis, final_analysis: &CodeAnalysis) -> QualityImprovements {
        QualityImprovements {
            complexity_reduction: (initial.complexity_metrics.cyclomatic_complexity as f64 - 
                                 final_analysis.complexity_metrics.cyclomatic_complexity as f64).max(0.0),
            code_smells_reduced: (initial.code_smells.len() as f64 - 
                                final_analysis.code_smells.len() as f64).max(0.0),
            maintainability_improved: final_analysis.maintainability_index - initial.maintainability_index,
            overall_score: self.calculate_overall_improvement(initial, final_analysis)
        }
    }
    
    fn calculate_overall_improvement(&self, initial: &CodeAnalysis, final_analysis: &CodeAnalysis) -> f64 {
        let complexity_weight = 0.4;
        let smells_weight = 0.3;
        let maintainability_weight = 0.3;
        
        let complexity_improvement = (initial.complexity_metrics.cyclomatic_complexity as f64 - 
                                    final_analysis.complexity_metrics.cyclomatic_complexity as f64).max(0.0);
        let smells_improvement = (initial.code_smells.len() as f64 - 
                                final_analysis.code_smells.len() as f64).max(0.0);
        let maintainability_improvement = final_analysis.maintainability_index - initial.maintainability_index;
        
        (complexity_improvement * complexity_weight + 
         smells_improvement * smells_weight + 
         maintainability_improvement * maintainability_weight) / 10.0 // Normalize
    }
}

// ============================================================================
// REFACTOR ANALYZER
// ============================================================================

impl RefactorAnalyzer {
    fn new() -> RefactorAnalyzer {
        RefactorAnalyzer {
            code_smell_detector: CodeSmellDetector::new(),
            complexity_analyzer: ComplexityAnalyzer::new(),
            dependency_analyzer: DependencyAnalyzer::new()
        }
    }
    
    fn analyze_code(&mut self, ast: &TypedAST) -> Result<CodeAnalysis> {
        println("🔍 Analyzing code quality...");
        
        let code_smells = self.code_smell_detector.detect_code_smells(ast)?;
        let complexity_metrics = self.complexity_analyzer.analyze_complexity(ast)?;
        let dependencies = self.dependency_analyzer.analyze_dependencies(ast)?;
        let maintainability_index = self.calculate_maintainability_index(&complexity_metrics, &code_smells);
        
        Ok(CodeAnalysis {
            code_smells,
            complexity_metrics,
            dependencies,
            maintainability_index,
            analysis_timestamp: get_current_timestamp()
        })
    }
    
    fn calculate_maintainability_index(&self, metrics: &ComplexityMetrics, smells: &[CodeSmell]) -> f64 {
        let base_score = 100.0;
        let complexity_penalty = metrics.cyclomatic_complexity as f64 * 0.5;
        let smells_penalty = smells.len() as f64 * 2.0;
        
        (base_score - complexity_penalty - smells_penalty).max(0.0)
    }
}

// ============================================================================
// TRANSFORMATION ENGINE
// ============================================================================

impl TransformationEngine {
    fn new() -> TransformationEngine {
        TransformationEngine {
            refactoring_strategies: vec![
                RefactoringStrategy::ExtractMethod,
                RefactoringStrategy::ExtractFunction,
                RefactoringStrategy::SimplifyConditionals,
                RefactoringStrategy::DecomposeMethod,
                RefactoringStrategy::ReduceCoupling,
                RefactoringStrategy::ExtractClass
            ],
            ast_transformer: ASTTransformer::new(),
            pattern_matcher: RefactorPatternMatcher::new()
        }
    }
    
    fn apply_transformation(&mut self, ast: &mut TypedAST, opportunity: &RefactoringOpportunity) -> Result<AppliedTransformation> {
        println("🔧 Applying transformation: {}", opportunity.opportunity_type);
        
        let transformation = match opportunity.opportunity_type {
            RefactorType::ExtractMethod => self.extract_method(ast, &opportunity.location)?,
            RefactorType::ExtractFunction => self.extract_function(ast, &opportunity.location)?,
            RefactorType::SimplifyConditionals => self.simplify_conditionals(ast, &opportunity.location)?,
            RefactorType::DecomposeMethod => self.decompose_method(ast, &opportunity.location)?,
            RefactorType::ReduceCoupling => self.reduce_coupling(ast, &opportunity.location)?,
            RefactorType::ExtractClass => self.extract_class(ast, &opportunity.location)?
        };
        
        Ok(AppliedTransformation {
            transformation_type: opportunity.opportunity_type.clone(),
            description: opportunity.description.clone(),
            applied_at: get_current_timestamp(),
            success: true,
            rollback_info: self.generate_rollback_info(&transformation)?
        })
    }
    
    fn extract_method(&mut self, ast: &mut TypedAST, location: &CodeLocation) -> Result<Transformation> {
        // Simplified method extraction
        Ok(Transformation {
            transformation_type: RefactorType::ExtractMethod,
            description: "Extract method".to_string(),
            changes: vec![
                ASTChange {
                    change_type: ChangeType::Insert,
                    location: location.clone(),
                    content: "fn extracted_method() {\n    // Extracted logic\n}".to_string()
                }
            ]
        })
    }
    
    fn extract_function(&mut self, ast: &mut TypedAST, location: &CodeLocation) -> Result<Transformation> {
        Ok(Transformation {
            transformation_type: RefactorType::ExtractFunction,
            description: "Extract function".to_string(),
            changes: vec![
                ASTChange {
                    change_type: ChangeType::Insert,
                    location: location.clone(),
                    content: "fn extracted_function() {\n    // Extracted logic\n}".to_string()
                }
            ]
        })
    }
    
    fn simplify_conditionals(&mut self, ast: &mut TypedAST, location: &CodeLocation) -> Result<Transformation> {
        Ok(Transformation {
            transformation_type: RefactorType::SimplifyConditionals,
            description: "Simplify conditional logic".to_string(),
            changes: vec![
                ASTChange {
                    change_type: ChangeType::Replace,
                    location: location.clone(),
                    content: "if condition {\n    // Simplified logic\n}".to_string()
                }
            ]
        })
    }
    
    fn decompose_method(&mut self, ast: &mut TypedAST, location: &CodeLocation) -> Result<Transformation> {
        Ok(Transformation {
            transformation_type: RefactorType::DecomposeMethod,
            description: "Decompose method into smaller functions".to_string(),
            changes: vec![
                ASTChange {
                    change_type: ChangeType::Insert,
                    location: location.clone(),
                    content: "fn part_one() { /* Part 1 */ }\nfn part_two() { /* Part 2 */ }".to_string()
                }
            ]
        })
    }
    
    fn reduce_coupling(&mut self, ast: &mut TypedAST, location: &CodeLocation) -> Result<Transformation> {
        Ok(Transformation {
            transformation_type: RefactorType::ReduceCoupling,
            description: "Reduce coupling between components".to_string(),
            changes: vec![
                ASTChange {
                    change_type: ChangeType::Insert,
                    location: location.clone(),
                    content: "interface Adapter {\n    fn adapt(&self);\n}".to_string()
                }
            ]
        })
    }
    
    fn extract_class(&mut self, ast: &mut TypedAST, location: &CodeLocation) -> Result<Transformation> {
        Ok(Transformation {
            transformation_type: RefactorType::ExtractClass,
            description: "Extract class from large class".to_string(),
            changes: vec![
                ASTChange {
                    change_type: ChangeType::Insert,
                    location: location.clone(),
                    content: "class ExtractedClass {\n    // Extracted functionality\n}".to_string()
                }
            ]
        })
    }
    
    fn generate_rollback_info(&self, transformation: &Transformation) -> Result<RollbackInfo> {
        Ok(RollbackInfo {
            original_code: String::new(), // Would store original code
            rollback_steps: transformation.changes.iter()
                .map(|change| RollbackStep {
                    step_type: match change.change_type {
                        ChangeType::Insert => RollbackStepType::Remove,
                        ChangeType::Remove => RollbackStepType::Insert,
                        ChangeType::Replace => RollbackStepType::Replace
                    },
                    location: change.location.clone(),
                    content: change.content.clone()
                })
                .collect()
        })
    }
}

// ============================================================================
// QUALITY ASSESSOR
// ============================================================================

impl QualityAssessor {
    fn new() -> QualityAssessor {
        QualityAssessor {
            metrics_calculator: MetricsCalculator::new(),
            improvement_tracker: ImprovementTracker::new(),
            best_practices_checker: BestPracticesChecker::new()
        }
    }
    
    fn assess_quality(&mut self, ast: &TypedAST) -> Result<CodeAnalysis> {
        let complexity_metrics = self.metrics_calculator.calculate_metrics(ast)?;
        let code_smells = self.detect_code_smells_simple(ast)?;
        let dependencies = self.analyze_dependencies_simple(ast)?;
        let maintainability_index = self.calculate_maintainability_index(&complexity_metrics, &code_smells);
        
        Ok(CodeAnalysis {
            code_smells,
            complexity_metrics,
            dependencies,
            maintainability_index,
            analysis_timestamp: get_current_timestamp()
        })
    }
    
    fn detect_code_smells_simple(&self, ast: &TypedAST) -> Result<Vec<CodeSmell>> {
        let mut smells = Vec::new();
        
        // Simplified code smell detection
        each node in ast.nodes() {
            if node.source_code.lines().count() > 20 {
                smells.push(CodeSmell {
                    smell_type: CodeSmellType::LongMethod,
                    location: CodeLocation {
                        file: "unknown".to_string(),
                        line: node.location.line,
                        column: node.location.column
                    },
                    severity: Severity::Medium,
                    description: format!("Method {} is too long", node.name)
                });
            }
        }
        
        Ok(smells)
    }
    
    fn analyze_dependencies_simple(&self, ast: &TypedAST) -> Result<Vec<Dependency>> {
        Ok(vec![
            Dependency {
                source: "module_a".to_string(),
                target: "module_b".to_string(),
                coupling_score: 0.5,
                dependency_type: DependencyType::Import,
                location: CodeLocation { file: "unknown".to_string(), line: 0, column: 0 }
            }
        ])
    }
    
    fn calculate_maintainability_index(&self, metrics: &ComplexityMetrics, smells: &[CodeSmell]) -> f64 {
        let base_score = 100.0;
        let complexity_penalty = metrics.cyclomatic_complexity as f64 * 0.5;
        let smells_penalty = smells.len() as f64 * 2.0;
        
        (base_score - complexity_penalty - smells_penalty).max(0.0)
    }
}

// ============================================================================
// SAFETY CHECKER
// ============================================================================

impl SafetyChecker {
    fn new() -> SafetyChecker {
        SafetyChecker {
            behavior_preserver: BehaviorPreserver::new(),
            test_runner: TestRunner::new(),
            rollback_manager: RollbackManager::new()
        }
    }
    
    fn verify_behavior(&mut self, ast: &TypedAST, transformations: &[AppliedTransformation]) -> Result<SafetyReport> {
        println("🔒 Verifying behavior preservation...");
        
        // 1. Check behavior preservation
        let behavior_preserved = self.behavior_preserver.check_behavior(ast, transformations)?;
        
        // 2. Run tests
        let test_results = self.test_runner.run_tests(ast)?;
        
        // 3. Prepare rollback if needed
        let rollback_available = self.rollback_manager.prepare_rollback(transformations)?;
        
        Ok(SafetyReport {
            behavior_preserved,
            test_results,
            rollback_available,
            safety_score: self.calculate_safety_score(&behavior_preserved, &test_results),
            recommendations: self.generate_safety_recommendations(&behavior_preserved, &test_results)?
        })
    }
    
    fn calculate_safety_score(&self, behavior_preserved: &bool, test_results: &TestResults) -> f64 {
        let mut score = 1.0;
        
        if !*behavior_preserved {
            score -= 0.5;
        }
        
        if test_results.failed_tests > 0 {
            score -= 0.3;
        }
        
        score.max(0.0)
    }
    
    fn generate_safety_recommendations(&self, behavior_preserved: &bool, test_results: &TestResults) -> Result<Vec<String>> {
        let mut recommendations = Vec::new();
        
        if !*behavior_preserved {
            recommendations.push("Behavior not preserved - consider rollback".to_string());
        }
        
        if test_results.failed_tests > 0 {
            recommendations.push(format!("{} tests failed - review changes", test_results.failed_tests));
        }
        
        if recommendations.is_empty() {
            recommendations.push("All safety checks passed".to_string());
        }
        
        Ok(recommendations)
    }
}

// ============================================================================
// IMPLEMENTATIONS
// ============================================================================

impl CodeSmellDetector {
    fn new() -> CodeSmellDetector {
        CodeSmellDetector
    }
    
    fn detect_code_smells(&mut self, ast: &TypedAST) -> Result<Vec<CodeSmell>> {
        let mut smells = Vec::new();
        
        each node in ast.nodes() {
            // Check for long methods
            if node.source_code.lines().count() > 20 {
                smells.push(CodeSmell {
                    smell_type: CodeSmellType::LongMethod,
                    location: CodeLocation {
                        file: "unknown".to_string(),
                        line: node.location.line,
                        column: node.location.column
                    },
                    severity: Severity::Medium,
                    description: format!("Method {} is too long", node.name)
                });
            }
            
            // Check for duplicate code (simplified)
            if node.source_code.contains("duplicate_pattern") {
                smells.push(CodeSmell {
                    smell_type: CodeSmellType::DuplicateCode,
                    location: CodeLocation {
                        file: "unknown".to_string(),
                        line: node.location.line,
                        column: node.location.column
                    },
                    severity: Severity::Low,
                    description: "Duplicate code detected".to_string()
                });
            }
        }
        
        Ok(smells)
    }
}

impl ComplexityAnalyzer {
    fn new() -> ComplexityAnalyzer {
        ComplexityAnalyzer
    }
    
    fn analyze_complexity(&mut self, ast: &TypedAST) -> Result<ComplexityMetrics> {
        let mut total_complexity = 0;
        let mut cognitive_complexity = 0;
        
        each node in ast.nodes() {
            if node.is_function() {
                total_complexity += self.calculate_cyclomatic_complexity(node);
                cognitive_complexity += self.calculate_cognitive_complexity(node);
            }
        }
        
        Ok(ComplexityMetrics {
            cyclomatic_complexity: total_complexity,
            cognitive_complexity,
            halstead_metrics: self.calculate_halstead_metrics(ast)?
        })
    }
    
    fn calculate_cyclomatic_complexity(&self, node: &Node) -> u32 {
        // Simplified cyclomatic complexity calculation
        let decision_points = node.source_code.matches("if").count() + 
                           node.source_code.matches("while").count() + 
                           node.source_code.matches("for").count();
        (decision_points + 1) as u32
    }
    
    fn calculate_cognitive_complexity(&self, node: &Node) -> u32 {
        // Simplified cognitive complexity calculation
        let nesting_level = node.source_code.matches("{").count() - 
                          node.source_code.matches("}").count();
        (nesting_level + 1) as u32
    }
    
    fn calculate_halstead_metrics(&self, ast: &TypedAST) -> Result<HalsteadMetrics> {
        Ok(HalsteadMetrics {
            vocabulary: 100,
            length: 500,
            difficulty: 10.0,
            effort: 1000.0
        })
    }
}

impl DependencyAnalyzer {
    fn new() -> DependencyAnalyzer {
        DependencyAnalyzer
    }
    
    fn analyze_dependencies(&mut self, ast: &TypedAST) -> Result<Vec<Dependency>> {
        let mut dependencies = Vec::new();
        
        // Simplified dependency analysis
        dependencies.push(Dependency {
            source: "main_module".to_string(),
            target: "utils_module".to_string(),
            coupling_score: 0.6,
            dependency_type: DependencyType::Import,
            location: CodeLocation { file: "unknown".to_string(), line: 0, column: 0 }
        });
        
        Ok(dependencies)
    }
}

impl MetricsCalculator {
    fn new() -> MetricsCalculator {
