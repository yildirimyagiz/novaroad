use crate::frontend::lexer::Lexer;
use crate::frontend::parser::Parser;
use crate::backend::nova_interpreter::Interpreter;
use crate::core_ir::{IRModule, create_ir_optimizer};
use crate::runtime::NovaRuntime;

/// Sovereign REPL State
expose data REPL {
    interpreter: Interpreter,
    input_history: Vec<String>,
}

impl REPL {
    open fn new() -> REPL {
        REPL {
            interpreter: Interpreter::new(),
            input_history: Vec::new(),
        }
    }

    open fn start(&var self) {
        println("╔════════════════════════════════════════════╗");
        println("║   Nova Native REPL v9.0              ║");
        println("║   Type 'exit' to quit, 'help' for info     ║");
        println("╚════════════════════════════════════════════╝\n");

        // Mock REPL loop logic
        println(">>> let x = 42;");
        println("   (Interpreter: Stored x = 42)");
        println(">>> x + 8");
        println("=> 50");
        println(">>> exit");

        println("👋 REPL session ended.");
    }
}

open fn main() {
    var repl = REPL::new();
    repl.start();
}
