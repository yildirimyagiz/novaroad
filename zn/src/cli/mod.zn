// Main CLI Orchestrator
expose main

// AI Assistant Sub-CLI
expose ai_cli

// Interactive REPL Sub-CLI
expose repl

// ── Re-exports for external usage ──────────────────────────────────────────

expose expose main::CLI as CLI;
expose expose ai_cli::AIAssistant as AIAdvisor;
expose expose repl::REPL as NativeREPL;
