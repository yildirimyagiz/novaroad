# CUDA Development Environment for GPU Army Matmul
FROM nvidia/cuda:12.2-devel-ubuntu22.04

# Install essential tools
RUN apt-get update && apt-get install -y \
    build-essential \
    git \
    vim \
    htop \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Set working directory
WORKDIR /workspace

# Copy source files
COPY ultra_advanced_matmul_cuda.cu .
COPY build_cuda.sh .

# Make scripts executable
RUN chmod +x build_cuda.sh

# Default command
CMD ["/bin/bash"]
