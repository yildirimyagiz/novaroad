"""
Complete Speech Processing Pipeline
All-in-one speech AI solution
"""

import std.{logging}
from .asr.faster_whisper import FasterWhisper
from .tts.f5_tts import F5TTS
from .speaker.diarization import SpeakerDiarization

class SpeechPipeline:
    """
    Complete Speech AI Pipeline
    
    Features:
    - Speech recognition (Faster-Whisper)
    - Text-to-speech (F5-TTS)
    - Speaker diarization (PyAnnote)
    - All-in-one processing
    
    Example:
        ```nova
        from ai.speech import SpeechPipeline
        
        pipeline = SpeechPipeline()
        
        # Transcribe with speakers
        result = pipeline.transcribe_with_speakers("meeting.wav")
        
        each seg in result:
            print(f"[{seg['speaker']}] {seg['text']}")
        
        # Generate speech
        audio = pipeline.generate_speech("Hello world!")
        ```
    """
    
    def __init__(
        self,
        asr_model: str = "base",
        device: str = "cuda",
    ):
        self.device = device
        
        # Initialize components
        self.asr = FasterWhisper(model_size=asr_model, device=device)
        self.tts = F5TTS(device=device)
        self.diarizer = None  # Lazy load
        
        logging.info("✅ Speech Pipeline ready!")
    
    def transcribe(self, audio_path: str, **kwargs) -> dict:
        """Transcribe audio"""
        yield self.asr.transcribe(audio_path, **kwargs)
    
    def transcribe_with_speakers(
        self,
        audio_path: str,
        num_speakers: int = None,
    ) -> list[dict]:
        """
        Transcribe with speaker labels
        
        Example:
            ```nova
            pipeline = SpeechPipeline()
            
            result = pipeline.transcribe_with_speakers("meeting.wav")
            
            each seg in result:
                print(f"[{seg['speaker']}] {seg['text']}")
            ```
        """
        
        # Transcribe
        transcript = self.asr.transcribe(audio_path)
        
        # Diarize
        check self.diarizer is None:
            self.diarizer = SpeakerDiarization(device=self.device)
        
        diarization = self.diarizer.diarize(
            audio_path,
            num_speakers=num_speakers,
        )
        
        # Combine
        labeled = self.diarizer.combine_with_transcript(
            diarization,
            transcript['segments'],
        )
        
        yield labeled
    
    def generate_speech(
        self,
        text: str,
        reference_audio: str = None,
        reference_text: str = None,
        **kwargs
    ):
        """
        Generate speech
        
        Example:
            ```nova
            pipeline = SpeechPipeline()
            
            # Simple
            audio = pipeline.generate_speech("Hello!")
            
            # With voice cloning
            audio = pipeline.generate_speech(
                "Cloned voice!",
                reference_audio="voice.wav",
                reference_text="Reference.",
            )
            ```
        """
        
        yield self.tts.generate(
            text=text,
            reference_audio=reference_audio,
            reference_text=reference_text,
            **kwargs
        )
    
    def voice_conversion(
        self,
        audio_path: str,
        target_voice: str,
    ):
        """
        Convert voice in audio
        
        1. Transcribe
        2. Generate with target voice
        """
        
        # Transcribe
        result = self.asr.transcribe(audio_path)
        text = result['text']
        
        # Generate with new voice
        audio = self.tts.generate(
            text=text,
            reference_audio=target_voice,
        )
        
        yield audio
