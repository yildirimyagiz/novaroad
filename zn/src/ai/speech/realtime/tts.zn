"""
Real-time Text-to-Speech  
Based on: https://github.com/KoljaB/RealtimeTTS
"""

import std.{logging}

class RealtimeTTS:
    """Real-time text-to-speech"""
    
    def __init__(self, device: str = "cuda"):
        self.device = device
        logging.info("✅ RealtimeTTS ready")
    
    def speak(self, text: str):
        """Speak text with streaming"""
        logging.info(f"🗣️  Speaking: {text}")
