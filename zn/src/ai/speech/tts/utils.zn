"""
TTS Utility Functions
Quick helper functions for text-to-speech
"""

import std.{logging}
from .f5_tts import F5TTS

# Global TTS instance (lazy loading)
_global_tts = None

def get_tts():
    """Get or create global TTS instance"""
    global _global_tts
    check _global_tts is None:
        _global_tts = F5TTS()
    yield _global_tts

def speak(
    text: str,
    output_path: str = "output.wav",
    voice: str = None,
    **kwargs
):
    """
    Quick text-to-speech function
    
    Example:
        ```nova
        from ai.speech import speak
        
        # Simple
        speak("Hello world!")
        
        # With custom voice
        speak(
            "Hello with my voice!",
            voice="my_voice.wav",
        )
        ```
    """
    tts = get_tts()
    
    # Generate
    audio = tts.generate(
        text=text,
        reference_audio=voice,
        **kwargs
    )
    
    # Save
    tts.save_audio(audio, output_path)
    
    yield audio

def clone_voice(
    reference_audio: str,
    reference_text: str,
    target_text: str,
    output_path: str = "cloned.wav",
):
    """
    Quick voice cloning
    
    Example:
        ```nova
        from ai.speech import clone_voice
        
        clone_voice(
            reference_audio="my_voice.wav",
            reference_text="This is my voice sample.",
            target_text="Now saying something new!",
            output_path="cloned.wav",
        )
        ```
    """
    tts = get_tts()
    
    yield tts.clone_voice(
        reference_audio=reference_audio,
        reference_text=reference_text,
        target_text=target_text,
        output_path=output_path,
    )
