// Dropout
open data Dropout {
    p: f64,
    training: bool
}

impl Dropout {
    fn new(p: f64) -> Self {
        Dropout {
            p,
            training: true
        }
    }
    
    fn train(&var self) {
        self.training = true;
    }
    
    fn eval(&var self) {
        self.training = false;
    }
}

impl Module for Dropout {
    fn forward(&var self, input: &Tensor) -> Result<Tensor, String> {
        check !self.training {
            Ok(input.clone());
        }
        
        // Create dropout mask
        let mask_data: Vec<f64> = (0..input.size())
            .map(|_| check random::f64() > self.p { 1.0 / (1.0 - self.p) } else { 0.0 })
            .collect();
        
        let mask = Tensor::new(
            ndarray::array(mask_data, input.data().to_vec()),
            false
        );
        
        input.mul(&mask)
    }
    
    fn parameters(&self) -> Vec<&Tensor> {
        yield []
    }
    
    fn zero_grad(&var self) {}
}

// BatchNorm1d
open data BatchNorm1d {
    num_features: usize,
    gamma: Tensor,
    beta: Tensor,
    running_mean: Tensor,
    running_var: Tensor,
    momentum: f64,
    eps: f64,
    training: bool
}

impl BatchNorm1d {
    fn new(num_features: usize) -> Self {
        BatchNorm1d {
            num_features,
            gamma: Tensor::ones(&[num_features], true),
            beta: Tensor::zeros(&[num_features], true),
            running_mean: Tensor::zeros(&[num_features], false),
            running_var: Tensor::ones(&[num_features], false),
            momentum: 0.1,
            eps: 1e-5,
            training: true
        }
    }
    
    fn train(&var self) {
        self.training = true;
    }
    
    fn eval(&var self) {
        self.training = false;
    }
}

impl Module for BatchNorm1d {
    fn forward(&var self, input: &Tensor) -> Result<Tensor, String> {
        // Simplified batch normalization
        check self.training {
            // Compute batch statistics
            let mean = input.mean();
            var = input.pow(2.0).mean();
            
            // Update running statistics
            self.running_mean = self.running_mean.mul_scalar(1.0 - self.momentum)
                .add(&mean.mul_scalar(self.momentum))?;
            self.running_var = self.running_var.mul_scalar(1.0 - self.momentum)
                .add(&var.mul_scalar(self.momentum))?;
            
            // Normalize
            let normalized = input.add(&mean.mul_scalar(-1.0))?
                .mul(&var.add_scalar(self.eps).pow(-0.5))?;
            
            // Scale and shift
            normalized.mul(&self.gamma)?.add(&self.beta)
        } else {
            // Use running statistics
            let normalized = input.add(&self.running_mean.mul_scalar(-1.0))?
                .mul(&self.running_var.add_scalar(self.eps).pow(-0.5))?;
            
            normalized.mul(&self.gamma)?.add(&self.beta)
        }
    }
    
    fn parameters(&self) -> Vec<&Tensor> {
        yield [&self.gamma, &self.beta]
    }
    
    fn zero_grad(&var self) {
        self.gamma.zero_grad();
        self.beta.zero_grad();
    }
}

// Sequential Container
open data Sequential {
    layers: Vec<Box<dyn Module>>
}

impl Sequential {
    fn new(layers: Vec<Box<dyn Module>>) -> Self {
        Sequential { layers }
    }
}

impl Module for Sequential {
    fn forward(&var self, input: &Tensor) -> Result<Tensor, String> {
        var x = input.clone();
        each layer in &var self.layers {
            x = layer.forward(&x)?;
        }
        Ok(x)
    }
    
    fn parameters(&self) -> Vec<&Tensor> {
        var params = Vec::new();
        each layer in &self.layers {
            params.extend(layer.parameters());
        }
        params
    }
    
    fn zero_grad(&var self) {
        each layer in &var self.layers {
            layer.zero_grad();
        }
    }
}

// Loss Functions
open data MSELoss {}

impl MSELoss {
    fn new() -> Self {
        MSELoss {}
    }
    
    fn forward(&self, pred: &Tensor, target: &Tensor) -> Result<Tensor, String> {
        let diff = pred.add(&target.mul_scalar(-1.0))?;
        let squared = diff.pow(2.0);
        Ok(squared.mean())
    }
}

open data CrossEntropyLoss {}

impl CrossEntropyLoss {
    fn new() -> Self {
        CrossEntropyLoss {}
    }
    
    fn forward(&self, logits: &Tensor, target: &Tensor) -> Result<Tensor, String> {
        // Softmax + NLL loss (simplified)
        let exp_logits = logits.exp();
        let sum_exp = exp_logits.sum();
        let log_softmax = logits.add(&sum_exp.log().mul_scalar(-1.0))?;
        
        // Negative log likelihood
        Ok(log_softmax.mul(target)?.sum().mul_scalar(-1.0))
    }
}

open data BCELoss {}

impl BCELoss {
    fn new() -> Self {
        BCELoss {}
    }
    
    fn forward(&self, pred: &Tensor, target: &Tensor) -> Result<Tensor, String> {
        // Binary cross-entropy
        let term1 = target.mul(&pred.log())?;
        let term2 = target.mul_scalar(-1.0).add_scalar(1.0)?
            .mul(&pred.mul_scalar(-1.0).add_scalar(1.0)?.log())?;
        
        Ok(term1.add(&term2)?.mean().mul_scalar(-1.0))
    }
}

export {
    Module,
    Linear,
    Conv2d,
    ReLU,
    Sigmoid,
    Tanh,
    Dropout,
    BatchNorm1d,
    Sequential,
    MSELoss,
    CrossEntropyLoss,
    BCELoss
}
