// Re-export key components
pub use ai_native::*;
pub use frontend::parser::Parser;
pub use backend::codegen::CodeGenerator;
pub use optimizer::fusion::FusionEngine;
pub use multilingual::MultilingualCompiler;
pub use generic_compiler::*; 
pub use power_aware::*; // 🆕 Power-aware components
pub use semantic::{analyze, SemanticResult}; // 🆕 Semantic analysis
pub use ffi_codegen::{FFICodeGenerator, generate_bindings}; // 🆕 FFI code generation
pub use plugins::{PluginManager, PluginPhase, default_plugin_config}; // 🆕 Plugin system 

/// Main compiler interface
pub struct NovaCompiler {
    parser: Parser,
    optimizer: FusionEngine,
    codegen: CodeGenerator,
    multilingual: MultilingualCompiler,
    power_optimizer: PowerOptimizer, // 🆕 Power-aware optimization
    plugin_manager: PluginManager,  // 🆕 Plugin system
    config: CompilerConfig,
}

impl NovaCompiler {
    pub fn new(config: CompilerConfig) -> Self {
        let plugin_config = default_plugin_config();
        NovaCompiler {
            parser: Parser::new(&config),
            optimizer: FusionEngine::new(&config),
            codegen: CodeGenerator::new(&config),
            multilingual: MultilingualCompiler::new(),
            power_optimizer: PowerOptimizer::new(), // 🆕 Initialize power optimizer
            plugin_manager: PluginManager::new(plugin_config), // 🆕 Initialize plugin manager
            config,
        }
    }
    
    pub fn compile(&mut self, source: &str) -> Result<CompiledProgram, CompilerError> {
        // 🆕 Run pre-parse plugins
        let pre_parse_result = self.plugin_manager.run_plugins(PluginPhase::PreParse, source, &Ast::empty());
        if !pre_parse_result.success {
            return Err(CompilerError::ParseError("Pre-parse plugin failed".into()));
        }
        
        // Try multilingual compilation first
        if let Ok(result) = self.multilingual.compile_multilingual(source) {
            return Ok(result);
        }
        
        // Try power-aware compilation if power budget is specified
        if let Some(power_budget) = &self.config.power_budget {
            return self.compile_with_power_awareness(source, power_budget);
        }
        
        // Fallback to regular compilation
        // Parse source code
        let ast = self.parser.parse(source)?;
        
        // 🆕 Run post-parse plugins
        let post_parse_result = self.plugin_manager.run_plugins(PluginPhase::PostParse, source, &ast);
        for warning in &post_parse_result.warnings {
            println!("⚠️  Post-parse plugin warning: {}", warning);
        }
        
        // 🆕 Perform semantic analysis
        let semantic_result = analyze(&ast);
        if !semantic_result.success {
            let error_msg = semantic_result.errors.iter()
                .map(|e| format!("{:?}", e))
                .collect::<Vec<_>>()
                .join("; ");
            return Err(CompilerError::ParseError(format!("Semantic analysis failed: {}", error_msg)));
        }
        
        // Report warnings
        for warning in &semantic_result.warnings {
            println!("⚠️  Semantic warning: {}", warning);
        }
        
        // 🆕 Run pre-optimize plugins
        let pre_opt_result = self.plugin_manager.run_plugins(PluginPhase::PreOptimize, source, &ast);
        for warning in &pre_opt_result.warnings {
            println!("⚠️  Pre-optimize plugin warning: {}", warning);
        }
        
        // Apply AI-native optimizations
        let optimized_ast = self.optimizer.optimize(ast)?;
        
        // 🆕 Run post-optimize plugins
        let post_opt_result = self.plugin_manager.run_plugins(PluginPhase::PostOptimize, source, &optimized_ast);
        for warning in &post_opt_result.warnings {
            println!("⚠️  Post-optimize plugin warning: {}", warning);
        }
        
        // 🆕 Run pre-codegen plugins
        let pre_codegen_result = self.plugin_manager.run_plugins(PluginPhase::PreCodegen, source, &optimized_ast);
        for warning in &pre_codegen_result.warnings {
            println!("⚠️  Pre-codegen plugin warning: {}", warning);
        }
        
        // Generate target code
        let compiled = self.codegen.generate(optimized_ast)?;
        
        // 🆕 Run post-codegen plugins
        let post_codegen_result = self.plugin_manager.run_plugins(PluginPhase::PostCodegen, source, &optimized_ast);
        for warning in &post_codegen_result.warnings {
            println!("⚠️  Post-codegen plugin warning: {}", warning);
        }
        
        Ok(compiled)
    }
    
    // 🆕 Power-aware compilation method
    pub fn compile_with_power_awareness(
        &mut self, 
        source: &str, 
        power_budget: &PowerBudget
    ) -> Result<PowerOptimizedProgram, CompilerError> {
        // Parse source code
        let ast = self.parser.parse(source)?;
        
        // 🆕 Perform semantic analysis
        let semantic_result = analyze(&ast);
        if !semantic_result.success {
            let error_msg = semantic_result.errors.iter()
                .map(|e| format!("{:?}", e))
                .collect::<Vec<_>>()
                .join("; ");
            return Err(CompilerError::ParseError(format!("Semantic analysis failed: {}", error_msg)));
        }
        
        // Apply power-aware optimizations
        let power_optimized = self.power_optimizer.optimize_with_power_constraints(
            ast, 
            power_budget
        )?;
        
        // Generate power-aware code
        let compiled = self.codegen.generate_power_optimized(power_optimized)?;
        
        Ok(compiled)
    }
}

pub struct CompilerConfig {
    pub target: TargetPlatform,
    pub optimization_level: OptimizationLevel,
    pub ai_features: AIFeatures,
    pub hardware_target: HardwareTarget,
    pub power_budget: Option<PowerBudget>, // 🆕 Optional power budget configuration
    pub google_collaboration: Option<GoogleCollaboration>, // 🆕 Google partnership settings
}

#[derive(Debug, Clone)]
pub enum TargetPlatform {
    CPU,
    GPU(GPUVendor),
    TPU,
    NPU,
    Unified,
}

#[derive(Debug, Clone)]
pub enum OptimizationLevel {
    None,
    Basic,
    Aggressive,
    Maximum,
}

#[derive(Debug, Clone)]
pub struct AIFeatures {
    pub enable_tensor_optimization: bool,
    pub enable_kernel_fusion: bool,
    pub enable_symbolic_computation: bool,
    pub enable_contract_checking: bool,
    pub enable_adaptive_performance: bool,
}

#[derive(Debug, Clone)]
pub enum HardwareTarget {
    Auto,
    NVIDIA,
    Apple,
    Google, // 🆕 Google TPU/Edge TPU
    AMD,
    Intel,
}

#[derive(Debug, Clone)]
pub enum GPUVendor {
    NVIDIA,
    AMD,
    Intel,
    Apple,
    Google, // 🆕 Google TPU support
}

#[derive(Debug, Clone)]
pub struct CompiledProgram {
    pub binary: Vec<u8>,
    pub metadata: ProgramMetadata,
    pub performance_info: PerformanceInfo,
}

#[derive(Debug, Clone)]
pub struct ProgramMetadata {
    pub version: String,
    pub target: TargetPlatform,
    pub compilation_time: std::time::Duration,
    pub optimizations_applied: Vec<String>,
}

#[derive(Debug, Clone)]
pub struct PerformanceInfo {
    pub estimated_performance: PerformanceMetrics,
    pub memory_usage: MemoryUsage,
    pub hardware_requirements: HardwareRequirements,
}

#[derive(Debug, Clone)]
pub struct PerformanceMetrics {
    pub execution_time: f64,
    pub memory_bandwidth: f64,
    pub compute_utilization: f64,
    pub energy_efficiency: f64,
}

#[derive(Debug, Clone)]
pub struct MemoryUsage {
    pub code_size: usize,
    pub data_size: usize,
    pub stack_size: usize,
    pub heap_size: usize,
}

#[derive(Debug, Clone)]
pub struct HardwareRequirements {
    pub min_compute_units: u32,
    pub min_memory_bandwidth: f64,
    pub required_features: Vec<String>,
}

#[derive(Debug, Clone)]
pub enum CompilerError {
    ParseError(String),
    OptimizerError(String),
    CodegenError(String),
    HardwareError(String),
    PowerError(String), // 🆕 Power-related compilation errors
    GoogleIntegrationError(String), // 🆕 Google API integration errors
}

impl std::fmt::Display for CompilerError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            CompilerError::ParseError(msg) => write!(f, "Parse error: {}", msg),
            CompilerError::OptimizerError(msg) => write!(f, "Optimizer error: {}", msg),
            CompilerError::CodegenError(msg) => write!(f, "Code generation error: {}", msg),
            CompilerError::HardwareError(msg) => write!(f, "Hardware error: {}", msg),
            CompilerError::PowerError(msg) => write!(f, "Power optimization error: {}", msg),
            CompilerError::GoogleIntegrationError(msg) => write!(f, "Google integration error: {}", msg),
        }
    }
}

impl std::error::Error for CompilerError {}