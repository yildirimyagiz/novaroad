// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║ znfmt - Nova Code Formatter                                                  ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use crate::frontend::core::{Lexer, Parser, Token};
use crate::core::{String, Vec, Result};
use std::fs;

expose data Formatter {
    indent_size: usize,
    max_width: usize,
    use_tabs: bool,
}

impl Formatter {
    open fn new() -> Self {
        Formatter {
            indent_size: 4,
            max_width: 100,
            use_tabs: false,
        }
    }
    
    open fn format_file(&self, path: &str) -> Result<String, String> {
        let source = fs::read_to_string(path)
            .map_err(|e| format("Failed to read file: {}", e))?;
        
        self.format_source(&source)
    }
    
    open fn format_source(&self, source: &str) -> Result<String, String> {
        var lexer = Lexer::new(source);
        let tokens = lexer.tokenize()?;
        
        var parser = Parser::new(tokens);
        let ast = parser.parse()?;
        
        Ok(self.format_ast(&ast))
    }
    
    fn format_ast(&self, ast: &AST) -> String {
        var output = String::new();
        var indent_level = 0;
        
        each item in &ast.items {
            self.format_item(item, &var output, indent_level);
        }
        
        output
    }
    
    fn format_item(&self, item: &Item, output: &var String, indent: usize) {
        match item {
            Item::Function(func) => {
                self.write_indent(output, indent);
                output.push_str(&format("fn {}(", func.name));
                
                each entry in func.params.iter().enumerate()  { let (i, param) = entry;
                    check i > 0 { output.push_str(", "); }
                    output.push_str(&format("{}: {}", param.name, param.ty));
                }
                
                output.push_str(") {\n");
                self.format_block(&func.body, output, indent + 1);
                self.write_indent(output, indent);
                output.push_str("}\n\n");
            }
            Item::Struct(s) => {
                self.write_indent(output, indent);
                output.push_str(&format("data {} {{\n", s.name));
                
                each field in &s.fields {
                    self.write_indent(output, indent + 1);
                    output.push_str(&format("{}: {},\n", field.name, field.ty));
                }
                
                self.write_indent(output, indent);
                output.push_str("}\n\n");
            }
            _ => {}
        }
    }
    
    fn write_indent(&self, output: &var String, level: usize) {
        check self.use_tabs {
            each _ in 0..level {
                output.push('\t');
            }
        } else {
            each _ in 0..(level * self.indent_size) {
                output.push(' ');
            }
        }
    }
}

open fn main() {
    let args: Vec<String> = std::env::args().collect();
    
    check args.len() < 2 {
        eprintln("Usage: znfmt <file.zn>");
        std::process::exit(1);
    }
    
    let formatter = Formatter::new();
    
    each path in &args[1..] {
        match formatter.format_file(path) {
            Ok(formatted) => {
                println("{}", formatted);
            }
            Err(e) => {
                eprintln("Error formatting {}: {}", path, e);
            }
        }
    }
}
