// §7  EXAMPLES AND USAGE
// ══════════════════════════════════════════════════════════════════════════════

/// Example: AI-native image processing
fn process_image(image: Tensor<f32, 3>) -> Tensor<f32, 3> 
where image: Tensor<f32, H=256, W=256, C=3> {
    
    // Named dimensions with compile-time checking
    let conv_weights = tensor!(f32, K=3, K=3, In=3, Out=64);
    let conv_bias = tensor!(f32, Out=64);
    
    // Automatic hardware optimization
    let optimized_image = image.optimize_for_device();
    let optimized_weights = conv_weights.optimize_memory_layout();
    
    // Efficient convolution with automatic kernel fusion
    let conv_result = optimized_image.conv2d(optimized_weights, conv_bias);
    
    // Automatic memory management
    conv_result
}

/// Example: Federated learning
fn federated_training_step(
    local_model: FederatedTensor<f32>,
    global_model: FederatedTensor<f32>
) -> FederatedTensor<f32> {
    
    // Privacy-preserving aggregation
    let aggregated = local_model.federated_average(
        global_model, 
        AggregationMethod::FedProx
    );
    
    // Automatic encryption based on privacy level
    match aggregated.privacy_level {
        PrivacyLevel::DifferentialPrivacy(epsilon) => {
            aggregated.apply_differential_privacy(epsilon)
        },
        PrivacyLevel::SecureAggregation => {
            aggregated.secure_aggregate()
        },
        _ => aggregated
    }
}

/// Example: Quantum-ready operations
fn quantum_neural_layer(input: QuantumTensor<Complex<f32>>) -> QuantumTensor<Complex<f32>> {
    
    // Hybrid quantum-classical operations
    let classical_part = input.amplitudes.matmul(quantum_weight_matrix());
    let quantum_part = input.apply_quantum_gate(HadamardGate);
    
    // Entanglement optimization
    let entangled = quantum_part.entangle_with(classical_part);
    
    entangled
}
