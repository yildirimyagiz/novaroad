// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  Nova — MIR (MID-LEVEL IR)  v8.0                                   ║
// ║  CFG-based representation for High-Level Optimizations                    ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

use crate::core_ir::canonical_ir::{IRType, IROp, IRLit};

/// Sovereignty: Control Flow Graph (CFG)
expose data MIRProgram {
    functions: Vec<MIRFunction>,
}

expose data MIRFunction {
    name:      String,
    blocks:    Vec<BasicBlock>,
    locals:    Vec<LocalDecl>,
    return_ty: IRType,
}

expose data BasicBlock {
    id:         i64,
    statements: Vec<MIRStmt>,
    terminator: MIRTerminator,
}

/// Linear execution steps
expose cases MIRStmt {
    Assign(Place, MIRExpr),
    Call(Place, String, Vec<Operand>),
    Nop,
}

/// Control flow transitions
expose cases MIRTerminator {
    Return,
    Goto(i64),
    Branch {
        cond: Operand,
        true_bb: i64,
        false_bb: i64,
    },
    Unreachable,
}

/// Memory locations
expose data Place {
    local_id: i64,
}

/// Values used in instructions
expose cases Operand {
    Copy(Place),
    Move(Place),
    Const(IRLit),
}

/// R-values
expose cases MIRExpr {
    Use(Operand),
    BinOp(IROp, Operand, Operand),
    UnOp(IROp, Operand),
}

expose data LocalDecl {
    ty:   IRType,
    name: String,
}

open fn main() {
    println("💎 Nova MIR Subsystem - Active");
}
