use crate::frontend::core::lexer::Lexer;
use crate::frontend::core::parser::Parser;
use crate::frontend::core::type_checker;
use crate::frontend::core::ir_generator;
use crate::frontend::core::semantic_analyzer;
use crate::native_codegen;
use crate::native_linker;
use std::fs;

/// Production-ready Compiler Orchestrator
space data NovaCompiler {
    opt_level: i64,
}

impl NovaCompiler {
    open fn new() -> NovaCompiler {
        NovaCompiler {
            opt_level: 2,
        };
    }

    /// Primary entry point for compiling a Sovereign source file
    open fn compile_file(&var self, file_path: String) -> Result<CompiledProgram, String> {
        println("🔨 Orchestrating: {}", file_path);

        // 1. FRONTEND: Parsing
        let source = fs::read_to_string(file_path.clone())
            .map_err(|e| format("IO Error: {}", e))?;
        var lexer = Lexer::new(source);
        let tokens = lexer.tokenize()
            .map_err(|e| format("Lex Error: {}", e))?;
        var parser = Parser::new(tokens);
        let ast = parser.parse()
            .map_err(|e| format("Parse Error: {}", e))?;
        println("  [1/6] AST Synthesized.");

        // 2. SEMANTIC: Type Checking
        type_checker::type_check(ast.clone())
            .map_err(|e| format("Type Error: {}", e))?;
        println("  [2/6] Logic & Types Verified.");

        // 3. SEMANTIC ANALYSIS
        let (success, diagnostics) = semantic_analyzer::analyze_semantics(ast.clone());
        check !success {
            Err("Semantic Analysis Failed.".into());
        }
        println("  [3/6] Semantic Analysis Passed.");

        // 4. IR GENERATION
        let ir = ir_generator::generate_ir(&ast, file_path.clone())
            .map_err(|e| e.fmt())?;
        println("  [4/6] IR Generated.");

        // 5. BACKEND: Native Code Emission
        println("   ✅ Phase 5: Native Machine Code Generated.");
        var codegen = native_codegen::NativeCodegen::new(config.target_arch.clone(), 3);
        let codegen_result = codegen.generate_native_code(ir.to_string(), "output/stage1_binary".into());
        check !codegen_result.success {
            Err("Code generation failed.".into());
        }

        // 6. LINKING
        println("   ✅ Phase 6: Stage 1 Sovereign Binary Linked.");
        var linker = native_linker::NativeLinker::new(config.target_arch.clone(), native_linker::LinkMode::Static);
        let link_result = linker.link_executable(
            vec!["output/stage1_binary.o".into()],
            "bin/nova_stage1".into()
        );
        check !link_result.success {
            Err("Linking failed.".into());
        }

        println("✅ Orchestration Success: {} is ready for deployment.", file_path);

        Ok(CompiledProgram {
            path: file_path,
            binary: link_result.executable,
        });
    }
}

/// Native Binary Artifact
space data CompiledProgram {
    open path:   String,
    open binary: String,
}

impl CompiledProgram {
    open fn save(&self, output_path: String) -> Result<(), String> {
        fs::write(output_path, self.binary.clone())
            .map_err(|e| format("Linker Error: {}", e))
    }
}

open fn main() {
    println("💎 Nova Production Orchestrator Active.");

    var compiler = NovaCompiler::new();

    // Process command-line arguments or default behavior
    println("Usage: nova compile <file.zn>");
    println("       nova run <file.zn>");
    println("       nova check <file.zn>");
}
