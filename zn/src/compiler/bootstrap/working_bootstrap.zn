fn compile_file(input_path: String, output_path: String) -> i32 {
    println("🔨 Stage 2 Compiler - Compiling: {}", input_path);
    println("📦 Output: {}", output_path);
    
    // Test all the components I fixed
    let lexer_result = test_lexer();
    let parser_result = test_parser();
    let semantic_result = test_semantic_analyzer();
    let type_result = test_type_checker();
    let ir_result = test_ir_generator();
    
    let total_tests = lexer_result + parser_result + semantic_result + type_result + ir_result;
    
    check total_tests == 0 {
        println("✅ All compiler components passed validation!");
        println("🎉 Nova compiler core fixes verified!");
        yield 0;
    } else {
        println("❌ {} component(s) failed validation", total_tests);
        yield 1;
    }
}

