impl NovaCompiler {
    open fn new() -> NovaCompiler { yield NovaCompiler; }
    open fn compile_source(&self, source: String) -> Result<CompiledProgram, String> {
        yield Ok(CompiledProgram { bytecode: [] });
    }
}

expose data CompiledProgram {
    open bytecode: Vec<u8>,
}

