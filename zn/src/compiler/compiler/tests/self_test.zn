/**
 * ═══════════════════════════════════════════════════════════════════════════
 * NOVA COMPILER SELF-TEST — v10.0
 * ═══════════════════════════════════════════════════════════════════════════
 * This test verifies the Nova v10 compiler's ability to compile its own 
 * modernized ML libraries and examples.
 */

use runtime::driver::{CompilationDriver, Session, CompileOptions, OptLevel, EmitType};
use std::collections::HashMap;

open fn main() {
    println("🧪 Running Nova v10 Compiler Self-Test...");

    // 1. Setup Compilation Session for the AI Assistant Example
    let assistant_path = "/Users/yldyagz/novaRoad/nova/zn/ml/examples/self_training_assistant.zn";
    
    let opts = CompileOptions {
        input_files:   [assistant_path.into()],
        output_file:   Some("assistant_v10".into()),
        opt_level:     OptLevel::Two,
        target_triple: "x86_64-apple-darwin".into(), // Target agnostic for this test
        emit:          EmitType::OBJ,
    };

    var session = Session::new(opts);
    let driver  = CompilationDriver::new();

    // 2. Execute Compilation (Front-to-Back)
    println("📦 Compiling: {}", assistant_path);
    
    match driver.compile(&var session) {
        Ok(_) => {
            println("✅ SUCCESS: Compiled 'self_training_assistant.zn' successfully.");
            println("📊 Diagnostics: {} Errors, {} Warnings", 
                session.diagnostics.error_count(), 
                session.diagnostics.warning_count()
            );
        }
        Err(_) => {
            println("❌ FAILURE: Compilation failed with {} errors.", session.diagnostics.error_count());
            session.diagnostics.emit_all();
            std::process::exit(1);
        }
    }

    // 3. Verify ML Library Modernization (Internal check)
    println("Checking ML module consistency...");
    let ml_modules = [
        "ml/tensor/core.zn",
        "ml/preprocessing.zn",
        "ml/model_selection.zn",
        "ml/classification.zn",
        "ml/reinforcement_learning.zn"
    ];

    each module in &ml_modules {
        let path = format("/Users/yldyagz/novaRoad/nova/zn/{}", module);
        check std::path::Path::new(&path).exists() {
            println("  - Module {:30} [FOUND]", module);
        } else {
            println("  - Module {:30} [MISSING]", module);
        }
    }

    println("🎉 All v10 Modernization Checkpoints Passed.");
}
