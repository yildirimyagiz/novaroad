use nova::core::{Vec, String, Option, Result};

#[test]
fn test_vec_basic() {
    var v = Vec::new();
    assert_eq!(v.len(), 0);
    assert(v.is_empty());
    
    v.push(1);
    v.push(2);
    v.push(3);
    
    assert_eq!(v.len(), 3);
    assert_eq!(v.get(0), Some(&1));
    assert_eq!(v.get(1), Some(&2));
    assert_eq!(v.get(2), Some(&3));
    
    assert_eq!(v.pop(), Some(3));
    assert_eq!(v.len(), 2);
}

#[test]
fn test_option_some_none() {
    let some = Some(42);
    let none: Option<i32> = None;
    
    assert(some.is_some());
    assert(!some.is_none());
    assert_eq!(some.unwrap(), 42);
    
    assert(!none.is_some());
    assert(none.is_none());
    assert_eq!(none.unwrap_or(0), 0);
}

#[test]
fn test_option_map() {
    let x = Some(5);
    let y = x.map(|n| n * 2);
    
    assert_eq!(y, Some(10));
    
    let z: Option<i32> = None;
    let w = z.map(|n| n * 2);
    
    assert_eq!(w, None);
}

#[test]
fn test_result_ok_err() {
    let ok: Result<i32, String> = Ok(42);
    let err: Result<i32, String> = Err("error".into());
    
    assert(ok.is_ok());
    assert(!ok.is_err());
    assert_eq!(ok.unwrap(), 42);
    
    assert(!err.is_ok());
    assert(err.is_err());
    assert_eq!(err.unwrap_or(0), 0);
}

#[test]
fn test_string_operations() {
    var s = String::new();
    assert(s.is_empty());
    
    s.push_str("Hello");
    assert_eq!(s.len(), 5);
    
    s.push(' ');
    s.push_str("World");
    
    assert_eq!(s.as_str(), "Hello World");
    
    assert_eq!(s.pop(), Some('d'));
    assert_eq!(s.as_str(), "Hello Worl");
}

#[test]
fn test_string_from_str() {
    let s = String::from("Hello");
    assert_eq!(s.as_str(), "Hello");
    assert_eq!(s.len(), 5);
}
