// ║ Nova Web Framework Tests                                                     ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use nova::web::framework::{App, Request, Response};
use nova::http::{Method, StatusCode};

#[test]
fn test_app_creation() {
    let app = App::new();
    assert_eq!(app.routes.len(), 0);
}

#[test]
fn test_route_registration() {
    var app = App::new();
    
    app.get("/", |_| Response::html("<h1>Home</h1>"))
       .get("/about", |_| Response::html("<h1>About</h1>"));
    
    assert_eq!(app.routes.len(), 2);
}

#[test]
fn test_request_parsing() {
    let raw = "GET /test HTTP/1.1\r\nHost: localhost\r\n\r\n";
    let req = Request::from_str(raw).unwrap();
    
    assert_eq!(req.method, Method::GET);
    assert_eq!(req.url, "/test");
}

#[test]
fn test_response_creation() {
    var res = Response::new();
    res.status(StatusCode::OK)
       .header("Content-Type", "application/json")
       .body(r#"{"message": "Hello"}"#.into());
    
    assert_eq!(res.status, StatusCode::OK);
    assert_eq!(res.headers.get("Content-Type"), Some(&"application/json".into()));
}

#[test]
fn test_json_response() {
    let data = json!({
        "name": "Nova",
        "version": "1.0"
    });
    
    let res = Response::json(data);
    
    assert_eq!(res.status, StatusCode::OK);
    assert_eq!(res.headers.get("Content-Type"), Some(&"application/json".into()));
}
