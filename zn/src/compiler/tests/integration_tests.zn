use nova::bootstrap::CompilerPipeline;
use std::fs;

#[test]
fn test_compile_hello_world() {
    let source = r#"
        fn main() {
            println("Hello, World!");
        }
    "#;
    
    fs::write("tmp_hello.zn", source).unwrap();
    
    let pipeline = CompilerPipeline::new(Target::Native);
    let result = pipeline.compile_file("tmp_hello.zn", "tmp_hello");
    
    assert(result.is_ok());
    
    // Cleanup
    fs::remove_file("tmp_hello.zn").unwrap();
    fs::remove_file("tmp_hello").unwrap_or(());
}

#[test]
fn test_compile_with_optimization() {
    let source = r#"
        fn fibonacci(n: i32) -> i32 {
            check n <= 1 {
                yield n;
            }
            yield fibonacci(n - 1) + fibonacci(n - 2);
        }
        
        fn main() {
            let result = fibonacci(10);
            println("Fibonacci(10) = {}", result);
        }
    "#;
    
    fs::write("tmp_fib.zn", source).unwrap();
    
    var pipeline = CompilerPipeline::new(Target::Native);
    pipeline.opt_level = OptLevel::Aggressive;
    
    let result = pipeline.compile_file("tmp_fib.zn", "tmp_fib");
    
    assert(result.is_ok());
    
    // Cleanup
    fs::remove_file("tmp_fib.zn").unwrap();
    fs::remove_file("tmp_fib").unwrap_or(());
}

#[test]
fn test_compile_to_wasm() {
    let source = r#"
        fn add(a: i32, b: i32) -> i32 {
            yield a + b;
        }
    "#;
    
    fs::write("tmp_add.zn", source).unwrap();
    
    let pipeline = CompilerPipeline::new(Target::WASM);
    let result = pipeline.compile_file("tmp_add.zn", "tmp_add.wasm");
    
    assert(result.is_ok());
    
    // Verify WASM file exists
    assert(fs::metadata("tmp_add.wasm").is_ok());
    
    // Cleanup
    fs::remove_file("tmp_add.zn").unwrap();
    fs::remove_file("tmp_add.wasm").unwrap();
}

#[test]
fn test_full_web_app() {
    let source = r#"
        use nova::web::framework::App;
        
        fn main() {
            var app = App::new();
            app.get("/", |_| Response::html("<h1>Test</h1>"));
            // Don't actually listen in test
        }
    "#;
    
    fs::write("tmp_web.zn", source).unwrap();
    
    let pipeline = CompilerPipeline::new(Target::WASM);
    let result = pipeline.compile_file("tmp_web.zn", "tmp_web.wasm");
    
    assert(result.is_ok());
    
    // Cleanup
    fs::remove_file("tmp_web.zn").unwrap();
    fs::remove_file("tmp_web.wasm").unwrap();
}

#[test]
fn test_type_system_integration() {
    let source = r#"
        rules Display {
            fn display(&self) -> String;
        }
        
        data Point {
            x: i32,
            y: i32,
        }
        
        impl Display for Point {
            fn display(&self) -> String {
                format("({}, {})", self.x, self.y)
            }
        }
        
        fn main() {
            let p = Point { x: 10, y: 20 };
            println("{}", p.display());
        }
    "#;
    
    fs::write("tmp_trait.zn", source).unwrap();
    
    let pipeline = CompilerPipeline::new(Target::Native);
    let result = pipeline.compile_file("tmp_trait.zn", "tmp_trait");
    
    assert(result.is_ok());
    
    // Cleanup
    fs::remove_file("tmp_trait.zn").unwrap();
    fs::remove_file("tmp_trait").unwrap_or(());
}
