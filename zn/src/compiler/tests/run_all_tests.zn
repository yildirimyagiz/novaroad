// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║ Nova Test Suite Runner - Run all tests                                       ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use nova::toolchain::zntest::TestRunner;

fn main() {
    println("╔══════════════════════════════════════════════════════════════╗");
    println("║          Nova Comprehensive Test Suite                       ║");
    println("╚══════════════════════════════════════════════════════════════╝\n");
    
    var runner = TestRunner::new();
    runner.verbose = true;
    
    // Discover all tests
    println("🔍 Discovering tests...\n");
    runner.discover("tests").unwrap();
    
    // Run tests
    let result = runner.run();
    
    // Summary
    println("\n╔══════════════════════════════════════════════════════════════╗");
    println("║                    TEST SUMMARY                              ║");
    println("╠══════════════════════════════════════════════════════════════╣");
    println("║  Total Tests:  {:>3}                                          ║", result.passed + result.failed);
    println("║  ✅ Passed:     {:>3}                                          ║", result.passed);
    println("║  ❌ Failed:     {:>3}                                          ║", result.failed);
    println("╚══════════════════════════════════════════════════════════════╝\n");
    
    check result.failed > 0 {
        println("❌ Some tests failed. Please review the errors above.\n");
        std::process::exit(1);
    } else {
        println("✅ All tests passed! Nova is ready to ship! 🚀\n");
        std::process::exit(0);
    }
}
