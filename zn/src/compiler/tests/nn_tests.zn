use nova::nn::{Tensor, Module, Linear, ReLU};

#[test]
fn test_tensor_creation() {
    let t = Tensor::zeros([2, 3]);
    assert_eq!(t.data, [2, 3]);
    assert_eq!(t.data.len(), 6);
}

#[test]
fn test_tensor_operations() {
    let a = Tensor::new([1.0, 2.0, 3.0], [3]);
    let b = Tensor::new([4.0, 5.0, 6.0], [3]);
    
    let c = a.add(&b);
    
    assert_eq!(c.data, [5.0, 7.0, 9.0]);
}

#[test]
fn test_tensor_matmul() {
    let a = Tensor::new([1.0, 2.0, 3.0, 4.0], [2, 2]);
    let b = Tensor::new([5.0, 6.0, 7.0, 8.0], [2, 2]);
    
    let c = a.matmul(&b);
    
    assert_eq!(c.data, [2, 2]);
    // [1, 2]   [5, 6]   [19, 22]
    // [3, 4] × [7, 8] = [43, 50]
    assert_eq!(c.data[0], 19.0);
    assert_eq!(c.data[1], 22.0);
    assert_eq!(c.data[2], 43.0);
    assert_eq!(c.data[3], 50.0);
}

#[test]
fn test_linear_layer() {
    let layer = Linear::new(3, 2);
    let input = Tensor::new([1.0, 2.0, 3.0], [1, 3]);
    
    let output = layer.forward(&input);
    
    assert_eq!(output.data, [1, 2]);
}

#[test]
fn test_module_forward() {
    var model = Module::new();
    model.add_layer(Box::new(Linear::new(3, 5)))
         .add_layer(Box::new(ReLU::new()))
         .add_layer(Box::new(Linear::new(5, 2)));
    
    let input = Tensor::randn([1, 3]);
    let output = model.forward(&input);
    
    assert_eq!(output.data, [1, 2]);
}

#[test]
fn test_gradient_computation() {
    var x = Tensor::new([2.0, 3.0], [2]);
    x.requires_grad(true);
    
    let y = x.mul(2.0);
    y.backward();
    
    assert(x.grad.is_some());
}
