use nova::frontend::core::{Lexer, Parser, TypeChecker};
use nova::ir::builder::IRBuilder;

#[test]
fn test_lexer_basic() {
    let source = "fn main() { let x = 42; }";
    var lexer = Lexer::new(source);
    let tokens = lexer.tokenize().unwrap();
    
    assert(tokens.len() > 0);
}

#[test]
fn test_parser_function() {
    let source = r#"
        fn add(a: i32, b: i32) -> i32 {
            yield a + b;
        }
    "#;
    
    var lexer = Lexer::new(source);
    let tokens = lexer.tokenize().unwrap();
    
    var parser = Parser::new(tokens);
    let ast = parser.parse().unwrap();
    
    assert_eq!(ast.functions.len(), 1);
    assert_eq!(ast.functions[0].name, "add");
}

#[test]
fn test_type_checker_simple() {
    let source = r#"
        fn test() -> i32 {
            let x: i32 = 42;
            yield x;
        }
    "#;
    
    var lexer = Lexer::new(source);
    let tokens = lexer.tokenize().unwrap();
    var parser = Parser::new(tokens);
    let ast = parser.parse().unwrap();
    
    var type_checker = TypeChecker::new();
    let result = type_checker.check(&ast);
    
    assert(result.is_ok());
}

#[test]
fn test_type_checker_error() {
    let source = r#"
        fn test() -> i32 {
            let x: String = 42;  // Type error
            yield x;
        }
    "#;
    
    var lexer = Lexer::new(source);
    let tokens = lexer.tokenize().unwrap();
    var parser = Parser::new(tokens);
    let ast = parser.parse().unwrap();
    
    var type_checker = TypeChecker::new();
    let result = type_checker.check(&ast);
    
    assert(result.is_err());
}

#[test]
fn test_ir_generation() {
    let source = r#"
        fn factorial(n: i32) -> i32 {
            check n <= 1 {
                yield 1;
            } else {
                yield n * factorial(n - 1);
            }
        }
    "#;
    
    var lexer = Lexer::new(source);
    let tokens = lexer.tokenize().unwrap();
    var parser = Parser::new(tokens);
    let ast = parser.parse().unwrap();
    
    var ir_builder = IRBuilder::new();
    let ir = ir_builder.build(&ast).unwrap();
    
    assert(ir.functions.len() > 0);
}
