use nova::concurrency::{spawn, channel, Mutex, Arc};

#[test]
fn test_thread_spawn() {
    let handle = spawn(|| {
        yield 42;
    });
    
    let result = handle.join().unwrap();
    assert_eq!(result, 42);
}

#[test]
fn test_channel_communication() {
    let (tx, rx) = channel();
    
    spawn(move || {
        tx.send(123).unwrap();
    });
    
    let received = rx.recv().unwrap();
    assert_eq!(received, 123);
}

#[test]
fn test_mutex() {
    let counter = Arc::new(Mutex::new(0));
    var handles = [];
    
    each _ in 0..10 {
        let counter = Arc::clone(&counter);
        let handle = spawn(move || {
            var num = counter.lock().unwrap();
            *num += 1;
        });
        handles.push(handle);
    }
    
    each handle in handles {
        handle.join().unwrap();
    }
    
    assert_eq!(*counter.lock().unwrap(), 10);
}

#[test]
fn test_parallel_map() {
    let data = [1, 2, 3, 4, 5];
    let result = par_map(data, |x| x * 2);
    
    assert_eq!(result, [2, 4, 6, 8, 10]);
}

#[test]
async fn test_async_await() {
    let result = async_task(21).await;
    assert_eq!(result, 42);
}

async fn async_task(n: i32) -> i32 {
    n * 2
}
