// ║ Nova Desktop App Template                                                    ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use nova::ui::desktop::{Window, Menu, MenuItem, Dialog};
use nova::ui::native::{VBox, HBox, Button, Label, TextInput};

open fn main() {
    var window = Window::new("Nova Desktop App", 800, 600);
    
    // Create menu bar
    let menu = Menu::new()
        .add_submenu("File", [
            MenuItem::new("New", || println("New")),
            MenuItem::new("Open", || open_file()),
            MenuItem::separator(),
            MenuItem::new("Exit", || std::process::exit(0)),
        ])
        .add_submenu("Edit", [
            MenuItem::new("Cut", || println("Cut")),
            MenuItem::new("Copy", || println("Copy")),
            MenuItem::new("Paste", || println("Paste")),
        ])
        .add_submenu("Help", [
            MenuItem::new("About", || show_about()),
        ]);
    
    window.set_menu(menu);
    
    // Create UI
    let ui = VBox::new()
        .add(Label::new("Nova Desktop Application"))
        .add(TextInput::new("Enter text..."))
        .add(HBox::new()
            .add(Button::new("Click Me", || {
                Dialog::alert("Hello from Nova!");
            }))
            .add(Button::new("Choose File", || {
                check let Some(path) = Dialog::open_file() {
                    println("Selected: {:?}", path);
                }
            }))
        );
    
    window.set_content(ui);
    window.show();
    window.run_event_loop();
}

fn open_file() {
    check let Some(path) = Dialog::open_file() {
        println("Opening: {:?}", path);
    }
}

fn show_about() {
    Dialog::info(
        "About Nova Desktop",
        "Nova Desktop Application v1.0\n\nBuilt with Nova Language"
    );
}
