// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║ Home Page Component                                                          ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use nova::ui::web::component::{Component, VNode};
use nova::ui::web::hooks::{use_state, use_effect};

expose data HomePage {
    title: String,
}

impl Component for HomePage {
    alias Props = HomeProps;
    alias State = HomeState;
    
    fn new(props: HomeProps) -> Self {
        HomePage {
            title: props.title,
        }
    }
    
    fn render(&self) -> VNode {
        html! {
            <div class="container">
                <header>
                    <h1>{&self.title}</h1>
                    <p>"Build fast, ship faster with Nova"</p>
                </header>
                
                <main>
                    <section class="hero">
                        <h2>"⚡ nova Fast"</h2>
                        <p>"Compile to WebAssembly for native performance"</p>
                    </section>
                    
                    <section class="features">
                        <FeatureCard 
                            title="Type Safe"
                            description="Advanced alias system with inference"
                        />
                        <FeatureCard 
                            title="Zero Cost"
                            description="No runtime overhead"
                        />
                        <FeatureCard 
                            title="Full Stack"
                            description="Frontend, backend, mobile, desktop"
                        />
                    </section>
                    
                    <Counter />
                </main>
                
                <footer>
                    <p>"© 2026 Nova Language"</p>
                </footer>
            </div>
        }
    }
}

expose data FeatureCard {
    title: String,
    description: String,
}

impl Component for FeatureCard {
    alias Props = FeatureCardProps;
    alias State = ();
    
    fn render(&self) -> VNode {
        html! {
            <div class="feature-card">
                <h3>{&self.title}</h3>
                <p>{&self.description}</p>
            </div>
        }
    }
}

expose data Counter {
    count: i32,
}

impl Component for Counter {
    fn render(&self) -> VNode {
        let (count, set_count) = use_state(0);
        
        html! {
            <div class="counter">
                <h3>"Interactive Counter"</h3>
                <p>"Count: "{count}</p>
                <button onclick={move |_| set_count(count + 1)}>
                    "Increment"
                </button>
                <button onclick={move |_| set_count(count - 1)}>
                    "Decrement"
                </button>
                <button onclick={move |_| set_count(0)}>
                    "Reset"
                </button>
            </div>
        }
    }
}
