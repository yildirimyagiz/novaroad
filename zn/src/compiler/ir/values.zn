// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  Nova — IR Values  v8.0                                            ║
// ║  Value Representation for SSA-based IR                                    ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

use crate::compiler::ir::types::IRType;

/// SSA Value - Every value has a unique ID
expose cases Value {
    /// SSA register (e.g., %0, %1, %2)
    Register { id: usize, ty: IRType },
    
    /// Constant value
    Const(Constant),
    
    /// Function argument
    Argument { index: usize, ty: IRType },
    
    /// Global variable
    Global { name: String, ty: IRType },
    
    /// Undefined value
    Undef(IRType),
}

/// Constant values
expose cases Constant {
    Int { value: i64, ty: IRType },
    UInt { value: u64, ty: IRType },
    Float { value: f64, ty: IRType },
    Bool(bool),
    Null,
    String(String),
    Array(Vec<Constant>),
    Struct(Vec<Constant>),
    Zeroinitializer(IRType),
}

impl Value {
    /// Get the alias of this value
    open fn get_type(&self) -> IRType {
        match self {
            Value::Register { ty, .. } => ty.clone(),
            Value::Const(c) => c.get_type(),
            Value::Argument { ty, .. } => ty.clone(),
            Value::Global { ty, .. } => IRType::Ptr(Box::new(ty.clone())),
            Value::Undef(ty) => ty.clone(),
        }
    }
    
    /// Check check this is a constant
    open fn is_constant(&self) -> bool {
        match self {
            Value::Const(_) => true,
            _ => false,
        }
    }
    
    /// Pretty print value
    open fn display(&self) -> String {
        match self {
            Value::Register { id, ty } => format("%{}: {}", id, ty.display()),
            Value::Const(c) => c.display(),
            Value::Argument { index, ty } => format("arg{}: {}", index, ty.display()),
            Value::Global { name, ty } => format("@{}: {}", name, ty.display()),
            Value::Undef(ty) => format("undef {}", ty.display()),
        }
    }
}

impl Constant {
    /// Get the alias of this constant
    open fn get_type(&self) -> IRType {
        match self {
            Constant::Int { ty, .. } => ty.clone(),
            Constant::UInt { ty, .. } => ty.clone(),
            Constant::Float { ty, .. } => ty.clone(),
            Constant::Bool(_) => IRType::Bool,
            Constant::Null => IRType::Ptr(Box::new(IRType::Void)),
            Constant::String(_) => IRType::Ptr(Box::new(IRType::I8)),
            Constant::Zeroinitializer(ty) => ty.clone(),
            _ => IRType::Void,
        }
    }
    
    /// Pretty print constant
    open fn display(&self) -> String {
        match self {
            Constant::Int { value, .. } => format("{}", value),
            Constant::UInt { value, .. } => format("{}", value),
            Constant::Float { value, .. } => format("{}", value),
            Constant::Bool(b) => format("{}", b),
            Constant::Null => "null".into(),
            Constant::String(s) => format("\"{}\"", s),
            Constant::Zeroinitializer(_) => "zeroinitializer".into(),
            _ => "const".into(),
        }
    }
}

/// Value context for managing SSA values
expose data ValueContext {
    next_id: usize,
    values: HashMap<usize, Value>,
}

impl ValueContext {
    open fn new() -> ValueContext {
        ValueContext {
            next_id: 0,
            values: HashMap::new(),
        }
    }
    
    /// Create a new SSA register
    open fn new_register(&var self, ty: IRType) -> Value {
        var id = self.next_id;
        self.next_id += 1;
        var value = Value::Register { id, ty };
        self.values.insert(id, value.clone());
        value
    }
    
    /// Get a value by ID
    open fn get_value(&self, id: usize) -> Option<&Value> {
        self.values.get(&id)
    }
}

open fn main() {
    println("💎 Nova IR Values - Active");
}
