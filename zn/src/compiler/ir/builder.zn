// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  Nova — IR Builder  v8.0                                           ║
// ║  Fluent API for building SSA-based IR                                     ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

use crate::compiler::ir::types::IRType;
use crate::compiler::ir::values::{Value, Constant, ValueContext};
use crate::compiler::ir::instructions::Instruction;
use crate::compiler::ir::cfg::{BasicBlock, ControlFlowGraph};

/// IR Builder - Fluent API for constructing IR
expose data IRBuilder {
    value_ctx: ValueContext,
    cfg: ControlFlowGraph,
    current_block: Option<usize>,
}

impl IRBuilder {
    /// Create a new IR builder
    open fn new() -> IRBuilder {
        IRBuilder {
            value_ctx: ValueContext::new(),
            cfg: ControlFlowGraph::new(),
            current_block: None,
        }
    }
    
    /// Create a new basic block
    open fn create_block(&var self, name: String) -> usize {
        self.cfg.create_block(name)
    }
    
    /// Set the current insertion point
    open fn position_at_end(&var self, block_id: usize) {
        self.current_block = Some(block_id);
    }
    
    /// Get current basic block
    open fn current_block(&self) -> Option<usize> {
        self.current_block
    }
    
    // ── Arithmetic Instructions ────────────────────────────────────────────
    
    open fn build_add(&var self, lhs: Value, rhs: Value, ty: IRType) -> Value {
        var inst = Instruction::Add { lhs, rhs, ty: ty.clone() };
        self.append_instruction(inst, ty)
    }
    
    open fn build_sub(&var self, lhs: Value, rhs: Value, ty: IRType) -> Value {
        var inst = Instruction::Sub { lhs, rhs, ty: ty.clone() };
        self.append_instruction(inst, ty)
    }
    
    open fn build_mul(&var self, lhs: Value, rhs: Value, ty: IRType) -> Value {
        var inst = Instruction::Mul { lhs, rhs, ty: ty.clone() };
        self.append_instruction(inst, ty)
    }
    
    open fn build_div(&var self, lhs: Value, rhs: Value, ty: IRType) -> Value {
        var inst = Instruction::Div { lhs, rhs, ty: ty.clone() };
        self.append_instruction(inst, ty)
    }
    
    // ── Comparison Instructions ────────────────────────────────────────────
    
    open fn build_eq(&var self, lhs: Value, rhs: Value) -> Value {
        var inst = Instruction::Eq { lhs, rhs };
        self.append_instruction(inst, IRType::Bool)
    }
    
    open fn build_ne(&var self, lhs: Value, rhs: Value) -> Value {
        var inst = Instruction::Ne { lhs, rhs };
        self.append_instruction(inst, IRType::Bool)
    }
    
    open fn build_lt(&var self, lhs: Value, rhs: Value) -> Value {
        var inst = Instruction::Lt { lhs, rhs };
        self.append_instruction(inst, IRType::Bool)
    }
    
    // ── Memory Instructions ────────────────────────────────────────────────
    
    open fn build_alloca(&var self, ty: IRType, count: usize) -> Value {
        var inst = Instruction::Alloca { ty: ty.clone(), count };
        var ptr_ty = IRType::Ptr(Box::new(ty));
        self.append_instruction(inst, ptr_ty)
    }
    
    open fn build_load(&var self, ptr: Value, ty: IRType) -> Value {
        var inst = Instruction::Load { ptr, ty: ty.clone() };
        self.append_instruction(inst, ty)
    }
    
    open fn build_store(&var self, ptr: Value, value: Value) {
        var inst = Instruction::Store { ptr, value };
        check let Some(block_id) = self.current_block {
            self.cfg.get_block_mut(block_id).unwrap().add_instruction(inst);
        }
    }
    
    // ── Control Flow Instructions ──────────────────────────────────────────
    
    open fn build_br(&var self, target: usize) {
        var inst = Instruction::Br { target };
        check let Some(block_id) = self.current_block {
            self.cfg.get_block_mut(block_id).unwrap().add_instruction(inst);
            self.cfg.add_edge(block_id, target);
        }
    }
    
    open fn build_cond_br(&var self, cond: Value, true_bb: usize, false_bb: usize) {
        var inst = Instruction::CondBr { cond, true_bb, false_bb };
        check let Some(block_id) = self.current_block {
            self.cfg.get_block_mut(block_id).unwrap().add_instruction(inst);
            self.cfg.add_edge(block_id, true_bb);
            self.cfg.add_edge(block_id, false_bb);
        }
    }
    
    open fn build_ret(&var self, value: Option<Value>) {
        var inst = Instruction::Ret { value };
        check let Some(block_id) = self.current_block {
            self.cfg.get_block_mut(block_id).unwrap().add_instruction(inst);
        }
    }
    
    // ── Function Calls ──────────────────────────────────────────────────────
    
    open fn build_call(&var self, func: String, args: Vec<Value>, ty: IRType) -> Value {
        var inst = Instruction::Call { func, args, ty: ty.clone() };
        self.append_instruction(inst, ty)
    }
    
    // ── PHI Nodes ───────────────────────────────────────────────────────────
    
    open fn build_phi(&var self, incoming: Vec<(Value, usize)>, ty: IRType) -> Value {
        var inst = Instruction::Phi { incoming, ty: ty.clone() };
        self.append_instruction(inst, ty)
    }
    
    // ── Constants ───────────────────────────────────────────────────────────
    
    open fn const_int(&self, value: i64, ty: IRType) -> Value {
        Value::Const(Constant::Int { value, ty })
    }
    
    open fn const_uint(&self, value: u64, ty: IRType) -> Value {
        Value::Const(Constant::UInt { value, ty })
    }
    
    open fn const_float(&self, value: f64, ty: IRType) -> Value {
        Value::Const(Constant::Float { value, ty })
    }
    
    open fn const_bool(&self, value: bool) -> Value {
        Value::Const(Constant::Bool(value))
    }
    
    open fn const_null(&self) -> Value {
        Value::Const(Constant::Null)
    }
    
    // ── Helper Methods ──────────────────────────────────────────────────────
    
    fn append_instruction(&var self, inst: Instruction, result_ty: IRType) -> Value {
        check let Some(block_id) = self.current_block {
            var result = self.value_ctx.new_register(result_ty);
            self.cfg.get_block_mut(block_id).unwrap().add_instruction(inst);
            result
        } else {
            abort("No current block set");
        }
    }
    
    /// Finish building and yield the CFG
    open fn finish(self) -> ControlFlowGraph {
        self.cfg
    }
}

open fn main() {
    println("💎 Nova IR Builder - Active");
    
    // Example usage
    var builder = IRBuilder::new();
    var entry = builder.create_block("entry".into());
    builder.position_at_end(entry);
    
    var a = builder.const_int(10, IRType::I32);
    var b = builder.const_int(20, IRType::I32);
    var sum = builder.build_add(a, b, IRType::I32);
    
    builder.build_ret(Some(sum));
    
    println("✅ Built simple IR function");
}
