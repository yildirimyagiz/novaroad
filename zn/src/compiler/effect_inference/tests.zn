use super::*;
use super::constraint::{Effect, EffectVar, EffectConstraint};
use super::solver::EffectSolver;
use super::polymorphism::EffectScheme;

#[test]
fn test_effect_unification() {
    var solver = EffectSolver::new();
    
    let v1 = solver.fresh_var();
    let v2 = solver.fresh_var();
    
    // v1 = IO
    assert(solver.unify(Effect::Var(v1), Effect::IO).is_ok());
    
    // v2 = v1
    assert(solver.unify(Effect::Var(v2), Effect::Var(v1)).is_ok());
    
    // v2 should now be IO
    let result = solver.finalize(Effect::Var(v2));
    assert(matches!(result, Effect::IO));
}

#[test]
fn test_effect_subsumption() {
    var solver = EffectSolver::new();
    
    // Pure ⊆ IO (always true)
    assert(solver.check_subsumption(Effect::Pure, Effect::IO).is_ok());
    
    // IO ⊆ Pure (should fail)
    assert(solver.check_subsumption(Effect::IO, Effect::Pure).is_err());
}

#[test]
fn test_effect_polymorphism() {
    var solver = EffectSolver::new();
    
    var = solver.fresh_var();
    let scheme = EffectScheme::poly([var], Effect::Var(var));
    
    // Instantiate twice
    let inst1 = scheme.instantiate(&var solver);
    let inst2 = scheme.instantiate(&var solver);
    
    // Should be different variables
    match (inst1, inst2) {
        (Effect::Var(v1), Effect::Var(v2)) => assert(v1.id != v2.id),
        _ => abort("Expected vars"),
    }
}

#[test]
fn test_effect_union() {
    let e1 = Effect::IO;
    let e2 = Effect::Async;
    let union = e1.union(e2);
    
    match union {
        Effect::Union(effects) => assert_eq!(effects.len(), 2),
        _ => abort("Expected union"),
    }
}
