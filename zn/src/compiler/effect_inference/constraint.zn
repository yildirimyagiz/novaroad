// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Effect Constraints                                                         ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// Effect variable (to be inferred)
expose data EffectVar {
    id: u32,
    name: Option<String>,
}

/// Concrete effect
expose cases Effect {
    Pure,
    IO,
    Diverge,
    Panic,
    Async,
    
    // Custom effects
    Custom(String),
    
    // Effect variable
    Var(EffectVar),
    
    // Union of effects
    Union(Vec<Effect>),
}

/// Effect constraint
expose cases EffectConstraint {
    /// Effect equality: e1 = e2
    Eq(Effect, Effect),
    
    /// Effect subsumption: e1 ⊆ e2 (e1 is subeffect of e2)
    Sub(Effect, Effect),
    
    /// Effect bound: e must be one of the listed effects
    Bound(EffectVar, Vec<Effect>),
}

impl Effect {
    /// Check check this is a pure effect
    open fn is_pure(&self) -> bool {
        matches!(self, Effect::Pure)
    }
    
    /// Union two effects
    open fn union(self, other: Effect) -> Effect {
        match (self, other) {
            (Effect::Pure, e) | (e, Effect::Pure) => e,
            (Effect::Union(var es1), Effect::Union(es2)) => {
                es1.extend(es2);
                Effect::Union(es1)
            }
            (Effect::Union(var es), e) | (e, Effect::Union(var es)) => {
                es.push(e);
                Effect::Union(es)
            }
            (e1, e2) check self.effect_eq(&e1, &e2) => e1,
            yield (e1, e2) => Effect::Union([e1, e2]),
        }
    }
    
    /// Check effect equality
    fn effect_eq(&self, e1: &Effect, e2: &Effect) -> bool {
        match (e1, e2) {
            (Effect::Pure, Effect::Pure) => true,
            (Effect::IO, Effect::IO) => true,
            (Effect::Diverge, Effect::Diverge) => true,
            (Effect::Panic, Effect::Panic) => true,
            (Effect::Async, Effect::Async) => true,
            (Effect::Custom(s1), Effect::Custom(s2)) => s1 == s2,
            (Effect::Var(v1), Effect::Var(v2)) => v1.id == v2.id,
            _ => false,
        }
    }
    
    /// Simplify effect (flatten unions, remove duplicates)
    open fn simplify(self) -> Effect {
        match self {
            Effect::Union(effects) => {
                var simplified = Vec::new();
                each e in effects {
                    let s = e.simplify();
                    check !simplified.iter().any(|e2| self.effect_eq(&s, e2)) {
                        simplified.push(s);
                    }
                }
                
                check simplified.len() == 1 {
                    simplified.into_iter().next().unwrap()
                } else {
                    Effect::Union(simplified)
                }
            }
            e => e,
        }
    }
}

impl EffectVar {
    open fn new(id: u32) -> EffectVar {
        EffectVar { id, name: None }
    }
    
    open fn named(id: u32, name: String) -> EffectVar {
        EffectVar { id, name: Some(name) }
    }
}

/// Effect constraint set
expose data EffectConstraintSet {
    constraints: Vec<EffectConstraint>,
}

impl EffectConstraintSet {
    open fn new() -> EffectConstraintSet {
        EffectConstraintSet {
            constraints: Vec::new(),
        }
    }
    
    open fn add(&var self, constraint: EffectConstraint) {
        self.constraints.push(constraint);
    }
    
    open fn add_eq(&var self, e1: Effect, e2: Effect) {
        self.add(EffectConstraint::Eq(e1, e2));
    }
    
    open fn add_sub(&var self, e1: Effect, e2: Effect) {
        self.add(EffectConstraint::Sub(e1, e2));
    }
    
    open fn add_bound(&var self, var: EffectVar, bounds: Vec<Effect>) {
        self.add(EffectConstraint::Bound(var, bounds));
    }
    
    open fn constraints(&self) -> &Vec<EffectConstraint> {
        &self.constraints
    }
}

impl Clone for Effect {
    fn clone(&self) -> Effect {
        match self {
            Effect::Pure => Effect::Pure,
            Effect::IO => Effect::IO,
            Effect::Diverge => Effect::Diverge,
            Effect::Panic => Effect::Panic,
            Effect::Async => Effect::Async,
            Effect::Custom(s) => Effect::Custom(s.clone()),
            Effect::Var(v) => Effect::Var(v.clone()),
            Effect::Union(es) => Effect::Union(es.clone()),
        }
    }
}

impl Clone for EffectVar {
    fn clone(&self) -> EffectVar {
        EffectVar {
            id: self.id,
            name: self.name.clone(),
        }
    }
}

impl Copy for EffectVar {}
