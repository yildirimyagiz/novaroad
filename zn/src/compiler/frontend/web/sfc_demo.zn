// ═══════════════════════════════════════════════════════════════════════════
// Nova Website - Single File Component (Vue.js-like)
// ═══════════════════════════════════════════════════════════════════════════
// HTML + CSS + JavaScript in ONE FILE! Just like Vue.js SFC
// ═══════════════════════════════════════════════════════════════════════════

import web.framework
import web.seo
import web.component_helpers
import ui.web.component

// ═══════════════════════════════════════════════════════════════════════════
// TEMPLATE (HTML) - Vue <template> equivalent
// ═══════════════════════════════════════════════════════════════════════════

fn render_template() -> VNode {
    yield h("div", {}, [
        // Navbar
        h("nav", {"class": "navbar"}, [
            h("div", {"class": "nav-container"}, [
                h("a", {"href": "/", "class": "nav-logo"}, [
                    h("span", {"class": "logo-icon"}, [VNode.text("⚡")]),
                    VNode.text("Nova")
                ]),
                h("div", {"class": "nav-links", "id": "navLinks"}, [
                    h("a", {"href": "#features"}, [VNode.text("Features")]),
                    h("a", {"href": "#mobile"}, [VNode.text("Mobile")]),
                    h("a", {"href": "#compilation"}, [VNode.text("Multi-Lang")]),
                    h("a", {"href": "#governance"}, [VNode.text("Governance")]),
                    h("a", {"href": "#security"}, [VNode.text("Security")]),
                    h("a", {"href": "https://github.com/nova", "target": "_blank"}, [VNode.text("GitHub")])
                ]),
                h("div", {"class": "hamburger", "id": "hamburger"}, [
                    h("span", {}, []),
                    h("span", {}, []),
                    h("span", {}, [])
                ])
            ])
        ]),
        
        // Hero Section
        h("section", {"class": "hero"}, [
            h("div", {"class": "container"}, [
                h("h1", {"class": "hero-title"}, [
                    VNode.text("The Programming Language"),
                    h("br", {}, []),
                    h("span", {"class": "gradient-text"}, [VNode.text("That Can't Be Gamed")])
                ]),
                h("p", {"class": "hero-subtitle"}, [
                    VNode.text("Multi-domain governance • Cryptographic ownership • Open source friendly • Formally verified")
                ]),
                h("div", {"class": "hero-buttons"}, [
                    h("a", {"href": "#features", "class": "btn btn-primary"}, [VNode.text("Explore Features")]),
                    h("a", {"href": "https://github.com/nova", "class": "btn btn-outline"}, [VNode.text("View on GitHub")])
                ])
            ])
        ]),
        
        // Features Section
        h("section", {"class": "features-grid", "id": "features"}, [
            h("div", {"class": "container"}, [
                h("h2", {}, [VNode.text("Why Nova?")]),
                h("div", {"class": "grid"}, [
                    feature_card("🔐", "4 Governance Layers", "Finance, Medical, Robotics, Privacy - AI cannot bypass sealed constraints"),
                    feature_card("🛡️", "Hierarchical Encryption", "3-tier access: Owner, Admin (audited), Users (execute only)"),
                    feature_card("🌍", "Open Source Friendly", "GitHub compatible, MIT/Apache licensed, community first"),
                    feature_card("🔬", "Formal Verification", "Lean 4 integration for mathematical proofs"),
                    feature_card("🧠", "Self-Learning AI", "AI that learns within constraints, cannot game the system"),
                    feature_card("⚡", "Native Performance", "LLVM backend, SIMD, GPU, Metal support")
                ])
            ])
        ]),
        
        // Footer
        h("footer", {"style": "background: #0f172a; border-top: 1px solid rgba(255,255,255,0.1); padding: 4rem 0 2rem; margin-top: 6rem;"}, [
            h("div", {"class": "container"}, [
                h("div", {"style": "text-align: center; padding-top: 2rem; border-top: 1px solid rgba(255,255,255,0.1); color: #64748b;"}, [
                    h("p", {}, [VNode.text("© 2026 Nova Foundation. Open source, production ready.")]),
                    h("p", {"style": "margin-top: 1rem;"}, [
                        VNode.text("Built with Nova itself • "),
                        h("a", {"href": "https://github.com/nova", "style": "color: var(--primary); text-decoration: none;"}, [VNode.text("GitHub")]),
                        VNode.text(" • MIT/Apache Licensed")
                    ])
                ])
            ])
        ])
    ])
}

fn feature_card(icon: str, title: str, desc: str) -> VNode {
    yield h("div", {"class": "feature-card"}, [
        h("div", {"class": "feature-icon"}, [VNode.text(icon)]),
        h("h3", {}, [VNode.text(title)]),
        h("p", {}, [VNode.text(desc)])
    ])
}

// ═══════════════════════════════════════════════════════════════════════════
// STYLE (CSS) - Vue <style> equivalent
// ═══════════════════════════════════════════════════════════════════════════

fn get_styles() -> str {
    yield stylesheet! {
        :root {
            --primary: #6366f1;
            --secondary: #8b5cf6;
            --accent: #ec4899;
            --dark: #0f172a;
            --light: #f8fafc;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
            background: var(--dark);
            color: var(--light);
            line-height: 1.6;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 2rem;
        }
        
        .navbar {
            position: fixed;
            top: 0;
            width: 100%;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            z-index: 1000;
        }
        
        .nav-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 1rem 2rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        
        .nav-logo {
            font-size: 1.5rem;
            font-weight: 800;
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .logo-icon {
            font-size: 2rem;
        }
        
        .nav-links {
            display: flex;
            gap: 2rem;
        }
        
        .nav-links a {
            color: #94a3b8;
            text-decoration: none;
            transition: color 0.3s;
        }
        
        .nav-links a:hover {
            color: white;
        }
        
        .hamburger {
            display: none;
            flex-direction: column;
            cursor: pointer;
            gap: 0.4rem;
        }
        
        .hamburger span {
            width: 25px;
            height: 3px;
            background: white;
            border-radius: 3px;
            transition: all 0.3s;
        }
        
        .hero {
            min-height: 100vh;
            display: flex;
            align-items: center;
            padding-top: 80px;
            background: radial-gradient(circle at top right, rgba(99, 102, 241, 0.1), transparent);
        }
        
        .hero-title {
            font-size: 4rem;
            font-weight: 800;
            margin-bottom: 1rem;
        }
        
        .gradient-text {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        
        .hero-subtitle {
            font-size: 1.25rem;
            color: #94a3b8;
            margin-bottom: 2rem;
        }
        
        .hero-buttons {
            display: flex;
            gap: 1rem;
            margin-bottom: 4rem;
            flex-wrap: wrap;
        }
        
        .btn {
            padding: 0.75rem 2rem;
            border-radius: 0.5rem;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
        }
        
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 30px rgba(99, 102, 241, 0.3);
        }
        
        .btn-outline {
            border: 2px solid rgba(255, 255, 255, 0.2);
            color: white;
        }
        
        .features-grid {
            padding: 6rem 0;
            background: linear-gradient(to bottom, transparent, rgba(99, 102, 241, 0.05));
        }
        
        .grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-top: 3rem;
        }
        
        .feature-card {
            background: rgba(255, 255, 255, 0.05);
            padding: 2rem;
            border-radius: 1rem;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: all 0.3s;
        }
        
        .feature-card:hover {
            transform: translateY(-5px);
            border-color: var(--primary);
            box-shadow: 0 10px 40px rgba(99, 102, 241, 0.2);
        }
        
        .feature-icon {
            font-size: 3rem;
            margin-bottom: 1rem;
        }
        
        h2 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            text-align: center;
        }
        
        h3 {
            font-size: 1.5rem;
            margin-bottom: 0.5rem;
        }
        
        @media (max-width: 768px) {
            .hamburger {
                display: flex;
            }
            
            .nav-links {
                position: fixed;
                top: 70px;
                right: -100%;
                flex-direction: column;
                background: rgba(15, 23, 42, 0.98);
                width: 100%;
                max-width: 300px;
                padding: 2rem;
                gap: 1.5rem;
                transition: right 0.3s ease;
            }
            
            .nav-links.active {
                right: 0;
            }
            
            .hero-title {
                font-size: 2.5rem;
            }
            
            .grid {
                grid-template-columns: 1fr;
            }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// SCRIPT (JavaScript) - Vue <script> equivalent
// ═══════════════════════════════════════════════════════════════════════════

fn get_scripts() -> str {
    yield "
        // Hamburger menu toggle
        const hamburger = document.getElementById('hamburger');
        const navLinks = document.getElementById('navLinks');
        
        hamburger.addEventListener('click', () => {
            hamburger.classList.toggle('active');
            navLinks.classList.toggle('active');
        });
        
        // Close menu when clicking on a link
        navLinks.querySelectorAll('a').forEach(link => {
            link.addEventListener('click', () => {
                hamburger.classList.remove('active');
                navLinks.classList.remove('active');
            });
        });
        
        // Smooth scroll
        document.querySelectorAll('a[href^=\"#\"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                check (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    "
}

// ═══════════════════════════════════════════════════════════════════════════
// MAIN - Combine everything (like Vue's export default)
// ═══════════════════════════════════════════════════════════════════════════

fn main() {
    println("🚀 Starting Nova Server...")
    
    // Create SEO config
    let seo = SEOConfig::new(
        "⚡ Nova - The Future of Programming",
        "Multi-domain governance • Cryptographic ownership • Open source friendly • Formally verified"
    )
    .with_keywords(["programming language", "native", "performance", "nova", "governance"])
    .with_og_image("https://Nova.dev/og.png")
    
    // Create web component (Vue-like SFC)
    let component = WebComponent::new("Nova Homepage")
        .with_template(render_template)
        .with_styles(get_styles())
        .with_script(get_scripts())
    
    // Create app
    let app = App::new_with_seo("https://Nova.dev")
    
    // Homepage - Render the component
    app.get("/", |ctx| {
        let html = component.render_with_seo(seo)
        yield html(html)
    })
    
    // API endpoints
    app.get("/api/info", |ctx| {
        yield json({
            "name": "Nova",
            "version": "1.0",
            "port": 1234,
            "language": "Nova",
            "sfc": "Single File Component - Like Vue.js!"
        })
    })
    
    println("✅ Nova online at http://localhost:1234")
    println("📦 Using Single File Component (SFC) architecture - Vue.js style!")
    app.listen(1234)
}