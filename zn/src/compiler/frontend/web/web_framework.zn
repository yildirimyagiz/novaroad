        -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 1rem; }
.tagline { font-size: 1.4rem; color: #94A3B8; margin-bottom: 2rem; }
.badge   { background: var(--accent); color: white; padding: .3rem .8rem; border-radius: 999px; font-size: .85rem; }
.features { display: flex; gap: 1.5rem; justify-content: center; margin-top: 3rem; flex-wrap: wrap; }
