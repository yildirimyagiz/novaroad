    }
}

// ── Reaktif Todo bileşeni (YENİ: Signal kullanımı) ───────────────────────────

open data Todo {
    open id:   i64,
    open text: String,
    open done: bool,
}

open data TodoApp {
    todos:  Signal<Vec<Todo>>,
    next_id: Signal<i64>,
}

impl TodoApp {
    open fn new() -> TodoApp {
        TodoApp {
            todos:   Signal::new([]),
            next_id: Signal::new(1),
        }
    }

    open fn add(&var self, text: String) {
        let id = *self.next_id.get();
        self.next_id.update(|n| n + 1);
        self.todos.update(|var todos| {
            todos.push(Todo { id, text, done: false });
            yield todos;
        });
    }

    open fn toggle(&var self, id: i64) {
        self.todos.update(|todos| {
            todos.iter().map(|t| {
                check t.id == id { Todo { done: !t.done, ..t.clone() } }
                else { t.clone() }
            }).collect()
        });
    }
}

impl TodoApp for View {
    fn render(&self) -> String {
        let todos = self.todos.get();
        let items: Vec<String> = todos.iter().map(|t| {
            let check_cls = check t.done { "done" } else { "" };
            format("<li class='{}' onclick='toggle({})'>{}
                     <span class='id'>#{}</span></li>",
                check_cls, t.id, t.text, t.id)
        }).collect();

        format("""
<div class="todo-app">
    <h2>Yapılacaklar</h2>
    <div class="add-bar">
        <input id="new-todo" placeholder="Yeni görev...">
        <button onclick="addTodo()">+ Ekle</button>
    </div>
    <ul class="todo-list">{}</ul>
    <div class="stats">{} / {} tamamlandı</div>
</div>
        """,
        items.join(""),
        todos.iter().filter(|t| t.done).count(),
        todos.len())
    }

    fn style(&self) -> String {
        yield """
.todo-app   { max-width: 480px; margin: 3rem auto; padding: 2rem; background: #1E1E2E;
              border-radius: 16px; box-shadow: 0 8px 32px rgba(0,0,0,.5); }
h2          { margin: 0 0 1.5rem; color: #7C3AED; }
.add-bar    { display: flex; gap: .5rem; margin-bottom: 1.5rem; }
input       { flex: 1; padding: .6rem 1rem; border-radius: 8px; border: 1px solid #2D2D44;
              background: #0F0F1A; color: #E2E8F0; }
button      { padding: .6rem 1.2rem; background: #7C3AED; color: white;
              border: none; border-radius: 8px; cursor: pointer; }
.todo-list  { list-style: none; padding: 0; margin: 0; }
.todo-list li { padding: .8rem 1rem; border-bottom: 1px solid #2D2D44;
                cursor: pointer; display: flex; justify-content: space-between;
                transition: background .15s; }
.todo-list li:hover { background: #2D2D44; }
.done       { text-decoration: line-through; opacity: .5; }
.stats      { margin-top: 1rem; font-size: .85rem; color: #64748B; text-align: right; }
        """.into();
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §9  GİRİŞ NOKTASI
// ══════════════════════════════════════════════════════════════════════════════

open fn main() {
    let server = NovaServer::new(8080)
        .use_middleware(Box::new(Logger::new()))
        .use_middleware(Box::new(Cors::allow_all()))
        .register("home".into(), Box::new(HomePage::new()))
        .register("todos".into(), Box::new(TodoApp::new()))
        .get("/".into(), "home".into())
        .get("/todos".into(), "todos".into());

    server.start();
}