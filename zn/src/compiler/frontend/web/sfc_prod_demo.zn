// 🚀 Nova Nova-Serve v4.0 Demo
// Layered Sovereignty: Core SSR + Hydrogen Reactivity

import web.nova_serve as ws
import std.collections::HashMap

// 1. Template with State/Props isolation
fn hero_template(props: HashMap<String, String>, state: HashMap<String, String>) -> VNode {
    let title = props.get("title").unwrap_or("Default Title");
    h("section", HashMap::from([("class", "hero")]), [
        h("h1", {}, [VNode.text(title)]),
        h("button", HashMap::from([("id", "cta-btn")]), [VNode.text("Click Me")])
    ])
}

let hero_styles = "
    .hero { background: #1a1a2e; padding: 4rem; text-align: center; }
    h1 { color: #e94560; font-size: 3rem; }
    #cta-btn { border: 2px solid #e94560; background: none; color: white; padding: 10px 20px; cursor: pointer; }
";

let hero_script = "
    const btn = document.querySelector('#cta-btn');
    btn.addEventListener('click', () => {
        alert('Action from v4.0 Layered Component!');
    });
";

fn main() {
    println("🚀 Launching Nova-Serve v4.0 (Layered Sovereignty)...");

    // Initialize Web Infrastructure
    let platform = ws::SEOPlatform::new();
    let security = ws::SecurityPolicy::new();
    let server = ws::WebServer { platform, security };

    // Create Component with Props and Initial State
    var props = HashMap::new();
    props.insert("title".into(), "Nova v4.0 Production".into());

    let hero_component = ws::NovaComponent {
        name: "Hero".into(),
        template: hero_template,
        css: hero_styles.into(),
        script: hero_script.into(),
        props,
        initial_state: HashMap::new(),
    };

    // Build Page
    let page_html = server.build_page(
        "Nova v4.0 PROD",
        [hero_component],
        None
    );

    println("--------------------------------------------------");
    println("✅ Page Rendered via Layered Architecture");
    println("🛡️ Thread-Safe Registry: Active");
    println("🌊 O(n) Diffing Engine: Injected");
    println("--------------------------------------------------");
    
    // In a real environment, the server would serve page_html
}