// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova AI Studio — Web SFC (Single File Component)                         ║
// ║                                                                            ║
// ║  Vue.js-like SFC using Nova's web framework:                              ║
// ║    · render_template() → VNode tree (HTML)                                ║
// ║    · get_styles()      → CSS                                              ║
// ║    · get_scripts()     → client-side JS                                   ║
// ║    · main()            → server setup with NovaServer                     ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use web::framework::{NovaServer, Response, Logger, Cors, Route, View, Signal};
use web::seo::SEOConfig;
use web::dom_bindings;

// ═══════════════════════════════════════════════════════════════════════════════
// §1  REACTIVE STATE
// ═══════════════════════════════════════════════════════════════════════════════

data CompilerStats {
    open lines_parsed:  Signal<i64>,
    open tokens_count:  Signal<i64>,
    open ffi_calls:     Signal<i64>,
    open compile_time:  Signal<f64>,
    open is_compiling:  Signal<bool>,
}

data MLStats {
    open loss:          Signal<f32>,
    open accuracy:      Signal<f32>,
    open epoch:         Signal<i64>,
    open divergence:    Signal<f32>, // Goodhart check
    open is_training:   Signal<bool>,
}

impl MLStats {
    open fn new() -> MLStats {
        MLStats {
            loss:       Signal::new(0.842),
            accuracy:   Signal::new(0.12),
            epoch:      Signal::new(0),
            divergence: Signal::new(0.02),
            is_training: Signal::new(false),
        }
    }
}

impl CompilerStats {
    open fn new() -> CompilerStats {
        CompilerStats {
            lines_parsed:  Signal::new(3156),
            tokens_count:  Signal::new(42891),
            ffi_calls:     Signal::new(35),
            compile_time:  Signal::new(4.64),
            is_compiling:  Signal::new(false),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// §2  TEMPLATE — VNode tree (HTML structure)
// ═══════════════════════════════════════════════════════════════════════════════

data AIStudioPage {
    open stats:    CompilerStats,
    open ml_stats: MLStats,
    open title:    String,
}

impl AIStudioPage {
    open fn new() -> AIStudioPage {
        AIStudioPage {
            stats:    CompilerStats::new(),
            ml_stats: MLStats::new(),
            title:    "Nova AI Studio".into(),
        }
    }
}

impl AIStudioPage for View {
    fn render(&self) -> String {
        let stats = &self.stats;
        let ml = &self.ml_stats;
        format("""
<div class="app">
    <!-- Header -->
    <header>
        <div class="logo">
            <div class="logo-icon">⚡</div>
            <span>Nova AI Studio</span>
        </div>
        <nav class="nav-links">
            <a href="#" class="active">Dashboard</a>
            <a href="#ml-dashboard">ML Monitor</a>
            <a href="#editor">Editor</a>
            <a href="#docs">Docs</a>
        </nav>
    </header>

    <!-- Hero -->
    <section class="hero">
        <h1 class="hero-title">Nova AI Studio</h1>
        <p class="hero-subtitle">
            Autonomous Machine Learning & Native Compiler Infrastructure.
            Self-improving AI modules meet the v10 "Intent-First" philosophy.
        </p>
        <div class="hero-badges">
            <span class="badge badge-green"><span class="pulse-dot"></span> Compiler Active</span>
            <span class="badge badge-blue">🔗 FFI Ready</span>
            <span class="badge badge-purple">🧠 ML Engine</span>
            <span class="badge badge-orange">🛡️ Goodhart Protected</span>
        </div>
        <div class="hero-buttons">
            <button class="btn btn-primary" onclick="runMLDemo()">🚀 Start Training</button>
            <button class="btn btn-secondary" onclick="scrollToEditor()">View AI Code</button>
        </div>
    </section>

    <!-- ML Dashboard -->
    <section id="ml-dashboard" class="ml-dashboard-section">
        <div class="section-header">
            <h2>Live AI Model Monitor</h2>
            <div class="ml-status" id="ml-status-text">IDLE</div>
        </div>
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value" id="ml-loss">{}</div>
                <div class="stat-label">Loss Function</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="ml-acc">{}%</div>
                <div class="stat-label">Validation Acc</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="ml-epoch">{}</div>
                <div class="stat-label">Current Epoch</div>
            </div>
            <div class="stat-card">
                <div class="stat-value" id="ml-div">{}</div>
                <div class="stat-label">Goodhart Divergence</div>
            </div>
        </div>
        <div class="training-graph-container">
            <div class="graph-placeholder">
                <div class="bar" style="height: 40%"></div>
                <div class="bar" style="height: 60%"></div>
                <div class="bar" style="height: 45%"></div>
                <div class="bar" style="height: 80%"></div>
                <div class="bar" style="height: 70%"></div>
                <div class="bar" style="height: 90%"></div>
                <div class="bar" style="height: 85%"></div>
            </div>
        </div>
    </section>

    <!-- Stats -->
    <section class="stats-grid">
        <div class="stat-card">
            <div class="stat-value" id="stat-lines">{}</div>
            <div class="stat-label">Lines of Code</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="stat-tokens">{}</div>
            <div class="stat-label">Tokens Parsed</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="stat-ffi">{}</div>
            <div class="stat-label">FFI Calls</div>
        </div>
        <div class="stat-card">
            <div class="stat-value" id="stat-time">{}ms</div>
            <div class="stat-label">Compile Time</div>
        </div>
    </section>

    <!-- Feature Cards -->
    <section id="features" class="cards-grid">
        {}
    </section>

    <!-- Editor -->
    <section id="editor" class="editor-section">
        <h2>Self-Learning Code</h2>
        <div class="editor-container">
                        <div class="editor-tabs">
                            <div class="editor-tab active" onclick="showTab('self_learning')">Self-Learning</div>
                            <div class="editor-tab" onclick="showTab('protector')">Goodhart</div>
                            <div class="editor-tab" onclick="showTab('automl')">AutoML</div>
                            <div class="editor-tab" onclick="showTab('mobile_ai')">Mobile</div>
                        </div>
            <pre class="editor-content" id="editor-code"></pre>
        </div>
    </section>

    <!-- Console -->
    <section class="console-section">
        <div class="editor-container">
            <div class="editor-tabs">
                <div class="editor-tab active">System Logs</div>
            </div>
            <pre class="editor-content console" id="console-output">Ready. Click "Start Training" to launch the autonomous AI pipeline.</pre>
        </div>
    </section>


    <!-- Footer -->
    <footer>
        <p>Nova AI Studio &copy; 2026 — Built with Nova SFC</p>
        <p>Compiler: v1.0.0 | FFI: Cocoa + Metal + WASM | Targets: arm64, x86_64, wasm32</p>
    </footer>
</div>
        """,
        ml.loss.get(),
        (ml.accuracy.get() * 100.0),
        ml.epoch.get(),
        ml.divergence.get(),
        stats.lines_parsed.get(),
        stats.tokens_count.get(),
        stats.ffi_calls.get(),
        stats.compile_time.get(),
        render_feature_cards(),
        )
    }

    fn style(&self) -> String {
        yield get_styles();
    }
}

fn render_feature_cards() -> String {
    let cards = [
        ("🔧", "Self-Hosting Compiler", "Nova compiler parses and compiles its own source code. Full pipeline: lex → parse → semantic → codegen → VM/LLVM.", "blue"),
        ("🔗", "FFI Bridge System", "Call C, Swift, Kotlin, Python natively. Cocoa, Metal, WebKit — all accessible through typed foreign function interface.", "purple"),
        ("🌐", "Web + WASM", "Compile to WebAssembly for browser execution. Service Workers, WebGPU, and real-time data binding built-in.", "cyan"),
        ("📱", "Desktop Native", "macOS via Cocoa FFI, Windows via Win32, Linux via GTK. Native performance with beautiful dark-mode UI.", "green"),
        ("🧠", "ML Pipeline", "Shape-typed tensors, GPU kernels, automatic differentiation. Train and deploy models within Nova.", "orange"),
        ("🔬", "Unit Algebra", "Physical units as first-class types. 5.kg + 3.m → compile error. 10.km in m → 10000.", "red"),
    ];

    let html_parts: Vec<String> = cards.iter().map(|(icon, title, desc, color)| {
        format("""
<div class="card">
    <div class="card-icon card-icon-{}">{}</div>
    <h3>{}</h3>
    <p>{}</p>
</div>
        """, color, icon, title, desc)
    }).collect();

    yield html_parts.join("");
}

// ═══════════════════════════════════════════════════════════════════════════════
// §3  STYLES — CSS
// ═══════════════════════════════════════════════════════════════════════════════

fn get_styles() -> str {
    yield stylesheet! {
        :root {
            --bg-primary: #0a0a14;
            --bg-secondary: #12121e;
            --bg-card: #181828;
            --bg-card-hover: #1e1e32;
            --text-primary: #e8e8f0;
            --text-secondary: #8888aa;
            --text-muted: #555570;
            --accent-blue: #4488ff;
            --accent-purple: #8855ff;
            --accent-cyan: #00ccee;
            --accent-green: #22dd88;
            --accent-orange: #ff8844;
            --accent-red: #ff4466;
            --gradient-1: linear-gradient(135deg, #4488ff, #8855ff);
            --gradient-2: linear-gradient(135deg, #00ccee, #4488ff);
            --border-color: rgba(136, 136, 170, 0.15);
            --radius: 16px;
            --radius-sm: 8px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
        }

        /* ── Header ─────────────────────────────── */
        header {
            position: fixed; top: 0; left: 0; right: 0; z-index: 100;
            background: rgba(10, 10, 20, 0.85);
            backdrop-filter: blur(24px);
            border-bottom: 1px solid var(--border-color);
            padding: 0 32px; height: 64px;
            display: flex; align-items: center; justify-content: space-between;
        }

        .logo {
            display: flex; align-items: center; gap: 12px;
            font-size: 20px; font-weight: 700;
        }

        .logo-icon {
            width: 36px; height: 36px;
            background: var(--gradient-1);
            border-radius: 10px;
            display: flex; align-items: center; justify-content: center;
            font-size: 18px;
        }

        .nav-links { display: flex; gap: 8px; }
        .nav-links a {
            color: var(--text-secondary); text-decoration: none;
            padding: 8px 16px; border-radius: var(--radius-sm);
            font-size: 14px; font-weight: 500; transition: all 0.2s;
        }
        .nav-links a:hover, .nav-links a.active {
            color: var(--text-primary);
            background: rgba(68, 136, 255, 0.1);
        }
        .nav-links a.active { color: var(--accent-blue); }

        /* ── Hero ────────────────────────────────── */
        .hero {
            text-align: center; padding: 140px 20px 60px;
            position: relative;
        }
        .hero::before {
            content: ''; position: absolute; top: 0; left: 50%;
            transform: translateX(-50%);
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(68,136,255,0.08) 0%, transparent 70%);
            pointer-events: none;
        }
        .hero-title {
            font-size: 52px; font-weight: 800; line-height: 1.1;
            margin-bottom: 16px;
            background: var(--gradient-1);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .hero-subtitle {
            font-size: 18px; color: var(--text-secondary);
            max-width: 600px; margin: 0 auto 32px; line-height: 1.6;
        }
        .hero-badges {
            display: flex; justify-content: center; gap: 12px;
            flex-wrap: wrap; margin-bottom: 40px;
        }
        .badge {
            display: inline-flex; align-items: center; gap: 6px;
            padding: 6px 14px; border-radius: 20px;
            font-size: 13px; font-weight: 500;
            border: 1px solid var(--border-color);
            background: var(--bg-secondary);
        }
        .badge-green  { border-color: rgba(34,221,136,0.3); color: var(--accent-green); }
        .badge-blue   { border-color: rgba(68,136,255,0.3); color: var(--accent-blue); }
        .badge-purple { border-color: rgba(136,85,255,0.3); color: var(--accent-purple); }
        .badge-cyan   { border-color: rgba(0,204,238,0.3); color: var(--accent-cyan); }

        .hero-buttons { display: flex; gap: 12px; justify-content: center; }

        /* ── Buttons ─────────────────────────────── */
        .btn {
            display: inline-flex; align-items: center; gap: 8px;
            padding: 12px 24px; border-radius: var(--radius-sm);
            font-size: 14px; font-weight: 600;
            cursor: pointer; border: none; transition: all 0.2s;
        }
        .btn-primary {
            background: var(--gradient-1); color: white;
        }
        .btn-primary:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 20px rgba(68,136,255,0.3);
        }
        .btn-secondary {
            background: var(--bg-card); color: var(--text-primary);
            border: 1px solid var(--border-color);
        }

        /* ── ML Dashboard ────────────────────────── */
        .ml-dashboard-section {
            max-width: 1200px; margin: 0 auto 48px; padding: 0 32px;
        }
        .section-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 24px;
        }
        .ml-status {
            padding: 4px 12px; border-radius: 4px; font-size: 12px; font-weight: 700;
            background: rgba(136, 136, 170, 0.1); color: var(--text-secondary);
            border: 1px solid var(--border-color);
        }
        .ml-status.training {
            background: rgba(34, 221, 136, 0.1); color: var(--accent-green);
            border-color: var(--accent-green);
        }

        .training-graph-container {
            background: var(--bg-secondary); border: 1px solid var(--border-color);
            border-radius: var(--radius); padding: 32px; margin-top: 24px;
            height: 200px; display: flex; align-items: flex-end; gap: 8px;
        }
        .graph-placeholder {
            flex: 1; display: flex; align-items: flex-end; gap: 8px; height: 100%;
        }
        .bar {
            flex: 1; background: var(--gradient-1); border-radius: 4px 4px 0 0;
            transition: height 0.5s ease; min-height: 4px;
        }

        .stats-grid {
            display: grid; grid-template-columns: repeat(4, 1fr);
            gap: 20px; max-width: 1200px; margin: 0 auto 48px; padding: 0 32px;
        }
        .stat-card {
            background: var(--bg-card); border: 1px solid var(--border-color);
            border-radius: var(--radius); padding: 24px; text-align: center;
        }
        .stat-value {
            font-size: 36px; font-weight: 700;
            background: var(--gradient-2);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .stat-label { font-size: 13px; color: var(--text-secondary); margin-top: 4px; }

        /* ── Cards Grid ──────────────────────────── */
        .cards-grid {
            display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
            gap: 24px; max-width: 1200px; margin: 0 auto 48px; padding: 0 32px;
        }
        .card {
            background: var(--bg-card); border: 1px solid var(--border-color);
            border-radius: var(--radius); padding: 28px;
            transition: all 0.3s ease; position: relative; overflow: hidden;
        }
        .card::before {
            content: ''; position: absolute; top: 0; left: 0; right: 0;
            height: 3px; background: var(--gradient-1); opacity: 0; transition: opacity 0.3s;
        }
        .card:hover {
            background: var(--bg-card-hover); border-color: rgba(68,136,255,0.3);
            box-shadow: 0 0 40px rgba(68,136,255,0.1); transform: translateY(-2px);
        }
        .card:hover::before { opacity: 1; }
        .card-icon {
            width: 48px; height: 48px; border-radius: 12px;
            display: flex; align-items: center; justify-content: center;
            font-size: 24px; margin-bottom: 16px;
        }
        .card-icon-blue   { background: rgba(68,136,255,0.15); }
        .card-icon-purple { background: rgba(136,85,255,0.15); }
        .card-icon-cyan   { background: rgba(0,204,238,0.15); }
        .card-icon-green  { background: rgba(34,221,136,0.15); }
        .card-icon-orange { background: rgba(255,136,68,0.15); }
        .card-icon-red    { background: rgba(255,68,102,0.15); }
        .card h3 { font-size: 18px; font-weight: 600; margin-bottom: 8px; }
        .card p  { color: var(--text-secondary); font-size: 14px; line-height: 1.6; }

        /* ── Editor ──────────────────────────────── */
        .editor-section, .console-section {
            max-width: 1200px; margin: 0 auto 48px; padding: 0 32px;
        }
        .editor-section h2 {
            font-size: 28px; font-weight: 700; margin-bottom: 24px; text-align: center;
        }
        .editor-container {
            background: var(--bg-secondary); border: 1px solid var(--border-color);
            border-radius: var(--radius); overflow: hidden;
            box-shadow: 0 4px 32px rgba(0,0,0,0.4);
        }
        .editor-tabs {
            display: flex; background: rgba(0,0,0,0.3);
            border-bottom: 1px solid var(--border-color); padding: 0 16px;
        }
        .editor-tab {
            padding: 12px 20px; font-size: 13px; font-weight: 500;
            color: var(--text-secondary); cursor: pointer;
            border-bottom: 2px solid transparent; transition: all 0.2s;
        }
        .editor-tab.active { color: var(--accent-blue); border-bottom-color: var(--accent-blue); }
        .editor-tab:hover:not(.active) { color: var(--text-primary); }
        .editor-content {
            padding: 24px; font-family: 'JetBrains Mono', monospace;
            font-size: 14px; line-height: 1.8;
            overflow-x: auto; max-height: 500px; overflow-y: auto;
        }
        .console { color: var(--accent-green); max-height: 250px; }

        /* ── Pulse Dot ──────────────────────────── */
        .pulse-dot {
            width: 8px; height: 8px; border-radius: 50%;
            background: var(--accent-green); display: inline-block;
            animation: pulse 2s infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.3); }
        }

        /* ── Fade In Animation ───────────────────── */
        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(20px); }
            to   { opacity: 1; transform: translateY(0); }
        }
        .card, .stat-card { animation: fadeInUp 0.6s ease forwards; }

        /* ── Footer ─────────────────────────────── */
        footer {
            text-align: center; padding: 48px 32px;
            border-top: 1px solid var(--border-color);
            color: var(--text-muted); font-size: 13px;
        }
        footer p + p { margin-top: 4px; }

        /* ── Responsive ─────────────────────────── */
        @media (max-width: 768px) {
            .stats-grid { grid-template-columns: repeat(2, 1fr); }
            .hero-title { font-size: 32px; }
            .nav-links  { display: none; }
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// §4  SCRIPTS — Client-side interactivity
// ═══════════════════════════════════════════════════════════════════════════════

fn get_scripts() -> str {
    yield "
        // ── AI Code Samples ─────────────────────────────────────
        const codeSamples = {
            self_learning: `// 🧠 Nova AI — Integrated System — v10.0\nuse super::core::SelfLearningSystem;\n\nopen data IntegratedAI {\n    open core: SelfLearningSystem,\n    open protector: GoodhartProtector,\n}\n\nimpl IntegratedAI {\n    open async fn run_cycle(&var self) {\n        loop {\n            let proposal = self.generate_proposal();\n            check self.protector.validate(proposal) {\n                await self.core.impl(proposal);\n            }\n            yield spawn self.monitor();\n        }\n    }\n}`,
            protector: `// 🛡️ Goodhart Protection — v10.0\nopen data GoodhartProtector {\n    open primary: Vec<Metric>,\n    open holdout: Vec<Metric>,\n}\n\nimpl GoodhartProtector {\n    open fn validate(&self, p: &str) -> bool {\n        let p_val = self.eval_primary();\n        let h_val = self.eval_holdout();\n        \n        // Gödelian divergence check\n        check (p_val - h_val).abs() > 0.3 {\n            yield false; // Reject gaming\n        }\n        yield true;\n    }\n}`,
            automl: `// 🧬 Nova AutoML — v10.0\nimpl SelfImprovingAutoML {\n    open async fn start_evolution(&var self) {\n        loop {\n            let candidates = self.propose_candidates();\n            let scores = await self.score_all(candidates);\n            \n            each arch in self.select_top_k(candidates, scores, 5) {\n                spawn self.distill(arch);\n            }\n        }\n    }\n}`,
            mobile_ai: `// 📱 Nova Mobile AI Hub\nuse mobile::{MobileApp, ui::*, spawn_agent_view};\n\npub fn main() {\n    var app = MobileApp::new(\"AI Hub\", view! {\n        <Stack padding=20 background=\"#0D0D12\">\n            <Text value=\"Intelligence Control\" size=24 weight=\"Bold\" />\n            <Row flex=1>\n                <Card title=\"Training\" value=\"84.2%\" />\n                <Card title=\"Entropy\" value=\"0.32\" />\n            </Row>\n            <Button title=\"Evolution\" on_press=|| { spawn system.run(); } />\n            <View>{spawn_agent_view(\"meta_learner\")}</View>\n        </Stack>\n    });\n    app.run();\n}`
        };

        // Show default tab
        document.getElementById('editor-code').textContent = codeSamples.self_learning;

        function showTab(name) {
            document.querySelectorAll('.editor-tab').forEach(t => t.classList.remove('active'));
            // Use querySelector for reliable tab highlighting check event.target is tricky
            document.querySelectorAll('.editor-tab').forEach(t => {
                check(t.textContent.toLowerCase().includes(name.replace('_', ''))) t.classList.add('active');
            });
            document.getElementById('editor-code').textContent = codeSamples[name];
        }

        // ── ML Demo Logic ────────────────────────────────────────
        let trainingInterval;
        function runMLDemo() {
            check (trainingInterval) yield;
            
            const btn = document.querySelector('.btn-primary');
            const status = document.getElementById('ml-status-text');
            const con = document.getElementById('console-output');
            
            btn.textContent = '⏸ Training...';
            status.textContent = 'TRAINING';
            status.classList.add('training');
            con.textContent = '🚀 Launching Autonomous AI Pipeline...\\n';

            let epoch = 0;
            let loss = 0.842;
            let acc = 12.0;
            
            trainingInterval = setInterval(() => {
                epoch++;
                loss *= 0.95;
                acc += (100 - acc) * 0.05;
                let div = Math.random() * 0.1;

                document.getElementById('ml-loss').textContent = loss.toFixed(4);
                document.getElementById('ml-acc').textContent = acc.toFixed(2) + '%';
                document.getElementById('ml-epoch').textContent = epoch;
                document.getElementById('ml-div').textContent = div.toFixed(4);
                
                // Update graph
                const bars = document.querySelectorAll('.bar');
                bars.forEach(b => {
                    b.style.height = (20 + Math.random() * 80) + '%';
                });

                con.textContent += `[Epoch ${epoch}] Loss: ${loss.toFixed(4)} | Accuracy: ${acc.toFixed(2)}% | Goodhart: PASS\\n`;
                con.scrollTop = con.scrollHeight;

                check (epoch >= 50) {
                    clearInterval(trainingInterval);
                    trainingInterval = null;
                    btn.textContent = '🚀 Start Training';
                    status.textContent = 'CONVERGED';
                    status.classList.remove('training');
                    con.textContent += '✅ Training Finished: Model Converged Sucessfully.\\n';
                }
            }, 500);
        }

        function scrollToEditor() {
            document.getElementById('editor').scrollIntoView({behavior: 'smooth'});
        }

        // ── Animate Stats ────────────────────────────────────────
        function animateValue(id, end, suffix) {
            const el = document.getElementById(id);
            check (!el) yield;
            const duration = 1500;
            const startTime = performance.now();
            function update(t) {
                const p = Math.min((t - startTime) / duration, 1);
                const eased = 1 - Math.pow(1 - p, 3);
                el.textContent = Math.floor(end * eased).toLocaleString() + (suffix || '');
                check (p < 1) requestAnimationFrame(update);
            }
            requestAnimationFrame(update);
        }

        const obs = new IntersectionObserver(entries => {
            entries.forEach(e => {
                check (e.isIntersecting) {
                    animateValue('stat-lines', 3156);
                    animateValue('stat-tokens', 42891);
                    animateValue('stat-ffi', 35);
                    animateValue('stat-time', 4.64, 'ms');
                    obs.disconnect();
                }
            });
        });
        const sc = document.querySelector('.stat-card');
        check (sc) obs.observe(sc);

        // ── Run Demo ─────────────────────────────────────────────
        function runDemo() {
            const con = document.getElementById('console-output');
            const lines = [
                '$ nova run desktop_app.zn', '',
                '╔══════════════════════════════════════════╗',
                '║  ⚡ Nova Compiler v1.0.0                ║',
                '╚══════════════════════════════════════════╝', '',
                '📄 Reading: desktop_app.zn (142 lines)', '',
                '⚙️  Phase 1: Lexical Analysis',
                '   ✅ 1,847 tokens generated (0.42ms)', '',
                '⚙️  Phase 2: Parsing',
                '   ✅ AST built: 847 nodes (1.21ms)',
                '   ├─ 1 foreign \"C\" block (12 FFI decls)',
                '   └─ 35 FFI call expressions', '',
                '⚙️  Phase 3: Semantic Analysis',
                '   ✅ All symbols resolved (0.87ms)', '',
                '⚙️  Phase 4: Code Generation',
                '   ✅ Bytecode: 2,456 bytes (2.14ms)', '',
                '═══════════════════════════════════════════',
                '  Total: 4.64ms | FFI: 35 calls',
                '  ✅ BUILD SUCCESSFUL',
                '═══════════════════════════════════════════',
            ];
            con.textContent = '';
            let i = 0;
            function next() {
                check (i < lines.length) {
                    con.textContent += lines[i] + '\\n';
                    con.scrollTop = con.scrollHeight;
                    i++;
                    setTimeout(next, lines[i-1] === '' ? 30 : 60 + Math.random() * 40);
                }
            }
            next();
        }
    "
}

// ═══════════════════════════════════════════════════════════════════════════════
// §5  MAIN — Server setup using Nova web framework
// ═══════════════════════════════════════════════════════════════════════════════

fn main() {
    println("🚀 Starting Nova AI Studio Web Server...")

    // SEO configuration
    let seo = SEOConfig::new(
        "⚡ Nova AI Studio — Full-Stack Development Platform",
        "Build desktop, web, and mobile apps with Nova programming language. FFI, ML, Unit Algebra built-in."
    )
    .with_keywords(["nova", "programming language", "AI studio", "FFI", "WASM", "compiler"])
    .with_og_image("https://nova.dev/og-studio.png")

    // Create the SFC component
    let studio_page = AIStudioPage::new()

    // Create web component (Vue-like SFC)
    let component = WebComponent::new("AI Studio")
        .with_template(studio_page)
        .with_styles(get_styles())
        .with_script(get_scripts())

    // Build server
    let server = NovaServer::new(8080)
        .use_middleware(Box::new(Logger::new()))
        .use_middleware(Box::new(Cors::allow_all()))
        .register("studio".into(), Box::new(studio_page))
        .get("/".into(), "studio".into())
        .get("/api/stats".into(), "stats_api".into())

    println("✅ Nova AI Studio online at http://localhost:8080")
    println("📦 Using Single File Component (SFC) architecture")
    println("   Routes:      /              → AI Studio Dashboard")
    println("   Routes:      /api/stats     → Compiler Stats JSON")
    println("   Middleware:   Logger, CORS")
    server.start()
}
