// ╔═══════════════════════════════════════════════════════════════════════════════╗
// ║                     Nova SSR SUPPORT                                    ║
// ║                   Server-Side Rendering & Hydration                            ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

// Server-Side Rendering support for Nova web applications
// SSR + Client hydration for SEO, performance, and progressive enhancement

use std::collections::HashMap;
use crate::frontend::web::web_framework::*;

// ============================================================================
// SSR CORE
// ============================================================================

/// SSR rendering context
expose data SSRContext {
    is_server: bool,
    request_url: String,
    user_agent: String,
    initial_state: HashMap<String, String>,
    rendered_components: Vec<String>,
}

/// Server-side rendering engine
expose data SSREngine {
    context: SSRContext,
    component_registry: HashMap<String, Box<dyn ServerRenderable>>,
}

/// Component that can be rendered on server
expose ability ServerRenderable {
    fn render_to_string(&self, props: HashMap<String, String>) -> String;
    fn get_initial_state(&self) -> HashMap<String, String>;
    fn get_client_hydration_script(&self) -> String;
}

// ============================================================================
// HYDRATION SYSTEM
// ============================================================================

/// Hydration configuration
expose data HydrationConfig {
    component_selector: String,  // CSS selector for components to hydrate
    progressive: bool,           // Enable progressive hydration
    timeout_ms: i32,            // Hydration timeout
    error_boundary: bool,       // Use error boundaries during hydration
}

/// Hydration engine for client-side reactivation
expose data HydrationEngine {
    config: HydrationConfig,
    hydrated_components: HashMap<String, bool>,
    hydration_queue: Vec<String>,
}

/// Hydration result
expose cases HydrationResult {
    Success(String),     // Component ID that was hydrated
    Failed(String),      // Component ID that failed hydration
    Skipped(String),     // Component ID that was skipped
    Timeout(String),     // Component ID that timed out
}

// ============================================================================
// STATIC SITE GENERATION
// ============================================================================

/// Static site generation configuration
expose data SSGConfig {
    routes: Vec<String>,                    // Routes to pre-generate
    output_dir: String,                     // Output directory
    base_url: String,                       // Base URL for absolute links
    include_sitemap: bool,                  // Generate sitemap.xml
    include_robots_txt: bool,               // Generate robots.txt
}

/// SSG build result
expose data SSGBuildResult {
    generated_pages: Vec<SSGPage>,
    sitemap_path: Option<String>,
    robots_txt_path: Option<String>,
    total_build_time_ms: i64,
}

/// Generated page information
expose data SSGPage {
    route: String,
    output_path: String,
    html_content: String,
    initial_state: HashMap<String, String>,
    meta_tags: Vec<MetaTag>,
}

/// HTML meta tag
expose data MetaTag {
    name: String,
    content: String,
    property: Option<String>,  // For Open Graph
}

// ============================================================================
// ROUTING & NAVIGATION
// ============================================================================

/// Server-side routing configuration
expose data ServerRouter {
    routes: HashMap<String, RouteHandler>,
    middleware: Vec<Box<dyn Middleware>>,
    error_handlers: HashMap<i32, Box<dyn ErrorHandler>>,
}

/// Route handler rules
expose ability RouteHandler {
    fn handle_route(&self, request: ServerRequest) -> Task<ServerResponse>;
}

/// Middleware rules for request processing
expose ability Middleware {
    fn process_request(&self, request: &var ServerRequest) -> Result<(), MiddlewareError>;
    fn process_response(&self, response: &var ServerResponse) -> Result<(), MiddlewareError>;
}

/// Error handler for HTTP errors
expose ability ErrorHandler {
    fn handle_error(&self, status_code: i32, error: Option<String>) -> ServerResponse;
}

// ============================================================================
// SERVER REQUEST/RESPONSE
// ============================================================================

/// Server-side HTTP request
expose data ServerRequest {
    method: String,
    url: String,
    headers: HashMap<String, String>,
    query_params: HashMap<String, String>,
    body: Option<String>,
    cookies: HashMap<String, String>,
    user_agent: String,
    ip_address: String,
}

/// Server-side HTTP response
expose data ServerResponse {
    status_code: i32,
    headers: HashMap<String, String>,
    body: String,
    content_type: String,
    cookies: Vec<Cookie>,
}

/// HTTP cookie
expose data Cookie {
    name: String,
    value: String,
    path: Option<String>,
    domain: Option<String>,
    max_age: Option<i64>,
    secure: bool,
    http_only: bool,
    same_site: Option<String>,
}

// ============================================================================
// STREAMING SSR
// ============================================================================

/// Streaming SSR configuration
expose data StreamingSSRConfig {
    enable_streaming: bool,
    chunk_size: usize,
    priority_chunks: Vec<String>,  // Component IDs to prioritize
    suspense_fallback: String,     // HTML for suspense boundaries
}

/// Streaming renderer
expose data StreamingRenderer {
    config: StreamingSSRConfig,
    stream_buffer: Vec<u8>,
    pending_components: HashMap<String, Box<dyn ServerRenderable>>,
}

/// Stream chunk types
expose cases StreamChunk {
    Html(String),
    ComponentData(String, HashMap<String, String>),
    Script(String),
    Style(String),
    End,
}

// ============================================================================
// PERFORMANCE OPTIMIZATION
// ============================================================================

/// SSR performance metrics
expose data SSRMetrics {
    total_render_time_ms: i64,
    component_render_times: HashMap<String, i64>,
    memory_usage_bytes: usize,
    cache_hit_ratio: f64,
}

/// SSR caching configuration
expose data SSRCache {
    enable_caching: bool,
    cache_ttl_seconds: i64,
    cache_key_generator: Box<dyn CacheKeyGenerator>,
    cache_backend: Box<dyn CacheBackend>,
}

/// Cache key generation rules
expose ability CacheKeyGenerator {
    fn generate_key(&self, request: &ServerRequest) -> String;
}

/// Cache backend rules
expose ability CacheBackend {
    fn get(&self, key: String) -> Option<String>;
    fn set(&self, key: String, value: String, ttl_seconds: i64);
    fn invalidate(&self, pattern: String);
}

// ============================================================================
// ERROR TYPES
// ============================================================================

expose cases MiddlewareError {
    RequestProcessingFailed(String),
    ResponseProcessingFailed(String),
}

expose cases SSRError {
    ComponentRenderFailed(String),
    HydrationFailed(String),
    RoutingError(String),
    TemplateError(String),
}

// ============================================================================
// UTILITY FUNCTIONS
// ============================================================================

impl SSRUtils {

    /// Create basic HTML document with SSR content
    open fn create_html_document(
        title: String,
        head_content: String,
        body_content: String,
        initial_state: HashMap<String, String>
    ) -> String {
        let state_json = self::serialize_state_to_json(initial_state);

        yield format(r#"<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{}</title>
    {}
    <script>
        window.__INITIAL_STATE__ = {};
    </script>
</head>
<body>
    <div id="root">{}</div>
    <script src="/client.js"></script>
</body>
</html>"#, title, head_content, state_json, body_content);
    }

    /// Serialize state to JSON for client hydration
    fn serialize_state_to_json(state: HashMap<String, String>) -> String {
        var json = "{".into();
        var first = true;

        each entry in state.iter()  { let (key, value) = entry;
            check !first { json.push_str(","); }
            json.push_str(&format("\"{}\":\"{}\"", self::escape_json_string(key), self::escape_json_string(value)));
            first = false;
        }
        json.push_str("}");

        yield json;
    }

    /// Escape string for JSON
    fn escape_json_string(s: &str) -> String {
        s.replace("\\", "\\\\")
         .replace("\"", "\\\"")
         .replace("\n", "\\n")
         .replace("\r", "\\r")
         .replace("\t", "\\t")
    }

    /// Generate meta tags for SEO
    open fn generate_meta_tags(tags: Vec<MetaTag>) -> String {
        var html = String::new();

        each tag in tags {
            check let Some(property) = tag.property {
                html.push_str(&format("<meta property=\"{}\" content=\"{}\" />\n", property, tag.content));
            } else {
                html.push_str(&format("<meta name=\"{}\" content=\"{}\" />\n", tag.name, tag.content));
            }
        }

        yield html;
    }

    /// Create basic server router
    open fn create_router() -> ServerRouter {
        ServerRouter {
            routes: HashMap::new(),
            middleware: Vec::new(),
            error_handlers: HashMap::new(),
        };
    }

    /// Add route to router
    open fn add_route(router: &var ServerRouter, path: String, handler: Box<dyn RouteHandler>) {
        router.routes.insert(path, handler);
    }
}