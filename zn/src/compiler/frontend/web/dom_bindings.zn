// ╔═══════════════════════════════════════════════════════════════════════════════╗
// ║                     Nova DOM BINDINGS                                  ║
// ║                   Browser DOM API Integration & Web APIs                      ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

// DOM bindings for Nova web applications
// Type-safe JavaScript DOM API access from Nova

use std::collections::HashMap;

// ============================================================================
// DOM CORE TYPES
// ============================================================================

/// DOM Element representation
expose data Element {
    tag_name: String,
    attributes: HashMap<String, String>,
    children: Vec<Node>,
    event_listeners: HashMap<String, Vec<EventListener>>,
}

/// DOM Node types
expose cases Node {
    Element(Element),
    Text(String),
    Comment(String),
}

// ============================================================================
// DOM MANIPULATION API
// ============================================================================

/// DOM manipulation interface
expose ability DOMManipulator {
    /// Create a new DOM element
    fn create_element(tag_name: String) -> Element;

    /// Get element by ID
    fn get_element_by_id(id: String) -> Option<Element>;

    /// Get elements by class name
    fn get_elements_by_class_name(class_name: String) -> Vec<Element>;

    /// Get elements by tag name
    fn get_elements_by_tag_name(tag_name: String) -> Vec<Element>;

    /// Query elements using CSS selectors
    fn query_selector(selector: String) -> Option<Element>;
    fn query_selector_all(selector: String) -> Vec<Element>;

    /// Set element attribute
    fn set_attribute(element: &var Element, name: String, value: String);

    /// Get element attribute
    fn get_attribute(element: &Element, name: String) -> Option<String>;

    /// Remove element attribute
    fn remove_attribute(element: &var Element, name: String);

    /// Set element text content
    fn set_text_content(element: &var Element, text: String);

    /// Get element text content
    fn get_text_content(element: &Element) -> String;

    /// Add CSS class
    fn add_class(element: &var Element, class_name: String);

    /// Remove CSS class
    fn remove_class(element: &var Element, class_name: String);

    /// Toggle CSS class
    fn toggle_class(element: &var Element, class_name: String);

    /// Check check element has CSS class
    fn has_class(element: &Element, class_name: String) -> bool;

    /// Append child element
    fn append_child(parent: &var Element, child: Node);

    /// Remove child element
    fn remove_child(parent: &var Element, child: &Node) -> Result<(), DOMError>;

    /// Replace child element
    fn replace_child(parent: &var Element, old_child: &Node, new_child: Node) -> Result<(), DOMError>;

    /// Insert element before another
    fn insert_before(parent: &var Element, new_node: Node, reference_node: &Node) -> Result<(), DOMError>;
}

// ============================================================================
// EVENT HANDLING
// ============================================================================

/// Event types
expose cases EventType {
    Click,
    DoubleClick,
    MouseDown,
    MouseUp,
    MouseMove,
    MouseEnter,
    MouseLeave,
    KeyDown,
    KeyUp,
    KeyPress,
    Focus,
    Blur,
    Change,
    Input,
    Submit,
    Load,
    Unload,
    Resize,
    Scroll,
    Custom(String),
}

/// Event data
expose data EventData {
    event_type: EventType,
    target: Option<Element>,
    current_target: Option<Element>,
    timestamp: i64,
    bubbles: bool,
    cancelable: bool,
    default_prevented: bool,
    propagation_stopped: bool,
    key_code: Option<i32>,
    mouse_x: Option<i32>,
    mouse_y: Option<i32>,
    button: Option<i32>,
    alt_key: bool,
    ctrl_key: bool,
    shift_key: bool,
    meta_key: bool,
    custom_data: HashMap<String, String>,
}

/// Event listener
expose data EventListener {
    event_type: EventType,
    handler: Box<dyn EventHandler>,
    use_capture: bool,
    once: bool,
}

/// Event handler rules
expose ability EventHandler {
    fn handle_event(&var self, event: EventData);
}

/// Event result
expose cases EventResult {
    Continue,
    StopPropagation,
    PreventDefault,
    Both,
}

// ============================================================================
// WEB APIs
// ============================================================================

/// Web Storage API (localStorage/sessionStorage)
expose ability WebStorage {
    fn set_item(key: String, value: String);
    fn get_item(key: String) -> Option<String>;
    fn remove_item(key: String);
    fn clear();
    fn key(index: i32) -> Option<String>;
    fn length() -> i32;
}

/// WebSocket API
expose data WebSocket {
    url: String,
    ready_state: WebSocketState,
    buffered_amount: i64,
    extensions: String,
    protocol: String,
    binary_type: String,
}

expose cases WebSocketState {
    Connecting,
    Open,
    Closing,
    Closed,
}

expose ability WebSocketHandler {
    fn on_open(&var self, event: WebSocketEvent);
    fn on_message(&var self, event: WebSocketEvent);
    fn on_error(&var self, event: WebSocketEvent);
    fn on_close(&var self, event: WebSocketEvent);
}

expose data WebSocketEvent {
    type_: WebSocketEventType,
    data: Option<String>,
    code: Option<i32>,
    reason: Option<String>,
    was_clean: Option<bool>,
}

expose cases WebSocketEventType {
    Open,
    Message,
    Error,
    Close,
}

// ============================================================================
// HTTP CLIENT
// ============================================================================

/// HTTP request configuration
expose data HttpRequest {
    method: HttpMethod,
    url: String,
    headers: HashMap<String, String>,
    body: Option<String>,
    timeout_ms: Option<i32>,
    credentials: bool,
    response_type: ResponseType,
}

expose cases HttpMethod {
    GET,
    POST,
    PUT,
    DELETE,
    PATCH,
    HEAD,
    OPTIONS,
}

expose cases ResponseType {
    Text,
    Json,
    ArrayBuffer,
    Blob,
}

/// HTTP response
expose data HttpResponse {
    status: i32,
    status_text: String,
    headers: HashMap<String, String>,
    body: Option<String>,
    url: String,
    ok: bool,
}

/// HTTP client interface
expose ability HttpClient {
    fn request(request: HttpRequest) -> Task<Result<HttpResponse, HttpError>>;
    fn get(url: String) -> Task<Result<HttpResponse, HttpError>>;
    fn post(url: String, body: String) -> Task<Result<HttpResponse, HttpError>>;
}

// ============================================================================
// BROWSER APIs
// ============================================================================

/// Geolocation API
expose data GeolocationPosition {
    latitude: f64,
    longitude: f64,
    altitude: Option<f64>,
    accuracy: f64,
    altitude_accuracy: Option<f64>,
    heading: Option<f64>,
    speed: Option<f64>,
    timestamp: i64,
}

expose ability GeolocationAPI {
    fn get_current_position() -> Task<Result<GeolocationPosition, GeolocationError>>;
    fn watch_position(callback: Box<dyn PositionCallback>) -> i32;
    fn clear_watch(watch_id: i32);
}

expose ability PositionCallback {
    fn on_position(&var self, position: GeolocationPosition);
    fn on_error(&var self, error: GeolocationError);
}

/// Notification API
expose data NotificationOptions {
    body: Option<String>,
    icon: Option<String>,
    badge: Option<String>,
    image: Option<String>,
    tag: Option<String>,
    require_interaction: bool,
    silent: bool,
    timestamp: Option<i64>,
}

expose ability NotificationAPI {
    fn request_permission() -> Task<NotificationPermission>;
    fn show_notification(title: String, options: NotificationOptions) -> Result<(), NotificationError>;
}

// ============================================================================
// ERROR TYPES
// ============================================================================

expose cases DOMError {
    ElementNotFound(String),
    InvalidSelector(String),
    NotFound,
    HierarchyError,
}

expose cases HttpError {
    NetworkError(String),
    Timeout,
    ParseError(String),
    StatusError(i32),
}

expose cases GeolocationError {
    PermissionDenied,
    PositionUnavailable,
    Timeout,
}

expose cases NotificationError {
    PermissionDenied,
    NotSupported,
    InvalidOptions(String),
}

expose cases NotificationPermission {
    Granted,
    Denied,
    Default,
}

// ============================================================================
// UTILITY FUNCTIONS
// ============================================================================

impl DOMUtils {

    /// Create a simple HTML element
    open fn create_html_element(tag: String, text: Option<String>, classes: Vec<String>) -> Element {
        var element = Element {
            tag_name: tag,
            attributes: HashMap::new(),
            children: Vec::new(),
            event_listeners: HashMap::new(),
        };

        check classes.len() > 0 {
            element.attributes.insert("class".into(), classes.join(" "));
        }

        check let Some(text_content) = text {
            element.children.push(Node::Text(text_content));
        }

        yield element;
    }

    /// Create a hyperlink element
    open fn create_link(href: String, text: String) -> Element {
        var link = create_html_element("a".into(), Some(text), Vec::new());
        link.attributes.insert("href".into(), href);
        yield link;
    }

    /// Create a button element
    open fn create_button(text: String, on_click: Box<dyn EventHandler>) -> Element {
        var button = create_html_element("button".into(), Some(text), Vec::new());
        button.event_listeners.insert("click".into(), [
            EventListener {
                event_type: EventType::Click,
                handler: on_click,
                use_capture: false,
                once: false,
            }
        ]);
        yield button;
    }

    /// Escape HTML text
    open fn escape_html(text: String) -> String {
        text.replace("&", "&amp;")
            .replace("<", "&lt;")
            .replace(">", "&gt;")
            .replace("\"", "&quot;")
            .replace("'", "&#39;")
    }
}