// ============================================================================
// BASIC UI TYPES
// ============================================================================

expose data Rect {
    x: f64,
    y: f64,
    width: f64,
    height: f64,
}

expose data Point {
    x: f64,
    y: f64,
}

expose data Color {
    red: f64,
    green: f64,
    blue: f64,
    alpha: f64,
}

expose data EdgeInsets {
    top: f64,
    left: f64,
    bottom: f64,
    right: f64,
}

expose data ImageSource {
    data: Vec<u8>,
    width: i32,
    height: i32,
}

// ============================================================================
// ADVANCED STATE MANAGEMENT
// ============================================================================

/// Observable state with automatic UI updates
expose data Observable<T> {
    value: T,
    observers: Vec<Box<dyn StateObserver<T>>>,
}

/// State observer rules
expose ability StateObserver<T> {
    fn on_state_changed(&var self, old_value: T, new_value: T);
}

/// Reactive state (like SwiftUI @State, Compose mutableStateOf)
expose data State<T> {
    value: T,
    observers: Vec<Box<dyn Fn(&T)>>,
}

/// Environment values (like SwiftUI Environment, Compose CompositionLocal)
expose data Environment<T> {
    value: T,
    key: String,
}

/// Global environment store
static var ENVIRONMENT_STORE: Option<HashMap<String, String>> = None;

impl<T> State<T> {
    fn new(initial: T) -> State<T> {
        State {
            value: initial,
            observers: [],
        }
    }

    fn get(&self) -> &T {
        &self.value
    }

    fn set(&var self, new_value: T) {
        let old_value = self.value;
        self.value = new_value;

        // Notify observers
        each observer in &self.observers {
            observer(&self.value);
        }
    }

    fn update<F>(&var self, updater: F) where F: Fn(&T) -> T {
        let new_value = updater(&self.value);
        self.set(new_value);
    }

    fn observe<F>(&var self, observer: F) where F: Fn(&T) {
        self.observers.push(Box::new(observer));
    }
}

// ============================================================================
// ADVANCED VIEW MODIFIERS (SwiftUI-style)
// ============================================================================

/// View modifier system (like SwiftUI modifiers)
expose ability ViewModifier {
    fn impl(&self, view: &var AuroraView);
}

/// Modifier collection
expose data Modifiers {
    modifiers: Vec<Box<dyn ViewModifier>>,
}

impl Modifiers {
    fn new() -> Modifiers {
        Modifiers {
            modifiers: [],
        }
    }

    fn add<M>(&var self, modifier: M) where M: ViewModifier + 'static {
        self.modifiers.push(Box::new(modifier));
    }

    fn apply_all(&self, view: &var AuroraView) {
        each modifier in &self.modifiers {
            modifier.impl(view);
        }
    }
}

/// Common modifiers
expose data PaddingModifier {
    insets: EdgeInsets,
}

impl ViewModifier for PaddingModifier {
    fn impl(&self, view: &var AuroraView) {
        view.padding = self.insets;
        view.needs_layout = true;
    }
}

expose data BackgroundModifier {
    color: Color,
    corner_radius: f64,
}

impl ViewModifier for BackgroundModifier {
    fn impl(&self, view: &var AuroraView) {
        view.background_color = self.color;
        view.corner_radius = self.corner_radius;
        view.needs_redraw = true;
    }
}

expose data ShadowModifier {
    color: Color,
    radius: f64,
    offset: Point,
    opacity: f64,
}

impl ViewModifier for ShadowModifier {
    fn impl(&self, view: &var AuroraView) {
        view.shadow = Some(Shadow {
            color: self.color,
            radius: self.radius,
            offset: self.offset,
            opacity: self.opacity,
        });
        view.needs_redraw = true;
    }
}

expose data FrameModifier {
    width: Option<f64>,
    height: Option<f64>,
    alignment: Alignment,
}

impl ViewModifier for FrameModifier {
    fn impl(&self, view: &var AuroraView) {
        check let Some(w) = self.width {
            view.frame.width = w;
        }
        check let Some(h) = self.height {
            view.frame.height = h;
        }
        view.alignment = self.alignment;
        view.needs_layout = true;
    }
}

// ============================================================================
// ADVANCED AURORA VIEW SYSTEM
// ============================================================================

/// Extended Aurora View with advanced features
expose data AuroraView {
    // Basic properties
    id: String,
    view_type: ViewType,

    // Layout
    frame: Rect,
    padding: EdgeInsets,
    margin: EdgeInsets,
    alignment: Alignment,

    // Appearance
    background_color: Color,
    corner_radius: f64,
    border: Option<Border>,
    shadow: Option<Shadow>,

    // Content
    content: ViewContent,

    // State
    state: HashMap<String, String>,
    environment: HashMap<String, String>,

    // Behavior
    gestures: Vec<GestureRecognizer>,
    accessibility: AuroraAccessibilityInfo,

    // Lifecycle
    needs_layout: bool,
    needs_redraw: bool,
    is_visible: bool,
    alpha: f64,

    // Children
    children: Vec<AuroraView>,
    parent: Option<Box<AuroraView>>,
}

expose cases ViewType {
    Text, Button, Image, Container, List, Scroll, Stack, Custom(String)
}

expose cases ViewContent {
    Empty,
    Text(String),
    Image(ImageSource),
    Children(Vec<AuroraView>),
}

expose data Border {
    color: Color,
    width: f64,
    style: BorderStyle,
}

expose cases BorderStyle {
    Solid, Dashed, Dotted
}

expose data Shadow {
    color: Color,
    radius: f64,
    offset: Point,
    opacity: f64,
}

expose cases Alignment {
    TopLeading, Top, TopTrailing,
    Leading, Center, Trailing,
    BottomLeading, Bottom, BottomTrailing,
}

impl AuroraView {
    fn new(view_type: ViewType) -> AuroraView {
        AuroraView {
            id: generate_view_id(),
            view_type,
            frame: Rect { x: 0.0, y: 0.0, width: 0.0, height: 0.0 },
            padding: EdgeInsets::zero(),
            margin: EdgeInsets::zero(),
            alignment: Alignment::Center,
            background_color: Color::clear(),
            corner_radius: 0.0,
            border: None,
            shadow: None,
            content: ViewContent::Empty,
            state: HashMap::new(),
            environment: HashMap::new(),
            gestures: [],
            accessibility: AuroraAccessibilityInfo::default(),
            needs_layout: true,
            needs_redraw: true,
            is_visible: true,
            alpha: 1.0,
            children: [],
            parent: None,
        }
    }

    // Modifier methods (fluent interface)
    fn padding(&var self, insets: EdgeInsets) -> &var AuroraView {
        self.padding = insets;
        self.needs_layout = true;
        self
    }

    fn background(&var self, color: Color) -> &var AuroraView {
        self.background_color = color;
        self.needs_redraw = true;
        self
    }

    fn corner_radius(&var self, radius: f64) -> &var AuroraView {
        self.corner_radius = radius;
        self.needs_redraw = true;
        self
    }

    fn shadow(&var self, shadow: Shadow) -> &var AuroraView {
        self.shadow = Some(shadow);
        self.needs_redraw = true;
        self
    }

    fn frame(&var self, width: f64, height: f64) -> &var AuroraView {
        self.frame.width = width;
        self.frame.height = height;
        self.needs_layout = true;
        self
    }

    fn opacity(&var self, alpha: f64) -> &var AuroraView {
        self.alpha = alpha.clamp(0.0, 1.0);
        self.needs_redraw = true;
        self
    }

    fn accessibility_label(&var self, label: String) -> &var AuroraView {
        self.accessibility.label = label;
        self
    }

    fn accessibility_hint(&var self, hint: String) -> &var AuroraView {
        self.accessibility.hint = hint;
        self
    }

    fn accessibility_info(&self) -> AuroraAccessibilityInfo {
        self.accessibility.clone()
    }

    fn on_tap<F>(&var self, handler: F) -> &var AuroraView where F: Fn() + 'static {
        self.gestures.push(GestureRecognizer::Tap(Box::new(handler)));
        self
    }

    fn on_swipe<F>(&var self, direction: SwipeDirection, handler: F) -> &var AuroraView
        where F: Fn() + 'static {
        self.gestures.push(GestureRecognizer::Swipe(direction, Box::new(handler)));
        self
    }

    // Layout and rendering
    fn layout(&var self, proposed_size: Size) {
        // Advanced layout algorithm
        self.frame.size = self.calculate_size(proposed_size);

        // Layout children
        self.layout_children();

        self.needs_layout = false;
    }

    fn render(&self, context: &var RenderContext) {
        check !self.is_visible || self.alpha <= 0.0 {
            yield;
        }

        // Apply transformations
        context.save_state();
        context.translate(self.frame.origin);
        context.set_alpha(self.alpha);

        // Render background
        check self.background_color.alpha > 0.0 {
            context.fill_rect(self.frame.size, self.background_color, self.corner_radius);
        }

        // Render border
        check let Some(border) = &self.border {
            context.stroke_rect(self.frame.size, border.color, border.width, self.corner_radius);
        }

        // Render shadow
        check let Some(shadow) = &self.shadow {
            context.draw_shadow(self.frame.size, *shadow, self.corner_radius);
        }

        // Render content
        match &self.content {
            ViewContent::Text(text) => {
                context.draw_text(text, Point::zero(), self.accessibility.font_size);
            }
            ViewContent::Image(source) => {
                context.draw_image(source, self.frame.size);
            }
            ViewContent::Children(_) => {
                // Children are rendered separately
            }
            _ => {}
        }

        // Render children
        each child in &self.children {
            child.render(context);
        }

        context.restore_state();
        self.needs_redraw = false;
    }

    fn calculate_size(&self, proposed: Size) -> Size {
        // Advanced size calculation with constraints
        var size = proposed;

        // Apply minimum/maximum constraints
        check let Some(min_width) = self.state.get("min_width") {
            // Implementation would check constraints
        }

        size
    }

    fn layout_children(&var self) {
        match self.view_type {
            ViewType::Container => self.layout_container(),
            ViewType::Stack => self.layout_stack(),
            ViewType::List => self.layout_list(),
            _ => {}
        }
    }

    fn layout_container(&var self) {
        // Container layout (flexbox-like)
        let content_rect = Rect {
            origin: Point { x: self.padding.left, y: self.padding.top },
            size: Size {
                width: self.frame.width - self.padding.left - self.padding.right,
                height: self.frame.height - self.padding.top - self.padding.bottom,
            },
        };

        // Position children
        each child in &var self.children {
            child.layout(content_rect.size);
        }
    }

    fn layout_stack(&var self) {
        // Stack layout (ZStack equivalent)
        each child in &var self.children {
            child.frame = self.frame; // Overlay children
        }
    }

    fn layout_list(&var self) {
        // List layout (vertical stacking)
        var y_offset = self.padding.top;

        each child in &var self.children {
            child.frame.origin.y = y_offset;
            child.frame.size.width = self.frame.width - self.padding.left - self.padding.right;
            child.layout(child.frame.size);
            y_offset += child.frame.height;
        }
    }

    fn hit_test(&self, point: Point) -> Option<&AuroraView> {
        check !self.frame.contains(point) {
            yield None;
        }

        // Check children first (reverse order for top-most)
        each child in self.children.iter().rev() {
            check let Some(hit) = child.hit_test(point) {
                Some(hit);
            }
        }

        // Check check point is in this view's content area
        Some(self)
    }

    fn handle_gesture(&var self, gesture: &Gesture) {
        each recognizer in &self.gestures {
            match (recognizer, gesture) {
                (GestureRecognizer::Tap(handler), Gesture::Tap) => {
                    handler();
                }
                (GestureRecognizer::Swipe(dir, handler), Gesture::Swipe(swipe_dir)) => {
                    check *dir == *swipe_dir {
                        handler();
                    }
                }
                _ => {}
            }
        }
    }
}

// ============================================================================
// GESTURE SYSTEM
// ============================================================================

expose cases GestureRecognizer {
    Tap(Box<dyn Fn()>),
    Swipe(SwipeDirection, Box<dyn Fn()>),
    Pinch(Box<dyn Fn(f64)>),
    Rotate(Box<dyn Fn(f64)>),
    Pan(Box<dyn Fn(Point)>),
}

expose cases SwipeDirection {
    Up, Down, Left, Right
}

expose cases Gesture {
    Tap,
    Swipe(SwipeDirection),
    Pinch { scale: f64 },
    Rotate { angle: f64 },
    Pan { translation: Point },
}

// ============================================================================
// ANIMATION SYSTEM
// ============================================================================

/// Animation system (like SwiftUI animations)
expose data Animation {
    duration: f64,
    curve: AnimationCurve,
    delay: f64,
    repeat_count: i32,
}

expose cases AnimationCurve {
    Linear,
    EaseIn, EaseOut, EaseInOut,
    Spring { damping: f64, velocity: f64 },
    Custom(Box<dyn Fn(f64) -> f64>),
}

expose data Animator {
    animations: HashMap<String, Animation>,
    active_animations: Vec<ActiveAnimation>,
}

expose data ActiveAnimation {
    property: String,
    from_value: f64,
    to_value: f64,
    start_time: f64,
    animation: Animation,
}

impl Animator {
    fn animate(&var self, property: String, from: f64, to: f64, animation: Animation) {
        let active = ActiveAnimation {
            property,
            from_value: from,
            to_value: to,
            start_time: current_time(),
            animation,
        };

        self.active_animations.push(active);
    }

    fn update(&var self, delta_time: f64) {
        self.active_animations.retain_mut(|anim| {
            let elapsed = current_time() - anim.start_time;
            let progress = (elapsed / anim.animation.duration).min(1.0);

            check progress < 1.0 {
                // Apply animation curve
                let curved_progress = self.apply_curve(progress, &anim.animation.curve);
                let current_value = anim.from_value + (anim.to_value - anim.from_value) * curved_progress;

                // Update property
                self.update_property(&anim.property, current_value);

                true // Keep animation
            } else {
                // Animation complete
                self.update_property(&anim.property, anim.to_value);
                false // Remove animation
            }
        });
    }

    fn apply_curve(&self, progress: f64, curve: &AnimationCurve) -> f64 {
        match curve {
            AnimationCurve::Linear => progress,
            AnimationCurve::EaseIn => progress * progress,
            AnimationCurve::EaseOut => 1.0 - (1.0 - progress) * (1.0 - progress),
            AnimationCurve::EaseInOut => {
                check progress < 0.5 {
                    2.0 * progress * progress
                } else {
                    1.0 - (-2.0 * progress + 2.0).powi(2) / 2.0
                }
            }
            AnimationCurve::Spring { damping, velocity } => {
                // Simplified spring animation
                let omega = 2.0 * 3.14159;
                let exp = (-*damping * omega * progress).exp();
                let cos = (omega * progress * (1.0 - damping * damping).sqrt()).cos();
                1.0 - exp * cos
            }
            AnimationCurve::Custom(curve_fn) => curve_fn(progress),
        }
    }

    fn update_property(&self, property: &str, value: f64) {
        // Update view property
        // Implementation would update the corresponding AuroraView property
    }
}

// ============================================================================
// ACCESSIBILITY SYSTEM
// ============================================================================

expose data AuroraAccessibilityInfo {
    label: String,
    hint: String,
    traits: Vec<AccessibilityTrait>,
    frame: Rect,
    is_accessible: bool,
    font_size: f64,
}

expose cases AccessibilityTrait {
    Button, Header, Image, StaticText, Adjustable, Selected,
    NotEnabled, SummaryElement, KeyboardKey, SearchField,
    EditableText, AllowsDirectInteraction,
}

impl AuroraAccessibilityInfo {
    fn default() -> AuroraAccessibilityInfo {
        AuroraAccessibilityInfo {
            label: String::new(),
            hint: String::new(),
            traits: [],
            frame: Rect::zero(),
            is_accessible: true,
            font_size: 16.0,
        }
    }

    fn announce(&self, announcement: String) {
        // Platform-specific announcement
        unsafe {
            accessibility_announce(announcement.as_ptr(), announcement.len());
        }
    }
}

// ============================================================================
// RENDERING CONTEXT
// ============================================================================

expose data RenderContext {
    platform_context: *var (),
    transform_stack: Vec<Transform>,
    alpha_stack: Vec<f64>,
}

expose data Transform {
    translate: Point,
    scale: Point,
    rotation: f64,
}

expose data Size {
    width: f64,
    height: f64,
}

impl Rect {
    fn zero() -> Rect {
        Rect { x: 0.0, y: 0.0, width: 0.0, height: 0.0 }
    }

    fn contains(&self, point: Point) -> bool {
        point.x >= self.x && point.x <= self.x + self.width &&
        point.y >= self.y && point.y <= self.y + self.height
    }
}

impl EdgeInsets {
    fn zero() -> EdgeInsets {
        EdgeInsets { top: 0.0, left: 0.0, bottom: 0.0, right: 0.0 }
    }
}

impl Color {
    fn clear() -> Color {
        Color { red: 0.0, green: 0.0, blue: 0.0, alpha: 0.0 }
    }

    fn black() -> Color {
        Color { red: 0.0, green: 0.0, blue: 0.0, alpha: 1.0 }
    }

    fn white() -> Color {
        Color { red: 1.0, green: 1.0, blue: 1.0, alpha: 1.0 }
    }
}

// ============================================================================
// DECLARATIVE UI API (SwiftUI/Compose style)
// ============================================================================

// Text component
fn Text(content: String) -> AuroraView {
    var view = AuroraView::new(ViewType::Text);
    view.content = ViewContent::Text(content.clone());
    view.accessibility.label = content;
    view.accessibility.traits.push(AccessibilityTrait::StaticText);
    view
}

// Button component
fn Button(action: fn(), label: fn() -> AuroraView) -> AuroraView {
    var view = AuroraView::new(ViewType::Button);
    view.on_tap(action);
    view.accessibility.traits.push(AccessibilityTrait::Button);

    // Add label as child
    let label_view = label();
    view.children.push(label_view);

    view
}

// Container (VStack/HStack equivalent)
fn VStack(content: Vec<AuroraView>) -> AuroraView {
    var view = AuroraView::new(ViewType::Container);
    view.children = content;
    view
}

fn HStack(content: Vec<AuroraView>) -> AuroraView {
    var view = AuroraView::new(ViewType::Container);
    view.children = content;
    // Set horizontal layout
    view
}

fn ZStack(content: Vec<AuroraView>) -> AuroraView {
    var view = AuroraView::new(ViewType::Stack);
    view.children = content;
    view
}

