    fn draw_text(&var self, text: &str, position: Point, font_size: f64) { /* Platform specific */ }
    fn draw_image(&var self, source: &ImageSource, size: Size) { /* Platform specific */ }
}

// ============================================================================
// EXAMPLE ADVANCED UI
// ============================================================================

fn create_advanced_ui() -> AuroraView {
    VStack([
        Text("Advanced Aurora UI".into())
            .font_size(24.0)
            .bold()
            .padding(EdgeInsets { top: 20.0, left: 20.0, bottom: 10.0, right: 20.0 }),

        HStack([
            Button(|| println("Left button pressed"), || Text("Left".into()))
                .padding(EdgeInsets::all(10.0))
                .background(Color::blue())
                .corner_radius(8.0),

            Button(|| println("Right button pressed"), || Text("Right".into()))
                .padding(EdgeInsets::all(10.0))
                .background(Color::green())
                .corner_radius(8.0),
        ]),

        ZStack([
            AuroraView::new(ViewType::Custom("Circle".into()))
                .frame(100.0, 100.0)
                .background(Color::red())
                .corner_radius(50.0),

            Text("Overlay".into())
                .foreground_color(Color::white()),
        ])
        .frame(200.0, 200.0),
    ])
    .padding(EdgeInsets::all(20.0))
    .background(Color { red: 0.95, green: 0.95, blue: 0.95, alpha: 1.0 })
}

// Extension methods for fluent API
impl AuroraView {
    fn font_size(&var self, size: f64) -> &var AuroraView {
        self.accessibility.font_size = size;
        self
    }

    fn bold(&var self) -> &var AuroraView {
        // Would modify font weight
        self
    }

    fn foreground_color(&var self, color: Color) -> &var AuroraView {
        // Would set text color
        self
    }
}

impl EdgeInsets {
    fn all(value: f64) -> EdgeInsets {
        EdgeInsets {
            top: value,
            left: value,
            bottom: value,
            right: value,
        }
    }
}
