// ============================================================================
// EXAMPLE ANIMATIONS
// ============================================================================

fn create_animated_ui() -> AuroraView {
    var button = Button(|| println("Animated button pressed"), || Text("Tap me!".into()))
        .frame(200.0, 50.0)
        .background(Color::blue())
        .corner_radius(25.0);

    // Add entrance animation
    button.on_appear(|view| {
        var animation = ViewAnimation::new();
        animation.animate_scale(1.0, PresetAnimations::scale_in(0.5));
        animation.animate_opacity(1.0, PresetAnimations::fade_in(0.3));
        view.attach_animation(animation);
    });

    // Add tap animation
    button.on_tap_start(|view| {
        var animation = ViewAnimation::new();
        animation.animate_scale(0.95, AnimationSpec::default());
        view.attach_animation(animation);
    });

    button
}

// Extension for AuroraView animation support
