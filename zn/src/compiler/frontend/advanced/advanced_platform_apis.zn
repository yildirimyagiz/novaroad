// ML FFI
extern "C" {
    fn ml_check_acceleration() -> i32;
    fn coreml_load_model(path: *const u8, len: usize, model_type: i32) -> i32;
    fn mlkit_load_model(path: *const u8, len: usize, model_type: i32) -> i32;
    fn coreml_run_inference(model_id: *const u8, id_len: usize, data: *const f64, data_len: usize, data: *const i32, shape_len: i32) -> MLResult;
    fn mlkit_run_inference(model_id: *const u8, id_len: usize, data: *const f64, data_len: usize, data: *const i32, shape_len: i32) -> MLResult;
    fn coreml_unload_model(model_id: *const u8, len: usize) -> i32;
    fn mlkit_unload_model(model_id: *const u8, len: usize) -> i32;
    fn coreml_generate_id() -> *const i8;
}

// AR FFI
extern "C" {
    fn ar_check_support() -> i32;
    fn arkit_start_session(session_id: *const u8, id_len: usize, world_tracking: i32, plane_detection: i32) -> i32;
    fn arcore_start_session(session_id: *const u8, id_len: usize, world_tracking: i32, plane_detection: i32) -> i32;
    fn arkit_add_anchor(session_id: *const u8, id_len: usize, anchor_id: *const u8, aid_len: usize, px: f64, py: f64, pz: f64, qx: f64, qy: f64, qz: f64, qw: f64, anchor_type: i32) -> i32;
    fn arcore_add_anchor(session_id: *const u8, id_len: usize, anchor_id: *const u8, aid_len: usize, px: f64, py: f64, pz: f64, qx: f64, qy: f64, qz: f64, qw: f64, anchor_type: i32) -> i32;
    fn arkit_get_frame(session_id: *const u8, id_len: usize) -> ARFrameResult;
    fn arcore_get_frame(session_id: *const u8, id_len: usize) -> ARFrameResult;
    fn arkit_stop_session(session_id: *const u8, id_len: usize) -> i32;
    fn arcore_stop_session(session_id: *const u8, id_len: usize) -> i32;
    fn arkit_generate_session_id() -> *const i8;
    fn arcore_generate_session_id() -> *const i8;
    fn arkit_generate_anchor_id() -> *const i8;
    fn arcore_generate_anchor_id() -> *const i8;
}

// Camera FFI
extern "C" {
    fn avf_configure_camera(position: i32, width: i32, height: i32, frame_rate: i32, flash: i32, focus: i32, exposure: i32, wb: i32) -> i32;
    fn camerax_configure_camera(position: i32, width: i32, height: i32, frame_rate: i32, flash: i32, focus: i32, exposure: i32, wb: i32) -> i32;
    fn avf_start_preview(surface: *var ()) -> i32;
    fn camerax_start_preview(surface: *var ()) -> i32;
    fn avf_capture_photo(callback: *var ()) -> i32;
    fn camerax_capture_photo(callback: *var ()) -> i32;
    fn avf_start_recording(path: *const u8, len: usize, width: i32, height: i32, fps: i32, bitrate: i32) -> i32;
    fn camerax_start_recording(path: *const u8, len: usize, width: i32, height: i32, fps: i32, bitrate: i32) -> i32;
    fn avf_stop_recording() -> VideoResultRaw;
    fn camerax_stop_recording() -> VideoResultRaw;
