    fn camerax_apply_effect(effect: i32) -> i32;
    fn avf_remove_effect(effect: i32) -> i32;
    fn camerax_remove_effect(effect: i32) -> i32;
}

// Background FFI
extern "C" {
    fn bgtask_schedule(task_id: *const u8, id_len: usize, task_type: i32, network: i32, charging: i32, idle: i32, min_interval: i64, max_time: i64, handler: *var ()) -> i32;
    fn workmanager_schedule(task_id: *const u8, id_len: usize, task_type: i32, network: i32, charging: i32, idle: i32, min_interval: i64, max_time: i64, handler: *var ()) -> i32;
    fn bgtask_cancel(task_id: *const u8, len: usize) -> i32;
    fn workmanager_cancel(task_id: *const u8, len: usize) -> i32;
    fn bgtask_generate_task_id() -> *const i8;
    fn workmanager_generate_task_id() -> *const i8;
}

// Platform capabilities FFI
extern "C" {
    fn platform_get_capabilities() -> PlatformCapabilitiesRaw;
    fn ml_get_platform() -> i32;
    fn ar_get_platform() -> i32;
    fn camera_get_platform() -> i32;
    fn bg_get_platform() -> i32;
}

// Raw FFI structs
space data MLResult {
    data: *var f64,
    size: usize,
}

space data ARFrameResult {
    timestamp: i64,
    camera_x: f64, camera_y: f64, camera_z: f64,
    camera_qx: f64, camera_qy: f64, camera_qz: f64, camera_qw: f64,
    image_data: *var u8,
    image_size: usize,
}

space data VideoResultRaw {
    file_path: *const i8,
    duration_ms: i64,
    file_size: i64,
}

space data PlatformCapabilitiesRaw {
    ml_acceleration: i32,
    ar_support: i32,
    advanced_camera: i32,
    background_processing: i32,
    max_memory_gb: f64,
    gpu_memory_gb: f64,
    neural_engine_tflops: f64,
}

// ============================================================================
// ADVANCED EXAMPLE APPLICATION
// ============================================================================

fn create_advanced_ml_app() -> AdvancedPlatformAPI {
    println("🚀 Creating Advanced ML Application...");

    var api = AdvancedPlatformAPI::new();

    // Load ML model for image classification
    match api.ml_engine.load_model("mobilenet_v2".into(), MLModelType::ImageClassification) {
        Ok(model_id) => println("✅ Loaded ML model: {}", model_id),
        Err(e) => println("❌ Failed to load ML model: {:?}", e),
    }

    // Configure advanced camera
    let camera_config = CameraConfig {
        position: CameraPosition::Back,
        resolution: (4032, 3024), // 4K
        frame_rate: 30,
        flash_mode: FlashMode::Auto,
        focus_mode: FocusMode::Continuous,
        exposure_mode: ExposureMode::Auto,
        white_balance: WhiteBalanceMode::Auto,
    };

    match api.camera.configure(camera_config) {
        Ok(_) => println("✅ Configured advanced camera"),
        Err(e) => println("❌ Camera configuration failed: {:?}", e),
    }

    // Schedule intelligent background sync
    match api.schedule_intelligent_sync("user_data".into()) {
        Ok(task_id) => println("✅ Scheduled background sync: {}", task_id),
        Err(e) => println("❌ Background sync scheduling failed: {:?}", e),
    }

    println("📊 Platform Score: {:.1}/100", api.get_platform_score());
    println("🎯 Advanced Platform APIs Ready!");

    api
}
