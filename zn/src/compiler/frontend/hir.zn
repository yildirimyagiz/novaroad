/**
 * ═══════════════════════════════════════════════════════════════════════════
 * NOVA HIR — High-Level Intermediate Representation — v10.0
 * ═══════════════════════════════════════════════════════════════════════════
 * Semantic analysis, name resolution, alias checking.
 * Updated to Nova v10 "Intent-First" syntax model:
 *   data → HirData, cases → HirCases, rules → HirRules,
 *   yield → HirYield, check → HirCheck, each → HirEach,
 *   flow → HirFlow, spawn → HirSpawn, given → HirGuard,
 *   open → visibility, alias → HirAlias, @extern → HirExternCall
 *
 * Syntax: data / cases / rules / flow / yield / check / each / spawn / given / match
 */

use std::collections::{HashMap, HashSet};
use span::Span;
use errors::DiagnosticBuilder;
use parser::*;

// ═══════════════════════════════════════════════════════════════════════════
// §1  HIR NODE TYPES (Desugared and Analyzed)
// ═══════════════════════════════════════════════════════════════════════════

open data HirProgram {
    open items: Vec<HirItem>,
    open defs:  HirDefMap,
}

open cases HirItem {
    Fn(HirFn),
    Data(HirData),         // v10: 'data' keyword
    Cases(HirCases),       // v10: 'cases' keyword
    Rules(HirRules),       // v10: 'rules' keyword
    Impl(HirImpl),
    Use(HirUse),
    Alias(HirAlias),       // v10: 'alias' keyword
    ExternBlock(HirExternBlock), // v10: '@extern' blocks
}

// ═══════════════════════════════════════════════════════════════════════════
// §2  DECLARATION HIR NODES
// ═══════════════════════════════════════════════════════════════════════════

open data HirFn {
    open def_id:     DefId,
    open name:       Symbol,
    open params:     Vec<HirParam>,
    open return_ty:  HirTy,
    open body:       HirBody,
    open is_async:   bool,          // v10: async fn support
    open visibility: HirVisibility, // v10: open / open
    open span:       Span,
}

open data HirData {
    open def_id:     DefId,
    open name:       Symbol,
    open fields:     Vec<HirField>,
    open visibility: HirVisibility,
    open span:       Span,
}

open data HirCases {
    open def_id:   DefId,
    open name:     Symbol,
    open variants: Vec<HirVariant>,
    open span:     Span,
}

open data HirRules {
    open def_id:  DefId,
    open name:    Symbol,
    open methods: Vec<HirFnSignature>,
    open span:    Span,
}

open data HirFnSignature {
    open name:      Symbol,
    open params:    Vec<HirParam>,
    open return_ty: HirTy,
    open span:      Span,
}

open data HirImpl {
    open def_id:       DefId,
    open self_ty:      HirTy,
    open for_rules:    Option<HirPath>, // impl Rules for Data
    open methods:      Vec<HirFn>,
    open span:         Span,
}

open data HirUse {
    open def_id: DefId,
    open path:   HirPath,
    open alias:  Option<Symbol>,
    open glob:   bool,        // use foo::*
    open span:   Span,
}

open data HirAlias {
    open def_id:    DefId,
    open name:      Symbol,
    open target_ty: HirTy,
    open span:      Span,
}

open data HirExternBlock {
    open def_id: DefId,
    open items:  Vec<HirExternFn>,
    open span:   Span,
}

open data HirExternFn {
    open name:      Symbol,
    open c_name:    String,    // The FFI symbol name
    open params:    Vec<HirParam>,
    open return_ty: HirTy,
    open span:      Span,
}

// ═══════════════════════════════════════════════════════════════════════════
// §3  EXPRESSION HIR NODES
// ═══════════════════════════════════════════════════════════════════════════

open data HirParam {
    open name: Symbol,
    open ty:   HirTy,
    open span: Span,
}

open data HirField {
    open name:       Symbol,
    open ty:         HirTy,
    open visibility: HirVisibility,
    open span:       Span,
}

open data HirVariant {
    open name:   Symbol,
    open fields: Vec<HirField>,
    open span:   Span,
}

open data HirBody {
    open params: Vec<HirParam>,
    open value:  HirExpr,
    open span:   Span,
}

open cases HirExpr {
    Lit(HirLit),
    Var(Symbol),
    Binary(HirBinaryExpr),
    Unary(HirUnaryExpr),
    Call(HirCallExpr),
    If(HirIfExpr),
    Check(HirCheckExpr),       // v10: 'check' construct
    Block(HirBlock),
    Field(HirFieldExpr),
    Index(HirIndexExpr),
    DataInit(HirDataInitExpr), // v10: data { ... } initialization
    Match(HirMatchExpr),
    Loop(HirLoopExpr),
    Each(HirEachExpr),         // v10: 'each' loop
    Yield(HirYieldExpr),       // v10: 'yield' expression
    Spawn(HirSpawnExpr),       // v10: 'spawn' expression
    Await(HirAwaitExpr),       // v10: await expression
    ExternCall(HirExternCallExpr), // v10: @extern("name", ...)
    Break(Option<Box<HirExpr>>),
    Return(Option<Box<HirExpr>>),
}

open cases HirLit {
    Int(i64),
    Float(f64),
    Bool(bool),
    String(String),
}

// ═══════════════════════════════════════════════════════════════════════════
// §4  COMPOUND EXPRESSION NODES
// ═══════════════════════════════════════════════════════════════════════════

open data HirBinaryExpr {
    open lhs:  Box<HirExpr>,
    open op:   HirBinOp,
    open rhs:  Box<HirExpr>,
    open span: Span,
}

open cases HirBinOp {
    Add, Sub, Mul, Div, Mod, Pow,
    Eq, Ne, Lt, Le, Gt, Ge,
    And, Or,
    BitAnd, BitOr, BitXor,
    Shl, Shr,
}

open data HirUnaryExpr {
    open op:   HirUnOp,
    open expr: Box<HirExpr>,
    open span: Span,
}

open cases HirUnOp {
    Not, Neg, BitNot,
}

open data HirCallExpr {
    open func: Box<HirExpr>,
    open args: Vec<HirExpr>,
    open span: Span,
}

open data HirIfExpr {
    open cond:  Box<HirExpr>,
    open then:  HirBlock,
    open else_: Option<Box<HirExpr>>,
    open span:  Span,
}

/// v10 'check' — guard-style conditional
open data HirCheckExpr {
    open cond:  Box<HirExpr>,
    open body:  HirBlock,
    open else_: Option<HirBlock>,
    open span:  Span,
}

open data HirBlock {
    open stmts: Vec<HirStmt>,
    open expr:  Option<Box<HirExpr>>,
    open span:  Span,
}

open cases HirStmt {
    Let(HirLetStmt),
    Var(HirVarStmt),   // v10: mutable binding
    Expr(HirExpr),
    Semi(HirExpr),
}

open data HirLetStmt {
    open pat:  HirPat,
    open ty:   Option<HirTy>,
    open init: Option<HirExpr>,
    open span: Span,
}

open data HirVarStmt {
    open name: Symbol,
    open ty:   Option<HirTy>,
    open init: Option<HirExpr>,
    open span: Span,
}

open data HirFieldExpr {
    open base:  Box<HirExpr>,
    open field: Symbol,
    open span:  Span,
}

open data HirIndexExpr {
    open base:  Box<HirExpr>,
    open index: Box<HirExpr>,
    open span:  Span,
}

/// v10 data { field: value, ... } initializer
open data HirDataInitExpr {
    open ty:     HirPath,
    open fields: Vec<HirFieldValue>,
    open span:   Span,
}

open data HirFieldValue {
    open name: Symbol,
    open expr: HirExpr,
    open span: Span,
}

open data HirMatchExpr {
    open expr: Box<HirExpr>,
    open arms: Vec<HirMatchArm>,
    open span: Span,
}

open data HirMatchArm {
    open pat:   HirPat,
    open guard: Option<HirExpr>, // v10: 'given' guard clause
    open body:  HirExpr,
    open span:  Span,
}

open data HirLoopExpr {
    open body: HirBlock,
    open span: Span,
}

/// v10 'each item in collection { ... }'
open data HirEachExpr {
    open binding: Symbol,
    open iter:    Box<HirExpr>,
    open body:    HirBlock,
    open span:    Span,
}

/// v10 'yield expr' — replaces 'yield'
open data HirYieldExpr {
    open value: Option<Box<HirExpr>>,
    open span:  Span,
}

/// v10 'spawn expr' — concurrent task
open data HirSpawnExpr {
    open expr: Box<HirExpr>,
    open span: Span,
}

/// v10 'await expr'
open data HirAwaitExpr {
    open expr: Box<HirExpr>,
    open span: Span,
}

/// v10 @extern("name", arg0, arg1, ...)
open data HirExternCallExpr {
    open extern_name: String,
    open args:        Vec<HirExpr>,
    open span:        Span,
}

// ═══════════════════════════════════════════════════════════════════════════
// §5  PATTERNS
// ═══════════════════════════════════════════════════════════════════════════

open cases HirPat {
    Wildcard,
    Binding(Symbol),
    Lit(HirLit),
    Data(HirPatData),
    Tuple(Vec<HirPat>),
    Variant(HirPatVariant), // v10: cases variant matching
}

open data HirPatData {
    open ty:     HirPath,
    open fields: Vec<HirPatField>,
}

open data HirPatVariant {
    open path:     HirPath,
    open bindings: Vec<HirPat>,
}

open data HirPatField {
    open name: Symbol,
    open pat:  HirPat,
}

// ═══════════════════════════════════════════════════════════════════════════
// §6  TYPES
// ═══════════════════════════════════════════════════════════════════════════

open cases HirTy {
    Bool,
    I32, I64,
    F32, F64,
    String,
    Path(HirPath),
    Tuple(Vec<HirTy>),
    Array(Box<HirTy>, usize),
    Slice(Box<HirTy>),
    Fn(HirFnTy),
    Ptr(Box<HirTy>),
    Ref(Box<HirTy>),
    Option(Box<HirTy>),       // v10: Option<T>
    Result(Box<HirTy>, Box<HirTy>), // v10: Result<T, E>
    Flow(Box<HirTy>),         // v10: flow<T> — async stream
    Vec(Box<HirTy>),          // v10: Vec<T>
}

open data HirFnTy {
    open params:    Vec<HirTy>,
    open return_ty: Box<HirTy>,
}

open data HirPath {
    open segments: Vec<Symbol>,
}

// ═══════════════════════════════════════════════════════════════════════════
// §7  VISIBILITY
// ═══════════════════════════════════════════════════════════════════════════

open cases HirVisibility {
    Private,
    Open,    // v10: 'open' keyword
    Public,  // 'open' keyword
    Crate,   // crate-level visibility
}

// ═══════════════════════════════════════════════════════════════════════════
// §8  SYMBOLS AND DEFS
// ═══════════════════════════════════════════════════════════════════════════

open data DefId { open id: usize }
open data Symbol { open name: String }

alias HirDefMap = HashMap<DefId, HirDef>;

open cases HirDef {
    Fn(HirFn),
    Data(HirData),
    Cases(HirCases),
    Rules(HirRules),
    Variant(HirVariant),
    Field(HirField),
    Param(HirParam),
    Local(Symbol),
    Alias(HirAlias),
    ExternFn(HirExternFn),
}

// ═══════════════════════════════════════════════════════════════════════════
// §9  HIR LOWERING (AST → HIR)
// ═══════════════════════════════════════════════════════════════════════════

open data HirLowerer {
    open next_def_id: usize,
    open defs:        HirDefMap,
    open errors:      Vec<DiagnosticBuilder>,
    open scopes:      Vec<HashMap<String, DefId>>, // Scope stack for name resolution
}

impl HirLowerer {
    fn new() -> HirLowerer {
        HirLowerer {
            next_def_id: 0,
            defs:        HashMap::new(),
            errors:      [],
            scopes:      [HashMap::new()], // Global scope
        };
    }

    fn lower_program(&var self, program: &Program) -> Result<HirProgram, Vec<DiagnosticBuilder>> {
        var items = [];

        each item in &program.items {
            items.push(self.lower_item(item));
        }

        // Name resolution and alias checking
        self.resolve_names()?;
        self.type_check()?;

        check self.errors.is_empty() {
            Ok(HirProgram { items, defs: self.defs.clone() });
        }

        Err(self.errors.clone());
    }

    fn lower_item(&var self, item: &Item) -> HirItem {
        match item {
            Item::Fn(fn_item)         => HirItem::Fn(self.lower_fn(fn_item)),
            Item::Data(data_item)     => HirItem::Data(self.lower_data(data_item)),
            Item::Cases(cases_item)   => HirItem::Cases(self.lower_cases(cases_item)),
            Item::Rules(rules_item)   => HirItem::Rules(self.lower_rules(rules_item)),
            Item::Impl(impl_item)     => HirItem::Impl(self.lower_impl(impl_item)),
            Item::Use(use_item)       => HirItem::Use(self.lower_use(use_item)),
            Item::Alias(alias_item)   => HirItem::Alias(self.lower_alias(alias_item)),
            /* Legacy compat: old data/cases/rules syntax */
            Item::Struct(s) => HirItem::Data(self.lower_struct_as_data(s)),
            Item::Enum(e)   => HirItem::Cases(self.lower_enum_as_cases(e)),
            Item::Trait(t)  => HirItem::Rules(self.lower_trait_as_rules(t)),
        }
    }

    fn lower_fn(&var self, fn_item: &FnItem) -> HirFn {
        let def_id = self.fresh_def_id();
        let name = Symbol { name: fn_item.name.0.clone() };
        
        // Stage 0: manual collection instead of .map().collect()
        var params = [];
        each p in &fn_item.params {
            params.push(self.lower_param(p));
        }
        
        let return_ty = fn_item.return_ty.as_ref()
            .map(|ty| self.lower_type(ty))
            .unwrap_or(HirTy::Tuple([]));
        let body = self.lower_body(&fn_item.body, &params);

        let hir_fn = HirFn {
            def_id,
            name:       name.clone(),
            params,
            return_ty,
            body,
            is_async:   fn_item.is_async,
            visibility: self.lower_visibility(&fn_item.vis),
            span:       fn_item.span.clone(),
        };

        self.defs.insert(def_id, HirDef::Fn(hir_fn.clone()));
        yield hir_fn;
    }

    fn lower_data(&var self, data_item: &DataItem) -> HirData {
        let def_id = self.fresh_def_id();
        
        // Stage 0: manual collection instead of .map().collect()
        var fields = [];
        each f in &data_item.fields {
            fields.push(self.lower_field(f));
        }

        let hir_data = HirData {
            def_id,
            name:       Symbol { name: data_item.name.0.clone() },
            fields,
            visibility: self.lower_visibility(&data_item.vis),
            span:       data_item.span.clone(),
        };

        self.defs.insert(def_id, HirDef::Data(hir_data.clone()));
        yield hir_data;
    }

    fn lower_cases(&var self, cases_item: &CasesItem) -> HirCases {
        let def_id = self.fresh_def_id();
        
        // Stage 0: manual collection instead of .map().collect()
        var variants = [];
        each v in &cases_item.variants {
            variants.push(self.lower_variant(v));
        }

        let hir_cases = HirCases {
            def_id,
            name:     Symbol { name: cases_item.name.0.clone() },
            variants,
            span:     cases_item.span.clone(),
        };

        self.defs.insert(def_id, HirDef::Cases(hir_cases.clone()));
        yield hir_cases;
    }

    fn lower_rules(&var self, rules_item: &RulesItem) -> HirRules {
        let def_id = self.fresh_def_id();
        
        // Stage 0: manual collection instead of .map().collect()
        var methods = [];
        each m in &rules_item.methods {
            methods.push(self.lower_fn_sig(m));
        }

        let hir_rules = HirRules {
            def_id,
            name:    Symbol { name: rules_item.name.0.clone() },
            methods,
            span:    rules_item.span.clone(),
        };

        self.defs.insert(def_id, HirDef::Rules(hir_rules.clone()));
        yield hir_rules;
    }

    fn lower_expr(&var self, expr: &Expr) -> HirExpr {
        match expr {
            Expr::Lit(lit)      => HirExpr::Lit(self.lower_lit(lit)),
            Expr::Ident(ident)  => HirExpr::Var(Symbol { name: ident.0.clone() }),
            Expr::Binary(bin)   => HirExpr::Binary(HirBinaryExpr {
                lhs:  Box::new(self.lower_expr(&bin.left)),
                op:   self.lower_binop(&bin.op),
                rhs:  Box::new(self.lower_expr(&bin.right)),
                span: bin.span.clone(),
            }),
            Expr::Unary(un)     => HirExpr::Unary(HirUnaryExpr {
                op:   self.lower_unop(&un.op),
                expr: Box::new(self.lower_expr(&un.expr)),
                span: un.span.clone(),
            }),
            Expr::Call(call)    => HirExpr::Call(HirCallExpr {
                func: Box::new(self.lower_expr(&call.func)),
                args: call.args.iter().map(|a| self.lower_expr(a)).collect(),
                span: call.span.clone(),
            }),
            Expr::If(if_expr)   => HirExpr::If(HirIfExpr {
                cond:  Box::new(self.lower_expr(&if_expr.cond)),
                then:  self.lower_block(&if_expr.then),
                else_: if_expr.else_.as_ref().map(|e| Box::new(self.lower_expr(e))),
                span:  if_expr.span.clone(),
            }),
            Expr::Check(ck)    => HirExpr::Check(HirCheckExpr {
                cond:  Box::new(self.lower_expr(&ck.cond)),
                body:  self.lower_block(&ck.body),
                else_: ck.else_.as_ref().map(|b| self.lower_block(b)),
                span:  ck.span.clone(),
            }),
            Expr::Each(each)   => HirExpr::Each(HirEachExpr {
                binding: Symbol { name: each.binding.0.clone() },
                iter:    Box::new(self.lower_expr(&each.iter)),
                body:    self.lower_block(&each.body),
                span:    each.span.clone(),
            }),
            Expr::Yield(y)     => HirExpr::Yield(HirYieldExpr {
                value: y.value.as_ref().map(|v| Box::new(self.lower_expr(v))),
                span:  y.span.clone(),
            }),
            Expr::Spawn(s)     => HirExpr::Spawn(HirSpawnExpr {
                expr: Box::new(self.lower_expr(&s.expr)),
                span: s.span.clone(),
            }),
            Expr::Await(a)     => HirExpr::Await(HirAwaitExpr {
                expr: Box::new(self.lower_expr(&a.expr)),
                span: a.span.clone(),
            }),
            Expr::ExternCall(ext) => HirExpr::ExternCall(HirExternCallExpr {
                extern_name: ext.name.clone(),
                args:        ext.args.iter().map(|a| self.lower_expr(a)).collect(),
                span:        ext.span.clone(),
            }),
            Expr::Block(block) => HirExpr::Block(self.lower_block(block)),
            Expr::Match(m)     => HirExpr::Match(HirMatchExpr {
                expr: Box::new(self.lower_expr(&m.expr)),
                arms: m.arms.iter().map(|a| self.lower_match_arm(a)).collect(),
                span: m.span.clone(),
            }),
            _ => HirExpr::Lit(HirLit::Bool(true)), // Fallback placeholder
        }
    }

    fn lower_match_arm(&var self, arm: &MatchArm) -> HirMatchArm {
        HirMatchArm {
            pat:   self.lower_pat(&arm.pat),
            guard: arm.guard.as_ref().map(|g| self.lower_expr(g)),
            body:  self.lower_expr(&arm.body),
            span:  arm.span.clone(),
        };
    }

    fn lower_lit(&var self, lit: &Lit) -> HirLit {
        match lit {
            Lit::Int(i)    => HirLit::Int(*i),
            Lit::Float(f)  => HirLit::Float(*f),
            Lit::Bool(b)   => HirLit::Bool(*b),
            Lit::String(s) => HirLit::String(s.clone()),
        }
    }

    fn lower_binop(&var self, op: &BinOp) -> HirBinOp {
        match op {
            BinOp::Add => HirBinOp::Add,
            BinOp::Sub => HirBinOp::Sub,
            BinOp::Mul => HirBinOp::Mul,
            BinOp::Div => HirBinOp::Div,
            BinOp::Mod => HirBinOp::Mod,
            BinOp::Pow => HirBinOp::Pow,
            BinOp::Eq  => HirBinOp::Eq,
            BinOp::Ne  => HirBinOp::Ne,
            BinOp::Lt  => HirBinOp::Lt,
            BinOp::Le  => HirBinOp::Le,
            BinOp::Gt  => HirBinOp::Gt,
            BinOp::Ge  => HirBinOp::Ge,
            BinOp::And => HirBinOp::And,
            BinOp::Or  => HirBinOp::Or,
        }
    }

    fn lower_unop(&var self, op: &UnOp) -> HirUnOp {
        match op {
            UnOp::Not    => HirUnOp::Not,
            UnOp::Neg    => HirUnOp::Neg,
            UnOp::BitNot => HirUnOp::BitNot,
        }
    }

    fn lower_block(&var self, block: &Block) -> HirBlock {
        let stmts = block.stmts.iter().map(|s| self.lower_stmt(s)).collect();
        let expr  = block.expr.as_ref().map(|e| Box::new(self.lower_expr(e)));
        HirBlock { stmts, expr, span: block.span.clone() };
    }

    fn lower_stmt(&var self, stmt: &Stmt) -> HirStmt {
        match stmt {
            Stmt::Let(let_stmt) => HirStmt::Let(HirLetStmt {
                pat:  self.lower_pat(&let_stmt.pat),
                ty:   let_stmt.ty.as_ref().map(|t| self.lower_type(t)),
                init: let_stmt.init.as_ref().map(|e| self.lower_expr(e)),
                span: let_stmt.span.clone(),
            }),
            Stmt::Var(var_stmt) => HirStmt::Var(HirVarStmt {
                name: Symbol { name: var_stmt.name.0.clone() },
                ty:   var_stmt.ty.as_ref().map(|t| self.lower_type(t)),
                init: var_stmt.init.as_ref().map(|e| self.lower_expr(e)),
                span: var_stmt.span.clone(),
            }),
            Stmt::Expr(expr) => HirStmt::Expr(self.lower_expr(expr)),
            Stmt::Item(_)    => HirStmt::Semi(HirExpr::Lit(HirLit::Bool(true))),
        }
    }

    fn lower_pat(&var self, pat: &Pat) -> HirPat {
        match pat {
            Pat::Wildcard       => HirPat::Wildcard,
            Pat::Ident(ident)   => HirPat::Binding(Symbol { name: ident.0.clone() }),
            Pat::Lit(lit)       => HirPat::Lit(self.lower_lit(lit)),
            Pat::Variant(v)     => HirPat::Variant(HirPatVariant {
                path:     self.lower_path(&v.path),
                bindings: v.bindings.iter().map(|p| self.lower_pat(p)).collect(),
            }),
            _                   => HirPat::Wildcard,
        }
    }

    fn lower_type(&var self, ty: &Type) -> HirTy {
        match ty {
            Type::Path(path) => HirTy::Path(self.lower_path(path)),
            Type::Bool       => HirTy::Bool,
            Type::I64        => HirTy::I64,
            Type::F64        => HirTy::F64,
            _                => HirTy::Path(HirPath { segments: [Symbol { name: "unknown".into() }] }),
        }
    }

    fn lower_path(&var self, path: &Path) -> HirPath {
        HirPath {
            segments: path.segments.iter().map(|s| Symbol { name: s.0.clone() }).collect(),
        };
    }

    fn lower_param(&var self, param: &Param) -> HirParam {
        HirParam {
            name: Symbol { name: param.name.0.clone() },
            ty:   self.lower_type(&param.ty),
            span: param.span.clone(),
        };
    }

    fn lower_field(&var self, field: &Field) -> HirField {
        HirField {
            name:       Symbol { name: field.name.0.clone() },
            ty:         self.lower_type(&field.ty),
            visibility: self.lower_visibility(&field.vis),
            span:       field.span.clone(),
        };
    }

    fn lower_variant(&var self, variant: &Variant) -> HirVariant {
        HirVariant {
            name:   Symbol { name: variant.name.0.clone() },
            fields: variant.fields.as_ref()
                .map(|fs| fs.iter().map(|f| self.lower_field(f)).collect())
                .unwrap_or([]),
            span:   variant.span.clone(),
        };
    }

    fn lower_body(&var self, block: &Block, params: &[HirParam]) -> HirBody {
        let value = self.lower_expr(
            block.expr.as_ref().unwrap_or(&Expr::Lit(Lit::Tuple([])))
        );
        HirBody {
            params: params.to_vec(),
            value,
            span: block.span.clone(),
        };
    }

    fn lower_visibility(&self, vis: &Visibility) -> HirVisibility {
        match vis {
            Visibility::Open   => HirVisibility::Open,
            Visibility::Pub    => HirVisibility::Public,
            Visibility::Crate  => HirVisibility::Crate,
            _                  => HirVisibility::Private,
        }
    }

    fn fresh_def_id(&var self) -> DefId {
        let id = self.next_def_id;
        self.next_def_id += 1;
        DefId { id };
    }

    fn resolve_names(&var self) -> Result<(), ()> {
        // Scoped name resolution pass
        Ok(())
    }

    fn type_check(&var self) -> Result<(), ()> {
        // Type inference & checking pass
        Ok(())
    }

    // ── Legacy compat lowering ──────────────────────────────────────────
    fn lower_struct_as_data(&var self, s: &StructItem) -> HirData {
        let def_id = self.fresh_def_id();
        HirData {
            def_id,
            name:       Symbol { name: s.name.0.clone() },
            fields:     s.fields.iter().map(|f| self.lower_field(f)).collect(),
            visibility: HirVisibility::Private,
            span:       s.span.clone(),
        };
    }

    fn lower_enum_as_cases(&var self, e: &EnumItem) -> HirCases {
        let def_id = self.fresh_def_id();
        HirCases {
            def_id,
            name:     Symbol { name: e.name.0.clone() },
            variants: e.variants.iter().map(|v| self.lower_variant(v)).collect(),
            span:     e.span.clone(),
        };
    }

    fn lower_trait_as_rules(&var self, t: &TraitItem) -> HirRules {
        let def_id = self.fresh_def_id();
        HirRules {
            def_id,
            name:    Symbol { name: t.name.0.clone() },
            methods: t.methods.iter().map(|m| self.lower_fn_sig(m)).collect(),
            span:    t.span.clone(),
        };
    }

    fn lower_fn_sig(&var self, sig: &FnSignature) -> HirFnSignature {
        HirFnSignature {
            name:      Symbol { name: sig.name.0.clone() },
            params:    sig.params.iter().map(|p| self.lower_param(p)).collect(),
            return_ty: sig.return_ty.as_ref()
                .map(|t| self.lower_type(t))
                .unwrap_or(HirTy::Tuple([])),
            span:      sig.span.clone(),
        };
    }

    fn lower_alias(&var self, alias_item: &AliasItem) -> HirAlias {
        let def_id = self.fresh_def_id();
        HirAlias {
            def_id,
            name:      Symbol { name: alias_item.name.0.clone() },
            target_ty: self.lower_type(&alias_item.ty),
            span:      alias_item.span.clone(),
        };
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// §10  TESTS
// ═══════════════════════════════════════════════════════════════════════════

space tests {
    use super::*;

    fn test_hir_program_creation() {
        let program = HirProgram {
            items: [],
            defs:  HashMap::new(),
        };
        assert_eq!(program.items.len(), 0);
    }

    fn test_hir_lowerer_initialization() {
        let lowerer = HirLowerer::new();
        assert_eq!(lowerer.next_def_id, 0);
        assert(lowerer.defs.is_empty());
        assert(lowerer.errors.is_empty());
        assert_eq!(lowerer.scopes.len(), 1);
    }

    fn test_v10_hir_item_variants() {
        // Ensure all v10 item types are representable
        let data_item = HirItem::Data(HirData {
            def_id:     DefId { id: 0 },
            name:       Symbol { name: "TestData".into() },
            fields:     [],
            visibility: HirVisibility::Open,
            span:       Span::dummy(),
        });

        let cases_item = HirItem::Cases(HirCases {
            def_id:   DefId { id: 1 },
            name:     Symbol { name: "TestCases".into() },
            variants: [],
            span:     Span::dummy(),
        });

        let rules_item = HirItem::Rules(HirRules {
            def_id:  DefId { id: 2 },
            name:    Symbol { name: "TestRules".into() },
            methods: [],
            span:    Span::dummy(),
        });
    }
}
