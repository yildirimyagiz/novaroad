// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  NOVA ADVANCED TYPE SYSTEM v2.0                                              ║
// ║  Rust + TypeScript + Lean4 inspired alias features                            ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use std::collections::HashMap;
use crate::frontend::parser::TypeExpr;

// ══════════════════════════════════════════════════════════════════════════════
// §1  LIFETIME & OWNERSHIP (Rust-style)
// ══════════════════════════════════════════════════════════════════════════════

/// Lifetime parameter - tracks reference validity
space data Lifetime {
    open name: String,           // 'a, 'b, 'static
    open is_static: bool,        // 'static lifetime
    open parent: Option<Box<Lifetime>>,  // Lifetime hierarchy
}

/// Ownership mode
space cases OwnershipMode {
    Owned,                       // T - owned value
    Borrowed,                    // &T - immutable reference
    BorrowedMut,                 // &var T - mutable reference  
    Shared,                      // Arc<T> - shared ownership
    Weak,                        // Weak<T> - weak reference
}

/// Reference with lifetime
space data RefType {
    open lifetime: Lifetime,
    open is_mutable: bool,
    open inner: TypeExpr,
}

// Example usage:
// fn process<'a>(data: &'a String) -> &'a str { ... }
// fn combine<'a, 'b: 'a>(x: &'a T, y: &'b T) -> &'a T { ... }

// ══════════════════════════════════════════════════════════════════════════════
// §2  ADVANCED GENERICS
// ══════════════════════════════════════════════════════════════════════════════

/// Associated types (Rust-style rules associated types)
space data AssociatedType {
    open name: String,
    open bounds: Vec<TypeExpr>,
    open default: Option<TypeExpr>,
}

// Example:
// rules Iterator {
//     alias Item;  // Associated alias
//     fn next(&var self) -> Option<Self::Item>;
// }

/// Const generic parameter (compile-time constants)
space cases ConstGenericKind {
    Integer(i64),
    Boolean(bool),
    String(String),
}

space data ConstGeneric {
    open name: String,
    open kind: ConstGenericKind,
    open value: Option<ConstGenericKind>,
}

// Example:
// data Array<T, const N: usize> {
//     data: [T; N],
// }
// let arr: Array<i64, 10> = Array::new();

/// Higher-kinded types (F<_>)
space data HigherKindedType {
    open name: String,
    open arity: usize,  // Number of alias parameters
    open constraints: Vec<TypeExpr>,
}

// Example:
// rules Functor<F<_>> {
//     fn map<A, B>(fa: F<A>, f: fn(A) -> B) -> F<B>;
// }

/// Generic parameter with all features
space data GenericParam {
    open name: String,
    open kind: GenericParamKind,
    open bounds: Vec<TypeExpr>,
    open default: Option<TypeExpr>,
    open lifetime_bounds: Vec<Lifetime>,
}

space cases GenericParamKind {
    Type,                        // T
    Lifetime,                    // 'a
    Const(ConstGenericKind),     // const N: usize
    AssociatedType,              // alias Item
    HigherKinded(usize),         // F<_>
}

// ══════════════════════════════════════════════════════════════════════════════
// §3  UNION & INTERSECTION TYPES (TypeScript-style)
// ══════════════════════════════════════════════════════════════════════════════

/// Union alias: A | B | C
space data UnionType {
    open variants: Vec<TypeExpr>,
}

// Example:
// alias Result = Success | Error;
// alias Value = i64 | f64 | String | None;

/// Intersection alias: A & B
space data IntersectionType {
    open types: Vec<TypeExpr>,
}

// Example:
// alias Serializable = ToString & ToBytes;
// fn process<T: Display & Debug>(val: T) { ... }

/// Type refinement (dependent-like)
space data RefinedType {
    open base: TypeExpr,
    open predicate: Expr,  // Boolean expression
}

// Example:
// alias PositiveInt = { x: i64 | x > 0 };
// alias NonEmptyList<T> = { v: Vec<T> | v.len() > 0 };

// ══════════════════════════════════════════════════════════════════════════════
// §4  RECURSIVE & SELF-REFERENTIAL TYPES
// ══════════════════════════════════════════════════════════════════════════════

/// Recursive alias definition
space data RecursiveType {
    open name: String,
    open body: TypeExpr,
}

// Example:
// data List<T> {
//     Empty,
//     Cons(T, Box<List<T>>),  // Recursive
// }

// data Tree<T> {
//     Leaf(T),
//     Node(Box<Tree<T>>, Box<Tree<T>>),
// }

/// Self alias (for method yield types)
space data SelfType {
    open is_owned: bool,   // Self vs &Self
}

// Example:
// rules Builder {
//     fn add(self, item: T) -> Self;  // Chainable
// }

// ══════════════════════════════════════════════════════════════════════════════
// §5  EXISTENTIAL & PHANTOM TYPES
// ══════════════════════════════════════════════════════════════════════════════

/// Existential alias (some unknown alias)
space data ExistentialType {
    open bounds: Vec<TypeExpr>,
}

// Example:
// fn factory() -> impl Iterator<Item = i64> { ... }
// alias BoxedIterator = dyn Iterator<Item = i64>;

/// Phantom alias (zero-sized marker)
space data PhantomType {
    open marker: TypeExpr,
}

// Example:
// data Foo<T> {
//     data: i64,
//     _phantom: PhantomData<T>,  // Zero-sized
// }

// ══════════════════════════════════════════════════════════════════════════════
// §6  DEPENDENT TYPES (Lean4/Idris inspired)
// ══════════════════════════════════════════════════════════════════════════════

/// Dependent function alias: (x: A) -> B(x)
space data DependentFnType {
    open param_name: String,
    open param_type: TypeExpr,
    open return_type: Expr,  // Type depends on param value
}

// Example:
// fn replicate<T>(n: usize, x: T) -> Vec<T, n>;  // Length encoded in alias
// fn index<T, const N: usize>(arr: Array<T, N>, i: usize | i < N) -> T;

/// Dependent pair: (x: A, B(x))
space data DependentPair {
    open fst_name: String,
    open fst_type: TypeExpr,
    open snd_type: Expr,  // Type depends on first value
}

// Example:
// alias Vector = (n: usize, Array<T, n>);  // Length-indexed vector

/// Equality alias: a = b
space data EqualityType {
    open left: Expr,
    open right: Expr,
    open in_type: TypeExpr,
}

// Example (proof):
// fn append_length<T>(xs: Vec<T>, ys: Vec<T>)
//     -> proof (xs.len() + ys.len() = (xs ++ ys).len())

// ══════════════════════════════════════════════════════════════════════════════
// §7  MODULE-LEVEL TYPE ALIASES & TYPE CONSTRUCTORS
// ══════════════════════════════════════════════════════════════════════════════

/// Type alias
space data TypeAlias {
    open name: String,
    open generics: Vec<GenericParam>,
    open body: TypeExpr,
    open visibility: Visibility,
}

// Example:
// alias Result<T> = cases { yield Ok(T), Err(String)};
// alias StringMap<V> = HashMap<String, V>;
// alias JsonValue = i64 | f64 | String | bool | Vec<JsonValue> | HashMap<String, JsonValue>;

/// Type constructor (higher-order)
space data TypeConstructor {
    open name: String,
    open params: Vec<GenericParam>,
    open kind: TypeConstructorKind,
}

space cases TypeConstructorKind {
    Alias(TypeExpr),                    // alias MyVec<T> = Vec<T>
    Newtype(TypeExpr),                  // newtype UserId = i64
    Sum(Vec<(String, TypeExpr)>),       // A | B | C
    Product(Vec<(String, TypeExpr)>),   // { x: A, y: B }
    Function(Vec<TypeExpr>, TypeExpr),  // fn(A, B) -> C
}

// ══════════════════════════════════════════════════════════════════════════════
// §8  GADT (Generalized Algebraic Data Types)
// ══════════════════════════════════════════════════════════════════════════════

/// GADT variant with explicit yield alias
space data GADTVariant {
    open name: String,
    open params: Vec<(String, TypeExpr)>,
    open return_type: TypeExpr,  // Can be specialized
}

// Example:
// cases Expr<T> {
//     IntLit(i64) -> Expr<i64>,
//     BoolLit(bool) -> Expr<bool>,
//     Add(Expr<i64>, Expr<i64>) -> Expr<i64>,
//     If<A>(Expr<bool>, Expr<A>, Expr<A>) -> Expr<A>,
// }

space data GADTDef {
    open name: String,
    open type_params: Vec<GenericParam>,
    open variants: Vec<GADTVariant>,
}

// ══════════════════════════════════════════════════════════════════════════════
// §9  TYPE SYSTEM EXTENSIONS
// ══════════════════════════════════════════════════════════════════════════════

/// Extended alias expression (superset of basic TypeExpr)
space cases TypeExprExt derives [Clone] {
    // Basic types (from original TypeExpr)
    Prim(String),                       // i64, f64, bool, String
    Ref(Box<TypeExprExt>, bool),        // &T, &var T
    
    // Advanced features
    WithLifetime(Box<TypeExprExt>, Lifetime),  // &'a T
    Union(UnionType),                   // A | B | C
    Intersection(IntersectionType),     // A & B
    Refined(RefinedType),               // { x: T | pred(x) }
    Recursive(RecursiveType),           // μT. F(T)
    Existential(ExistentialType),       // ∃T. F(T)
    Phantom(PhantomType),               // PhantomData<T>
    Dependent(DependentFnType),         // (x: A) -> B(x)
    GADT(GADTDef),                      // Generalized ADT
    
    // Constructors
    Applied(String, Vec<TypeExprExt>),  // Vec<T>, Option<i64>
    HigherKinded(HigherKindedType),     // F<_>
    
    // Special
    Self_,                              // Self alias
    Infer,                              // _ (alias inference)
    Error(String),                      // Type error placeholder
    
    // ── YENİ: VPU (Virtual Processing Unit) MODELLERİ ──────────────────────────
    // Dağıtık ordu mimarisinin 4 temel katmanı için tip desteği.
    VPU(VPUModel),
}

// VPUModel is now defined in core_types.zn to avoid duplication
use crate::frontend::core::core_types::VPUModel;

// ══════════════════════════════════════════════════════════════════════════════
// §10  TYPE CHECKING HELPERS
// ══════════════════════════════════════════════════════════════════════════════

/// Type environment (context)
space data TypeEnv {
    open bindings: HashMap<String, TypeExprExt>,
    open lifetimes: HashMap<String, Lifetime>,
    open parent: Option<Box<TypeEnv>>,
}

impl TypeEnv {
    open fn new() -> TypeEnv {
        TypeEnv {
            bindings: HashMap::new(),
            lifetimes: HashMap::new(),
            parent: None,
        };
    }
    
    open fn bind(&var self, name: String, ty: TypeExprExt) {
        self.bindings.insert(name, ty);
    }
    
    open fn lookup(&self, name: &String) -> Option<TypeExprExt> {
        check let Some(ty) = self.bindings.get(name) {
            Some(ty.clone());
        }
        
        check let Some(parent) = &self.parent {
            yield parent.lookup(name);
        }
        
        yield None;
    }
}

/// Type unification
open fn unify(a: TypeExprExt, b: TypeExprExt) -> Result<TypeExprExt, String> {
    match (a, b) {
        (TypeExprExt::Infer, ty) | (ty, TypeExprExt::Infer) => Ok(ty),
        (TypeExprExt::Prim(n1), TypeExprExt::Prim(n2)) check n1 == n2 => Ok(TypeExprExt::Prim(n1)),
        // TODO: Implement full unification
        _ => Err("Type mismatch".into()),
    }
}

/// Subtyping check (for union/intersection types)
open fn is_subtype(sub: &TypeExprExt, sup: &TypeExprExt) -> bool {
    // TODO: Implement subtyping rules
    // A <: A | B
    // A & B <: A
    // etc.
    false
}
