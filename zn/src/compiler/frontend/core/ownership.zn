    let r1 = &x;  // OK
    let r2 = &x;  // OK - multiple immutable borrows
    println(r1 + r2);
    
    // let r3 = &var x;  // ERROR: can't borrow mutably while immutably borrowed
}

Example 6: RAII (defer/drop)

