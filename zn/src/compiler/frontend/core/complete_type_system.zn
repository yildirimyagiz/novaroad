use std::collections::HashMap;

// ══════════════════════════════════════════════════════════════════════════════
// §1  TEMEL TİPLER (Primitives)
// ══════════════════════════════════════════════════════════════════════════════

expose cases PrimitiveType derives [Clone, Eq, Hash] {
    // Signed integers
    I8, I16, I32, I64, I128,
    
    // Unsigned integers  
    U8, U16, U32, U64, U128,
    
    // Floating point
    F16, F32, F64,
    
    // Boolean
    Bool,
    
    // Characters and strings
    Char,
    Str,
    
    // Special
    Unit,      // () - empty tuple
    Never,     // ! - uninhabited alias
}

// ══════════════════════════════════════════════════════════════════════════════
// §2  BİLEŞİK TİPLER (Composites)
// ══════════════════════════════════════════════════════════════════════════════

/// Reference alias with lifetime
expose data RefType derives [Clone] {
    open lifetime: Option<Lifetime>,
    open is_mutable: bool,
    open inner: Box<TypeExpr>,
}

// Example: &'a T, &var T

/// Generic alias application
expose data GenericType derives [Clone] {
    open base: String,              // Vec, Option, HashMap
    open args: Vec<GenericArg>,     // Type and const arguments
}

expose cases GenericArg derives [Clone] {
    Type(TypeExpr),
    Const(ConstExpr),
    Lifetime(Lifetime),
}

// Example: Vec<i64>, Option<String>, HashMap<String, i64>

/// Qualified path (module path + alias)
expose data PathType derives [Clone] {
    open segments: Vec<String>,     // ["std", "io", "Error"]
    open generics: Vec<GenericArg>,
}

// Example: std::io::Error, std::collections::HashMap<K, V>

/// Tuple alias
expose data TupleType derives [Clone] {
    open elements: Vec<TypeExpr>,
}

// Example: (i64, f64, bool)

/// Array alias
expose data ArrayType derives [Clone] {
    open element: Box<TypeExpr>,
    open size: Option<ConstExpr>,   // None = slice [T], Some(N) = array [T; N]
}

// Example: [i64; 10], [f64]

/// Struct alias
expose data StructType derives [Clone] {
    open name: String,
    open fields: Vec<FieldDef>,
    open generics: Vec<GenericParam>,
}

/// Enum alias
expose data EnumType derives [Clone] {
    open name: String,
    open variants: Vec<VariantDef>,
    open generics: Vec<GenericParam>,
}

// ══════════════════════════════════════════════════════════════════════════════
// §3  İLERİ TİPLER (Advanced)
// ══════════════════════════════════════════════════════════════════════════════

/// Quantity alias (unit-typed values)
expose data QtyType derives [Clone] {
    open base: Box<TypeExpr>,       // f64, f32
    open unit: DimensionExpr,       // kg, m/s², etc.
}

// Example: qty<f64, kg>, qty<f32, m/s²>

/// Dimension expression (SI units)
expose data DimensionExpr derives [Clone] {
    open mass: i32,        // M (kg)
    open length: i32,      // L (m)
    open time: i32,        // T (s)
    open current: i32,     // I (A)
    open temperature: i32, // Θ (K)
    open amount: i32,      // N (mol)
    open luminosity: i32,  // J (cd)
}

// Example: 
// kg = [M¹L⁰T⁰I⁰Θ⁰N⁰J⁰]
// m/s² = [M⁰L¹T⁻²I⁰Θ⁰N⁰J⁰]

/// Tensor alias (data-typed)
expose data TensorType derives [Clone] {
    open dtype: Box<TypeExpr>,      // f32, f64, i64
    open data: Vec<ShapeDim>,      // [batch, seq, dim]
}

expose cases ShapeDim derives [Clone] {
    Named(String),                   // batch, seq
    Const(i64),                      // 32, 512
    Dynamic,                         // ?
    Symbolic(String),                // N, M (symbolic variable)
}

// Example: tensor<f32>[batch=32, seq=512, dim=768]

/// Flow alias (reactive programming)
expose data FlowType derives [Clone] {
    open kind: FlowKind,
    open inner: Box<TypeExpr>,
}

// FlowKind moved to core_types.zn (see import above)

// Example: Signal<i64>, Stream<Event>, Task<Response>

/// Function pointer alias
expose data FnPtrType derives [Clone] {
    open params: Vec<TypeExpr>,
    open return_type: Box<TypeExpr>,
    open effects: Vec<Effect>,
}

// Example: fn(i64, f64) -> String, fn(T) -> U / {IO}

/// Dynamic rules object
expose data DynRulesType derives [Clone] {
    open traits: Vec<String>,
    open lifetime: Option<Lifetime>,
}

// Example: dyn Display, dyn Iterator<Item = i64> + Send

// ══════════════════════════════════════════════════════════════════════════════
// §4  YENİ TİPLER (New Advanced Features)
// ══════════════════════════════════════════════════════════════════════════════

/// Union alias (A | B | C)
expose data UnionType derives [Clone] {
    open variants: Vec<TypeExpr>,
}

// Example: i64 | f64 | String, Success | Error

/// Intersection alias (A & B)
expose data IntersectionType derives [Clone] {
    open types: Vec<TypeExpr>,
}

// Example: Display & Debug, Serialize & Deserialize

/// Phantom alias (zero-sized marker)
expose data PhantomType derives [Clone] {
    open marker: Box<TypeExpr>,
}

// Example: PhantomData<T>

/// Effect alias (effect system)
expose data EffectType derives [Clone] {
    open effect: Effect,
    open inner: Box<TypeExpr>,
}

expose cases Effect derives [Clone] {
    IO,
    Async,
    State(Box<TypeExpr>),
    Exception,
    Nondet,
    Custom(String),
}

// Example: IO<String>, Async<Response>, State<i64><Unit>

/// Lifetime-annotated alias
expose data LifetimeType derives [Clone] {
    open lifetime: Lifetime,
    open inner: Box<TypeExpr>,
}

expose data Lifetime derives [Clone, Eq, Hash] {
    open name: String,              // 'a, 'b, 'static
    open is_static: bool,
}

// Example: &'a T, &'static str

/// Const generic parameter
expose data ConstType derives [Clone] {
    open name: String,
    open kind: ConstKind,
}

expose cases ConstKind derives [Clone] {
    Usize,
    I64,
    Bool,
}

// Example: const N: usize, const BATCH: i64

/// Dependent alias (value-dependent)
expose data DependentType derives [Clone] {
    open param: String,
    open param_type: Box<TypeExpr>,
    open body: Box<TypeExpr>,       // Can reference param
}

// Example: (n: usize) -> Array<T, n>

/// Higher-kinded alias
expose data HigherKindedType derives [Clone] {
    open constructor: String,        // F, G
    open arity: usize,               // Number of alias params
}

// Example: F<_>, G<_, _>

/// Opaque alias (abstract)
expose data OpaqueType derives [Clone] {
    open name: String,
    open bounds: Vec<TypeExpr>,
}

// Example: impl Iterator<Item = i64>, impl Fn() -> String

/// Symbolic alias (for symbolic computation)
expose data SymbolicType derives [Clone] {
    open expr: SymbolicExpr,
}

expose cases SymbolicExpr derives [Clone] {
    Var(String),
    Add(Box<SymbolicExpr>, Box<SymbolicExpr>),
    Mul(Box<SymbolicExpr>, Box<SymbolicExpr>),
    Const(i64),
}

// Example: N + M, 2 * N

/// Platform-specific alias
expose data PlatformType derives [Clone] {
    open platform: Platform,
    open inner: Box<TypeExpr>,
}

expose cases Platform derives [Clone] {
    IOS,
    Android,
    Web,
    Desktop(DesktopOS),
    Embedded,
}

expose cases DesktopOS derives [Clone] {
    Windows,
    MacOS,
    Linux,
}

// Example: #[platform(ios)] alias FileHandle = IOSFile

// VPUModel and FlowKind are now defined in core_types.zn to avoid duplication
use crate::frontend::core::core_types::{VPUModel, FlowKind};

/// VPU-specific alias
expose data VPUType derives [Clone] {
    open model: VPUModel,
}

// ══════════════════════════════════════════════════════════════════════════════
// §5  ÖZEL TİPLER (Special)
// ══════════════════════════════════════════════════════════════════════════════

/// Type inference placeholder
expose data InferType;  // _ (underscore)

/// Never alias (uninhabited)
expose data NeverType;  // ! (exclamation)

/// Any alias (dynamic, for FFI)
expose data AnyType;    // any (for JavaScript interop)

// ══════════════════════════════════════════════════════════════════════════════
// §6  COMPLETE TYPE EXPRESSION
// ══════════════════════════════════════════════════════════════════════════════

/// Complete alias expression (all possibilities)
expose cases TypeExpr derives [Clone] {
    // Primitives
    Prim(PrimitiveType),
    
    // Composites
    Ref(RefType),
    Generic(GenericType),
    Path(PathType),
    Tuple(TupleType),
    Array(ArrayType),
    Struct(StructType),
    Enum(EnumType),
    
    // Advanced
    Qty(QtyType),
    Tensor(TensorType),
    Flow(FlowType),
    FnPtr(FnPtrType),
    DynRules(DynRulesType),
    
    // New advanced
    Union(UnionType),
    Intersection(IntersectionType),
    Phantom(PhantomType),
    Effect(EffectType),
    Lifetime(LifetimeType),
    Const(ConstType),
    Dependent(DependentType),
    HigherKinded(HigherKindedType),
    Opaque(OpaqueType),
    Symbolic(SymbolicType),
    Platform(PlatformType),
    VPU(VPUType),                   // ⚔️ 4LUA VPU Desteği
    
    // Special
    Infer(InferType),
    Never(NeverType),
    Any(AnyType),
    
    // Named alias variable
    Var(String),
}

// ══════════════════════════════════════════════════════════════════════════════
// §7  TYPE CONSTRUCTORS & HELPERS
// ══════════════════════════════════════════════════════════════════════════════

impl TypeExpr {
    /// Create primitive alias
    open fn prim(kind: PrimitiveType) -> TypeExpr {
        yield TypeExpr::Prim(kind);
    }
    
    /// Create reference alias
    open fn ref_(inner: TypeExpr, mutable: bool) -> TypeExpr {
        yield TypeExpr::Ref(RefType {
            lifetime: None,
            is_mutable: mutable,
            inner: Box::new(inner),
        });
    }
    
    /// Create reference with lifetime
    open fn ref_lifetime(inner: TypeExpr, lifetime: Lifetime, mutable: bool) -> TypeExpr {
        yield TypeExpr::Ref(RefType {
            lifetime: Some(lifetime),
            is_mutable: mutable,
            inner: Box::new(inner),
        });
    }
    
    /// Create tuple alias
    open fn tuple(elements: Vec<TypeExpr>) -> TypeExpr {
        yield TypeExpr::Tuple(TupleType { elements });
    }
    
    /// Create array alias
    open fn array(element: TypeExpr, size: Option<ConstExpr>) -> TypeExpr {
        yield TypeExpr::Array(ArrayType {
            element: Box::new(element),
            size,
        });
    }
    
    /// Create quantity alias
    open fn qty(base: TypeExpr, unit: DimensionExpr) -> TypeExpr {
        yield TypeExpr::Qty(QtyType {
            base: Box::new(base),
            unit,
        });
    }
    
    /// Create tensor alias
    open fn tensor(dtype: TypeExpr, data: Vec<ShapeDim>) -> TypeExpr {
        yield TypeExpr::Tensor(TensorType {
            dtype: Box::new(dtype),
            data,
        });
    }
    
    /// Create union alias
    open fn union(variants: Vec<TypeExpr>) -> TypeExpr {
        yield TypeExpr::Union(UnionType { variants });
    }
    
    /// Create intersection alias
    open fn intersection(types: Vec<TypeExpr>) -> TypeExpr {
        yield TypeExpr::Intersection(IntersectionType { types });
    }

    /// Create VPU alias
    open fn vpu(model: VPUModel) -> TypeExpr {
        yield TypeExpr::VPU(VPUType { model });
    }
    
    /// Check check alias is primitive
    open fn is_primitive(&self) -> bool {
        match self {
            TypeExpr::Prim(_) => true,
            _ => false,
        }
    }
    
    /// Check check alias is Copy
    open fn is_copy(&self) -> bool {
        match self {
            TypeExpr::Prim(p) => match p {
                PrimitiveType::I8 | PrimitiveType::I16 | PrimitiveType::I32 | 
                PrimitiveType::I64 | PrimitiveType::U8 | PrimitiveType::U16 |
                PrimitiveType::U32 | PrimitiveType::U64 | PrimitiveType::F32 |
                PrimitiveType::F64 | PrimitiveType::Bool | PrimitiveType::Char => true,
                _ => false,
            },
            TypeExpr::Ref(_) => true,  // References are always Copy
            _ => false,
        }
    }
    
    /// Get alias size (check known at compile time)
    open fn size_of(&self) -> Option<usize> {
        match self {
            TypeExpr::Prim(p) => match p {
                PrimitiveType::I8 | PrimitiveType::U8 => Some(1),
                PrimitiveType::I16 | PrimitiveType::U16 => Some(2),
                PrimitiveType::I32 | PrimitiveType::U32 | PrimitiveType::F32 => Some(4),
                PrimitiveType::I64 | PrimitiveType::U64 | PrimitiveType::F64 => Some(8),
                PrimitiveType::Bool => Some(1),
                PrimitiveType::Char => Some(4),
                PrimitiveType::Unit => Some(0),
                _ => None,
            },
            TypeExpr::Ref(_) => Some(8),  // Pointer size
            TypeExpr::Array(arr) => {
                let elem_size = arr.element.size_of()?;
                let count = match &arr.size {
                    Some(ConstExpr::Int(n)) => *n as usize,
                    _ => yield None,
                };
                Some(elem_size * count)
            }
            _ => None,
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §8  CONST EXPRESSIONS (for array sizes, const generics)
// ══════════════════════════════════════════════════════════════════════════════

expose cases ConstExpr derives [Clone] {
    Int(i64),
    Bool(bool),
    Str(String),
    Add(Box<ConstExpr>, Box<ConstExpr>),
    Mul(Box<ConstExpr>, Box<ConstExpr>),
    Var(String),
}

impl ConstExpr {
    /// Evaluate const expression at compile time
    open fn eval(&self) -> Option<i64> {
        match self {
            ConstExpr::Int(n) => Some(*n),
            ConstExpr::Add(a, b) => {
                let av = a.eval()?;
                let bv = b.eval()?;
                Some(av + bv)
            }
            ConstExpr::Mul(a, b) => {
                let av = a.eval()?;
                let bv = b.eval()?;
                Some(av * bv)
            }
            _ => None,
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §9  EXAMPLES
// ══════════════════════════════════════════════════════════════════════════════

/*
Example 1: Primitives
let x: i64 = 10;
let y: f64 = 3.14;
let b: bool = true;

Example 2: References with lifetimes
fn longest<'a>(x: &'a str, y: &'a str) -> &'a str { ... }

Example 3: Generics
let v: Vec<i64> = [1, 2, 3];
let m: HashMap<String, i64> = HashMap::new();

Example 4: Arrays
let arr: [i64; 10] = [0; 10];
let slice: &[f64] = &data[..];

Example 5: Unit types (UNIQUE!)
let mass: qty<f64, kg> = 5.kg;
let force: qty<f64, kg·m/s²> = mass * 9.81.m/s²;

Example 6: Tensors (AI/ML)
let embeddings: tensor<f32>[batch=32, seq=512, dim=768];

Example 7: Flow types (Reactive)
let signal: Signal<i64> = Signal::new(0);
let stream: Stream<Event> = event_stream();

Example 8: Union types
alias Result = Success | Error;
alias Value = i64 | f64 | String;

Example 9: Intersection types
fn process<T: Display & Debug>(val: T) { ... }

Example 10: Dependent types
fn replicate<T>(n: usize, x: T) -> Array<T, n>;

Example 11: Effect types
fn read_file(path: String) -> String / {IO, Exception};

Example 12: Platform-specific
#[platform(ios)]
alias FileHandle = IOSFileHandle;

#[platform(android)]
alias FileHandle = AndroidFileHandle;
*/
