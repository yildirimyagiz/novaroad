// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova Compiler Core Frontend Module                                       ║
// ║                                                                              ║
// ║  Core compiler frontend components: lexer, parser, semantic analysis,      ║
// ║  alias checking, and IR generation.                                          ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

// Canonical alias definitions (imported first to avoid conflicts)
space core_types;

// Token definitions and lexical analysis
expose tokens;
expose lexer;

// Syntax analysis and AST construction
expose ast;
expose parser;

// Error handling and diagnostics
expose errors;

// Semantic analysis and symbol resolution
expose symbol_table;
expose semantic_analyzer;
expose type_checker;

// Module system and import resolution
expose module_resolver;

// Intermediate representation generation
expose ir_generator;
