// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova Lexer-Parser Bridge                                                ║
// ║  Converts Vec<Token> to Vec<Spanned<Token>> for parser compatibility         ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use span::{Span, Spanned};
use tokens::{Token, TokenKind};

// Bridge function to convert lexer output to parser input
open fn bridge_tokens_to_parser(tokens: Vec<Token>) -> Vec<Spanned<Token>> {
    var spanned_tokens = [];
    
    each token in tokens {
        let span = Span::new(
            span::BytePos(token.line as usize),
            span::BytePos(token.line as usize + token.lexeme.len()),
            span::SyntaxContext(0)
        );
        
        // Convert TokenKind to parser Token type
        let parser_token = match token.kind {
            TokenKind::Fn => Token::Fn,
            TokenKind::Let => Token::Let,
            TokenKind::Var => Token::Var,
            TokenKind::Check => Token::Check,
            TokenKind::Yield => Token::Yield,
            TokenKind::Abort => Token::Abort,
            TokenKind::Next => Token::Next,
            TokenKind::Data => Token::Data,
            TokenKind::Cases => Token::Cases,
            TokenKind::Rules => Token::Rules,
            TokenKind::Skill => Token::Impl, // Skill -> Impl
            TokenKind::Flow => Token::Flow,
            TokenKind::Space => Token::Mod, // Space -> Mod
            TokenKind::Given => Token::Given,
            TokenKind::Tag => Token::Tag,
            TokenKind::Open => Token::Open,
            TokenKind::Alias => Token::Alias,
            TokenKind::Component => Token::Component,
            TokenKind::View => Token::View,
            TokenKind::Else => Token::Else,
            TokenKind::Match => Token::Match,
            TokenKind::Each => Token::Each,
            TokenKind::For => Token::For,
            TokenKind::In => Token::In,
            TokenKind::Loop => Token::Loop,
            TokenKind::While => Token::While,
            TokenKind::Return => Token::Return,
            TokenKind::Try => Token::Try,
            TokenKind::Catch => Token::Catch,
            TokenKind::Sync => Token::Sync,
            TokenKind::Thread => Token::Thread,
            TokenKind::Block => Token::Block,
            TokenKind::Use => Token::Use,
            TokenKind::From => Token::From,
            TokenKind::As => Token::As,
            TokenKind::Async => Token::Async,
            TokenKind::Await => Token::Await,
            TokenKind::Spawn => Token::Spawn,
            TokenKind::Channel => Token::Channel,
            TokenKind::Unit => Token::Unit,
            TokenKind::Qty => Token::Qty,
            TokenKind::Dims => Token::Dims,
            TokenKind::Tensor => Token::Tensor,
            TokenKind::On => Token::On,
            TokenKind::Parallel => Token::Parallel,
            TokenKind::Kernel => Token::Kernel,
            TokenKind::Silicon_Vpu => Token::Silicon_Vpu,
            TokenKind::Kernel_Vpu => Token::Kernel_Vpu,
            TokenKind::Web_Nexus => Token::Web_Nexus,
            TokenKind::Mesh_Vpu => Token::Mesh_Vpu,
            TokenKind::Grad => Token::Grad,
            TokenKind::Diff => Token::Diff,
            TokenKind::Integral => Token::Integral,
            TokenKind::Sum => Token::Sum,
            TokenKind::Prod => Token::Prod,
            TokenKind::Limit => Token::Limit,
            TokenKind::Solve => Token::Solve,
            TokenKind::Assert => Token::Assert,
            TokenKind::Ensure => Token::Ensure,
            TokenKind::Require => Token::Require,
            TokenKind::Proof => Token::Proof,
            TokenKind::Assume => Token::Assume,
            TokenKind::Axiom => Token::Axiom,
            TokenKind::Molecule => Token::Molecule,
            TokenKind::React => Token::React,
            TokenKind::Seq => Token::Seq,
            TokenKind::Elem => Token::Elem,
            TokenKind::Plus => Token::Plus,
            TokenKind::Minus => Token::Minus,
            TokenKind::Star => Token::Star,
            TokenKind::Slash => Token::Slash,
            TokenKind::Percent => Token::Percent,
            TokenKind::Power => Token::Power,
            TokenKind::MatMul => Token::MatMul,
            TokenKind::And => Token::And,
            TokenKind::Or => Token::Or,
            TokenKind::Not => Token::Not,
            TokenKind::BitAnd => Token::BitAnd,
            TokenKind::BitOr => Token::BitOr,
            TokenKind::BitXor => Token::BitXor,
            TokenKind::Shl => Token::Shl,
            TokenKind::Shr => Token::Shr,
            TokenKind::EqEq => Token::EqEq,
            TokenKind::NotEq => Token::NotEq,
            TokenKind::Lt => Token::Lt,
            TokenKind::Gt => Token::Gt,
            TokenKind::Lte => Token::Lte,
            TokenKind::Gte => Token::Gte,
            TokenKind::Assign => Token::Assign,
            TokenKind::PlusEq => Token::PlusEq,
            TokenKind::MinusEq => Token::MinusEq,
            TokenKind::StarEq => Token::StarEq,
            TokenKind::SlashEq => Token::SlashEq,
            TokenKind::Pipe => Token::Pipe,
            TokenKind::Arrow => Token::Arrow,
            TokenKind::FatArrow => Token::FatArrow,
            TokenKind::Walrus => Token::Walrus,
            TokenKind::ColonColon => Token::ColonColon,
            TokenKind::Dot => Token::Dot,
            TokenKind::DotDot => Token::DotDot,
            TokenKind::DotDotEq => Token::DotDotEq,
            TokenKind::At => Token::At,
            TokenKind::Question => Token::Question,
            TokenKind::Hash => Token::Hash,
            TokenKind::LParen => Token::LParen,
            TokenKind::RParen => Token::RParen,
            TokenKind::LBrace => Token::LBrace,
            TokenKind::RBrace => Token::RBrace,
            TokenKind::LBracket => Token::LBracket,
            TokenKind::RBracket => Token::RBracket,
            TokenKind::Comma => Token::Comma,
            TokenKind::Semi => Token::Semi,
            TokenKind::Colon => Token::Colon,
            TokenKind::SelfVal => Token::SelfVal,
            TokenKind::Dyn => Token::Dyn,
            TokenKind::Crate => Token::Crate,
            TokenKind::Underscore => Token::Underscore,
            TokenKind::Tilde => Token::Tilde,
            TokenKind::Eof => Token::Eof,
            TokenKind::Ident(s) => Token::Ident(s.clone()),
            TokenKind::LitInt(n) => Token::IntLit(*n),
            TokenKind::LitFloat(n) => Token::FloatLit(*n),
            TokenKind::LitStr(s) => Token::StringLit(s.clone()),
            TokenKind::LitTrue => Token::True,
            TokenKind::LitFalse => Token::False,
            _ => Token::Illegal,
        };
        
        spanned_tokens.push(Spanned::new(parser_token, span));
    }
    
    yield spanned_tokens;
}
