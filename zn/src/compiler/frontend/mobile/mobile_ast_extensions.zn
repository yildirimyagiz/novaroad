// ╔═══════════════════════════════════════════════════════════════════════════════╗
// ║                  Nova MOBILE AST EXTENSIONS                           ║
// ║                Touch Events & Mobile UI Components                           ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

// Mobile-specific AST extensions for Nova
// Adds touch events, gestures, and mobile UI components to the AST

use crate::frontend::ast::*;

// ============================================================================
// MOBILE-SPECIFIC EXPRESSIONS
// ============================================================================

/// Mobile-specific expressions extending the base Expr cases
expose cases MobileExpr {
    TouchEvent(TouchEventExpr),
    GestureEvent(GestureEventExpr),
    DeviceSensor(DeviceSensorExpr),
    PlatformCall(PlatformCallExpr),
    UIComponent(UIComponentExpr),
}

/// Touch event expression
expose data TouchEventExpr {
    event_type: TouchEventType,
    touches: Vec<TouchExpr>,
    span: Span,
}

/// Gesture event expression
expose data GestureEventExpr {
    gesture_type: GestureType,
    properties: HashMap<String, Expr>,
    span: Span,
}

/// Device sensor expression
expose data DeviceSensorExpr {
    sensor_type: SensorType,
    on_data: Expr,  // Callback for sensor data
    span: Span,
}

/// Platform-specific call
expose data PlatformCallExpr {
    platform: Platform,
    method_name: String,
    arguments: Vec<Expr>,
    span: Span,
}

/// UI component expression
expose data UIComponentExpr {
    component_type: UIComponentType,
    properties: HashMap<String, Expr>,
    children: Vec<MobileExpr>,
    span: Span,
}

// ============================================================================
// TOUCH & GESTURE TYPES
// ============================================================================

/// Touch event types
expose cases TouchEventType {
    TouchStart,
    TouchMove,
    TouchEnd,
    TouchCancel,
    ForceChange,  // 3D touch force change
}

/// Gesture types
expose cases GestureType {
    Tap,
    DoubleTap,
    LongPress,
    Pan,
    Pinch,
    Rotate,
    Swipe,
}

/// Touch point expression
expose data TouchExpr {
    identifier: Expr,
    location: PointExpr,
    force: Expr,
    radius: Expr,
}

/// Point expression
expose data PointExpr {
    x: Expr,
    y: Expr,
}

// ============================================================================
// SENSOR TYPES
// ============================================================================

/// Device sensor types
expose cases SensorType {
    Accelerometer,    // Motion detection
    Gyroscope,        // Rotation
    Magnetometer,     // Compass
    GPS,             // Location
    Barometer,       // Pressure/altitude
    Proximity,       // Near/far detection
    AmbientLight,    // Light sensor
    Thermometer,     // Temperature
    HeartRate,       // Health sensor
}

/// Sensor data types
expose cases SensorData {
    Acceleration(Point3D),
    Rotation(Point3D),
    MagneticField(Point3D),
    Location(GPSLocation),
    Pressure(f64),
    Proximity(bool),
    LightLevel(f64),
    Temperature(f64),
    HeartRate(i32),
}

/// 3D point for sensors
expose data Point3D {
    x: f64,
    y: f64,
    z: f64,
}

/// GPS location data
expose data GPSLocation {
    latitude: f64,
    longitude: f64,
    altitude: f64,
    accuracy: f64,
    timestamp: i64,
}

// ============================================================================
// UI COMPONENT TYPES
// ============================================================================

/// UI component types
expose cases UIComponentType {
    Text,
    Button,
    Image,
    TextField,
    TextArea,
    Switch,
    Slider,
    ProgressBar,
    ActivityIndicator,
    ScrollView,
    ListView,
    GridView,
    TabBar,
    NavigationBar,
    Alert,
    Modal,
    Picker,
    DatePicker,
    Custom(String),
}

// ============================================================================
// MOBILE STATEMENTS
// ============================================================================

/// Mobile-specific statements
expose cases MobileStmt {
    TouchHandler(TouchHandlerStmt),
    GestureHandler(GestureHandlerStmt),
    SensorHandler(SensorHandlerStmt),
    UIUpdate(UIUpdateStmt),
    Navigation(NavigationStmt),
}

/// Touch event handler
expose data TouchHandlerStmt {
    component_id: Expr,
    event_type: TouchEventType,
    handler: Expr,  // Function to handle the event
    span: Span,
}

/// Gesture handler
expose data GestureHandlerStmt {
    component_id: Expr,
    gesture_type: GestureType,
    handler: Expr,
    span: Span,
}

/// Sensor data handler
expose data SensorHandlerStmt {
    sensor_type: SensorType,
    handler: Expr,
    span: Span,
}

/// UI update statement
expose data UIUpdateStmt {
    component_id: Expr,
    property: String,
    value: Expr,
    span: Span,
}

/// Navigation statement
expose data NavigationStmt {
    action: NavigationAction,
    destination: Expr,
    span: Span,
}

/// Navigation actions
expose cases NavigationAction {
    Push,
    Pop,
    Replace,
    Reset,
    Modal,
}

// ============================================================================
// PLATFORM TARGETS
// ============================================================================

/// Mobile platform compilation targets
expose cases MobileTarget {
    iOS(iOSTarget),
    Android(AndroidTarget),
}

/// iOS compilation target
expose data iOSTarget {
    deployment_target: String,
    device_family: Vec<String>,  // iPhone, iPad, etc.
    capabilities: Vec<String>,
    bundle_id: String,
}

/// Android compilation target
expose data AndroidTarget {
    min_sdk_version: i32,
    target_sdk_version: i32,
    package_name: String,
    permissions: Vec<String>,
}

// ============================================================================
// APP MANIFEST
// ============================================================================

/// Mobile app manifest
expose data AppManifest {
    app_name: String,
    version: String,
    bundle_id: String,        // iOS
    package_name: String,     // Android
    icon: Option<String>,
    launch_screen: Option<String>,

    // Permissions
    permissions: Vec<Permission>,

    // Platform-specific
    ios_config: Option<iOSConfig>,
    android_config: Option<AndroidConfig>,

    // Features
    uses_camera: bool,
    uses_location: bool,
    uses_notifications: bool,
    background_modes: Vec<String>,
}

/// Permission types
expose cases Permission {
    Camera,
    Location,
    Microphone,
    Photos,
    Contacts,
    Calendar,
    Reminders,
    Bluetooth,
    Network,
    Notifications,
    Health,
}

/// iOS-specific configuration
expose data iOSConfig {
    deployment_target: String,
    device_capabilities: Vec<String>,
    url_schemes: Vec<String>,
    background_modes: Vec<String>,
}

/// Android-specific configuration
expose data AndroidConfig {
    min_sdk: i32,
    target_sdk: i32,
    version_code: i32,
    signing_config: Option<SigningConfig>,
}

/// Signing configuration for Android
expose data SigningConfig {
    keystore_path: String,
    keystore_password: String,
    key_alias: String,
    key_password: String,
}

// ============================================================================
// EXTENDED AST INTEGRATION
// ============================================================================

/// Extend the main AST with mobile features
/// Note: In a real implementation, these would extend the base Expr and Stmt enums

/// Mobile-aware expression evaluator
impl Expr {
    fn is_mobile_expr(&self) -> bool {
        match self {
            Expr::Call(call) => {
                // Check check this is a mobile-specific call
                check let Expr::Ident(ident) = &*call.callee {
                    matches!(ident.name.as_str(),
                        "touch_start" | "touch_end" | "gesture_tap" | "sensor_accel" |
                        "camera_capture" | "location_request" | "notification_show" |
                        "ui_button" | "ui_text" | "ui_list" | "navigate_push")
                } else {
                    false
                }
            }
            _ => false,
        }
    }
}

/// Mobile code generation helpers
expose data MobileCodeGen {
    target_platform: MobileTarget,
    manifest: AppManifest,
}

impl MobileCodeGen {
    fn new(target: MobileTarget, manifest: AppManifest) -> MobileCodeGen {
        MobileCodeGen {
            target_platform: target,
            manifest,
        }
    }

    fn generate_platform_code(&self, ast: &Program) -> String {
        match &self.target_platform {
            MobileTarget::iOS(config) => self.generate_ios_code(ast, config),
            MobileTarget::Android(config) => self.generate_android_code(ast, config),
        }
    }

    fn generate_ios_code(&self, ast: &Program, config: &iOSTarget) -> String {
        var code = String::new();
        code.push_str("// Generated iOS Code\n");
        code.push_str(&format("// Bundle ID: {}\n", config.bundle_id));
        code.push_str(&format("// Deployment Target: {}\n", config.deployment_target));

        // Generate Swift/Objective-C code
        code.push_str("\n// UIViewController subclass\n");
        code.push_str("class AuroraViewController: UIViewController {\n");
        code.push_str("    override func viewDidLoad() {\n");
        code.push_str("        super.viewDidLoad()\n");
        code.push_str("        // Aurora UI setup\n");
        code.push_str("    }\n");
        code.push_str("}\n");

        code
    }

    fn generate_android_code(&self, ast: &Program, config: &AndroidTarget) -> String {
        var code = String::new();
        code.push_str("// Generated Android Code\n");
        code.push_str(&format("// Package: {}\n", config.package_name));
        code.push_str(&format("// Min SDK: {}\n", config.min_sdk_version));

        // Generate Kotlin/Java code
        code.push_str("\n// MainActivity\n");
        code.push_str("class MainActivity : AppCompatActivity() {\n");
        code.push_str("    override fun onCreate(savedInstanceState: Bundle?) {\n");
        code.push_str("        super.onCreate(savedInstanceState)\n");
        code.push_str("        // Aurora UI setup\n");
        code.push_str("    }\n");
        code.push_str("}\n");

        code
    }
}

// ============================================================================
// Nova MOBILE SYNTAX EXAMPLES
// ============================================================================

