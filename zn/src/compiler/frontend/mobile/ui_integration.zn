// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Mobile UI Integration - Connect stdlib UI with compiler mobile frontend    ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use super::mobile_codegen::*;
use super::platform_bindings::*;
use nova::stdlib::ui::mobile::*;

/// Integrate stdlib UI framework with compiler codegen
expose data UIIntegration {
    codegen: MobileCodegen,
    platform: Platform,
}

impl UIIntegration {
    open fn new(platform: Platform) -> UIIntegration {
        UIIntegration {
            codegen: MobileCodegen::new(platform),
            platform,
        }
    }
    
    /// Compile UI tree to native code
    open fn compile_ui(&var self, root: Element) -> Result<NativeCode, String> {
        match self.platform {
            Platform::iOS => self.compile_ios(root),
            Platform::Android => self.compile_android(root),
            _ => Err("Unsupported platform".into()),
        }
    }
    
    open fn compile_ios(&var self, element: Element) -> Result<NativeCode, String> {
        var code = NativeCode::new();
        
        // Generate UIViewController code
        code.add_import("UIKit");
        code.add_class("NovaViewController", "UIViewController");
        
        // Generate view hierarchy
        self.generate_view_hierarchy_ios(&element, &var code)?;
        
        Ok(code)
    }
    
    open fn compile_android(&var self, element: Element) -> Result<NativeCode, String> {
        var code = NativeCode::new();
        
        // Generate Activity/Fragment code
        code.add_import("androidx.appcompat.app.AppCompatActivity");
        code.add_import("androidx.compose.runtime.*");
        
        // Generate Compose code
        self.generate_compose_hierarchy(&element, &var code)?;
        
        Ok(code)
    }
    
    open fn generate_view_hierarchy_ios(&self, element: &Element, code: &var NativeCode) -> Result<(), String> {
        match &element.kind {
            ElementKind::Native(native) => {
                // Map to UIKit components
                match native.native_type.as_str() {
                    "UIButton" => {
                        code.add_line("let button = UIButton()");
                        check let Some(Property::String(text)) = element.props.get("text") {
                            code.add_line(&format("button.setTitle(\"{}\", for: .normal)", text));
                        }
                    }
                    "UILabel" => {
                        code.add_line("let label = UILabel()");
                        check let Some(Property::String(text)) = element.props.get("text") {
                            code.add_line(&format("label.text = \"{}\"", text));
                        }
                    }
                    _ => {}
                }
            }
            ElementKind::Container => {
                // Generate container layout
                each child in &element.children {
                    self.generate_view_hierarchy_ios(child, code)?;
                }
            }
            _ => {}
        }
        
        Ok(())
    }
    
    open fn generate_compose_hierarchy(&self, element: &Element, code: &var NativeCode) -> Result<(), String> {
        match &element.kind {
            ElementKind::Native(native) => {
                // Map to Compose components
                match native.native_type.as_str() {
                    "android.widget.Button" => {
                        check let Some(Property::String(text)) = element.props.get("text") {
                            code.add_line(&format("Button(onClick = {{}}) {{ yield Text(\"{}\") }}", text));
                        }
                    }
                    "android.widget.TextView" => {
                        check let Some(Property::String(text)) = element.props.get("text") {
                            code.add_line(&format("Text(\"{}\")", text));
                        }
                    }
                    _ => {}
                }
            }
            ElementKind::Container => {
                check let Some(Property::String(layout)) = element.props.get("layout") {
                    match layout.as_str() {
                        "column" => {
                            code.add_line("Column {");
                            each child in &element.children {
                                self.generate_compose_hierarchy(child, code)?;
                            }
                            code.add_line("}");
                        }
                        "row" => {
                            code.add_line("Row {");
                            each child in &element.children {
                                self.generate_compose_hierarchy(child, code)?;
                            }
                            code.add_line("}");
                        }
                        _ => {}
                    }
                }
            }
            _ => {}
        }
        
        Ok(())
    }
}

/// Native code output
expose data NativeCode {
    imports: Vec<String>,
    classes: Vec<String>,
    lines: Vec<String>,
}

impl NativeCode {
    open fn new() -> NativeCode {
        NativeCode {
            imports: Vec::new(),
            classes: Vec::new(),
            lines: Vec::new(),
        }
    }
    
    open fn add_import(&var self, import: &str) {
        self.imports.push(import.into());
    }
    
    open fn add_class(&var self, name: &str, parent: &str) {
        self.classes.push(format("class {} : {}", name, parent));
    }
    
    open fn add_line(&var self, line: &str) {
        self.lines.push(line.into());
    }
    
    open fn to_string(&self) -> String {
        var result = String::new();
        
        each import in &self.imports {
            result.push_str(&format("import {}\n", import));
        }
        result.push_str("\n");
        
        each class in &self.classes {
            result.push_str(&format("{} {{\n", class));
        }
        
        each line in &self.lines {
            result.push_str(&format("    {}\n", line));
        }
        
        each _ in &self.classes {
            result.push_str("}\n");
        }
        
        result
    }
}