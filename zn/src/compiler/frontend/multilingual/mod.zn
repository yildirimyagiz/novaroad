// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova Multilingual Frontend - Nova-unique Dil Yapısı                       ║
// ║  Çok dilli frontend parsing ve analysis (space kullanır)                        ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

// Nova'nın unique dil yapısı - Frontend ile uyumlu olarak space kullanır
space multilingual_parser;
space language_detector;
space cultural_analyzer;
space syntax_validator;

/// Çok dilli frontend manager
pub struct MultilingualFrontend {
    parser: MultilingualParser,
    language_detector: LanguageDetector,
    cultural_analyzer: CulturalAnalyzer,
    syntax_validator: SyntaxValidator,
}

impl MultilingualFrontend {
    pub fn new() -> Self {
        MultilingualFrontend {
            parser: MultilingualParser::new(),
            language_detector: LanguageDetector::new(),
            cultural_analyzer: CulturalAnalyzer::new(),
            syntax_validator: SyntaxValidator::new(),
        }
    }
    
    pub fn parse_multilingual(&mut self, code: &str) -> Result<MultilingualAST, FrontendError> {
        // 1. Dil tespiti
        let detected_language = self.language_detector.detect(code)?;
        
        // 2. Kültürel analiz
        let cultural_context = self.cultural_analyzer.analyze(code, &detected_language)?;
        
        // 3. Dil spesifik parsing
        let parsed_ast = self.parser.parse(code, &detected_language)?;
        
        // 4. Syntax validasyonu
        self.syntax_validator.validate(&parsed_ast, &detected_language)?;
        
        let multilingual_ast = MultilingualAST {
            original_code: code.to_string(),
            detected_language,
            cultural_context,
            parsed_ast,
        };
        
        Ok(multilingual_ast)
    }
    
    pub fn get_supported_languages(&self) -> Vec<String> {
        self.parser.get_supported_languages()
    }
}

/// Çok dilli AST
pub struct MultilingualAST {
    pub original_code: String,
    pub detected_language: String,
    pub cultural_context: CulturalContext,
    pub parsed_ast: ParsedAST,
}

/// Frontend hata tipleri
#[derive(Debug, Clone)]
pub enum FrontendError {
    LanguageDetectionFailed(String),
    UnsupportedLanguage(String),
    ParseError(String),
    CulturalAnalysisError(String),
    SyntaxValidationError(String),
}

impl std::fmt::Display for FrontendError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            FrontendError::LanguageDetectionFailed(msg) => write!(f, "Language detection failed: {}", msg),
            FrontendError::UnsupportedLanguage(lang) => write!(f, "Unsupported language: {}", lang),
            FrontendError::ParseError(msg) => write!(f, "Parse error: {}", msg),
            FrontendError::CulturalAnalysisError(msg) => write!(f, "Cultural analysis error: {}", msg),
            FrontendError::SyntaxValidationError(msg) => write!(f, "Syntax validation error: {}", msg),
        }
    }
}

impl std::error::Error for FrontendError {}

// Re-export types from submodules
pub use multilingual_parser::*;
pub use language_detector::*;
pub use cultural_analyzer::*;
pub use syntax_validator::*;
