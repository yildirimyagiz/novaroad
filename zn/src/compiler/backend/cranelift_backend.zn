//===- cranelift_backend.zn - Cranelift Code Generation Backend -------------===//
//
// Part of the Nova Compiler - Fast Debug Builds
//
//===----------------------------------------------------------------------===//
//
// This backend uses Cranelift for fast compilation and debugging.
// Cranelift is chosen for its speed and reliability in debug builds,
// providing better developer experience compared to LLVM's debug overhead.
//
// Key Features:
// - Fast compilation (5-10x faster than LLVM for debug builds)
// - Good debug info generation
// - Incremental compilation support
// - Cross-platform native code generation
//
// Architecture:
// - IR → Cranelift IR → Machine Code
// - Uses Cranelift's SSA-based IR
// - Supports all Nova targets via Cranelift backends
//

use std::collections::HashMap;
use std::sync::Arc;

// ══════════════════════════════════════════════════════════════════════════════
// §1  CRANELIFT BACKEND CORE
// ══════════════════════════════════════════════════════════════════════════════

expose data CraneliftBackend derives [Clone] {
    open target: String,              // "x86_64", "aarch64", "wasm32", etc.
    open opt_level: OptLevel,
    open features: Vec<String>,       // CPU features: "sse4.2", "avx2", etc.
    open debug_info: bool,
    open pic: bool,                   // Position Independent Code
}

expose cases OptLevel derives [Clone, Copy] {
    None,        // -O0 - fast debug builds
    Speed,       // -O2 - release builds
    SpeedAndSize,// -Os - size optimized
}

impl CraneliftBackend {

    open fn new(target: String) -> CraneliftBackend {
        CraneliftBackend {
            target,
            opt_level: OptLevel::None,
            features: [],
            debug_info: true,
            pic: false,
        }
    }

    open fn with_opt_level(self, level: OptLevel) -> CraneliftBackend {
        CraneliftBackend { opt_level: level, ..self }
    }

    open fn with_features(self, features: Vec<String>) -> CraneliftBackend {
        CraneliftBackend { features, ..self }
    }

    open fn enable_debug_info(self, enabled: bool) -> CraneliftBackend {
        CraneliftBackend { debug_info: enabled, ..self }
    }

    open fn enable_pic(self, enabled: bool) -> CraneliftBackend {
        CraneliftBackend { pic: enabled, ..self }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §2  CODE GENERATION CONTEXT
// ══════════════════════════════════════════════════════════════════════════════

/// Cranelift code generation context
/// Manages the lifetime of Cranelift objects and compilation state
expose data CodegenContext derives [Clone] {
    open backend: CraneliftBackend,
    open module: Arc<CraneliftModule>,
    open functions: HashMap<String, CraneliftFunction>,
    open globals: HashMap<String, CraneliftGlobal>,
    open types: HashMap<String, CraneliftType>,
}

expose data CraneliftModule derives [Clone] {
    open name: String,
    open target_config: TargetConfig,
    open functions: Vec<CompiledFunction>,
    open data_sections: Vec<DataSection>,
}

expose data TargetConfig derives [Clone] {
    open triple: String,              // "x86_64-apple-darwin"
    open pointer_width: u32,          // 32 or 64
    open endianness: Endianness,
    open features: Vec<String>,
}

expose cases Endianness derives [Clone, Copy] {
    Little,
    Big,
}

// ══════════════════════════════════════════════════════════════════════════════
// §3  FUNCTION COMPILATION
// ══════════════════════════════════════════════════════════════════════════════

expose data CraneliftFunction derives [Clone] {
    open name: String,
    open signature: FunctionSignature,
    open body: Option<FunctionBody>,
    open compiled: Option<CompiledFunction>,
}

expose data FunctionSignature derives [Clone] {
    open params: Vec<CraneliftType>,
    open returns: Vec<CraneliftType>,
    open calling_convention: CallingConvention,
}

expose cases CallingConvention derives [Clone, Copy] {
    SystemV,     // Linux, macOS, BSD
    WindowsFastcall,
    Wasm,
}

expose data FunctionBody derives [Clone] {
    open blocks: Vec<BasicBlock>,
    open locals: Vec<LocalVar>,
}

expose data BasicBlock derives [Clone] {
    open label: String,
    open instructions: Vec<Instruction>,
}

expose data LocalVar derives [Clone] {
    open name: String,
    open ty: CraneliftType,
    open index: u32,
}

// ══════════════════════════════════════════════════════════════════════════════
// §4  INSTRUCTION SET
// ══════════════════════════════════════════════════════════════════════════════

expose cases Instruction derives [Clone] {
    // Control Flow
    Jump(String),                    // jump to block
    Branch(Value, String, String),   // check cond then true_block else false_block
    Return(Option<Value>),           // yield value
    Call(String, Vec<Value>),        // call function

    // Memory Operations
    Load(Value, CraneliftType),      // load from address
    Store(Value, Value),             // store value to address
    GlobalLoad(String),              // load global
    GlobalStore(String, Value),      // store to global

    // Arithmetic
    IAdd(Value, Value),              // integer add
    ISub(Value, Value),
    IMul(Value, Value),
    IDiv(Value, Value),
    FAdd(Value, Value),              // float add
    FSub(Value, Value),
    FMul(Value, Value),
    FDiv(Value, Value),

    // Comparison
    ICmp(CmpOp, Value, Value),       // integer compare
    FCmp(CmpOp, Value, Value),       // float compare

    // Type Conversion
    SExt(Value, CraneliftType),      // sign extend
    ZExt(Value, CraneliftType),      // zero extend
    Trunc(Value, CraneliftType),     // truncate
    F32ToF64(Value),
    F64ToF32(Value),
    I32ToF64(Value),
    F64ToI32(Value),

    // Special
    Phi(Vec<(Value, String)>),       // phi node for SSA
}

expose cases CmpOp derives [Clone, Copy] {
    Eq, Ne, Lt, Le, Gt, Ge,
}

expose data Value derives [Clone] {
    open id: u32,
    open ty: CraneliftType,
}

// ══════════════════════════════════════════════════════════════════════════════
// §5  TYPE SYSTEM
// ══════════════════════════════════════════════════════════════════════════════

expose cases CraneliftType derives [Clone] {
    I8, I16, I32, I64,           // signed integers
    U8, U16, U32, U64,           // unsigned integers
    F32, F64,                    // floats
    B1,                          // boolean (i8)
    Ptr(CraneliftType),          // pointer to alias
    Array(CraneliftType, u32),   // array alias
    Struct(Vec<CraneliftType>),  // data alias
    Void,                        // unit alias
}

// ══════════════════════════════════════════════════════════════════════════════
// §6  COMPILATION OUTPUT
// ══════════════════════════════════════════════════════════════════════════════

expose data CompiledFunction derives [Clone] {
    open name: String,
    open code: Vec<u8>,               // machine code bytes
    open relocations: Vec<Relocation>,
    open debug_info: Option<DebugInfo>,
}

expose data Relocation derives [Clone] {
    open offset: u32,                 // offset in code
    open kind: RelocationKind,
    open symbol: String,              // target symbol
}

expose cases RelocationKind derives [Clone, Copy] {
    Absolute32,
    Relative32,
    FunctionCall,
    DataLoad,
}

expose data DebugInfo derives [Clone] {
    open line_table: Vec<LineEntry>,
    open symbols: HashMap<String, SymbolInfo>,
}

expose data LineEntry derives [Clone] {
    open address: u32,
    open line: u32,
    open file: String,
}

expose data SymbolInfo derives [Clone] {
    open name: String,
    open address: u32,
    open size: u32,
    open kind: SymbolKind,
}

expose cases SymbolKind derives [Clone, Copy] {
    Function,
    Global,
    Local,
}

// ══════════════════════════════════════════════════════════════════════════════
// §7  DATA SECTIONS
// ══════════════════════════════════════════════════════════════════════════════

expose data DataSection derives [Clone] {
    open name: String,
    open kind: SectionKind,
    open data: Vec<u8>,
    open alignment: u32,
}

expose cases SectionKind derives [Clone, Copy] {
    ReadOnlyData,
    ReadWriteData,
    UninitializedData,
}

expose data CraneliftGlobal derives [Clone] {
    open name: String,
    open ty: CraneliftType,
    open init: Option<Vec<u8>>,       // initial data
    open mutable: bool,
}

// ══════════════════════════════════════════════════════════════════════════════
// §8  COMPILATION INTERFACE
// ══════════════════════════════════════════════════════════════════════════════

impl CodegenContext {

    open fn compile_module(self, ir_module: IRModule) -> Result<CompiledModule, CodegenError> {
        // 1. Set up target configuration
        let target_config = self.setup_target_config();

        // 2. Create Cranelift module
        var module = CraneliftModule::new(ir_module.name, target_config);

        // 3. Compile each function
        each ir_func in ir_module.functions {
            let compiled_func = self.compile_function(ir_func)?;
            module.functions.push(compiled_func);
        }

        // 4. Handle globals and data sections
        each ir_global in ir_module.globals {
            let global = self.compile_global(ir_global)?;
            module.globals.push(global);
        }

        // 5. Finalize and yield Ok(CompiledModule { module })
    }

    fn setup_target_config(self) -> TargetConfig {
        // Platform-specific target setup
        match self.backend.target.as_str() {
            "x86_64" => TargetConfig {
                triple: "x86_64-unknown-unknown".into(),
                pointer_width: 64,
                endianness: Endianness::Little,
                features: self.backend.features.clone(),
            },
            "aarch64" => TargetConfig {
                triple: "aarch64-unknown-unknown".into(),
                pointer_width: 64,
                endianness: Endianness::Little,
                features: [],
            },
            "wasm32" => TargetConfig {
                triple: "wasm32-unknown-unknown".into(),
                pointer_width: 32,
                endianness: Endianness::Little,
                features: [],
            },
            _ => panic("Unsupported target"),
        }
    }

    fn compile_function(self, ir_func: IRFunction) -> Result<CompiledFunction, CodegenError> {
        // Convert IR function to Cranelift IR
        let signature = self.convert_signature(ir_func.signature);
        var function = CraneliftFunction::new(ir_func.name, signature);

        // Build function body
        let body = self.build_function_body(ir_func.body)?;
        function.body = Some(body);

        // Compile to machine code
        let compiled = self.emit_machine_code(function)?;
        Ok(compiled)
    }

    fn convert_signature(self, ir_sig: IRSignature) -> FunctionSignature {
        FunctionSignature {
            params: ir_sig.params.iter().map(|t| self.convert_type(t)).collect(),
            returns: ir_sig.returns.iter().map(|t| self.convert_type(t)).collect(),
            calling_convention: CallingConvention::SystemV, // Default
        }
    }

    fn convert_type(self, ir_type: IRType) -> CraneliftType {
        match ir_type {
            IRType::I32 => CraneliftType::I32,
            IRType::I64 => CraneliftType::I64,
            IRType::F32 => CraneliftType::F32,
            IRType::F64 => CraneliftType::F64,
            IRType::Ptr(inner) => CraneliftType::Ptr(Box::new(self.convert_type(*inner))),
            IRType::Void => CraneliftType::Void,
            _ => CraneliftType::I32, // Placeholder
        }
    }

    fn build_function_body(self, ir_body: IRBody) -> Result<FunctionBody, CodegenError> {
        var body = FunctionBody::new();

        // Convert IR blocks to Cranelift blocks
        each ir_block in ir_body.blocks {
            let block = self.convert_block(ir_block)?;
            body.blocks.push(block);
        }

        Ok(body)
    }

    fn convert_block(self, ir_block: IRBlock) -> Result<BasicBlock, CodegenError> {
        var block = BasicBlock::new(ir_block.label);

        // Convert IR instructions
        each ir_inst in ir_block.instructions {
            let inst = self.convert_instruction(ir_inst)?;
            block.instructions.push(inst);
        }

        Ok(block)
    }

    fn convert_instruction(self, ir_inst: IRInstruction) -> Result<Instruction, CodegenError> {
        match ir_inst {
            IRInstruction::Add(lhs, rhs) => Ok(Instruction::IAdd(lhs, rhs)),
            IRInstruction::Return(val) => Ok(Instruction::Return(val)),
            _ => Err(CodegenError::UnsupportedInstruction),
        }
    }

    fn emit_machine_code(self, function: CraneliftFunction) -> Result<CompiledFunction, CodegenError> {
        // This would interface with Cranelift's code emission
        // For now, yield a placeholder
        Ok(CompiledFunction {
            name: function.name,
            code: [], // Would be filled by Cranelift
            relocations: [],
            debug_info: check self.backend.debug_info { yield Some(DebugInfo::new())} else { yield None },
        })
    }

    fn compile_global(self, ir_global: IRGlobal) -> Result<CraneliftGlobal, CodegenError> {
        Ok(CraneliftGlobal {
            name: ir_global.name,
            ty: self.convert_type(ir_global.ty),
            init: ir_global.init,
            mutable: ir_global.mutable,
        })
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §9  ERROR HANDLING
// ══════════════════════════════════════════════════════════════════════════════

expose cases CodegenError derives [Clone] {
    UnsupportedInstruction,
    TypeMismatch(String),
    TargetNotSupported(String),
    CompilationFailed(String),
}

expose data CompiledModule derives [Clone] {
    open module: CraneliftModule,
}

// ══════════════════════════════════════════════════════════════════════════════
// §10  UTILITY FUNCTIONS
// ══════════════════════════════════════════════════════════════════════════════

impl CraneliftModule {
    open fn new(name: String, config: TargetConfig) -> CraneliftModule {
        CraneliftModule {
            name,
            target_config: config,
            functions: [],
            data_sections: [],
        }
    }
}

impl FunctionBody {
    open fn new() -> FunctionBody {
        FunctionBody {
            blocks: [],
            locals: [],
        }
    }
}

impl BasicBlock {
    open fn new(label: String) -> BasicBlock {
        BasicBlock {
            label,
            instructions: [],
        }
    }
}

impl DebugInfo {
    open fn new() -> DebugInfo {
        DebugInfo {
            line_table: [],
            symbols: HashMap::new(),
        }
    }
}

// ══════════════════════════════════════════════════════════════════════════════
// §11  INTEGRATION WITH COMPILER PIPELINE
// ══════════════════════════════════════════════════════════════════════════════

/// Backend rules implementation for Cranelift
impl CraneliftBackend {

    open fn generate_code(self, ir: IRModule) -> Result<CompiledModule, CodegenError> {
        let context = CodegenContext {
            backend: self,
            module: Arc::new(CraneliftModule::new(ir.name.clone(), TargetConfig::default())),
            functions: HashMap::new(),
            globals: HashMap::new(),
            types: HashMap::new(),
        };

        context.compile_module(ir)
    }

    open fn supported_targets(self) -> Vec<String> {
        [
            "x86_64-linux".into(),
            "x86_64-macos".into(),
            "x86_64-windows".into(),
            "aarch64-linux".into(),
            "aarch64-macos".into(),
            "wasm32-browser".into(),
        ]
    }

    open fn target_features(self, target: String) -> Vec<String> {
        match target.as_str() {
            "x86_64-linux" => ["sse2".into(), "sse4.1".into()],
            "aarch64-macos" => ["neon".into()],
            _ => [],
        }
    }
}

impl TargetConfig {
    open fn default() -> TargetConfig {
        TargetConfig {
            triple: "x86_64-unknown-unknown".into(),
            pointer_width: 64,
            endianness: Endianness::Little,
            features: [],
        }
    }
}