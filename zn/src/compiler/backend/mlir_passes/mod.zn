// Nova module syntax:
//   expose mod_name
//   expose mod_name as alias
//
// All MLIR pass components are public by default within this crate.

// ── MLIR Pass Infrastructure ──────────────────────────────────────────────

// Core pass system and traits
expose nova_passes_impl

// TableGen pass definitions for MLIR integration
expose NovaPasses.td

// ── Type Safety Passes ────────────────────────────────────────────────────

// Ownership and borrowing analysis
expose borrow_checker

// Lifetime inference and validation
expose lifetime_inference

// Linear alias enforcement
expose linear_type_checker

// ── Effect System Passes ──────────────────────────────────────────────────

// Effect inference and checking
expose effect_system

// Side effect analysis and optimization
expose effect_analysis

// ── Advanced Analysis Passes ─────────────────────────────────────────────

// Escape analysis for memory optimization
expose escape_analysis

// Alias analysis using ownership information
expose alias_analysis

// Region-based memory management
expose region_analysis

// ── Optimization Passes ───────────────────────────────────────────────────

// Automatic parallelization based on effects
expose auto_parallelization

// Memory operation coalescing
expose memory_coalescing

// Zero-cost abstraction elimination
expose zero_cost_abstraction

// ── Pass Pipelines ────────────────────────────────────────────────────────

// Pre-configured pass pipelines
expose pipelines

// ── Testing Infrastructure ────────────────────────────────────────────────

// Comprehensive test suite
expose test_mlir_passes

// ── Re-exports for external crates ─────────────────────────────────────────

// Public API surface for pass system
expose nova_passes_impl::PassManager as pass_manager
expose nova_passes_impl::create_type_safety_pipeline as type_safety_pipeline
expose nova_passes_impl::create_optimization_pipeline as optimization_pipeline
expose nova_passes_impl::create_full_pipeline as full_pipeline
expose pipelines::*
expose test_mlir_passes::*