use std::collections::{HashMap, HashSet, Vec};

// ============================================================================
// PASS INFRASTRUCTURE
// ============================================================================

ability MLIRPass {
    fn name(&self) -> String;
    fn run(&var self, module: &var MLIRModule) -> PassResult;
}

kind PassResult {
    Success,
    Failure(Vec<String>),  // errors
    Modified,              // IR was changed
}

data PassManager {
    passes: Vec<Box<dyn MLIRPass>>,
    statistics: HashMap<String, PassStats>,
}

data PassStats {
    run_count: i32,
    time_us: i64,
    modifications: i32,
}

impl PassManager {
    fn new() -> PassManager {
        PassManager {
            passes: vec[],
            statistics: HashMap::new(),
        }
    }

    fn add_pass(&var self, pass: Box<dyn MLIRPass>) {
        self.passes.push(pass);
    }

    fn run_pipeline(&var self, module: &var MLIRModule) -> bool {
        println(format("🚀 Running Nova MLIR Pass Pipeline ({} passes)", self.passes.len()));

        var all_success = true;

        each pass in &var self.passes {
            let name = pass.name();
            println(format("  ▶ Running: {}", name));

            let start = std::time::now();
            let result = pass.run(module);
            let elapsed = std::time::elapsed(start);

            match result {
                PassResult::Success => {
                    println("    ✓ Success");
                }
                PassResult::Modified => {
                    println("    ✓ Modified IR");
                }
                PassResult::Failure(errors) => {
                    println(format("    ✗ Failed with {} errors:", errors.len()));
                    each err in errors {
                        println(format("      - {}", err));
                    }
                    all_success = false;
                }
            }

            // Update statistics
            let stats = self.statistics.entry(name.clone()).or_insert(PassStats {
                run_count: 0,
                time_us: 0,
                modifications: 0,
            });
            stats.run_count += 1;
            stats.time_us += elapsed;
        }

        all_success
    }
}

// ============================================================================
// MLIR IR STRUCTURES (Simplified)
// ============================================================================

data MLIRModule {
    functions: Vec<MLIRFunction>,
    types: Vec<MLIRType>,
    attributes: HashMap<String, MLIRAttribute>,
}

data MLIRFunction {
    name: String,
    params: Vec<(String, MLIRType)>,
    return_type: MLIRType,
    blocks: Vec<MLIRBlock>,
    effects: EffectSet,
    ownership_attrs: HashMap<String, OwnershipState>,
}

data MLIRBlock {
    label: String,
    operations: Vec<MLIROperation>,
}

kind MLIROperation {
    Move { source: String, dest: String },
    Borrow { value: String, lifetime: String, is_mut: bool },
    Drop { value: String },
    Call { callee: String, args: Vec<String>, effects: EffectSet },
    PureCall { callee: String, args: Vec<String> },
    LinearAlloc { result: String },
    LinearConsume { resource: String },
    LifetimeBegin { lifetime: String },
    LifetimeEnd { lifetime: String },
    WithEffect { effects: EffectSet, body: Vec<MLIROperation> },
}

kind MLIRType {
    Linear(Box<MLIRType>),
    Affine(Box<MLIRType>),
    Borrowed { target: Box<MLIRType>, lifetime: String, is_mut: bool },
    Owned(Box<MLIRType>),
    I64,
    F64,
    Bool,
}

kind MLIRAttribute {
    EffectSet(EffectSet),
    ProofLevel(ProofLevel),
    Lifetime(String),
}

// ============================================================================
// EFFECT SYSTEM (from effect_system.zn)
// ============================================================================

bitflags! {
    data EffectSet: u64 {
        const PURE = 0;
        const IO = 1 << 0;
        const MEMORY = 1 << 1;
        const THROW = 1 << 2;
        const ASYNC = 1 << 3;
        const UNSAFE = 1 << 4;
        const UNKNOWN = 1 << 5;
    }
}

kind ProofLevel {
    Verified,
    Trusted,
    Heuristic,
    Unknown,
}

// ============================================================================
// OWNERSHIP STATES (from borrow_checker.zn)
// ============================================================================

kind OwnershipState {
    Owned,
    BorrowedShared(i32),  // count
    BorrowedMutable,
    Moved(String),  // moved to location
    Dropped,
}

// ============================================================================
// PASS 1: BORROW CHECKER
// ============================================================================

data BorrowCheckPass {
    errors: Vec<String>,
    var_states: HashMap<String, OwnershipState>,
    active_borrows: HashMap<String, Vec<String>>,  // var -> borrowers
}

impl BorrowCheckPass {
    fn new() -> BorrowCheckPass {
        BorrowCheckPass {
            errors: vec[],
            var_states: HashMap::new(),
            active_borrows: HashMap::new(),
        }
    }

    fn check_borrow(&var self, value: &str, is_mut: bool, lifetime: &str) {
        check let Some(state) = self.var_states.get(value) {
            match state {
                OwnershipState::Owned => {
                    // OK - can borrow owned value
                    check is_mut {
                        self.var_states.insert(value.into(), OwnershipState::BorrowedMutable);
                    } else {
                        self.var_states.insert(value.into(), OwnershipState::BorrowedShared(1));
                    }
                }
                OwnershipState::BorrowedShared(count) => {
                    check is_mut {
                        self.errors.push(format(
                            "Cannot create mutable borrow of '{}' while shared borrows exist", 
                            value
                        ));
                    } else {
                        // Multiple shared borrows OK
                        self.var_states.insert(value.into(), OwnershipState::BorrowedShared(count + 1));
                    }
                }
                OwnershipState::BorrowedMutable => {
                    self.errors.push(format(
                        "Cannot borrow '{}' - already mutably borrowed", 
                        value
                    ));
                }
                OwnershipState::Moved(location) => {
                    self.errors.push(format(
                        "Cannot borrow '{}' - value was moved to {}", 
                        value, location
                    ));
                }
                OwnershipState::Dropped => {
                    self.errors.push(format(
                        "Cannot borrow '{}' - value was dropped", 
                        value
                    ));
                }
            }
        } else {
            self.errors.push(format("Unknown variable: '{}'", value));
        }
    }

    fn check_move(&var self, source: &str, dest: &str) {
        check let Some(state) = self.var_states.get(source) {
            match state {
                OwnershipState::Owned => {
                    // OK - move ownership
                    self.var_states.insert(source.into(), OwnershipState::Moved(dest.into()));
                    self.var_states.insert(dest.into(), OwnershipState::Owned);
                }
                OwnershipState::BorrowedShared(_) | OwnershipState::BorrowedMutable => {
                    self.errors.push(format(
                        "Cannot move '{}' - it is currently borrowed", 
                        source
                    ));
                }
                OwnershipState::Moved(location) => {
                    self.errors.push(format(
                        "Cannot move '{}' - already moved to {}", 
                        source, location
                    ));
                }
                OwnershipState::Dropped => {
                    self.errors.push(format(
                        "Cannot move '{}' - value was dropped", 
                        source
                    ));
                }
            }
        }
    }
}

impl MLIRPass for BorrowCheckPass {
    fn name(&self) -> String {
        "BorrowCheckPass".into()
    }

    fn run(&var self, module: &var MLIRModule) -> PassResult {
        self.errors.clear();
        
        each func in &module.functions {
            // Initialize all parameters as Owned
            each entry in &func.params  { let (param_name, _) = entry;
                self.var_states.insert(param_name.clone(), OwnershipState::Owned);
            }
            
            // Check all operations
            each block in &func.blocks {
                each op in &block.operations {
                    match op {
                        MLIROperation::Borrow { value, lifetime, is_mut } => {
                            self.check_borrow(value, *is_mut, lifetime);
                        }
                        MLIROperation::Move { source, dest } => {
                            self.check_move(source, dest);
                        }
                        MLIROperation::Drop { value } => {
                            self.var_states.insert(value.clone(), OwnershipState::Dropped);
                        }
                        _ => {}
                    }
                }
            }
        }
        
        check self.errors.is_empty() {
            PassResult::Success
        } else {
            PassResult::Failure(self.errors.clone())
        }
    }
}

// ============================================================================
// PASS 2: EFFECT INFERENCE
// ============================================================================

data EffectInferencePass {
    function_effects: HashMap<String, EffectSet>,
    trust_unannotated: bool,
}

impl EffectInferencePass {
    fn new(trust_unannotated: bool) -> EffectInferencePass {
        EffectInferencePass {
            function_effects: HashMap::new(),
            trust_unannotated,
        }
    }

    fn infer_operation_effects(&self, op: &MLIROperation) -> EffectSet {
        match op {
            MLIROperation::PureCall { .. } => EffectSet::PURE,
            MLIROperation::Call { effects, .. } => *effects,
            MLIROperation::WithEffect { effects, .. } => *effects,
            MLIROperation::Move { .. } |
            MLIROperation::Borrow { .. } |
            MLIROperation::Drop { .. } |
            MLIROperation::LinearAlloc { .. } |
            MLIROperation::LinearConsume { .. } |
            MLIROperation::LifetimeBegin { .. } |
            MLIROperation::LifetimeEnd { .. } => EffectSet::PURE,
        }
    }

    fn infer_block_effects(&self, block: &MLIRBlock) -> EffectSet {
        var combined = EffectSet::PURE;
        each op in &block.operations {
            combined |= self.infer_operation_effects(op);
        }
        combined
    }
}

impl MLIRPass for EffectInferencePass {
    fn name(&self) -> String {
        "EffectInferencePass".into()
    }

    fn run(&var self, module: &var MLIRModule) -> PassResult {
        var modified = false;
        
        each func in &var module.functions {
            var inferred = EffectSet::PURE;
            
            each block in &func.blocks {
                inferred |= self.infer_block_effects(block);
            }
            
            // Update function effects check they differ
            check func.effects != inferred {
                println("    Inferred effects for {}: {:?}", func.name, inferred);
                func.effects = inferred;
                modified = true;
            }
            
            self.function_effects.insert(func.name.clone(), inferred);
        }
        
        check modified {
            PassResult::Modified
        } else {
            PassResult::Success
        }
    }
}

// ============================================================================
// PASS 3: LINEAR TYPE CHECKER
// ============================================================================

data LinearTypeCheckPass {
    linear_vars: HashMap<String, bool>,  // var -> consumed?
    errors: Vec<String>,
}

impl LinearTypeCheckPass {
    fn new() -> LinearTypeCheckPass {
        LinearTypeCheckPass {
            linear_vars: HashMap::new(),
            errors: [],
        }
    }

    fn check_operation(&var self, op: &MLIROperation) {
        match op {
            MLIROperation::LinearAlloc { result } => {
                self.linear_vars.insert(result.clone(), false);
            }
            MLIROperation::LinearConsume { resource } => {
                check let Some(consumed) = self.linear_vars.get_mut(resource) {
                    check *consumed {
                        self.errors.push(format(
                            "Linear resource '{}' consumed more than once", 
                            resource
                        ));
                    } else {
                        *consumed = true;
                    }
                } else {
                    self.errors.push(format(
                        "Unknown linear resource: '{}'", 
                        resource
                    ));
                }
            }
            _ => {}
        }
    }
}

impl MLIRPass for LinearTypeCheckPass {
    fn name(&self) -> String {
        "LinearTypeCheckPass".into()
    }

    fn run(&var self, module: &var MLIRModule) -> PassResult {
        self.errors.clear();
        
        each func in &module.functions {
            self.linear_vars.clear();
            
            each block in &func.blocks {
                each op in &block.operations {
                    self.check_operation(op);
                }
            }
            
            // Check that all linear vars were consumed
            each entry in &self.linear_vars  { let (var, consumed) = entry;
                check !consumed {
                    self.errors.push(format(
                        "Linear resource '{}' not consumed in function '{}'", 
                        var, func.name
                    ));
                }
            }
        }
        
        check self.errors.is_empty() {
            PassResult::Success
        } else {
            PassResult::Failure(self.errors.clone())
        }
    }
}

// ============================================================================
// PASS 4: LIFETIME INFERENCE (Non-Lexical Lifetimes)
// ============================================================================

data LifetimeInferencePass {
    lifetime_regions: HashMap<String, LifetimeRegion>,
    constraints: Vec<LifetimeConstraint>,
    errors: Vec<String>,
}

data LifetimeRegion {
    name: String,
    start_point: i32,
    end_point: i32,
}

data LifetimeConstraint {
    sub: String,      // sub-lifetime
    sup: String,      // super-lifetime (must outlive sub)
}

impl LifetimeInferencePass {
    fn new() -> LifetimeInferencePass {
        LifetimeInferencePass {
            lifetime_regions: HashMap::new(),
            constraints: [],
            errors: [],
        }
    }

    fn add_constraint(&var self, sub: String, sup: String) {
        self.constraints.push(LifetimeConstraint { sub, sup });
    }

    fn solve_constraints(&var self) -> bool {
        // Simplified constraint solving
        // In real implementation, this would:
        // 1. Build dependency graph
        // 2. Topological sort
        // 3. Check for cycles (invalid lifetimes)
        // 4. Compute minimal lifetimes
        
        each constraint in &self.constraints {
            check let (Some(sub_region), Some(sup_region)) = (
                self.lifetime_regions.get(&constraint.sub),
                self.lifetime_regions.get(&constraint.sup)
            ) {
                // sub must not outlive sup
                check sub_region.end_point > sup_region.end_point {
                    self.errors.push(format(
                        "Lifetime constraint violation: '{}' outlives '{}'",
                        constraint.sub, constraint.sup
                    ));
                    yield false;
                }
            }
        }
        
        true
    }
}

impl MLIRPass for LifetimeInferencePass {
    fn name(&self) -> String {
        "LifetimeInferencePass".into()
    }

    fn run(&var self, module: &var MLIRModule) -> PassResult {
        self.errors.clear();
        self.constraints.clear();
        
        each func in &module.functions {
            var point = 0;
            
            each block in &func.blocks {
                each op in &block.operations {
                    match op {
                        MLIROperation::LifetimeBegin { lifetime } => {
                            self.lifetime_regions.insert(lifetime.clone(), LifetimeRegion {
                                name: lifetime.clone(),
                                start_point: point,
                                end_point: -1,  // TBD
                            });
                        }
                        MLIROperation::LifetimeEnd { lifetime } => {
                            check let Some(region) = self.lifetime_regions.get_mut(lifetime) {
                                region.end_point = point;
                            }
                        }
                        MLIROperation::Borrow { lifetime, .. } => {
                            // Add constraint: borrow lifetime must be within value lifetime
                            // This is simplified - real impl would track value lifetimes too
                        }
                        _ => {}
                    }
                    point += 1;
                }
            }
        }
        
        check self.solve_constraints() {
            PassResult::Success
        } else {
            PassResult::Failure(self.errors.clone())
        }
    }
}

// ============================================================================
// PASS 5: ESCAPE ANALYSIS
// ============================================================================

data EscapeAnalysisPass {
    escaping_values: HashSet<String>,
    stack_promotable: HashSet<String>,
}

impl EscapeAnalysisPass {
    fn new() -> EscapeAnalysisPass {
        EscapeAnalysisPass {
            escaping_values: HashSet::new(),
            stack_promotable: HashSet::new(),
        }
    }

    fn mark_escaping(&var self, value: &str) {
        self.escaping_values.insert(value.into());
        self.stack_promotable.remove(value);
    }
}

impl MLIRPass for EscapeAnalysisPass {
    fn name(&self) -> String {
        "EscapeAnalysisPass".into()
    }

    fn run(&var self, module: &var MLIRModule) -> PassResult {
        // Simplified escape analysis
        // Real implementation would:
        // 1. Track all allocations
        // 2. Mark values that escape through returns, global stores, etc.
        // 3. Values that don't escape can be stack-allocated
        
        println("    Found {} stack-promotable allocations", self.stack_promotable.len());
        PassResult::Success
    }
}

// ============================================================================
// PASS 6: AUTO-PARALLELIZATION
// ============================================================================

data AutoParallelizationPass {
    min_grain_size: i64,
    parallelized_regions: i32,
}

impl AutoParallelizationPass {
    fn new(min_grain_size: i64) -> AutoParallelizationPass {
        AutoParallelizationPass {
            min_grain_size,
            parallelized_regions: 0,
        }
    }

    fn can_parallelize(&self, block: &MLIRBlock, effects: EffectSet) -> bool {
        // Only pure code can be safely parallelized
        check effects != EffectSet::PURE {
            yield false;
        }
        
        // Check check block is large enough
        check block.operations.len() < self.min_grain_size as usize {
            yield false;
        }
        
        true
    }
}

impl MLIRPass for AutoParallelizationPass {
    fn name(&self) -> String {
        "AutoParallelizationPass".into()
    }

    fn run(&var self, module: &var MLIRModule) -> PassResult {
        var modified = false;
        
        each func in &module.functions {
            each block in &func.blocks {
                check self.can_parallelize(block, func.effects) {
                    println("    Parallelizing block '{}' in function '{}'", 
                             block.label, func.name);
                    self.parallelized_regions += 1;
                    modified = true;
                }
            }
        }
        
        check modified {
            println("    Parallelized {} regions", self.parallelized_regions);
            PassResult::Modified
        } else {
            PassResult::Success
        }
    }
}

// ============================================================================
// STANDARD PIPELINES
// ============================================================================

fn create_type_safety_pipeline() -> PassManager {
    var pm = PassManager::new();
    
    pm.add_pass(Box::new(BorrowCheckPass::new()));
    pm.add_pass(Box::new(LifetimeInferencePass::new()));
    pm.add_pass(Box::new(LinearTypeCheckPass::new()));
    pm.add_pass(Box::new(EffectInferencePass::new(false)));
    
    pm
}

fn create_optimization_pipeline() -> PassManager {
    var pm = PassManager::new();
    
    pm.add_pass(Box::new(EffectInferencePass::new(true)));
    pm.add_pass(Box::new(EscapeAnalysisPass::new()));
    pm.add_pass(Box::new(AutoParallelizationPass::new(1000)));
    
    pm
}

fn create_full_pipeline() -> PassManager {
    var pm = PassManager::new();
    
    // Type safety first
    pm.add_pass(Box::new(BorrowCheckPass::new()));
    pm.add_pass(Box::new(LifetimeInferencePass::new()));
    pm.add_pass(Box::new(LinearTypeCheckPass::new()));
    pm.add_pass(Box::new(EffectInferencePass::new(false)));
    
    // Then optimizations
    pm.add_pass(Box::new(EscapeAnalysisPass::new()));
    pm.add_pass(Box::new(AutoParallelizationPass::new(1000)));
    
    pm
}

