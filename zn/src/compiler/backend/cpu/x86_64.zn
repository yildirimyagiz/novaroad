// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║ x86-64 Code Generator                                                        ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use crate::ir::IR;
use crate::core::{Vec, Result, String};

expose data X86CodeGen {
    code: Vec<u8>,
    registers_used: u32,
}

impl X86CodeGen {
    open fn new() -> Self {
        X86CodeGen {
            code: Vec::new(),
            registers_used: 0,
        }
    }
    
    open fn generate(&var self, ir: &IR) -> Result<Vec<u8>, String> {
        self.emit_prologue();
        
        each instruction in &ir.instructions {
            self.emit_instruction(instruction)?;
        }
        
        self.emit_epilogue();
        
        Ok(self.code.clone())
    }
    
    fn emit_prologue(&var self) {
        // push rbp
        self.code.push(0x55);
        // mov rbp, rsp
        self.code.extend_from_slice(&[0x48, 0x89, 0xe5]);
    }
    
    fn emit_epilogue(&var self) {
        // pop rbp
        self.code.push(0x5d);
        // ret
        self.code.push(0xc3);
    }
    
    fn emit_instruction(&var self, instr: &Instruction) -> Result<(), String> {
        match instr.opcode {
            OpCode::Add => self.emit_add(instr),
            OpCode::Sub => self.emit_sub(instr),
            OpCode::Mul => self.emit_mul(instr),
            OpCode::Mov => self.emit_mov(instr),
            OpCode::Call => self.emit_call(instr),
            _ => Ok(()),
        }
    }
    
    fn emit_add(&var self, instr: &Instruction) -> Result<(), String> {
        // add rax, rbx (example)
        self.code.extend_from_slice(&[0x48, 0x01, 0xd8]);
        Ok(())
    }
    
    fn emit_sub(&var self, instr: &Instruction) -> Result<(), String> {
        // sub rax, rbx
        self.code.extend_from_slice(&[0x48, 0x29, 0xd8]);
        Ok(())
    }
    
    fn emit_mul(&var self, instr: &Instruction) -> Result<(), String> {
        // imul rax, rbx
        self.code.extend_from_slice(&[0x48, 0x0f, 0xaf, 0xc3]);
        Ok(())
    }
    
    fn emit_mov(&var self, instr: &Instruction) -> Result<(), String> {
        // mov rax, imm64
        self.code.extend_from_slice(&[0x48, 0xb8]);
        // Add immediate value (placeholder)
        self.code.extend_from_slice(&[0, 0, 0, 0, 0, 0, 0, 0]);
        Ok(())
    }
    
    fn emit_call(&var self, instr: &Instruction) -> Result<(), String> {
        // call relative
        self.code.push(0xe8);
        self.code.extend_from_slice(&[0, 0, 0, 0]); // offset
        Ok(())
    }
}
