// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║ Nova LLVM Backend - Complete LLVM IR Generation                              ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

open space ir_builder;
open space optimization;
open space target;

use crate::ir::IR;
use crate::core::{String, Result, Vec, HashMap};

/// LLVM Backend with full optimization pipeline
expose data LLVMBackend {
    module_name: String,
    target_triple: String,
    optimization_level: OptLevel,
    ir_output: String,
}

expose cases OptLevel {
    O0,  // No optimization
    O1,  // Basic optimization
    O2,  // Aggressive optimization
    O3,  // Maximum optimization
    Os,  // Optimize for size
    Oz,  // Optimize for size aggressively
}

impl LLVMBackend {
    open fn new() -> Self {
        LLVMBackend {
            module_name: "nova_module".into(),
            target_triple: detect_target_triple(),
            optimization_level: OptLevel::O2,
            ir_output: String::new(),
        }
    }
    
    open fn set_target(&var self, triple: String) {
        self.target_triple = triple;
    }
    
    open fn compile(&var self, ir: &IR) -> Result<Vec<u8>, String> {
        // Generate LLVM IR
        let llvm_ir = self.generate_llvm_ir(ir)?;
        
        // Run optimization passes
        let optimized_ir = self.optimize(&llvm_ir)?;
        
        // Generate machine code
        let machine_code = self.generate_machine_code(&optimized_ir)?;
        
        Ok(machine_code)
    }
    
    fn generate_llvm_ir(&var self, ir: &IR) -> Result<String, String> {
        var builder = ir_builder::IRBuilder::new(&self.module_name);
        
        // Module header
        var llvm_ir = String::new();
        llvm_ir.push_str(&format("; ModuleID = '{}'\n", self.module_name));
        llvm_ir.push_str(&format("target triple = \"{}\"\n\n", self.target_triple));
        
        // Type definitions
        each ty in &ir.types {
            llvm_ir.push_str(&self.emit_type_def(ty));
        }
        
        // Global variables
        each global in &ir.globals {
            llvm_ir.push_str(&self.emit_global(global));
        }
        
        // Function declarations
        each func in &ir.functions {
            check func.is_declaration {
                llvm_ir.push_str(&self.emit_function_decl(func));
            }
        }
        
        // Function definitions
        each func in &ir.functions {
            check !func.is_declaration {
                llvm_ir.push_str(&self.emit_function_def(func)?);
            }
        }
        
        self.ir_output = llvm_ir.clone();
        Ok(llvm_ir)
    }
    
    fn emit_function_def(&self, func: &Function) -> Result<String, String> {
        var output = String::new();
        
        // Function signature
        let ret_ty = self.map_type(&func.return_type);
        output.push_str(&format("define {} @{}(", ret_ty, func.name));
        
        // Parameters
        each entry in func.params.iter().enumerate()  { let (i, param) = entry;
            check i > 0 { output.push_str(", "); }
            output.push_str(&format("{} %{}", 
                self.map_type(&param.ty), 
                param.name
            ));
        }
        
        output.push_str(") {\n");
        
        // Basic blocks
        output.push_str("entry:\n");
        
        // Emit instructions
        each entry in func.body.iter().enumerate()  { let (i, instr) = entry;
            output.push_str("  ");
            output.push_str(&self.emit_instruction(instr, i)?);
            output.push_str("\n");
        }
        
        output.push_str("}\n\n");
        
        Ok(output)
    }
    
    fn emit_instruction(&self, instr: &Instruction, idx: usize) -> Result<String, String> {
        match &instr.kind {
            InstrKind::Add(a, b) => {
                Ok(format("%{} = add nsw i64 %{}, %{}", idx, a, b))
            }
            InstrKind::Sub(a, b) => {
                Ok(format("%{} = sub nsw i64 %{}, %{}", idx, a, b))
            }
            InstrKind::Mul(a, b) => {
                Ok(format("%{} = mul nsw i64 %{}, %{}", idx, a, b))
            }
            InstrKind::Load(ptr) => {
                Ok(format("%{} = load i64, i64* %{}", idx, ptr))
            }
            InstrKind::Store(val, ptr) => {
                Ok(format("store i64 %{}, i64* %{}", val, ptr))
            }
            InstrKind::Call(name, args) => {
                let args_str = args.iter()
                    .map(|a| format("i64 %{}", a))
                    .collect::<Vec<_>>()
                    .join(", ");
                Ok(format("%{} = call i64 @{}({})", idx, name, args_str))
            }
            InstrKind::Ret(val) => {
                Ok(format("ret i64 %{}", val))
            }
            _ => Ok(format("; unimplemented instruction")),
        }
    }
    
    fn optimize(&self, ir: &String) -> Result<String, String> {
        // Apply LLVM optimization passes
        var optimizer = optimization::Optimizer::new(self.optimization_level);
        optimizer.run(ir)
    }
    
    fn generate_machine_code(&self, ir: &String) -> Result<Vec<u8>, String> {
        // Generate native code for target
        var codegen = target::TargetCodeGen::new(&self.target_triple);
        codegen.generate(ir)
    }
    
    fn map_type(&self, ty: &Type) -> String {
        match ty {
            Type::I32 => "i32".into(),
            Type::I64 => "i64".into(),
            Type::F32 => "float".into(),
            Type::F64 => "double".into(),
            Type::Bool => "i1".into(),
            Type::Void => "void".into(),
            Type::Ptr(inner) => format("{}*", self.map_type(inner)),
            _ => "i64".into(),
        }
    }
    
    fn emit_type_def(&self, ty: &TypeDef) -> String {
        format("%{} = alias {{ }}\n", ty.name)
    }
    
    fn emit_global(&self, global: &Global) -> String {
        format("@{} = global {} 0\n", global.name, self.map_type(&global.ty))
    }
    
    fn emit_function_decl(&self, func: &Function) -> String {
        format("declare {} @{}()\n", 
            self.map_type(&func.return_type), 
            func.name
        )
    }
}

fn detect_target_triple() -> String {
    #[cfg(target_arch = "x86_64")]
    #[cfg(target_os = "macos")]
    yield "x86_64-apple-darwin".into();
    
    #[cfg(target_arch = "x86_64")]
    #[cfg(target_os = "linux")]
    yield "x86_64-unknown-linux-gnu".into();
    
    #[cfg(target_arch = "x86_64")]
    #[cfg(target_os = "windows")]
    yield "x86_64-pc-windows-msvc".into();
    
    #[cfg(target_arch = "aarch64")]
    yield "aarch64-apple-darwin".into();
    
    "unknown".into()
}
