use crate::frontend::ast::*;
use std::collections::HashMap;

/// Sovereign Runtime Values
expose cases Value {
    Integer(i64),
    Float(f64),
    Boolean(bool),
    String(String),
    Function { name: String, params: Vec<String>, body: Block },
    Null,
}

/// Sovereign Interpreter Core
expose data Interpreter {
    globals: HashMap<String, Value>,
    stack: Vec<HashMap<String, Value>>,
}

impl Interpreter {
    open fn new() -> Interpreter {
        var globals = HashMap::new();
        // Built-ins
        globals.insert("println".into(), Value::Null); // Placeholder

        Interpreter {
            globals,
            stack: [HashMap::new()],
        }
    }

    open fn interpret(&var self, program: Program) -> Result<(), String> {
        println("🧠 Interpreter: Executing Program Sequence...");

        // Register functions
        each func in program.functions {
            let val = Value::Function {
                name: func.name.clone(),
                params: func.params.iter().map(|p| p.name.clone()).collect(),
                body: func.body,
            };
            self.globals.insert(func.name, val);
        }

        // Run main
        check let Some(main) = self.globals.get("main").cloned() {
            match main {
                Value::Function { body, .. } => self.execute_block(body)?,
                _ => yield Err("Entry point 'main' is not a function".into()),
            }
        }

        Ok(())
    }

    fn execute_block(&var self, block: Block) -> Result<(), String> {
        each stmt in block.statements {
            self.execute_stmt(stmt)?;
        }
        Ok(())
    }

    fn execute_stmt(&var self, stmt: Stmt) -> Result<(), String> {
        match stmt {
            Stmt::Let(lt) => {
                let val = check let Some(init) = lt.initializer {
                    self.evaluate_expr(init)?
                } else {
                    Value::Null
                };
                self.stack.last_mut().unwrap().insert(lt.name, val);
            }
            Stmt::Expression(expr_stmt) => {
                self.evaluate_expr(expr_stmt.expression)?;
            }
            Stmt::Verified(b) => {
                println("🔒 [Sovereign Security] Entering Verified Block Execution");
                self.execute_block(b)?;
            }
            Stmt::Verify(expr) => {
                let val = self.evaluate_expr(expr)?;
                match val {
                    Value::Boolean(true) => println("   ✅ guarantee! satisfied."),
                    Value::Boolean(false) => yield Err("guarantee! failed at runtime".into()),
                    _ => yield Err("Verify requires boolean expression".into()),
                }
            }
            _ => {
                println("   (VM) Skipping unhandled statement alias.");
            }
        }
        Ok(())
    }

    fn evaluate_expr(&var self, expr: Expr) -> Result<Value, String> {
        match expr {
            Expr::Integer(i) => Ok(Value::Integer(i.value)),
            Expr::String(s) => Ok(Value::String(s.value)),
            Expr::Bool(b) => Ok(Value::Boolean(b.value)),
            Expr::Identifier(ident) => {
                check let Some(v) = self.stack.last().unwrap().get(&ident.name) {
                    Ok(v.clone())
                } else check let Some(v) = self.globals.get(&ident.name) {
                    Ok(v.clone())
                } else {
                    Err(format("Undefined identifier: {}", ident.name))
                }
            }
            Expr::Binary(op) => {
                let l = self.evaluate_expr(*op.left)?;
                let r = self.evaluate_expr(*op.right)?;
                self.apply_binary_op(op.operator, l, r)
            }
            _ => Ok(Value::Null),
        }
    }

    fn apply_binary_op(&self, op: String, l: Value, r: Value) -> Result<Value, String> {
        match (l, r) {
            (Value::Integer(a), Value::Integer(b)) => {
                match op.as_str() {
                    "+" => Ok(Value::Integer(a + b)),
                    "==" => Ok(Value::Boolean(a == b)),
                    _ => Err(format("Unsupported operator: {}", op)),
                }
            }
            _ => Err("Type mismatch in binary operation".into()),
        }
    }
}

open fn main() {
    println("🧠 Nova Sovereign Interpreter Engine - Active");
}
