// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  Nova — LLVM C FFI BINDINGS  v8.0                                   ║
// ║  Direct Native Interface to LLVM Libraries                                ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

// Opaque handles for LLVM structures
expose alias LLVMContext  = *var u8;
expose alias LLVMModule   = *var u8;
expose alias LLVMBuilder  = *var u8;
expose alias LLVMValue    = *var u8;
expose alias LLVMType     = *var u8;
expose alias LLVMBlock    = *var u8;

/// Native LLVM Core Functions
foreign "C" {
    // Context & Module
    fn LLVMContextCreate() -> LLVMContext;
    fn LLVMContextDispose(ctx: LLVMContext);
    fn LLVMModuleCreateWithNameInContext(name: *char, ctx: LLVMContext) -> LLVMModule;
    fn LLVMDisposeModule(m: LLVMModule);

    // Builder
    fn LLVMCreateBuilderInContext(ctx: LLVMContext) -> LLVMBuilder;
    fn LLVMDisposeBuilder(b: LLVMBuilder);
    fn LLVMPositionBuilderAtEnd(b: LLVMBuilder, bb: LLVMBlock);

    // Instructions
    fn LLVMBuildAdd(b: LLVMBuilder, lhs: LLVMValue, rhs: LLVMValue, name: *char) -> LLVMValue;
    fn LLVMBuildRet(b: LLVMBuilder, val: LLVMValue) -> LLVMValue;

    // Types
    fn LLVMInt32TypeInContext(ctx: LLVMContext) -> LLVMType;
    fn LLVMVoidTypeInContext(ctx: LLVMContext) -> LLVMType;
}

open fn main() {
    println("🔗 Nova LLVM FFI Bridge - Active");
}
