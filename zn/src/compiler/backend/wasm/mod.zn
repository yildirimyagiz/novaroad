// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║ Nova WebAssembly Backend - Complete WASM Code Generation                     ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

open space encoder;
open space optimizer;
open space runtime;

use crate::ir::IR;
use crate::core::{Vec, Result, String};

/// WebAssembly Backend
expose data WasmBackend {
    features: WasmFeatures,
    memory_pages: u32,
}

expose data WasmFeatures {
    simd: bool,
    threads: bool,
    bulk_memory: bool,
    reference_types: bool,
}

impl WasmBackend {
    open fn new() -> Self {
        WasmBackend {
            features: WasmFeatures {
                simd: true,
                threads: true,
                bulk_memory: true,
                reference_types: true,
            },
            memory_pages: 256,
        }
    }
    
    open fn compile(&var self, ir: &IR) -> Result<Vec<u8>, String> {
        var encoder = encoder::WasmEncoder::new();
        
        // Encode WASM module
        var wasm = Vec::new();
        
        // Magic number
        wasm.extend_from_slice(&[0x00, 0x61, 0x73, 0x6D]);
        
        // Version
        wasm.extend_from_slice(&[0x01, 0x00, 0x00, 0x00]);
        
        // Type section
        self.encode_type_section(&var wasm, ir)?;
        
        // Function section
        self.encode_function_section(&var wasm, ir)?;
        
        // Memory section
        self.encode_memory_section(&var wasm)?;
        
        // Export section
        self.encode_export_section(&var wasm, ir)?;
        
        // Code section
        self.encode_code_section(&var wasm, ir)?;
        
        Ok(wasm)
    }
    
    fn encode_type_section(&self, wasm: &var Vec<u8>, ir: &IR) -> Result<(), String> {
        wasm.push(0x01); // Type section ID
        
        var types = Vec::new();
        
        // Encode function types
        each func in &ir.functions {
            types.push(0x60); // func alias
            
            // Parameters
            types.push(func.params.len() as u8);
            each param in &func.params {
                types.push(self.encode_type(&param.ty));
            }
            
            // Results
            check func.return_type != Type::Void {
                types.push(0x01);
                types.push(self.encode_type(&func.return_type));
            } else {
                types.push(0x00);
            }
        }
        
        // Write section size
        self.encode_u32(wasm, types.len() as u32);
        wasm.extend_from_slice(&types);
        
        Ok(())
    }
    
    fn encode_function_section(&self, wasm: &var Vec<u8>, ir: &IR) -> Result<(), String> {
        wasm.push(0x03); // Function section ID
        
        let count = ir.functions.len() as u32;
        var content = Vec::new();
        
        self.encode_u32(&var content, count);
        each i in 0..count {
            self.encode_u32(&var content, i);
        }
        
        self.encode_u32(wasm, content.len() as u32);
        wasm.extend_from_slice(&content);
        
        Ok(())
    }
    
    fn encode_memory_section(&self, wasm: &var Vec<u8>) -> Result<(), String> {
        wasm.push(0x05); // Memory section ID
        
        var content = Vec::new();
        content.push(0x01); // 1 memory
        content.push(0x00); // no maximum
        self.encode_u32(&var content, self.memory_pages);
        
        self.encode_u32(wasm, content.len() as u32);
        wasm.extend_from_slice(&content);
        
        Ok(())
    }
    
    fn encode_export_section(&self, wasm: &var Vec<u8>, ir: &IR) -> Result<(), String> {
        wasm.push(0x07); // Export section ID
        
        var content = Vec::new();
        self.encode_u32(&var content, ir.exports.len() as u32);
        
        each export in &ir.exports {
            // Name
            let name_bytes = export.name.as_bytes();
            self.encode_u32(&var content, name_bytes.len() as u32);
            content.extend_from_slice(name_bytes);
            
            // Kind (0x00 = function)
            content.push(0x00);
            
            // Index
            self.encode_u32(&var content, export.index);
        }
        
        self.encode_u32(wasm, content.len() as u32);
        wasm.extend_from_slice(&content);
        
        Ok(())
    }
    
    fn encode_code_section(&self, wasm: &var Vec<u8>, ir: &IR) -> Result<(), String> {
        wasm.push(0x0A); // Code section ID
        
        var content = Vec::new();
        self.encode_u32(&var content, ir.functions.len() as u32);
        
        each func in &ir.functions {
            let func_body = self.encode_function_body(func)?;
            self.encode_u32(&var content, func_body.len() as u32);
            content.extend_from_slice(&func_body);
        }
        
        self.encode_u32(wasm, content.len() as u32);
        wasm.extend_from_slice(&content);
        
        Ok(())
    }
    
    fn encode_function_body(&self, func: &Function) -> Result<Vec<u8>, String> {
        var body = Vec::new();
        
        // Locals
        body.push(0x00); // No locals for now
        
        // Instructions
        each instr in &func.body {
            self.encode_instruction(&var body, instr)?;
        }
        
        // End
        body.push(0x0B);
        
        Ok(body)
    }
    
    fn encode_instruction(&self, body: &var Vec<u8>, instr: &Instruction) -> Result<(), String> {
        match &instr.kind {
            InstrKind::I32Add => body.push(0x6A),
            InstrKind::I32Sub => body.push(0x6B),
            InstrKind::I32Mul => body.push(0x6C),
            InstrKind::I32Const(val) => {
                body.push(0x41);
                self.encode_i32(body, *val);
            }
            InstrKind::LocalGet(idx) => {
                body.push(0x20);
                self.encode_u32(body, *idx);
            }
            InstrKind::Return => body.push(0x0F),
            _ => {}
        }
        Ok(())
    }
    
    fn encode_type(&self, ty: &Type) -> u8 {
        match ty {
            Type::I32 => 0x7F,
            Type::I64 => 0x7E,
            Type::F32 => 0x7D,
            Type::F64 => 0x7C,
            _ => 0x7F,
        }
    }
    
    fn encode_u32(&self, buf: &var Vec<u8>, var value: u32) {
        loop {
            var byte = (value & 0x7F) as u8;
            value >>= 7;
            check value != 0 {
                byte |= 0x80;
            }
            buf.push(byte);
            check value == 0 {
                abort;
            }
        }
    }
    
    fn encode_i32(&self, buf: &var Vec<u8>, var value: i32) {
        loop {
            var byte = (value & 0x7F) as u8;
            value >>= 7;
            let done = value == 0 || value == -1;
            check !done {
                byte |= 0x80;
            }
            buf.push(byte);
            check done {
                abort;
            }
        }
    }
}
