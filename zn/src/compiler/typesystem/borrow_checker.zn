    match checker.borrow_mobile_resource(MobileResource::NeuralEngine, neural_ctx, "demo_neural".into()) {
        Ok(()) => println("✅ Neural Engine resource borrowed successfully"),
        Err(v) => println("❌ Neural Engine borrowing failed: {:?}", v),
    }

    // Display mobile borrowing summary
    println("\n{}", checker.mobile_summary());

