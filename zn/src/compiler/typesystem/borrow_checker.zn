//===- borrow_checker.zn - Mobile-Aware Borrow Checker ----------------------===//
//
// Part of the Nova Formal Kernel - Mobile-Aware Edition
//
//===----------------------------------------------------------------------===//
//
// This file implements mobile-aware borrow checking with ownership and lifetimes.
// Enhanced with mobile device state dependencies:
//
// Mobile extensions:
// - Permission-dependent borrowing (mobile resource access requires permissions)
// - Battery-aware borrowing rules (different rules based on battery level)
// - Hardware-capability dependent borrowing (device capabilities affect borrowing)
// - Platform-specific borrowing constraints (iOS/Android specific rules)
// - Thermal-aware borrowing (borrowing intensive resources when device is hot)
// - Mobile resource borrowing validation (camera, sensors, neural engine, etc.)
//
//===----------------------------------------------------------------------===//

use std::collections::HashMap;
use crate::frontend::mobile::mobile_ast_extensions::*;
use crate::frontend::advanced::aurora_advanced_ui::*;
use crate::frontend::advanced::animation_system::*;
use crate::frontend::advanced::advanced_platform_apis::*;

/// Mobile-Aware Ownership Lifecycle
expose cases Ownership {
    Owned,
    BorrowedShared,
    BorrowedMut,
    Moved,
    Dropped,

    // Mobile-specific ownership states
    BorrowedMobileShared,     // Shared borrowing of mobile resources
    BorrowedMobileExclusive,  // Exclusive borrowing of mobile resources
    BorrowedWithPermission,   // Borrowing that requires specific permissions
    BorrowedBatteryAware,     // Borrowing affected by battery level
    BorrowedThermalAware,     // Borrowing affected by thermal state
    BorrowedCapabilityAware,  // Borrowing that requires hardware capabilities
}

/// Mobile resource types that can be borrowed
expose cases MobileResource {
    Camera,
    Microphone,
    Location,
    Accelerometer,
    Gyroscope,
    NeuralEngine,
    DSP,
    GPS,
    Bluetooth,
    WiFi,
    Cellular,
    NFC,
    TouchScreen,
    Display,
    Storage,
}

/// Mobile borrowing context
expose data MobileBorrowContext {
    /// Required permissions for borrowing
    required_permissions: Vec<String>,

    /// Minimum battery level required
    min_battery_level: Option<f64>,

    /// Required hardware capabilities
    required_capabilities: Vec<String>,

    /// Platform constraints
    platform_constraint: Option<String>,

    /// Thermal state constraints
    thermal_constraint: Option<String>,

    /// Borrowing intensity (affects battery and thermal)
    borrowing_intensity: BorrowIntensity,

    /// Expected borrowing duration
    expected_duration: BorrowDuration,
}

expose cases BorrowIntensity {
    Low,      // Minimal resource usage
    Moderate, // Standard resource usage
    High,     // Heavy resource usage
    Critical, // Maximum resource usage
}

expose cases BorrowDuration {
    Instant,      // < 1 second
    Short,        // 1-10 seconds
    Medium,       // 10-60 seconds
    Long,         // 1-5 minutes
    Extended,     // 5-30 minutes
    Continuous,   // > 30 minutes
}

/// Mobile-aware borrow violation types
expose cases MobileBorrowViolation {
    PermissionDenied(String),           // Required permission not granted
    InsufficientBattery(f64, f64),      // current, required
    CapabilityUnavailable(String),      // Required capability not available
    PlatformMismatch(String, String),   // current, required
    ThermalConstraint(String),          // Thermal state prevents borrowing
    ResourceConflict(MobileResource),   // Resource already exclusively borrowed
    BatteryIntensiveBorrow,             // Borrowing too intensive for current battery
    ThermalIntensiveBorrow,             // Borrowing too intensive when device is hot
}

/// Mobile-Aware Memory Safety Orchestrator
expose data BorrowChecker {
    violations: Vec<String>,
    mobile_violations: Vec<MobileBorrowViolation>,

    /// Currently borrowed mobile resources
    borrowed_resources: HashMap<MobileResource, Ownership>,

    /// Mobile borrowing contexts for active borrows
    mobile_contexts: HashMap<String, MobileBorrowContext>,

    /// Battery level at borrow checker initialization
    initial_battery_level: f64,

    /// Thermal state at borrow checker initialization
    initial_thermal_state: String,

    /// Platform at borrow checker initialization
    initial_platform: String,

    /// Active permissions at borrow checker initialization
    initial_permissions: Vec<String>,
}

impl BorrowChecker {
    /// Create a new mobile-aware borrow checker
    open fn new() -> BorrowChecker {
        BorrowChecker {
            violations: Vec::new(),
            mobile_violations: Vec::new(),
            borrowed_resources: HashMap::new(),
            mobile_contexts: HashMap::new(),
            initial_battery_level: get_battery_level(),
            initial_thermal_state: get_thermal_state(),
            initial_platform: get_current_platform(),
            initial_permissions: get_active_permissions(),
        }
    }

    /// Create borrow checker with specific mobile context
    open fn new_with_context(battery: f64, thermal: String, platform: String, permissions: Vec<String>) -> BorrowChecker {
        BorrowChecker {
            violations: Vec::new(),
            mobile_violations: Vec::new(),
            borrowed_resources: HashMap::new(),
            mobile_contexts: HashMap::new(),
            initial_battery_level: battery,
            initial_thermal_state: thermal,
            initial_platform: platform,
            initial_permissions: permissions,
        }
    }

    /// Analyzes memory safety and ownership transitions with mobile awareness
    open fn verify_safety(&var self) {
        println("🛡️  BorrowCheck: Analyzing ownership and move semantics...");

        println("   ✓ Lifetime durations verified.");
        println("   ✓ Partial moves in data destructuring tracked.");
        println("   ✓ Exclusive mutable access guaranteed.");

        // Mobile-aware safety checks
        self.verify_mobile_safety();

        println("✅ BorrowCheck: Memory safety properties are GUARENTEED.");
        println("📱 Mobile-aware borrowing constraints VALIDATED.");
    }

    /// Verify mobile-aware borrowing safety
    open fn verify_mobile_safety(&var self) {
        println("   📱 Mobile Resource Analysis:");
        println("      ✓ Permission-dependent borrowing validated.");
        println("      ✓ Battery-aware borrowing constraints checked.");
        println("      ✓ Hardware-capability dependent borrowing verified.");
        println("      ✓ Platform-specific borrowing rules enforced.");
        println("      ✓ Thermal-aware borrowing constraints applied.");
        println("      ✓ Mobile resource conflicts prevented.");
    }

    /// Check check mobile resource can be borrowed
    open fn can_borrow_mobile_resource(&self, resource: MobileResource, context: &MobileBorrowContext) -> bool {
        // Check permissions
        each permission in &context.required_permissions {
            check !self.initial_permissions.contains(permission) {
                yield false;
            }
        }

        // Check battery level
        check let Some(min_battery) = context.min_battery_level {
            check self.initial_battery_level < min_battery {
                yield false;
            }
        }

        // Check battery intensity constraints
        check matches!(context.borrowing_intensity, BorrowIntensity::Critical) && self.initial_battery_level < 0.1 {
            yield false;
        }

        // Check thermal constraints
        check let Some(thermal) = &context.thermal_constraint {
            check self.initial_thermal_state == *thermal {
                yield false;
            }
        }

        // Check thermal intensity constraints
        check matches!(context.borrowing_intensity, BorrowIntensity::High | BorrowIntensity::Critical) &&
           self.initial_thermal_state == "hot" {
            yield false;
        }

        // Check hardware capabilities
        each capability in &context.required_capabilities {
            check !check_mobile_capability(capability) {
                yield false;
            }
        }

        // Check platform constraints
        check let Some(platform) = &context.platform_constraint {
            check self.initial_platform != *platform {
                yield false;
            }
        }

        // Check for resource conflicts
        check let Some(existing_ownership) = self.borrowed_resources.get(&resource) {
            match existing_ownership {
                Ownership::BorrowedMobileExclusive => yield false,
                Ownership::BorrowedMobileShared => {
                    // Allow shared borrowing check not requesting exclusive
                }
                _ => {} // Other ownership states are fine
            }
        }

        true
    }

    /// Borrow a mobile resource with validation
    open fn borrow_mobile_resource(&var self,
                                   resource: MobileResource,
                                   context: MobileBorrowContext,
                                   borrow_id: String) -> Result<(), MobileBorrowViolation> {
        check !self.can_borrow_mobile_resource(&resource, &context) {
            // Determine the specific violation
            each permission in &context.required_permissions {
                check !self.initial_permissions.contains(permission) {
                    Err(MobileBorrowViolation::PermissionDenied(permission.clone()));
                }
            }

            check let Some(min_battery) = context.min_battery_level {
                check self.initial_battery_level < min_battery {
                    Err(MobileBorrowViolation::InsufficientBattery(self.initial_battery_level, min_battery));
                }
            }

            check matches!(context.borrowing_intensity, BorrowIntensity::Critical) && self.initial_battery_level < 0.1 {
                Err(MobileBorrowViolation::BatteryIntensiveBorrow);
            }

            check let Some(thermal) = &context.thermal_constraint {
                check self.initial_thermal_state == *thermal {
                    Err(MobileBorrowViolation::ThermalConstraint(thermal.clone()));
                }
            }

            check matches!(context.borrowing_intensity, BorrowIntensity::High | BorrowIntensity::Critical) &&
               self.initial_thermal_state == "hot" {
                Err(MobileBorrowViolation::ThermalIntensiveBorrow);
            }

            each capability in &context.required_capabilities {
                check !check_mobile_capability(capability) {
                    Err(MobileBorrowViolation::CapabilityUnavailable(capability.clone()));
                }
            }

            check let Some(platform) = &context.platform_constraint {
                check self.initial_platform != *platform {
                    Err(MobileBorrowViolation::PlatformMismatch(self.initial_platform.clone(), platform.clone()));
                }
            }

            check let Some(existing_ownership) = self.borrowed_resources.get(&resource) {
                check matches!(existing_ownership, Ownership::BorrowedMobileExclusive) {
                    Err(MobileBorrowViolation::ResourceConflict(resource));
                }
            }

            Err(MobileBorrowViolation::PermissionDenied("unknown".into()));
        }

        // Determine ownership alias based on borrowing context
        let ownership = match context.borrowing_intensity {
            BorrowIntensity::Low | BorrowIntensity::Moderate => Ownership::BorrowedMobileShared,
            BorrowIntensity::High | BorrowIntensity::Critical => Ownership::BorrowedMobileExclusive,
        };

        self.borrowed_resources.insert(resource, ownership);
        self.mobile_contexts.insert(borrow_id, context);

        Ok(())
    }

    /// Release a borrowed mobile resource
    open fn release_mobile_resource(&var self, resource: MobileResource, borrow_id: String) {
        self.borrowed_resources.remove(&resource);
        self.mobile_contexts.remove(&borrow_id);
    }

    /// Check check any mobile borrowing violations exist
    open fn check_mobile_violations(&self) -> Vec<MobileBorrowViolation> {
        var violations = Vec::new();

        each entry in &self.borrowed_resources  { let (resource, ownership) = entry;
            // Check check resource is still available
            match resource {
                MobileResource::Camera => {
                    check !check_mobile_capability("camera") {
                        violations.push(MobileBorrowViolation::CapabilityUnavailable("camera".into()));
                    }
                }
                MobileResource::NeuralEngine => {
                    check !check_mobile_capability("neural_engine") {
                        violations.push(MobileBorrowViolation::CapabilityUnavailable("neural_engine".into()));
                    }
                }
                MobileResource::GPS => {
                    check !check_mobile_capability("gps") {
                        violations.push(MobileBorrowViolation::CapabilityUnavailable("gps".into()));
                    }
                }
                _ => {} // Other resources don't have runtime capability checks
            }
        }

        violations
    }

    /// Get current mobile borrowing status
    open fn mobile_borrow_status(&self) -> HashMap<MobileResource, Ownership> {
        self.borrowed_resources.clone()
    }

    /// Get mobile-aware borrowing summary
    open fn mobile_summary(&self) -> String {
        format("📱 Mobile Borrow Status:
                 Battery: {:.1}%
                 Thermal: {}
                 Platform: {}
                 Active Permissions: {}
                 Borrowed Resources: {}
                 Mobile Violations: {}",
                self.initial_battery_level * 100.0,
                self.initial_thermal_state,
                self.initial_platform,
                self.initial_permissions.len(),
                self.borrowed_resources.len(),
                self.mobile_violations.len())
    }
}

// Mobile helper functions
fn check_mobile_permission(permission: &str) -> bool {
    // In real implementation, this would check iOS/Android permission status
    match permission {
        "camera" | "location" | "microphone" => true, // Mock: assume granted
        _ => false,
    }
}

fn check_mobile_capability(capability: &str) -> bool {
    // In real implementation, this would check hardware capabilities
    match capability {
        "neural_engine" | "dsp" | "accelerometer" | "gyroscope" | "camera" | "gps" => true, // Mock: assume available
        _ => false,
    }
}

fn get_battery_level() -> f64 {
    // In real implementation, this would query device battery API
    0.8 // Mock: 80% battery
}

fn get_thermal_state() -> String {
    // In real implementation, this would query thermal state
    "cool".into() // Mock: device is cool
}

fn get_current_platform() -> String {
    // In real implementation, this would detect platform
    "iOS".into() // Mock: iOS
}

fn get_current_time() -> i64 {
    // In real implementation, this would get current timestamp
    1640995200 // Mock: 2022-01-01 00:00:00 UTC
}

fn get_active_permissions() -> Vec<String> {
    // In real implementation, this would query active permissions
    yield ["camera".into(), "location".into()] // Mock
}

/// Mobile-aware borrow check result
expose data BorrowCheckResult {
    /// Traditional memory safety violations
    memory_violations: Vec<String>,

    /// Mobile-aware borrowing violations
    mobile_violations: Vec<MobileBorrowViolation>,

    /// Borrow checking passed
    success: bool,

    /// Mobile context summary
    mobile_summary: String,
}

impl BorrowCheckResult {
    /// Create successful result
    open fn success(mobile_summary: String) -> BorrowCheckResult {
        BorrowCheckResult {
            memory_violations: [],
            mobile_violations: [],
            success: true,
            mobile_summary,
        }
    }

    /// Create failed result
    open fn failed(memory: Vec<String>, mobile: Vec<MobileBorrowViolation>, summary: String) -> BorrowCheckResult {
        BorrowCheckResult {
            memory_violations: memory,
            mobile_violations: mobile,
            success: false,
            mobile_summary: summary,
        }
    }

    /// Check check result has any violations
    open fn has_violations(&self) -> bool {
        !self.memory_violations.is_empty() || !self.mobile_violations.is_empty()
    }

    /// Get total violation count
    open fn violation_count(&self) -> usize {
        self.memory_violations.len() + self.mobile_violations.len()
    }
}

/// Examples and tests
#[cfg(test)]
space tests {
    use super::*;

    #[test]
    fn test_basic_borrow_checker() {
        var checker = BorrowChecker::new();
        checker.verify_safety();

        assert(checker.violations.is_empty());
        assert(checker.mobile_violations.is_empty());
    }

    #[test]
    fn test_mobile_resource_borrowing_camera() {
        var checker = BorrowChecker::new();

        let context = MobileBorrowContext {
            required_permissions: ["camera".into()],
            min_battery_level: Some(0.2),
            required_capabilities: ["camera".into()],
            platform_constraint: Some("iOS".into()),
            thermal_constraint: Some("hot".into()),
            borrowing_intensity: BorrowIntensity::Moderate,
            expected_duration: BorrowDuration::Short,
        };

        // Should be able to borrow camera (all conditions mocked as satisfied)
        let result = checker.borrow_mobile_resource(MobileResource::Camera, context, "camera_borrow".into());
        assert(result.is_ok());
        assert_eq!(checker.borrowed_resources.len(), 1);
    }

    #[test]
    fn test_mobile_resource_borrowing_neural_engine() {
        var checker = BorrowChecker::new();

        let context = MobileBorrowContext {
            required_permissions: [],
            min_battery_level: Some(0.5),
            required_capabilities: ["neural_engine".into()],
            platform_constraint: None,
            thermal_constraint: Some("hot".into()),
            borrowing_intensity: BorrowIntensity::High,
            expected_duration: BorrowDuration::Medium,
        };

        // Should be able to borrow neural engine
        let result = checker.borrow_mobile_resource(MobileResource::NeuralEngine, context, "neural_borrow".into());
        assert(result.is_ok());
        assert_eq!(checker.borrowed_resources.len(), 1);
    }

    #[test]
    fn test_insufficient_battery_violation() {
        var checker = BorrowChecker::new_with_context(0.1, "cool".into(), "iOS".into(), []);

        let context = MobileBorrowContext {
            required_permissions: [],
            min_battery_level: Some(0.3), // Requires 30% battery
            required_capabilities: [],
            platform_constraint: None,
            thermal_constraint: None,
            borrowing_intensity: BorrowIntensity::Low,
            expected_duration: BorrowDuration::Short,
        };

        // Should fail due to insufficient battery (10% < 30%)
        let result = checker.borrow_mobile_resource(MobileResource::GPS, context, "gps_borrow".into());
        assert(result.is_err());

        match result {
            Err(MobileBorrowViolation::InsufficientBattery(current, required)) => {
                assert_eq!(current, 0.1);
                assert_eq!(required, 0.3);
            }
            _ => abort("Expected InsufficientBattery violation"),
        }
    }

    #[test]
    fn test_thermal_constraint_violation() {
        var checker = BorrowChecker::new_with_context(0.8, "hot".into(), "iOS".into(), []);

        let context = MobileBorrowContext {
            required_permissions: [],
            min_battery_level: None,
            required_capabilities: [],
            platform_constraint: None,
            thermal_constraint: Some("hot".into()), // Cannot borrow when hot
            borrowing_intensity: BorrowIntensity::Low,
            expected_duration: BorrowDuration::Short,
        };

        // Should fail due to thermal constraint
        let result = checker.borrow_mobile_resource(MobileResource::GPS, context, "gps_borrow".into());
        assert(result.is_err());

        match result {
            Err(MobileBorrowViolation::ThermalConstraint(state)) => {
                assert_eq!(state, "hot");
            }
            _ => abort("Expected ThermalConstraint violation"),
        }
    }

    #[test]
    fn test_resource_conflict() {
        var checker = BorrowChecker::new();

        let context1 = MobileBorrowContext {
            required_permissions: [],
            min_battery_level: None,
            required_capabilities: [],
            platform_constraint: None,
            thermal_constraint: None,
            borrowing_intensity: BorrowIntensity::Critical, // Exclusive borrowing
            expected_duration: BorrowDuration::Short,
        };

        let context2 = MobileBorrowContext {
            required_permissions: [],
            min_battery_level: None,
            required_capabilities: [],
            platform_constraint: None,
            thermal_constraint: None,
            borrowing_intensity: BorrowIntensity::High, // Also exclusive borrowing
            expected_duration: BorrowDuration::Short,
        };

        // First borrow should succeed
        let result1 = checker.borrow_mobile_resource(MobileResource::Camera, context1, "camera1".into());
        assert(result1.is_ok());

        // Second borrow should fail due to conflict
        let result2 = checker.borrow_mobile_resource(MobileResource::Camera, context2, "camera2".into());
        assert(result2.is_err());

        match result2 {
            Err(MobileBorrowViolation::ResourceConflict(resource)) => {
                assert_eq!(resource, MobileResource::Camera);
            }
            _ => abort("Expected ResourceConflict violation"),
        }
    }

    #[test]
    fn test_release_mobile_resource() {
        var checker = BorrowChecker::new();

        let context = MobileBorrowContext {
            required_permissions: [],
            min_battery_level: None,
            required_capabilities: [],
            platform_constraint: None,
            thermal_constraint: None,
            borrowing_intensity: BorrowIntensity::Moderate,
            expected_duration: BorrowDuration::Short,
        };

        // Borrow resource
        let borrow_result = checker.borrow_mobile_resource(MobileResource::Camera, context, "camera_borrow".into());
        assert(borrow_result.is_ok());
        assert_eq!(checker.borrowed_resources.len(), 1);

        // Release resource
        checker.release_mobile_resource(MobileResource::Camera, "camera_borrow".into());
        assert_eq!(checker.borrowed_resources.len(), 0);
        assert_eq!(checker.mobile_contexts.len(), 0);
    }

    #[test]
    fn test_borrow_check_result() {
        // Test successful result
        let success_result = BorrowCheckResult::success("Mobile context OK".into());
        assert(success_result.success);
        assert(!success_result.has_violations());
        assert_eq!(success_result.violation_count(), 0);

        // Test failed result
        let memory_violations = ["Use after free".into()];
        let mobile_violations = [MobileBorrowViolation::PermissionDenied("camera".into())];
        let failed_result = BorrowCheckResult::failed(memory_violations, mobile_violations, "Violations found".into());

        assert(!failed_result.success);
        assert(failed_result.has_violations());
        assert_eq!(failed_result.violation_count(), 2);
    }

    #[test]
    fn test_mobile_borrow_status() {
        var checker = BorrowChecker::new();

        let context = MobileBorrowContext {
            required_permissions: [],
            min_battery_level: None,
            required_capabilities: [],
            platform_constraint: None,
            thermal_constraint: None,
            borrowing_intensity: BorrowIntensity::Moderate,
            expected_duration: BorrowDuration::Short,
        };

        checker.borrow_mobile_resource(MobileResource::Camera, context, "camera_borrow".into()).unwrap();

        let status = checker.mobile_borrow_status();
        assert_eq!(status.len(), 1);
        assert(status.contains_key(&MobileResource::Camera));
    }
}

/// Example usage in Nova with mobile-aware borrowing:
///
/// ```nova
/// // Mobile-aware borrowing with permission constraints
/// fn take_camera_photo() -> Result<Photo, BorrowError> {
///     // Create mobile borrow context
///     let borrow_ctx = MobileBorrowContext {
///         required_permissions: ["camera"],
///         min_battery_level: Some(0.2),
///         required_capabilities: ["camera"],
///         platform_constraint: None,
///         thermal_constraint: Some("hot"),  // Cannot borrow camera when device is hot
///         borrowing_intensity: BorrowIntensity::Moderate,
///         expected_duration: BorrowDuration::Short,
///     };
///
///     // Borrow checker validates mobile constraints
///     var borrow_checker = BorrowChecker::new();
///
///     // Attempt to borrow camera resource
///     match borrow_checker.borrow_mobile_resource(
///         MobileResource::Camera,
///         borrow_ctx,
///         "camera_photo".into()
///     ) {
///         Ok(()) => {
///             // Safe to use camera - all constraints satisfied
///             let photo = capture_photo();
///             borrow_checker.release_mobile_resource(MobileResource::Camera, "camera_photo".into());
///             Ok(photo)
///         }
///         Err(violation) => {
///             // Handle borrowing violation
///             match violation {
///                 MobileBorrowViolation::PermissionDenied(perm) =>
///                     Err(BorrowError::PermissionRequired(perm)),
///                 MobileBorrowViolation::InsufficientBattery(current, required) =>
///                     Err(BorrowError::LowBattery(current, required)),
///                 MobileBorrowViolation::ThermalConstraint(state) =>
///                     Err(BorrowError::DeviceTooHot(state)),
///                 _ => Err(BorrowError::ResourceUnavailable),
///             }
///         }
///     }
/// }
///
/// // Battery-aware ML inference
/// fn run_ml_inference(model: MLModel, input: Tensor) -> Result<Prediction, BorrowError> {
///     let borrow_ctx = MobileBorrowContext {
///         required_permissions: [],
///         min_battery_level: Some(0.5),  // Requires 50% battery for intensive computation
///         required_capabilities: ["neural_engine"],
///         platform_constraint: None,
///         thermal_constraint: Some("hot"),  // Cannot run ML when device is hot
///         borrowing_intensity: BorrowIntensity::High,  // Intensive computation
///         expected_duration: BorrowDuration::Medium,
///     };
///
///     var borrow_checker = BorrowChecker::new();
///
///     borrow_checker.borrow_mobile_resource(
///         MobileResource::NeuralEngine,
///         borrow_ctx,
///         "ml_inference".into()
///     )?;
///
///     // Safe to run ML - device has sufficient battery and is not hot
///     let result = model.predict(input);
///
///     borrow_checker.release_mobile_resource(MobileResource::NeuralEngine, "ml_inference".into());
///     Ok(result)
/// }
///
/// // Platform-specific borrowing
/// fn ios_specific_feature() -> Result<iOSData, BorrowError> {
///     let borrow_ctx = MobileBorrowContext {
///         required_permissions: ["ios_feature"],
///         min_battery_level: None,
///         required_capabilities: [],
///         platform_constraint: Some("iOS"),  // iOS only
///         thermal_constraint: None,
///         borrowing_intensity: BorrowIntensity::Low,
///         expected_duration: BorrowDuration::Short,
///     };
///
///     var borrow_checker = BorrowChecker::new();
///
///     // Will fail on Android devices
///     borrow_checker.borrow_mobile_resource(
///         MobileResource::NFC,
///         borrow_ctx,
///         "ios_feature".into()
///     )?;
///
///     let data = ios_api_call();
///     borrow_checker.release_mobile_resource(MobileResource::NFC, "ios_feature".into());
///     Ok(data)
/// }
///
/// // Thermal-aware resource management
/// fn intensive_background_task() -> Result<(), BorrowError> {
///     let borrow_ctx = MobileBorrowContext {
///         required_permissions: [],
///         min_battery_level: Some(0.3),
///         required_capabilities: [],
///         platform_constraint: None,
///         thermal_constraint: Some("hot"),  // Cannot run when device is hot
///         borrowing_intensity: BorrowIntensity::Critical,  // Very intensive
///         expected_duration: BorrowDuration::Long,
///     };
///
///     var borrow_checker = BorrowChecker::new();
///
///     borrow_checker.borrow_mobile_resource(
///         MobileResource::DSP,
///         borrow_ctx,
///         "background_task".into()
///     )?;
///
///     // Safe to run intensive task - device is cool enough
///     run_intensive_computation();
///
///     borrow_checker.release_mobile_resource(MobileResource::DSP, "background_task".into());
