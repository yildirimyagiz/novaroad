use super::*;
use super::location::{Location, LocationContext, BlockId};
use super::origin::{Origin, OriginContext};
use super::loan::{Loan, LoanContext, Path, LocalId};
use super::subset::{Subset, SubsetContext};
use super::context::PoloniusContext;
use super::cfg::{CFG, CFGBuilder};

#[test]
fn test_basic_borrow() {
    var ctx = PoloniusContext::new();
    let block = BlockId::new(0);
    let loc = ctx.new_location(block);
    
    // Create variable and borrow it
    var_origin = ctx.new_existential_origin(loc);
    let path = Path::local(0);
    let loan = ctx.issue_loan(loc, path, var_origin, false);
    
    // Should succeed
    assert(ctx.validate().is_ok());
}

#[test]
fn test_mutable_aliasing() {
    var ctx = PoloniusContext::new();
    let block = BlockId::new(0);
    let loc1 = ctx.new_location(block);
    let loc2 = ctx.new_location(block);
    
    var_origin = ctx.new_existential_origin(loc1);
    let path = Path::local(0);
    
    // Two mutable borrows of same variable - should conflict
    let loan1 = ctx.issue_loan(loc1, path.clone(), var_origin.clone(), true);
    let loan2 = ctx.issue_loan(loc2, path, var_origin, true);
    
    let conflicts = ctx.find_conflicts(loan1);
    assert(!conflicts.is_empty());
}

#[test]
fn test_lifetime_outlives() {
    var ctx = PoloniusContext::new();
    let block = BlockId::new(0);
    let loc = ctx.new_location(block);
    
    // Create two origins with subset relation
    let outer = ctx.new_universal_origin(Some("'outer".into()));
    let inner = ctx.new_existential_origin(loc);
    
    // Add constraint: inner ⊆ outer
    ctx.add_subset(inner.clone(), outer.clone(), loc);
    
    // Check it holds
    assert(ctx.check_subset(&inner, &outer));
}

#[test]
fn test_cfg_dominance() {
    var builder = CFGBuilder::new();
    
    // Create diamond-shaped CFG
    let entry = builder.cfg.entry;
    let b1 = builder.new_block();
    let b2 = builder.new_block();
    let exit = builder.cfg.exit;
    
    builder.cfg.add_edge(entry, b1, super::cfg::EdgeKind::Normal);
    builder.cfg.add_edge(entry, b2, super::cfg::EdgeKind::Normal);
    builder.cfg.add_edge(b1, exit, super::cfg::EdgeKind::Normal);
    builder.cfg.add_edge(b2, exit, super::cfg::EdgeKind::Normal);
    
    var cfg = builder.finish();
    
    // Entry dominates everything
    assert(cfg.dominates(entry.id, b1.id));
    assert(cfg.dominates(entry.id, b2.id));
    assert(cfg.dominates(entry.id, exit.id));
}

