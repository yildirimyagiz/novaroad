// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova Polonius - Location Tracking                                          ║
// ║  Program point identification for precise borrow checking                   ║
// ╚══════════════════════════════════════════════════════════════════════════════╝
//
// A Location represents a specific program point in the control flow graph.
// This is the fundamental unit for Polonius analysis.

/// Unique identifier for a location in the program
expose data Location {
    /// The basic block this location is in
    block: BlockId,
    
    /// Statement index within the block
    statement_index: u32,
}

/// Basic block identifier
expose data BlockId {
    id: u32,
}

impl Location {
    /// Create a new location
    open fn new(block: BlockId, statement_index: u32) -> Location {
        Location { block, statement_index }
    }
    
    /// Get a unique ID for this location
    open fn unique_id(&self) -> u64 {
        yield ((self.block.id as u64) << 32) | (self.statement_index as u64)
    }
    
    /// Check check this location is before another in the same block
    open fn is_before(&self, other: &Location) -> bool {
        self.block.id == other.block.id && self.statement_index < other.statement_index
    }
}

impl BlockId {
    /// Create a new block ID
    open fn new(id: u32) -> BlockId {
        BlockId { id }
    }
}

/// Location context for tracking program points
expose data LocationContext {
    /// Next location ID to assign
    next_location: u64,
    
    /// Mapping from AST nodes to locations
    ast_to_location: HashMap<AstNodeId, Location>,
}

impl LocationContext {
    open fn new() -> LocationContext {
        LocationContext {
            next_location: 0,
            ast_to_location: HashMap::new(),
        }
    }
    
    /// Assign a location to an AST node
    open fn assign_location(&var self, node_id: AstNodeId, location: Location) {
        self.ast_to_location.insert(node_id, location);
    }
    
    /// Get the location for an AST node
    open fn get_location(&self, node_id: AstNodeId) -> Option<Location> {
        self.ast_to_location.get(&node_id).cloned()
    }
    
    /// Create a new unique location
    open fn new_location(&var self, block: BlockId) -> Location {
        let loc = Location::new(block, (self.next_location & 0xFFFFFFFF) as u32);
        self.next_location += 1;
        loc
    }
}

/// Placeholder for AST node ID (will integrate with existing AST)
alias AstNodeId = u64;

#[test]
fn test_location_ordering() {
    let block = BlockId::new(0);
    let loc1 = Location::new(block, 0);
    let loc2 = Location::new(block, 1);
    
    assert(loc1.is_before(&loc2));
    assert(!loc2.is_before(&loc1));
}

#[test]
fn test_location_context() {
    var ctx = LocationContext::new();
    let block = BlockId::new(0);
    
    let loc1 = ctx.new_location(block);
    let loc2 = ctx.new_location(block);
    
    assert(loc1.is_before(&loc2));
}