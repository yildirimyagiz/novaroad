// EXAMPLE USAGE & TESTS
// ============================================================================

// Mobile helper functions
fn check_mobile_permission(permission: &str) -> bool {
    // In real implementation, this would check iOS/Android permission status
    match permission {
        "camera" | "location" | "microphone" => true, // Mock: assume granted
        _ => false,
    }
}

fn check_mobile_capability(capability: &str) -> bool {
    // In real implementation, this would check hardware capabilities
    match capability {
        "neural_engine" | "dsp" | "accelerometer" | "gyroscope" | "camera" | "gps" => true, // Mock: assume available
        _ => false,
    }
}

fn get_battery_level() -> f64 {
    // In real implementation, this would query device battery API
    0.8 // Mock: 80% battery
}

fn get_thermal_state() -> String {
    // In real implementation, this would query thermal state
    "cool".into() // Mock: device is cool
}

fn get_current_platform() -> String {
    // In real implementation, this would detect platform
    "iOS".into() // Mock: iOS
}

fn get_current_time() -> i64 {
    // In real implementation, this would get current timestamp
    1640995200 // Mock: 2022-01-01 00:00:00 UTC
}

fn get_active_permissions() -> Vec<String> {
    // In real implementation, this would query active permissions
    yield ["camera".into(), "location".into()] // Mock
}

fn get_available_capabilities() -> Vec<String> {
    // In real implementation, this would query device capabilities
    yield ["camera".into(), "neural_engine".into(), "gps".into()] // Mock
}

fn check_power_source(power_source: &str) -> bool {
    // In real implementation, this would check power source
    power_source == "battery" || power_source == "ac" // Mock: both OK
}

open fn main() {
    println("🌊 Nova Mobile-Aware Supreme Effect System - Active");
    println("===========================================================");

    // Create mobile-aware effect checker
    var checker = EffectChecker::new();

    // Test basic effects
    println("✅ Basic effect system initialized");

    // Test mobile effects
    let camera_effect = Effect::CameraAccess;
    let neural_effect = Effect::NeuralEngine;

    println("📱 Testing Mobile Effects:");
    println("  Camera Access: {}", camera_effect.mobile_description());
    println("  Neural Engine: {}", neural_effect.mobile_description());

    // Validate mobile effects
    let camera_valid = checker.validate_mobile_effect(&camera_effect, "test_camera");
    let neural_valid = checker.validate_mobile_effect(&neural_effect, "test_neural");

    println("  Camera Access Valid: {}", camera_valid);
    println("  Neural Engine Valid: {}", neural_valid);

    // Register mobile-aware function signatures
    let camera_sig = EffectSignature::new(["image_data".into()], "processed_image".into())
        .with_effect(Effect::CameraAccess)
        .with_mobile_constraints(MobileEffectConstraints {
            required_permissions: ["camera".into()],
            min_battery_level: Some(0.2),
            thermal_constraint: Some("hot".into()),
            platform_constraint: None,
            required_capabilities: ["camera".into()],
            max_execution_time: Some(30),
            resource_limits: Some(ResourceLimits {
                max_cpu_usage: Some(80.0),
                max_memory_mb: Some(100),
                max_battery_drain: Some(0.05),
                max_thermal_increase: Some(10.0),
            }),
        });

    let neural_sig = EffectSignature::new(["tensor".into()], "prediction".into())
        .with_effect(Effect::NeuralEngine)
        .with_mobile_constraints(MobileEffectConstraints {
            required_permissions: [],
            min_battery_level: Some(0.5),
            thermal_constraint: Some("hot".into()),
            platform_constraint: None,
            required_capabilities: ["neural_engine".into()],
            max_execution_time: Some(60),
            resource_limits: Some(ResourceLimits {
                max_cpu_usage: Some(95.0),
                max_memory_mb: Some(500),
                max_battery_drain: Some(0.1),
                max_thermal_increase: Some(20.0),
            }),
        });

    checker.register_function("take_photo".into(), camera_sig);
    checker.register_function("run_inference".into(), neural_sig);

    println("✅ Mobile-aware function signatures registered");

    // Display mobile effect summary
    println("\n{}", checker.mobile_effect_summary());

    println("\n🎯 Mobile-Aware Effect System Key Features:");
    println("==========================================");
