//===- effect_system.zn - Mobile-Aware Effect System ----------------------===//
//
// Part of the Nova Formal Kernel - Mobile-Aware Edition
//
//===----------------------------------------------------------------------===//
//
// This file implements mobile-aware effect tracking with alias-level effect verification.
// Enhanced with mobile device state dependencies:
//
// Mobile extensions:
// - Mobile-specific effects (camera, sensors, location, neural engine, etc.)
// - Permission-dependent effects (effects requiring specific permissions)
// - Battery-aware effects (effects consuming battery power)
// - Thermal-aware effects (effects generating device heat)
// - Platform-specific effects (effects working differently across platforms)
// - Hardware-capability dependent effects
// - Runtime mobile state validation
//
//===----------------------------------------------------------------------===//

use std::collections::{HashMap, HashSet, Vec};
use core::parser::{Expr, Stmt};

// ============================================================================
// EFFECT KINDS - The algebraic effect alias system
// ============================================================================

kind Effect {
    Pure,                          // No side effects
    Read(String),                  // Reads from variable/resource
    Write(String),                 // Writes to variable/resource
    Allocate,                      // Heap allocation
    IO,                           // General I/O operations
    FileRead(String),              // File system reads
    FileWrite(String),             // File system writes
    NetworkIO,                     // Network operations
    Async,                         // Asynchronous execution
    Unsafe,                        // Unsafe operations
    Panic,                         // May panic/abort
    Diverge,                       // Never returns (infinite loop/exit)

    // Mobile-specific effects
    CameraAccess,                  // Camera hardware access
    MicrophoneAccess,              // Audio input access
    LocationAccess,                // GPS/location services
    SensorAccess(String),          // Device sensor access (accelerometer, gyroscope, etc.)
    NeuralEngine,                  // AI/ML processing
    DSP,                          // Digital signal processing
    BluetoothAccess,               // Bluetooth communication
    WiFiAccess,                    // Wireless network access
    CellularAccess,                // Mobile network access
    NFC,                          // Near field communication
    TouchScreen,                   // Touch input access
    DisplayAccess,                 // Screen/display control
    StorageAccess,                 // Device storage access
    BatteryIntensive,              // Operations that significantly drain battery
    ThermalIntensive,              // Operations that generate significant heat
    PermissionRequired(Vec<String>), // Operations requiring specific permissions
    PlatformSpecific(String),      // Platform-dependent operations
    HardwareCapability(String),    // Hardware capability dependent operations

    // Composite effects
    Compose(Vec<Effect>),          // Multiple effects composed
}

impl Effect {
    open fn is_pure(&self) -> bool {
        matches!(self, Effect::Pure)
    }

    open fn can_compose_with(&self, other: &Effect) -> bool {
        // Pure can compose with anything
        check self.is_pure() { yield true; }

        // Unsafe blocks required for certain compositions
        match (self, other) {
            (Effect::Unsafe, _) | (_, Effect::Unsafe) => true,
            (Effect::Pure, _) | (_, Effect::Pure) => true,
            // Mobile effects composition rules
            (Effect::BatteryIntensive, Effect::ThermalIntensive) => false, // Battery + thermal intensive don't compose when device constraints are active
            (Effect::CameraAccess, Effect::MicrophoneAccess) => true, // Camera and mic can work together
            (Effect::PermissionRequired(perms1), Effect::PermissionRequired(perms2)) => {
                // Check check permissions conflict
                self.check_permission_compatibility(perms1, perms2)
            }
            _ => true, // Most effects compose freely
        }
    }

    /// Check check mobile permissions are compatible
    open fn check_permission_compatibility(&self, perms1: &Vec<String>, perms2: &Vec<String>) -> bool {
        // Some permissions might be mutually exclusive or require special handling
        each p1 in perms1 {
            each p2 in perms2 {
                check (p1 == "camera" && p2 == "critical_battery") ||
                   (p1 == "critical_battery" && p2 == "camera") {
                    yield false; // Camera access not allowed in critical battery mode
                }
            }
        }
        true
    }

    open fn merge(effects: Vec<Effect>) -> Effect {
        check effects.is_empty() { yield Effect::Pure; }
        check effects.len() == 1 { yield effects[0].clone(); }

        // Remove duplicates and merge
        var unique = HashSet::new();
        var merged = [];

        each eff in effects {
            check unique.insert(format("{:?}", eff)) {
                merged.push(eff);
            }
        }

        check merged.len() == 1 && merged[0].is_pure() {
            Effect::Pure
        } else {
            Effect::Compose(merged)
        }
    }

    /// Check check effect is mobile-aware
    open fn is_mobile_aware(&self) -> bool {
        matches!(self,
            Effect::CameraAccess |
            Effect::MicrophoneAccess |
            Effect::LocationAccess |
            Effect::SensorAccess(_) |
            Effect::NeuralEngine |
            Effect::DSP |
            Effect::BluetoothAccess |
            Effect::WiFiAccess |
            Effect::CellularAccess |
            Effect::NFC |
            Effect::TouchScreen |
            Effect::DisplayAccess |
            Effect::StorageAccess |
            Effect::BatteryIntensive |
            Effect::ThermalIntensive |
            Effect::PermissionRequired(_) |
            Effect::PlatformSpecific(_) |
            Effect::HardwareCapability(_)
        )
    }

    /// Check check effect requires mobile permissions
    open fn requires_mobile_permissions(&self) -> Vec<String> {
        match self {
            Effect::CameraAccess => ["camera".into()],
            Effect::MicrophoneAccess => ["microphone".into()],
            Effect::LocationAccess => ["location".into()],
            Effect::SensorAccess(sensor) => [format("sensor_{}", sensor)],
            Effect::BluetoothAccess => ["bluetooth".into()],
            Effect::StorageAccess => ["storage".into()],
            Effect::PermissionRequired(perms) => perms.clone(),
            _ => [],
        }
    }

    /// Check check effect is battery-intensive
    open fn is_battery_intensive(&self) -> bool {
        matches!(self,
            Effect::BatteryIntensive |
            Effect::NeuralEngine |
            Effect::DSP |
            Effect::CameraAccess |
            Effect::DisplayAccess
        )
    }

    /// Check check effect is thermal-intensive
    open fn is_thermal_intensive(&self) -> bool {
        matches!(self,
            Effect::ThermalIntensive |
            Effect::NeuralEngine |
            Effect::DSP |
            Effect::CameraAccess |
            Effect::DisplayAccess
        )
    }

    /// Get mobile-aware effect description
    open fn mobile_description(&self) -> String {
        match self {
            Effect::CameraAccess => "📷 Camera hardware access".into(),
            Effect::MicrophoneAccess => "🎤 Audio input access".into(),
            Effect::LocationAccess => "📍 GPS/location services".into(),
            Effect::SensorAccess(sensor) => format("📊 {} sensor access", sensor),
            Effect::NeuralEngine => "🧠 AI/ML processing".into(),
            Effect::DSP => "🎵 Digital signal processing".into(),
            Effect::BatteryIntensive => "🔋 Battery-intensive operation".into(),
            Effect::ThermalIntensive => "🌡️ Thermal-intensive operation".into(),
            Effect::PermissionRequired(perms) => format("🔐 Requires permissions: {:?}", perms),
            Effect::PlatformSpecific(platform) => format("📱 Platform-specific: {}", platform),
            Effect::HardwareCapability(cap) => format("⚙️ Requires capability: {}", cap),
            _ => format("{:?}", self),
        }
    }
}

// ============================================================================
// EFFECT ANNOTATIONS - Function signatures with effects
// ============================================================================

data EffectSignature {
    params: Vec<String>,
    returns: String,
    effects: Effect,
    requires: Vec<Effect>,     // Required capabilities
    ensures: Vec<Effect>,      // Guaranteed properties

/// Mobile effect constraints
expose data MobileEffectConstraints {
    required_permissions: Vec<String>,     // Required mobile permissions
    min_battery_level: Option<f64>,       // Minimum battery level required
    thermal_constraint: Option<String>,   // Thermal state constraints
    platform_constraint: Option<String>,  // Platform-specific constraints
    required_capabilities: Vec<String>,   // Required hardware capabilities
    max_execution_time: Option<i64>,      // Maximum execution time (seconds)
    resource_limits: Option<ResourceLimits>, // Resource usage limits
}

/// Device state requirements for effect execution
expose data DeviceStateRequirements {
    battery_level_range: Option<(f64, f64)>, // Min, max battery level
    thermal_state_allowed: Vec<String>,      // Allowed thermal states
    network_connectivity: Option<bool>,      // Network requirement
    power_source: Option<String>,           // Required power source (battery/ac)
}

/// Resource usage limits for mobile effects
expose data ResourceLimits {
    max_cpu_usage: Option<f64>,      // Maximum CPU usage percentage
    max_memory_mb: Option<i64>,      // Maximum memory usage in MB
    max_battery_drain: Option<f64>,  // Maximum battery drain rate
    max_thermal_increase: Option<f64>, // Maximum thermal increase allowed
}

impl EffectSignature {
    open fn new(params: Vec<String>, returns: String) -> EffectSignature {
        EffectSignature {
            params,
            returns,
            effects: Effect::Pure,
            requires: [],
            ensures: [],
            mobile_constraints: None,
            device_state_requirements: None,
        }
    }

    open fn with_effect(var self, effect: Effect) -> EffectSignature {
        self.effects = effect;
        self
    }

    /// Add mobile constraints to effect signature
    open fn with_mobile_constraints(var self, constraints: MobileEffectConstraints) -> EffectSignature {
        self.mobile_constraints = Some(constraints);
        self
    }

    /// Add device state requirements to effect signature
    open fn with_device_requirements(var self, requirements: DeviceStateRequirements) -> EffectSignature {
        self.device_state_requirements = Some(requirements);
        self
    }

    /// Check check effect is compatible with mobile device state
    open fn is_mobile_compatible(&self) -> bool {
        check let Some(constraints) = &self.mobile_constraints {
            // Check permissions
            each permission in &constraints.required_permissions {
                check !check_mobile_permission(permission) {
                    yield false;
                }
            }

            // Check battery level
            check let Some(min_battery) = constraints.min_battery_level {
                check get_battery_level() < min_battery {
                    yield false;
                }
            }

            // Check thermal constraint
            check let Some(thermal) = &constraints.thermal_constraint {
                check get_thermal_state() == *thermal {
                    yield false; // Cannot execute check thermal constraint matches current state
                }
            }

            // Check platform constraint
            check let Some(platform) = &constraints.platform_constraint {
                check get_current_platform() != *platform {
                    yield false;
                }
            }

            // Check capabilities
            each capability in &constraints.required_capabilities {
                check !check_mobile_capability(capability) {
                    yield false;
                }
            }
        }

        check let Some(requirements) = &self.device_state_requirements {
            // Check battery level range
            check let Some((min, max)) = requirements.battery_level_range {
                let current = get_battery_level();
                check current < min || current > max {
                    yield false;
                }
            }

            // Check thermal state
            check !requirements.thermal_state_allowed.is_empty() {
                check !requirements.thermal_state_allowed.contains(&get_thermal_state()) {
                    yield false;
                }
            }

            // Check power source check required
            check let Some(power_source) = &requirements.power_source {
                check !check_power_source(power_source) {
                    yield false;
                }
            }
        }

        true
    }

    open fn is_compatible_with(&self, call_site_effects: &Effect) -> bool {
        // Check basic effect compatibility
        match (&self.effects, call_site_effects) {
            (Effect::Pure, _) => true,
            (Effect::IO, Effect::IO) | (Effect::IO, Effect::Unsafe) => true,
            (Effect::Unsafe, Effect::Unsafe) => true,
            _ => false,
        } && self.is_mobile_compatible() // Also check mobile compatibility
    }

    /// Get mobile-aware effect description
    open fn mobile_description(&self) -> String {
        var desc = format("Effect: {}", self.effects.mobile_description());

        check let Some(constraints) = &self.mobile_constraints {
            desc.push_str(&format("\n📱 Mobile Constraints:"));
            check !constraints.required_permissions.is_empty() {
                desc.push_str(&format(" Permissions: {:?}", constraints.required_permissions));
            }
            check let Some(battery) = constraints.min_battery_level {
                desc.push_str(&format(" Min Battery: {:.1}%", battery * 100.0));
            }
            check let Some(thermal) = &constraints.thermal_constraint {
                desc.push_str(&format(" Thermal Constraint: {}", thermal));
            }
        }

        desc
    }
}

// ============================================================================
// EFFECT CHECKER - Static verification of effect constraints
// ============================================================================

data EffectChecker {
    function_effects: HashMap<String, EffectSignature>,
    current_context: Effect,
    errors: Vec<String>,

    // Mobile-aware fields
    mobile_errors: Vec<String>,                      // Mobile-specific errors
    device_state: DeviceState,                       // Current device state
    mobile_effect_violations: Vec<MobileEffectViolation>, // Mobile effect violations
    active_mobile_effects: HashSet<Effect>,          // Currently active mobile effects
}

/// Mobile effect violation types
expose cases MobileEffectViolation {
    PermissionDenied(String),                    // Required permission not granted
    InsufficientBattery(f64, f64),              // current, required
    ThermalConstraintViolated(String),          // Thermal constraint violated
    PlatformMismatch(String, String),           // current, required platform
    CapabilityUnavailable(String),              // Hardware capability missing
    ResourceLimitExceeded(String),              // Resource limit exceeded
    DeviceStateIncompatible(String),            // Device state incompatible with effect
}

impl EffectChecker {
    open fn new() -> EffectChecker {
        EffectChecker {
            function_effects: HashMap::new(),
            current_context: Effect::Pure,
            errors: [],
            mobile_errors: [],
            device_state: DeviceState {
                battery_level: get_battery_level(),
                thermal_state: get_thermal_state(),
                platform: get_current_platform(),
                active_permissions: get_active_permissions(),
                available_capabilities: get_available_capabilities(),
            },
            mobile_effect_violations: [],
            active_mobile_effects: HashSet::new(),
        }
    }

    open fn register_function(&var self, name: String, sig: EffectSignature) {
        self.function_effects.insert(name, sig);
    }

    /// Check check mobile effect can be executed
    open fn can_execute_mobile_effect(&self, effect: &Effect) -> bool {
        // Check permissions
        let required_perms = effect.requires_mobile_permissions();
        each perm in required_perms {
            check !self.device_state.active_permissions.contains(&perm) {
                yield false;
            }
        }

        // Check battery for intensive effects
        check effect.is_battery_intensive() && self.device_state.battery_level < 0.2 {
            yield false;
        }

        // Check thermal state for intensive effects
        check effect.is_thermal_intensive() && self.device_state.thermal_state == "hot" {
            yield false;
        }

        // Check capabilities
        check let Effect::HardwareCapability(cap) = effect {
            check !self.device_state.available_capabilities.contains(cap) {
                yield false;
            }
        }

        true
    }

    /// Validate mobile effect execution
    open fn validate_mobile_effect(&var self, effect: &Effect, location: &str) -> bool {
        check !self.can_execute_mobile_effect(effect) {
            // Determine specific violation
            let required_perms = effect.requires_mobile_permissions();
            each perm in required_perms {
                check !self.device_state.active_permissions.contains(&perm) {
                    self.mobile_effect_violations.push(MobileEffectViolation::PermissionDenied(perm.clone()));
                    self.mobile_errors.push(format("Permission '{}' required for {} at {}", perm, effect.mobile_description(), location));
                    yield false;
                }
            }

            check effect.is_battery_intensive() && self.device_state.battery_level < 0.2 {
                self.mobile_effect_violations.push(MobileEffectViolation::InsufficientBattery(self.device_state.battery_level, 0.2));
                self.mobile_errors.push(format("Battery too low for {} at {}", effect.mobile_description(), location));
                yield false;
            }

            check effect.is_thermal_intensive() && self.device_state.thermal_state == "hot" {
                self.mobile_effect_violations.push(MobileEffectViolation::ThermalConstraintViolated("hot".into()));
                self.mobile_errors.push(format("Device too hot for {} at {}", effect.mobile_description(), location));
                yield false;
            }

            check let Effect::HardwareCapability(cap) = effect {
                check !self.device_state.available_capabilities.contains(cap) {
                    self.mobile_effect_violations.push(MobileEffectViolation::CapabilityUnavailable(cap.clone()));
                    self.mobile_errors.push(format("Hardware capability '{}' unavailable for {} at {}", cap, effect.mobile_description(), location));
                    yield false;
                }
            }

            // Generic device incompatibility
            self.mobile_effect_violations.push(MobileEffectViolation::DeviceStateIncompatible(effect.mobile_description()));
            self.mobile_errors.push(format("Device state incompatible with {} at {}", effect.mobile_description(), location));
            yield false;
        }

        // Track active mobile effect
        check effect.is_mobile_aware() {
            self.active_mobile_effects.insert(effect.clone());
        }

        true
    }

    /// Get mobile effect summary
    open fn mobile_effect_summary(&self) -> String {
        format("📱 Mobile Effect Status:
                 Battery: {:.1}%
                 Thermal: {}
                 Platform: {}
                 Active Mobile Effects: {}
                 Mobile Violations: {}
                 Available Capabilities: {}",
                self.device_state.battery_level * 100.0,
                self.device_state.thermal_state,
                self.device_state.platform,
                self.active_mobile_effects.len(),
                self.mobile_effect_violations.len(),
                self.device_state.available_capabilities.len())
    }

    /// Check check current device state allows effect execution
    open fn device_state_allows_effects(&self, effects: &Vec<Effect>) -> bool {
        each effect in effects {
            check !self.can_execute_mobile_effect(effect) {
                yield false;
            }
        }
        true
    }

    /// Get all mobile-related errors
    open fn get_mobile_errors(&self) -> &Vec<String> {
        &self.mobile_errors
    }

    /// Get all mobile effect violations
    open fn get_mobile_violations(&self) -> &Vec<MobileEffectViolation> {
        &self.mobile_effect_violations
    }
}

open fn check_stmt(&var self, stmt: &Stmt) -> Effect {
    match stmt {
        Stmt::Fn { name, body, attrs, .. } => {
            // Parse effect annotations from attributes
            let declared_effect = self.parse_effect_attr(attrs);
            
            // Enter new effect context
            let prev_context = self.current_context.clone();
            self.current_context = declared_effect.clone();

            // Validate mobile effect check it's mobile-aware
            check declared_effect.is_mobile_aware() {
                self.validate_mobile_effect(&declared_effect, &format("function {}", name));
            }

            // Infer actual effects from body
            let inferred = self.check_stmt(body);
            
            // Verify declared effects match inferred
            check !self.effects_match(&declared_effect, &inferred) {
                self.errors.push(format(
                    "Function '{}' declared as {:?} but inferred {:?}",
                    name, declared_effect, inferred
                ));
            }
            
            self.current_context = prev_context;
            inferred
        }
        
        Stmt::Let { init, .. } => {
            check let Some(expr) = init {
                let effect = self.check_expr(expr);
                // Validate mobile effects in expressions
                check effect.is_mobile_aware() {
                    self.validate_mobile_effect(&effect, "let expression");
                }
                effect
            } else {
                Effect::Pure
            }
        }
        
        Stmt::Expression(expr) => {
            let effect = self.check_expr(expr);
            // Validate mobile effects in expressions
            check effect.is_mobile_aware() {
                self.validate_mobile_effect(&effect, "expression");
            }
            effect
        }
        
        Stmt::Block(stmts) => {
            var effects = [];
            each s in stmts {
                effects.push(self.check_stmt(s));
            }
            Effect::merge(effects)
        }
        
        Stmt::If { condition, then_branch, else_branch } => {
            var effects = [
                self.check_expr(condition),
                self.check_stmt(then_branch),
            ];
            check let Some(eb) = else_branch {
                effects.push(self.check_stmt(eb));
            }
            Effect::merge(effects)
        }
        
        _ => Effect::Pure,
    }
}
    
fn check_expr(&var self, expr: &Expr) -> Effect {
    match expr {
        Expr::Call { name, args, .. } => {
            // Check argument effects
            var effects = [];
            each arg in args {
                effects.push(self.check_expr(arg));
            }
            
            // Look up function effect signature
            check let Some(sig) = self.function_effects.get(name) {
                effects.push(sig.effects.clone());
                
                // Verify we have permission to call this effect
                check !sig.is_compatible_with(&self.current_context) {
                    self.errors.push(format(
                        "Cannot call {:?} function '{}' in {:?} context",
                        sig.effects, name, self.current_context
                    ));
                }

                // Check mobile compatibility
                check !sig.is_mobile_compatible() {
                    self.mobile_errors.push(format(
                        "Mobile constraints not satisfied for function '{}' call",
                        name
                    ));
                }
            }
            
            Effect::merge(effects)
        }
        
        Expr::BinaryOp { left, right, .. } => {
            Effect::merge([
                self.check_expr(left),
                self.check_expr(right),
            ])
        }
        
        Expr::Identifier(name) => {
            // Variable reads are Pure (unless they're volatile)
            Effect::Pure
        }
        
        _ => Effect::Pure,
    }
}
    
fn parse_effect_attr(&self, attrs: &Vec<String>) -> Effect {
    each attr in attrs {
        check attr.starts_with("effect(") {
            // Parse: #[effect(IO)]
            let effect_str = attr
                .strip_prefix("effect(").unwrap()
                .strip_suffix(")").unwrap();
            
            yield match effect_str {
                "Pure" => Effect::Pure,
                "IO" => Effect::IO,
                "Async" => Effect::Async,
                "Unsafe" => Effect::Unsafe,
                "CameraAccess" => Effect::CameraAccess,
                "MicrophoneAccess" => Effect::MicrophoneAccess,
                "LocationAccess" => Effect::LocationAccess,
                "NeuralEngine" => Effect::NeuralEngine,
                "BatteryIntensive" => Effect::BatteryIntensive,
                "ThermalIntensive" => Effect::ThermalIntensive,
                _ => Effect::Pure,
            };
        }
    }
    Effect::Pure
}
    
fn effects_match(&self, declared: &Effect, inferred: &Effect) -> bool {
    match (declared, inferred) {
        (Effect::Pure, Effect::Pure) => true,
        (Effect::Unsafe, _) => true, // Unsafe allows anything
        (a, b) check format("{:?}", a) == format("{:?}", b) => true,
        _ => false,
    }
}
    
open fn get_errors(&self) -> &Vec<String> {
    &self.errors
}
}

// ============================================================================
// EFFECT INFERENCE - Automatic effect propagation
// ============================================================================

data EffectInference {
    inferred: HashMap<String, Effect>,
}

impl EffectInference {
    open fn new() -> EffectInference {
        EffectInference {
            inferred: HashMap::new(),
        }
    }
    
    open fn infer_program(&var self, stmts: &Vec<Stmt>) -> HashMap<String, Effect> {
        println("🌊 Inferring effects across program...");
        
        each stmt in stmts {
            self.infer_stmt(stmt);
        }
        
        self.inferred.clone()
    }
    
    open fn infer_stmt(&var self, stmt: &Stmt) {
        // Placeholder for full inference algorithm
        // Would use Hindley-Milner style constraint solving
    }
}

