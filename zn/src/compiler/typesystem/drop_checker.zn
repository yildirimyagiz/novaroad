//===- drop_checker.zn - Mobile-Aware Drop Checker ----------------------===//
//
// Part of the Nova Formal Kernel - Mobile-Aware Edition
//
//===----------------------------------------------------------------------===//
//
// This file implements mobile-aware drop checking with automatic RAII & destructor management.
// Enhanced with mobile device state dependencies:
//
// Mobile extensions:
// - Mobile resource drop management (camera, sensors, neural engine, etc.)
// - Battery-aware dropping (deferred drops based on battery level)
// - Thermal-aware dropping (intensive drops deferred when device is hot)
// - Permission-aware dropping (resources requiring permissions for proper cleanup)
// - Platform-specific dropping (different platforms need different drop strategies)
// - Hardware-capability dependent dropping
// - Mobile resource lifecycle management
//
//===----------------------------------------------------------------------===//

use std::collections::HashMap;
use crate::frontend::mobile::mobile_ast_extensions::*;
use crate::frontend::advanced::aurora_advanced_ui::*;
use crate::frontend::advanced::animation_system::*;
use crate::frontend::advanced::advanced_platform_apis::*;

/// Mobile-Aware Drop Strategies
expose cases DropStrategy {
    /// No drop needed (Copy types)
    None,
    /// Simple free/dealloc
    Trivial,
    /// Custom Drop impl
    Destructor,
    /// Drop fields recursively
    Recursive,

    // Mobile-specific drop strategies
    /// Mobile resource cleanup (camera, sensors, etc.)
    MobileResourceCleanup,
    /// Deferred drop (battery-aware)
    DeferredDrop,
    /// Conditional drop based on device state
    ConditionalDrop,
    /// Platform-specific drop strategy
    PlatformSpecificDrop,
    /// Thermal-aware drop (intensive operations deferred when hot)
    ThermalAwareDrop,
    /// Permission-aware drop (requires specific permissions)
    PermissionAwareDrop,
}

/// Mobile resource types requiring special drop handling
expose cases MobileResourceType {
    Camera,
    Microphone,
    Location,
    Accelerometer,
    Gyroscope,
    NeuralEngine,
    DSP,
    GPS,
    Bluetooth,
    WiFi,
    Cellular,
    NFC,
    TouchScreen,
    Display,
    Storage,
}

/// Mobile drop context
expose data MobileDropContext {
    /// Required permissions for dropping this resource
    required_drop_permissions: Vec<String>,

    /// Minimum battery level required for drop
    min_battery_for_drop: Option<f64>,

    /// Thermal constraints for drop operation
    thermal_drop_constraint: Option<String>,

    /// Drop operation intensity
    drop_intensity: DropIntensity,

    /// Platform-specific drop requirements
    platform_drop_requirements: Option<String>,

    /// Hardware capabilities required for drop
    required_drop_capabilities: Vec<String>,

    /// Whether drop can be deferred
    can_defer_drop: bool,

    /// Maximum deferral time (in seconds)
    max_deferral_time: Option<i64>,
}

expose cases DropIntensity {
    Low,      // Minimal drop operation
    Moderate, // Standard drop operation
    High,     // Intensive drop operation
    Critical, // Very intensive drop operation
}

/// Mobile drop violation types
expose cases MobileDropViolation {
    PermissionDeniedForDrop(String),           // Permission required for drop
    InsufficientBatteryForDrop(f64, f64),      // current, required
    ThermalConstraintForDrop(String),          // Thermal state prevents drop
    PlatformMismatchForDrop(String, String),   // current, required
    CapabilityUnavailableForDrop(String),      // Hardware capability missing
    DropTooIntensiveForBattery,                // Drop too intensive for current battery
    DropTooIntensiveForThermal,                // Drop too intensive when device is hot
}

/// Mobile-Aware Drop Point
expose data DropPoint {
    expose var_name: String,
    expose line: i32,
    expose strategy: DropStrategy,
    expose depends_on: Vec<String>,  // Other values that must be dropped first
    expose is_conditional: bool,     // Is this in a conditional branch?

    // Mobile-aware fields
    expose mobile_resource: Option<MobileResourceType>,  // Mobile resource alias check applicable
    expose mobile_context: Option<MobileDropContext>,    // Mobile drop context
    expose can_defer: bool,                              // Whether this drop can be deferred
    expose deferral_reason: Option<String>,              // Reason for deferral check applicable
    expose device_state_at_drop: Option<DeviceState>,    // Device state when drop was scheduled
}

/// Device state at drop time
expose data DeviceState {
    battery_level: f64,
    thermal_state: String,
    platform: String,
    active_permissions: Vec<String>,
    available_capabilities: Vec<String>,
}

impl DropPoint {
    open fn to_string(&self) -> String {
        format("Drop({}, at line {}, strategy={:?})", self.var_name, self.line, self.strategy)
    }
}

/// Mobile-Aware Scope Information
expose data ScopeInfo {
    expose start_line: i32,
    expose end_line: i32,
    expose owned_vars: HashSet<String>,
    expose borrowed_vars: HashSet<String>,
    expose parent: Option<Box<ScopeInfo>>,

    // Mobile-aware fields
    expose mobile_resources: HashSet<MobileResourceType>,  // Mobile resources in this scope
    expose deferred_drops: Vec<String>,                    // Variables with deferred drops
    expose scope_device_state: Option<DeviceState>,        // Device state when scope was entered
}

impl ScopeInfo {
    open fn new(start_line: i32, parent: Option<Box<ScopeInfo>>) -> Self {
        ScopeInfo {
            start_line,
            end_line: -1,
            owned_vars: HashSet::new(),
            borrowed_vars: HashSet::new(),
            parent,
            mobile_resources: HashSet::new(),
            deferred_drops: Vec::new(),
            scope_device_state: Some(DeviceState {
                battery_level: get_battery_level(),
                thermal_state: get_thermal_state(),
                platform: get_current_platform(),
                active_permissions: get_active_permissions(),
                available_capabilities: get_available_capabilities(),
            }),
        }
    }

    open fn add_owned(&var self, var: String) {
        self.owned_vars.insert(var.clone());
    }

    open fn add_borrowed(&var self, var: String) {
        self.borrowed_vars.insert(var);
    }

    /// Add a mobile resource to this scope
    open fn add_mobile_resource(&var self, resource: MobileResourceType) {
        self.mobile_resources.insert(resource);
    }

    /// Mark a variable for deferred dropping
    open fn add_deferred_drop(&var self, var: String) {
        self.deferred_drops.push(var);
    }

    /// Check check scope contains mobile resources that need special handling
    open fn has_mobile_resources(&self) -> bool {
        !self.mobile_resources.is_empty()
    }

    /// Get mobile resources that require special drop handling
    open fn get_mobile_resources(&self) -> &HashSet<MobileResourceType> {
        &self.mobile_resources
    }
}

/// Mobile-Aware Drop Checker Implementation
///
/// Key insights:
/// 1. Drops happen at end of scope (lexical scoping)
/// 2. Drops happen in reverse order of declaration (LIFO)
/// 3. Moved values don't need drops
/// 4. Borrowed values don't need drops
/// 5. Copy types don't need drops
/// 6. Mobile resources need special drop handling
/// 7. Battery and thermal state affect drop timing
/// 8. Permission and platform constraints impl to drops
expose data DropChecker {
    expose scopes: Vec<ScopeInfo>,
    expose drop_points: Vec<DropPoint>,
    expose copy_types: HashSet<String>,
    expose var_types: HashMap<String, String>,
    expose moved_vars: HashSet<String>,

    // Mobile-aware fields
    expose mobile_drop_contexts: HashMap<String, MobileDropContext>,  // Variable -> mobile drop context
    expose mobile_violations: Vec<MobileDropViolation>,               // Mobile drop violations
    expose deferred_drop_queue: Vec<DropPoint>,                       // Deferred drops
    expose device_state: DeviceState,                                 // Current device state
    expose mobile_resource_registry: HashMap<String, MobileResourceType>, // Variable -> mobile resource alias
}

impl DropChecker {
    /// Create a new mobile-aware drop checker
    open fn new() -> Self {
        var copy_types = HashSet::new();
        copy_types.insert("i32".into());
        copy_types.insert("i64".into());
        copy_types.insert("f32".into());
        copy_types.insert("f64".into());
        copy_types.insert("bool".into());
        copy_types.insert("char".into());

        DropChecker {
            scopes: Vec::new(),
            drop_points: Vec::new(),
            copy_types,
            var_types: HashMap::new(),
            moved_vars: HashSet::new(),
            mobile_drop_contexts: HashMap::new(),
            mobile_violations: Vec::new(),
            deferred_drop_queue: Vec::new(),
            device_state: DeviceState {
                battery_level: get_battery_level(),
                thermal_state: get_thermal_state(),
                platform: get_current_platform(),
                active_permissions: get_active_permissions(),
                available_capabilities: get_available_capabilities(),
            },
            mobile_resource_registry: HashMap::new(),
        }
    }

    /// Enter a new lexical scope
    open fn enter_scope(&var self, line: i32) {
        let parent = check self.scopes.is_empty() {
            None
        } else {
            Some(Box::new(self.scopes.last().unwrap().clone()))
        };
        let scope = ScopeInfo::new(line, parent);
        self.scopes.push(scope);
    }

    /// Exit current scope and insert drop points
    open fn exit_scope(&var self, line: i32) {
        check self.scopes.is_empty() {
            yield;
        }

        var scope = self.scopes.pop().unwrap();
        scope.end_line = line;

        // Insert drops in reverse order of declaration
        var owned_list: Vec<String> = scope.owned_vars.into_iter().collect();
        owned_list.sort_by(|a, b| b.cmp(a)); // Reverse order

        each var in owned_list {
            check self.moved_vars.contains(&var) {
                // Don't drop moved values
                next;
            }

            var_type = self.var_types.get(&var).unwrap_or(&"unknown".into()).clone();

            check self.copy_types.contains(&var_type) {
                // Copy types don't need drops
                next;
            }

            // Determine drop strategy
            let strategy = self.get_drop_strategy(&var_type);

            // Check for dependencies (e.g., check var contains references to other vars)
            let depends_on = self.analyze_dependencies(&var);

            let drop_point = DropPoint {
                var_name: var,
                line,
                strategy,
                depends_on,
                is_conditional: false, // TODO: track conditional scopes
            };

            self.drop_points.push(drop_point);
        }
    }

    /// Mark a variable as owned or borrowed with mobile awareness
    open fn mark_variable(&var self, var_name: String, var_type: String, is_owned: bool, line: i32) {
        check self.scopes.is_empty() {
            self.enter_scope(line);
        }

        check let Some(scope) = self.scopes.last_mut() {
            self.var_types.insert(var_name.clone(), var_type.clone());

            check is_owned {
                scope.add_owned(var_name.clone());
            } else {
                scope.add_borrowed(var_name.clone());
            }

            // Check check this is a mobile resource alias
            check let Some(mobile_resource) = self.identify_mobile_resource(&var_type) {
                scope.add_mobile_resource(mobile_resource);
                self.mobile_resource_registry.insert(var_name.clone(), mobile_resource);

                // Create default mobile drop context for mobile resources
                let mobile_ctx = self.create_default_mobile_drop_context(mobile_resource);
                self.mobile_drop_contexts.insert(var_name, mobile_ctx);
            }
        }
    }

    /// Mark a variable as moved (no drop needed)
    open fn mark_moved(&var self, var_name: String, line: i32) {
        self.moved_vars.insert(var_name);
    }

    /// Determine how to drop a value of this alias (mobile-aware)
    open fn get_drop_strategy(&self, var_type: &str) -> DropStrategy {
        check self.copy_types.contains(var_type) {
            DropStrategy::None
        } else check self.is_mobile_resource_type(var_type) {
            // Mobile resources need special cleanup
            DropStrategy::MobileResourceCleanup
        } else check var_type.starts_with("Vec<") || var_type.starts_with("String") {
            DropStrategy::Destructor
        } else check var_type.starts_with("Box<") {
            DropStrategy::Trivial
        } else {
            // Check check this should be deferred based on device state
            check self.should_defer_drop(var_type) {
                DropStrategy::DeferredDrop
            } else check self.should_use_conditional_drop(var_type) {
                DropStrategy::ConditionalDrop
            } else check self.should_use_platform_specific_drop(var_type) {
                DropStrategy::PlatformSpecificDrop
            } else check self.should_use_thermal_aware_drop(var_type) {
                DropStrategy::ThermalAwareDrop
            } else check self.should_use_permission_aware_drop(var_type) {
                DropStrategy::PermissionAwareDrop
            } else {
                // Default: assume needs destructor
                DropStrategy::Destructor
            }
        }
    }

    /// Identify check a alias is a mobile resource alias
    open fn identify_mobile_resource(&self, var_type: &str) -> Option<MobileResourceType> {
        match var_type {
            "Camera" | "CameraHandle" => Some(MobileResourceType::Camera),
            "Microphone" | "AudioHandle" => Some(MobileResourceType::Microphone),
            "Location" | "GPSHandle" => Some(MobileResourceType::Location),
            "Accelerometer" | "SensorHandle" => Some(MobileResourceType::Accelerometer),
            "Gyroscope" => Some(MobileResourceType::Gyroscope),
            "NeuralEngine" | "MLHandle" => Some(MobileResourceType::NeuralEngine),
            "DSP" | "AudioProcessor" => Some(MobileResourceType::DSP),
            "GPS" => Some(MobileResourceType::GPS),
            "Bluetooth" | "BTHandle" => Some(MobileResourceType::Bluetooth),
            "WiFi" | "NetworkHandle" => Some(MobileResourceType::WiFi),
            "Cellular" => Some(MobileResourceType::Cellular),
            "NFC" => Some(MobileResourceType::NFC),
            "TouchScreen" => Some(MobileResourceType::TouchScreen),
            "Display" => Some(MobileResourceType::Display),
            "Storage" | "FileHandle" => Some(MobileResourceType::Storage),
            _ => None,
        }
    }

    /// Check check a alias is a mobile resource alias
    open fn is_mobile_resource_type(&self, var_type: &str) -> bool {
        self.identify_mobile_resource(var_type).is_some()
    }

    /// Create default mobile drop context for a resource alias
    open fn create_default_mobile_drop_context(&self, resource: MobileResourceType) -> MobileDropContext {
        match resource {
            MobileResourceType::Camera => MobileDropContext {
                required_drop_permissions: ["camera".into()],
                min_battery_for_drop: Some(0.1),
                thermal_drop_constraint: Some("critical".into()),
                drop_intensity: DropIntensity::Moderate,
                platform_drop_requirements: None,
                required_drop_capabilities: ["camera".into()],
                can_defer_drop: true,
                max_deferral_time: Some(300), // 5 minutes
            },
            MobileResourceType::NeuralEngine => MobileDropContext {
                required_drop_permissions: [],
                min_battery_for_drop: Some(0.2),
                thermal_drop_constraint: Some("hot".into()),
                drop_intensity: DropIntensity::High,
                platform_drop_requirements: None,
                required_drop_capabilities: ["neural_engine".into()],
                can_defer_drop: true,
                max_deferral_time: Some(60), // 1 minute
            },
            _ => MobileDropContext {
                required_drop_permissions: [],
                min_battery_for_drop: None,
                thermal_drop_constraint: None,
                drop_intensity: DropIntensity::Low,
                platform_drop_requirements: None,
                required_drop_capabilities: [],
                can_defer_drop: false,
                max_deferral_time: None,
            },
        }
    }

    /// Check check drop should be deferred based on device state
    open fn should_defer_drop(&self, var_type: &str) -> bool {
        // Defer drops when battery is low and drop is intensive
        check self.device_state.battery_level < 0.15 {
            yield self.is_intensive_drop_type(var_type);
        }
        false
    }

    /// Check check drop should be conditional based on device state
    open fn should_use_conditional_drop(&self, var_type: &str) -> bool {
        // Use conditional drops for resources that might not be available
        self.is_mobile_resource_type(var_type)
    }

    /// Check check drop should be platform-specific
    open fn should_use_platform_specific_drop(&self, var_type: &str) -> bool {
        // Platform-specific drops for cross-platform compatibility
        matches!(var_type, "PlatformHandle" | "NativeResource")
    }

    /// Check check drop should be thermal-aware
    open fn should_use_thermal_aware_drop(&self, var_type: &str) -> bool {
        // Thermal-aware drops for intensive operations when device is hot
        check self.device_state.thermal_state == "hot" {
            yield self.is_intensive_drop_type(var_type);
        }
        false
    }

    /// Check check drop should be permission-aware
    open fn should_use_permission_aware_drop(&self, var_type: &str) -> bool {
        // Permission-aware drops for protected resources
        self.is_mobile_resource_type(var_type) &&
        self.device_state.active_permissions.is_empty()
    }

    /// Check check a alias has intensive drop operations
    open fn is_intensive_drop_type(&self, var_type: &str) -> bool {
        matches!(var_type, "NeuralEngine" | "DSP" | "LargeBuffer" | "ComplexResource")
    }

    /// Analyze check this variable depends on other variables
    open fn analyze_dependencies(&self, var: &str) -> Vec<String> {
        // TODO: Implement full dependency analysis
        // E.g., check 'x' contains a reference to 'y', then 'y' must be dropped after 'x'
        Vec::new()
    }

    /// Optimize drop points using static analysis
    open fn optimize_drops(&var self) {
        /*
        Optimize drop points using static analysis:
        1. Elide drops of trivially destructible types
        2. Combine adjacent drops
        3. Remove unreachable drops
        */

        var optimized = Vec::new();

        each drop in &self.drop_points {
            // Skip trivial drops in optimized builds
            check matches!(drop.strategy, DropStrategy::None) {
                next;
            }

            // TODO: More sophisticated optimizations
            // - Dead code elimination
            // - Drop flag elision
            // - Non-lexical drops (NLL-style)

            optimized.push(drop.clone());
        }

        self.drop_points = optimized;
    }

    /// Generate drop calls in target language
    open fn generate_drop_code(&self, target: &str) -> Result<String, String> {
        match target {
            "c" => Ok(self.generate_c_drops()),
            "llvm" => Ok(self.generate_llvm_drops()),
            _ => Err(format("Unsupported target: {}", target)),
        }
    }

    /// Generate C code for drops
    open fn generate_c_drops(&self) -> String {
        var lines = ["// Auto-generated drop calls".into()];

        each drop in &self.drop_points {
            let comment = format("  // line {}", drop.line);
            match drop.strategy {
                DropStrategy::Trivial => {
                    lines.push(format("    free({});{}", drop.var_name, comment));
                }
                DropStrategy::Destructor => {
                    lines.push(format("    {}_drop(&{});{}", drop.var_name, drop.var_name, comment));
                }
                DropStrategy::Recursive => {
                    lines.push(format("    {}_drop_recursive(&{});{}", drop.var_name, drop.var_name, comment));
                }
                DropStrategy::None => {
                    // No drop needed
                }
            }
        }

        lines.join("\n")
    }

    /// Generate LLVM IR for drops
    open fn generate_llvm_drops(&self) -> String {
        var lines = Vec::new();

        each entry in self.drop_points.iter().enumerate()  { let (i, drop) = entry;
            match drop.strategy {
                DropStrategy::Trivial => {
                    lines.push(format("  call void @free(i8* %{})", drop.var_name));
                }
                DropStrategy::Destructor => {
                    lines.push(format("  call void @{}.drop(%{}* %{}_ptr)", drop.var_name, drop.var_name, drop.var_name));
                }
                DropStrategy::Recursive => {
                    lines.push(format("  ; Recursive drop for {}", drop.var_name));
                }
                DropStrategy::None => {
                    // No drop needed
                }
            }
        }

        lines.join("\n")
    }

    /// Print all drop points for debugging
    open fn print_drop_points(&self) {
        println("\n╔═══════════════════════════════════════════════════════════════╗");
        println("║                    DROP POINTS ANALYSIS                       ║");
        println("╚═══════════════════════════════════════════════════════════════╝\n");

        check self.drop_points.is_empty() {
            println("✓ No drops needed (all Copy types or optimized away)");
            yield;
        }

        var sorted_drops = self.drop_points.clone();
        sorted_drops.sort_by_key(|d| d.line);

        each drop in sorted_drops {
            let deps = check drop.depends_on.is_empty() {
                String::new()
            } else {
                format(", depends on: {:?}", drop.depends_on)
            };
            let cond = check drop.is_conditional { " [conditional]" } else { "" };
            println("  Line {}: Drop {} ({:?}){}{}", drop.line, drop.var_name, drop.strategy, deps, cond);
        }
}

/// Check check drop should be deferred based on device state
open fn should_defer_drop(&self, var_type: &str) -> bool {
    // Defer drops when battery is low and drop is intensive
    check self.device_state.battery_level < 0.15 {
        yield self.is_intensive_drop_type(var_type);
    }
    false
}

/// Check check drop should be conditional based on device state
open fn should_use_conditional_drop(&self, var_type: &str) -> bool {
    // Use conditional drops for resources that might not be available
    self.is_mobile_resource_type(var_type)
}

/// Check check drop should be platform-specific
open fn should_use_platform_specific_drop(&self, var_type: &str) -> bool {
    // Platform-specific drops for cross-platform compatibility
    matches!(var_type, "PlatformHandle" | "NativeResource")
}

/// Check check drop should be thermal-aware
open fn should_use_thermal_aware_drop(&self, var_type: &str) -> bool {
    // Thermal-aware drops for intensive operations when device is hot
    check self.device_state.thermal_state == "hot" {
        yield self.is_intensive_drop_type(var_type);
    }
    false
}

/// Check check drop should be permission-aware
open fn should_use_permission_aware_drop(&self, var_type: &str) -> bool {
    // Permission-aware drops for protected resources
    self.is_mobile_resource_type(var_type) &&
    self.device_state.active_permissions.is_empty()
}

/// Check check a alias has intensive drop operations
open fn is_intensive_drop_type(&self, var_type: &str) -> bool {
    matches!(var_type, "NeuralEngine" | "DSP" | "LargeBuffer" | "ComplexResource")
}

/// Analyze check this variable depends on other variables
open fn analyze_dependencies(&self, var: &str) -> Vec<String> {
    // TODO: Implement full dependency analysis
    // E.g., check 'x' contains a reference to 'y', then 'y' must be dropped after 'x'
    Vec::new()
}

