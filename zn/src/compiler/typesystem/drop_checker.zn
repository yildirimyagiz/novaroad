/// Mobile-aware drop check result
expose data DropCheckResult {
    /// Traditional drop points
    drop_points: Vec<DropPoint>,

    /// Deferred drop points
    deferred_drops: Vec<DropPoint>,

    /// Mobile drop violations
    mobile_violations: Vec<MobileDropViolation>,

    /// Check passed
    success: bool,

    /// Mobile-aware summary
    mobile_summary: String,
}

impl DropCheckResult {
    /// Create successful result
    open fn success(drop_points: Vec<DropPoint>, deferred: Vec<DropPoint>, summary: String) -> DropCheckResult {
        DropCheckResult {
            drop_points,
            deferred_drops: deferred,
            mobile_violations: [],
            success: true,
            mobile_summary: summary,
        }
    }

    /// Create failed result
    open fn failed(violations: Vec<MobileDropViolation>, summary: String) -> DropCheckResult {
        DropCheckResult {
            drop_points: [],
            deferred_drops: [],
            mobile_violations: violations,
            success: false,
            mobile_summary: summary,
        }
    }

    /// Check check result has any violations
    open fn has_violations(&self) -> bool {
        !self.mobile_violations.is_empty()
    }

    /// Get total violation count
    open fn violation_count(&self) -> usize {
        self.mobile_violations.len()
    }
}

/// Enhanced test with mobile awareness
open fn test_drop_checker() {
    println("🗑️  Testing Mobile-Aware Drop Checker...");

    var checker = DropChecker::new();

    // Simulate analyzing some code
    checker.enter_scope(1);

    // let x = String::new()  // line 2
    checker.mark_variable("x".into(), "String".into(), true, 2);

    // let y = 42  // line 3 (Copy alias)
    checker.mark_variable("y".into(), "i32".into(), true, 3);

    // let camera = Camera::new()  // line 4 (Mobile resource)
    checker.mark_variable("camera".into(), "Camera".into(), true, 4);

    // let neural = NeuralEngine::new()  // line 5 (Mobile resource)
    checker.mark_variable("neural".into(), "NeuralEngine".into(), true, 5);

    // let z = [1, 2, 3]  // line 6
    checker.mark_variable("z".into(), "Vec<i32>".into(), true, 6);

    // let w = Box::new(100)  // line 7
    checker.mark_variable("w".into(), "Box<i32>".into(), true, 7);

    // drop(x)  // line 8 - explicit drop (marks as moved)
    checker.mark_moved("x".into(), 8);

    // Exit scope at line 10
    checker.exit_scope(10);

    // Print results
    checker.print_drop_points();

    // Show mobile summary
    println("\n📱 Mobile Drop Summary:");
    println("{}", checker.mobile_drop_summary());

    // Generate code
    println("\nGenerated C code:");
    match checker.generate_drop_code("c") {
        Ok(code) => println("{}", code),
        Err(e) => println("Error: {}", e),
    }

    // Optimize
    println("\n\nOptimizing drops...");
    checker.optimize_drops();
    checker.print_drop_points();

    println("\n✅ Mobile-aware drop checking completed!");
}

/// Mobile-aware drop summary
impl DropChecker {
    open fn mobile_drop_summary(&self) -> String {
        format("📱 Mobile Drop Status:
                 Battery: {:.1}%
                 Thermal: {}
                 Platform: {}
                 Mobile Resources: {}
                 Deferred Drops: {}
                 Mobile Violations: {}
                 Active Permissions: {}",
                self.device_state.battery_level * 100.0,
                self.device_state.thermal_state,
                self.device_state.platform,
                self.mobile_resource_registry.len(),
                self.deferred_drop_queue.len(),
                self.mobile_violations.len(),
                self.device_state.active_permissions.len())
    }
}

