    }

    lines.join("\n")
}

/// Print all drop points for debugging
open fn print_drop_points(&self) {
    println("\n╔═══════════════════════════════════════════════════════════════╗");
    println("║                    DROP POINTS ANALYSIS                       ║");
    println("╚═══════════════════════════════════════════════════════════════╝\n");

    check self.drop_points.is_empty() {
        println("✓ No drops needed (all Copy types or optimized away)");
        yield;
    }

    var sorted_drops = self.drop_points.clone();
    sorted_drops.sort_by_key(|d| d.line);

    each drop in sorted_drops {
        let deps = check drop.depends_on.is_empty() {
            String::new()
        } else {
            format(", depends on: {:?}", drop.depends_on)
        };
        let cond = check drop.is_conditional { " [conditional]" } else { "" };
        println("  Line {}: Drop {} ({:?}){}{}", drop.line, drop.var_name, drop.strategy, deps, cond);
    }

    println("\n✓ Total drop points: {}", self.drop_points.len());
}

// Mobile helper functions
open fn check_mobile_permission(permission: &str) -> bool {
    // In real implementation, this would check iOS/Android permission status
    match permission {
        "camera" | "location" | "microphone" => true, // Mock: assume granted
        _ => false,
    }
}

