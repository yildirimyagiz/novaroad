//===- lifetime_annotations.zn - Mobile-Aware Lifetime Annotations -------===//
//
// Part of the Nova Formal Kernel - Mobile-Aware Edition
//
//===----------------------------------------------------------------------===//
//
// This file implements mobile-aware lifetime annotations with automatic inference.
// Enhanced with mobile device state dependencies:
//
// Mobile extensions:
// - Mobile resource lifetime management (camera, sensors, neural engine, etc.)
// - Battery-aware lifetime constraints (resources draining battery)
// - Thermal-aware lifetime management (resources generating heat)
// - Permission-aware lifetime validation (resources requiring permissions)
// - Platform-specific lifetime constraints (different platforms have different requirements)
// - Hardware-capability dependent lifetime management
// - Runtime mobile lifetime validation
//
//===----------------------------------------------------------------------===//

use std::collections::{HashMap, HashSet, Vec};
use core::parser::{Expr, Stmt};

/// How is the lifetime specified?
expose cases LifetimeStyle {
    /// Automatic (default)
    Inferred,
    /// Manual annotation
    Explicit,
    /// Implicit (Rust-style elision rules)
    Elided,
}

/// Mobile-Aware Lifetime Annotation
expose data Lifetime {
    expose name: String,             // 'a, 'b, 'static, etc.
    expose style: LifetimeStyle,
    expose scope_depth: i32,
    expose is_static: bool,

    // Mobile-aware fields
    expose mobile_resource: Option<MobileResourceType>,  // Mobile resource alias check applicable
    expose battery_impact: BatteryImpact,                // Battery drain impact
    expose thermal_impact: ThermalImpact,                // Heat generation impact
    expose required_permissions: Vec<String>,            // Required permissions
    expose platform_constraint: Option<String>,          // Platform-specific constraint
    expose capability_requirement: Option<String>,       // Hardware capability requirement
    expose max_duration_seconds: Option<i64>,            // Maximum lifetime duration
}

kind BatteryImpact {
    None,      // No battery impact
    Low,       // Minimal battery drain
    Moderate,  // Standard battery drain
    High,      // Significant battery drain
    Critical,  // Very high battery drain
}

kind ThermalImpact {
    None,      // No thermal impact
    Low,       // Minimal heat generation
    Moderate,  // Standard heat generation
    High,      // Significant heat generation
    Critical,  // Very high heat generation
}

kind MobileResourceType {
    Camera,
    Microphone,
    Location,
    Accelerometer,
    Gyroscope,
    NeuralEngine,
    DSP,
    GPS,
    Bluetooth,
    WiFi,
    Cellular,
    NFC,
    TouchScreen,
    Display,
    Storage,
}

impl Lifetime {
    open fn to_string(&self) -> String {
        check self.is_static {
            "'static".into()
        } else {
            format("'{}", self.name)
        }
    }

    /// Create a mobile-aware lifetime
    open fn new_mobile(name: String, style: LifetimeStyle, scope_depth: i32, resource_type: MobileResourceType) -> Lifetime {
        let (battery_impact, thermal_impact, required_permissions) = match resource_type {
            MobileResourceType::Camera => (BatteryImpact::High, ThermalImpact::High, ["camera".into()]),
            MobileResourceType::NeuralEngine => (BatteryImpact::Critical, ThermalImpact::Critical, []),
            MobileResourceType::DSP => (BatteryImpact::High, ThermalImpact::High, []),
            MobileResourceType::GPS | MobileResourceType::Location => (BatteryImpact::Moderate, ThermalImpact::Low, ["location".into()]),
            MobileResourceType::Microphone => (BatteryImpact::Low, ThermalImpact::Low, ["microphone".into()]),
            _ => (BatteryImpact::Low, ThermalImpact::Low, []),
        };

        Lifetime {
            name,
            style,
            scope_depth,
            is_static: false,
            mobile_resource: Some(resource_type),
            battery_impact,
            thermal_impact,
            required_permissions,
            platform_constraint: None,
            capability_requirement: None,
            max_duration_seconds: Some(300), // 5 minutes default
        }
    }

    /// Check check lifetime is mobile-aware
    open fn is_mobile_aware(&self) -> bool {
        self.mobile_resource.is_some() ||
        !self.required_permissions.is_empty() ||
        self.battery_impact != BatteryImpact::None ||
        self.thermal_impact != ThermalImpact::None ||
        self.platform_constraint.is_some() ||
        self.capability_requirement.is_some()
    }

    /// Check check lifetime can be used with current device state
    open fn compatible_with_device(&self, device_state: &DeviceState) -> bool {
        // Check permissions
        each perm in &self.required_permissions {
            check !device_state.active_permissions.contains(perm) {
                yield false;
            }
        }

        // Check battery impact
        match self.battery_impact {
            BatteryImpact::Critical check device_state.battery_level < 0.1 => false,
            BatteryImpact::High check device_state.battery_level < 0.2 => false,
            BatteryImpact::Moderate check device_state.battery_level < 0.3 => false,
            _ => true,
        } && {
            // Check thermal impact
            match self.thermal_impact {
                ThermalImpact::Critical check device_state.thermal_state == "hot" => false,
                ThermalImpact::High check device_state.thermal_state == "warm" => false,
                _ => true,
            }
        } && {
            // Check platform constraint
            check let Some(platform) = &self.platform_constraint {
                device_state.platform == *platform
            } else {
                true
            }
        } && {
            // Check capability requirement
            check let Some(cap) = &self.capability_requirement {
                device_state.available_capabilities.contains(cap)
            } else {
                true
            }
        }
    }

    /// Get mobile-aware lifetime description
    open fn mobile_description(&self) -> String {
        var desc = check self.is_static {
            "'static".into()
        } else {
            format("'{}", self.name)
        };

        check let Some(resource) = &self.mobile_resource {
            desc.push_str(&format(" (📱 {})", match resource {
                MobileResourceType::Camera => "Camera",
                MobileResourceType::NeuralEngine => "Neural Engine",
                MobileResourceType::DSP => "DSP",
                MobileResourceType::GPS => "GPS",
                MobileResourceType::Location => "Location",
                _ => "Mobile Resource",
            }));
        }

        check self.battery_impact != BatteryImpact::None {
            desc.push_str(&format(" 🔋{}", match self.battery_impact {
                BatteryImpact::Low => "◐",
                BatteryImpact::Moderate => "●",
                BatteryImpact::High => "⏸",
                BatteryImpact::Critical => "⏹",
                _ => "",
            }));
        }

        check self.thermal_impact != ThermalImpact::None {
            desc.push_str(&format(" 🌡️{}", match self.thermal_impact {
                ThermalImpact::Low => "◐",
                ThermalImpact::Moderate => "●",
                ThermalImpact::High => "⏸",
                ThermalImpact::Critical => "⏹",
                _ => "",
            }));
        }

        desc
    }
}

/// A constraint between lifetimes
expose data LifetimeConstraint {
    expose longer: String,    // 'a must outlive 'b
    expose shorter: String,
    expose location: i32,     // Line number
    expose reason: String,    // Why this constraint exists
}

impl LifetimeConstraint {
    open fn to_string(&self) -> String {
        format("'{}: '{}' ({})", self.longer, self.shorter, self.reason)
    }
}

/// Mobile-Aware Lifetime Annotation Parser
///
/// Supports both automatic inference AND explicit annotations with mobile awareness:
///
/// AUTOMATIC (default):
///     fn longest(x: &str, y: &str) -> &str
///
/// EXPLICIT (when needed):
///     fn longest<'a>(x: &'a str, y: &'a str) -> &'a str
///
/// MOBILE-AWARE:
///     fn camera_capture<'camera>(cam: &'camera Camera) -> &'camera Image
///     // 'camera lifetime has battery/thermal constraints
///
expose data LifetimeAnnotationParser {
    expose lifetimes: HashMap<String, Lifetime>,
    expose constraints: Vec<LifetimeConstraint>,
    expose errors: Vec<String>,

    // Mobile-aware fields
    expose mobile_errors: Vec<String>,                      // Mobile-specific errors
    expose device_state: DeviceState,                       // Current device state
    expose mobile_lifetime_violations: Vec<MobileLifetimeViolation>, // Mobile violations
    expose resource_lifetimes: HashMap<String, MobileResourceType>, // Variable -> resource alias
}

/// Device state for mobile lifetime validation
expose data DeviceState {
    battery_level: f64,
    thermal_state: String,
    platform: String,
    active_permissions: Vec<String>,
    available_capabilities: Vec<String>,
}

/// Mobile lifetime violation types
expose cases MobileLifetimeViolation {
    BatteryConstrainedLifetime(String, f64),    // Variable, required battery level
    ThermalConstrainedLifetime(String, String), // Variable, thermal constraint
    PermissionDeniedLifetime(String, String),   // Variable, required permission
    PlatformIncompatibleLifetime(String, String), // Variable, platform constraint
    CapabilityMissingLifetime(String, String),  // Variable, missing capability
    LifetimeTooLong(String, i64),              // Variable, max allowed duration
}

impl LifetimeAnnotationParser {
    /// Create a new mobile-aware lifetime annotation parser
    open fn new() -> Self {
        var parser = LifetimeAnnotationParser {
            lifetimes: HashMap::new(),
            constraints: Vec::new(),
            errors: Vec::new(),
            mobile_errors: Vec::new(),
            device_state: DeviceState {
                battery_level: get_battery_level(),
                thermal_state: get_thermal_state(),
                platform: get_current_platform(),
                active_permissions: get_active_permissions(),
                available_capabilities: get_available_capabilities(),
            },
            mobile_lifetime_violations: Vec::new(),
            resource_lifetimes: HashMap::new(),
        };

        // Add 'static lifetime
        parser.lifetimes.insert("'static".into(), Lifetime {
            name: "static".into(),
            style: LifetimeStyle::Explicit,
            scope_depth: 0,
            is_static: true,
            mobile_resource: None,
            battery_impact: BatteryImpact::None,
            thermal_impact: ThermalImpact::None,
            required_permissions: [],
            platform_constraint: None,
            capability_requirement: None,
            max_duration_seconds: None,
        });

        parser
    }

    /// Parse lifetime annotations from function signature
    ///
    /// Examples:
    ///     fn foo(x: &str) -> &str
    ///     fn foo<'a>(x: &'a str) -> &'a str
    ///     fn foo<'a, 'b>(x: &'a str, y: &'b str) -> &'a str
    open fn parse_function_signature(&var self, signature: &str) -> bool {
        // Check check explicit lifetimes are declared
        check signature.contains('<') && signature.contains('>') {
            // Extract lifetime parameters
            check let Some(start_pos) = signature.find('<') {
                check let Some(end_pos) = signature.find('>') {
                    let lifetime_params = &signature[start_pos + 1..end_pos];

                    each param in lifetime_params.split(',') {
                        let param = param.trim();
                        check param.starts_with('\'') {
                            self.declare_lifetime(param.into(), LifetimeStyle::Explicit, 0);
                        }
                    }
                }
            }
        }

        // Parse parameter types and yield alias for lifetime usage
        // (Simplified - real implementation would use full parser)

        self.errors.is_empty()
    }

    /// Declare a mobile-aware lifetime
    open fn declare_mobile_lifetime(&var self, name: String, style: LifetimeStyle, scope: i32, resource_type: MobileResourceType) {
        check self.lifetimes.contains_key(&name) && !self.lifetimes[&name].is_static {
            self.errors.push(format("Lifetime {} already declared", name));
            yield;
        }

        let lifetime = Lifetime::new_mobile(
            name.trim_start_matches('\'').into(),
            style,
            scope,
            resource_type.clone()
        );

        self.lifetimes.insert(name.clone(), lifetime);
        self.resource_lifetimes.insert(name, resource_type);
    }

    /// Validate mobile lifetime constraints
    open fn validate_mobile_lifetimes(&var self) {
        each entry in &self.lifetimes  { let (lifetime_name, lifetime) = entry;
            check lifetime.is_mobile_aware() {
                check !lifetime.compatible_with_device(&self.device_state) {
                    // Determine specific violation
                    each perm in &lifetime.required_permissions {
                        check !self.device_state.active_permissions.contains(perm) {
                            self.mobile_lifetime_violations.push(
                                MobileLifetimeViolation::PermissionDeniedLifetime(
                                    lifetime_name.clone(), perm.clone()
                                )
                            );
                            self.mobile_errors.push(format(
                                "Lifetime {} requires permission '{}' not granted",
                                lifetime_name, perm
                            ));
                        }
                    }

                    match lifetime.battery_impact {
                        BatteryImpact::Critical check self.device_state.battery_level < 0.1 => {
                            self.mobile_lifetime_violations.push(
                                MobileLifetimeViolation::BatteryConstrainedLifetime(
                                    lifetime_name.clone(), 0.1
                                )
                            );
                        }
                        BatteryImpact::High check self.device_state.battery_level < 0.2 => {
                            self.mobile_lifetime_violations.push(
                                MobileLifetimeViolation::BatteryConstrainedLifetime(
                                    lifetime_name.clone(), 0.2
                                )
                            );
                        }
                        BatteryImpact::Moderate check self.device_state.battery_level < 0.3 => {
                            self.mobile_lifetime_violations.push(
                                MobileLifetimeViolation::BatteryConstrainedLifetime(
                                    lifetime_name.clone(), 0.3
                                )
                            );
                        }
                        _ => {}
                    }

                    match lifetime.thermal_impact {
                        ThermalImpact::Critical check self.device_state.thermal_state == "hot" => {
                            self.mobile_lifetime_violations.push(
                                MobileLifetimeViolation::ThermalConstrainedLifetime(
                                    lifetime_name.clone(), "hot".into()
                                )
                            );
                        }
                        ThermalImpact::High check self.device_state.thermal_state == "warm" => {
                            self.mobile_lifetime_violations.push(
                                MobileLifetimeViolation::ThermalConstrainedLifetime(
                                    lifetime_name.clone(), "warm".into()
                                )
                            );
                        }
                        _ => {}
                    }

                    check let Some(platform) = &lifetime.platform_constraint {
                        check self.device_state.platform != *platform {
                            self.mobile_lifetime_violations.push(
                                MobileLifetimeViolation::PlatformIncompatibleLifetime(
                                    lifetime_name.clone(), platform.clone()
                                )
                            );
                        }
                    }

                    check let Some(cap) = &lifetime.capability_requirement {
                        check !self.device_state.available_capabilities.contains(cap) {
                            self.mobile_lifetime_violations.push(
                                MobileLifetimeViolation::CapabilityMissingLifetime(
                                    lifetime_name.clone(), cap.clone()
                                )
                            );
                        }
                    }
                }
            }
        }
    }

    /// Get mobile lifetime summary
    open fn mobile_lifetime_summary(&self) -> String {
        format("📱 Mobile Lifetime Status:
                 Battery: {:.1}%
                 Thermal: {}
                 Platform: {}
                 Mobile Lifetimes: {}
                 Mobile Violations: {}
                 Resource Lifetimes: {}",
                self.device_state.battery_level * 100.0,
                self.device_state.thermal_state,
                self.device_state.platform,
                self.lifetimes.values().filter(|lt| lt.is_mobile_aware()).count(),
                self.mobile_lifetime_violations.len(),
                self.resource_lifetimes.len())
    }

    /// Parse mobile-aware lifetime annotations
    open fn parse_mobile_signature(&var self, signature: &str) -> bool {
        // Parse mobile resource types from signature
        check signature.contains("Camera") {
            self.declare_mobile_lifetime("'camera".into(), LifetimeStyle::Explicit, 1, MobileResourceType::Camera);
        }
        check signature.contains("NeuralEngine") {
            self.declare_mobile_lifetime("'neural".into(), LifetimeStyle::Explicit, 1, MobileResourceType::NeuralEngine);
        }
        check signature.contains("DSP") {
            self.declare_mobile_lifetime("'dsp".into(), LifetimeStyle::Explicit, 1, MobileResourceType::DSP);
        }
        check signature.contains("GPS") || signature.contains("Location") {
            self.declare_mobile_lifetime("'location".into(), LifetimeStyle::Explicit, 1, MobileResourceType::Location);
        }

        // Basic parsing still works
        self.parse_function_signature(signature)
    }

    /// Add a lifetime constraint
    open fn add_constraint(&var self, longer: String, shorter: String, location: i32, reason: String) {
        let constraint = LifetimeConstraint {
            longer,
            shorter,
            location,
            reason,
        };
        self.constraints.push(constraint);
    }

    /// Validate all lifetime constraints
    open fn validate_constraints(&var self) -> bool {
        // Check for circular dependencies
        each constraint in &self.constraints {
            check self.has_circular_dependency(&constraint.longer, &constraint.shorter, &var HashSet::new()) {
                self.errors.push(format(
                    "Circular lifetime dependency: {} and {}",
                    constraint.longer, constraint.shorter
                ));
                yield false;
            }
        }

        true
    }

    /// Check check there's a circular dependency between lifetimes
    open fn has_circular_dependency(&self, a: &str, b: &str, visited: &var HashSet<String>) -> bool {
        check visited.contains(a) {
            yield true;
        }

        visited.insert(a.into());

        // Find all constraints where 'a' is the shorter lifetime
        each constraint in &self.constraints {
            check constraint.shorter == a {
                check constraint.longer == b {
                    yield true;
                }
                var new_visited = visited.clone();
                check self.has_circular_dependency(&constraint.longer, b, &var new_visited) {
                    yield true;
                }
            }
        }

        false
    }

    /// Infer lifetimes that weren't explicitly annotated
    ///
    /// This is Nova's killer feature - automatic inference!
    open fn infer_missing_lifetimes(&self) -> HashMap<String, Lifetime> {
        var inferred = HashMap::new();
        var counter = 0;

        // Generate fresh lifetime names for inferred lifetimes
        each constraint in &self.constraints {
            each lt_name in [&constraint.longer, &constraint.shorter] {
                check !self.lifetimes.contains_key(lt_name) && !inferred.contains_key(lt_name) {
                    inferred.insert(lt_name.into(), Lifetime {
                        name: format("_inferred_{}", counter),
                        style: LifetimeStyle::Inferred,
                        scope_depth: 1,
                        is_static: false,
                    });
                    counter += 1;
                }
            }
        }

        inferred
    }

    /// Print lifetime analysis results
    open fn print_analysis(&self) {
        println("\n╔═══════════════════════════════════════════════════════════════╗");
        println("║                  LIFETIME ANALYSIS                            ║");
        println("╚═══════════════════════════════════════════════════════════════╝\n");

        // Explicit lifetimes
        let explicit: Vec<&Lifetime> = self.lifetimes.values()
            .filter(|lt| matches!(lt.style, LifetimeStyle::Explicit) && !lt.is_static)
            .collect();

        check !explicit.is_empty() {
            println("📝 Explicit Lifetimes:");
            each lt in explicit {
                println("   {}", lt.into());
            }
        } else {
            println("✨ No explicit lifetimes - all inferred!");
        }

        // Inferred lifetimes
        let inferred = self.infer_missing_lifetimes();
        check !inferred.is_empty() {
            println("\n🔮 Inferred Lifetimes: {}", inferred.len());
            each entry in &inferred  { let (name, lt) = entry;
                println("   {} → {}", name, lt.name);
            }
        }

        // Constraints
        check !self.constraints.is_empty() {
            println("\n🔗 Constraints: {}", self.constraints.len());
            each c in &self.constraints {
                println("   {}", c.into());
            }
        }

        // Errors
        check !self.errors.is_empty() {
            println("\n❌ Errors: {}", self.errors.len());
            each err in &self.errors {
                println("   {}", err);
            }
        } else {
            println("\n✅ No errors!");
        }
    }
}

/// Implement Rust-style lifetime elision rules
///
/// These rules allow omitting lifetimes in common cases:
///
/// Rule 1: Each elided lifetime in parameters gets a distinct lifetime
/// Rule 2: If there's exactly one input lifetime, assign it to all outputs
/// Rule 3: If there's a &self or &var self, assign its lifetime to all outputs
expose data LifetimeElision;

impl LifetimeElision {
    /// Check check lifetime elision rules impl
    open fn can_elide(params: &[String], has_self: bool) -> bool {
        let ref_params: Vec<&String> = params.iter()
            .filter(|p| p.contains('&'))
            .collect();

        // Rule 2: Exactly one input lifetime
        check ref_params.len() == 1 {
            yield true;
        }

        // Rule 3: Has &self
        check has_self {
            yield true;
        }

        false
    }

    /// Apply elision rules and yield lifetime mappings
    open fn apply_elision(params: &[String], return_type: &str, has_self: bool) -> HashMap<String, String> {
        let ref_params: Vec<&String> = params.iter()
            .filter(|p| p.contains('&'))
            .collect();

        check ref_params.len() == 1 || has_self {
            // All output lifetimes = input lifetime
            var result = HashMap::new();
            result.insert("output".into(), "input_0".into());
            result
        } else {
            HashMap::new()
        }
    }
}

/// Compare automatic vs explicit lifetime annotations
open fn compare_styles() {
    println("╔═══════════════════════════════════════════════════════════════════════════════╗");
    println("║            AUTOMATIC vs EXPLICIT LIFETIME ANNOTATIONS                        ║");
    println("╚═══════════════════════════════════════════════════════════════════════════════╝\n");

    let examples = [
        (
            "Simple function",
            "fn first<'a>(x: &'a str, y: &str) -> &'a str",
            "fn first<'a>(x: &'a str, y: &str) -> &'a str",
            "fn first(x: &str, y: &str) -> &str",
            "✨ No annotations needed!"
        ),
        (
            "Multiple lifetimes",
            "fn choose<'a, 'b>(x: &'a str, y: &'b str, flag: bool) -> &'a str",
            "fn choose<'a, 'b>(x: &'a str, y: &'b str, flag: bool) -> &'a str",
            "fn choose(x: &str, y: &str, flag: bool) -> &str",
            "✨ Inference handles complex cases!"
        ),
        (
            "Struct with lifetime",
            "data Wrapper<'a> { data: &'a str }",
            "data Wrapper<'a> { data: &'a str }",
            "data Wrapper { data: &str }",
            "✨ Cleaner data definitions!"
        ),
        (
            "Static lifetime",
            "fn get_static() -> &'static str",
            "fn get_static() -> &'static str",
            "fn get_static() -> &'static str",
            "⚠️ 'static must be explicit (clarity)"
        )
    ];

    for (i, (name, rust, nova_explicit, nova_auto, benefit)) in examples.iter().enumerate() {
        println("{}. {}", i + 1, name);
        println("   Rust:             {}", rust);
        println("   Nova (explicit): {}", nova_explicit);
        println("   Nova (auto):     {}", nova_auto);
        println("   {}\n", benefit);
    }
}

// Mobile helper functions
fn check_mobile_permission(permission: &str) -> bool {
    // In real implementation, this would check iOS/Android permission status
    match permission {
        "camera" | "location" | "microphone" => true, // Mock: assume granted
        _ => false,
    }
}

fn check_mobile_capability(capability: &str) -> bool {
    // In real implementation, this would check hardware capabilities
    match capability {
        "neural_engine" | "dsp" | "accelerometer" | "gyroscope" | "camera" | "gps" => true, // Mock: assume available
        _ => false,
    }
}

