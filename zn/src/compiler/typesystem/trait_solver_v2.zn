    println("🔧 Nova Mobile-Aware Supreme Trait Solver v2 - Active");
    println("==========================================================");

    // Create mobile-aware rules solver
    var solver = TraitSolver::new();

    // Test basic rules registration
    println("✅ Basic rules solver initialized");

    // Test mobile-aware rules registration
    println("\n🧪 Testing Mobile-Aware Trait Registration:");

    // Register mobile-aware Display rules
    let display_trait = Trait {
        name: "Display".into(),
        type_params: [],
        supertraits: [],
        associated_types: HashMap::new(),
        methods: [
            TraitMethod {
                name: "to_string".into(),
                params: [],
                return_type: "String".into(),
                default_impl: None,
            }
        ],
        mobile_resource_requirements: [], // No specific mobile resources
        required_permissions: [], // No special permissions
        battery_impact: BatteryImpact::Low,
        thermal_impact: ThermalImpact::Low,
        platform_constraints: [],
        capability_requirements: [],
        device_state_requirements: None,
    };

    solver.register_trait(display_trait);
    println("✅ Registered mobile-aware Display rules");

    // Test mobile-aware implementations
    println("\n🧪 Testing Mobile-Aware Trait Implementations:");

    // Generic implementation
    let generic_impl = TraitImpl {
        trait_name: "Display".into(),
        type_name: "T".into(),
        type_params: ["T".into()],
        where_clauses: [],
        methods: HashMap::new(),
        specialization_priority: 0,
        device_state: DeviceState {
            battery_level: 0.8,
            thermal_state: "cool".into(),
            platform: "iOS".into(),
            active_permissions: ["camera".into()],
            available_capabilities: ["camera".into()],
        },
        mobile_compatibility_score: 50,
        platform_specific: false,
        battery_efficiency: 0.7,
        thermal_efficiency: 0.7,
        hardware_accelerated: false,
    };

    // Specialized i32 implementation with hardware acceleration
    let i32_impl = TraitImpl {
        trait_name: "Display".into(),
        type_name: "i32".into(),
        type_params: [],
        where_clauses: [],
        methods: HashMap::new(),
        specialization_priority: 10,
        device_state: DeviceState {
            battery_level: 0.9,
            thermal_state: "cool".into(),
            platform: "iOS".into(),
            active_permissions: ["camera".into()],
            available_capabilities: ["camera".into(), "neural_engine".into()],
        },
        mobile_compatibility_score: 80,
        platform_specific: false,
        battery_efficiency: 0.9,
        thermal_efficiency: 0.9,
        hardware_accelerated: true,
    };

    solver.register_impl(generic_impl);
    solver.register_impl(i32_impl);

    println("✅ Registered mobile-aware rules implementations");

    // Test mobile-aware rules resolution
    println("\n🧪 Testing Mobile-Aware Trait Resolution:");

    check let Some(idx) = solver.resolve_trait_mobile("Display", "i32") {
        println("✅ Mobile-aware resolution: Display for i32 -> implementation #{}", idx);

        let selected_impl = &solver.impls[idx];
        println("   Selected implementation details:");
        println("   - Battery efficiency: {:.1}%", selected_impl.battery_efficiency * 100.0);
        println("   - Thermal efficiency: {:.1}%", selected_impl.thermal_efficiency * 100.0);
        println("   - Hardware accelerated: {}", selected_impl.hardware_accelerated);
        println("   - Mobile compatibility score: {}", selected_impl.calculate_mobile_score());
    }

    // Display mobile rules summary
    println("\n{}", solver.mobile_trait_summary());

    println("\n🎯 Mobile-Aware Trait Solver Key Features:");
    println("=========================================");
    println("✅ Mobile-specific rules bounds (permissions, capabilities)");
    println("✅ Device-aware rules resolution (different implementations based on device state)");
    println("✅ Battery/thermal-aware rules specialization");
    println("✅ Platform-specific rules implementations");
    println("✅ Hardware-capability dependent traits");
    println("✅ Runtime mobile rules validation");
