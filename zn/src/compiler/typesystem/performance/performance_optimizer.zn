            compilation_cache: HashMap::new(),
            hot_path_detector: HotPathDetector::new(config.hot_path_threshold),
            optimization_level: config.optimization_level,
            target_architecture: config.target_arch
        }
    }
    
    fn compile_hot_paths(&mut self, program: &CompiledProgram) -> Result<CompiledProgram, OptimizationError> {
        println("🚀 Selective JIT compilation başlatılıyor...");
        
        // Hot path'leri tespit et
        let hot_functions = self.hot_path_detector.detect_hot_paths(program)?;
        
        // Sadece hot path'leri JIT derle
        let jit_compiled = self.compile_selected_functions(program, &hot_functions)?;
        
        println("✅ Selective JIT compilation tamamlandı");
        Ok(jit_compiled)
    }
    
