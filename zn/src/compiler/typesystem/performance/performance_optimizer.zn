expose struct IncrementalCache;
expose struct DependencyGraph;
expose struct TypeInferenceCache;
expose struct TypeCache;
expose struct MethodCache;
expose struct CompilationCache;
expose struct MemoryPool;
expose struct ThreadPool;
expose struct TaskScheduler;
expose struct WorkStealingQueue;
expose struct InlineCache;
expose struct Module;
expose struct TypedAST;
expose struct CompiledProgram;
expose type TypeId = u64;

