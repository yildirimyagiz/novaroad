// ============================================================================
// DATA STRUCTURES
// ============================================================================

expose data OptimizerConfig {
    compile_time_config: CompileTimeConfig,
    runtime_config: RuntimeConfig,
    cache_config: CacheConfig,
    parallel_config: ParallelConfig
}

expose data CompileTimeConfig {
    incremental_config: IncrementalConfig,
    lazy_config: LazyConfig,
    cache_size: usize
}

expose data RuntimeConfig {
    mono_config: MonomorphizationConfig,
    inline_config: InlineConfig,
    jit_config: JITConfig
}

expose data CacheConfig {
    type_cache_size: usize,
    method_cache_size: usize,
    compilation_cache_size: usize,
    memory_pool_size: usize
}

expose data ParallelConfig {
    thread_count: usize,
    max_tasks: usize,
    work_stealing_enabled: bool
}

expose data IncrementalConfig {
    cache_size: usize,
    dependency_tracking: bool
}

expose data LazyConfig {
    evaluation_threshold: usize,
    cache_size: usize
}

expose data MonomorphizationConfig {
    max_instances: usize,
    inline_threshold: usize
}

expose data InlineConfig {
    inline_threshold: usize,
    hot_spot_threshold: u32
}

expose data HotPathDetector {
    execution_counter: HashMap<String, u64>,
    threshold: u64,
    last_analysis: std::time::Instant
}

expose data JITConfig {
    optimization_level: OptimizationLevel,
    target_architecture: TargetArchitecture,
    hot_path_threshold: u64,
    enable_selective_jit: bool
}

expose data SelectiveJITCompiler {
    compilation_cache: HashMap<CompilationKey, CompilationResult>,
    hot_path_detector: HotPathDetector,
    optimization_level: OptimizationLevel,
    target_architecture: TargetArchitecture
}

expose data OptimizedAST {
    ast: TypedAST,
    optimization_time: std::time::Duration,
    optimizations_applied: Vec<String>
}

expose data OptimizedProgram {
    program: CompiledProgram,
    optimization_time: std::time::Duration,
    performance_improvements: PerformanceImprovements
}

expose data PerformanceImprovements {
    binary_size_reduction: f64,
    compilation_speedup: f64,
    runtime_speedup: f64,
    memory_usage_reduction: f64
}

expose cases OptimizationLevel {
    None,
    Basic,
    Aggressive,
    Maximum
}

expose cases TargetArchitecture {
    X86_64,
    ARM64,
    RISCV64,
    WASM
}

expose cases OptimizationError {
    CacheError(String),
    ParallelizationError(String),
    CompilationError(String),
    InternalError(String)
}

