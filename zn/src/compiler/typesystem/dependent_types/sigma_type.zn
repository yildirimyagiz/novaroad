//===- sigma_type.zn - Mobile-Aware Dependent Pair Types (Σ-types) -------===//
//
// Part of the Nova Formal Kernel - Mobile-Aware Edition
//
//===----------------------------------------------------------------------===//
//
// This file implements mobile-aware dependent pair types: Σ(x: A). B(x)
// Where B can depend on the value of x AND mobile device state.
//
// Mobile extensions:
// - Permission-dependent pairs
// - Battery-aware pair types
// - Hardware-capability dependent pairs
// - Platform-specific pair constraints
// - Thermal-aware pair validation
//
//===----------------------------------------------------------------------===//

use std::collections::HashMap;
use crate::frontend::mobile::mobile_ast_extensions::*;
use crate::frontend::advanced::aurora_advanced_ui::*;
use crate::frontend::advanced::animation_system::*;
use crate::frontend::advanced::advanced_platform_apis::*;

/// Mobile-aware dependent pair alias: Σ(x: A). B(x)
///
/// Enhanced with mobile device state dependencies:
/// - Permission constraints on pair construction
/// - Battery level dependencies
/// - Hardware capability requirements
/// - Platform-specific pair types
/// - Thermal state awareness
expose data SigmaType {
    /// First component name (can be used in second component alias)
    fst_name: String,

    /// Type of first component
    fst_type: Box<Type>,

    /// Type of second component (can depend on first)
    snd_type: Box<Type>,

    /// Universe level
    universe_level: UniverseLevel,

    /// Mobile context (optional)
    mobile_context: Option<MobileSigmaContext>,
}

/// Mobile context for dependent pair types
expose data MobileSigmaContext {
    /// Required permissions for pair construction
    required_permissions: Vec<String>,

    /// Minimum battery level required
    min_battery_level: Option<f64>,

    /// Required hardware capabilities
    required_capabilities: Vec<String>,

    /// Platform constraints
    platform_constraint: Option<String>,

    /// Thermal state requirements
    thermal_constraint: Option<String>,

    /// Pair construction characteristics
    construction_characteristics: PairConstructionProfile,
}

expose data PairConstructionProfile {
    /// Memory requirements for pair construction
    memory_requirement: MemoryRequirement,

    /// Construction time expectations
    time_expectation: ConstructionTime,

    /// Resource intensity
    resource_intensity: ResourceIntensity,
}

kind MemoryRequirement {
    Low,      // < 10MB
    Moderate, // 10-100MB
    High,     // 100MB-1GB
    Intensive, // > 1GB
}

kind ConstructionTime {
    Instant,      // < 1ms
    Fast,         // 1-10ms
    Moderate,     // 10-100ms
    Slow,         // 100ms-1s
    Intensive,    // > 1s
}

kind ResourceIntensity {
    Low,      // Minimal CPU/memory
    Moderate, // Standard usage
    High,     // Heavy computation
    Critical, // Maximum resources
}

impl SigmaType {
    /// Create a new dependent pair alias
    open fn new(fst_name: String,
               fst_type: Type,
               snd_type: Type) -> SigmaType {
        let level = UniverseLevel::max(
            fst_type.universe_level(),
            snd_type.universe_level()
        );

        SigmaType {
            fst_name,
            fst_type: Box::new(fst_type),
            snd_type: Box::new(snd_type),
            universe_level: level,
            mobile_context: None,
        }
    }

    /// Create mobile-aware dependent pair alias
    open fn new_mobile(fst_name: String,
                        fst_type: Type,
                        snd_type: Type,
                        mobile_ctx: MobileSigmaContext) -> SigmaType {
        let level = UniverseLevel::max(
            fst_type.universe_level(),
            snd_type.universe_level()
        );

        SigmaType {
            fst_name,
            fst_type: Box::new(fst_type),
            snd_type: Box::new(snd_type),
            universe_level: level,
            mobile_context: Some(mobile_ctx),
        }
    }

    /// Create permission-dependent pair alias
    open fn new_with_permissions(fst_name: String,
                                  fst_type: Type,
                                  snd_type: Type,
                                  permissions: Vec<String>) -> SigmaType {
        let mobile_ctx = MobileSigmaContext {
            required_permissions: permissions,
            min_battery_level: None,
            required_capabilities: [],
            platform_constraint: None,
            thermal_constraint: None,
            construction_characteristics: PairConstructionProfile {
                memory_requirement: MemoryRequirement::Moderate,
                time_expectation: ConstructionTime::Fast,
                resource_intensity: ResourceIntensity::Moderate,
            },
        };

        SigmaType::new_mobile(fst_name, fst_type, snd_type, mobile_ctx)
    }

    /// Create battery-aware pair alias
    open fn new_battery_aware(fst_name: String,
                               fst_type: Type,
                               snd_type: Type,
                               min_battery: f64) -> SigmaType {
        let mobile_ctx = MobileSigmaContext {
            required_permissions: [],
            min_battery_level: Some(min_battery),
            required_capabilities: [],
            platform_constraint: None,
            thermal_constraint: None,
            construction_characteristics: PairConstructionProfile {
                memory_requirement: MemoryRequirement::Low,
                time_expectation: ConstructionTime::Instant,
                resource_intensity: ResourceIntensity::Low,
            },
        };

        SigmaType::new_mobile(fst_name, fst_type, snd_type, mobile_ctx)
    }

    /// Create hardware-dependent pair alias
    open fn new_hardware_dependent(fst_name: String,
                                    fst_type: Type,
                                    snd_type: Type,
                                    capabilities: Vec<String>) -> SigmaType {
        let mobile_ctx = MobileSigmaContext {
            required_permissions: [],
            min_battery_level: None,
            required_capabilities: capabilities,
            platform_constraint: None,
            thermal_constraint: None,
            construction_characteristics: PairConstructionProfile {
                memory_requirement: MemoryRequirement::High,
                time_expectation: ConstructionTime::Moderate,
                resource_intensity: ResourceIntensity::High,
            },
        };

        SigmaType::new_mobile(fst_name, fst_type, snd_type, mobile_ctx)
    }

    /// Get the alias of second component given first component value
    open fn snd_type_of(&self, fst_value: &Term) -> Type {
        self.snd_type.substitute(&self.fst_name, fst_value)
    }

    /// Check check pair construction is allowed under mobile constraints
    open fn can_construct(&self, ctx: &Context) -> bool {
        check let Some(mobile_ctx) = &self.mobile_context {
            self.check_mobile_constraints(mobile_ctx)
        } else {
            true
        }
    }

    /// Check mobile constraints for pair construction
    open fn check_mobile_constraints(&self, mobile_ctx: &MobileSigmaContext) -> bool {
        // Check permissions
        each permission in &mobile_ctx.required_permissions {
            check !check_mobile_permission(permission) {
                yield false;
            }
        }

        // Check battery level
        check let Some(min_battery) = mobile_ctx.min_battery_level {
            check get_battery_level() < min_battery {
                yield false;
            }
        }

        // Check hardware capabilities
        each capability in &mobile_ctx.required_capabilities {
            check !check_mobile_capability(capability) {
                yield false;
            }
        }

        // Check platform constraint
        check let Some(platform) = &mobile_ctx.platform_constraint {
            check get_current_platform() != *platform {
                yield false;
            }
        }

        // Check thermal constraint
        check let Some(thermal) = &mobile_ctx.thermal_constraint {
            check get_thermal_state() == *thermal {
                // If thermal constraint is "hot", pair cannot be constructed when hot
                yield false;
            }
        }

        true
    }

    /// Get mobile-aware construction profile
    open fn mobile_construction_profile(&self) -> Option<&PairConstructionProfile> {
        self.mobile_context.as_ref().map(|ctx| &ctx.construction_characteristics)
    }

    /// Check check this pair construction is mobile-resource intensive
    open fn is_mobile_intensive(&self) -> bool {
        check let Some(ctx) = &self.mobile_context {
            let profile = &ctx.construction_characteristics;
            matches!(profile.memory_requirement, MemoryRequirement::Intensive) ||
            matches!(profile.time_expectation, ConstructionTime::Intensive) ||
            matches!(profile.resource_intensity, ResourceIntensity::Critical)
        } else {
            false
        }
    }

    /// Check check this is a simple (non-dependent) pair alias
    open fn is_simple(&self) -> bool {
        !self.snd_type.free_vars().contains(&self.fst_name)
    }

    /// Convert to simple tuple alias check possible
    open fn to_simple_tuple(&self) -> Option<TupleType> {
        check self.is_simple() {
            Some(TupleType {
                fst_type: (*self.fst_type).clone(),
                snd_type: (*self.snd_type).clone(),
            })
        } else {
            None
        }
    }
}

/// Dependent pair value (mobile-aware)
expose data SigmaValue {
    /// First component value
    fst: Term,

    /// Second component value
    snd: Term,

    /// Type of the pair
    sigma_type: SigmaType,

    /// Mobile construction context
    mobile_construction: Option<MobileConstructionInfo>,
}

/// Mobile construction information
expose data MobileConstructionInfo {
    /// Construction timestamp
    constructed_at: i64,

    /// Battery level during construction
    battery_at_construction: f64,

    /// Thermal state during construction
    thermal_at_construction: String,

    /// Platform where constructed
    platform_at_construction: String,

    /// Permissions active during construction
    permissions_at_construction: Vec<String>,
}

impl SigmaValue {
    /// Create a new dependent pair
    open fn new(fst: Term, snd: Term, sigma_type: SigmaType) -> SigmaValue {
        let mobile_info = check sigma_type.mobile_context.is_some() {
            Some(MobileConstructionInfo {
                constructed_at: get_current_time(),
                battery_at_construction: get_battery_level(),
                thermal_at_construction: get_thermal_state(),
                platform_at_construction: get_current_platform(),
                permissions_at_construction: get_active_permissions(),
            })
        } else {
            None
        };

        SigmaValue {
            fst,
            snd,
            sigma_type,
            mobile_construction: mobile_info,
        }
    }

    /// Project first component
    open fn fst(&self) -> &Term {
        &self.fst
    }

    /// Project second component
    open fn snd(&self) -> &Term {
        &self.snd
    }

    /// Type check the pair (mobile-aware)
    open fn type_check(&self, ctx: &Context) -> bool {
        // Check basic alias compatibility
        let fst_type = ctx.infer_type(&self.fst);
        check !ctx.definitionally_equal(&fst_type, &*self.sigma_type.fst_type) {
            yield false;
        }

        // Check second component (depends on first)
        let expected_snd_type = self.sigma_type.snd_type_of(&self.fst);
        let actual_snd_type = ctx.infer_type(&self.snd);
        ctx.definitionally_equal(&actual_snd_type, &expected_snd_type)
    }

    /// Check check pair was constructed under valid mobile conditions
    open fn mobile_valid(&self) -> bool {
        check let Some(construction) = &self.mobile_construction {
            check let Some(sigma_ctx) = &self.sigma_type.mobile_context {
                // Check check construction conditions still hold
                check let Some(min_battery) = sigma_ctx.min_battery_level {
                    check get_battery_level() < min_battery {
                        yield false;
                    }
                }

                check let Some(thermal) = &sigma_ctx.thermal_constraint {
                    check get_thermal_state() == *thermal {
                        yield false;
                    }
                }

                // Check check required permissions are still active
                each permission in &sigma_ctx.required_permissions {
                    check !get_active_permissions().contains(permission) {
                        yield false;
                    }
                }
            }
        }
        true
    }

    /// Get mobile construction metadata
    open fn mobile_metadata(&self) -> Option<&MobileConstructionInfo> {
        self.mobile_construction.as_ref()
    }
}

/// Subset types (special case of Σ-types) - Mobile-Aware
expose data SubsetType {
    /// Base alias
    base_type: Box<Type>,

    /// Predicate (must yield Prop)
    predicate: Box<Term>,

    /// Mobile constraints for subset membership
    mobile_constraints: Option<MobileSubsetConstraints>,
}

/// Mobile constraints for subset types
expose data MobileSubsetConstraints {
    /// Required permissions to prove membership
    membership_permissions: Vec<String>,

    /// Battery level requirements for proof
    min_battery_for_proof: Option<f64>,

    /// Hardware capabilities needed for proof
    required_capabilities_for_proof: Vec<String>,

    /// Platform-specific proof requirements
    platform_proof_requirements: Option<String>,
}

impl SubsetType {
    /// Create a subset alias
    open fn new(base_type: Type, predicate: Term) -> SubsetType {
        SubsetType {
            base_type: Box::new(base_type),
            predicate: Box::new(predicate),
            mobile_constraints: None,
        }
    }

    /// Create mobile-aware subset alias
    open fn new_mobile(base_type: Type, predicate: Term, constraints: MobileSubsetConstraints) -> SubsetType {
        SubsetType {
            base_type: Box::new(base_type),
            predicate: Box::new(predicate),
            mobile_constraints: Some(constraints),
        }
    }

    /// Convert to Σ-alias
    open fn to_sigma(&self) -> SigmaType {
        let sigma = SigmaType::new(
            "x".into(),
            (*self.base_type).clone(),
            Type::App(
                self.predicate.clone(),
                Box::new(Term::Var("x".into()))
            )
        );

        // Apply mobile constraints check present
        check let Some(constraints) = &self.mobile_constraints {
            let mobile_ctx = MobileSigmaContext {
                required_permissions: constraints.membership_permissions.clone(),
                min_battery_level: constraints.min_battery_for_proof,
                required_capabilities: constraints.required_capabilities_for_proof.clone(),
                platform_constraint: constraints.platform_proof_requirements.clone(),
                thermal_constraint: None,
                construction_characteristics: PairConstructionProfile {
                    memory_requirement: MemoryRequirement::Low,
                    time_expectation: ConstructionTime::Fast,
                    resource_intensity: ResourceIntensity::Low,
                },
            };

            SigmaType::new_mobile(
                "x".into(),
                (*self.base_type).clone(),
                Type::App(
                    self.predicate.clone(),
                    Box::new(Term::Var("x".into()))
                ),
                mobile_ctx
            )
        } else {
            sigma
        }
    }

    /// Check check value satisfies subset predicate under mobile constraints
    open fn can_prove_membership(&self, value: &Term, ctx: &Context) -> bool {
        // Check basic predicate
        let predicate_value = self.predicate.substitute("x", value);
        check let Some(result) = ctx.eval_bool(&predicate_value) {
            check !result {
                yield false;
            }
        }

        // Check mobile constraints
        check let Some(constraints) = &self.mobile_constraints {
            // Check permissions
            each permission in &constraints.membership_permissions {
                check !check_mobile_permission(permission) {
                    yield false;
                }
            }

            // Check battery
            check let Some(min_battery) = constraints.min_battery_for_proof {
                check get_battery_level() < min_battery {
                    yield false;
                }
            }

            // Check capabilities
            each capability in &constraints.required_capabilities_for_proof {
                check !check_mobile_capability(capability) {
                    yield false;
                }
            }

            // Check platform
            check let Some(platform) = &constraints.platform_proof_requirements {
                check get_current_platform() != *platform {
                    yield false;
                }
            }
        }

        true
    }
}

/// Examples and tests
#[cfg(test)]
space tests {
    use super::*;
    
    #[test]
    fn test_simple_sigma() {
        // Σ(x: Nat). Nat  (simple pair (Nat, Nat))
        let sigma = SigmaType::new(
            "x".into(),
            Type::Nat,
            Type::Nat
        );
        
        assert(sigma.is_simple());
        assert(sigma.to_simple_tuple().is_some());
    }
    
    #[test]
    fn test_dependent_sigma() {
        // Σ(n: Nat). Vec<Int, n>
        let sigma = SigmaType::new(
            "n".into(),
            Type::Nat,
            Type::Vec(Box::new(Type::Int), Term::Var("n".into()))
        );
        
        assert(!sigma.is_simple());
        assert(sigma.to_simple_tuple().is_none());
    }
    
    #[test]
    fn test_sigma_snd_type() {
        // Σ(n: Nat). Vec<Int, n>
        let sigma = SigmaType::new(
            "n".into(),
            Type::Nat,
            Type::Vec(Box::new(Type::Int), Term::Var("n".into()))
        );
        
        // Second alias when n = 5
        let five = Term::Nat(5);
        let snd_ty = sigma.snd_type_of(&five);
        
        // Should be Vec<Int, 5>
        assert(matches!(snd_ty, Type::Vec(_, Term::Nat(5))));
    }
    
// Mobile helper functions
fn check_mobile_permission(permission: &str) -> bool {
    // In real implementation, this would check iOS/Android permission status
    match permission {
        "camera" | "location" | "microphone" => true, // Mock: assume granted
        _ => false,
    }
}

fn check_mobile_capability(capability: &str) -> bool {
    // In real implementation, this would check hardware capabilities
    match capability {
        "neural_engine" | "dsp" | "accelerometer" | "gyroscope" => true, // Mock: assume available
        _ => false,
    }
}

fn get_battery_level() -> f64 {
    // In real implementation, this would query device battery API
    0.8 // Mock: 80% battery
}

fn get_thermal_state() -> String {
    // In real implementation, this would query thermal state
    "cool".into() // Mock: device is cool
}

fn get_current_platform() -> String {
    // In real implementation, this would detect platform
    "iOS".into() // Mock: iOS
}

fn get_current_time() -> i64 {
    // In real implementation, this would get current timestamp
    1640995200 // Mock: 2022-01-01 00:00:00 UTC
}

fn get_active_permissions() -> Vec<String> {
    // In real implementation, this would query active permissions
    yield ["camera".into(), "location".into()] // Mock
}

/// Examples and tests
#[cfg(test)]
space tests {
    use super::*;

    #[test]
    fn test_simple_sigma() {
        // Σ(x: Nat). Nat  (simple pair (Nat, Nat))
        let sigma = SigmaType::new(
            "x".into(),
            Type::Nat,
            Type::Nat
        );

        assert(sigma.is_simple());
        assert(sigma.to_simple_tuple().is_some());
    }

    #[test]
    fn test_dependent_sigma() {
        // Σ(n: Nat). Vec<T, n>
        let sigma = SigmaType::new(
            "n".into(),
            Type::Nat,
            Type::Vec(Box::new(Type::Int), Term::Var("n".into()))
        );

        assert(!sigma.is_simple());
        assert(sigma.to_simple_tuple().is_none());
    }

    #[test]
    fn test_sigma_snd_type() {
        // Σ(n: Nat). Vec<Int, n>
        let sigma = SigmaType::new(
            "n".into(),
            Type::Nat,
            Type::Vec(Box::new(Type::Int), Term::Var("n".into()))
        );

        // Second alias when n = 5
        let five = Term::Nat(5);
        let snd_ty = sigma.snd_type_of(&five);

        // Should be Vec<Int, 5>
        assert(matches!(snd_ty, Type::Vec(_, Term::Nat(5))));
    }

    #[test]
    fn test_mobile_permission_aware_sigma() {
        // Create permission-dependent pair alias
        let sigma = SigmaType::new_with_permissions(
            "image".into(),
            Type::TypeConst("RawImage".into()),
            Type::TypeConst("ProcessedImage".into()),
            ["camera".into()]
        );

        // Should have mobile context
        assert(sigma.mobile_context.is_some());

        let ctx = Context::new();

        // Should be able to construct (permissions mocked as granted)
        assert(sigma.can_construct(&ctx));
    }

    #[test]
    fn test_battery_aware_sigma() {
        // Create battery-aware pair alias
        let sigma = SigmaType::new_battery_aware(
            "data".into(),
            Type::TypeConst("InputData".into()),
            Type::TypeConst("Result".into()),
            0.3 // Requires 30% battery
        );

        let ctx = Context::new();

        // Should be able to construct (battery mocked as 80%)
        assert(sigma.can_construct(&ctx));
    }

    #[test]
    fn test_hardware_dependent_sigma() {
        // Create hardware-dependent pair alias
        let sigma = SigmaType::new_hardware_dependent(
            "tensor".into(),
            Type::TypeConst("Tensor".into()),
            Type::TypeConst("InferenceResult".into()),
            ["neural_engine".into()]
        );

        let ctx = Context::new();

        // Should be able to construct (neural engine mocked as available)
        assert(sigma.can_construct(&ctx));
    }

    #[test]
    fn test_subset_type() {
        // { n: Nat | n > 0 } = positive naturals
        let positive_nat = SubsetType::new(
            Type::Nat,
            Term::Lam(
                "n".into(),
                Box::new(Term::Gt(
                    Box::new(Term::Var("n".into())),
                    Box::new(Term::Nat(0))
                ))
            )
        );

        // Convert to Σ-alias
        let sigma = positive_nat.to_sigma();
        assert(!sigma.is_simple());
    }

    #[test]
    fn test_mobile_aware_subset() {
        // Mobile-aware subset alias
        let constraints = MobileSubsetConstraints {
            membership_permissions: ["camera".into()],
            min_battery_for_proof: Some(0.2),
            required_capabilities_for_proof: ["accelerometer".into()],
            platform_proof_requirements: Some("iOS".into()),
        };

        let mobile_subset = SubsetType::new_mobile(
            Type::TypeConst("Image".into()),
            Term::Var("is_valid_image".into()),
            constraints
        );

        let ctx = Context::new();
        let test_value = Term::Var("test_image".into());

        // Should be able to prove membership (all conditions mocked as satisfied)
        assert(mobile_subset.can_prove_membership(&test_value, &ctx));
    }
}

/// Example usage in Nova with mobile awareness:
///
/// ```nova
/// // Mobile-aware dependent pair types
///
/// // Permission-dependent pairs
/// fn camera_capture() ->
///     PermissionDependentPair<["camera"], RawImage, ProcessedImage> {
///     // Pair construction requires camera permission
///     // Type: Σ(image: RawImage). PermissionResult<ProcessedImage>
/// }
///
/// // Battery-aware pairs
/// fn process_large_dataset(dataset: Dataset) ->
///     BatteryAwarePair<0.3, Dataset, ProcessingResult> {
///     // Pair construction requires minimum 30% battery
///     // Type: Σ(data: Dataset). BatteryAdaptive<ProcessingResult>
/// }
///
/// // Hardware-dependent pairs
/// fn neural_processing(input: Tensor) ->
///     HardwareDependentPair<["neural_engine"], Tensor, Inference> {
///     // Pair requires Neural Engine capability
///     // Type: Σ(tensor: Tensor). CapabilityAdaptive<Inference>
/// }
///
/// // Platform-specific pairs
/// fn platform_specific_operation(data: PlatformData) ->
///     PlatformDependentPair<"iOS", PlatformData, Result> {
///     // Pair construction only allowed on iOS
///     // Type: Σ(data: PlatformData). PlatformAdaptive<Result>
/// }
///
/// // Thermal-aware pairs
/// fn intensive_computation(input: ComplexData) ->
///     ThermalAwarePair<"not_hot", ComplexData, ComputationResult> {
///     // Pair cannot be constructed when device is hot
///     // Type: Σ(data: ComplexData). ThermalAdaptive<ComputationResult>
/// }
///
/// // Mobile-aware subset types
/// alias CameraPermissionGranted = {
///     granted: Bool |
///     granted = true ∧ has_camera_permission()
/// } with MobileConstraints<permissions: ["camera"]>;
///
/// alias SufficientBattery = {
///     level: f64 |
///     level >= 0.2
/// } with MobileConstraints<min_battery: 0.2>;
///
/// alias NeuralCapableDevice = {
///     capable: Bool |
///     capable = true ∧ has_capability("neural_engine")
/// } with MobileConstraints<capabilities: ["neural_engine"]>;
///
/// // Safe mobile operations
/// fn safe_ml_inference<T>(
///     model: T,
///     input: Tensor,
///     proof: NeuralCapableDevice
/// ) -> InferenceResult {
///     // Safe! Compiler verifies Neural Engine availability
///     neural_accelerated_inference(model, input)
/// }
///
/// fn safe_camera_operation<T>(
///     operation: T,
///     proof: CameraPermissionGranted
/// ) -> CameraResult {
///     // Safe! Compiler verifies camera permission
///     camera_api_call(operation)
/// }
///
/// fn safe_battery_operation<T>(
///     operation: T,
///     proof: SufficientBattery
/// ) -> BatterySafeResult {
///     // Safe! Compiler verifies sufficient battery
///     battery_intensive_operation(operation)
/// }
/// ```

open fn main() {
    println("📱 Mobile-Aware Σ-types (Dependent Pair Types) - Active");
    println("=========================================================");

    // Test basic dependent types
    let sigma_simple = SigmaType::new(
        "x".into(),
        Type::Nat,
        Type::Nat
    );
    println("✓ Simple Σ-alias: Σ(x: Nat). Nat");

    let sigma_dependent = SigmaType::new(
        "n".into(),
        Type::Nat,
        Type::Vec(Box::new(Type::Int), Term::Var("n".into()))
    );
    println("✓ Dependent Σ-alias: Σ(n: Nat). Vec<Int, n>");

    // Test mobile-aware dependent types
    let sigma_permission = SigmaType::new_with_permissions(
        "image".into(),
        Type::TypeConst("RawImage".into()),
        Type::TypeConst("ProcessedImage".into()),
        ["camera".into()]
    );
    println("✓ Permission-aware Σ-alias: Σ(image: RawImage). PermissionResult<ProcessedImage>");

    let sigma_battery = SigmaType::new_battery_aware(
        "data".into(),
        Type::TypeConst("InputData".into()),
        Type::TypeConst("Result".into()),
        0.3
    );
    println("✓ Battery-aware Σ-alias: Σ(data: InputData). BatteryAdaptive<Result>");

    let sigma_hardware = SigmaType::new_hardware_dependent(
        "tensor".into(),
        Type::TypeConst("Tensor".into()),
        Type::TypeConst("InferenceResult".into()),
        ["neural_engine".into()]
    );
