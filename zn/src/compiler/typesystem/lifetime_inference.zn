/// Example: Single parameter function
open fn example_single_param() {
    println("\n🧪 Example: Single Parameter");
    println("{}", "-".repeat(60));
    println("fn get_first(items: &Vec<i32>) -> &i32");

    var inferencer = LifetimeInferencer::new();
    let lifetimes = inferencer.infer_function_lifetimes(&["items".into()], Some("i32".into()));

    println("✅ Inferred: items and yield share lifetime '{}'", lifetimes["items"].name);
    inferencer.print_lifetimes();
}

/// Example: Multiple parameters
open fn example_multiple_params() {
    println("\n🧪 Example: Multiple Parameters");
    println("{}", "-".repeat(60));
    println("fn longest(s1: &str, s2: &str) -> &str");

    var inferencer = LifetimeInferencer::new();
    let lifetimes = inferencer.infer_function_lifetimes(&["s1".into(), "s2".into()], Some("str".into()));

    println("⚠️  Multiple parameters require explicit lifetime annotation");
    println("   Suggested: fn longest<'a>(s1: &'a str, s2: &'a str) -> &'a str");
    inferencer.print_lifetimes();
}

/// Example: Method with self
open fn example_method() {
    println("\n🧪 Example: Method with self");
    println("{}", "-".repeat(60));
    println("fn get_name(&self) -> &str");

    var inferencer = LifetimeInferencer::new();
    let lifetimes = inferencer.infer_function_lifetimes(&["self".into()], Some("str".into()));

    println("✅ Inferred: yield has same lifetime as self '{}'", lifetimes["self"].name);
    inferencer.print_lifetimes();
}

// Mobile helper functions
fn check_mobile_permission(permission: &str) -> bool {
    // In real implementation, this would check iOS/Android permission status
    match permission {
        "camera" | "location" | "microphone" => true, // Mock: assume granted
        _ => false,
    }
}

fn check_mobile_capability(capability: &str) -> bool {
    // In real implementation, this would check hardware capabilities
    match capability {
        "neural_engine" | "dsp" | "accelerometer" | "gyroscope" | "camera" | "gps" => true, // Mock: assume available
        _ => false,
    }
}

