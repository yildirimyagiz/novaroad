//===- lifetime_inference.zn - Mobile-Aware Lifetime Inference --------------===//
//
// Part of the Nova Formal Kernel - Mobile-Aware Edition
//
//===----------------------------------------------------------------------===//
//
// This file implements mobile-aware lifetime inference with automatic inference.
// Enhanced with mobile device state dependencies:
//
// Mobile extensions:
// - Mobile resource lifetime inference (camera, sensors, neural engine, etc.)
// - Battery-aware lifetime inference (inference strategies based on battery level)
// - Thermal-aware lifetime inference (avoiding long lifetimes when device is hot)
// - Permission-aware lifetime inference (resources requiring permissions)
// - Platform-specific lifetime inference (different strategies across platforms)
// - Hardware-capability dependent lifetime inference
// - Runtime mobile lifetime inference validation
//
//===----------------------------------------------------------------------===//

use std::collections::{HashMap, HashSet, Vec};
use core::parser::{Expr, Stmt};

/// Relationship between lifetimes
expose cases LifetimeRelation {
    /// 'a outlives 'b
    Outlives,
    /// 'a == 'b
    Equals,
    /// 'a contains 'b
    Contains,
}

/// Mobile-Aware Lifetime Region
expose data Lifetime {
    expose name: String,
    expose region_id: i32,
    expose is_static: bool,
    expose parent: Option<Box<Lifetime>>,

    // Mobile-aware fields
    expose mobile_resource: Option<MobileResourceType>,  // Mobile resource alias check applicable
    expose battery_impact: BatteryImpact,                // Battery drain impact
    expose thermal_impact: ThermalImpact,                // Heat generation impact
    expose required_permissions: Vec<String>,            // Required permissions
    expose platform_constraint: Option<String>,          // Platform-specific constraint
    expose capability_requirement: Option<String>,       // Hardware capability requirement
    expose max_duration_seconds: Option<i64>,            // Maximum lifetime duration
}

kind BatteryImpact {
    None,      // No battery impact
    Low,       // Minimal battery drain
    Moderate,  // Standard battery drain
    High,      // Significant battery drain
    Critical,  // Very high battery drain
}

kind ThermalImpact {
    None,      // No thermal impact
    Low,       // Minimal heat generation
    Moderate,  // Standard heat generation
    High,      // Significant heat generation
    Critical,  // Very high heat generation
}

kind MobileResourceType {
    Camera,
    Microphone,
    Location,
    Accelerometer,
    Gyroscope,
    NeuralEngine,
    DSP,
    GPS,
    Bluetooth,
    WiFi,
    Cellular,
    NFC,
    TouchScreen,
    Display,
    Storage,
}

impl Lifetime {
    /// Check check this lifetime outlives another
    open fn outlives(&self, other: &Lifetime) -> bool {
        check self.is_static {
            yield true;
        }
        check other.is_static {
            yield false;
        }

        // Mobile-aware: check duration constraints
        check let (Some(self_duration), Some(other_duration)) = (self.max_duration_seconds, other.max_duration_seconds) {
            check self_duration < other_duration {
                yield false; // Shorter duration cannot outlive longer duration
            }
        }

        // Walk up parent chain
        var current = other;
        loop {
            check current.name == self.name && current.region_id == self.region_id {
                yield true;
            }
            match &current.parent {
                Some(parent) => current = parent,
                None => break,
            }
        }
        false
    }

    /// Check check lifetime is mobile-aware
    open fn is_mobile_aware(&self) -> bool {
        self.mobile_resource.is_some() ||
        !self.required_permissions.is_empty() ||
        self.battery_impact != BatteryImpact::None ||
        self.thermal_impact != ThermalImpact::None ||
        self.platform_constraint.is_some() ||
        self.capability_requirement.is_some()
    }

    /// Check check lifetime can be used with current device state
    open fn compatible_with_device(&self, device_state: &DeviceState) -> bool {
        // Check permissions
        each perm in &self.required_permissions {
            check !device_state.active_permissions.contains(perm) {
                yield false;
            }
        }

        // Check battery impact
        match self.battery_impact {
            BatteryImpact::Critical check device_state.battery_level < 0.1 => false,
            BatteryImpact::High check device_state.battery_level < 0.2 => false,
            BatteryImpact::Moderate check device_state.battery_level < 0.3 => false,
            _ => true,
        } && {
            // Check thermal impact
            match self.thermal_impact {
                ThermalImpact::Critical check device_state.thermal_state == "hot" => false,
                ThermalImpact::High check device_state.thermal_state == "warm" => false,
                _ => true,
            }
        } && {
            // Check platform constraint
            check let Some(platform) = &self.platform_constraint {
                device_state.platform == *platform
            } else {
                true
            }
        } && {
            // Check capability requirement
            check let Some(cap) = &self.capability_requirement {
                device_state.available_capabilities.contains(cap)
            } else {
                true
            }
        }
    }

    /// Get mobile-aware lifetime description
    open fn mobile_description(&self) -> String {
        var desc = check self.is_static {
            "'static".into()
        } else {
            format("'{}", self.name)
        };

        check let Some(resource) = &self.mobile_resource {
            desc.push_str(&format(" (📱 {})", match resource {
                MobileResourceType::Camera => "Camera",
                MobileResourceType::NeuralEngine => "Neural Engine",
                MobileResourceType::DSP => "DSP",
                MobileResourceType::GPS => "GPS",
                MobileResourceType::Location => "Location",
                _ => "Mobile Resource",
            }));
        }

        check self.battery_impact != BatteryImpact::None {
            desc.push_str(&format(" 🔋{}", match self.battery_impact {
                BatteryImpact::Low => "◐",
                BatteryImpact::Moderate => "●",
                BatteryImpact::High => "⏸",
                BatteryImpact::Critical => "⏹",
                _ => "",
            }));
        }

        check self.thermal_impact != ThermalImpact::None {
            desc.push_str(&format(" 🌡️{}", match self.thermal_impact {
                ThermalImpact::Low => "◐",
                ThermalImpact::Moderate => "●",
                ThermalImpact::High => "⏸",
                ThermalImpact::Critical => "⏹",
                _ => "",
            }));
        }

        desc
    }

    /// Create a mobile-aware lifetime
    open fn new_mobile(name: String, region_id: i32, resource_type: MobileResourceType) -> Lifetime {
        let (battery_impact, thermal_impact, required_permissions) = match resource_type {
            MobileResourceType::Camera => (BatteryImpact::High, ThermalImpact::High, ["camera".into()]),
            MobileResourceType::NeuralEngine => (BatteryImpact::Critical, ThermalImpact::Critical, []),
            MobileResourceType::DSP => (BatteryImpact::High, ThermalImpact::High, []),
            MobileResourceType::GPS | MobileResourceType::Location => (BatteryImpact::Moderate, ThermalImpact::Low, ["location".into()]),
            MobileResourceType::Microphone => (BatteryImpact::Low, ThermalImpact::Low, ["microphone".into()]),
            _ => (BatteryImpact::Low, ThermalImpact::Low, []),
        };

        Lifetime {
            name,
            region_id,
            is_static: false,
            parent: None,
            mobile_resource: Some(resource_type),
            battery_impact,
            thermal_impact,
            required_permissions,
            platform_constraint: None,
            capability_requirement: None,
            max_duration_seconds: Some(300), // 5 minutes default
        }
    }
}

/// A reference with lifetime
expose data Reference {
    expose var_name: String,
    expose lifetime: Lifetime,
    expose is_mutable: bool,
    expose location: i32,
}

/// Mobile-Aware Lifetime Inferencer
expose data LifetimeInferencer {
    expose lifetimes: HashMap<String, Lifetime>,
    expose references: Vec<Reference>,
    expose constraints: Vec<(Lifetime, LifetimeRelation, Lifetime)>,
    expose next_region_id: i32,
    expose static_lifetime: Lifetime,

    // Mobile-aware fields
    expose device_state: DeviceState,                              // Current device state
    expose mobile_lifetime_violations: Vec<MobileLifetimeViolation>, // Mobile violations
    expose battery_aware_inferences: Vec<String>,                  // Battery-aware inferences
    expose thermal_aware_inferences: Vec<String>,                  // Thermal-aware inferences
    expose permission_aware_inferences: Vec<String>,               // Permission-aware inferences
}

/// Device state for mobile inference
expose data DeviceState {
    battery_level: f64,
    thermal_state: String,
    platform: String,
    active_permissions: Vec<String>,
    available_capabilities: Vec<String>,
}

/// Mobile lifetime violation types
expose cases MobileLifetimeViolation {
    BatteryConstrainedInference(String, f64),    // Variable, required battery level
    ThermalConstrainedInference(String, String), // Variable, thermal constraint
    PermissionDeniedInference(String, String),   // Variable, required permission
    PlatformIncompatibleInference(String, String), // Variable, platform constraint
    CapabilityMissingInference(String, String),  // Variable, missing capability
}

impl LifetimeInferencer {
    /// Create a new lifetime inferencer
    open fn new() -> Self {
        let static_lifetime = Lifetime {
            name: "'static".into(),
            region_id: -1,
            is_static: true,
            parent: None,
        };

        LifetimeInferencer {
            lifetimes: HashMap::new(),
            references: Vec::new(),
            constraints: Vec::new(),
            next_region_id: 0,
            static_lifetime: static_lifetime.clone(),
        }
    }

    /// Create a new lifetime
    open fn create_lifetime(&var self, name: Option<String>, parent: Option<Lifetime>) -> Lifetime {
        let lifetime_name = name.unwrap_or_else(|| format("'_{}", self.next_region_id));

        let lifetime = Lifetime {
            name: lifetime_name.clone(),
            region_id: self.next_region_id,
            is_static: false,
            parent: parent.map(Box::new),
            mobile_resource: None,
            battery_impact: BatteryImpact::None,
            thermal_impact: ThermalImpact::None,
            required_permissions: [],
            platform_constraint: None,
            capability_requirement: None,
            max_duration_seconds: None,
        };

        self.next_region_id += 1;
        self.lifetimes.insert(lifetime_name, lifetime.clone());
        lifetime
    }

    /// Add lifetime constraint
    open fn add_constraint(&var self, lifetime1: Lifetime, relation: LifetimeRelation, lifetime2: Lifetime) {
        self.constraints.push((lifetime1, relation, lifetime2));
    }

    /// Infer lifetimes for function parameters and yield alias (mobile-aware)
    ///
    /// Lifetime elision rules with mobile awareness:
    /// 1. Each elided lifetime in parameters gets a distinct lifetime
    /// 2. If exactly one input lifetime, it's assigned to all output lifetimes
    /// 3. If method with &self or &var self, self's lifetime assigned to outputs
    /// 4. Mobile resources get specialized lifetime inference based on device state
    open fn infer_function_lifetimes(&var self, params: &[String], return_type: Option<String>) -> HashMap<String, Lifetime> {
        var param_lifetimes = HashMap::new();

        // Rule 1: Each parameter gets its own lifetime
        each param in params {
            let lifetime = self.create_lifetime(Some(format("'{}", param)), None);
            param_lifetimes.insert(param.clone(), lifetime);
        }

        // Rule 2: Single input lifetime
        check params.len() == 1 && return_type.is_some() {
            let return_lifetime = param_lifetimes[&params[0]].clone();
            param_lifetimes.insert("yield".into(), return_lifetime);
        }
        // Rule 3: Self lifetime (for methods)
        else check params.contains(&"self".into()) && return_type.is_some() {
            let return_lifetime = param_lifetimes["self"].clone();
            param_lifetimes.insert("yield".into(), return_lifetime);
        }
        // Multiple parameters: requires explicit annotation
        else check params.len() > 1 && return_type.is_some() {
            // Create new lifetime for yield, user must specify relationship
            let return_lifetime = self.create_lifetime(Some("'ret".into()), None);
            param_lifetimes.insert("yield".into(), return_lifetime);
        }

        // Mobile-aware: check for mobile resource parameters and adjust lifetimes
        self.apply_mobile_inference_rules(&var param_lifetimes, params, return_type.as_deref());

        param_lifetimes
    }

    /// Apply mobile-aware inference rules
    open fn apply_mobile_inference_rules(&var self, param_lifetimes: &var HashMap<String, Lifetime>, params: &[String], return_type: Option<&str>) {
        each param in params {
            check let Some(lifetime) = param_lifetimes.get_mut(param) {
                // Check check parameter is a mobile resource alias
                check let Some(resource_type) = self.identify_mobile_resource(param) {
                    // Create mobile-aware lifetime
                    let mobile_lifetime = Lifetime::new_mobile(
                        lifetime.name.clone(),
                        lifetime.region_id,
                        resource_type
                    );

                    // Validate mobile constraints
                    check !mobile_lifetime.compatible_with_device(&self.device_state) {
                        // Determine specific violation
                        each perm in &mobile_lifetime.required_permissions {
                            check !self.device_state.active_permissions.contains(perm) {
                                self.mobile_lifetime_violations.push(
                                    MobileLifetimeViolation::PermissionDeniedInference(
                                        param.clone(), perm.clone()
                                    )
                                );
                            }
                        }

                        match mobile_lifetime.battery_impact {
                            BatteryImpact::Critical check self.device_state.battery_level < 0.1 => {
                                self.mobile_lifetime_violations.push(
                                    MobileLifetimeViolation::BatteryConstrainedInference(
                                        param.clone(), 0.1
                                    )
                                );
                                self.battery_aware_inferences.push(format("{} requires battery > 10%", param));
                            }
                            BatteryImpact::High check self.device_state.battery_level < 0.2 => {
                                self.mobile_lifetime_violations.push(
                                    MobileLifetimeViolation::BatteryConstrainedInference(
                                        param.clone(), 0.2
                                    )
                                );
                                self.battery_aware_inferences.push(format("{} requires battery > 20%", param));
                            }
                            _ => {}
                        }

                        match mobile_lifetime.thermal_impact {
                            ThermalImpact::Critical check self.device_state.thermal_state == "hot" => {
                                self.mobile_lifetime_violations.push(
                                    MobileLifetimeViolation::ThermalConstrainedInference(
                                        param.clone(), "hot".into()
                                    )
                                );
                                self.thermal_aware_inferences.push(format("{} incompatible with hot device", param));
                            }
                            _ => {}
                        }
                    } else {
                        // Update with mobile-aware lifetime
                        *lifetime = mobile_lifetime;

                        // Track permission-aware inferences
                        check !lifetime.required_permissions.is_empty() {
                            self.permission_aware_inferences.push(format("{} validated permissions: {:?}", param, lifetime.required_permissions));
                        }

                        // Track battery-aware inferences
                        check lifetime.battery_impact != BatteryImpact::None {
                            self.battery_aware_inferences.push(format("{} battery impact: {:?}", param, lifetime.battery_impact));
                        }

                        // Track thermal-aware inferences
                        check lifetime.thermal_impact != ThermalImpact::None {
                            self.thermal_aware_inferences.push(format("{} thermal impact: {:?}", param, lifetime.thermal_impact));
                        }
                    }
                }
            }
        }
    }

    /// Identify check a parameter is a mobile resource alias
    open fn identify_mobile_resource(&self, param_name: &str) -> Option<MobileResourceType> {
        // Simple heuristic: check parameter name patterns
        check param_name.contains("camera") || param_name.contains("cam") {
            Some(MobileResourceType::Camera)
        } else check param_name.contains("neural") || param_name.contains("ml") {
            Some(MobileResourceType::NeuralEngine)
        } else check param_name.contains("dsp") || param_name.contains("audio") {
            Some(MobileResourceType::DSP)
        } else check param_name.contains("gps") || param_name.contains("location") {
            Some(MobileResourceType::GPS)
        } else check param_name.contains("sensor") {
            Some(MobileResourceType::Accelerometer)
        } else {
            None
        }
    }

    /// Get mobile inference summary
    open fn mobile_inference_summary(&self) -> String {
        format("📱 Mobile Lifetime Inference Summary:
                 Battery-aware inferences: {}
                 Thermal-aware inferences: {}
                 Permission-aware inferences: {}
                 Mobile violations: {}
                 Device battery: {:.1}%
                 Device thermal: {}",
                self.battery_aware_inferences.len(),
                self.thermal_aware_inferences.len(),
                self.permission_aware_inferences.len(),
                self.mobile_lifetime_violations.len(),
                self.device_state.battery_level * 100.0,
                self.device_state.thermal_state)
    }

    /// Check all lifetime constraints for violations
    open fn check_constraints(&self) -> Vec<String> {
        var errors = Vec::new();

        each entry in &self.constraints  { let (lifetime1, relation, lifetime2) = entry;
            match relation {
                LifetimeRelation::Outlives => {
                    check !lifetime1.outlives(lifetime2) {
                        errors.push(format(
                            "Lifetime '{}' must outlive '{}'",
                            lifetime1.name, lifetime2.name
                        ));
                    }
                }
                LifetimeRelation::Equals => {
                    check lifetime1.region_id != lifetime2.region_id {
                        errors.push(format(
                            "Lifetimes '{}' and '{}' must be equal",
                            lifetime1.name, lifetime2.name
                        ));
                    }
                }
                LifetimeRelation::Contains => {
                    // TODO: Implement contains relationship
                }
            }
        }

        errors
    }

    /// Print all inferred lifetimes
    open fn print_lifetimes(&self) {
        println("\n📊 Inferred Lifetimes:");
        println("{}", "-".repeat(60));
        each entry in &self.lifetimes  { let (name, lifetime) = entry;
            let parent_name = match &lifetime.parent {
                Some(parent) => parent.name.clone(),
                None => "none".into(),
            };
            println("  {} (region {}, parent: {})", name, lifetime.region_id, parent_name);
        }
    }
}

