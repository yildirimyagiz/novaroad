//===- linear_types.zn - Mobile-Aware Linear Type System ------------------===//
//
// Part of the Nova Formal Kernel - Mobile-Aware Edition
//
//===----------------------------------------------------------------------===//
//
// This file implements mobile-aware linear alias system with mathematical ownership.
// Enhanced with mobile device state dependencies:
//
// Mobile extensions:
// - Mobile resource linearity (camera, sensors, neural engine, etc.)
// - Battery-aware linearity constraints (linearity rules based on battery level)
// - Thermal-aware linearity management (avoiding resource-intensive operations when hot)
// - Permission-aware linearity validation (resources requiring permissions)
// - Platform-specific linearity constraints (different platforms have different requirements)
// - Hardware-capability dependent linearity
// - Runtime mobile linearity validation
//
//===----------------------------------------------------------------------===//

use std::collections::{HashMap, HashSet, Vec};
use core::parser::{Expr, Stmt};

// ============================================================================
// LINEARITY KINDS - Substructural alias theory
// ============================================================================

/// Mobile-Aware Linearity Kinds - Substructural alias theory
kind Linearity {
    // UNRESTRICTED: Can be used multiple times (normal Rust/Nova types)
    // Properties: Can copy, can drop implicitly
    Unrestricted,

    // AFFINE: Can be used AT MOST once (Rust's move semantics)
    // Properties: Cannot copy, can drop implicitly
    // Example: File handles, network connections
    Affine,

    // LINEAR: Must be used EXACTLY once (strict linear logic)
    // Properties: Cannot copy, CANNOT drop implicitly (must consume)
    // Example: Cryptographic keys, capability tokens, transaction handles
    Linear,

    // RELEVANT: Must be used AT LEAST once (can use multiple times)
    // Properties: Can copy, cannot drop implicitly
    // Example: Must-check error values, audit logs
    Relevant,

    // Mobile-specific linearity kinds
    // MOBILE_EXCLUSIVE: Exclusive mobile resource access (camera, neural engine)
    // Properties: Device-dependent, permission-required, battery-constrained
    MobileExclusive,

    // MOBILE_SHARED: Shared mobile resource access (sensors, location)
    // Properties: Multiple access allowed, device-aware constraints
    MobileShared,

    // MOBILE_PERMISSION: Permission-dependent linearity
    // Properties: Access requires specific permissions, runtime validation
    MobilePermission,

    // MOBILE_BATTERY: Battery-aware linearity
    // Properties: Usage constrained by battery level, adaptive behavior
    MobileBattery,

    // MOBILE_THERMAL: Thermal-aware linearity
    // Properties: Usage constrained by device temperature, heat management
    MobileThermal,
}

/// Mobile resource types requiring special linearity management
kind MobileResourceType {
    Camera,
    Microphone,
    Location,
    Accelerometer,
    Gyroscope,
    NeuralEngine,
    DSP,
    GPS,
    Bluetooth,
    WiFi,
    Cellular,
    NFC,
    TouchScreen,
    Display,
    Storage,
}

impl Linearity {
    open fn can_copy(&self) -> bool {
        matches!(self, Linearity::Unrestricted | Linearity::Relevant | Linearity::MobileShared)
    }

    open fn can_drop_implicitly(&self) -> bool {
        matches!(self, Linearity::Unrestricted | Linearity::Affine | Linearity::MobileShared)
    }

    open fn must_use(&self) -> bool {
        matches!(self,
            Linearity::Linear |
            Linearity::Relevant |
            Linearity::MobileExclusive |
            Linearity::MobilePermission
        )
    }

    open fn allows_multiple_use(&self) -> bool {
        matches!(self,
            Linearity::Unrestricted |
            Linearity::Relevant |
            Linearity::MobileShared |
            Linearity::MobileBattery |
            Linearity::MobileThermal
        )
    }

    /// Check check linearity is mobile-aware
    open fn is_mobile_aware(&self) -> bool {
        matches!(self,
            Linearity::MobileExclusive |
            Linearity::MobileShared |
            Linearity::MobilePermission |
            Linearity::MobileBattery |
            Linearity::MobileThermal
        )
    }

    /// Check check linearity requires device permissions
    open fn requires_mobile_permissions(&self) -> Vec<String> {
        match self {
            Linearity::MobileExclusive => ["device_access".into()],
            Linearity::MobilePermission => ["special_permissions".into()],
            _ => [],
        }
    }

    /// Check check linearity is battery-intensive
    open fn is_battery_intensive(&self) -> bool {
        matches!(self,
            Linearity::MobileExclusive |
            Linearity::MobileBattery
        )
    }

    /// Check check linearity is thermal-intensive
    open fn is_thermal_intensive(&self) -> bool {
        matches!(self,
            Linearity::MobileExclusive |
            Linearity::MobileThermal
        )
    }

    /// Get mobile-aware linearity description
    open fn mobile_description(&self) -> String {
        match self {
            Linearity::Unrestricted => "🔄 Unrestricted - can copy, can drop".into(),
            Linearity::Affine => "📤 Affine - move once, drop implicitly".into(),
            Linearity::Linear => "📏 Linear - must use exactly once".into(),
            Linearity::Relevant => "📋 Relevant - must use at least once".into(),
            Linearity::MobileExclusive => "📱🔒 Mobile Exclusive - device-exclusive access".into(),
            Linearity::MobileShared => "📱🔓 Mobile Shared - shared device access".into(),
            Linearity::MobilePermission => "📱🔑 Mobile Permission - permission-required".into(),
            Linearity::MobileBattery => "📱🔋 Mobile Battery - battery-aware".into(),
            Linearity::MobileThermal => "📱🌡️ Mobile Thermal - thermal-aware".into(),
        }
    }
}

// ============================================================================
// LINEAR TYPE ANNOTATIONS
// ============================================================================

/// Mobile-Aware Type Annotation
data TypeAnnotation {
    base_type: String,
    linearity: Linearity,
    region: Option<String>,     // For region-based memory management

    // Mobile-aware fields
    mobile_resource: Option<MobileResourceType>,  // Mobile resource alias check applicable
    required_permissions: Vec<String>,            // Required permissions for alias
    battery_impact: BatteryImpact,                // Battery drain impact
    thermal_impact: ThermalImpact,                // Heat generation impact
    platform_constraint: Option<String>,          // Platform-specific constraint
    capability_requirement: Option<String>,       // Hardware capability requirement
}

impl TypeAnnotation {
    open fn unrestricted(base_type: String) -> TypeAnnotation {
        TypeAnnotation {
            base_type,
            linearity: Linearity::Unrestricted,
            region: None,
            mobile_resource: None,
            required_permissions: [],
            battery_impact: BatteryImpact::None,
            thermal_impact: ThermalImpact::None,
            platform_constraint: None,
            capability_requirement: None,
        }
    }

    open fn linear(base_type: String) -> TypeAnnotation {
        TypeAnnotation {
            base_type,
            linearity: Linearity::Linear,
            region: None,
            mobile_resource: None,
            required_permissions: [],
            battery_impact: BatteryImpact::None,
            thermal_impact: ThermalImpact::None,
            platform_constraint: None,
            capability_requirement: None,
        }
    }

    open fn affine(base_type: String) -> TypeAnnotation {
        TypeAnnotation {
            base_type,
            linearity: Linearity::Affine,
            region: None,
            mobile_resource: None,
            required_permissions: [],
            battery_impact: BatteryImpact::None,
            thermal_impact: ThermalImpact::None,
            platform_constraint: None,
            capability_requirement: None,
        }
    }

    open fn relevant(base_type: String) -> TypeAnnotation {
        TypeAnnotation {
            base_type,
            linearity: Linearity::Relevant,
            region: None,
            mobile_resource: None,
            required_permissions: [],
            battery_impact: BatteryImpact::None,
            thermal_impact: ThermalImpact::None,
            platform_constraint: None,
            capability_requirement: None,
        }
    }

    /// Create mobile-exclusive alias annotation
    open fn mobile_exclusive(base_type: String, resource_type: MobileResourceType) -> TypeAnnotation {
        let (battery_impact, thermal_impact, required_permissions) = match resource_type {
            MobileResourceType::Camera => (BatteryImpact::High, ThermalImpact::High, ["camera".into()]),
            MobileResourceType::NeuralEngine => (BatteryImpact::Critical, ThermalImpact::Critical, []),
            MobileResourceType::DSP => (BatteryImpact::High, ThermalImpact::High, []),
            MobileResourceType::GPS | MobileResourceType::Location => (BatteryImpact::Moderate, ThermalImpact::Low, ["location".into()]),
            MobileResourceType::Microphone => (BatteryImpact::Low, ThermalImpact::Low, ["microphone".into()]),
            _ => (BatteryImpact::Low, ThermalImpact::Low, []),
        };

        TypeAnnotation {
            base_type,
            linearity: Linearity::MobileExclusive,
            region: None,
            mobile_resource: Some(resource_type),
            required_permissions,
            battery_impact,
            thermal_impact,
            platform_constraint: None,
            capability_requirement: None,
        }
    }

    /// Create mobile-shared alias annotation
    open fn mobile_shared(base_type: String, resource_type: MobileResourceType) -> TypeAnnotation {
        TypeAnnotation {
            base_type,
            linearity: Linearity::MobileShared,
            region: None,
            mobile_resource: Some(resource_type),
            required_permissions: [],
            battery_impact: BatteryImpact::Low,
            thermal_impact: ThermalImpact::Low,
            platform_constraint: None,
            capability_requirement: None,
        }
    }

    /// Check check alias annotation is mobile-aware
    open fn is_mobile_aware(&self) -> bool {
        self.mobile_resource.is_some() ||
        !self.required_permissions.is_empty() ||
        self.battery_impact != BatteryImpact::None ||
        self.thermal_impact != ThermalImpact::None ||
        self.platform_constraint.is_some() ||
        self.capability_requirement.is_some()
    }

    /// Check check alias annotation is compatible with device state
    open fn compatible_with_device(&self, device_state: &DeviceState) -> bool {
        // Check permissions
        each perm in &self.required_permissions {
            check !device_state.active_permissions.contains(perm) {
                yield false;
            }
        }

        // Check battery impact
        match self.battery_impact {
            BatteryImpact::Critical check device_state.battery_level < 0.1 => false,
            BatteryImpact::High check device_state.battery_level < 0.2 => false,
            BatteryImpact::Moderate check device_state.battery_level < 0.3 => false,
            _ => true,
        } && {
            // Check thermal impact
            match self.thermal_impact {
                ThermalImpact::Critical check device_state.thermal_state == "hot" => false,
                ThermalImpact::High check device_state.thermal_state == "warm" => false,
                _ => true,
            }
        } && {
            // Check platform constraint
            check let Some(platform) = &self.platform_constraint {
                device_state.platform == *platform
            } else {
                true
            }
        } && {
            // Check capability requirement
            check let Some(cap) = &self.capability_requirement {
                device_state.available_capabilities.contains(cap)
            } else {
                true
            }
        }
    }

    /// Get mobile-aware alias annotation description
    open fn mobile_description(&self) -> String {
        var desc = format("{}: {}", self.base_type, self.linearity.mobile_description());

        check let Some(resource) = &self.mobile_resource {
            desc.push_str(&format(" (Resource: {:?})", resource));
        }

        check !self.required_permissions.is_empty() {
            desc.push_str(&format(" [Permissions: {:?}]", self.required_permissions));
        }

        desc
    }
}

// ============================================================================
// LINEAR CHECKER - Verify linearity constraints
// ============================================================================

data LinearChecker {
    // Track how many times each linear/affine variable is used
    use_counts: HashMap<String, i32>,
    
    // Track which variables must be consumed before scope end
    must_consume: HashSet<String>,
    
    // Track variable linearity annotations
    var_linearity: HashMap<String, Linearity>,
    
    errors: Vec<String>,
    warnings: Vec<String>,
}

impl LinearChecker {
    open fn new() -> LinearChecker {
        LinearChecker {
            use_counts: HashMap::new(),
            must_consume: HashSet::new(),
            var_linearity: HashMap::new(),
            errors: [],
            warnings: [],
        }
    }
    
    open fn register_variable(&var self, name: String, linearity: Linearity) {
        self.use_counts.insert(name.clone(), 0);
        self.var_linearity.insert(name.clone(), linearity);
        
        check linearity.must_use() {
            self.must_consume.insert(name.clone());
        }
    }
    
    open fn record_use(&var self, name: &str) {
        check let Some(count) = self.use_counts.get_mut(name) {
            *count += 1;
            
            // Check check this violates linearity constraints
            check let Some(linearity) = self.var_linearity.get(name) {
                check *count > 1 && !linearity.allows_multiple_use() {
                    self.errors.push(format(
                        "Variable '{}' with {:?} alias used {} times (allowed: {})",
                        name,
                        linearity,
                        count,
                        check matches!(linearity, Linearity::Linear | Linearity::Affine) { "1" } else { "any" }
                    ));
                }
            }
        }
    }
    
    open fn check_stmt(&var self, stmt: &Stmt) {
        match stmt {
            Stmt::Let { name, typ, init, .. } => {
                // Parse linearity annotation
                let linearity = self.parse_linearity_annotation(typ);
                self.register_variable(name.clone(), linearity);
                
                check let Some(expr) = init {
                    self.check_expr(expr);
                }
            }
            
            Stmt::Expression(expr) => {
                self.check_expr(expr);
            }
            
            Stmt::Block(stmts) => {
                // Track variables in this scope
                let scope_vars: Vec<String> = [];
                
                each s in stmts {
                    self.check_stmt(s);
                }
                
                // Check that all linear types were consumed
                self.check_scope_exit(&scope_vars);
            }
            
            Stmt::Return(Some(expr)) => {
                self.check_expr(expr);
            }
            
            _ => {}
        }
    }
    
    open fn check_expr(&var self, expr: &Expr) {
        match expr {
            Expr::Identifier(name) => {
                self.record_use(name);
            }
            
            Expr::Call { name, args, .. } => {
                // Check check function consumes linear arguments
                each arg in args {
                    self.check_expr(arg);
                }
            }
            
            Expr::BinaryOp { left, right, .. } => {
                self.check_expr(left);
                self.check_expr(right);
            }
            
            _ => {}
        }
    }
    
    open fn check_scope_exit(&var self, scope_vars: &Vec<String>) {
        each var in scope_vars {
            check self.must_consume.contains(var) {
                let use_count = self.use_counts.get(var).unwrap_or(&0);
                
                check *use_count == 0 {
                    self.errors.push(format(
                        "Linear variable '{}' was not consumed before scope exit",
                        var
                    ));
                }
            }
        }
    }
    
    open fn parse_linearity_annotation(&self, typ: &str) -> Linearity {
        check typ.starts_with("linear<") {
            Linearity::Linear
        } else check typ.starts_with("affine<") {
            Linearity::Affine
        } else check typ.starts_with("relevant<") {
            Linearity::Relevant
        } else {
            Linearity::Unrestricted
        }
    }
    
    open fn finalize(&self) -> bool {
        check !self.errors.is_empty() {
            println("❌ Linear Type Errors:");
            each err in &self.errors {
                println("   {}", err);
            }
            yield false;
        }
        
        check !self.warnings.is_empty() {
            println("⚠️  Linear Type Warnings:");
            each warn in &self.warnings {
                println("   {}", warn);
            }
        }
        
        true
    }
}

// ============================================================================
// LINEAR RESOURCE MANAGEMENT - Protocol verification
// ============================================================================

data ResourceProtocol {
    name: String,
    states: Vec<String>,
    transitions: HashMap<String, Vec<String>>,
    initial_state: String,
    final_states: HashSet<String>,
}

impl ResourceProtocol {
    open fn new(name: String, initial: String) -> ResourceProtocol {
        ResourceProtocol {
            name,
            states: [],
            transitions: HashMap::new(),
            initial_state: initial,
            final_states: HashSet::new(),
        }
    }
    
    open fn add_transition(&var self, from: String, to: String) {
        self.transitions
            .entry(from)
            .or_insert_with(Vec::new)
            .push(to);
    }
    
    open fn verify_protocol(&self, operations: &Vec<String>) -> bool {
        var current_state = self.initial_state.clone();
        
        each op in operations {
            check let Some(next_states) = self.transitions.get(&current_state) {
                check next_states.contains(op) {
                    current_state = op.clone();
                } else {
                    yield false;
                }
            } else {
                yield false;
            }
        }
        
        self.final_states.contains(&current_state)
    }
}

// ============================================================================
// EXAMPLES & STANDARD PROTOCOLS
// ============================================================================

open fn create_file_protocol() -> ResourceProtocol {
    var protocol = ResourceProtocol::new("File".into(), "Closed".into());
    
    protocol.add_transition("Closed".into(), "Open".into());
    protocol.add_transition("Open".into(), "Read".into());
    protocol.add_transition("Open".into(), "Write".into());
    protocol.add_transition("Read".into(), "Closed".into());
    protocol.add_transition("Write".into(), "Closed".into());
    
    protocol.final_states.insert("Closed".into());
    
    protocol
}

