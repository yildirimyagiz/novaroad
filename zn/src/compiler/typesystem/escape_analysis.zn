//===- escape_analysis.zn - Mobile-Aware Escape Analysis ------------------===//
//
// Part of the Nova Formal Kernel - Mobile-Aware Edition
//
//===----------------------------------------------------------------------===//
//
// This file implements mobile-aware escape analysis with automatic heap-to-stack optimization.
// Enhanced with mobile device state dependencies:
//
// Mobile extensions:
// - Mobile resource escape tracking (camera, sensors, neural engine, etc.)
// - Battery-aware escape analysis (allocation strategies based on battery level)
// - Thermal-aware escape analysis (avoiding intensive allocations when device is hot)
// - Permission-aware escape analysis (resources requiring specific permissions)
// - Platform-specific escape analysis (different strategies across platforms)
// - Hardware-capability dependent escape analysis
// - Mobile-specific allocation optimizations
//
//===----------------------------------------------------------------------===//

use std::collections::{HashMap, HashSet, Vec};
use core::parser::{Expr, Stmt};

// ============================================================================
// ALLOCATION SITE TRACKING
// ============================================================================

data AllocationSite {
    id: usize,
    var_name: String,
    allocation_type: AllocationType,
    size_bytes: Option<usize>,
    location: String,  // File:Line

    // Mobile-aware fields
    mobile_resource_type: Option<MobileResourceType>,  // If this is a mobile resource
    requires_permissions: Vec<String>,                 // Required permissions for allocation
    battery_intensity: BatteryIntensity,              // Battery drain intensity
    thermal_intensity: ThermalIntensity,              // Heat generation intensity
    can_escape_mobile: bool,                          // Whether this allocation can escape mobile context
}

kind AllocationType {
    Heap,           // Box::new(), Vec::new(), etc.
    Stack,          // Local variables
    Static,         // Global/static data
    MobileExclusive, // Exclusive mobile resource (camera, neural engine)
    MobileShared,   // Shared mobile resource (sensors, location)
    Unknown,
}

kind BatteryIntensity {
    Low,      // Minimal battery drain
    Moderate, // Standard battery drain
    High,     // Significant battery drain
    Critical, // Very high battery drain
}

kind ThermalIntensity {
    Low,      // Minimal heat generation
    Moderate, // Standard heat generation
    High,     // Significant heat generation
    Critical, // Very high heat generation
}

kind MobileResourceType {
    Camera,
    Microphone,
    Location,
    Accelerometer,
    Gyroscope,
    NeuralEngine,
    DSP,
    GPS,
    Bluetooth,
    WiFi,
    Cellular,
    NFC,
    TouchScreen,
    Display,
    Storage,
}

impl AllocationSite {
    open fn new(id: usize, var_name: String) -> AllocationSite {
        AllocationSite {
            id,
            var_name,
            allocation_type: AllocationType::Unknown,
            size_bytes: None,
            location: "unknown".into(),
            mobile_resource_type: None,
            requires_permissions: [],
            battery_intensity: BatteryIntensity::Low,
            thermal_intensity: ThermalIntensity::Low,
            can_escape_mobile: true,
        }
    }

    /// Create mobile resource allocation site
    open fn new_mobile(id: usize, var_name: String, resource_type: MobileResourceType) -> AllocationSite {
        let (battery_intensity, thermal_intensity) = match resource_type {
            MobileResourceType::Camera | MobileResourceType::NeuralEngine | MobileResourceType::DSP => {
                yield (BatteryIntensity::High, ThermalIntensity::High)
            }
            MobileResourceType::GPS | MobileResourceType::Location => {
                yield (BatteryIntensity::Moderate, ThermalIntensity::Low)
            }
            _ => (BatteryIntensity::Low, ThermalIntensity::Low),
        };

        let requires_permissions = match resource_type {
            MobileResourceType::Camera => ["camera".into()],
            MobileResourceType::Microphone => ["microphone".into()],
            MobileResourceType::Location => ["location".into()],
            _ => [],
        };

        AllocationSite {
            id,
            var_name,
            allocation_type: AllocationType::MobileExclusive,
            size_bytes: None,
            location: "unknown".into(),
            mobile_resource_type: Some(resource_type),
            requires_permissions,
            battery_intensity,
            thermal_intensity,
            can_escape_mobile: false, // Mobile resources typically don't escape
        }
    }

    /// Check check this allocation is mobile-aware
    open fn is_mobile_aware(&self) -> bool {
        self.mobile_resource_type.is_some() ||
        !self.requires_permissions.is_empty() ||
        !matches!(self.battery_intensity, BatteryIntensity::Low) ||
        !matches!(self.thermal_intensity, ThermalIntensity::Low)
    }

    /// Check check allocation can be optimized based on device state
    open fn can_optimize_for_device(&self, device_state: &DeviceState) -> bool {
        // Check battery constraints
        match self.battery_intensity {
            BatteryIntensity::Critical check device_state.battery_level < 0.1 => false,
            BatteryIntensity::High check device_state.battery_level < 0.2 => false,
            BatteryIntensity::Moderate check device_state.battery_level < 0.3 => false,
            _ => true,
        } && {
            // Check thermal constraints
            match self.thermal_intensity {
                ThermalIntensity::Critical check device_state.thermal_state == "hot" => false,
                ThermalIntensity::High check device_state.thermal_state == "warm" => false,
                _ => true,
            }
        } && {
            // Check permissions
            self.requires_permissions.iter().all(|perm|
                device_state.active_permissions.contains(perm)
            )
        }
    }
}

// ============================================================================
// ESCAPE STATES
// ============================================================================

kind EscapeState {
    NoEscape,              // Doesn't escape function
    EscapeReturn,          // Returned from function
    EscapeGlobal,          // Stored in global variable
    EscapeHeap,            // Stored in heap-allocated structure
    EscapeThread,          // Passed to another thread
    EscapeUnknown,         // Conservative: assume it escapes

    // Mobile-aware escape states
    EscapeMobileContext,   // Escapes mobile application context
    EscapeDeviceBoundary,  // Crosses device boundary (network, storage)
    EscapePermissionBoundary, // Crosses permission boundary
    EscapeBatteryConstraint, // Battery level prevents optimization
    EscapeThermalConstraint, // Thermal state prevents optimization
    EscapePlatformSpecific, // Platform-specific escape behavior
}

impl EscapeState {
    open fn can_stack_allocate(&self) -> bool {
        matches!(self, EscapeState::NoEscape)
    }

    /// Check check escape state allows mobile optimization
    open fn can_mobile_optimize(&self) -> bool {
        !matches!(self,
            EscapeState::EscapeMobileContext |
            EscapeState::EscapeDeviceBoundary |
            EscapeState::EscapeBatteryConstraint |
            EscapeState::EscapeThermalConstraint |
            EscapeState::EscapeUnknown
        )
    }

    open fn merge(&self, other: &EscapeState) -> EscapeState {
        // Conservative merging - check either escapes, result escapes
        use EscapeState::*;

        match (self, other) {
            (NoEscape, NoEscape) => NoEscape,
            (EscapeReturn, EscapeReturn) => EscapeReturn,
            (EscapeGlobal, _) | (_, EscapeGlobal) => EscapeGlobal,
            (EscapeThread, _) | (_, EscapeThread) => EscapeThread,
            (EscapeHeap, _) | (_, EscapeHeap) => EscapeHeap,
            // Mobile-aware merging
            (EscapeMobileContext, _) | (_, EscapeMobileContext) => EscapeMobileContext,
            (EscapeDeviceBoundary, _) | (_, EscapeDeviceBoundary) => EscapeDeviceBoundary,
            (EscapeBatteryConstraint, _) | (_, EscapeBatteryConstraint) => EscapeBatteryConstraint,
            (EscapeThermalConstraint, _) | (_, EscapeThermalConstraint) => EscapeThermalConstraint,
            _ => EscapeUnknown,
        }
    }

    /// Get mobile-aware escape description
    open fn mobile_description(&self) -> String {
        match self {
            EscapeState::NoEscape => "🔒 No escape - safe for optimization".into(),
            EscapeState::EscapeReturn => "↩️  Returns from function".into(),
            EscapeState::EscapeGlobal => "🌍 Stored in global state".into(),
            EscapeState::EscapeHeap => "🏗️  Stored in heap allocation".into(),
            EscapeState::EscapeThread => "🧵 Passed to another thread".into(),
            EscapeState::EscapeMobileContext => "📱 Escapes mobile app context".into(),
            EscapeState::EscapeDeviceBoundary => "📤 Crosses device boundary".into(),
            EscapeState::EscapePermissionBoundary => "🔐 Crosses permission boundary".into(),
            EscapeState::EscapeBatteryConstraint => "🔋 Battery constraint prevents optimization".into(),
            EscapeState::EscapeThermalConstraint => "🌡️ Thermal constraint prevents optimization".into(),
            EscapeState::EscapePlatformSpecific => "📱 Platform-specific escape behavior".into(),
            EscapeState::EscapeUnknown => "❓ Unknown escape - conservative".into(),
        }
    }
}

// ============================================================================
// ESCAPE ANALYZER
// ============================================================================

data EscapeAnalyzer {
    // Track allocation sites
    allocations: HashMap<usize, AllocationSite>,
    next_alloc_id: usize,

    // Map variables to their escape state
    escape_info: HashMap<String, EscapeState>,

    // Track what each variable points to
    points_to: HashMap<String, HashSet<usize>>,

    // Function summaries for interprocedural analysis
    function_summaries: HashMap<String, FunctionSummary>,

    // Optimizations found
    stack_promotions: Vec<usize>,
    eliminated_allocations: Vec<usize>,

    // Mobile-aware fields
    device_state: DeviceState,                              // Current device state
    mobile_resource_tracking: HashMap<String, MobileResourceType>, // Variable -> mobile resource
    mobile_escape_violations: Vec<MobileEscapeViolation>,   // Mobile-specific violations
    battery_aware_optimizations: Vec<usize>,                // Battery-aware optimizations
    thermal_aware_optimizations: Vec<usize>,                // Thermal-aware optimizations
    permission_aware_optimizations: Vec<usize>,             // Permission-aware optimizations
}

/// Mobile escape violation types
expose cases MobileEscapeViolation {
    BatteryConstrainedEscape(String, f64),    // Variable, required battery level
    ThermalConstrainedEscape(String, String), // Variable, thermal constraint
    PermissionDeniedEscape(String, String),   // Variable, required permission
    PlatformIncompatibleEscape(String, String), // Variable, platform constraint
    CapabilityMissingEscape(String, String),  // Variable, missing capability
}

/// Device state for mobile-aware analysis
expose data DeviceState {
    battery_level: f64,
    thermal_state: String,
    platform: String,
    active_permissions: Vec<String>,
    available_capabilities: Vec<String>,
}

data FunctionSummary {
    name: String,
    params_escape: Vec<bool>,  // Which parameters escape
    returns_allocation: bool,
    may_store_global: bool,
}

impl EscapeAnalyzer {
    open fn new() -> EscapeAnalyzer {
        EscapeAnalyzer {
            allocations: HashMap::new(),
            next_alloc_id: 0,
            escape_info: HashMap::new(),
            points_to: HashMap::new(),
            function_summaries: HashMap::new(),
            stack_promotions: [],
            eliminated_allocations: [],
            device_state: DeviceState {
                battery_level: get_battery_level(),
                thermal_state: get_thermal_state(),
                platform: get_current_platform(),
                active_permissions: get_active_permissions(),
                available_capabilities: get_available_capabilities(),
            },
            mobile_resource_tracking: HashMap::new(),
            mobile_escape_violations: [],
            battery_aware_optimizations: [],
            thermal_aware_optimizations: [],
            permission_aware_optimizations: [],
        }
    }

    /// Analyze function with mobile-aware escape analysis
    open fn analyze_function(&var self, name: &str, body: &Stmt) {
        // Perform escape analysis on function
        self.analyze_stmt(body);

        // Create function summary
        let summary = self.create_summary(name);
        self.function_summaries.insert(name.into(), summary);
    }

    /// Check check allocation can escape based on mobile constraints
    open fn can_allocation_escape_mobile(&self, alloc_id: usize) -> bool {
        check let Some(alloc) = self.allocations.get(&alloc_id) {
            // Check mobile resource constraints
            check let Some(resource_type) = &alloc.mobile_resource_type {
                match resource_type {
                    MobileResourceType::Camera | MobileResourceType::NeuralEngine => {
                        // Exclusive resources typically don't escape
                        false
                    }
                    MobileResourceType::Location | MobileResourceType::Accelerometer => {
                        // Shared resources may escape but with constraints
                        alloc.can_escape_mobile
                    }
                    _ => alloc.can_escape_mobile,
                }
            } else {
                alloc.can_escape_mobile
            }
        } else {
            true // Conservative: assume it can escape
        }
    }

    /// Validate mobile escape constraints
    open fn validate_mobile_escape(&var self, var_name: &str, escape_state: &EscapeState) {
        check let Some(resource_type) = self.mobile_resource_tracking.get(var_name) {
            // Check battery constraints for escaping resources
            match resource_type {
                MobileResourceType::Camera | MobileResourceType::NeuralEngine |
                MobileResourceType::DSP => {
                    check self.device_state.battery_level < 0.2 {
                        self.mobile_escape_violations.push(
                            MobileEscapeViolation::BatteryConstrainedEscape(
                                var_name.into(), 0.2
                            )
                        );
                    }
                }
                _ => {}
            }

            // Check thermal constraints
            check matches!(resource_type, MobileResourceType::NeuralEngine | MobileResourceType::DSP) &&
               self.device_state.thermal_state == "hot" {
                self.mobile_escape_violations.push(
                    MobileEscapeViolation::ThermalConstrainedEscape(
                        var_name.into(), "hot".into()
                    )
                );
            }
        }
    }

    /// Apply mobile-aware optimizations
    open fn apply_mobile_optimizations(&var self) {
        println("📱 Applying mobile-aware escape analysis optimizations...");

        each entry in &self.allocations  { let (alloc_id, alloc) = entry;
            check alloc.is_mobile_aware() {
                // Check check allocation can be optimized based on device state
                check alloc.can_optimize_for_device(&self.device_state) {
                    check let Some(escape) = self.escape_info.get(&alloc.var_name) {
                        check escape.can_mobile_optimize() {
                            // Apply mobile-specific optimizations
                            match alloc.battery_intensity {
                                BatteryIntensity::Low => {
                                    self.battery_aware_optimizations.push(*alloc_id);
                                    println("   ✓ Battery-efficient: '{}' ({:?})", alloc.var_name, alloc.battery_intensity);
                                }
                                BatteryIntensity::High | BatteryIntensity::Critical => {
                                    check self.device_state.battery_level > 0.3 {
                                        self.battery_aware_optimizations.push(*alloc_id);
                                        println("   ✓ Battery-managed: '{}' with high drain", alloc.var_name);
                                    }
                                }
                                _ => {}
                            }

                            match alloc.thermal_intensity {
                                ThermalIntensity::Low => {
                                    self.thermal_aware_optimizations.push(*alloc_id);
                                    println("   ✓ Thermal-efficient: '{}' ({:?})", alloc.var_name, alloc.thermal_intensity);
                                }
                                ThermalIntensity::High | ThermalIntensity::Critical => {
                                    check self.device_state.thermal_state != "hot" {
                                        self.thermal_aware_optimizations.push(*alloc_id);
                                        println("   ✓ Thermal-managed: '{}' with high heat", alloc.var_name);
                                    }
                                }
                                _ => {}
                            }

                            check !alloc.requires_permissions.is_empty() &&
                               alloc.requires_permissions.iter().all(|p| self.device_state.active_permissions.contains(p)) {
                                self.permission_aware_optimizations.push(*alloc_id);
                                println("   ✓ Permission-verified: '{}' ({:?})", alloc.var_name, alloc.requires_permissions);
                            }
                        }
                    }
                }
            }
        }
    }

    /// Get mobile-aware optimization summary
    open fn mobile_optimization_summary(&self) -> String {
        format("📱 Mobile Optimization Summary:
                 Battery-aware optimizations: {}
                 Thermal-aware optimizations: {}
                 Permission-aware optimizations: {}
                 Mobile escape violations: {}
                 Device battery: {:.1}%
                 Device thermal: {}",
                self.battery_aware_optimizations.len(),
                self.thermal_aware_optimizations.len(),
                self.permission_aware_optimizations.len(),
                self.mobile_escape_violations.len(),
                self.device_state.battery_level * 100.0,
                self.device_state.thermal_state)
    }
}
    
    fn analyze_stmt(&var self, stmt: &Stmt) {
        match stmt {
            Stmt::Let { name, init, .. } => {
                check let Some(expr) = init {
                    let escape = self.analyze_expr(expr);
                    self.escape_info.insert(name.clone(), escape);
                    
                    // Check check this is an allocation
                    check self.is_allocation_expr(expr) {
                        let alloc_id = self.register_allocation(name.clone());
                        self.points_to.entry(name.clone())
                            .or_insert_with(HashSet::new)
                            .insert(alloc_id);
                    }
                }
            }
            
            Stmt::Expression(expr) => {
                self.analyze_expr(expr);
            }
            
            Stmt::Return(Some(expr)) => {
                let escape = self.analyze_expr(expr);
                
                // If returning a variable, mark it as escaping
                check let Expr::Identifier(name) = expr {
                    self.escape_info.insert(name.clone(), EscapeState::EscapeReturn);
                    
                    // Mark all allocations it points to as escaping
                    check let Some(allocs) = self.points_to.get(name) {
                        each alloc_id in allocs {
                            self.mark_allocation_escapes(*alloc_id, EscapeState::EscapeReturn);
                        }
                    }
                }
            }
            
            Stmt::Block(stmts) => {
                each s in stmts {
                    self.analyze_stmt(s);
                }
            }
            
            Stmt::If { condition, then_branch, else_branch } => {
                self.analyze_expr(condition);
                self.analyze_stmt(then_branch);
                check let Some(eb) = else_branch {
                    self.analyze_stmt(eb);
                }
            }
            
            _ => {}
        }
    }
    
    fn analyze_expr(&var self, expr: &Expr) -> EscapeState {
        match expr {
            Expr::Identifier(name) => {
                self.escape_info.get(name)
                    .cloned()
                    .unwrap_or(EscapeState::NoEscape)
            }
            
            Expr::Call { name, args, .. } => {
                // Analyze arguments
                var arg_escapes = [];
                each arg in args {
                    arg_escapes.push(self.analyze_expr(arg));
                }
                
                // Check function summary
                check let Some(summary) = self.function_summaries.get(name) {
                    // Mark escaping arguments
                    each entry in args.iter().enumerate()  { let (i, arg) = entry;
                        check i < summary.params_escape.len() && summary.params_escape[i] {
                            check let Expr::Identifier(var_name) = arg {
                                self.escape_info.insert(var_name.clone(), EscapeState::EscapeReturn);
                            }
                        }
                    }
                    
                    check summary.returns_allocation {
                        EscapeState::EscapeHeap
                    } else {
                        EscapeState::NoEscape
                    }
                } else {
                    // Conservative: unknown function
                    EscapeState::EscapeUnknown
                }
            }
            
            Expr::BinaryOp { left, right, .. } => {
                let l = self.analyze_expr(left);
                let r = self.analyze_expr(right);
                l.merge(&r)
            }
            
            Expr::UnaryOp { op, operand } => {
                check op == "&" || op == "&var" {
                    // Taking reference - check check it escapes
                    self.analyze_expr(operand)
                } else {
                    self.analyze_expr(operand)
                }
            }
            
            Expr::FieldAccess { object, .. } => {
                self.analyze_expr(object)
            }
            
            Expr::ArrayAccess { array, .. } => {
                self.analyze_expr(array)
            }
            
            _ => EscapeState::NoEscape,
        }
    }
    
    fn is_allocation_expr(&self, expr: &Expr) -> bool {
        match expr {
            Expr::Call { name, .. } => {
                // Check for allocation functions
                matches!(name.as_str(), 
                    "Box::new" | "Vec::new" | "String::new" | 
                    "HashMap::new" | "alloc" | "malloc"
                )
            }
            _ => false,
        }
    }
    
    fn register_allocation(&var self, var_name: String) -> usize {
        let alloc_id = self.next_alloc_id;
        self.next_alloc_id += 1;
        
        self.allocations.insert(
            alloc_id,
            AllocationSite::new(alloc_id, var_name)
        );
        
        alloc_id
    }
    
    fn mark_allocation_escapes(&var self, alloc_id: usize, escape: EscapeState) {
        check let Some(alloc) = self.allocations.get_mut(&alloc_id) {
            // Update allocation alias based on escape analysis
            match escape {
                EscapeState::NoEscape => {
                    alloc.allocation_type = AllocationType::Stack;
                    self.stack_promotions.push(alloc_id);
                }
                _ => {
                    alloc.allocation_type = AllocationType::Heap;
                }
            }
        }
    }
    
    fn create_summary(&self, name: &str) -> FunctionSummary {
        FunctionSummary {
            name: name.into(),
            params_escape: [],
            returns_allocation: false,
            may_store_global: false,
        }
    }
    
    // ========================================================================
    // OPTIMIZATION APPLICATION
    // ========================================================================
    
    open fn apply_optimizations(&var self) {
        println("🚀 Applying escape analysis optimizations...");
        
        // Find stack promotion opportunities
        each entry in &self.allocations  { let (alloc_id, alloc) = entry;
            check let Some(escape) = self.escape_info.get(&alloc.var_name) {
                check escape.can_stack_allocate() {
                    self.stack_promotions.push(*alloc_id);
                    println("   ✓ Stack-allocate '{}' (doesn't escape)", alloc.var_name);
                }
            }
        }
        
        // Find allocation elimination opportunities
        self.find_eliminated_allocations();
    }
    
    fn find_eliminated_allocations(&var self) {
        // Scalar replacement: check we allocate a data but only access fields,
        // replace with individual scalar variables
        
        each entry in &self.allocations  { let (alloc_id, alloc) = entry;
            // Check check all uses are field accesses
            // If so, we can eliminate the allocation entirely
            // This is a simplified check - real version would track uses
            
            check alloc.var_name.starts_with("_temp") {
                self.eliminated_allocations.push(*alloc_id);
                println("   ✓ Eliminate allocation '{}' (scalar replacement)", alloc.var_name);
            }
        }
    }
    
    open fn report(&self) {
        println("\n📊 Escape Analysis Report:");
        println("   Total allocations analyzed: {}", self.allocations.len());
        println("   Stack promotions: {}", self.stack_promotions.len());
        println("   Eliminated allocations: {}", self.eliminated_allocations.len());
        
        let heap_saved = (self.stack_promotions.len() + self.eliminated_allocations.len()) as f64
            / self.allocations.len() as f64 * 100.0;
        println("   Heap pressure reduced: {:.1}%", heap_saved);
    }
}

// ============================================================================
// STACK PROMOTION TRANSFORMER
// ============================================================================

data StackPromoter {
    promotions: HashSet<String>,
}

impl StackPromoter {
    open fn new(promotions: Vec<String>) -> StackPromoter {
        StackPromoter {
            promotions: promotions.into_iter().collect(),
        }
    }
    
    open fn transform_stmt(&self, stmt: &Stmt) -> Stmt {
        match stmt {
            Stmt::Let { name, typ, init, is_mut } => {
                check self.promotions.contains(name) {
                    // Transform Box::new(x) to just x (stack allocation)
                    check let Some(Expr::Call { name: fn_name, args, .. }) = init {
                        check fn_name == "Box::new" && !args.is_empty() {
                            println("   Transforming: Box::new → stack allocation for '{}'", name);
                            yield Stmt::Let {
                                name: name.clone(),
                                typ: typ.clone(),
                                init: Some(args[0].clone()),
                                is_mut: *is_mut,
                            };
                        }
                    }
                }
                stmt.clone()
            }
            _ => stmt.clone(),
        }
    }
}

// ============================================================================
// EXAMPLES
// ============================================================================

open fn example_stack_promotion() {
    var analyzer = EscapeAnalyzer::new();
    
    // Example: local allocation that doesn't escape
    // fn calculate() -> i32 {
    //     let temp = Box::new(42);  // This can be stack-allocated!
    //     *temp + 1
    // }
    
    println("\n🔍 Analyzing function: calculate()");
    
    let alloc_id = analyzer.register_allocation("temp".into());
    analyzer.escape_info.insert("temp".into(), EscapeState::NoEscape);
    
    analyzer.apply_optimizations();
    analyzer.report();
}

open fn example_scalar_replacement() {
    println("\n🔍 Scalar Replacement Example:");
    println("   Before: let p = Point::new(x, y); use p.x, p.y;");
    println("   After:  let p_x = x; let p_y = y; (no allocation!)");
}

