/// Mobile resource analysis example
fn example_mobile_resource_analysis() {
    println("\n📱 Mobile Resource Escape Analysis Example:");

    var analyzer = EscapeAnalyzer::new();

    // Simulate camera resource that escapes (bad practice)
    analyzer.register_allocation("escaping_camera".into());
    analyzer.mobile_resource_tracking.insert("escaping_camera".into(), MobileResourceType::Camera);
    analyzer.escape_info.insert("escaping_camera".into(), EscapeState::EscapeReturn);

    // Simulate neural engine that doesn't escape (good practice)
    analyzer.register_allocation("local_neural".into());
    analyzer.mobile_resource_tracking.insert("local_neural".into(), MobileResourceType::NeuralEngine);
    analyzer.escape_info.insert("local_neural".into(), EscapeState::NoEscape);

    // Validate escapes
    analyzer.validate_mobile_escape("escaping_camera", &EscapeState::EscapeReturn);
    analyzer.validate_mobile_escape("local_neural", &EscapeState::NoEscape);

    println("  Escaping camera violations: {}", analyzer.mobile_escape_violations.len());
    println("  Local neural violations: 0 (expected - doesn't escape)");
}