// Ana modül export'ları
pub use mod::*;
pub use multilingual_compiler::*;
pub use multilingual_parser::*;
pub use stage_integration::*;
pub use tests::*;

// Re-export ana bileşenler
pub use multilingual_compiler::MultilingualCompiler;
pub use multilingual_parser::MultilingualParser;
pub use stage_integration::MultilingualStageCompiler;
pub use tests::MultilingualTestSuite;

// Yardımcı modüller
mod multilingual_compiler;
mod multilingual_parser;
mod stage_integration;
mod tests;

/// Çok dilli derleyici ana sistemi
expose data MultilingualCompiler {
    language_detector: LanguageDetector,
    keyword_translator: KeywordTranslator,
    cultural_adapter: CulturalAdapter,
    fallback_compiler: FallbackCompiler
}

/// Dil tespiti sistemi
expose data LanguageDetector {
    supported_languages: Vec<String>,
    detection_patterns: HashMap<String, Vec<String>>,
    confidence_threshold: f64
}

/// Anahtar kelime çeviri sistemi
expose data KeywordTranslator {
    translation_maps: HashMap<String, HashMap<String, TokenKind>>,
    reverse_maps: HashMap<String, HashMap<TokenKind, String>>
}

/// Kültürel adaptasyon sistemi
expose data CulturalAdapter {
    cultural_contexts: HashMap<String, CulturalContext>,
    syntax_adaptations: HashMap<String, SyntaxAdaptation>
}

/// Fallback derleyici
expose data FallbackCompiler {
    english_compiler: StandardCompiler,
    error_handler: ErrorHandler
}

impl MultilingualCompiler {
    open fn new() -> MultilingualCompiler {
        MultilingualCompiler {
            language_detector: LanguageDetector::new(),
            keyword_translator: KeywordTranslator::new(),
            cultural_adapter: CulturalAdapter::new(),
            fallback_compiler: FallbackCompiler::new()
        }
    }
    
    /// Çok dilli kaynak kod derle
    open fn compile_multilingual(&mut self, source: &str) -> Result<CompiledProgram, MultilingualError> {
        println("🌍 Çok dilli derleme başlatılıyor...");
        
        // 1. Dil tespiti
        let detected_language = self.language_detector.detect_language(source)?;
        println("🔍 Tespit edilen dil: {}", detected_language);
        
        // 2. Anahtar kelime çevirisi
        let translated_tokens = self.keyword_translator.translate_keywords(source, &detected_language)?;
        
        // 3. Kültürel adaptasyon
        let adapted_source = self.cultural_adapter.adapt_syntax(&translated_tokens, &detected_language)?;
        
        // 4. Derleme
        match self.compile_with_language(&adapted_source, &detected_language) {
            Ok(result) => {
                println("✅ Çok dilli derleme başarılı");
                Ok(result)
            },
            Err(e) => {
                println("⚠️ Çok dilli derleme başarısız, fallback deneniyor...");
                self.fallback_compiler.compile_english_fallback(source)
            }
        }
    }
    
    fn compile_with_language(&mut self, source: &str, language: &str) -> Result<CompiledProgram, MultilingualError> {
        // Dil spesifik derleme mantığı
        match language {
            "tr" => self.compile_turkish(source),
            "de" => self.compile_german(source),
            "es" => self.compile_spanish(source),
            "fr" => self.compile_french(source),
            "ru" => self.compile_russian(source),
            "zh" => self.compile_chinese(source),
            "ko" => self.compile_korean(source),
            "ja" => self.compile_japanese(source),
            "hi" => self.compile_hindi(source),
            _ => self.compile_english(source)
        }
    }
    
    fn compile_turkish(&mut self, source: &str) -> Result<CompiledProgram, MultilingualError> {
        println("🇹🇷 Türkçe derleme...");
        
        // Türkçe anahtar kelimeleri çevir
        let translated = source
            .replace("fonksiyon", "fn")
            .replace("veri", "data")
            .replace("varyant", "cases")
            .replace("kurallar", "rules")
            .replace("yetenek", "impl")
            .replace("akis", "flow")
            .replace("alan", "space")
            .replace("verilen", "given")
            .replace("etiket", "tag")
            .replace("tanımla", "let")
            .replace("degisken", "var")
            .replace("acik", "open")
            .replace("kontrol", "check")
            .replace("eşleştir", "match")
            .replace("her", "each")
            .replace("dongu", "loop")
            .replace("ver", "yield")
            .replace("kes", "abort")
            .replace("sonraki", "next")
            .replace("dene", "try")
            .replace("yakala", "catch");
        
        // Standart derleyici ile derle
        self.fallback_compiler.english_compiler.compile(&translated)
            .map_err(|e| MultilingualError::CompilationError(e.to_string()))
    }
    
