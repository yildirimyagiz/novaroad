/// Kültürel context
pub struct CulturalContext {
    pub language_code: String,
    pub formal_address: bool,
    pub mathematical_terms: HashMap<String, String>,
    pub programming_concepts: HashMap<String, String>,
    pub greetings: Vec<String>,
    pub farewells: Vec<String>,
}

impl CulturalContext {
    pub fn new(language_code: &str) -> Self {
        let context = match language_code {
            "tr" => Self::turkish_context(),
            "de" => Self::german_context(),
            "es" => Self::spanish_context(),
            "fr" => Self::french_context(),
            "en" => Self::english_context(),
            "ru" => Self::russian_context(),
            "zh" => Self::chinese_context(),
            "ko" => Self::korean_context(),
            "ja" => Self::japanese_context(),
            "hi" => Self::hindi_context(),
            _ => Self::default_context(),
        };
        
        context
    }
    
