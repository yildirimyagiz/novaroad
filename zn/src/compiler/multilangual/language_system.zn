// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova Language System - Nova-unique Dil Yapısı                               ║
// ║  İspanyolca, Rusça, Çince, Korece, Japonca, Hintçe desteği                        ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use std::collections::HashMap;

// ══════════════════════════════════════════════════════════════════════════════
// §1  NOVA-UNIQUE DİL SİSTEMİ
// ══════════════════════════════════════════════════════════════════════════════

/// Nova'nın unique dil sistemi - Rust'tan farklı olarak space kullanır
pub struct LanguageSystem {
    supported_languages: HashMap<String, LanguageConfig>,
    cultural_contexts: HashMap<String, CulturalContext>,
    syntax_patterns: HashMap<String, SyntaxPatterns>,
    keyword_mappings: HashMap<String, KeywordMapping>,
}

impl LanguageSystem {
    pub fn new() -> Self {
        let mut system = LanguageSystem {
            supported_languages: HashMap::new(),
            cultural_contexts: HashMap::new(),
            syntax_patterns: HashMap::new(),
            keyword_mappings: HashMap::new(),
        };
        
        // Önce kullanıcının sistem dilini tespit et
        let user_language = system::detect_user_system_language();
        
        // Kullanıcı dilini ekle (destekleniyorsa)
        if let Some(user_config) = system::create_language_config_for_user(&user_language) {
            system.add_language(user_config);
        }
        
        // Diğer dilleri ekle
        system.initialize_all_languages();
        
        system
    }
    
    fn initialize_all_languages(&mut self) {
        // Mevcut diller
        self.add_language(LanguageConfig::turkish());
        self.add_language(LanguageConfig::german());
        self.add_language(LanguageConfig::spanish());
        self.add_language(LanguageConfig::french());
        self.add_language(LanguageConfig::english());
        
        // Yeni diller
        self.add_language(LanguageConfig::russian());
        self.add_language(LanguageConfig::chinese());
        self.add_language(LanguageConfig::korean());
        self.add_language(LanguageConfig::japanese());
        self.add_language(LanguageConfig::hindi());
    }
    
    /// Kullanıcının sistem dilini otomatik tespit eder
    pub fn detect_user_system_language(&self) -> String {
        // 1. Sistem dilini tespit et
        let system_language = self::get_system_locale();
        
        // 2. Dil kodunu normalize et
        let normalized_language = self::normalize_language_code(&system_language);
        
        // 3. Destekleniyorsa bu dili kullan
        if self.is_language_supported(&normalized_language) {
            return normalized_language;
        }
        
        // 4. Desteklenmiyorsa en yakın dili bul
        self::find_closest_supported_language(&system_language)
    }
    
    /// Kullanıcı için özel dil konfigürasyonu oluştur
    pub fn create_language_config_for_user(&self, language_code: &str) -> Option<LanguageConfig> {
        match language_code {
            "tr" => Some(LanguageConfig::turkish()),
            "de" => Some(LanguageConfig::german()),
            "es" => Some(LanguageConfig::spanish()),
            "fr" => Some(LanguageConfig::french()),
            "en" => Some(LanguageConfig::english()),
            "ru" => Some(LanguageConfig::russian()),
            "zh" => Some(LanguageConfig::chinese()),
            "ko" => Some(LanguageConfig::korean()),
            "ja" => Some(LanguageConfig::japanese()),
            "hi" => Some(LanguageConfig::hindi()),
            // Diğer diller için otomatik konfigürasyon oluştur
            _ => self::create_adaptive_language_config(language_code),
        }
    }
    
    /// Otomatik dil konfigürasyonu oluştur (desteklenmeyen diller için)
    pub fn create_adaptive_language_config(&self, language_code: &str) -> Option<LanguageConfig> {
        let language_name = self::get_language_name(language_code)?;
        let writing_system = self::detect_writing_system(language_code);
        let text_direction = self::detect_text_direction(language_code);
        
        Some(LanguageConfig {
            code: language_code.to_string(),
            name: language_name,
            native_name: language_name,
            keywords: self::generate_adaptive_keywords(language_code),
            cultural_patterns: self::generate_adaptive_cultural_patterns(language_code),
            syntax_patterns: self::generate_adaptive_syntax_patterns(language_code),
            writing_system,
            text_direction,
            keyword_weight: 1.0,
            cultural_weight: 0.8,
            syntax_weight: 0.6,
        })
    }
    
    /// Kullanıcının diline göre kendini otomatik yapılandır
    pub fn auto_configure_for_user(&mut self) -> Result<String, LanguageError> {
        // 1. Kullanıcı dilini tespit et
        let user_language = self.detect_user_system_language();
        
        // 2. Dil zaten ekli mi kontrol et
        if !self.supported_languages.contains_key(&user_language) {
            // 3. Otomatik konfigürasyon oluştur
            if let Some(config) = self.create_language_config_for_user(&user_language) {
                self.add_language(config);
            }
        }
        
        // 4. Kullanıcı dilini varsayılan yap
        self.set_default_language(&user_language)?;
        
        Ok(user_language)
    }
    
    /// Varsayılan dili ayarla
    pub fn set_default_language(&mut self, language_code: &str) -> Result<(), LanguageError> {
        if !self.supported_languages.contains_key(language_code) {
            return Err(LanguageError::UnsupportedLanguage(language_code.to_string()));
        }
        
        // Varsayılan dil ayarla (implementasyona göre)
        self::update_default_language_preference(language_code);
        
        Ok(())
    }
    
    /// Kullanıcı diline göre mesajları yerelleştir
    pub fn localize_message(&self, message_key: &str, user_language: &str) -> String {
        let cultural_context = self.cultural_contexts.get(user_language)
            .unwrap_or_else(|| self.cultural_contexts.get("en").unwrap());
        
        match message_key {
            "welcome" => self::get_welcome_message(cultural_context),
            "error" => self::get_error_message(cultural_context),
            "success" => self::get_success_message(cultural_context),
            "function_created" => self::get_function_created_message(cultural_context),
            "compilation_success" => self::get_compilation_success_message(cultural_context),
            _ => format!("Message: {}", message_key),
        }
    }
    
    /// Kullanıcının diline göre keyword'leri uyarla
    pub fn adapt_keywords_for_user(&self, user_language: &str) -> HashMap<String, String> {
        let keyword_mapping = self.keyword_mappings.get(user_language)
            .unwrap_or_else(|| self.keyword_mappings.get("en").unwrap());
        
        keyword_mapping.mappings.clone()
    }
    
    /// Kullanıcının diline göre syntax highlight'ı uyarla
    pub fn get_syntax_highlighting_for_user(&self, user_language: &str) -> SyntaxHighlightingConfig {
        let syntax_patterns = self.syntax_patterns.get(user_language)
            .unwrap_or_else(|| self.syntax_patterns.get("en").unwrap());
        
        SyntaxHighlightingConfig {
            keywords: syntax_patterns.get_keyword_patterns(),
            operators: syntax_patterns.get_operator_patterns(),
            strings: syntax_patterns.get_string_patterns(),
            comments: syntax_patterns.get_comment_patterns(),
        }
    }
    
    /// Kullanıcının diline göre hata mesajlarını yerelleştir
    pub fn localize_error_message(&self, error: &LanguageError, user_language: &str) -> String {
        let cultural_context = self.cultural_contexts.get(user_language)
            .unwrap_or_else(|| self.cultural_contexts.get("en").unwrap());
        
        match error {
            LanguageError::DetectionFailed(msg) => {
                format!("{}: {}", cultural_context.get_error_text("detection_failed"), msg)
            },
            LanguageError::UnsupportedLanguage(lang) => {
                format!("{}: {}", cultural_context.get_error_text("unsupported_language"), lang)
            },
            LanguageError::InvalidConfiguration(msg) => {
                format!("{}: {}", cultural_context.get_error_text("invalid_configuration"), msg)
            },
        }
    }
    
    /// Kullanıcının diline göre kod tamamlama önerileri
    pub fn get_code_completions_for_user(&self, user_language: &str, partial_input: &str) -> Vec<CodeCompletion> {
        let keyword_mapping = self.keyword_mappings.get(user_language)
            .unwrap_or_else(|| self.keyword_mappings.get("en").unwrap());
        
        let mut completions = Vec::new();
        
        // Keyword tamamlamaları
        for (english_keyword, localized_keyword) in &keyword_mapping.mappings {
            if localized_keyword.starts_with(partial_input) {
                completions.push(CodeCompletion {
                    text: localized_keyword.clone(),
                    description: Some(english_keyword.clone()),
                    completion_type: CompletionType::Keyword,
                });
            }
        }
        
        // Cultural pattern tamamlamaları
        let cultural_context = self.cultural_contexts.get(user_language)
            .unwrap_or_else(|| self.cultural_contexts.get("en").unwrap());
        
        for greeting in &cultural_context.greetings {
            if greeting.starts_with(partial_input) {
                completions.push(CodeCompletion {
                    text: greeting.clone(),
                    description: Some("greeting".to_string()),
                    completion_type: CompletionType::CulturalPattern,
                });
            }
        }
        
        completions
    }
    
    /// Kullanıcının diline göre IDE temasını uyarla
    pub fn adapt_ide_theme_for_user(&self, user_language: &str) -> ThemeAdaptation {
        let cultural_context = self.cultural_contexts.get(user_language)
            .unwrap_or_else(|| self.cultural_contexts.get("en").unwrap());
        
        ThemeAdaptation {
            font_family: self::get_appropriate_font_for_language(user_language),
            text_direction: cultural_context.text_direction.clone(),
            color_scheme: self::get_cultural_color_scheme(user_language),
            ui_layout: self::get_cultural_ui_layout(user_language),
        }
    }
    
    /// Dil desteğini kontrol et
    pub fn is_language_supported(&self, language_code: &str) -> bool {
        self.supported_languages.contains_key(language_code)
    }
    
    /// Desteklenen dilleri listele
    pub fn get_supported_languages(&self) -> Vec<String> {
        self.supported_languages.keys().cloned().collect()
    }
    
    /// Dil bilgisi al
    pub fn get_language_info(&self, language_code: &str) -> Option<&LanguageConfig> {
        self.supported_languages.get(language_code)
    }
}
    
    pub fn add_language(&mut self, config: LanguageConfig) {
        let language_code = config.code.clone();
        
        // Kültürel context ekle
        self.cultural_contexts.insert(
            language_code.clone(),
            CulturalContext::new(&language_code)
        );
        
        // Syntax pattern'leri ekle
        self.syntax_patterns.insert(
            language_code.clone(),
            SyntaxPatterns::new(&language_code)
        );
        
        // Keyword mapping ekle
        self.keyword_mappings.insert(
            language_code.clone(),
            KeywordMapping::new(&language_code)
        );
        
        self.supported_languages.insert(language_code, config);
    }
    
    pub fn detect_language(&self, code: &str) -> Result<String, LanguageError> {
        let mut language_scores = HashMap::new();
        
        for (code, config) in &self.supported_languages {
            let score = self::calculate_language_score(code, config);
            language_scores.insert(code.clone(), score);
        }
        
        let best_language = language_scores
            .iter()
            .max_by(|a, b| a.1.partial_cmp(&b.1).unwrap_or(std::cmp::Ordering::Equal))
            .map(|(lang, _score)| lang.clone())
            .ok_or(LanguageError::DetectionFailed("No language detected".to_string()))?;
        
        Ok(best_language)
    }
    
    fn calculate_language_score(&self, code: &str, config: &LanguageConfig) -> f64 {
        let mut score = 0.0;
        
        // Keyword skorlama
        for keyword in &config.keywords {
            let count = code.matches(keyword).count() as f64;
            score += count * config.keyword_weight;
        }
        
        // Cultural pattern skorlama
        for pattern in &config.cultural_patterns {
            let count = code.matches(pattern).count() as f64;
            score += count * config.cultural_weight;
        }
        
        // Syntax pattern skorlama
        for pattern in &config.syntax_patterns {
            let count = code.matches(pattern).count() as f64;
            score += count * config.syntax_weight;
        }
        
        score
    }
}

/// Dil konfigürasyonu
#[derive(Debug, Clone)]
pub struct LanguageConfig {
    pub code: String,
    pub name: String,
    pub native_name: String,
    pub keywords: Vec<String>,
    pub cultural_patterns: Vec<String>,
    pub syntax_patterns: Vec<String>,
    pub writing_system: WritingSystem,
    pub text_direction: TextDirection,
    pub keyword_weight: f64,
    pub cultural_weight: f64,
    pub syntax_weight: f64,
}

/// Yazı sistemleri
#[derive(Debug, Clone, PartialEq)]
pub enum WritingSystem {
    Latin,      // Türkçe, Almanca, İspanyolca, Fransızca, İngilizce
    Cyrillic,   // Rusça
    Han,        // Çince
    Hangul,     // Korece
    Kana,       // Japonca
    Devanagari, // Hintçe
}

/// Metin yönü
#[derive(Debug, Clone, PartialEq)]
pub enum TextDirection {
    LeftToRight,
    RightToLeft,
    TopToBottom,
}

impl LanguageConfig {
    // Mevcut diller
    pub fn turkish() -> Self {
        LanguageConfig {
            code: "tr".to_string(),
            name: "Turkish".to_string(),
            native_name: "Türkçe".to_string(),
            keywords: vec![
                "fonksiyon".to_string(),
                "eğer".to_string(),
                "değilse".to_string(),
                "için".to_string(),
                "iken".to_string(),
                "döndür".to_string(),
                "yapı".to_string(),
                "sınıf".to_string(),
                "genel".to_string(),
                "özel".to_string(),
                "doğrula".to_string(),
                "eşittir".to_string(),
                "farklı".to_string(),
                "ve".to_string(),
                "veya".to_string(),
            ],
            cultural_patterns: vec![
                r"merhaba".to_string(),
                r"selam".to_string(),
                r"teşekkürler".to_string(),
                r"lütfen".to_string(),
            ],
            syntax_patterns: vec![
                r"fonksiyon\s+\w+\s*\([^)]*\)\s*->".to_string(),
                r"eğer\s+.+\s*\{".to_string(),
                r"değilse\s*\{".to_string(),
                r"için\s+\w+\s+in\s+.+".to_string(),
            ],
            writing_system: WritingSystem::Latin,
            text_direction: TextDirection::LeftToRight,
            keyword_weight: 1.0,
            cultural_weight: 0.8,
            syntax_weight: 0.6,
        }
    }
    
