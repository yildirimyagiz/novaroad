/// Dil hataları
#[derive(Debug, Clone)]
pub enum LanguageError {
    DetectionFailed(String),
    UnsupportedLanguage(String),
    InvalidConfiguration(String),
}

impl std::fmt::Display for LanguageError {
    fn fmt(&self, f: &mut std::fmt::Formatter<'_>) -> std::fmt::Result {
        match self {
            LanguageError::DetectionFailed(msg) => write!(f, "Language detection failed: {}", msg),
            LanguageError::UnsupportedLanguage(lang) => write!(f, "Unsupported language: {}", lang),
            LanguageError::InvalidConfiguration(msg) => write!(f, "Invalid configuration: {}", msg),
        }
    }
}

impl std::error::Error for LanguageError {}
