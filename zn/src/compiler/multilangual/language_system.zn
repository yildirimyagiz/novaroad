/// Syntax pattern'leri
pub struct SyntaxPatterns {
    pub patterns: Vec<SyntaxPattern>,
}

impl SyntaxPatterns {
    pub fn new(language_code: &str) -> Self {
        let patterns = match language_code {
            "tr" => Self::turkish_patterns(),
            "de" => Self::german_patterns(),
            "es" => Self::spanish_patterns(),
            "fr" => Self::french_patterns(),
            "en" => Self::english_patterns(),
            "ru" => Self::russian_patterns(),
            "zh" => Self::chinese_patterns(),
            "ko" => Self::korean_patterns(),
            "ja" => Self::japanese_patterns(),
            "hi" => Self::hindi_patterns(),
            _ => Self::default_patterns(),
        };
        
        patterns
    }
    
    fn turkish_patterns() -> Self {
        SyntaxPatterns {
            patterns: vec![
                SyntaxPattern {
                    name: "function_declaration".to_string(),
                    pattern: r"fonksiyon\s+\w+\s*\([^)]*\)\s*->".to_string(),
                    replacement: r"function $1($2) -> $3".to_string(),
                },
                SyntaxPattern {
                    name: "if_statement".to_string(),
                    pattern: r"eğer\s+.+\s*\{".to_string(),
                    replacement: r"if $1 {".to_string(),
                },
                SyntaxPattern {
                    name: "for_loop".to_string(),
                    pattern: r"için\s+\w+\s+in\s+.+".to_string(),
                    replacement: r"for $1 in $2".to_string(),
                },
            ],
        }
    }
    
    fn german_patterns() -> Self {
        SyntaxPatterns {
            patterns: vec![
                SyntaxPattern {
                    name: "function_declaration".to_string(),
                    pattern: r"Funktion\s+\w+\s*\([^)]*\)\s*->".to_string(),
                    replacement: r"function $1($2) -> $3".to_string(),
                },
                SyntaxPattern {
                    name: "if_statement".to_string(),
                    pattern: r"wenn\s+.+\s*\{".to_string(),
                    replacement: r"if $1 {".to_string(),
                },
                SyntaxPattern {
                    name: "for_loop".to_string(),
                    pattern: r"für\s+\w+\s+in\s+.+".to_string(),
                    replacement: r"for $1 in $2".to_string(),
                },
            ],
        }
    }
    
    fn spanish_patterns() -> Self {
        SyntaxPatterns {
            patterns: vec![
                SyntaxPattern {
                    name: "function_declaration".to_string(),
                    pattern: r"función\s+\w+\s*\([^)]*\)\s*->".to_string(),
                    replacement: r"function $1($2) -> $3".to_string(),
                },
                SyntaxPattern {
                    name: "if_statement".to_string(),
                    pattern: r"si\s+.+\s*\{".to_string(),
                    replacement: r"if $1 {".to_string(),
                },
                SyntaxPattern {
                    name: "for_loop".to_string(),
                    pattern: r"para\s+\w+\s+en\s+.+".to_string(),
                    replacement: r"for $1 in $2".to_string(),
                },
            ],
        }
    }
    
