/// Syntax pattern
#[derive(Debug, Clone)]
pub struct SyntaxPattern {
    pub name: String,
    pub pattern: String,
    pub replacement: String,
}

/// Keyword mapping
pub struct KeywordMapping {
    pub mappings: HashMap<String, String>,
}

impl KeywordMapping {
    pub fn new(language_code: &str) -> Self {
        let mappings = match language_code {
            "tr" => Self::turkish_mappings(),
            "de" => Self::german_mappings(),
            "es" => Self::spanish_mappings(),
            "fr" => Self::french_mappings(),
            "en" => Self::english_mappings(),
            "ru" => Self::russian_mappings(),
            "zh" => Self::chinese_mappings(),
            "ko" => Self::korean_mappings(),
            "ja" => Self::japanese_mappings(),
            "hi" => Self::hindi_mappings(),
            _ => Self::default_mappings(),
        };
        
        mappings
    }
    
    fn turkish_mappings() -> Self {
        let mut mappings = HashMap::new();
        mappings.insert("fonksiyon".to_string(), "function".to_string());
        mappings.insert("eğer".to_string(), "if".to_string());
        mappings.insert("değilse".to_string(), "else".to_string());
        mappings.insert("için".to_string(), "for".to_string());
        mappings.insert("iken".to_string(), "while".to_string());
        mappings.insert("döndür".to_string(), "return".to_string());
        
        KeywordMapping { mappings }
    }
    
    fn german_mappings() -> Self {
        let mut mappings = HashMap::new();
        mappings.insert("Funktion".to_string(), "function".to_string());
        mappings.insert("wenn".to_string(), "if".to_string());
        mappings.insert("sonst".to_string(), "else".to_string());
        mappings.insert("für".to_string(), "for".to_string());
        mappings.insert("während".to_string(), "while".to_string());
        mappings.insert("returniere".to_string(), "return".to_string());
        
        KeywordMapping { mappings }
    }
    
    fn spanish_mappings() -> Self {
        let mut mappings = HashMap::new();
        mappings.insert("función".to_string(), "function".to_string());
        mappings.insert("si".to_string(), "if".to_string());
        mappings.insert("sino".to_string(), "else".to_string());
        mappings.insert("para".to_string(), "for".to_string());
        mappings.insert("mientras".to_string(), "while".to_string());
        mappings.insert("devuelve".to_string(), "return".to_string());
        
        KeywordMapping { mappings }
    }
    
    fn french_mappings() -> Self {
        let mut mappings = HashMap::new();
        mappings.insert("fonction".to_string(), "function".to_string());
        mappings.insert("si".to_string(), "if".to_string());
        mappings.insert("sinon".to_string(), "else".to_string());
        mappings.insert("pour".to_string(), "for".to_string());
        mappings.insert("tant_que".to_string(), "while".to_string());
        mappings.insert("retourne".to_string(), "return".to_string());
        
        KeywordMapping { mappings }
    }
    
    fn english_mappings() -> Self {
        let mut mappings = HashMap::new();
        mappings.insert("function".to_string(), "function".to_string());
        mappings.insert("if".to_string(), "if".to_string());
        mappings.insert("else".to_string(), "else".to_string());
        mappings.insert("for".to_string(), "for".to_string());
        mappings.insert("while".to_string(), "while".to_string());
        mappings.insert("return".to_string(), "return".to_string());
        
        KeywordMapping { mappings }
    }
    
