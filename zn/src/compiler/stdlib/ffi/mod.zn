// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║ Nova FFI - Foreign Function Interface                                        ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

open space c;
open space js;
open space rust;
open space python;

/// C FFI - Call C functions from Nova
open use c::{CFunction, c_call, extern_c};

/// JavaScript FFI - Interop with JavaScript (WASM)
open use js::{JsValue, js_call, wasm_bindgen};

/// Rust FFI - Call Rust libraries
open use rust::{rust_call, link_rust};

/// Python FFI - Call Python from Nova
open use python::{PyObject, py_call};

/// External C function declaration
expose macro extern_c {
    (fn $name:ident($($arg:ident: $ty:ty),*) -> $ret:ty;) => {
        #[link_name = stringify!($name)]
        extern "C" {
            open fn $name($($arg: $ty),*) -> $ret;
        }
    }
}

/// Call JavaScript function from WASM
expose macro js_call {
    ($fn_name:expr, $($arg:expr),*) => {
        unsafe {
            __wasm_js_call($fn_name, &[$($arg),*])
        }
    }
}

/// Example C interop
expose space libc {
    extern_c! {
        fn printf(fmt: *const u8, ...) -> i32;
        fn malloc(size: usize) -> *var u8;
        fn free(ptr: *var u8);
    }
}

/// Example: Call C function
open fn print_from_c(msg: &str) {
    unsafe {
        libc::printf(msg.as_ptr());
    }
}

/// JavaScript interop for WASM
expose space wasm_js {
    use wasm_bindgen::prelude::*;
    
    #[wasm_bindgen]
    extern "C" {
        fn alert(s: &str);
        
        #[wasm_bindgen(js_namespace = console)]
        fn log(s: &str);
        
        #[wasm_bindgen(js_namespace = Math)]
        fn random() -> f64;
    }
    
    open fn show_alert(msg: &str) {
        alert(msg);
    }
    
    open fn console_log(msg: &str) {
        log(msg);
    }
}

/// Rust library linking
expose macro link_rust {
    ($crate_name:ident) => {
        #[link(name = stringify!($crate_name))]
        extern "Rust" {}
    }
}
