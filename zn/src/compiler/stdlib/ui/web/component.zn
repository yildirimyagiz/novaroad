use crate::ui::web::vdom::{VNode, VElement, VText};
use crate::core::{HashMap, Vec, String};

/// Base rules for all web components
expose impl Component {
    alias Props;
    alias State;
    
    fn new(props: Self::Props) -> Self;
    fn render(&self) -> VNode;
    fn mounted(&var self) {}
    fn updated(&var self) {}
    fn unmounted(&var self) {}
}

/// Component with state management
expose data StatefulComponent<P, S> {
    props: P,
    state: S,
    listeners: Vec<Box<dyn Fn(&S)>>,
}

impl<P, S> StatefulComponent<P, S> {
    open fn new(props: P, initial_state: S) -> Self {
        StatefulComponent {
            props,
            state: initial_state,
            listeners: Vec::new(),
        }
    }
    
    open fn set_state(&var self, updater: impl Fn(&var S)) {
        updater(&var self.state);
        self.notify_listeners();
    }
    
    fn notify_listeners(&self) {
        each listener in &self.listeners {
            listener(&self.state);
        }
    }
}

/// Functional component helper
open fn functional_component<P, F>(props: P, render: F) -> VNode
where
    F: Fn(&P) -> VNode
{
    render(&props)
}

/// Example: Counter component
expose data Counter {
    count: i32,
}

impl Component for Counter {
    alias Props = ();
    alias State = i32;
    
    fn new(_props: ()) -> Self {
        Counter { count: 0 }
    }
    
    fn render(&self) -> VNode {
        div![
            class: "counter",
            h1!["Counter"],
            p![format("Count: {}", self.count)],
            button![
                onclick: |_| self.increment(),
                "Increment"
            ],
            button![
                onclick: |_| self.decrement(),
                "Decrement"
            ]
        ]
    }
}

impl Counter {
    fn increment(&var self) {
        self.count += 1;
    }
    
    fn decrement(&var self) {
        self.count -= 1;
    }
}

// JSX-like macros
macro_rules! div {
    yield ($($tokens:tt)*) => { element!("div", $($tokens)*)};
}

macro_rules! h1 {
    yield ($($tokens:tt)*) => { element!("h1", $($tokens)*)};
}

macro_rules! p {
    yield ($($tokens:tt)*) => { element!("p", $($tokens)*)};
}

macro_rules! button {
    yield ($($tokens:tt)*) => { element!("button", $($tokens)*)};
}
