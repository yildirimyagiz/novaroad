use crate::ui::native::{Widget, Layout, Event};
use crate::core::{Vec, String, Box};

/// Mobile application structure
expose data MobileApp {
    title: String,
    root_view: Box<dyn View>,
    navigator: Navigator,
    platform: Platform,
}

expose cases Platform {
    iOS,
    Android,
    Unknown,
}

/// Core view rules
expose impl View {
    fn render(&self) -> Widget;
    fn on_event(&var self, event: Event);
    fn layout(&self) -> Layout;
}

/// Navigation controller
expose data Navigator {
    stack: Vec<Box<dyn View>>,
}

impl Navigator {
    open fn new() -> Self {
        Navigator {
            stack: Vec::new(),
        }
    }
    
    open fn push(&var self, view: Box<dyn View>) {
        self.stack.push(view);
    }
    
    open fn pop(&var self) -> Option<Box<dyn View>> {
        self.stack.pop()
    }
    
    open fn current(&self) -> Option<&Box<dyn View>> {
        self.stack.last()
    }
}

/// Common mobile widgets
open fn Text(content: &str) -> Widget {
    Widget::Text {
        content: content.into(),
        font_size: 16.0,
        color: Color::black(),
    }
}

open fn Button(label: &str, on_press: impl Fn() + 'static) -> Widget {
    Widget::Button {
        label: label.into(),
        on_press: Box::new(on_press),
        style: ButtonStyle::default(),
    }
}

open fn VStack(children: Vec<Widget>) -> Widget {
    Widget::VStack {
        children,
        spacing: 8.0,
        alignment: Alignment::Center,
    }
}

open fn HStack(children: Vec<Widget>) -> Widget {
    Widget::HStack {
        children,
        spacing: 8.0,
        alignment: Alignment::Center,
    }
}

open fn ScrollView(content: Widget) -> Widget {
    Widget::ScrollView {
        content: Box::new(content),
        direction: ScrollDirection::Vertical,
    }
}

open fn List<T>(items: Vec<T>, render: impl Fn(&T) -> Widget) -> Widget {
    let children = items.iter().map(render).collect();
    Widget::List { children }
}
