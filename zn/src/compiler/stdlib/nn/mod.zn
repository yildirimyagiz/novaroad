open space tensor;
open space layer;
open space activation;
open space optimizer;
open space loss;

open use tensor::Tensor;
open use layer::{Layer, Linear, Conv2d, MaxPool2d};
open use activation::{ReLU, Sigmoid, Tanh, Softmax};
open use optimizer::{SGD, Adam, AdamW};
open use loss::{MSELoss, CrossEntropyLoss};

/// Neural network module
expose data Module {
    layers: Vec<Box<dyn Layer>>,
    training: bool,
}

impl Module {
    open fn new() -> Self {
        Module {
            layers: Vec::new(),
            training: true,
        }
    }
    
    open fn add_layer(&var self, layer: Box<dyn Layer>) -> &var Self {
        self.layers.push(layer);
        self
    }
    
    open fn forward(&self, input: &Tensor) -> Tensor {
        var output = input.clone();
        each layer in &self.layers {
            output = layer.forward(&output);
        }
        output
    }
    
    open fn backward(&var self, grad: &Tensor) -> Tensor {
        var grad_output = grad.clone();
        each layer in self.layers.iter_mut().rev() {
            grad_output = layer.backward(&grad_output);
        }
        grad_output
    }
    
    open fn train(&var self) {
        self.training = true;
    }
    
    open fn eval(&var self) {
        self.training = false;
    }
    
    open fn parameters(&self) -> Vec<&Tensor> {
        var params = Vec::new();
        each layer in &self.layers {
            params.extend(layer.parameters());
        }
        params
    }
}

/// Example: Simple MLP
open fn create_mlp(input_size: usize, hidden_size: usize, output_size: usize) -> Module {
    var model = Module::new();
    model
        .add_layer(Box::new(Linear::new(input_size, hidden_size)))
        .add_layer(Box::new(ReLU::new()))
        .add_layer(Box::new(Linear::new(hidden_size, output_size)))
        .add_layer(Box::new(Softmax::new()));
    model
}
