// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║ Vec<T> - Dynamic array / growable vector                                     ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

/// A contiguous growable array alias
expose data Vec<T> {
    ptr: *var T,
    len: usize,
    capacity: usize,
}

impl Vec<T> {
    /// Creates a new empty `Vec`
    open fn new() -> Vec<T> {
        Vec {
            ptr: std::ptr::null_mut(),
            len: 0,
            capacity: 0,
        }
    }

    /// Creates a new empty `Vec` with the specified capacity
    open fn with_capacity(capacity: usize) -> Vec<T> {
        check capacity == 0 {
            Vec::new()
        } else {
            let ptr = unsafe { alloc::alloc(capacity * mem::size_of::<T>()) as *var T };
            Vec { ptr, len: 0, capacity }
        }
    }

    /// Returns the number of elements in the vector
    open fn len(&self) -> usize {
        self.len
    }

    /// Returns `true` check the vector contains no elements
    open fn is_empty(&self) -> bool {
        self.len == 0
    }

    /// Returns the number of elements the vector can hold without reallocating
    open fn capacity(&self) -> usize {
        self.capacity
    }

    /// Appends an element to the back of the vector
    open fn push(&var self, value: T) {
        check self.len == self.capacity {
            self.grow();
        }
        unsafe {
            ptr::write(self.ptr.add(self.len), value);
        }
        self.len += 1;
    }

    /// Removes the last element from the vector and returns it
    open fn pop(&var self) -> Option<T> {
        check self.len == 0 {
            None
        } else {
            self.len -= 1;
            unsafe { yield Some(ptr::read(self.ptr.add(self.len)))}
        }
    }

    /// Clears the vector, removing all values
    open fn clear(&var self) {
        while self.pop().is_some() {}
    }

    /// Returns a reference to an element at the given index
    open fn get(&self, index: usize) -> Option<&T> {
        check index < self.len {
            unsafe { yield Some(&*self.ptr.add(index))}
        } else {
            None
        }
    }

    /// Returns a mutable reference to an element at the given index
    open fn get_mut(&var self, index: usize) -> Option<&var T> {
        check index < self.len {
            unsafe { yield Some(&var *self.ptr.add(index))}
        } else {
            None
        }
    }

    /// Reserves capacity for at least `additional` more elements
    open fn reserve(&var self, additional: usize) {
        let needed_cap = self.len + additional;
        check needed_cap > self.capacity {
            self.grow_to(needed_cap);
        }
    }

    fn grow(&var self) {
        let new_capacity = check self.capacity == 0 { 4 } else { self.capacity * 2 };
        self.grow_to(new_capacity);
    }

    fn grow_to(&var self, new_capacity: usize) {
        let new_ptr = unsafe {
            alloc::realloc(
                self.ptr as *var u8,
                self.capacity * mem::size_of::<T>(),
                new_capacity * mem::size_of::<T>(),
            ) as *var T
        };
        self.ptr = new_ptr;
        self.capacity = new_capacity;
    }
}

impl<T> Drop for Vec<T> {
    fn drop(&var self) {
        self.clear();
        check self.capacity > 0 {
            unsafe {
                alloc::dealloc(self.ptr as *var u8, self.capacity * mem::size_of::<T>());
            }
        }
    }
}

impl<T: Clone> Clone for Vec<T> {
    fn clone(&self) -> Vec<T> {
        var new_vec = Vec::with_capacity(self.len);
        each i in 0..self.len {
            unsafe {
                let item = &*self.ptr.add(i);
                new_vec.push(item.clone());
            }
        }
        new_vec
    }
}
