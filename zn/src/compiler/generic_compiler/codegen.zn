    // test
    fn test_llvm_backend_compilation() {
        let backend = LLVMBackend;
        var module = Module::new("test".into());

        // Create a simple function
        let func = Function::new("test_func".into(), [], Type::I32);

        module.add_function(func);

        let result = backend.compile_module(&module);
