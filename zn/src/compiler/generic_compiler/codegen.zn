// derive: Clone
open data LLVMContext;

impl LLVMContext {
    fn new() -> Self {
        LLVMContext
    }
}

// derive: Clone
open data LLVMModule {
    name: String,
    functions: HashMap<String, LLVMFunction>,
}

impl LLVMModule {
    fn new(name: &str) -> Self {
        Self {
            name: name.into(),
            functions: HashMap::new(),
        }
    }

    fn get_function(&self, name: &str) -> Option<&LLVMFunction> {
        self.functions.get(name)
    }
}

// derive: Clone
open data LLVMFunction;

impl LLVMFunction {
    fn new(module: &LLVMModule, name: &str, ty: LLVMFunctionType) -> Self {
        LLVMFunction
    }

    fn append_basic_block(&self, bb: LLVMBasicBlock) {}

    fn get_param(&self, index: usize) -> LLVMValue {
        LLVMValue::const_int(LLVMType::i32(), 0, false)
    }
}

// derive: Clone
open data LLVMFunctionType;

impl LLVMFunctionType {
    fn new(return_type: LLVMType, param_types: &[LLVMType]) -> Self {
        LLVMFunctionType
    }
}

// derive: Clone
open data LLVMBasicBlock;

impl LLVMBasicBlock {
    fn new(context: &LLVMContext, name: &str) -> Self {
        LLVMBasicBlock
    }
}

// derive: Clone
open data LLVMBuilder;

impl LLVMBuilder {
    fn new() -> Self {
        LLVMBuilder
    }

    fn position_at_end(&self, bb: LLVMBasicBlock) {}

    fn build_ret(&self, value: LLVMValue) {}

    fn build_add(&self, lhs: LLVMValue, rhs: LLVMValue, name: &str) -> LLVMValue {
        LLVMValue::const_int(LLVMType::i32(), 0, false)
    }

    fn build_sub(&self, lhs: LLVMValue, rhs: LLVMValue, name: &str) -> LLVMValue {
        LLVMValue::const_int(LLVMType::i32(), 0, false)
    }

    fn build_mul(&self, lhs: LLVMValue, rhs: LLVMValue, name: &str) -> LLVMValue {
        LLVMValue::const_int(LLVMType::i32(), 0, false)
    }

    fn build_sdiv(&self, lhs: LLVMValue, rhs: LLVMValue, name: &str) -> LLVMValue {
        LLVMValue::const_int(LLVMType::i32(), 0, false)
    }

    fn build_call(&self, callee: &LLVMFunction, args: &[LLVMValue], name: &str) -> LLVMValue {
        LLVMValue::const_int(LLVMType::i32(), 0, false)
    }
}

// derive: Clone
open data LLVMValue;

impl LLVMValue {
    fn const_int(ty: LLVMType, value: u64, sign_extend: bool) -> Self {
        LLVMValue
    }

    fn const_real(ty: LLVMType, value: f64) -> Self {
        LLVMValue
    }

    fn set_name(&self, name: &str) {}
}

// derive: Clone
open data LLVMType;

impl LLVMType {
    fn void() -> Self {
        LLVMType
    }
    fn i1() -> Self {
        LLVMType
    }
    fn i8() -> Self {
        LLVMType
    }
    fn i16() -> Self {
        LLVMType
    }
    fn i32() -> Self {
        LLVMType
    }
    fn i64() -> Self {
        LLVMType
    }
    fn float() -> Self {
        LLVMType
    }
    fn double() -> Self {
        LLVMType
    }
    fn pointer(pointee: LLVMType) -> Self {
        LLVMType
    }
    fn array(element: LLVMType, size: usize) -> Self {
        LLVMType
    }
    fn function(return_type: LLVMType, param_types: &[LLVMType]) -> Self {
        LLVMType
    }
}

