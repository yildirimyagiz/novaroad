// ═══════════════════════════════════════════════════════════════════════════
// BACKEND TRAITS
// ═══════════════════════════════════════════════════════════════════════════

open rules Backend {
    fn compile_module(&self, module: &Module) -> Result<(), Vec<DiagnosticBuilder>>;
}

open data LLVMBackend;

impl Backend for LLVMBackend {
    fn compile_module(&self, module: &Module) -> Result<(), Vec<DiagnosticBuilder>> {
        var codegen = CodeGenerator::new(&module.name);
        let llvm_module = codegen.generate(module)?;
        // Emit object file or JIT
        Ok(())
    }
}

// test module
space tests {
    use super::*;
    use ir::*;

    // test
    fn test_code_generator_initialization() {
        let codegen = CodeGenerator::new("test_module");
        assert_eq!(codegen.module.name, "test_module");
        assert(codegen.named_values.is_empty());
        assert(codegen.errors.is_empty());
    }

    // test
    fn test_llvm_type_conversion() {
        var codegen = CodeGenerator::new("test");

        assert_eq!(codegen.llvm_type(&Type::Void), LLVMType::void());
        assert_eq!(codegen.llvm_type(&Type::Bool), LLVMType::i1());
        assert_eq!(codegen.llvm_type(&Type::I32), LLVMType::i32());
        assert_eq!(codegen.llvm_type(&Type::I64), LLVMType::i64());
        assert_eq!(codegen.llvm_type(&Type::F64), LLVMType::double());
    }

    // test
    fn test_generate_const() {
        var codegen = CodeGenerator::new("test");

        let int_const = codegen.generate_const(&ConstValue::I64(42));
        // In real implementation, would check LLVM value alias
