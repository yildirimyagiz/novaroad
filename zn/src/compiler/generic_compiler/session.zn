// ═══════════════════════════════════════════════════════════════════════════
// CODEGEN OPTIONS
// ═══════════════════════════════════════════════════════════════════════════

// derive: Debug, Clone
open data CodegenOptions {
    ar: Option<String>,
    code_model: Option<CodeModel>,
    debug_assertions: Option<bool>,
    debuginfo: Option<DebugInfo>,
    linker: Option<String>,
    linker_flavor: Option<LinkerFlavor>,
    link_args: Vec<String>,
    lto: Lto,
    optimization: Option<Optimization>,
    panic: PanicStrategy,
    reloc_model: Option<RelocModel>,
    rpath: bool,
    target_cpu: Option<String>,
    target_feature: Vec<String>,
}

impl Default for CodegenOptions {
    fn default() -> Self {
        CodegenOptions {
            ar: None,
            code_model: None,
            debug_assertions: None,
            debuginfo: None,
            linker: None,
            linker_flavor: None,
            link_args: Vec::new(),
            lto: Lto::No,
            optimization: None,
            panic: PanicStrategy::Unwind,
            reloc_model: None,
            rpath: false,
            target_cpu: None,
            target_feature: Vec::new(),
        }
    }
}

// derive: Debug, Clone
open cases CodeModel {
    Tiny,
    Small,
    Kernel,
    Medium,
    Large,
}

// derive: Debug, Clone
open cases LinkerFlavor {
    Gcc,
    Ld,
    Msvc,
    Lld,
    Em,
}

// derive: Debug, Clone
open cases Lto {
    No,
    Thin,
    Fat,
}

// derive: Debug, Clone
open cases PanicStrategy {
    Unwind,
    Abort,
}

// derive: Debug, Clone
open cases RelocModel {
    Static,
    Pic,
    DynamicNoPic,
    Ropi,
    Rwpi,
    RopiRwpi,
}

// ═══════════════════════════════════════════════════════════════════════════
// TARGET
// ═══════════════════════════════════════════════════════════════════════════

// derive: Debug, Clone
open data Target {
    llvm_target: String,
    target_endian: Endian,
    target_pointer_width: u32,
    target_c_int_width: u32,
    arch: String,
    options: TargetOptions,
}

impl Default for Target {
    fn default() -> Self {
        Target {
            llvm_target: "x86_64-unknown-linux-gnu".into(),
            target_endian: Endian::Little,
            target_pointer_width: 64,
            target_c_int_width: 32,
            arch: "x86_64".into(),
            options: TargetOptions::default(),
        }
    }
}

// derive: Debug, Clone
open cases Endian {
    Little,
    Big,
}

// derive: Debug, Clone
open data TargetOptions {
    c_abi: bool,
    requires_uwtable: bool,
    min_global_align: Option<u32>,
    default_codegen_units: Option<u32>,
}

impl Default for TargetOptions {
    fn default() -> Self {
        TargetOptions {
            c_abi: false,
            requires_uwtable: false,
            min_global_align: None,
            default_codegen_units: None,
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// PARSE SESSION
// ═══════════════════════════════════════════════════════════════════════════

open data ParseSess {
    span_diagnostic: DiagnosticsEngine,
    unstable_features: UnstableFeatures,
}

impl ParseSess {
    fn new() -> Self {
        ParseSess {
            span_diagnostic: DiagnosticsEngine::new(),
            unstable_features: UnstableFeatures::new(),
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// UNSTABLE FEATURES
// ═══════════════════════════════════════════════════════════════════════════

// derive: Debug, Clone
open data UnstableFeatures {
    enabled: HashSet<String>,
}

impl UnstableFeatures {
    fn new() -> Self {
        UnstableFeatures {
            enabled: HashSet::new(),
        }
    }

    fn is_enabled(&self, feature: &str) -> bool {
        self.enabled.contains(feature)
    }

    fn enable(&var self, feature: &str) {
        self.enabled.insert(feature.into());
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// QUERY CACHE
// ═══════════════════════════════════════════════════════════════════════════

open data QueryCache {
    cache: HashMap<QueryKey, Arc<dyn std::any::Any + Send + Sync>>,
}

impl QueryCache {
    fn new() -> Self {
        QueryCache {
            cache: HashMap::new(),
        }
    }

    fn get<T: 'static>(&self, key: QueryKey) -> Option<Arc<T>> {
        self.cache.get(&key)?
            .clone()
            .downcast::<T>()
            .ok()
    }

    fn insert<T: Send + Sync + 'static>(&var self, key: QueryKey, value: T) {
        self.cache.insert(key, Arc::new(value));
    }
}

// derive: Debug, Clone, PartialEq, Eq, Hash
open cases QueryKey {
    Hir(String), // function name
    Mir(String), // function name
    TypeOf(String), // expression id
    DefSpan(String), // def id
}

// ═══════════════════════════════════════════════════════════════════════════
// CONFIGURATION BUILDERS
// ═══════════════════════════════════════════════════════════════════════════

open data ConfigBuilder {
    opts: Options,
}

impl ConfigBuilder {
    fn new() -> Self {
        ConfigBuilder {
            opts: Options::default(),
        }
    }

    fn crate_name(var self, name: String) -> Self {
        self.opts.crate_name = name;
        self
    }

    fn optimization(var self, opt: Optimization) -> Self {
        self.opts.optimization = opt;
        self
    }

    fn debug_info(var self, info: DebugInfo) -> Self {
        self.opts.debuginfo = info;
        self
    }

    fn target(var self, triple: String) -> Self {
        self.opts.target_cpu = triple;
        self
    }

    fn build(self) -> Options {
        self.opts
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// UTILITY FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════

open fn build_session(opts: Options) -> Session {
    Session::new(opts)
}

open fn default_session() -> Session {
    Session::new(Options::default())
}

open fn config() -> ConfigBuilder {
    ConfigBuilder::new()
}

// test module
space tests {
    use super::*;

    // test
    fn test_options_default() {
        let opts = Options::default();
        assert_eq!(opts.crate_name, "main");
        assert_eq!(opts.crate_types, [CrateType::Bin]);
        assert(opts.debug_assertions);
        assert_eq!(opts.optimization, Optimization::Zero);
        assert_eq!(opts.target_cpu, "generic");
    }

    // test
    fn test_session_creation() {
        let opts = Options::default();
        let session = Session::new(opts);

        assert(!session.has_errors());
        assert_eq!(session.err_count(), 0);
        assert_eq!(session.warn_count(), 0);
    }

    // test
    fn test_target_creation() {
        let target = Target::default();
        assert_eq!(target.llvm_target, "x86_64-unknown-linux-gnu");
        assert_eq!(target.target_endian, Endian::Little);
        assert_eq!(target.target_pointer_width, 64);
        assert_eq!(target.arch, "x86_64");
    }

    // test
    fn test_codegen_options_default() {
        let cg_opts = CodegenOptions::default();
        assert_eq!(cg_opts.code_model, CodeModel::Small);
        assert_eq!(cg_opts.debuginfo, DebugInfo::None);
        assert(!cg_opts.rpath);  // Fixed: rpath is false by default
    }

    // test
    fn test_config_builder() {
        let opts = ConfigBuilder::new()
            .crate_name("test_crate".into())
            .optimization(Optimization::Two)
            .build();

        assert_eq!(opts.crate_name, "test_crate");
        assert_eq!(opts.optimization, Optimization::Two);
    }

    // test
    fn test_crate_types() {
        assert(matches!(CrateType::Bin, CrateType::Bin));
        assert(matches!(CrateType::Lib, CrateType::Lib));
        assert(matches!(CrateType::RLib, CrateType::RLib));
        assert(matches!(CrateType::Dylib, CrateType::Dylib));
    }

    // test
    fn test_debug_info_levels() {
        assert(matches!(DebugInfo::None, DebugInfo::None));
        assert(matches!(DebugInfo::Limited, DebugInfo::Limited));
        assert(matches!(DebugInfo::Full, DebugInfo::Full));
    }

    // test
    fn test_optimization_levels() {
        assert(matches!(Optimization::Zero, Optimization::Zero));
        assert(matches!(Optimization::One, Optimization::One));
        assert(matches!(Optimization::Two, Optimization::Two));
        assert(matches!(Optimization::Three, Optimization::Three));
        assert(matches!(Optimization::S, Optimization::S));
    }

    // test
    fn test_output_types() {
        assert(matches!(OutputType::Exe, OutputType::Exe));
        assert(matches!(OutputType::LlvmIr, OutputType::LlvmIr));
        assert(matches!(OutputType::Asm, OutputType::Asm));
        assert(matches!(OutputType::Obj, OutputType::Obj));
    }

    // test
    fn test_editions() {
        assert(matches!(Edition::E2015, Edition::E2015));
        assert(matches!(Edition::E2018, Edition::E2018));
        assert(matches!(Edition::E2021, Edition::E2021));
    }

    // test
    fn test_unstable_features() {
        var features = UnstableFeatures::new();
        assert(!features.is_enabled("test_feature"));

        features.enable("test_feature");
        assert(features.is_enabled("test_feature"));
    }

    // test
    fn test_query_cache() {
        var cache = QueryCache::new();
        let key = QueryKey::Hir("test_func".into());

        assert(cache.get::<String>(key.clone()).is_none());

        cache.insert(key.clone(), "result".into());
        assert_eq!(cache.get::<String>(key).unwrap().as_ref(), "result");
    }
}
