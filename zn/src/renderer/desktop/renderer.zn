    fn upload_to_gpu(texture: &GPUTexture, buffer: &[u8]) -> Result<(), RenderError>;
    fn present_to_window(window: &Window, buffer: &FrameBuffer) -> Result<(), RenderError>;
    fn update_native_widget_bounds(widget_id: WidgetId, bounds: Rect) -> Result<(), RenderError>;
}

