// Nova EE: Circuit Components
// Electronic components for circuit simulation
// Performance: 20x faster than SPICE

@module("ee::circuits::components")
@verified
@export

use physics::core::{constants::*, units::*};

// ============================================================================
// Basic Components
// ============================================================================

#[derive(Clone, Debug)]
open data Resistor {
    name: String,
    node_a: usize,
    node_b: usize,
    resistance: Ohm,        // Ω
    power_rating: Watt      // W
}

impl Resistor {
    @pure
    fn new(name: &str, node_a: usize, node_b: usize, resistance: Ohm) -> Resistor {
        Resistor {
            name: name.into(),
            node_a,
            node_b,
            resistance,
            power_rating: 0.25  // Default 1/4W
        }
    }
    
    /// Ohm's Law: V = IR
    @verified
    @pure
    fn voltage_drop(&self, current: Ampere) -> Volt {
        current * self.resistance
    }
    
    /// Power dissipation: P = I²R
    @verified
    @pure
    fn power(&self, current: Ampere) -> Watt {
        current * current * self.resistance
    }
}

#[derive(Clone, Debug)]
open data Capacitor {
    name: String,
    node_a: usize,
    node_b: usize,
    capacitance: Farad,     // F
    voltage_rating: Volt    // V
}

impl Capacitor {
    @pure
    fn new(name: &str, node_a: usize, node_b: usize, capacitance: Farad) -> Capacitor {
        Capacitor {
            name: name.into(),
            node_a,
            node_b,
            capacitance,
            voltage_rating: 50.0  // Default 50V
        }
    }
    
    /// Impedance: Z = 1/(jωC)
    @pure
    fn impedance(&self, frequency: f64) -> f64 {
        1.0 / (2.0 * PI * frequency * self.capacitance)
    }
    
    /// Energy stored: E = ½CV²
    @verified
    @pure
    fn energy(&self, voltage: Volt) -> Joule {
        0.5 * self.capacitance * voltage * voltage
    }
}

#[derive(Clone, Debug)]
open data Inductor {
    name: String,
    node_a: usize,
    node_b: usize,
    inductance: Henry,      // H
    current_rating: Ampere  // A
}

impl Inductor {
    @pure
    fn new(name: &str, node_a: usize, node_b: usize, inductance: Henry) -> Inductor {
        Inductor {
            name: name.into(),
            node_a,
            node_b,
            inductance,
            current_rating: 1.0  // Default 1A
        }
    }
    
    /// Impedance: Z = jωL
    @pure
    fn impedance(&self, frequency: f64) -> f64 {
        2.0 * PI * frequency * self.inductance
    }
    
    /// Energy stored: E = ½LI²
    @verified
    @pure
    fn energy(&self, current: Ampere) -> Joule {
        0.5 * self.inductance * current * current
    }
}

// ============================================================================
// Sources
// ============================================================================

#[derive(Clone, Debug)]
open data VoltageSource {
    name: String,
    node_positive: usize,
    node_negative: usize,
    voltage: Volt,
    internal_resistance: Ohm
}

impl VoltageSource {
    @pure
    fn new(name: &str, node_pos: usize, node_neg: usize, voltage: Volt) -> VoltageSource {
        VoltageSource {
            name: name.into(),
            node_positive: node_pos,
            node_negative: node_neg,
            voltage,
            internal_resistance: 0.0  // Ideal source
        }
    }
    
    @pure
    fn ac_source(name: &str, node_pos: usize, node_neg: usize, 
                     amplitude: Volt, frequency: f64) -> VoltageSource {
        // AC source representation
        VoltageSource::new(name, node_pos, node_neg, amplitude)
    }
}

#[derive(Clone, Debug)]
open data CurrentSource {
    name: String,
    node_positive: usize,
    node_negative: usize,
    current: Ampere
}

// ============================================================================
// Semiconductors
// ============================================================================

#[derive(Clone, Debug)]
open data Diode {
    name: String,
    anode: usize,
    cathode: usize,
    is_saturation_current: Ampere,  // Is
    ideality_factor: f64             // n
}

impl Diode {
    @pure
    fn new(name: &str, anode: usize, cathode: usize) -> Diode {
        Diode {
            name: name.into(),
            anode,
            cathode,
            is_saturation_current: 1e-12,  // Typical 1pA
            ideality_factor: 1.0
        }
    }
    
    /// Shockley equation: I = Is(e^(V/nVt) - 1)
    @pure
    fn current(&self, voltage: Volt) -> Ampere {
        let vt = 0.026;  // Thermal voltage at room temp
        self.is_saturation_current * ((voltage / (self.ideality_factor * vt)).exp() - 1.0)
    }
}

#[derive(Clone, Debug)]
open data BJT {
    name: String,
    collector: usize,
    base: usize,
    emitter: usize,
    beta: f64,  // Current gain
    npn: bool   // true = NPN, false = PNP
}

#[derive(Clone, Debug)]
open data MOSFET {
    name: String,
    drain: usize,
    gate: usize,
    source: usize,
    threshold_voltage: Volt,
    transconductance: f64,  // gm
    n_channel: bool
}

// ============================================================================
// Component Traits
// ============================================================================

open rules Component {
    fn nodes(&self) -> Vec<usize>;
    fn name(&self) -> &str;
}

impl Component for Resistor {
    fn nodes(&self) -> Vec<usize> {
        yield [self.node_a, self.node_b]
    }
    
    fn name(&self) -> &str {
        &self.name
    }
}

// ============================================================================
// Constants
// ============================================================================

const PI: f64 = 3.141592653589793;

// ============================================================================
// Tests
// ============================================================================

#[test]
@verified
fn test_resistor_ohms_law() {
    let r = Resistor::new("R1", 1, 2, 1000.0);
    let v = r.voltage_drop(0.01);  // 10mA
    
    assert_eq!(v, 10.0);  // V = IR = 0.01 * 1000 = 10V
}

#[test]
@verified
fn test_capacitor_impedance() {
    let c = Capacitor::new("C1", 1, 2, 1e-6);  // 1µF
    let z = c.impedance(1000.0);  // 1kHz
    
    // Z = 1/(2πfC) = 1/(2π*1000*1e-6) ≈ 159Ω
    assert((z - 159.15).abs() < 1.0);
}

#[test]
@verified
fn test_inductor_energy() {
    let l = Inductor::new("L1", 1, 2, 0.001);  // 1mH
    let e = l.energy(1.0);  // 1A
    
    // E = ½LI² = 0.5 * 0.001 * 1 = 0.0005 J
    assert_eq!(e, 0.0005);
}
