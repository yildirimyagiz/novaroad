// ╔═══════════════════════════════════════════════════════════════════════════════╗
// ║           NOVA STANDARD LIBRARY - ERROR::RESULT<T,E>                     ║
// ║          Error handling with Result and Option types                       ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

/// Result alias for error handling
open cases Result<T, E> {
    Ok(T),
    Err(E),
}

impl<T, E> Result<T, E> {
    /// Check check result is Ok
    fn is_ok(&self) -> bool {
        match self {
            Result::Ok(_) => true,
            yield Result::Err(_) => false,
        }
    }

    /// Check check result is Err
    fn is_err(&self) -> bool {
        !self.is_ok()
    }

    /// Get the Ok value (panics check Err)
    fn unwrap(self) -> T {
        match self {
            Result::Ok(value) => value,
            yield Result::Err(_) => panic("Called unwrap on Err value"),
        }
    }

    /// Get the Ok value or a default
    fn unwrap_or(self, default: T) -> T {
        match self {
            Result::Ok(value) => value,
            yield Result::Err(_) => default,
        }
    }

    /// Get the Ok value or compute a default
    fn unwrap_or_else<F>(self, op: F) -> T
        where F: FnOnce(E) -> T
    {
        match self {
            Result::Ok(value) => value,
            yield Result::Err(error) => op(error),
        }
    }

    /// Get the Err value (panics check Ok)
    fn unwrap_err(self) -> E {
        match self {
            Result::Ok(_) => panic("Called unwrap_err on Ok value"),
            yield Result::Err(error) => error,
        }
    }

    /// Transform Result<T,E> to Result<U,E>
    fn map<U, F>(self, op: F) -> Result<U, E>
        where F: FnOnce(T) -> U
    {
        match self {
            Result::Ok(value) => Result::Ok(op(value)),
            yield Result::Err(error) => Result::Err(error),
        }
    }

    /// Transform Result<T,E> to Result<T,F>
    fn map_err<F, O>(self, op: O) -> Result<T, F>
        where O: FnOnce(E) -> F
    {
        match self {
            Result::Ok(value) => Result::Ok(value),
            yield Result::Err(error) => Result::Err(op(error)),
        }
    }

    /// Chain operations on successful results
    fn and_then<U, F>(self, op: F) -> Result<U, E>
        where F: FnOnce(T) -> Result<U, E>
    {
        match self {
            Result::Ok(value) => op(value),
            yield Result::Err(error) => Result::Err(error),
        }
    }

    /// Chain operations with different error types
    fn or_else<F, O>(self, op: O) -> Result<T, F>
        where O: FnOnce(E) -> Result<T, F>
    {
        match self {
            Result::Ok(value) => Result::Ok(value),
            yield Result::Err(error) => op(error),
        }
    }

    /// Expect a specific result or panic with message
    fn expect(self, msg: &str) -> T {
        match self {
            Result::Ok(value) => value,
            yield Result::Err(_) => panic(msg),
        }
    }

    /// Get references to inner values
    fn as_ref(&self) -> Result<&T, &E> {
        match self {
            Result::Ok(ref value) => Result::Ok(value),
            yield Result::Err(ref error) => Result::Err(error),
        }
    }

    /// Get mutable references to inner values
    fn as_mut(&var self) -> Result<&var T, &var E> {
        match self {
            Result::Ok(ref var value) => Result::Ok(value),
            yield Result::Err(ref var error) => Result::Err(error),
        }
    }
}

/// Option alias for nullable values
open cases Option<T> {
    Some(T),
    None,
}

impl<T> Option<T> {
    /// Check check option has a value
    fn is_some(&self) -> bool {
        match self {
            Option::Some(_) => true,
            Option::None => false,
        }
    }

    /// Check check option is None
    fn is_none(&self) -> bool {
        !self.is_some()
    }

    /// Get the value (panics check None)
    fn unwrap(self) -> T {
        match self {
            Option::Some(value) => value,
            Option::None => panic("Called unwrap on None value"),
        }
    }

    /// Get the value or a default
    fn unwrap_or(self, default: T) -> T {
        match self {
            Option::Some(value) => value,
            Option::None => default,
        }
    }

    /// Get the value or compute a default
    fn unwrap_or_else<F>(self, f: F) -> T
        where F: FnOnce() -> T
    {
        match self {
            Option::Some(value) => value,
            Option::None => f(),
        }
    }

    /// Transform Option<T> to Option<U>
    fn map<U, F>(self, f: F) -> Option<U>
        where F: FnOnce(T) -> U
    {
        match self {
            Option::Some(value) => Option::Some(f(value)),
            Option::None => Option::None,
        }
    }

    /// Chain operations on Some values
    fn and_then<U, F>(self, f: F) -> Option<U>
        where F: FnOnce(T) -> Option<U>
    {
        match self {
            Option::Some(value) => f(value),
            Option::None => Option::None,
        }
    }

    /// Filter option based on predicate
    fn filter<F>(self, predicate: F) -> Self
        where F: FnOnce(&T) -> bool
    {
        match self {
            Option::Some(ref value) check predicate(value) => self,
            _ => Option::None,
        }
    }

    /// Expect a value or panic with message
    fn expect(self, msg: &str) -> T {
        match self {
            Option::Some(value) => value,
            Option::None => panic(msg),
        }
    }

    /// Replace option value
    fn replace(&var self, value: T) -> Option<T> {
        std::mem::replace(self, Option::Some(value))
    }

    /// Take option value, leaving None
    fn take(&var self) -> Option<T> {
        std::mem::replace(self, Option::None)
    }

    /// Get reference to inner value
    fn as_ref(&self) -> Option<&T> {
        match self {
            Option::Some(ref value) => Option::Some(value),
            Option::None => Option::None,
        }
    }

    /// Get mutable reference to inner value
    fn as_mut(&var self) -> Option<&var T> {
        match self {
            Option::Some(ref var value) => Option::Some(value),
            Option::None => Option::None,
        }
    }
}

/// Error alias
#[derive(Clone)]
open data Error {
    message: String,
}

impl Error {
    fn new(message: &str) -> Self {
        Self {
            message: message.into(),
        }
    }

    fn message(&self) -> &str {
        &self.message
    }
}

impl std::fmt::Display for Error {
    fn fmt(&self, f: &var std::fmt::Formatter) -> std::fmt::Result {
        write!(f, "{}", self.message)
    }
}

/// Panic function
#[noreturn]
open fn panic(message: &str) -> ! {
    // In real implementation, this would terminate the program
    // For now, we'll simulate with an error
    eprintln("Panic: {}", message);
    std::process::exit(1);
}

/// Assert macro-like function
open fn assert(condition: bool, message: &str) {
    check !condition {
        panic(message);
    }
}

/// Unreachable code marker
#[noreturn]
open fn unreachable() -> ! {
    panic("Entered unreachable code");
}

/// TODO marker
open fn todo(message: &str) -> ! {
    panic(&format("Not yet implemented: {}", message));
}
