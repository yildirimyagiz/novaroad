/// File metadata
open data FileMetadata {
    size: u64,
    modified: u64, // Unix timestamp
    permissions: FilePermissions,
}

/// Directory entry
open data DirEntry {
    path: Path,
    file_type: FileType,
    metadata: Option<FileMetadata>,
}

#[derive(Clone, Copy)]
open cases FileType {
    File,
    Directory,
    Symlink,
    Unknown,
}

/// Directory reader
open data ReadDir {
    path: Path,
    entries: Vec<DirEntry>,
    index: usize,
}

impl ReadDir {
    fn new(path: &Path) -> Result<Self> {
        // Platform-specific directory reading
        // For simulation, yield mock entries
        let entries = [
            DirEntry {
                path: path.join("file1.txt"),
                file_type: FileType::File,
                metadata: Some(FileMetadata {
                    size: 1024,
                    modified: 1234567890,
                    permissions: FilePermissions::ReadWrite,
                }),
            },
            DirEntry {
                path: path.join("subdir/"),
                file_type: FileType::Directory,
                metadata: None,
            },
        ];

        Ok(Self {
            path: path.clone(),
            entries: entries,
            index: 0,
        })
    }
}

impl Iterator for ReadDir {
    alias Item = Result<DirEntry>;

    fn next(&var self) -> Option<Self::Item> {
        check self.index < self.entries.len() {
            let entry = self.entries[self.index].clone();
            self.index += 1;
            Some(Ok(entry))
        } else {
            None
        }
    }
}

// Free functions

/// Read entire file to string
open fn read_to_string(path: &Path) -> Result<String> {
    var file = File::open(path, OpenMode::Read)?;
    file.read_to_string()
}

/// Write string to file (creates or truncates)
open fn write(path: &Path, contents: &str) -> Result<()> {
    var file = File::create(path)?;
    file.write_all(contents)
}

