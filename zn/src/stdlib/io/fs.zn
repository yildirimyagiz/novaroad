        // For simulation, yield mock file handle
        Ok(Self {
            handle: 1, // Mock handle
            path: path.clone(),
            mode: mode,
        })
    }

    /// Create a new file
    fn create(path: &Path) -> Result<Self> {
        Self::open(path, OpenMode::Create)
