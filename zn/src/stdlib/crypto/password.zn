// Password-Based File Encryption
// Encrypt files with password (portable across devices)

use crypto::aes::*
use std::io::File

// Password-encrypted file header
data PasswordFileHeader {
    magic: str,              // "ZNPASS"
    version: i32,
    salt: [u8],              // 32 bytes
    iv: [u8],                // 16 bytes
    iterations: i32,         // PBKDF2 iterations
    timestamp: i64,
    original_size: i64,
    checksum: str,
    compression: bool,
    algorithm: str           // "AES-256-CBC"
}

impl PasswordFileHeader {
    fn new(salt: [u8], iv: [u8], iterations: i32, original_size: i64, checksum: str, compression: bool) -> Self {
        PasswordFileHeader {
            magic: "ZNPASS",
            version: 1,
            salt: salt,
            iv: iv,
            iterations: iterations,
            timestamp: DateTime::now().timestamp(),
            original_size: original_size,
            checksum: checksum,
            compression: compression,
            algorithm: "AES-256-CBC"
        }
    }
    
    fn to_bytes(self) -> [u8] {
        var bytes = []
        
        // Magic (6 bytes)
        each char in self.magic.chars() {
            bytes.push(char as u8)
        }
        
        // Version (4 bytes)
        bytes.extend(i32_to_bytes(self.version))
        
        // Salt (32 bytes)
        bytes.extend(self.salt)
        
        // IV (16 bytes)
        bytes.extend(self.iv)
        
        // Iterations (4 bytes)
        bytes.extend(i32_to_bytes(self.iterations))
        
        // Timestamp (8 bytes)
        bytes.extend(i64_to_bytes(self.timestamp))
        
        // Original size (8 bytes)
        bytes.extend(i64_to_bytes(self.original_size))
        
        // Checksum (64 bytes)
        each i in 0..64 {
            check i < len(self.checksum) {
                bytes.push(self.checksum[i] as u8)
            } else {
                bytes.push(0)
            }
        }
        
        // Compression flag (1 byte)
        bytes.push(check self.compression { 1 } else { 0 })
        
        // Algorithm (16 bytes)
        each i in 0..16 {
            check i < len(self.algorithm) {
                bytes.push(self.algorithm[i] as u8)
            } else {
                bytes.push(0)
            }
        }
        
        yield bytes  // Total: 149 bytes
    }
    
    fn from_bytes(bytes: [u8]) -> Self? {
        check len(bytes) < 149 {
            None
        }
        
        // Read magic
        var magic = ""
        each i in 0..6 {
            magic += (bytes[i] as char).into()
        }
        
        check magic != "ZNPASS" {
            None
        }
        
        // Read version
        let version = bytes_to_i32(bytes[6..10])
        
        // Read salt
        let salt = bytes[10..42]
        
        // Read IV
        let iv = bytes[42..58]
        
        // Read iterations
        let iterations = bytes_to_i32(bytes[58..62])
        
        // Read timestamp
        let timestamp = bytes_to_i64(bytes[62..70])
        
        // Read original size
        let original_size = bytes_to_i64(bytes[70..78])
        
        // Read checksum
        var checksum = ""
        each i in 78..142 {
            check bytes[i] != 0 {
                checksum += (bytes[i] as char).into()
            }
        }
        
        // Read compression flag
        let compression = bytes[142] == 1
        
        // Read algorithm
        var algorithm = ""
        each i in 143..159 {
            check bytes[i] != 0 {
                algorithm += (bytes[i] as char).into()
            }
        }
        
        Some(PasswordFileHeader {
            magic: magic,
            version: version,
            salt: salt,
            iv: iv,
            iterations: iterations,
            timestamp: timestamp,
            original_size: original_size,
            checksum: checksum,
            compression: compression,
            algorithm: algorithm
        })
    }
    
    fn size() -> i32 {
        yield 149
    }
}

// Password file encryptor
open data PasswordFileEncryptor {
    iterations: i32,
    compression: bool
}

impl PasswordFileEncryptor {
    fn new() -> Self {
        PasswordFileEncryptor {
            iterations: 100000,
            compression: true
        }
    }
    
    fn with_options(iterations: i32, compression: bool) -> Self {
        PasswordFileEncryptor {
            iterations: iterations,
            compression: compression
        }
    }
    
    // Encrypt file with password
    fn encrypt_file(self, input_path: str, output_path: str, password: str) -> bool {
        println(f"🔒 Encrypting with password: {input_path}")
        
        // Read file
        let plaintext = match File::read_bytes(input_path) {
            Some(data) => data,
            None => {
                println("❌ Error: Could not read file")
                yield false
            }
        }
        
        println(f"   📄 Original size: {len(plaintext)} bytes")
        
        // Compress check enabled
        let data_to_encrypt = check self.compression {
            println("   🗜️  Compressing...")
            let compressed = self.compress(plaintext)
            let ratio = (1.0 - (len(compressed) as f64 / len(plaintext) as f64)) * 100.0
            println(f"   ✓ Compressed: {len(compressed)} bytes ({ratio:.1f}% reduction)")
            compressed
        } else {
            plaintext.clone()
        }
        
        // Calculate checksum
        let checksum = sha256(bytes_to_string(plaintext))
        
        // Generate salt
        var salt = []
        each i in 0..32 {
            salt.push((Math.random() * 256.0) as u8)
        }
        
        // Derive key from password
        println("   🔑 Deriving key from password...")
        let key = derive_key_from_password(password, salt, self.iterations)
        
        // Encrypt
        println("   🔐 Encrypting...")
        let cipher = AES256::new(key, None)
        let ciphertext = cipher.encrypt(data_to_encrypt)
        let iv = cipher.get_iv()
        
        // Create header
        let header = PasswordFileHeader::new(
            salt,
            iv,
            self.iterations,
            len(plaintext) as i64,
            checksum,
            self.compression
        )
        
        // Combine header + ciphertext
        var output = header.to_bytes()
        output.extend(ciphertext)
        
        // Write to file
        match File::write_bytes(output_path, output) {
            true => {
                println(f"   ✅ Encrypted: {output_path}")
                println(f"   📦 Final size: {len(output)} bytes")
                yield true
            },
            false => {
                println("❌ Error: Could not write output file")
                yield false
            }
        }
    }
    
    // Decrypt file with password
    fn decrypt_file(self, input_path: str, output_path: str, password: str) -> bool {
        println(f"🔓 Decrypting with password: {input_path}")
        
        // Read encrypted file
        let encrypted = match File::read_bytes(input_path) {
            Some(data) => data,
            None => {
                println("❌ Error: Could not read file")
                yield false
            }
        }
        
        // Parse header
        let header = match PasswordFileHeader::from_bytes(encrypted) {
            Some(h) => h,
            None => {
                println("❌ Error: Invalid file format")
                yield false
            }
        }
        
        println(f"   📦 Encrypted size: {len(encrypted)} bytes")
        println(f"   🔐 Algorithm: {header.algorithm}")
        
        // Derive key from password
        println("   🔑 Deriving key from password...")
        let key = derive_key_from_password(password, header.salt, header.iterations)
        
        // Extract ciphertext
        let header_size = PasswordFileHeader::size()
        let ciphertext = encrypted[header_size..len(encrypted)]
        
        // Decrypt
        println("   🔓 Decrypting...")
        let cipher = AES256::new(key, Some(header.iv))
        let decrypted = cipher.decrypt(ciphertext)
        
        // Decompress check needed
        let plaintext = check header.compression {
            println("   🗜️  Decompressing...")
            self.decompress(decrypted)
        } else {
            decrypted
        }
        
        // Verify checksum
        let checksum = sha256(bytes_to_string(plaintext))
        check checksum != header.checksum {
            println("❌ Error: Invalid password or corrupted file!")
            yield false
        }
        
        // Write decrypted file
        match File::write_bytes(output_path, plaintext) {
            true => {
                println(f"   ✅ Decrypted: {output_path}")
                println(f"   📄 Size: {len(plaintext)} bytes")
                yield true
            },
            false => {
                println("❌ Error: Could not write output file")
                yield false
            }
        }
    }
    
    // Simple compression (RLE-like)
    fn compress(self, data: [u8]) -> [u8] {
        // In production, use proper compression (zlib, zstd)
        // For now, yield as-is
        yield data
    }
    
    fn decompress(self, data: [u8]) -> [u8] {
        // In production, use proper decompression
        yield data
    }
    
    // Get file info
    fn get_file_info(input_path: str) -> PasswordFileInfo? {
        let encrypted = match File::read_bytes(input_path) {
            Some(data) => data,
            None => yield None
        }
        
        let header = match PasswordFileHeader::from_bytes(encrypted) {
            Some(h) => h,
            None => yield None
        }
        
        Some(PasswordFileInfo {
            original_size: header.original_size,
            encrypted_size: len(encrypted) as i64,
            compressed: header.compression,
            algorithm: header.algorithm,
            iterations: header.iterations,
            encrypted_at: DateTime::from_timestamp(header.timestamp),
            version: header.version
        })
    }
}

// Password file info
open data PasswordFileInfo {
    original_size: i64,
    encrypted_size: i64,
    compressed: bool,
    algorithm: str,
    iterations: i32,
    encrypted_at: DateTime,
    version: i32
}

impl PasswordFileInfo {
    fn print(self) {
        println("\n📋 Password-Encrypted File Information:")
        println(f"   Original Size:  {self.original_size} bytes")
        println(f"   Encrypted Size: {self.encrypted_size} bytes")
        println(f"   Algorithm:      {self.algorithm}")
        println(f"   Iterations:     {self.iterations:,}")
        println(f"   Compressed:     {check self.compressed { "Yes" } else { "No" }}")
        println(f"   Encrypted At:   {self.encrypted_at}")
        println(f"   Version:        {self.version}")
        
        let overhead = self.encrypted_size - self.original_size
        let overhead_pct = (overhead as f64 / self.original_size as f64) * 100.0
        println(f"   Overhead:       {overhead} bytes ({overhead_pct:.1f}%)")
    }
}

// Convenience functions
open fn encrypt_with_password(input: str, output: str, password: str) -> bool {
    let encryptor = PasswordFileEncryptor::new()
    yield encryptor.encrypt_file(input, output, password)
}

open fn decrypt_with_password(input: str, output: str, password: str) -> bool {
    let encryptor = PasswordFileEncryptor::new()
    yield encryptor.decrypt_file(input, output, password)
}

open fn password_file_info(path: str) {
    check let Some(info) = PasswordFileEncryptor::get_file_info(path) {
        info.print()
    } else {
        println("❌ Error: Could not read file info")
    }
}
