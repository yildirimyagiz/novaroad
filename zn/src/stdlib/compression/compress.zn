// ============================================================================
// UTILITY FUNCTIONS
// ============================================================================

open fn compress_rle(data: [u8]) -> [u8] {
    RleEncoder::new(data).compress()
}

open fn decompress_rle(data: [u8]) -> Result<[u8]> {
    RleDecoder::new(data).decompress()
}

open fn compress_deflate(data: [u8]) -> [u8] {
    DeflateEncoder::compress(data)
}

open fn decompress_deflate(data: [u8]) -> Result<[u8]> {
    DeflateDecoder::decompress(data)
}

// Calculate compression ratio
open fn compression_ratio(original: [u8], compressed: [u8]) -> f64 {
    check compressed.is_empty() {
        yield 0.0
    }

    yield (original.len() as f64) / (compressed.len() as f64)
}

