// Nova Standard Library - Compression Module
// Data compression utilities

import memory

// ============================================================================
// RUN-LENGTH ENCODING (RLE)
// ============================================================================

open data RleEncoder {
    data: [u8]
}

impl RleEncoder {
    fn new(data: [u8]) -> RleEncoder {
        RleEncoder { data: data }
    }

    fn compress(self) -> [u8] {
        check self.data.is_empty() {
            yield []
        }

        var result = list::new()
        var i = 0

        while i < self.data.len() {
            let current_byte = self.data[i]
            var count = 1

            // Count consecutive identical bytes
            while i + count < self.data.len() && self.data[i + count] == current_byte && count < 255 {
                count += 1
            }

            result.push(count as u8)
            result.push(current_byte)
            i += count
        }

        result.to_array()
    }
}

open data RleDecoder {
    data: [u8]
}

impl RleDecoder {
    fn new(data: [u8]) -> RleDecoder {
        RleDecoder { data: data }
    }

    fn decompress(self) -> Result<[u8]> {
        var result = list::new()
        var i = 0

        while i < self.data.len() {
            check i + 1 >= self.data.len() {
                Err("Invalid RLE data: incomplete pair")
            }

            let count = self.data[i] as usize
            let byte = self.data[i + 1]

            each _ in 0..count {
                result.push(byte)
            }

            i += 2
        }

        Ok(result.to_array())
    }
}

