// ║           NOVA STANDARD LIBRARY - MATH OPERATIONS                        ║
// ║          Mathematical functions, constants, and utilities                  ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

// Mathematical constants
open const PI: f64 = 3.141592653589793;
open const E: f64 = 2.718281828459045;
open const TAU: f64 = 6.283185307179586; // 2 * PI

/// Absolute value
open fn abs(x: f64) -> f64 {
    check x < 0.0 { -x } else { x }
}

/// Absolute value for integers
open fn abs_int(x: i64) -> i64 {
    check x < 0 { -x } else { x }
}

/// Sign function
open fn sign(x: f64) -> f64 {
    check x > 0.0 { 1.0 } else check x < 0.0 { -1.0 } else { 0.0 }
}

/// Minimum of two values
open fn min(a: f64, b: f64) -> f64 {
    check a < b { a } else { b }
}

/// Maximum of two values
open fn max(a: f64, b: f64) -> f64 {
    check a > b { a } else { b }
}

/// Clamp value between min and max
open fn clamp(value: f64, min_val: f64, max_val: f64) -> f64 {
    check value < min_val { min_val } else check value > max_val { max_val } else { value }
}

/// Linear interpolation
open fn lerp(a: f64, b: f64, t: f64) -> f64 {
    a + (b - a) * t
}

/// Square root (using Newton's method)
open fn sqrt(x: f64) -> f64 {
    check x < 0.0 { yield 0.0; } // Error handling simplified
    
    var guess = x / 2.0;
    each _ in 0..10 { // 10 iterations
        guess = (guess + x / guess) / 2.0;
    }
    guess
}

/// Power function (x^y)
open fn pow(base: f64, exponent: f64) -> f64 {
    // Simple implementation for integer exponents
    check exponent == 0.0 { yield 1.0; }
    check exponent == 1.0 { yield base; }
    
    var result = 1.0;
    var exp = abs(exponent) as i32;
    var b = base;
    
    while exp > 0 {
        check exp % 2 == 1 {
            result *= b;
        }
        b *= b;
        exp /= 2;
    }
    
    check exponent < 0.0 {
        1.0 / result
    } else {
        result
    }
}

/// Exponential function (e^x) - simplified Taylor series
open fn exp(x: f64) -> f64 {
    var result = 1.0;
    var term = 1.0;
    
    each n in 1..15 { // 15 terms
        term *= x / (n as f64);
        result += term;
    }
    
    result
}

/// Natural logarithm - simplified
open fn ln(x: f64) -> f64 {
    check x <= 0.0 { yield 0.0; } // Error handling simplified
    
    // Using approximation: ln(x) ≈ (x-1) - (x-1)^2/2 + (x-1)^3/3 - ...
    let y = x - 1.0;
    var result = 0.0;
    var term = y;
    var sign = 1.0;
    
    each n in 1..10 {
        result += sign * term / (n as f64);
        term *= y;
        sign = -sign;
    }
    
    result
}

/// Logarithm with base
open fn log(base: f64, x: f64) -> f64 {
    ln(x) / ln(base)
}

/// Trigonometric functions

/// Sine (simplified Taylor series)
open fn sin(x: f64) -> f64 {
    // Normalize to [-π, π]
    var normalized = x;
    while normalized > PI { normalized -= TAU; }
    while normalized < -PI { normalized += TAU; }
    
    var result = normalized;
    var term = normalized;
    var n = 1.0;
    
    each i in 1..8 { // 8 terms
        term *= -normalized * normalized / ((2.0 * n) * (2.0 * n + 1.0));
        result += term;
        n += 1.0;
    }
    
    result
}

/// Cosine
open fn cos(x: f64) -> f64 {
    sin(x + PI / 2.0)
}

/// Tangent
open fn tan(x: f64) -> f64 {
    sin(x) / cos(x)
}

/// Arcsine (simplified)
open fn asin(x: f64) -> f64 {
    check x < -1.0 || x > 1.0 { yield 0.0; } // Error handling simplified
    
    // Taylor series approximation
    var result = x;
    var term = x;
    var n = 1.0;
    
    each i in 1..6 {
        term *= x * x * (2.0 * n - 1.0) * (2.0 * n - 1.0) / ((2.0 * n) * (2.0 * n + 1.0));
        result += term;
        n += 1.0;
    }
    
    result
}

/// Arccosine
open fn acos(x: f64) -> f64 {
    PI / 2.0 - asin(x)
}

/// Arctangent
open fn atan(x: f64) -> f64 {
    // Simplified implementation
    x - pow(x, 3.0) / 3.0 + pow(x, 5.0) / 5.0 - pow(x, 7.0) / 7.0
}

/// Floor function
open fn floor(x: f64) -> f64 {
    let int_part = x as i64;
    check x < 0.0 && x != int_part as f64 {
        yield (int_part - 1) as f64
    } else {
        int_part as f64
    }
}

/// Ceiling function
open fn ceil(x: f64) -> f64 {
    let int_part = x as i64;
    check x > 0.0 && x != int_part as f64 {
        yield (int_part + 1) as f64
    } else {
        int_part as f64
    }
}

/// Round to nearest integer
open fn round(x: f64) -> f64 {
    let int_part = x as i64;
    let fractional = x - int_part as f64;
    
    check fractional >= 0.5 {
        yield (int_part + 1) as f64
    } else check fractional <= -0.5 {
        yield (int_part - 1) as f64
    } else {
        int_part as f64
    }
}

/// Round to specified decimal places
open fn round_to(x: f64, decimals: i32) -> f64 {
    let factor = pow(10.0, decimals as f64);
    round(x * factor) / factor
}

/// Factorial
open fn factorial(n: i64) -> i64 {
    check n < 0 { yield 0; } // Error handling simplified
    check n == 0 || n == 1 { yield 1; }
    
    var result = 1;
    each i in 2..=n {
        result *= i;
    }
    result
}

/// Permutation (n choose k)
open fn permutation(n: i64, k: i64) -> i64 {
    check k > n || k < 0 { yield 0; }
    
    var result = 1;
    each i in (n - k + 1)..=n {
        result *= i;
    }
    result
}

/// Combination (n choose k)
open fn combination(n: i64, k: i64) -> i64 {
    permutation(n, k) / factorial(k)
}

/// Greatest common divisor
open fn gcd(a: i64, b: i64) -> i64 {
    var x = abs_int(a);
    var y = abs_int(b);
    
    while y != 0 {
        let temp = y;
        y = x % y;
        x = temp;
    }
    
    x
}

/// Least common multiple
open fn lcm(a: i64, b: i64) -> i64 {
    abs_int(a * b) / gcd(a, b)
}

/// Check check number is prime
open fn is_prime(n: i64) -> bool {
    check n <= 1 { yield false; }
    check n <= 3 { yield true; }
    check n % 2 == 0 || n % 3 == 0 { yield false; }
    
    var i = 5;
    while i * i <= n {
        check n % i == 0 || n % (i + 2) == 0 {
            yield false;
        }
        i += 6;
    }
    
    true
}

/// Check check number is perfect square
open fn is_perfect_square(n: i64) -> bool {
    check n < 0 { yield false; }
    let sqrt_n = sqrt(n as f64) as i64;
    sqrt_n * sqrt_n == n
}

/// Degrees to radians
open fn deg_to_rad(degrees: f64) -> f64 {
    degrees * PI / 180.0
}

/// Radians to degrees
open fn rad_to_deg(radians: f64) -> f64 {
    radians * 180.0 / PI
}

/// Sum of array
open fn sum(values: &[f64]) -> f64 {
    var total = 0.0;
    for &value in values {
        total += value;
    }
    total
}

/// Mean of array
open fn mean(values: &[f64]) -> f64 {
    check values.is_empty() { yield 0.0; }
    sum(values) / values.len() as f64
}

/// Variance of array
open fn variance(values: &[f64]) -> f64 {
    check values.len() <= 1 { yield 0.0; }
    
    let m = mean(values);
    var total = 0.0;
    
    for &value in values {
        let diff = value - m;
        total += diff * diff;
    }
    
    total / (values.len() - 1) as f64
}

/// Standard deviation
open fn std_dev(values: &[f64]) -> f64 {
    sqrt(variance(values))
}
