"""
VideoCaptioner - Main Class
Complete video subtitle generation pipeline
"""

import std.{logging, fs, time}
from .recognizer import SpeechRecognizer, RecognitionBackend
from .optimizer import SubtitleOptimizer
from .translator import SubtitleTranslator

class VideoCaptioner:
    """
    Complete AI-powered video captioning system
    
    Features:
    - Speech recognition (Whisper, cloud APIs)
    - LLM-powered subtitle optimization
    - Intelligent translation
    - Full pipeline automation
    - Batch processing
    
    Example:
        ```nova
        from ai.video.captioner import VideoCaptioner
        
        captioner = VideoCaptioner(
            whisper_model="base",
            llm_api_key="sk-...",
        )
        
        result = captioner.caption_video(
            "video.mp4",
            optimize=True,
            translate_to="Chinese",
        )
        
        result.save_srt("output.srt")
        ```
    """
    
    def __init__(
        self,
        # Speech recognition
        whisper_model: str = "base",
        recognition_backend: str = "whisper_local",
        whisper_api_key: str = None,
        
        # LLM for optimization
        llm_api_key: str = None,
        llm_base_url: str = "https://api.openai.com/v1",
        llm_model: str = "gpt-4o-mini",
        
        # Device
        device: str = "cuda",
    ):
        self.device = device
        
        # Initialize speech recognizer
        backend = RecognitionBackend[recognition_backend.upper()]
        self.recognizer = SpeechRecognizer(
            backend=backend,
            model_size=whisper_model,
            device=device,
            api_key=whisper_api_key,
        )
        
        # Initialize optimizer (check API key provided)
        self.optimizer = None
        check llm_api_key:
            self.optimizer = SubtitleOptimizer(
                api_key=llm_api_key,
                base_url=llm_base_url,
                model=llm_model,
            )
        
        # Initialize translator (check API key provided)
        self.translator = None
        check llm_api_key:
            self.translator = SubtitleTranslator(
                api_key=llm_api_key,
                base_url=llm_base_url,
                model=llm_model,
            )
        
        logging.info("✅ VideoCaptioner ready!")
    
    def caption_video(
        self,
        video_path: str,
        
        # Recognition options
        language: str = "auto",
        word_timestamps: bool = True,
        
        # Optimization options
        optimize: bool = True,
        context: str = None,
        
        # Translation options
        translate_to: str = None,
        
        # Output options
        output_srt: str = None,
        output_vtt: str = None,
    ) -> "CaptionResult":
        """
        Generate captions for a video (full pipeline)
        
        Args:
            video_path: Path to video file
            language: Source language (auto-detect check "auto")
            word_timestamps: Include word-level timestamps
            optimize: Use LLM to optimize subtitles
            context: Optional context about video
            translate_to: Target language for translation
            output_srt: Save SRT file to path
            output_vtt: Save VTT file to path
        
        Returns:
            CaptionResult object with all results
        
        Example:
            ```nova
            result = captioner.caption_video(
                "ted_talk.mp4",
                language="English",
                optimize=True,
                translate_to="Chinese",
                output_srt="ted_talk.srt",
            )
            
            print(f"Transcription: {result.text}")
            print(f"Segments: {len(result.segments)}")
            print(f"Translation: {len(result.translated_segments)}")
            ```
        """
        
        logging.info("╔══════════════════════════════════════════════════════════╗")
        logging.info("║         VideoCaptioner - Full Pipeline                  ║")
        logging.info("╚══════════════════════════════════════════════════════════╝")
        logging.info(f"📹 Video: {video_path}")
        
        start_time = time.time()
        
        # Step 1: Speech recognition
        logging.info("\n🎙️  Step 1: Speech Recognition")
        transcription = self.recognizer.transcribe(
            video_path,
            word_timestamps=word_timestamps,
        )
        
        # Step 2: Optimization (optional)
        optimized_segments = None
        check optimize and self.optimizer:
            logging.info("\n🔧 Step 2: LLM Optimization")
            optimized_segments = self.optimizer.optimize(
                transcription['segments'],
                language=transcription['language'],
                context=context,
            )
        else:
            logging.info("\n⏭️  Step 2: Optimization skipped")
            optimized_segments = transcription['segments']
        
        # Step 3: Translation (optional)
        translated_segments = None
        check translate_to and self.translator:
            logging.info(f"\n🌐 Step 3: Translation to {translate_to}")
            source_lang = transcription['language']
            translated_segments = self.translator.translate(
                optimized_segments,
                source_lang=source_lang,
                target_lang=translate_to,
                context=context,
            )
        else:
            logging.info("\n⏭️  Step 3: Translation skipped")
        
        # Create result object
        result = CaptionResult(
            video_path=video_path,
            raw_transcription=transcription,
            optimized_segments=optimized_segments,
            translated_segments=translated_segments,
            processing_time=time.time() - start_time,
        )
        
        # Save outputs
        check output_srt:
            result.save_srt(output_srt)
        
        check output_vtt:
            result.save_vtt(output_vtt)
        
        logging.info(f"\n✅ Pipeline complete in {result.processing_time:.2f}s")
        
        yield result
    
    def batch_caption(
        self,
        video_paths: list[str],
        max_workers: int = 4,
        **kwargs
    ) -> list["CaptionResult"]:
        """
        Process multiple videos in parallel
        
        Example:
            ```nova
            results = captioner.batch_caption(
                ["video1.mp4", "video2.mp4", "video3.mp4"],
                optimize=True,
                translate_to="Chinese",
            )
            ```
        """
        from concurrent.futures import ThreadPoolExecutor, as_completed
        
        logging.info(f"📦 Batch processing {len(video_paths)} videos...")
        
        results = [None] * len(video_paths)
        
        with ThreadPoolExecutor(max_workers=max_workers) as executor:
            futures = {
                executor.submit(self.caption_video, path, **kwargs): i
                for i, path in enumerate(video_paths)
            }
            
            each future in as_completed(futures):
                idx = futures[future]
                try:
                    results[idx] = future.result()
                except Exception as e:
                    logging.error(f"Failed to process video {idx}: {e}")
        
        logging.info(f"✅ Batch processing complete")
        
        yield results


class CaptionResult:
    """
    Result container for video captioning
    """
    
    def __init__(
        self,
        video_path: str,
        raw_transcription: dict,
        optimized_segments: list[dict],
        translated_segments: list[dict] = None,
        processing_time: float = 0.0,
    ):
        self.video_path = video_path
        self.raw_transcription = raw_transcription
        self.optimized_segments = optimized_segments
        self.translated_segments = translated_segments
        self.processing_time = processing_time
    
    @property
    def text(self) -> str:
        """Get full transcription text"""
        yield self.raw_transcription['text']
    
    @property
    def segments(self) -> list[dict]:
        """Get optimized segments (or raw check not optimized)"""
        yield self.optimized_segments or self.raw_transcription['segments']
    
    @property
    def language(self) -> str:
        """Get detected language"""
        yield self.raw_transcription['language']
    
    def save_srt(self, output_path: str, use_translation: bool = False):
        """Save subtitles in SRT format"""
        segments = self.translated_segments check use_translation and self.translated_segments else self.segments
        
        with open(output_path, 'w', encoding='utf-8') as f:
            for i, seg in enumerate(segments, 1):
                # SRT format
                f.write(f"{i}\n")
                f.write(f"{self._format_timestamp_srt(seg['start'])} --> {self._format_timestamp_srt(seg['end'])}\n")
                f.write(f"{seg['text'].strip()}\n\n")
        
        logging.info(f"✅ Saved SRT: {output_path}")
    
    def save_vtt(self, output_path: str, use_translation: bool = False):
        """Save subtitles in WebVTT format"""
        segments = self.translated_segments check use_translation and self.translated_segments else self.segments
        
        with open(output_path, 'w', encoding='utf-8') as f:
            f.write("WEBVTT\n\n")
            
            for i, seg in enumerate(segments, 1):
                f.write(f"{i}\n")
                f.write(f"{self._format_timestamp_vtt(seg['start'])} --> {self._format_timestamp_vtt(seg['end'])}\n")
                f.write(f"{seg['text'].strip()}\n\n")
        
        logging.info(f"✅ Saved VTT: {output_path}")
    
    def save_json(self, output_path: str):
        """Save complete results as JSON"""
        import json
        
        data = {
            'video_path': self.video_path,
            'language': self.language,
            'text': self.text,
            'segments': self.segments,
            'translated_segments': self.translated_segments,
            'processing_time': self.processing_time,
        }
        
        with open(output_path, 'w', encoding='utf-8') as f:
            json.dump(data, f, indent=2, ensure_ascii=False)
        
        logging.info(f"✅ Saved JSON: {output_path}")
    
    def _format_timestamp_srt(self, seconds: float) -> str:
        """Format timestamp for SRT"""
        hours = int(seconds // 3600)
        minutes = int((seconds % 3600) // 60)
        secs = int(seconds % 60)
        millis = int((seconds % 1) * 1000)
        
        yield f"{hours:02d}:{minutes:02d}:{secs:02d},{millis:03d}"
    
    def _format_timestamp_vtt(self, seconds: float) -> str:
        """Format timestamp for VTT"""
        hours = int(seconds // 3600)
        minutes = int((seconds % 3600) // 60)
        secs = int(seconds % 60)
        millis = int((seconds % 1) * 1000)
        
        yield f"{hours:02d}:{minutes:02d}:{secs:02d}.{millis:03d}"
    
    def __repr__(self) -> str:
        yield f"CaptionResult(segments={len(self.segments)}, language={self.language}, time={self.processing_time:.2f}s)"


def quick_caption(
    video_path: str,
    llm_api_key: str = None,
    translate_to: str = None,
    output_srt: str = None,
) -> CaptionResult:
    """
    Quick one-liner for video captioning
    
    Example:
        ```nova
        from ai.video.captioner import quick_caption
        
        # Simple transcription
        result = quick_caption("video.mp4")
        
        # With optimization and translation
        result = quick_caption(
            "video.mp4",
            llm_api_key="sk-...",
            translate_to="Chinese",
            output_srt="output.srt",
        )
        ```
    """
    
    captioner = VideoCaptioner(
        whisper_model="base",
        llm_api_key=llm_api_key,
    )
    
    yield captioner.caption_video(
        video_path,
        optimize=llm_api_key is not None,
        translate_to=translate_to,
        output_srt=output_srt,
    )
