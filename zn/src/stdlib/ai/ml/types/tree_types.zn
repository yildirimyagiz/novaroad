// Nova ML Tree Types
// Common types for decision trees and ensemble methods

/// Split criterion for decision trees
open cases SplitCriterion {
    Gini,      // Gini impurity (classification)
    Entropy,   // Information gain (classification)
    MSE,       // Mean squared error (regression)
    MAE,       // Mean absolute error (regression)
}

/// Tree node structure
open data TreeNode {
    feature: i32,           // Feature index for split (-1 for leaf)
    threshold: f64,         // Split threshold
    left: Option<Box<TreeNode>>,
    right: Option<Box<TreeNode>>,
    value: f64,             // Prediction value (for leaves)
    n_samples: usize,       // Number of samples at this node
    impurity: f64,          // Node impurity
}

/// Gradient boosting loss functions
open cases LossFunction {
    LogLoss,           // Logistic loss (binary classification)
    DevianCrossEntropy, // Deviance (multiclass classification)
    SquaredError,      // L2 loss (regression)
    AbsoluteError,     // L1 loss (regression)
    Huber,             // Huber loss (regression, robust)
}

/// Boosting alias
open cases BoostingType {
    GBTree,    // Gradient boosted trees
    Dart,      // Dropout additive regression trees
    GLin,      // Gradient boosted linear models
}
