// Nova ML: Physics-Informed Optimization
// ML-based surrogate models for nonlinear optics optimization
// PyTorch integration for efficiency optimization

@module("ml::physics_optimization")
@reproducible
@export

use physics::optics::nonlinear::{ParametricDownConversion, SecondHarmonicGeneration};
use physics::thermal::radiation::HumanBodyRadiation;
use ml::tensor::core::Tensor;
