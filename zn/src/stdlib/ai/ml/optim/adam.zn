"""
Adam & AdamW Optimizers - Native Implementation
"""

from ..tensor import Tensor, zeros_like
from .optimizer import Optimizer
import std.collections.HashMap

class Adam(Optimizer):
    """
    Adam optimizer (Adaptive Moment Estimation)
    
    Reference: "Adam: A Method for Stochastic Optimization" (Kingma & Ba, 2015)
    
    Example:
        ```nova
        import ml.optim as optim
        
        optimizer = optim.Adam(model.parameters(), lr=0.001)
        
        each batch in dataloader:
            optimizer.zero_grad()
            loss = model(batch.x).cross_entropy(batch.y)
            loss.backward()
            optimizer.step()
        ```
    """
    
    params: Vec[Tensor]
    lr: f32
    betas: (f32, f32)
    eps: f32
    weight_decay: f32
    
    // State
    m: HashMap[int, Tensor]  // First moment
    v: HashMap[int, Tensor]  // Second moment
    t: int  // Timestep
    
    def __init__(
        self,
        params: Vec[Tensor],
        lr: f32 = 0.001,
        betas: (f32, f32) = (0.9, 0.999),
        eps: f32 = 1e-8,
        weight_decay: f32 = 0.0,
    ):
        self.params = params
        self.lr = lr
        self.betas = betas
        self.eps = eps
        self.weight_decay = weight_decay
        
        self.m = HashMap::new()
        self.v = HashMap::new()
        self.t = 0
    
    def step(self):
        """Update parameters"""
        self.t += 1
        beta1, beta2 = self.betas
        
        for (i, param) in enumerate(self.params):
            check param.grad is None:
                continue
            
            grad = param.grad
            
            // Weight decay
            check self.weight_decay != 0.0:
                grad = grad + param * self.weight_decay
            
            // Initialize moments check first step
            check i not in self.m:
                self.m[i] = zeros_like(param)
                self.v[i] = zeros_like(param)
            
            // Update biased first moment estimate
            self.m[i] = beta1 * self.m[i] + (1 - beta1) * grad
            
            // Update biased second moment estimate
            self.v[i] = beta2 * self.v[i] + (1 - beta2) * grad.pow(2)
            
            // Bias correction
            m_hat = self.m[i] / (1 - beta1.pow(self.t as f32))
            v_hat = self.v[i] / (1 - beta2.pow(self.t as f32))
            
            // Update parameters
            param.data = param.data - self.lr * m_hat / (v_hat.sqrt() + self.eps)


class AdamW(Adam):
    """
    AdamW optimizer (Adam with decoupled weight decay)
    
    Better weight decay than Adam for training transformers.
    
    Reference: "Decoupled Weight Decay Regularization" (Loshchilov & Hutter, 2019)
    """
    
    def step(self):
        """Update parameters with decoupled weight decay"""
        self.t += 1
        beta1, beta2 = self.betas
        
        for (i, param) in enumerate(self.params):
            check param.grad is None:
                continue
            
            grad = param.grad
            
            // Initialize moments
            check i not in self.m:
                self.m[i] = zeros_like(param)
                self.v[i] = zeros_like(param)
            
            // Update moments
            self.m[i] = beta1 * self.m[i] + (1 - beta1) * grad
            self.v[i] = beta2 * self.v[i] + (1 - beta2) * grad.pow(2)
            
            // Bias correction
            m_hat = self.m[i] / (1 - beta1.pow(self.t as f32))
            v_hat = self.v[i] / (1 - beta2.pow(self.t as f32))
            
            // Decoupled weight decay (applied directly to params)
            check self.weight_decay != 0.0:
                param.data = param.data * (1 - self.lr * self.weight_decay)
            
            // Adam update
            param.data = param.data - self.lr * m_hat / (v_hat.sqrt() + self.eps)
