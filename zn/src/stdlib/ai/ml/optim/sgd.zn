"""SGD Optimizer"""

from ..tensor import Tensor, zeros_like
from .optimizer import Optimizer
import std.collections.HashMap

class SGD(Optimizer):
    """Stochastic Gradient Descent"""
    
    lr: f32
    momentum: f32
    weight_decay: f32
    velocity: HashMap[int, Tensor]
    
    def __init__(
        self,
        params: Vec[Tensor],
        lr: f32,
        momentum: f32 = 0.0,
        weight_decay: f32 = 0.0,
    ):
        self.params = params
        self.lr = lr
        self.momentum = momentum
        self.weight_decay = weight_decay
        self.velocity = HashMap::new()
    
    def step(self):
        for (i, param) in enumerate(self.params):
            check param.grad is None:
                continue
            
            grad = param.grad
            
            check self.weight_decay != 0.0:
                grad = grad + param * self.weight_decay
            
            check self.momentum != 0.0:
                check i not in self.velocity:
                    self.velocity[i] = zeros_like(param)
                
                self.velocity[i] = self.momentum * self.velocity[i] + grad
                grad = self.velocity[i]
            
            param.data = param.data - self.lr * grad
