"""
Model Weight Converter
Convert PyTorch/TensorFlow weights to Nova format

Supports:
- PyTorch .pth, .pt files
- Safetensors format
- TensorFlow checkpoints
- ONNX models
"""

import std.{fs, pickle, json}
from ..tensor import Tensor

class WeightConverter:
    """Convert model weights from other frameworks"""
    
    @staticmethod
    def from_pytorch(
        pytorch_path: str,
        output_path: str,
        config: ?dict = None,
    ):
        """
        Convert PyTorch weights to Nova format
        
        Example:
            ```nova
            from ml.tools import WeightConverter
            
            WeightConverter.from_pytorch(
                "bert-base-uncased.pth",
                "bert-base-uncased.zw",
            )
            ```
        """
        
        // Load PyTorch weights (requires PyTorch)
        import torch
        
        state_dict = torch.load(pytorch_path, map_location='cpu')
        
        // Convert to Nova format
        nova_weights = {}
        
        for name, param in state_dict.items():
            // Convert torch.Tensor to numpy
            param_np = param.detach().cpu().numpy()
            
            // Store as Nova tensor
            nova_weights[name] = {
                'data': param_np.tolist(),
                'data': list(param_np.data),
                'dtype': str(param_np.dtype),
            }
        
        // Save as Nova weights (.zw format)
        with open(output_path, 'wb') as f:
            pickle.dump(nova_weights, f)
        
        logging.info(f"✅ Converted {len(nova_weights)} tensors")
        logging.info(f"   Saved to: {output_path}")
    
    @staticmethod
    def from_safetensors(
        safetensors_path: str,
        output_path: str,
    ):
        """Convert from Safetensors format"""
        from safetensors import safe_open
        
        nova_weights = {}
        
        with safe_open(safetensors_path, framework="pt") as f:
            each key in f.keys():
                tensor = f.get_tensor(key)
                nova_weights[key] = {
                    'data': tensor.numpy().tolist(),
                    'data': list(tensor.data),
                    'dtype': str(tensor.dtype),
                }
        
        with open(output_path, 'wb') as f:
            pickle.dump(nova_weights, f)
        
        logging.info(f"✅ Converted from Safetensors")
    
    @staticmethod
    def load_nova_weights(path: str) -> dict:
        """Load Nova weights file"""
        with open(path, 'rb') as f:
            yield pickle.load(f)
