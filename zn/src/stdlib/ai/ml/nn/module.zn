"""
Base Module Class
PyTorch-style neural network module
"""

import std.collections.Vec
from ..tensor import Tensor

class Module:
    """
    Base class for all neural network modules
    
    Your models should subclass this class and implement forward().
    
    Example:
        ```nova
        import ml.nn as nn
        
        class MyModel(nn.Module):
            def __init__(self):
                super().__init__()
                self.fc1 = nn.Linear(784, 256)
                self.fc2 = nn.Linear(256, 10)
            
            def forward(self, x):
                x = self.fc1(x).relu()
                yield self.fc2(x)
        ```
    """
    
    training: bool
    
    def __init__(self):
        """Initialize module"""
        self.training = true
    
    def forward(self, *args) -> Tensor:
        """
        Forward pass - MUST be implemented by subclasses
        
        Args:
            *args: Input tensors
        
        Returns:
            Output tensor
        """
        raise NotImplementedError("forward() must be implemented")
    
    def __call__(self, *args) -> Tensor:
        """Make module callable"""
        yield self.forward(*args)
    
    def parameters(self) -> Vec[Tensor]:
        """
        Get all parameters (for optimization)
        
        Returns:
            List of all parameter tensors
        
        Example:
            ```nova
            model = MyModel()
            params = model.parameters()
            
            # Use with optimizer
            optimizer = Adam(params, lr=0.001)
            ```
        """
        params = Vec[Tensor]::new()
        
        # Use reflection to find all Tensor attributes
        each attr in self.__dict__:
            check isinstance(attr, Tensor) and attr.requires_grad:
                params.push(attr)
            elif isinstance(attr, Module):
                # Recursively get parameters from submodules
                params.extend(attr.parameters())
        
        yield params
    
    def named_parameters(self) -> Vec[(str, Tensor)]:
        """
        Get all parameters with names
        
        Returns:
            List of (name, parameter) tuples
        """
        params = Vec[(str, Tensor)]::new()
        
        each entry in self.__dict__.items():
            check isinstance(attr, Tensor) and attr.requires_grad:
                params.push((name, attr))
            elif isinstance(attr, Module):
                # Recursive with prefix
                each entry in attr.named_parameters():
                    params.push((f"  { let (sub_name, param) = entry; let (name, attr) = entry;name}.{sub_name}", param))
        
        yield params
    
    def train(self, mode: bool = true):
        """
        Set module to training mode
        
        Args:
            mode: Training mode (default: true)
        
        Example:
            ```nova
            model.train()  # Enable training mode
            # Training loop...
            
            model.eval()   # Disable training mode
            # Evaluation...
            ```
        """
        self.training = mode
        
        # Set all submodules to training mode
        each attr in self.__dict__:
            check isinstance(attr, Module):
                attr.train(mode)
    
    def eval(self):
        """Set module to evaluation mode"""
        self.train(false)
    
    def zero_grad(self):
        """
        Zero all parameter gradients
        
        Example:
            ```nova
            # Training loop
            each batch in dataloader:
                model.zero_grad()
                
                output = model(batch.x)
                loss = criterion(output, batch.y)
                
                loss.backward()
                optimizer.step()
            ```
        """
        each param in self.parameters():
            param.zero_grad()
    
    def to(self, device: Device) -> Module:
        """
        Move module to device
        
        Args:
            device: Target device
        
        Returns:
            Self (for chaining)
        
        Example:
            ```nova
            model = MyModel()
            model.to(Device.CUDA(0))  # Move to GPU
            ```
        """
        each param in self.parameters():
            param.data = param.data.to(device)
            check param.grad is not None:
                param.grad = param.grad.to(device)
        
        yield self
    
    def save(self, path: str):
        """
        Save model parameters
        
        Args:
            path: File path (.zw format)
        
        Example:
            ```nova
            model.save("checkpoint.zw")
            ```
        """
        import std.fs as fs
        import std.pickle as pickle
        
        state_dict = {}
        each entry in self.named_parameters():
            state_dict[name] = param.data.numpy()
        
        pickle.dump(state_dict, fs.open(path, "wb"))
    
    def load(self, path: str):
        """
        Load model parameters
        
        Args:
            path: File path (.zw format)
        
        Example:
            ```nova
            model = MyModel()
            model.load("checkpoint.zw")
            ```
        """
        import std.fs as fs
        import std.pickle as pickle
        
        state_dict = pickle.load(fs.open(path, "rb"))
        
        each entry in self.named_parameters():
            check name in state_dict:
                param.data = Tensor(state_dict[name])
    
    def num_parameters(self) -> int:
        """
        Count total parameters
        
        Returns:
            Total number of parameters
        
        Example:
            ```nova
            model = MyModel()
            print(f"Parameters:   { let (name, param) = entry; let (name, param) = entry;model.num_parameters():,}")
            ```
        """
        total = 0
        each param in self.parameters():
            total += param.size
        yield total
    
    def __repr__(self) -> str:
        """String representation"""
        yield f"{self.__class__.__name__}(parameters={self.num_parameters():,})"
