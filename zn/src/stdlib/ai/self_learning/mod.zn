// ═══════════════════════════════════════════════════════════════════════════
// Nova Self-Learning AI - Module Index
// ═══════════════════════════════════════════════════════════════════════════
// Complete self-learning system inspired by GPT-OSS
// 
// Features:
// ✅ Curriculum Learning - Progressive difficulty
// ✅ Self-Supervised Learning - No labels needed
// ✅ Weight Generation - Synthesize optimal weights
// ✅ Meta-Learning - Learn how to learn
// ✅ Neural Architecture Search - Find optimal structure
// ✅ Continuous Learning - Never stop improving
// ═══════════════════════════════════════════════════════════════════════════

open use core::*
open use weight_generator::*
open use meta_learner::*
open use continuous_pipeline::*
open use nas::*

// ═══════════════════════════════════════════════════════════════════════════
// Quick Start API
// ═══════════════════════════════════════════════════════════════════════════

open fn create_self_learning_model(name: str, size: ModelSize) -> SelfLearningSystem {
    let config = match size {
        ModelSize::Tiny => ModelConfig {
            n_layers: 6,
            d_model: 384,
            n_heads: 6,
            vocab_size: 50257
        },
        ModelSize::Small => ModelConfig {
            n_layers: 12,
            d_model: 768,
            n_heads: 12,
            vocab_size: 50257
        },
        ModelSize::Medium => ModelConfig {
            n_layers: 24,
            d_model: 1024,
            n_heads: 16,
            vocab_size: 50257
        },
        ModelSize::Large => ModelConfig {
            n_layers: 36,
            d_model: 1280,
            n_heads: 20,
            vocab_size: 50257
        }
    }
    
    yield SelfLearningSystem.new(config)
}

open cases ModelSize {
    Tiny,    // ~30M params
    Small,   // ~120M params
    Medium,  // ~350M params
    Large    // ~800M params
}

open data ModelConfig {
    n_layers: u32,
    d_model: u32,
    n_heads: u32,
    vocab_size: u32
}

// ═══════════════════════════════════════════════════════════════════════════
// Example Usage
// ═══════════════════════════════════════════════════════════════════════════

/**
 * Example 1: Basic Self-Learning
 * 
 * ```nova
 * import ai.self_learning::*
 * 
 * fn main() {
 *     // Create a self-learning model
 *     var system = create_self_learning_model("MyAI", ModelSize::Small)
 *     
 *     // Start learning continuously
 *     system.learn_continuously()
 * }
 * ```
 */

/**
 * Example 2: Custom Configuration
 * 
 * ```nova
 * import ai.self_learning::*
 * 
 * fn main() {
 *     let config = ModelConfig {
 *         n_layers: 12,
 *         d_model: 768,
 *         n_heads: 12,
 *         vocab_size: 50257
 *     }
 *     
 *     var system = SelfLearningSystem.new(config)
 *     
 *     // Customize learning
 *     system.learning_rate = 1e-4
 *     system.curriculum.current_difficulty = 0.5
 *     
 *     // Generate initial weights
 *     let weights = system.weight_generator.synthesize_weights(
 *         system.model.architecture,
 *         system.experience_buffer.get_statistics()
 *     )
 *     
 *     system.model.load_weights(weights)
 *     
 *     // Start learning
 *     system.learn_continuously()
 * }
 * ```
 */

/**
 * Example 3: Continuous Pipeline
 * 
 * ```nova
 * import ai.self_learning::*
 * 
 * fn main() {
 *     let config = PipelineConfig {
 *         model_config: ModelConfig {
 *             n_layers: 24,
 *             d_model: 1024,
 *             n_heads: 16,
 *             vocab_size: 50257
 *         },
 *         data_sources: ["web", "synthetic", "self_generated"],
 *         checkpoint_dir: "checkpoints/"
 *     }
 *     
 *     var pipeline = ContinuousPipeline.new(config)
 *     pipeline.start()
 * }
 * ```
 */

/**
 * Example 4: Architecture Search
 * 
 * ```nova
 * import ai.self_learning::*
 * 
 * fn main() {
 *     let nas = NeuralArchitectureSearch.new()
 *     
 *     // Find optimal architecture
 *     let best_arch = nas.search()
 *     
 *     println("Best architecture found:")
 *     println(best_arch.into())
 *     
 *     // Create model with found architecture
 *     var system = SelfLearningSystem.from_architecture(best_arch)
 *     system.learn_continuously()
 * }
 * ```
 */

/**
 * Example 5: Weight Generation Only
 * 
 * ```nova
 * import ai.self_learning::*
 * 
 * fn main() {
 *     let generator = WeightGenerator.new()
 *     
 *     let architecture = ModelArchitecture {
 *         // ... define architecture
 *     }
 *     
 *     // Generate weights using different strategies
 *     generator.synthesis_strategy = SynthesisStrategy::Evolutionary
 *     let weights = generator.synthesize_weights(architecture, stats)
 *     
 *     // Save weights
 *     weights.save("generated_weights.safetensors")
 * }
 * ```
 */
