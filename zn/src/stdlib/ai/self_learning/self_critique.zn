// ═══════════════════════════════════════════════════════════════════════════
// Supporting Types
// ═══════════════════════════════════════════════════════════════════════════

open data Claim {
    statement: str,
    alias: ClaimType,
    evidence: Evidence,
    strength: f32
}

open cases ClaimType {
    PerformanceImprovement,
    NoRegression,
    Generalization,
    ArchitecturalValidity
}

open data Evidence {
    // Placeholder for evidence data
}

open data RefutationResult {
    refuted: bool,
    counterexample: str,
    strength: f32,
    method: str
}

open data ProofResult {
    proved: bool,
    proof: Option<str>,
    method: str
}

open data Decision {
    approved: bool,
    confidence: f32,
    reasoning: str
}

open data CritiqueResult {
    approved: bool,
    confidence: f32,
    reasoning: str,
    surviving_claims: Vec<Claim>,
    refuted_claims: usize,
    proved_claims: usize
}

open data CritiqueRecord {
    proposed_change: Change,
    claims: Vec<Claim>,
    refutation_results: Vec<RefutationResult>,
    proof_results: Vec<ProofResult>,
    decision: Decision,
    timestamp: u64
}

open data CritiqueSummary {
    total_critiques: usize,
    approved: usize,
    rejected: usize,
    approval_rate: f32,
    total_claims: usize,
    refuted_claims: usize,
    proved_claims: usize,
    refutation_rate: f32
}

impl CritiqueSummary {
    fn empty() -> CritiqueSummary {
        CritiqueSummary {
            total_critiques: 0,
            approved: 0,
            rejected: 0,
            approval_rate: 0.0,
            total_claims: 0,
            refuted_claims: 0,
            proved_claims: 0,
            refutation_rate: 0.0
        }
    }
}

open data Change {
    expected_improvement: f32,
    performance_evidence: Evidence,
    holdout_evidence: Evidence,
    ood_evidence: Evidence,
    architecture_evidence: Evidence
}

impl Change {
    fn is_architecture_change(self) -> bool {
        yield false  // Placeholder
    }
}

open data State {
    // Current system state
}

open data ClaimTemplate {
    // Template for generating claims
}

open cases AttackStrategy {
    Counterexample,
    EdgeCase,
    DistributionShift,
    LogicalContradiction
}

open data TestResult {
    failed: bool,
    confidence: f32
}
