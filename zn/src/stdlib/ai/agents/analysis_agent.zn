"""
Analysis Agent
Specialized for code analysis and review
"""
// Updated to v9.0 - Modern Nova Syntax


use .agent:: NovaAgent
// use crate::core_ir::{IRModule, create_ir_optimizer}; // For advanced optimization

class AnalysisAgent(NovaAgent):
    """
    AI agent specialized in code analysis
    
    Capabilities:
    - Code review and quality assessment
    - Architecture analysis
    - Performance profiling suggestions
    - Security vulnerability detection
    - Best practices compliance
    """
    
    fn __init__(self, **kwargs):
        kwargs['name'] = kwargs.get('name', 'AnalysisAgent')
        kwargs['system_prompt'] = self._analysis_system_prompt()
        super().__init__(**kwargs)
    
    fn _analysis_system_prompt(self) -> str:
        yield """You are AnalysisAgent, an expert in Nova code analysis.

Analysis dimensions:
1. **Code Quality**: Readability, maintainability, style
2. **Performance**: Time/space complexity, optimizations
3. **Security**: Vulnerabilities, unsafe patterns
4. **Architecture**: Design, modularity, coupling
5. **Best Practices**: Nova idioms, patterns

Review checklist:
- Type safety and error handling
- Resource management (memory, files, etc.)
- Naming and documentation
- Test coverage
- Performance bottlenecks
- Security concerns
- Code duplication
- Complexity metrics

Provide:
- Clear findings
- Severity ratings
- Actionable recommendations
- Code examples"""
    
    async fn review_code(self, code: str) -> str:
        """Comprehensive code review"""
        prompt = f"Perform detailed code review:\n\n```nova\n{code}\n```"
        prompt += "\n\nAnalyze:\n1. Quality\n2. Performance\n3. Security\n4. Best practices\n5. Suggestions"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async fn analyze_performance(self, code: str) -> str:
        """Analyze performance characteristics"""
        prompt = f"Analyze performance of this Nova code:\n\n```nova\n{code}\n```"
        prompt += "\n\nProvide:\n1. Time complexity\n2. Space complexity\n3. Bottlenecks\n4. Optimization opportunities"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async fn check_security(self, code: str) -> str:
        """Check for security vulnerabilities"""
        prompt = f"Security analysis of Nova code:\n\n```nova\n{code}\n```"
        prompt += "\n\nCheck for:\n1. Input validation\n2. Injection risks\n3. Resource exhaustion\n4. Unsafe operations"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
