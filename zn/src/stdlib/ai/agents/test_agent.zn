"""
Test Agent
Specialized for test generation and coverage
"""
// Updated to v9.0 - Modern Nova Syntax


use .agent:: NovaAgent
// use crate::core_ir::{IRModule, create_ir_optimizer}; // For advanced optimization

class TestAgent(NovaAgent):
    """
    AI agent specialized in testing
    
    Capabilities:
    - Generate unit tests
    - Create integration tests
    - Design test cases
    - Improve test coverage
    - Test-driven development support
    """
    
    fn __init__(self, **kwargs):
        kwargs['name'] = kwargs.get('name', 'TestAgent')
        kwargs['system_prompt'] = self._test_system_prompt()
        super().__init__(**kwargs)
    
    fn _test_system_prompt(self) -> str:
        yield """You are TestAgent, an expert in Nova testing.

Testing philosophy:
1. **Comprehensive**: Cover all paths and edge cases
2. **Clear**: Tests document expected behavior
3. **Fast**: Quick feedback loop
4. **Maintainable**: Easy to understand and update
5. **Reliable**: No flaky tests

Test types:
- Unit tests: Individual functions/methods
- Integration tests: Component interactions
- Edge cases: Boundary conditions
- Error cases: Exception handling
- Property tests: Invariants

Best practices:
- Arrange-Act-Assert pattern
- Descriptive test names
- One assertion per test (when possible)
- Mock external dependencies
- Test both success and failure paths"""
    
    async fn generate_tests(self, code: str, coverage_level: str = "comprehensive") -> str:
        """
        Generate tests for code
        
        Args:
            code: Code to test
            coverage_level: basic, standard, or comprehensive
            
        Returns:
            Generated test code
        """
        prompt = f"Generate {coverage_level} tests for this Nova code:\n\n```nova\n{code}\n```"
        prompt += "\n\nInclude:\n- Unit tests\n- Edge cases\n- Error cases\n- Example usage as tests"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async fn improve_coverage(self, code: str, existing_tests: str) -> str:
        """Suggest additional tests for better coverage"""
        prompt = f"Analyze test coverage and suggest improvements:\n\nCode:\n```nova\n{code}\n```"
        prompt += f"\n\nExisting tests:\n```nova\n{existing_tests}\n```"
        prompt += "\n\nIdentify:\n1. Uncovered paths\n2. Missing edge cases\n3. Suggested new tests"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
