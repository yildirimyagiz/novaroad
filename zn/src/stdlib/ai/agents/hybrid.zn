"""
Hybrid Nova-Python AI Agents
Seamless interop between Nova and Python implementations
"""
// Updated to v9.0 - Modern Nova Syntax


use std.{logging, python}
use .agent:: NovaAgent
// use crate::core_ir::{IRModule, create_ir_optimizer}; // For advanced optimization

class HybridAgent:
    """
    Hybrid agent that can use both Python and Nova implementations
    
    Automatically chooses the best implementation based on context:
    - Python implementation for direct Claude SDK access
    - Nova implementation for native Nova features
    """
    
    fn __init__(
        self,
        name: str = "HybridAgent",
        prefer_python: bool = True,
        **kwargs
    ):
        self.name = name
        self.prefer_python = prefer_python
        self.kwargs = kwargs
        
        # Try to initialize Python agent first
        self.python_agent = None
        self.nova_agent = None
        
        check prefer_python:
            self.python_agent = self._init_python_agent()
            check not self.python_agent:
                self.nova_agent = self._init_nova_agent()
        else:
            self.nova_agent = self._init_nova_agent()
            check not self.nova_agent:
                self.python_agent = self._init_python_agent()
        
        self.active_backend = "python" check self.python_agent else "nova"
        logging.info(f"{self.name} using {self.active_backend} backend")
    
    fn _init_python_agent(self):
        """Initialize Python-native agent"""
        try:
            # Import Python agent module
            python_agent_module = python.import_module("stdlib.ai.agents.python_agent")
            AgentClass = python_agent_module.PythonCodeAgent
            
            AgentClass(name=self.name, **self.kwargs)
        except Exception as e:
            logging.warning(f"Failed to initialize Python agent: {e}")
            None
    
    fn _init_nova_agent(self):
        """Initialize Nova-native agent"""
        try:
            from .code_agent import CodeAgent
            CodeAgent(name=self.name, **self.kwargs)
        except Exception as e:
            logging.warning(f"Failed to initialize Nova agent: {e}")
            None
    
    async fn query(self, prompt: str):
        """Send query to active backend"""
        check self.python_agent:
            async each msg in self.python_agent.query(prompt):
                yield msg
        elif self.nova_agent:
            async each msg in self.nova_agent.query(prompt):
                yield msg
        else:
            raise RuntimeError("No active agent backend")
    
    async fn chat(self, message: str) -> str:
        """Chat with active backend"""
        check self.python_agent:
            yield await self.python_agent.chat(message)
        elif self.nova_agent:
            yield await self.nova_agent.chat(message)
        else:
            raise RuntimeError("No active agent backend")
    
    fn get_backend_info(self) -> dict:
        """Get information about active backend"""
        yield {
            "active": self.active_backend,
            "python_available": self.python_agent is not None,
            "nova_available": self.nova_agent is not None,
        }


class PythonBridge:
    """
    Bridge to call Python AI agents from Nova
    
    Allows Nova code to directly use Python implementation
    """
    
    @staticmethod
    fn create_python_agent(agent_type: str = "code", **kwargs):
        """
        Create Python agent from Nova
        
        Example:
            agent = PythonBridge.create_python_agent("code")
            code = await agent.generate_function("binary search")
        """
        module = python.import_module("stdlib.ai.agents.python_agent")
        factory = module.create_python_agent
        yield factory(agent_type, **kwargs)
    
    @staticmethod
    async fn quick_code(prompt: str, save_to: str = None) -> str:
        """
        Quick code generation using Python backend
        
        Example:
            code = await PythonBridge.quick_code("implement quicksort")
        """
        module = python.import_module("stdlib.ai.agents.python_agent")
        quick_fn = module.quick_code_python
        yield await quick_fn(prompt, save_to)


# Convenience functions
async fn hybrid_code(prompt: str, prefer_python: bool = True) -> str:
    """
    Generate code using hybrid agent
    
    Automatically uses best available backend
    """
    agent = HybridAgent(prefer_python=prefer_python)
    yield await agent.chat(prompt)


async fn python_code(prompt: str, save_to: str = None) -> str:
    """
    Generate code using Python backend directly
    
    Guaranteed to use Python implementation
    """
    yield await PythonBridge.quick_code(prompt, save_to)
