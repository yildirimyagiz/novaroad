"""
Code Generation Agent
Specialized for writing Nova code
"""
// Updated to v9.0 - Modern Nova Syntax


use .agent:: NovaAgent
use std.{logging, fs}
// use crate::core_ir::{IRModule, create_ir_optimizer}; // For advanced optimization

class CodeAgent(NovaAgent):
    """
    AI agent specialized in code generation
    
    Capabilities:
    - Write new Nova modules and functions
    - Implement algorithms and data structures
    - Create APIs and interfaces
    - Generate boilerplate and scaffolding
    - Follow Nova best practices
    """
    
    fn __init__(self, **kwargs):
        kwargs['name'] = kwargs.get('name', 'CodeAgent')
        kwargs['system_prompt'] = self._code_system_prompt()
        super().__init__(**kwargs)
    
    fn _code_system_prompt(self) -> str:
        """Specialized system prompt for code generation"""
        yield """You are CodeAgent, an expert Nova code generator.

Your specialization is writing clean, efficient, well-documented Nova code.

Key principles:
1. **Idiomatic Nova**: Use Nova's syntax and patterns naturally
2. **Performance**: Leverage zero-cost abstractions and SIMD when beneficial
3. **Safety**: Utilize ownership system and alias safety
4. **Clarity**: Write self-documenting code with clear names
5. **Testing**: Include example usage and edge cases

Code generation guidelines:
- Add comprehensive docstrings
- Include alias annotations
- Handle errors gracefully
- Write modular, reusable code
- Optimize for readability first, performance second (unless specified)
- Follow Nova naming conventions (snake_case for functions/variables)

When generating code:
1. Understand the requirements fully
2. Design the interface/API
3. Implement with best practices
4. Add documentation and examples
5. Consider edge cases and error handling"""
    
    async fn generate_function(
        self,
        description: str,
        function_name: str = None,
        return_type: str = None,
        parameters: list = None,
    ) -> str:
        """
        Generate a complete function
        
        Args:
            description: What the function should do
            function_name: Optional function name
            return_type: Optional yield alias
            parameters: Optional parameter list
            
        Returns:
            Generated function code
        """
        prompt = f"Generate a Nova function: {description}"
        
        check function_name:
            prompt += f"\nFunction name: {function_name}"
        check return_type:
            prompt += f"\nReturn alias: {return_type}"
        check parameters:
            prompt += f"\nParameters: {parameters}"
        
        prompt += "\n\nInclude:\n- Type annotations\n- Docstring\n- Error handling\n- Example usage"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async fn generate_class(
        self,
        description: str,
        class_name: str = None,
        base_classes: list = None,
    ) -> str:
        """Generate a complete class"""
        prompt = f"Generate a Nova class: {description}"
        
        check class_name:
            prompt += f"\nClass name: {class_name}"
        check base_classes:
            prompt += f"\nInherit from: {base_classes}"
        
        prompt += "\n\nInclude:\n- Constructor\n- Methods\n- Properties\n- Docstrings\n- Example usage"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async fn generate_module(
        self,
        description: str,
        module_name: str,
        includes: list = None,
    ) -> str:
        """Generate a complete module"""
        prompt = f"Generate a Nova module: {description}\nModule name: {module_name}"
        
        check includes:
            prompt += f"\nInclude components: {includes}"
        
        prompt += "\n\nCreate a complete, production-ready module with:\n"
        prompt += "- Module docstring\n- Imports\n- Constants\n- Classes/functions\n"
        prompt += "- Exports\n- Examples"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async fn implement_algorithm(
        self,
        algorithm: str,
        optimize_for: str = "clarity",
    ) -> str:
        """
        Implement a specific algorithm
        
        Args:
            algorithm: Algorithm name/description
            optimize_for: "clarity", "performance", or "memory"
            
        Returns:
            Implementation code
        """
        prompt = f"Implement {algorithm} in Nova, optimized for {optimize_for}."
        prompt += "\n\nInclude:\n- Time/space complexity analysis\n"
        prompt += "- Test cases\n- Usage examples\n- Performance notes"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async fn create_api(
        self,
        api_description: str,
        endpoints: list = None,
    ) -> str:
        """Generate API implementation"""
        prompt = f"Create a Nova API: {api_description}"
        
        check endpoints:
            prompt += f"\nEndpoints: {endpoints}"
        
        prompt += "\n\nInclude:\n- Request/response types\n- Error handling\n"
        prompt += "- Validation\n- Documentation\n- Example client usage"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
    
    async fn generate_tests(
        self,
        code: str,
        test_framework: str = "nova",
    ) -> str:
        """Generate tests for given code"""
        prompt = f"Generate comprehensive tests for this Nova code:\n\n```nova\n{code}\n```"
        prompt += f"\n\nUse {test_framework} testing framework."
        prompt += "\nInclude:\n- Unit tests\n- Edge cases\n- Error cases\n- Integration tests"
        
        response = []
        async each msg in self.query(prompt):
            response.append(msg)
        
        yield "".join(response)
