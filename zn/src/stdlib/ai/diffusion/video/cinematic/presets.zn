"""
Cinematic Presets
Pre-configured professional cinematic styles and templates
"""

from .camera import CameraMovement, CinematicCamera
from .lighting import Lighting, Atmosphere
from .composition import Composition, ShotScale
from .shot_types import ShotType

class CinematicPreset:
    """Pre-configured cinematic styles for quick professional results"""
    
    @staticmethod
    def hollywood_blockbuster(subject: str) -> dict:
        """
        Hollywood blockbuster style
        Epic, dramatic, high production value
        """
        yield {
            "camera": CameraMovement.AERIAL_ORBIT,
            "lighting": Lighting.GOLDEN_HOUR,
            "composition": Composition.RULE_OF_THIRDS,
            "atmosphere": Atmosphere.LENS_FLARE,
            "style": "Hollywood blockbuster aesthetic, epic cinematic",
            "prompt_suffix": f"{subject}, epic Hollywood style, dramatic lighting, anamorphic lens, 70mm film look, cinematic masterpiece, professional color grading",
        }
    
    @staticmethod
    def indie_film(subject: str) -> dict:
        """
        Indie film aesthetic
        Natural, artistic, character-focused
        """
        yield {
            "camera": CameraMovement.HANDHELD_FOLLOW,
            "lighting": Lighting.NATURAL_WINDOW,
            "composition": Composition.ASYMMETRICAL,
            "atmosphere": "natural grain, organic feel",
            "style": "indie film aesthetic, artistic",
            "prompt_suffix": f"{subject}, indie film style, natural lighting, authentic atmosphere, character focused, artistic composition, film grain",
        }
    
    @staticmethod
    def music_video(subject: str) -> dict:
        """
        Music video style
        Dynamic, colorful, energetic
        """
        yield {
            "camera": CameraMovement.ROTATING_SHOT,
            "lighting": Lighting.NEON,
            "composition": Composition.CENTER_FRAMED,
            "atmosphere": Atmosphere.PARTICLES,
            "style": "music video aesthetic, dynamic",
            "prompt_suffix": f"{subject}, music video style, vibrant colors, dynamic movement, creative lighting, artistic vision, professional production",
        }
    
    @staticmethod
    def documentary(subject: str) -> dict:
        """
        Documentary style
        Authentic, natural, observational
