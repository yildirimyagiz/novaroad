            "style": "film noir aesthetic, classic",
            "prompt_suffix": f"{subject}, film noir style, dramatic shadows, high contrast, venetian blinds lighting, mysterious atmosphere, classic noir aesthetic",
        }
    
    @staticmethod
    def sci_fi_epic(subject: str) -> dict:
