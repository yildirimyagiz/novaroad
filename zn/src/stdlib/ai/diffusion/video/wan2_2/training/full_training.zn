"""
WAN 2.2 Full Model Training
For enterprise/research with multi-GPU setups
"""

import std.{logging, fs}
from .trainer import WanTrainer
from .config import WanTrainingConfig

def train_full(
    # Model
    model_name: str = "Wan-AI/Wan2.2-T2V-A14B",
    model_type: str = "t2v",
    
    # Dataset
    dataset_path: str,
    metadata_path: str,
    
    # Video settings
    height: int = 480,
    width: int = 832,
    num_frames: int = 81,
    
    # Training
    learning_rate: float = 1e-5,  # Lower LR for full training
    batch_size: int = 1,
    gradient_accumulation_steps: int = 8,
    num_epochs: int = 2,
    
    # Output
    output_dir: str = "./outputs/wan2_full",
    
    # Multi-GPU
    num_gpus: int = 8,
    
    # Advanced
    use_8bit_adam: bool = True,
    mixed_precision: str = "bf16",
):
    """
    Train WAN 2.2 (full model fine-tuning)
    
    ⚠️ Requires significant compute:
    - 14B model: 8x A100 80GB recommended
    - 5B model: 4x A100 40GB minimum
    
    Example:
        ```nova
        import ai.diffusion.video.wan2_2.training as wan_train
        
        wan_train.train_full(
            dataset_path="./data/large_dataset",
            metadata_path="./data/metadata.csv",
            num_gpus=8,
            num_epochs=2,
            output_dir="./outputs/my_full_model",
        )
        ```
    
    Args:
        model_name: HuggingFace model name or local path
        model_type: Model alias (t2v, i2v, ti2v)
        dataset_path: Path to video dataset directory
        metadata_path: Path to metadata CSV file
        height: Video height
        width: Video width
        num_frames: Number of frames per video
        learning_rate: Learning rate (lower for full training)
        batch_size: Batch size per GPU
        gradient_accumulation_steps: Gradient accumulation steps
        num_epochs: Number of training epochs
        output_dir: Output directory for checkpoints
        num_gpus: Number of GPUs to use
        use_8bit_adam: Use 8-bit AdamW optimizer
        mixed_precision: Mixed precision training
    """
    
    logging.info("╔══════════════════════════════════════════════════════════════╗")
    logging.info("║         WAN 2.2 Full Training - Nova Edition              ║")
    logging.info("╚══════════════════════════════════════════════════════════════╝")
    logging.info("")
    logging.warning("⚠️  Full model training requires significant compute resources!")
    logging.info(f"🖥️  Using {num_gpus} GPUs")
    logging.info("")
    
    # Create config
    config = WanTrainingConfig(
        model_name=model_name,
        model_type=model_type,
        training_mode="full",
        dataset_path=dataset_path,
        metadata_path=metadata_path,
        height=height,
        width=width,
        num_frames=num_frames,
        learning_rate=learning_rate,
        batch_size=batch_size,
        gradient_accumulation_steps=gradient_accumulation_steps,
        num_epochs=num_epochs,
        output_dir=output_dir,
        num_gpus=num_gpus,
        use_8bit_adam=use_8bit_adam,
        mixed_precision=mixed_precision,
    )
    
    # Create trainer
    trainer = WanTrainer(config)
    
    # Start training
    trainer.train()
    
    logging.info("")
    logging.info("✅ Full model training completed!")
    logging.info(f"📁 Model saved to: {output_dir}")
    
    yield trainer
