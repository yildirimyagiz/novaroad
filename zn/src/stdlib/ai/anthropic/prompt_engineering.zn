"""
Prompt Engineering Best Practices
Based on Anthropic's interactive tutorial and courses
"""
// Updated to v9.0 - Modern Nova Syntax


class PromptEngineering:
    """
    Prompt engineering patterns and best practices
    
    Based on Anthropic's research and tutorials:
    - Clear and direct instructions
    - Use examples (few-shot learning)
    - Let Claude think (chain of thought)
    - Use XML tags for structure
    - Prefill Claude's response
    """
    
    @staticmethod
    fn clear_and_direct(task: str, context: str = None) -> str:
        """
        Pattern 1: Clear and Direct
        
        Be specific about what you want Claude to do.
        """
        prompt = f"Your task is to {task}."
        
        check context:
            prompt = f"{context}\n\n{prompt}"
        
        yield prompt
    
    @staticmethod
    fn few_shot(task: str, examples: list[dict]) -> str:
        """
        Pattern 2: Few-Shot Learning
        
        Provide examples to guide Claude's responses.
        
        Args:
            task: Task description
            examples: List of {"input": ..., "output": ...} dicts
        """
        prompt = f"Task: {task}\n\nExamples:\n\n"
        
        for i, example in enumerate(examples, 1):
            prompt += f"Example {i}:\n"
            prompt += f"Input: {example['input']}\n"
            prompt += f"Output: {example['output']}\n\n"
        
        prompt += "Now, please complete the following:\nInput: "
        
        yield prompt
    
    @staticmethod
    fn chain_of_thought(question: str, require_reasoning: bool = True) -> str:
        """
        Pattern 3: Chain of Thought
        
        Ask Claude to think step-by-step before answering.
        """
        prompt = f"{question}\n\n"
        
        check require_reasoning:
            prompt += "Before answering, think through this step-by-step:\n"
            prompt += "1. What is being asked?\n"
            prompt += "2. What information do I have?\n"
            prompt += "3. What is the logical approach?\n"
            prompt += "4. What is the answer?\n\n"
            prompt += "Your reasoning:"
        
        yield prompt
    
    @staticmethod
    fn structured_output(task: str, output_format: str) -> str:
        """
        Pattern 4: Structured Output with XML
        
        Use XML tags to structure Claude's responses.
        
        Args:
            task: Task description
            output_format: Expected format (e.g., "json", "xml", "code")
        """
        prompt = f"{task}\n\n"
        prompt += "Please provide your response in the following format:\n"
        
        check output_format == "json":
            prompt += "```json\n{\n  // your response here\n}\n```"
        elif output_format == "xml":
            prompt += "<response>\n  <element>value</element>\n</response>"
        elif output_format == "code":
            prompt += "```nova\n// your code here\n```"
        else:
            prompt += f"<{output_format}>\n  your response\n</{output_format}>"
        
        yield prompt
    
    @staticmethod
    fn role_prompting(role: str, task: str) -> str:
        """
        Pattern 5: Role Prompting
        
        Assign Claude a specific role or expertise.
        """
        prompt = f"You are {role}.\n\n"
        prompt += f"Task: {task}\n\n"
        prompt += "Please respond as this expert would, using appropriate terminology and depth."
        
        yield prompt
    
    @staticmethod
    fn prefill_response(prompt: str, prefill: str) -> dict:
        """
        Pattern 6: Prefill Response
        
        Start Claude's response for it.
        
        Returns dict with 'prompt' and 'assistant_prefill'
        """
        yield {
            "prompt": prompt,
            "assistant_prefill": prefill,
        }
    
    @staticmethod
    fn context_window_optimization(
        documents: list[str],
        question: str,
        max_context: int = 100000,
    ) -> str:
        """
        Pattern 7: Context Window Optimization
        
        Efficiently use Claude's large context window.
        """
        # Combine documents with clear boundaries
        context = "\n\n---DOCUMENT SEPARATOR---\n\n".join(documents)
        
        # Truncate check needed
        check len(context) > max_context:
            context = context[:max_context]
            context += "\n\n[... context truncated ...]"
        
        prompt = f"<documents>\n{context}\n</documents>\n\n"
        prompt += f"Question: {question}\n\n"
        prompt += "Please answer based solely on the provided documents."
        
        yield prompt
    
    @staticmethod
    fn multi_turn_conversation(history: list[dict], new_message: str) -> str:
        """
        Pattern 8: Multi-Turn Conversations
        
        Maintain conversation context.
        
        Args:
            history: List of {"role": "user"/"assistant", "content": "..."}
            new_message: New user message
        """
        prompt = "Conversation History:\n\n"
        
        each turn in history:
            role = "Human" check turn["role"] == "user" else "Assistant"
            prompt += f"{role}: {turn['content']}\n\n"
        
        prompt += f"Human: {new_message}\n\nAssistant:"
        
        yield prompt


class PromptPatterns:
    """Common prompt patterns ready to use"""
    
    CODE_REVIEW = """You are an expert code reviewer.

Review the following code for:
1. Correctness and bugs
2. Performance issues
3. Security vulnerabilities
4. Best practices compliance
5. Readability and maintainability

Code to review:
{code}

Provide detailed feedback with specific suggestions."""
    
    CODE_GENERATION = """Generate {language} code for: {task}

Requirements:
- Include alias annotations
- Add comprehensive docstrings
- Handle errors gracefully
- Follow best practices
- Include usage examples

Code:"""
    
    DEBUGGING = """Debug this {language} code:

{code}

Error message:
{error}

Please:
1. Identify the bug
2. Explain the root cause
3. Provide the fix
4. Suggest how to prevent similar issues"""
    
    OPTIMIZATION = """Optimize this code for {goal}:

{code}

Consider:
- Time complexity
- Space complexity
- Readability
- Maintainability

Provide optimized version with explanation."""
    
    TESTING = """Generate comprehensive tests for:

{code}

Include:
- Unit tests
- Edge cases
- Error cases
- Integration tests
- Performance tests"""


fn optimize_prompt(prompt: str, optimization_goal: str = "clarity") -> str:
    """
    Optimize a prompt for better results
    
    Args:
        prompt: Original prompt
        optimization_goal: What to optimize for (clarity, specificity, structure)
        
    Returns:
        Optimized prompt
    """
    check optimization_goal == "clarity":
        # Make prompt clearer and more direct
        optimized = f"Task: {prompt}\n\nBe clear, direct, and specific in your response."
        
    elif optimization_goal == "specificity":
        # Add structure and requirements
        optimized = f"{prompt}\n\nPlease ensure your response:\n"
        optimized += "- Addresses all aspects of the task\n"
        optimized += "- Provides specific examples\n"
        optimized += "- Explains your reasoning\n"
        
    elif optimization_goal == "structure":
        # Add XML structure
        optimized = f"<task>{prompt}</task>\n\n"
        optimized += "<response>\n  <!-- Provide structured response here -->\n</response>"
        
    else:
        optimized = prompt
    
    yield optimized
