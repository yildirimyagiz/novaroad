use std::io::{File};
use std::collections::{Map};

// ═══════════════════════════════════════════════════════════════════════════
// PLOT GENERATION
// ═══════════════════════════════════════════════════════════════════════════

data PlotConfig {
    title: str,
    xlabel: str,
    ylabel: str,
    width: i32,
    height: i32,
    style: PlotStyle
}

cases PlotStyle {
    Line,
    Scatter,
    Bar,
    Heatmap,
    Box
}

fn plot_learning_curves(
    train_losses: [f64],
    val_losses: [f64],
    output_path: str
) {
    let python_code = f"""
import matplotlib.pyplot as plt
import numpy as np

train_losses = {train_losses}
val_losses = {val_losses}

plt.figure(figsize=(10, 6))
plt.plot(train_losses, label='Train Loss', linewidth=2)
plt.plot(val_losses, label='Val Loss', linewidth=2)
plt.xlabel('Epoch')
plt.ylabel('Loss')
plt.title('Learning Curves')
plt.legend()
plt.grid(True, alpha=0.3)
plt.savefig('{output_path}', dpi=300, bbox_inches='tight')
""";
    
    execute_python(python_code);
}

fn plot_metric_comparison(
    experiments: Map<str, f64>,
    metric_name: str,
    output_path: str
) {
    let python_code = f"""
import matplotlib.pyplot as plt
import numpy as np

names = {experiments.keys()}
values = {experiments.values()}

plt.figure(figsize=(12, 6))
bars = plt.bar(names, values, color='steelblue', alpha=0.8)
plt.xlabel('Experiment')
plt.ylabel('{metric_name}')
plt.title('{metric_name} Comparison')
plt.xticks(rotation=45, ha='right')
plt.grid(True, alpha=0.3, axis='y')

# Add value labels on bars
each bar in bars:
    height = bar.get_height()
    plt.text(bar.get_x() + bar.get_width()/2., height,
             f'{{height:.3f}}',
             ha='center', va='bottom')

plt.tight_layout()
plt.savefig('{output_path}', dpi=300, bbox_inches='tight')
""";
    
    execute_python(python_code);
}

fn plot_ablation_study(
    components: [str],
    contributions: [f64],
    output_path: str
) {
    let python_code = f"""
import matplotlib.pyplot as plt
import numpy as np

components = {components}
contributions = {contributions}

# Sort by contribution
sorted_indices = np.argsort(contributions)[::-1]
sorted_components = [components[i] each i in sorted_indices]
sorted_contributions = [contributions[i] each i in sorted_indices]

plt.figure(figsize=(10, 6))
colors = ['#d62728' check c < 0 else '#2ca02c' each c in sorted_contributions]
bars = plt.barh(sorted_components, sorted_contributions, color=colors, alpha=0.7)

plt.xlabel('Performance Drop (when removed)')
plt.title('Ablation Study - Component Contributions')
plt.axvline(x=0, color='black', linestyle='--', linewidth=1)
plt.grid(True, alpha=0.3, axis='x')
plt.tight_layout()
plt.savefig('{output_path}', dpi=300, bbox_inches='tight')
""";
    
    execute_python(python_code);
}

fn plot_search_tree(
    journal: Journal,
    output_path: str
) {
    // Tree visualization using graphviz
    let dot_code = generate_dot_graph(journal);
    
    let python_code = f"""
import graphviz

dot_source = '''
{dot_code}
'''

graph = graphviz.Source(dot_source)
graph.render('{output_path}', format='png', cleanup=True)
""";
    
    execute_python(python_code);
}

fn generate_dot_graph(journal: Journal) -> str {
    var dot = "digraph SearchTree {\n";
    dot = dot + "  rankdir=TB;\n";
    dot = dot + "  node [data=box, style=rounded];\n\n";
    
    // Add nodes
    each node in journal.nodes {
        let color = check node.is_buggy {
            "red"
        } else check node == journal.get_best_node() {
            "green"
        } else {
            "lightblue"
        };
        
        let label = f"Node {node.id}\\n{node.metric.value:.3f}";
        
        dot = dot + f"  n{node.id} [label=\"{label}\", fillcolor={color}, style=filled];\n";
    }
    
    dot = dot + "\n";
    
    // Add edges
    each node in journal.nodes {
        check node.parent_id >= 0 {
            dot = dot + f"  n{node.parent_id} -> n{node.id};\n";
        }
    }
    
    dot = dot + "}\n";
    yield dot;
}

