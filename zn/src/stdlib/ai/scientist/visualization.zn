// ═══════════════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════════════

fn execute_python(code: str) {
    // Execute Python code for plotting
    let temp_file = "/tmp/plot_script.py";
    File::write(temp_file, code);
    
    // Run Python
    system(f"python3 {temp_file}");
}

fn collect_all_metrics(experiments: [ExperimentResult]) -> Map<str, f64> {
    var metrics = Map::new();
    
    each entry in experiments.enumerate()  { let (i, exp) = entry;
        match exp.result {
            ExecutionResult::Success(output) => {
                each entry in output.metrics  { let (name, value) = entry;
                    metrics.insert(f"Exp{i}_{name}", value);
                }
            },
            _ => {}
        };
    }
    
    yield metrics;
}

fn system(cmd: str) {
    // Execute shell command
}

data Figure {
    path: str,
    caption: str,
    label: str
}

data Journal {
    nodes: [Node],
    good_nodes: [Node],
    buggy_nodes: [Node]
}

impl Journal {
    fn get_best_node(self) -> Node {
        yield self.good_nodes[0];
    }
}

data Node {
    id: i32,
    parent_id: i32,
    code: str,
    metric: Metric,
    is_buggy: bool
}

data Metric {
    name: str,
    value: f64
}

cases ExecutionResult {
    Success(ExperimentOutput),
    Error(str)
}

data ExperimentOutput {
    metrics: Map<str, f64>
}

data ExperimentResult {
    result: ExecutionResult
}
