// PAPER FIGURES GENERATION
// ═══════════════════════════════════════════════════════════════════════════

fn generate_paper_figures(
    journal: Journal,
    output_dir: str
) -> [Figure] {
    var figures: [Figure] = [];
    
    // Figure 1: Main results
    let main_results_path = f"{output_dir}/fig1_main_results.pdf";
    plot_main_results(journal, main_results_path);
    figures.push(Figure {
        path: main_results_path,
        caption: "Main experimental results showing performance across different variants.",
        label: "fig:main_results"
    });
    
    // Figure 2: Ablation study
    let ablation_path = f"{output_dir}/fig2_ablation.pdf";
    plot_ablation_from_journal(journal, ablation_path);
    figures.push(Figure {
        path: ablation_path,
        caption: "Ablation study demonstrating the contribution of each component.",
        label: "fig:ablation"
    });
    
    // Figure 3: Search tree
    let tree_path = f"{output_dir}/fig3_search_tree.pdf";
    plot_search_tree(journal, tree_path);
    figures.push(Figure {
        path: tree_path,
        caption: "Visualization of the exploration tree during the search process.",
        label: "fig:search_tree"
    });
    
    yield figures;
}

