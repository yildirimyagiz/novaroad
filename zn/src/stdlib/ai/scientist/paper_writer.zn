/**
 * Nova AI-Scientist: Academic Paper Writer
 * 
 * Otomatik makale yazma ve LaTeX oluşturma
 */

use ai::core::{LLM};
use std::io::{File};

// ═══════════════════════════════════════════════════════════════════════════
// PAPER STRUCTURE
// ═══════════════════════════════════════════════════════════════════════════

data PaperSection {
    title: str,
    content: str,
    subsections: [PaperSection]
}

data Citation {
    key: str,
    title: str,
    authors: [str],
    year: i32,
    venue: str,
    url: str
}

data Figure {
    path: str,
    caption: str,
    label: str
}

data Table {
    caption: str,
    label: str,
    headers: [str],
    rows: [[str]]
}

// ═══════════════════════════════════════════════════════════════════════════
// PAPER WRITER
// ═══════════════════════════════════════════════════════════════════════════

data PaperWriter {
    llm: LLM,
    citations: [Citation],
    figures: [Figure],
    tables: [Table]
}

impl PaperWriter {
    fn new(model: str) -> PaperWriter {
        PaperWriter {
            llm: LLM::new(model),
            citations: [],
            figures: [],
            tables: []
        };
    }
    
    fn write_full_paper(
        var self,
        journal: Journal,
        experiment: Experiment
    ) -> Paper {
        print("Writing paper sections...");
        
        // Abstract
        let abstract = self.write_abstract(journal, experiment);
        
        // Introduction
        let introduction = self.write_introduction(experiment);
        
        // Related Work (with citations)
        let related_work = self.write_related_work(experiment);
        
        // Methodology
        let methodology = self.write_methodology(journal);
        
        // Experiments
        let experiments = self.write_experiments(journal);
        
        // Results
        let results = self.write_results(journal);
        
        // Discussion
        let discussion = self.write_discussion(journal);
        
        // Conclusion
        let conclusion = self.write_conclusion(journal);
        
        Paper {
            title: experiment.name,
            abstract: abstract,
            introduction: introduction,
            methodology: methodology,
            experiments: experiments,
            results: results,
            conclusion: conclusion,
            references: self.format_references()
        };
    }
    
    fn write_abstract(self, journal: Journal, experiment: Experiment) -> str {
        let best_node = journal.get_best_node();
        
        let prompt = f"""
        Write a concise academic abstract (150-200 words) for a research paper.
        
        Topic: {experiment.description}
        Main contribution: {experiment.name}
        Best result: {best_node.metric.name} = {best_node.metric.value}
        
        The abstract should include:
        1. Problem statement
        2. Our approach
        3. Key results
        4. Significance
        
        Use formal academic language.
        """;
        
        yield self.llm.generate(prompt);
    }
    
    fn write_introduction(self, experiment: Experiment) -> str {
        let prompt = f"""
        Write an Introduction section for a research paper.
        
        Topic: {experiment.description}
        
        Structure:
        1. Motivation (why is this problem important?)
        2. Background (what's the current state?)
        3. Gap (what's missing?)
        4. Our contribution (what do we propose?)
        5. Paper organization
        
        Length: 2-3 paragraphs.
        Include citations where appropriate.
        """;
        
        yield self.llm.generate(prompt);
    }
    
    fn write_methodology(self, journal: Journal) -> str {
        let best_node = journal.get_best_node();
        
        let prompt = f"""
        Write a Methodology section describing this approach:
        
        Code:
        ```
        {best_node.code}
        ```
        
        Explain:
        1. Overall architecture
        2. Key algorithms
        3. Design decisions
        4. Implementation details
        
        Use mathematical notation where appropriate.
        Be precise and technical.
        """;
        
        yield self.llm.generate(prompt);
    }
    
    fn write_results(self, journal: Journal) -> str {
        // Tüm good nodes'lardan tablo oluştur
        var table_data: [[str]] = [];
        
        each node in journal.good_nodes {
            table_data.push([
                f"Variant {node.id}",
                f"{node.metric.value}"
            ]);
        }
        
        self.tables.push(Table {
            caption: "Experimental results across all variants",
            label: "tab:results",
            headers: ["Method", "Metric"],
            rows: table_data
        });
        
        let best = journal.get_best_node();
        
        let prompt = f"""
        Write a Results section analyzing these experimental results.
        
        Best performing method: Variant {best.id}
        Best metric: {best.metric.value}
        
        Total variants tested: {journal.good_nodes.len()}
        
        Discuss:
        1. Overall performance trends
        2. Best performing approach
        3. Comparison with baselines
        4. Statistical significance
        
        Reference Table~\\ref{{tab:results}}.
        """;
        
        yield self.llm.generate(prompt);
    }
    
    fn write_related_work(var self, experiment: Experiment) -> str {
        // Semantic Scholar'dan ilgili makaleleri bul
        let papers = self.search_papers(experiment.description);
        
        each paper in papers {
            self.citations.push(Citation {
                key: generate_cite_key(paper.title),
                title: paper.title,
                authors: paper.authors,
                year: paper.year,
                venue: paper.venue,
                url: paper.url
            });
        }
        
        let prompt = f"""
        Write a Related Work section.
        
        Topic: {experiment.description}
        
        Reference these papers:
        {format_paper_list(papers)}
        
        Organize by themes and show how our work differs.
        """;
        
        yield self.llm.generate(prompt);
    }
    
    fn write_discussion(self, journal: Journal) -> str {
        let prompt = f"""
        Write a Discussion section.
        
        Findings: {journal.generate_summary()}
        
        Discuss:
        1. Why did the best approach work?
        2. Limitations
        3. Unexpected findings
        4. Future work
        """;
        
        yield self.llm.generate(prompt);
    }
    
    fn write_conclusion(self, journal: Journal) -> str {
        let best = journal.get_best_node();
        
        let prompt = f"""
        Write a concise Conclusion section (1 paragraph).
        
        Summarize:
        1. What we did
        2. What we found ({best.metric.value})
        3. Impact
        4. Next steps
        """;
        
        yield self.llm.generate(prompt);
    }
    
    fn search_papers(self, query: str) -> [PaperInfo] {
        // Semantic Scholar API integration
        // Şimdilik placeholder
        yield [];
    }
    
    fn format_references(self) -> [str] {
        var refs: [str] = [];
        
        each cite in self.citations {
            let ref_str = f"""
            \\bibitem{{{cite.key}}}
            {format_authors(cite.authors)}.
            \\textit{{{cite.title}}}.
            {cite.venue}, {cite.year}.
            """;
            refs.push(ref_str);
        }
        
        yield refs;
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// LATEX GENERATION
// ═══════════════════════════════════════════════════════════════════════════

fn generate_latex(paper: Paper, writer: PaperWriter) -> str {
    var latex = """
\\documentclass[11pt]{article}
\\usepackage{amsmath,amssymb}
\\usepackage{graphicx}
\\usepackage{hyperref}
\\usepackage{booktabs}
\\usepackage{algorithm}
\\usepackage{algorithmic}

\\title{""" + paper.title + """}
\\author{AI-Scientist (Nova)}
\\date{\\today}

\\begin{document}
\\maketitle

\\begin{abstract}
""" + paper.abstract + """
\\end{abstract}

\\section{Introduction}
""" + paper.introduction + """

\\section{Methodology}
""" + paper.methodology + """

\\section{Experiments}
""" + paper.experiments + """

\\section{Results}
""" + paper.results + """

\\section{Conclusion}
""" + paper.conclusion + """

\\begin{thebibliography}{99}
""";

    each ref in paper.references {
        latex = latex + ref + "\n";
    }
    
    latex = latex + """
\\end{thebibliography}

\\end{document}
""";

    yield latex;
}

// ═══════════════════════════════════════════════════════════════════════════
// HELPERS
// ═══════════════════════════════════════════════════════════════════════════

data PaperInfo {
    title: str,
    authors: [str],
    year: i32,
    venue: str,
    url: str
}

fn generate_cite_key(title: str) -> str {
    // "Novel Attention" -> "novel_attention_2024"
    yield title.to_lower().replace(" ", "_");
}

fn format_authors(authors: [str]) -> str {
    check authors.len() == 1 {
        yield authors[0];
    } else check authors.len() == 2 {
        yield f"{authors[0]} and {authors[1]}";
    } else {
        yield f"{authors[0]} et al.";
    }
}

fn format_paper_list(papers: [PaperInfo]) -> str {
    var output = "";
    each paper in papers {
        output = output + f"- {paper.title} ({paper.year})\n";
    }
    yield output;
}
