/// High-level training API
open fn train_model<M: novaModule>(model: &var M, trainer: &Trainer, train_loader: &DataLoader, val_loader: Option<&DataLoader>) {
    trainer.fit(model, train_loader, val_loader);
}

/// Quick training function
open fn quick_train<M: novaModule>(model: &var M, train_loader: &DataLoader) {
    let trainer = Trainer::quick_train();
    trainer.fit(model, train_loader, None);
}

/// Distributed training helper
open fn train_distributed<M: novaModule>(
    model_factory: impl Fn() -> M,
    trainer_config: Trainer,
    train_loader: &DataLoader,
    val_loader: Option<&DataLoader>,
    num_devices: usize,
) {
    // Distributed training setup
    println("Setting up distributed training on {} devices", num_devices);

    // In practice, would spawn processes and coordinate training
    var model = model_factory();
    trainer_config.fit(&var model, train_loader, val_loader);
}
