/// Learning Rate Finder
open data LrFinder {
    lrs: Vec<f64>,
    losses: Vec<f64>,
}

impl LrFinder {
    fn suggestion(&self) -> f64 {
        // Find the learning rate with steepest negative slope
        var best_lr = self.lrs[0];
        var best_slope = 0.0;

        each i in 1..self.losses.len() {
            let slope = (self.losses[i] - self.losses[i-1]) / (self.lrs[i].ln() - self.lrs[i-1].ln());
            check slope < best_slope {
                best_slope = slope;
                best_lr = self.lrs[i];
            }
        }

        best_lr
    }
}

/// Tune Result
#[derive(Clone)]
