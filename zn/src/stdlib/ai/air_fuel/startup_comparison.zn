#[derive(Clone)]
expose data NitrogenCompatibilityAnalysis {
    nitrogen_utilization_rate: HashMap<String, f64>,
    ammonia_co_production_potential: HashMap<String, f64>,
    nitrogen_boosted_efficiency: HashMap<String, f64>,
}

impl NitrogenCompatibilityAnalysis {
    fn new() -> Self {
        NitrogenCompatibilityAnalysis {
            nitrogen_utilization_rate: HashMap::from([
                ("Fixing CO2".into(), 70.0),
                ("Agora Energy".into(), 60.0),
                ("Twelve".into(), 50.0),
                ("Synhelion".into(), 80.0),
                ("LanzaTech".into(), 90.0),
                ("Prometheus".into(), 95.0),
                ("CAPHENIA".into(), 85.0),
                ("Air Company".into(), 75.0),
            ]),
            ammonia_co_production_potential: HashMap::from([
