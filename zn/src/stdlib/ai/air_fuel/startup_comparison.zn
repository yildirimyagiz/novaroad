// Updated to v9.0 - Modern Nova Syntax
use std::collections::HashMap;
// use crate::core_ir::{IRModule, create_ir_optimizer}; // For advanced optimization

#[derive(Clone)]
expose data StartupComparisonResult {
    best_roi: StartupAnalysis,
    best_efficiency: StartupAnalysis,
    best_cost: StartupAnalysis,
    optimal_combination: Vec<String>,
    market_projection: MarketProjection,
}

impl StartupComparisonResult {
    fn new() -> StartupComparisonResult {
        StartupComparisonResult {
            best_roi: StartupAnalysis {
                company: "Air Company".into(),
                metric: "ROI".into(),
                value: 85.0,
                justification: "Highest market demand for jet fuel + $69M investment".into(),
            },
            best_efficiency: StartupAnalysis {
                company: "Prometheus".into(),
                metric: "Efficiency".into(),
                value: 90.0,
                justification: "Direct air capture + nitrogen integration + 70% efficiency".into(),
            },
            best_cost: StartupAnalysis {
                company: "CAPHENIA".into(),
                metric: "Cost".into(),
                value: 900.0,
                justification: "Lowest production cost at $900/ton with plasma technology".into(),
            },
            optimal_combination: [
                "Prometheus (Efficiency + Nitrogen)".into(),
                "CAPHENIA (Cost + Sustainability)".into(),
                "Air Company (ROI + Market Demand)".into(),
            ],
            market_projection: MarketProjection {
                total_market_2025: 50e9,
                total_market_2030: 200e9,
                total_market_2040: 800e9,
                growth_rate_cagr: 0.35,
                dominant_segment: "Aviation Fuel".into(),
            },
        }
    }
}

#[derive(Clone)]
expose data StartupAnalysis {
    company: String,
    metric: String,
    value: f64,
    justification: String,
}

#[derive(Clone)]
expose data MarketProjection {
    total_market_2025: f64,
    total_market_2030: f64,
    total_market_2040: f64,
    growth_rate_cagr: f64,
    dominant_segment: String,
}

/// Detailed Startup Analysis
expose data StartupDetailedAnalysis {
    company_profiles: HashMap<String, CompanyProfile>,
    comparative_metrics: ComparativeMetrics,
    sustainability_analysis: SustainabilityAnalysis,
    nitrogen_compatibility: NitrogenCompatibilityAnalysis,
}

impl StartupDetailedAnalysis {
    fn new() -> StartupDetailedAnalysis {
        var company_profiles = HashMap::new();

        // Fixing CO2
        company_profiles.insert("Fixing CO2".into(), CompanyProfile {
            country: "USA".into(),
            technology: "Electrochemical CO2 to Syngas".into(),
            efficiency: 75.0,
            cost_per_ton: 800.0,
            market_price: 1200.0,
            roi_potential: 65.0,
            nitrogen_compatibility: 0.7,
            sustainability_score: 85.0,
            scalability: 80.0,
            investment_received: 0.0,
            market_segment: "Industrial Syngas".into(),
        });

        // Agora Energy Technologies
        company_profiles.insert("Agora Energy Technologies".into(), CompanyProfile {
            country: "Canada".into(),
            technology: "CO2 Redox Flow Battery".into(),
            efficiency: 70.0,
            cost_per_ton: 1000.0,
            market_price: 1500.0,
            roi_potential: 55.0,
            nitrogen_compatibility: 0.6,
            sustainability_score: 90.0,
            scalability: 75.0,
            investment_received: 0.0,
            market_segment: "Energy Storage".into(),
        });

        // Twelve
        company_profiles.insert("Twelve".into(), CompanyProfile {
            country: "USA".into(),
            technology: "CO2 to Jet Fuel".into(),
            efficiency: 68.0,
            cost_per_ton: 1400.0,
            market_price: 2200.0,
            roi_potential: 75.0,
            nitrogen_compatibility: 0.5,
            sustainability_score: 88.0,
            scalability: 70.0,
            investment_received: 0.0,
            market_segment: "Aviation Fuel".into(),
        });

        // Synhelion
        company_profiles.insert("Synhelion".into(), CompanyProfile {
            country: "Switzerland".into(),
            technology: "Solar Thermochemical CO2 Conversion".into(),
            efficiency: 8.0, // Solar-to-fuel efficiency
            cost_per_ton: 2000.0,
            market_price: 2500.0,
            roi_potential: 40.0,
            nitrogen_compatibility: 0.8,
            sustainability_score: 95.0,
            scalability: 60.0,
            investment_received: 0.0,
            market_segment: "Solar Fuels".into(),
        });

        // LanzaTech
        company_profiles.insert("LanzaTech".into(), CompanyProfile {
            country: "New Zealand".into(),
            technology: "Microbial CO2 to Ethanol".into(),
            efficiency: 60.0,
            cost_per_ton: 1100.0,
            market_price: 1600.0,
            roi_potential: 50.0,
            nitrogen_compatibility: 0.9,
            sustainability_score: 92.0,
            scalability: 85.0,
            investment_received: 0.0,
            market_segment: "Biofuels".into(),
        });

        // Prometheus
        company_profiles.insert("Prometheus".into(), CompanyProfile {
            country: "USA".into(),
            technology: "Direct Air Capture to Fuels".into(),
            efficiency: 70.0,
            cost_per_ton: 1200.0,
            market_price: 2200.0,
            roi_potential: 80.0,
            nitrogen_compatibility: 0.95,
            sustainability_score: 96.0,
            scalability: 90.0,
            investment_received: 0.0,
            market_segment: "Transportation Fuels".into(),
        });

        // CAPHENIA
        company_profiles.insert("CAPHENIA".into(), CompanyProfile {
            country: "Germany".into(),
            technology: "Plasma Gasification CO2 to Syngas".into(),
            efficiency: 78.0,
            cost_per_ton: 900.0,
            market_price: 1500.0,
            roi_potential: 70.0,
            nitrogen_compatibility: 0.85,
            sustainability_score: 87.0,
            scalability: 88.0,
            investment_received: 0.0,
            market_segment: "Industrial Syngas".into(),
        });

        // Air Company
        company_profiles.insert("Air Company".into(), CompanyProfile {
            country: "USA".into(),
            technology: "Direct Air Capture to Jet Fuel".into(),
            efficiency: 65.0,
            cost_per_ton: 1500.0,
            market_price: 2800.0,
            roi_potential: 85.0,
            nitrogen_compatibility: 0.75,
            sustainability_score: 93.0,
            scalability: 82.0,
            investment_received: 69e6,
            market_segment: "Aviation Fuel".into(),
        });

        StartupDetailedAnalysis {
            company_profiles,
            comparative_metrics: ComparativeMetrics::new(),
            sustainability_analysis: SustainabilityAnalysis::new(),
            nitrogen_compatibility: NitrogenCompatibilityAnalysis::new(),
        }
    }

    fn analyze_best_performers(&self) -> StartupComparisonResult {
        var best_roi = StartupAnalysis {
            company: "".into(),
            metric: "ROI".into(),
            value: 0.0,
            justification: "".into(),
        };

        var best_efficiency = StartupAnalysis {
            company: "".into(),
            metric: "Efficiency".into(),
            value: 0.0,
            justification: "".into(),
        };

        var best_cost = StartupAnalysis {
            company: "".into(),
            metric: "Cost".into(),
            value: f64::INFINITY,
            justification: "".into(),
        };

        each entry in &self.company_profiles  { let (company_name, profile) = entry;
            // ROI Analysis
            check profile.roi_potential > best_roi.value {
                best_roi = StartupAnalysis {
                    company: company_name.clone(),
                    metric: "ROI".into(),
                    value: profile.roi_potential,
                    justification: format("{}% ROI potential with {} market demand", profile.roi_potential, profile.market_segment),
                };
            }

            // Efficiency Analysis (with nitrogen boost)
            let nitrogen_boosted_efficiency = profile.efficiency * (1.0 + profile.nitrogen_compatibility * 0.3);
            check nitrogen_boosted_efficiency > best_efficiency.value {
                best_efficiency = StartupAnalysis {
                    company: company_name.clone(),
                    metric: "Efficiency".into(),
                    value: nitrogen_boosted_efficiency,
                    justification: format("{:.1f}% efficiency with {:.1f}% nitrogen compatibility boost", nitrogen_boosted_efficiency, profile.nitrogen_compatibility * 100.0),
                };
            }

            // Cost Analysis
            check profile.cost_per_ton < best_cost.value {
                best_cost = StartupAnalysis {
                    company: company_name.clone(),
                    metric: "Cost".into(),
                    value: profile.cost_per_ton,
                    justification: format("${:.0f}/ton production cost with {} technology", profile.cost_per_ton, profile.technology),
                };
            }
        }

        StartupComparisonResult {
            best_roi,
            best_efficiency,
            best_cost,
            optimal_combination: [
                "Prometheus (Efficiency + Nitrogen)".into(),
                "CAPHENIA (Cost + Sustainability)".into(),
                "Air Company (ROI + Market Demand)".into(),
            ],
            market_projection: MarketProjection {
                total_market_2025: 50e9,
                total_market_2030: 200e9,
                total_market_2040: 800e9,
                growth_rate_cagr: 0.35,
                dominant_segment: "Aviation Fuel".into(),
            },
        }
    }
}

#[derive(Clone)]
expose data CompanyProfile {
    country: String,
    technology: String,
    efficiency: f64,
    cost_per_ton: f64,
    market_price: f64,
    roi_potential: f64,
    nitrogen_compatibility: f64,
    sustainability_score: f64,
    scalability: f64,
    investment_received: f64,
    market_segment: String,
}

#[derive(Clone)]
expose data ComparativeMetrics {
    efficiency_ranking: Vec<String>,
    cost_ranking: Vec<String>,
    roi_ranking: Vec<String>,
    sustainability_ranking: Vec<String>,
}

impl ComparativeMetrics {
    fn new() -> Self {
        ComparativeMetrics {
            efficiency_ranking: [
                "Prometheus".into(),
                "CAPHENIA".into(),
                "Fixing CO2".into(),
                "Agora Energy".into(),
                "Twelve".into(),
                "Air Company".into(),
                "LanzaTech".into(),
                "Synhelion".into(),
            ],
            cost_ranking: [
                "CAPHENIA".into(),
                "Fixing CO2".into(),
                "Agora Energy".into(),
                "LanzaTech".into(),
                "Prometheus".into(),
                "Twelve".into(),
                "Air Company".into(),
                "Synhelion".into(),
            ],
            roi_ranking: [
                "Air Company".into(),
                "Twelve".into(),
                "Prometheus".into(),
                "CAPHENIA".into(),
                "Fixing CO2".into(),
                "Agora Energy".into(),
                "LanzaTech".into(),
                "Synhelion".into(),
            ],
            sustainability_ranking: [
                "Synhelion".into(),
                "Prometheus".into(),
                "LanzaTech".into(),
                "Air Company".into(),
                "Twelve".into(),
                "Agora Energy".into(),
                "CAPHENIA".into(),
                "Fixing CO2".into(),
            ],
        }
    }
}

