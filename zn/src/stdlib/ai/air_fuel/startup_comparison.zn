            ]),
        }
    }
}

/// Comprehensive Startup Comparison Function
open fn analyze_startup_comparison() -> StartupComparisonResult {
    let analysis = StartupDetailedAnalysis::new();
    analysis.analyze_best_performers()
}

/// Example usage and results display
open fn display_startup_analysis() {
    let results = analyze_startup_comparison();

    println("🚀 NOVA STARTUP COMPARISON ANALYSIS");
    println("====================================");
    println("");
    println("🎯 ANALYSIS RESULTS:");
    println("");
    println("🥇 EN VERİMLİ KAR ÇARPANI (ROI):");
    println("   🏆 {}: {:.1f}% {}", results.best_roi.company, results.best_roi.value, results.best_roi.metric);
    println("   💡 {}", results.best_roi.justification);
    println("");
    println("⚡ EN YÜKSEK VERİM (SÜRDÜRÜLEBİLİRLİK + AZOT):");
    println("   🏆 {}: {:.1f}% {}", results.best_efficiency.company, results.best_efficiency.value, results.best_efficiency.metric);
    println("   💡 {}", results.best_efficiency.justification);
    println("");
    println("💰 EN UYGUN MALİYET:");
    println("   🏆 {}: ${:.0f}/ton {}", results.best_cost.company, results.best_cost.value, results.best_cost.metric);
    println("   💡 {}", results.best_cost.justification);
    println("");
    println("🎯 OPTIMUM KOMBİNASYON:");
    each entry in results.optimal_combination.iter().enumerate()  { let (i, company) = entry;
        println("   {}. {}", i + 1, company);
    }
    println("");
    println("📊 PAZAR PROJEKSİYONU:");
    println("   2025: ${:.1e}", results.market_projection.total_market_2025);
    println("   2030: ${:.1e}", results.market_projection.total_market_2030);
    println("   2040: ${:.1e}", results.market_projection.total_market_2040);
    println("   CAGR: {:.1f}%", results.market_projection.growth_rate_cagr * 100.0);
    println("   Dominant Segment: {}", results.market_projection.dominant_segment);
    println("");
    println("🎉 CONCLUSION:");
    println("   🏆 Air Company: Highest ROI potential");
    println("   ⚡ Prometheus: Best efficiency with nitrogen");
    println("   💰 CAPHENIA: Lowest production cost");
    println("   🚀 Combine all three for maximum impact!");
}
