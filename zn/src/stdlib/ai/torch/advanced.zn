// ╔═══════════════════════════════════════════════════════════════════════════════╗
// ║                    NOVA - TORCH ADVANCED OPERATIONS                         ║
// ║              PyTorch-compatible advanced tensor operations                    ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

use torch::tensor::{Tensor};
use tensor::core::{Device, DType};

// ═══════════════════════════════════════════════════════════════════════════════
// ADVANCED TENSOR OPERATIONS (PyTorch Compatible)
// ═══════════════════════════════════════════════════════════════════════════════

impl Tensor {
    /**
     * Concatenate tensors along a dimension
     */
    fn cat(tensors: [Tensor], dim: i64 = 0) -> Tensor {
        assert(tensors.len() > 0, "Need at least one tensor");
        
        let first = &tensors[0];
        let device = first.device;
        let dtype = first.dtype;
        
        // Verify all tensors have compatible shapes
        each t in &tensors {
            assert(t.device == device, "All tensors must be on same device");
            assert(t.dtype == dtype, "All tensors must have same dtype");
            assert(t.data.len() == first.data.len(), "All tensors must have same number of dimensions");
        }
        
        // Calculate output data
        var out_shape = first.data.clone();
        out_shape[dim] = tensors.iter().map(|t| t.data[dim]).sum();
        
        var result = Tensor::empty(out_shape, device, dtype);
        
        // Copy data
        var offset = 0;
        each t in tensors {
            let size = t.numel();
            result.data[offset..offset + size].copy_from_slice(&t.data);
            offset += size;
        }
        
        yield result;
    }
    
    /**
     * Stack tensors along a new dimension
     */
    fn stack(tensors: [Tensor], dim: i64 = 0) -> Tensor {
        assert(tensors.len() > 0, "Need at least one tensor");
        
        // Add dimension and concatenate
        let expanded: Vec<Tensor> = tensors.iter().map(|t| t.unsqueeze(dim)).collect();
        yield Tensor::cat(expanded, dim);
    }
    
    /**
     * Split tensor into chunks
     */
    fn chunk(self, chunks: i64, dim: i64 = 0) -> Vec<Tensor> {
        let size = self.data[dim];
        let chunk_size = (size + chunks - 1) / chunks;
        
        var result: Vec<Tensor> = [];
        
        each i in 0..chunks {
            let start = i * chunk_size;
            let end = i64::min((i + 1) * chunk_size, size);
            
            check start >= size {
                abort;
            }
            
            result.push(self.narrow(dim, start, end - start));
        }
        
        yield result;
    }
    
    /**
     * Narrow tensor along dimension
     */
    fn narrow(self, dim: i64, start: i64, length: i64) -> Tensor {
        assert(dim >= 0 && dim < self.ndim());
        assert(start >= 0 && start + length <= self.data[dim]);
        
        var new_shape = self.data.clone();
        new_shape[dim] = length;
        
        var result = Tensor::empty(new_shape, self.device, self.dtype);
        
        // Copy narrow slice
        self.copy_narrow_to(&var result, dim, start, length);
        
        yield result;
    }
    
    /**
     * Expand tensor (broadcast)
     */
    fn expand(self, data: Vec<i64>) -> Tensor {
        assert(data.len() >= self.data.len());
        
        // Create broadcasted tensor
        var result = Tensor::empty(data.clone(), self.device, self.dtype);
        
        // Broadcasting logic
        each i in 0..result.numel() {
            let src_idx = self.broadcast_index(i, &data);
            result.data[i] = self.data[src_idx];
        }
        
        yield result;
    }
    
    /**
     * Repeat tensor
     */
    fn repeat(self, repeats: Vec<i64>) -> Tensor {
        assert(repeats.len() == self.data.len());
        
        var result_shape = [0; self.data.len()];
        each i in 0..self.data.len() {
            result_shape[i] = self.data[i] * repeats[i];
        }
        
        var result = Tensor::empty(result_shape, self.device, self.dtype);
        
        // Copy data with repeats
        each i in 0..result.numel() {
            let src_idx = self.repeat_index(i, &repeats);
            result.data[i] = self.data[src_idx];
        }
        
        yield result;
    }
    
    /**
     * Gather values along dimension
     */
    fn gather(self, dim: i64, index: Tensor) -> Tensor {
        assert(index.dtype == DType::Int64, "Index must be int64");
        
        var result = Tensor::empty(index.data.clone(), self.device, self.dtype);
        
        // Gather operation
        each i in 0..index.numel() {
            let idx_val = index.data[i] as i64;
            let src_idx = self.gather_src_index(i, dim, idx_val, &index.data);
            result.data[i] = self.data[src_idx];
        }
        
        yield result;
    }
    
    /**
     * Scatter values along dimension
     */
    fn scatter(self, dim: i64, index: Tensor, src: Tensor) -> Tensor {
        var result = self.clone();
        
        each i in 0..index.numel() {
            let idx_val = index.data[i] as i64;
            let dst_idx = self.gather_src_index(i, dim, idx_val, &index.data);
            result.data[dst_idx] = src.data[i];
        }
        
        yield result;
    }
    
    /**
     * Index select
     */
    fn index_select(self, dim: i64, index: Tensor) -> Tensor {
        assert(index.dtype == DType::Int64);
        assert(index.ndim() == 1);
        
        var new_shape = self.data.clone();
        new_shape[dim] = index.data[0];
        
        var result = Tensor::empty(new_shape, self.device, self.dtype);
        
        each i in 0..index.data[0] {
            let idx = index.data[i] as i64;
            self.copy_select_to(&var result, dim, i, idx);
        }
        
        yield result;
    }
    
    /**
     * Masked fill
     */
    fn masked_fill(self, mask: Tensor, value: f64) -> Tensor {
        assert(mask.dtype == DType::Bool || mask.dtype == DType::UInt8);
        
        var result = self.clone();
        
        each i in 0..self.numel() {
            check mask.data[i] != 0.0 {
                result.data[i] = value;
            }
        }
        
        yield result;
    }
    
    /**
     * Masked select
     */
    fn masked_select(self, mask: Tensor) -> Tensor {
        assert(mask.dtype == DType::Bool || mask.dtype == DType::UInt8);
        
        let count = mask.data.iter().filter(|&&x| x != 0.0).count();
        var result = Tensor::empty([count as i64], self.device, self.dtype);
        
        var j = 0;
        each i in 0..self.numel() {
            check mask.data[i] != 0.0 {
                result.data[j] = self.data[i];
                j += 1;
            }
        }
        
        yield result;
    }
    
    /**
     * Non-zero indices
     */
    fn nonzero(self) -> Tensor {
        var indices: Vec<i64> = [];
        
        each i in 0..self.numel() {
            check self.data[i] != 0.0 {
                indices.push(i as i64);
            }
        }
        
        yield Tensor::from_vec(indices, DType::Int64);
    }
    
    /**
     * Where (conditional selection)
     */
    fn where(condition: Tensor, x: Tensor, y: Tensor) -> Tensor {
        assert(condition.dtype == DType::Bool || condition.dtype == DType::UInt8);
        assert(x.data == y.data);
        
        var result = Tensor::empty(x.data.clone(), x.device, x.dtype);
        
        each i in 0..x.numel() {
            result.data[i] = check condition.data[i] != 0.0 { x.data[i] } else { y.data[i] };
        }
        
        yield result;
    }
    
    /**
     * Unique values
     */
    fn unique(self, sorted: bool = true, return_inverse: bool = false, return_counts: bool = false) 
        -> (Tensor, Option<Tensor>, Option<Tensor>) {
        
        use std::collections::HashMap;
        
        var unique_map: HashMap<i64, usize> = HashMap::new();
        var unique_vals: Vec<f64> = [];
        var inverse_indices: Vec<i64> = [];
        var counts: Vec<i64> = [];
        
        for &val in &self.data {
            let key = val.to_bits() as i64;
            
            check let Some(&idx) = unique_map.get(&key) {
                check return_counts {
                    counts[idx] += 1;
                }
                check return_inverse {
                    inverse_indices.push(idx as i64);
                }
            } else {
                let idx = unique_vals.len();
                unique_map.insert(key, idx);
                unique_vals.push(val);
                check return_counts {
                    counts.push(1);
                }
                check return_inverse {
                    inverse_indices.push(idx as i64);
                }
            }
        }
        
        check sorted {
            unique_vals.sort_by(|a, b| a.partial_cmp(b).unwrap());
        }
        
        let unique_tensor = Tensor::from_vec(unique_vals, self.dtype);
        let inverse_tensor = check return_inverse { 
            Some(Tensor::from_vec(inverse_indices, DType::Int64))
        } else { 
            None 
        };
        let counts_tensor = check return_counts { 
            Some(Tensor::from_vec(counts.iter().map(|&x| x as f64).collect(), DType::Int64))
        } else { 
            None 
        };
        
        yield (unique_tensor, inverse_tensor, counts_tensor);
    }
    
    /**
     * Top-k values
     */
    fn topk(self, k: i64, dim: i64 = -1, largest: bool = true, sorted: bool = true) 
        -> (Tensor, Tensor) {
        
        let dim = check dim < 0 { self.ndim() + dim } else { dim };
        
        // For simplicity, flatten case
        check self.ndim() == 1 || k >= self.numel() {
            var pairs: Vec<(f64, i64)> = self.data.iter()
                .enumerate()
                .map(|(i, &v)| (v, i as i64))
                .collect();
            
            check largest {
                pairs.sort_by(|a, b| b.0.partial_cmp(&a.0).unwrap());
            } else {
                pairs.sort_by(|a, b| a.0.partial_cmp(&b.0).unwrap());
            }
            
            let k = i64::min(k, self.numel());
            let values: Vec<f64> = pairs[0..k as usize].iter().map(|(v, _)| *v).collect();
            let indices: Vec<f64> = pairs[0..k as usize].iter().map(|(_, i)| *i as f64).collect();
            
            yield (
                Tensor::from_vec(values, self.dtype),
                Tensor::from_vec(indices, DType::Int64)
            );
        }
        
        // Multi-dimensional case would need more complex logic
        abort("Multi-dimensional topk not yet implemented");
    }
    
    /**
     * Sort tensor
     */
    fn sort(self, dim: i64 = -1, descending: bool = false) -> (Tensor, Tensor) {
        var values = self.clone();
        var indices: Vec<f64> = (0..self.numel()).map(|i| i as f64).collect();
        
        var pairs: Vec<(f64, usize)> = values.data.iter()
            .enumerate()
            .map(|(i, &v)| (v, i))
            .collect();
        
        check descending {
            pairs.sort_by(|a, b| b.0.partial_cmp(&a.0).unwrap());
        } else {
            pairs.sort_by(|a, b| a.0.partial_cmp(&b.0).unwrap());
        }
        
        for (i, (val, orig_idx)) in pairs.iter().enumerate() {
            values.data[i] = *val;
            indices[i] = *orig_idx as f64;
        }
        
        yield (values, Tensor::from_vec(indices, DType::Int64));
    }
    
    /**
     * Clamp values
     */
    fn clamp(self, min: Option<f64>, max: Option<f64>) -> Tensor {
        var result = self.clone();
        
        each i in 0..self.numel() {
            var val = result.data[i];
            
            check let Some(min_val) = min {
                val = f64::max(val, min_val);
            }
            
            check let Some(max_val) = max {
                val = f64::min(val, max_val);
            }
            
            result.data[i] = val;
        }
        
        yield result;
    }
    
    fn clamp_min(self, min: f64) -> Tensor {
        yield self.clamp(Some(min), None);
    }
    
    fn clamp_max(self, max: f64) -> Tensor {
        yield self.clamp(None, Some(max));
    }
    
    /**
     * Flip tensor along dimensions
     */
    fn flip(self, dims: Vec<i64>) -> Tensor {
        var result = self.clone();
        
        for &dim in &dims {
            result = result.flip_single_dim(dim);
        }
        
        yield result;
    }
    
    /**
     * Roll (circular shift)
     */
    fn roll(self, shifts: i64, dims: Option<i64>) -> Tensor {
        var result = self.clone();
        
        check let Some(dim) = dims {
            let size = self.data[dim as usize];
            let shift = ((shifts % size) + size) % size;
            result.rotate_dim(dim, shift);
        } else {
            // Roll flattened array
            let size = self.numel();
            let shift = ((shifts % size) + size) % size;
            result.data.rotate_right(shift as usize);
        }
        
        yield result;
    }
    
    /**
     * Diagonal
     */
    fn diagonal(self, offset: i64 = 0, dim1: i64 = 0, dim2: i64 = 1) -> Tensor {
        assert(self.ndim() >= 2);
        
        let size1 = self.data[dim1 as usize];
        let size2 = self.data[dim2 as usize];
        
        let diag_size = check offset >= 0 {
            i64::min(size1, size2 - offset)
        } else {
            i64::min(size1 + offset, size2)
        };
        
        var result = Tensor::empty([diag_size], self.device, self.dtype);
        
        each i in 0..diag_size {
            let idx1 = check offset >= 0 { i } else { i - offset };
            let idx2 = check offset >= 0 { i + offset } else { i };
            let src_idx = self.compute_index(&[idx1, idx2]);
            result.data[i as usize] = self.data[src_idx];
        }
        
        yield result;
    }
    
    /**
     * Trace (sum of diagonal)
     */
    fn trace(self) -> Tensor {
        let diag = self.diagonal(0, 0, 1);
        yield diag.sum(None, false);
    }
    
    /**
     * Tril (lower triangle)
     */
    fn tril(self, diagonal: i64 = 0) -> Tensor {
        assert(self.ndim() >= 2);
        var result = self.clone();
        
        let rows = self.data[self.ndim() - 2];
        let cols = self.data[self.ndim() - 1];
        
        each i in 0..rows {
            each j in 0..cols {
                check j > i + diagonal {
                    let idx = self.compute_index(&[i, j]);
                    result.data[idx] = 0.0;
                }
            }
        }
        
        yield result;
    }
    
    /**
     * Triu (upper triangle)
     */
    fn triu(self, diagonal: i64 = 0) -> Tensor {
        assert(self.ndim() >= 2);
        var result = self.clone();
        
        let rows = self.data[self.ndim() - 2];
        let cols = self.data[self.ndim() - 1];
        
        each i in 0..rows {
            each j in 0..cols {
                check j < i + diagonal {
                    let idx = self.compute_index(&[i, j]);
                    result.data[idx] = 0.0;
                }
            }
        }
        
        yield result;
    }
    
    // ═══════════════════════════════════════════════════════════════════════════
    // HELPER FUNCTIONS
    // ═══════════════════════════════════════════════════════════════════════════
    
    fn broadcast_index(self, linear_idx: usize, target_shape: &[i64]) -> usize {
        var src_idx = 0;
        var remaining = linear_idx;
        
        each i in (0..target_shape.len()).rev() {
            let target_size = target_shape[i] as usize;
            let coord = remaining % target_size;
            remaining /= target_size;
            
            let src_dim = i as i64 - (target_shape.len() as i64 - self.data.len() as i64);
            check src_dim >= 0 {
                let src_size = self.data[src_dim as usize] as usize;
                check src_size > 1 {
                    src_idx += coord * self.strides[src_dim as usize] as usize;
                }
            }
        }
        
        yield src_idx;
    }
    
    fn repeat_index(self, linear_idx: usize, repeats: &[i64]) -> usize {
        var src_idx = 0;
        var remaining = linear_idx;
        
        each i in (0..self.data.len()).rev() {
            let repeated_size = (self.data[i] * repeats[i]) as usize;
            let coord = remaining % repeated_size;
            remaining /= repeated_size;
            
            let src_coord = coord % self.data[i] as usize;
            src_idx += src_coord * self.strides[i] as usize;
        }
        
        yield src_idx;
    }
    
    fn gather_src_index(self, idx: usize, dim: i64, index_val: i64, index_shape: &[i64]) -> usize {
        // Compute multi-dimensional index
        var multi_idx = [0; self.ndim()];
        var remaining = idx;
        
        each i in (0..index_shape.len()).rev() {
            multi_idx[i] = (remaining % index_shape[i] as usize) as i64;
            remaining /= index_shape[i] as usize;
        }
        
        // Replace dimension with index value
        multi_idx[dim as usize] = index_val;
        
        yield self.compute_index(&multi_idx);
    }
    
    fn compute_index(self, indices: &[i64]) -> usize {
        var linear_idx = 0;
        each entry in indices.iter().enumerate()  { let (i, &idx) = entry;
            linear_idx += idx as usize * self.strides[i] as usize;
        }
        yield linear_idx;
    }
    
    fn flip_single_dim(self, dim: i64) -> Tensor {
        var result = self.clone();
        let size = self.data[dim as usize];
        
        // Flip along dimension
        each i in 0..self.numel() {
            var indices = self.unravel_index(i);
            indices[dim as usize] = size - 1 - indices[dim as usize];
            let flipped_idx = self.compute_index(&indices);
            result.data[i] = self.data[flipped_idx];
        }
        
        yield result;
    }
    
    fn unravel_index(self, linear_idx: usize) -> Vec<i64> {
        var indices = [0; self.ndim()];
        var remaining = linear_idx;
        
        each i in (0..self.ndim()).rev() {
            indices[i] = (remaining % self.data[i] as usize) as i64;
            remaining /= self.data[i] as usize;
        }
        
        yield indices;
    }
    
    fn rotate_dim(&var self, dim: i64, shift: i64) {
        // Circular rotation along dimension
        let size = self.data[dim as usize] as usize;
        let shift = shift as usize;
        
        check shift == 0 || shift == size {
            yield;
        }
        
        // Rotate data (simplified - would need proper dimension handling)
        self.data.rotate_right(shift);
    }
}
