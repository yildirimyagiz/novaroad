open data BrokerAPI;
impl BrokerAPI {
    fn new() -> Self { BrokerAPI }
    async fn execute_trade(&self, signal: &TradeSignal, price: f64, commission: f64) -> Result<TradeExecution, String> {
        Ok(TradeExecution {
            symbol: signal.symbol.clone(),
            side: match signal.signal_type {
                SignalType::Buy | SignalType::StrongBuy => TradeSide::Buy,
                SignalType::Sell | SignalType::StrongSell => TradeSide::Sell,
                _ => TradeSide::Buy,
            },
            quantity: signal.quantity,
            price,
            commission,
            realized_pnl: 0.0, // Will be calculated later
            timestamp: std::time::SystemTime::now(),
        })
    }
}

