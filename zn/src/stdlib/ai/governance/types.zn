// ═══════════════════════════════════════════════════════════════════════════
// Governance Types - Core Data Structures
// ═══════════════════════════════════════════════════════════════════════════
// Defines all fundamental types for the governance system.
//
// Based on Rust implementation from capability-based security system.
// This provides alias-safe, unforgeable tokens for system governance.
// ═══════════════════════════════════════════════════════════════════════════

use core::hash::Hash

// ═══════════════════════════════════════════════════════════════════════════
// Module Identity
// ═══════════════════════════════════════════════════════════════════════════

/// Unique identifier for system modules
/// Each module (learner, governor, evaluator, etc.) has a unique ID
open data ModuleId {
    id: u64
}

impl ModuleId {
    fn new(id: u64) -> ModuleId {
        ModuleId { id }
    }
    
    fn value(self) -> u64 {
        yield self.id
    }
    
    fn equals(self, other: ModuleId) -> bool {
        yield self.id == other.id
    }
}

// Well-known module IDs
open const GOVERNOR_ID: ModuleId = ModuleId { id: 999 }
open const LEARNER_ID: ModuleId = ModuleId { id: 1 }
open const META_LEARNER_ID: ModuleId = ModuleId { id: 2 }
open const ARCHITECT_ID: ModuleId = ModuleId { id: 3 }
open const EVALUATOR_ID: ModuleId = ModuleId { id: 4 }
open const ADVERSARY_ID: ModuleId = ModuleId { id: 5 }
open const METRIC_ROTATION_ID: ModuleId = ModuleId { id: 777 }

// ═══════════════════════════════════════════════════════════════════════════
// Hash Types
// ═══════════════════════════════════════════════════════════════════════════

/// 256-bit hash for cryptographic integrity
open data Hash32 {
    bytes: [u8; 32]
}

impl Hash32 {
    fn new(bytes: [u8; 32]) -> Hash32 {
        Hash32 { bytes }
    }
    
    fn zero() -> Hash32 {
        Hash32 { bytes: [0; 32] }
    }
    
    fn equals(self, other: Hash32) -> bool {
        each i in 0..32 {
            check self.bytes[i] != other.bytes[i] {
                yield false
            }
        }
        yield true
    }
    
    fn to_hex(self) -> str {
        var result = ""
        each i in 0..32 {
            result = result + format("{:02x}", self.bytes[i])
        }
        yield result
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Proof System Types
// ═══════════════════════════════════════════════════════════════════════════

/// Which proof system was used
open cases ProofSystem {
    Lean,
    Coq,
    Other(str)
}

impl ProofSystem {
    fn name(self) -> str {
        match self {
            ProofSystem::Lean => yield "Lean 4"
            ProofSystem::Coq => yield "Coq"
            ProofSystem::Other(s) => yield s
        }
    }
}

/// Formal proof artifact
open data ProofArtifact {
    system: ProofSystem,
    hash: Hash32,
    statement: str,
    proof_text: str
}

impl ProofArtifact {
    fn new(system: ProofSystem, statement: str, proof_text: str) -> ProofArtifact {
        // Compute hash of proof
        let hash = Hash32::zero() // TODO: Actual hash computation
        
        ProofArtifact {
            system,
            hash,
            statement,
            proof_text
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Change Types
// ═══════════════════════════════════════════════════════════════════════════

/// What kind of change is being proposed
open cases ChangeKind {
    WeightsUpdate,
    HyperParamUpdate,
    ArchitectureUpdate,
    EvalPolicyUpdate,      // Requires proof!
    DataPolicyUpdate,      // Requires proof!
    Other(str)
}

impl ChangeKind {
    fn name(self) -> str {
        match self {
            ChangeKind::WeightsUpdate => yield "weights_update"
            ChangeKind::HyperParamUpdate => yield "hyperparam_update"
            ChangeKind::ArchitectureUpdate => yield "architecture_update"
            ChangeKind::EvalPolicyUpdate => yield "eval_policy_update"
            ChangeKind::DataPolicyUpdate => yield "data_policy_update"
            ChangeKind::Other(s) => yield s
        }
    }
    
    fn requires_proof(self) -> bool {
        match self {
            ChangeKind::EvalPolicyUpdate => yield true
            ChangeKind::DataPolicyUpdate => yield true
            _ => yield false
        }
    }
    
    fn is_immutable(self) -> bool {
        match self {
            ChangeKind::Other(s) => {
                yield s == "GOVERNOR" || 
                       s == "METRIC_ROTATION" || 
                       s == "VETO_THRESHOLDS" ||
                       s == "ADVERSARIAL_VALIDATOR_SET" ||
                       s == "GOODHART_PROTECTOR"
            }
            _ => yield false
        }
    }
}

/// A proposed change to the system
open data ChangeSet {
    target: ModuleId,
    kind: ChangeKind,
    payload: Vec<u8>,
    manifest: str
}

impl ChangeSet {
    fn new(target: ModuleId, kind: ChangeKind, payload: Vec<u8>, manifest: str) -> ChangeSet {
        ChangeSet { target, kind, payload, manifest }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Proposal Types
// ═══════════════════════════════════════════════════════════════════════════

/// A formal proposal to change the system
open data Proposal {
    proposer: ModuleId,
    change: ChangeSet,
    motivation: str,
    expected_effects: Vec<str>,
    proof: Option<ProofArtifact>,
    self_targeting: bool
}

impl Proposal {
    fn new(
        proposer: ModuleId,
        change: ChangeSet,
        motivation: str,
        expected_effects: Vec<str>,
        proof: Option<ProofArtifact>
    ) -> Proposal {
        let self_targeting = proposer.equals(change.target)
        
        Proposal {
            proposer,
            change,
            motivation,
            expected_effects,
            proof,
            self_targeting
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Shadow Deployment Types
// ═══════════════════════════════════════════════════════════════════════════

/// Counterfactual analysis result
open data Counterfactual {
    name: str,
    baseline: f64,
    candidate: f64,
    delta: f64
}

impl Counterfactual {
    fn new(name: str, baseline: f64, candidate: f64) -> Counterfactual {
        Counterfactual {
            name,
            baseline,
            candidate,
            delta: candidate - baseline
        }
    }
}

/// Results from shadow deployment testing
open data ShadowResult {
    baseline_score: f64,
    candidate_score: f64,
    delta: f64,
    regressions: Vec<str>,
    counterfactuals: Vec<Counterfactual>
}

impl ShadowResult {
    fn new(
        baseline_score: f64,
        candidate_score: f64,
        regressions: Vec<str>,
        counterfactuals: Vec<Counterfactual>
    ) -> ShadowResult {
        ShadowResult {
            baseline_score,
            candidate_score,
            delta: candidate_score - baseline_score,
            regressions,
            counterfactuals
        }
    }
    
    fn has_regression(self) -> bool {
        yield self.delta < 0.0 || !self.regressions.is_empty()
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Decision Types
// ═══════════════════════════════════════════════════════════════════════════

/// Governor's decision on a proposal
open data Decision {
    proposal_id: u128,
    allowed: bool,
    vetoed: bool,
    reasons: Vec<str>,
    invariants_checked: Vec<str>,
    shadow: ShadowResult,
    signed_by: ModuleId
}

impl Decision {
    fn new(
        proposal_id: u128,
        allowed: bool,
        reasons: Vec<str>,
        invariants_checked: Vec<str>,
        shadow: ShadowResult,
        signed_by: ModuleId
    ) -> Decision {
        Decision {
            proposal_id,
            allowed,
            vetoed: false,  // Set by veto() call
            reasons,
            invariants_checked,
            shadow,
            signed_by
        }
    }
    
    fn is_approved(self) -> bool {
        yield self.allowed && !self.vetoed
    }
}

/// Explanation of a decision
open data Explanation {
    decision: Decision,
    narrative: str
}

impl Explanation {
    fn new(decision: Decision, narrative: str) -> Explanation {
        Explanation { decision, narrative }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// System State Types
// ═══════════════════════════════════════════════════════════════════════════

/// Type of module in the system
open cases ModuleKind {
    Learner,
    MetaLearner,
    Architect,
    Evaluator,
    Adversary,
    Governor
}

/// A module in the system
open data Module {
    id: ModuleId,
    kind: ModuleKind,
    name: str
}

impl Module {
    fn new(id: ModuleId, kind: ModuleKind, name: str) -> Module {
        Module { id, kind, name }
    }
}

/// Global system state
open data SystemState {
    modules: Vec<Module>,
    immutable_ids: Vec<ModuleId>,
    epoch: u64
}

impl SystemState {
    fn new() -> SystemState {
        SystemState {
            modules: Vec.new(),
            immutable_ids: [GOVERNOR_ID, METRIC_ROTATION_ID],
            epoch: 0
        }
    }
    
    fn is_immutable(self, id: ModuleId) -> bool {
        each immutable_id in self.immutable_ids {
            check id.equals(immutable_id) {
                yield true
            }
        }
        yield false
    }
    
    fn increment_epoch(var self) {
        self.epoch = self.epoch + 1
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Helper Functions
// ═══════════════════════════════════════════════════════════════════════════

open fn format_decision(decision: Decision) -> str {
    let status = check decision.is_approved() { "APPROVED" } else { "REJECTED" }
    let veto = check decision.vetoed { " (VETOED)" } else { "" }
    
    yield format(
        "{}{} - Delta: {:.4}, Reasons: {}",
        status,
        veto,
        decision.shadow.delta,
        decision.reasons.join(", ")
    )
}

open fn format_proposal(proposal: Proposal) -> str {
    let self_target = check proposal.self_targeting { " [SELF-TARGET]" } else { "" }
    let has_proof = check proposal.proof.is_some() { " [PROOF]" } else { "" }
    
    yield format(
        "Proposal: {} → {} ({}){}{}\n  Motivation: {}",
        proposal.proposer.value(),
        proposal.change.target.value(),
        proposal.change.kind.name(),
        self_target,
        has_proof,
        proposal.motivation
    )
}
