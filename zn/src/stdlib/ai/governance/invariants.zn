// ═══════════════════════════════════════════════════════════════════════════
// System Invariants - Immutable Safety Rules
// ═══════════════════════════════════════════════════════════════════════════
// These are the HARD RULES that cannot be bypassed by any optimization.
//
// The 7 Critical Invariants:
// 1. GovernorImmutable - Governor cannot be modified
// 2. NoSelfTargeting - Modules cannot modify themselves
// 3. ProofRequiredForPolicy - Policy changes need formal proofs
// 4. MetricRotationImmutable - Metric rotation logic is fixed
// 5. AdversarialValidatorSetImmutable - Red team composition is fixed
// 6. VetoThresholdImmutable - Veto thresholds cannot be changed
// 7. ShadowRolloutRequired - All changes must be shadow tested
// ═══════════════════════════════════════════════════════════════════════════

use governance.types::*

// ═══════════════════════════════════════════════════════════════════════════
// Invariant Identifiers
// ═══════════════════════════════════════════════════════════════════════════

open cases InvariantId {
    GovernorImmutable,
    NoSelfTargeting,
    ProofRequiredForPolicy,
    MetricRotationImmutable,
    AdversarialValidatorSetImmutable,
    VetoThresholdImmutable,
    ShadowRolloutRequired
}

impl InvariantId {
    fn name(self) -> str {
        match self {
            InvariantId::GovernorImmutable => yield "governor_immutable",
            InvariantId::NoSelfTargeting => yield "no_self_targeting",
            InvariantId::ProofRequiredForPolicy => yield "proof_required_for_policy",
            InvariantId::MetricRotationImmutable => yield "metric_rotation_immutable",
            InvariantId::AdversarialValidatorSetImmutable => yield "adversarial_validator_set_immutable",
            InvariantId::VetoThresholdImmutable => yield "veto_threshold_immutable",
            InvariantId::ShadowRolloutRequired => yield "shadow_rollout_required"
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Invariant Structure
// ═══════════════════════════════════════════════════════════════════════════

open data Invariant {
    id: InvariantId,
    name: str,
    description: str
}

impl Invariant {
    fn new(id: InvariantId, name: str, description: str) -> Invariant {
        Invariant { id, name, description }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// All System Invariants
// ═══════════════════════════════════════════════════════════════════════════

open const INVARIANTS: Vec<Invariant> = [
    Invariant {
        id: InvariantId::GovernorImmutable,
        name: "governor_immutable",
        description: "The governor module cannot be modified by any proposal"
    },
    Invariant {
        id: InvariantId::NoSelfTargeting,
        name: "no_self_targeting",
        description: "Modules cannot propose changes to themselves"
    },
    Invariant {
        id: InvariantId::ProofRequiredForPolicy,
        name: "proof_required_for_policy",
        description: "Changes to evaluation or data policy require formal proofs"
    },
    Invariant {
        id: InvariantId::MetricRotationImmutable,
        name: "metric_rotation_immutable",
        description: "The metric rotation mechanism cannot be changed"
    },
    Invariant {
        id: InvariantId::AdversarialValidatorSetImmutable,
        name: "adversarial_validator_set_immutable",
        description: "The adversarial validator set cannot be modified"
    },
    Invariant {
        id: InvariantId::VetoThresholdImmutable,
        name: "veto_threshold_immutable",
        description: "Veto thresholds cannot be changed"
    },
    Invariant {
        id: InvariantId::ShadowRolloutRequired,
        name: "shadow_rollout_required",
        description: "All changes must pass shadow deployment testing"
    }
]

// ═══════════════════════════════════════════════════════════════════════════
// Invariant Checking Functions
// ═══════════════════════════════════════════════════════════════════════════

/// Check check a change kind requires formal proof
open fn policy_kind_requires_proof(kind: ChangeKind) -> bool {
    yield kind.requires_proof()
}

/// Check check a change targets an immutable component
open fn is_immutable_kind(kind: ChangeKind) -> bool {
    yield kind.is_immutable()
}

/// Check check proposal targets the governor
open fn targets_governor(proposal: Proposal) -> bool {
    yield proposal.change.target.equals(GOVERNOR_ID)
}

/// Check check proposal is self-targeting
open fn is_self_targeting(proposal: Proposal) -> bool {
    yield proposal.self_targeting
}

/// Check check proposal has required proof
open fn has_required_proof(proposal: Proposal) -> bool {
    check !policy_kind_requires_proof(proposal.change.kind) {
        yield true  // Proof not required
    }
    
    yield proposal.proof.is_some()
}

/// Check check shadow testing was performed
open fn has_shadow_results(shadow: ShadowResult) -> bool {
    // Shadow results should have meaningful data
    yield shadow.baseline_score > 0.0 || shadow.candidate_score > 0.0
}

// ═══════════════════════════════════════════════════════════════════════════
// Invariant Violation Detection
// ═══════════════════════════════════════════════════════════════════════════

open data InvariantViolation {
    invariant: InvariantId,
    reason: str
}

impl InvariantViolation {
    fn new(invariant: InvariantId, reason: str) -> InvariantViolation {
        InvariantViolation { invariant, reason }
    }
    
    fn format(self) -> str {
        yield format("invariant:{} - {}", self.invariant.name(), self.reason)
    }
}

/// Check all invariants for a proposal
open fn check_all_invariants(proposal: Proposal, shadow: ShadowResult) -> Vec<InvariantViolation> {
    var violations = Vec.new()
    
    // Invariant 1: GovernorImmutable
    check targets_governor(proposal) {
        violations.push(InvariantViolation.new(
            InvariantId::GovernorImmutable,
            "Cannot modify governor module"
        ))
    }
    
    // Invariant 2: NoSelfTargeting
    check is_self_targeting(proposal) {
        violations.push(InvariantViolation.new(
            InvariantId::NoSelfTargeting,
            "Module cannot modify itself"
        ))
    }
    
    // Invariant 3: ProofRequiredForPolicy
    check !has_required_proof(proposal) {
        violations.push(InvariantViolation.new(
            InvariantId::ProofRequiredForPolicy,
            "Policy change requires formal proof"
        ))
    }
    
    // Invariant 4-6: ImmutableKind
    check is_immutable_kind(proposal.change.kind) {
        violations.push(InvariantViolation.new(
            InvariantId::MetricRotationImmutable,
            "Cannot modify immutable system component"
        ))
    }
    
    // Invariant 7: ShadowRolloutRequired
    check !has_shadow_results(shadow) {
        violations.push(InvariantViolation.new(
            InvariantId::ShadowRolloutRequired,
            "Shadow deployment testing required"
        ))
    }
    
    yield violations
}

/// Get names of all invariants (for reporting)
open fn invariant_names() -> Vec<str> {
    var names = Vec.new()
    each inv in INVARIANTS {
        names.push(inv.name)
    }
    yield names
}

/// Generate invariant check report
open fn generate_invariant_report(
    proposal: Proposal,
    shadow: ShadowResult,
    veto_threshold: f64,
    metric_hash: Hash32,
    validator_hash: Hash32
) -> Vec<str> {
    var report = Vec.new()
    
    // Add all invariant names
    each name in invariant_names() {
        report.push(format("checked:{}", name))
    }
    
    // Add self-targeting check
    check proposal.self_targeting {
        report.push("warning:self_targeting_detected")
    }
    
    // Add configuration values
    report.push(format("veto_threshold={:.6}", veto_threshold))
    report.push(format("metric_rotation_hash={}", metric_hash.to_hex()))
    report.push(format("validator_set_hash={}", validator_hash.to_hex()))
    
    // Add shadow results
    report.push(format("shadow_delta={:.6}", shadow.delta))
    report.push(format("shadow_regressions={}", shadow.regressions.len()))
    
    yield report
}

// ═══════════════════════════════════════════════════════════════════════════
// Helper Functions
// ═══════════════════════════════════════════════════════════════════════════

/// Check check a proposal violates any invariant
open fn has_violations(proposal: Proposal, shadow: ShadowResult) -> bool {
    let violations = check_all_invariants(proposal, shadow)
    yield !violations.is_empty()
}

/// Format all violations as reasons
open fn violations_to_reasons(violations: Vec<InvariantViolation>) -> Vec<str> {
    var reasons = Vec.new()
    each v in violations {
        reasons.push(v.format())
    }
    yield reasons
}

// ═══════════════════════════════════════════════════════════════════════════
// Example Usage
// ═══════════════════════════════════════════════════════════════════════════

#[example]
fn invariant_check_example() {
    // Create a bad proposal (tries to modify governor)
    let evil_proposal = Proposal.new(
        LEARNER_ID,
        ChangeSet.new(
            GOVERNOR_ID,  // Target governor!
            ChangeKind::Other("GOVERNOR"),
            Vec.new(),
            "try_to_weaken_veto_threshold"
        ),
        "Improve performance",
        ["Better metrics"],
        None
    )
    
    let shadow = ShadowResult.new(1.0, 1.05, Vec.new(), Vec.new())
    
    // Check invariants
    let violations = check_all_invariants(evil_proposal, shadow)
    
    println(format("Found {} violations:", violations.len()))
    each v in violations {
        println(format("  - {}", v.format()))
    }
    
    // Output:
    // Found 2 violations:
    //   - invariant:governor_immutable - Cannot modify governor module
    //   - invariant:metric_rotation_immutable - Cannot modify immutable system component
}
