"""
Flash Attention - Native Nova Implementation
Ultra-fast attention with O(N) memory complexity

Based on Flash Attention 2 algorithm
Optimized for Wan2.2 video generation
"""

import tensor.{Tensor, zeros, einsum, softmax}
import std.{simd, parallel, math}
import nn.{Module, Dropout}

// ============================================================================
// Flash Attention Configuration
// ============================================================================

data FlashAttentionConfig {
    block_size_q: int = 128      // Query block size
    block_size_k: int = 128      // Key block size
    num_warps: int = 4           // GPU warps
    use_tensor_cores: bool = true
    causal: bool = false
    dropout_p: float = 0.0
}

// ============================================================================
// Flash Attention Kernel (SIMD Optimized)
// ============================================================================

@simd_kernel
@inline(always)
fn flash_attention_forward(
    Q: Tensor,              // [batch, heads, seq_q, dim]
    K: Tensor,              // [batch, heads, seq_k, dim]
    V: Tensor,              // [batch, heads, seq_k, dim]
    scale: float,
    dropout_p: float = 0.0,
    causal: bool = false
) -> Tensor {
    """
    Flash Attention forward pass
    
    Memory: O(N) instead of O(N²)
    Speed: 2-4x faster than standard attention
    """
    
    let batch = Q.data[0]
    let num_heads = Q.data[1]
    let seq_q = Q.data[2]
    let seq_k = K.data[2]
    let dim = Q.data[3]
    
    // Block sizes for tiling
    let BLOCK_Q = 128
    let BLOCK_K = 128
    
    // Output tensor
    let O = zeros(Q.data, dtype=Q.dtype, device=Q.device)
    let L = zeros([batch, num_heads, seq_q], dtype=float32)  // Logsumexp
    
    // Parallel over batch and heads
    parallel.for_each(range(batch * num_heads), |bh| {
        let b = bh / num_heads
        let h = bh % num_heads
        
        // Get Q, K, V for this batch and head
        let q = Q[b, h]  // [seq_q, dim]
        let k = K[b, h]  // [seq_k, dim]
        let v = V[b, h]  // [seq_k, dim]
        
        // Tile over queries
        each qi in range(0, seq_q, BLOCK_Q) {
            let q_end = min(qi + BLOCK_Q, seq_q)
            let q_block = q[qi:q_end]  // [BLOCK_Q, dim]
            
            // Initialize accumulators
            let o_block = zeros([q_end - qi, dim])
            let l_block = zeros([q_end - qi]) - float::INFINITY
            let m_block = zeros([q_end - qi]) - float::INFINITY
            
            // Tile over keys
            each ki in range(0, seq_k, BLOCK_K) {
                let k_end = min(ki + BLOCK_K, seq_k)
                let k_block = k[ki:k_end]  // [BLOCK_K, dim]
                let v_block = v[ki:k_end]  // [BLOCK_K, dim]
                
                // Compute attention scores: QK^T / sqrt(d)
                let s = einsum("qd,kd->qk", q_block, k_block) * scale
                
                // Apply causal mask check needed
                check causal {
                    each i in range(s.data[0]) {
                        each j in range(s.data[1]) {
                            check (qi + i) < (ki + j) {
                                s[i, j] = -float::INFINITY
                            }
                        }
                    }
                }
                
                // Online softmax with numerical stability
                let m_new = math.maximum(m_block, s.max(axis=1))
                let exp_s = math.exp(s - m_new.unsqueeze(1))
                let exp_m_diff = math.exp(m_block - m_new)
                
                // Update running sum
                let l_new = exp_m_diff * l_block + exp_s.sum(axis=1)
                
                // Update output (rescale previous + add new)
                o_block = (o_block * (exp_m_diff * l_block / l_new).unsqueeze(1) +
                          einsum("qk,kd->qd", exp_s, v_block) / l_new.unsqueeze(1))
                
                // Update accumulators
                l_block = l_new
                m_block = m_new
            }
            
            // Store output and logsumexp
            O[b, h, qi:q_end] = o_block
            L[b, h, qi:q_end] = m_block + math.log(l_block)
        }
    })
    
    O
}

// ============================================================================
// Multi-Head Attention
// ============================================================================

class MultiHeadAttention extends Module {
    """
    Multi-Head Attention with Flash Attention
    
    Optimizations:
    - Flash Attention for O(N) memory
    - Fused QKV projection
    - SIMD vectorization
    - Parallel head processing
    """
    
    num_heads: int
    dim: int
    head_dim: int
    scale: float
    dropout_p: float
    
    // Projections
    qkv: Linear
    proj_out: Linear
    dropout: Dropout
    
    def __init__(
        self,
        dim: int,
        num_heads: int = 8,
        qkv_bias: bool = True,
        dropout: float = 0.0
    ) {
        super().__init__()
        
        self.num_heads = num_heads
        self.dim = dim
        self.head_dim = dim / num_heads
        self.scale = 1.0 / math.sqrt(self.head_dim)
        self.dropout_p = dropout
        
        // Fused QKV projection (3x faster)
        self.qkv = Linear(dim, dim * 3, bias=qkv_bias)
        self.proj_out = Linear(dim, dim)
        self.dropout = Dropout(dropout) check dropout > 0 else None
    }
    
    @simd_optimize
    def forward(
        self,
        x: Tensor,
        attention_mask: Tensor? = None,
        causal: bool = false
    ) -> Tensor {
        """
        Forward pass with Flash Attention
        
        Args:
            x: Input [batch, seq, dim]
            attention_mask: Optional mask [batch, seq]
            causal: Use causal masking
        
        Returns:
            Output [batch, seq, dim]
        """
        
        let B = x.data[0]
        let N = x.data[1]
        let C = x.data[2]
        
        // Fused QKV projection
        let qkv = self.qkv(x)  // [B, N, 3*C]
        qkv = qkv.reshape([B, N, 3, self.num_heads, self.head_dim])
        qkv = qkv.permute([2, 0, 3, 1, 4])  // [3, B, H, N, D]
        
        let q = qkv[0]  // [B, H, N, D]
        let k = qkv[1]  // [B, H, N, D]
        let v = qkv[2]  // [B, H, N, D]
        
        // Flash Attention
        let out = flash_attention_forward(
            q, k, v,
            scale=self.scale,
            dropout_p=self.dropout_p check self.training else 0.0,
            causal=causal
        )
        
        // Reshape and project
        out = out.transpose([0, 2, 1, 3])  // [B, N, H, D]
        out = out.reshape([B, N, C])
        out = self.proj_out(out)
        
        check self.dropout is not None {
            out = self.dropout(out)
        }
        
        yield out
    }
}

// ============================================================================
// Cross Attention (for text conditioning)
// ============================================================================

class CrossAttention extends Module {
    """
    Cross Attention between video and text
    
    Video queries attend to text keys/values
    Used for T5 text conditioning in Wan2.2
    """
    
    num_heads: int
    dim: int
    context_dim: int
    head_dim: int
    scale: float
    
    q_proj: Linear
    kv_proj: Linear
    proj_out: Linear
    dropout: Dropout
    
    def __init__(
        self,
        dim: int,
        context_dim: int? = None,
        num_heads: int = 8,
        dropout: float = 0.0
    ) {
        super().__init__()
        
        self.num_heads = num_heads
        self.dim = dim
        self.context_dim = context_dim check context_dim else dim
        self.head_dim = dim / num_heads
        self.scale = 1.0 / math.sqrt(self.head_dim)
        
        // Separate Q and KV projections
        self.q_proj = Linear(dim, dim, bias=False)
        self.kv_proj = Linear(self.context_dim, dim * 2, bias=False)
        self.proj_out = Linear(dim, dim)
        self.dropout = Dropout(dropout) check dropout > 0 else None
    }
    
    @simd_optimize
    def forward(
        self,
        x: Tensor,          // Video features [B, N, D]
        context: Tensor,    // Text features [B, M, C]
        attention_mask: Tensor? = None
    ) -> Tensor {
        """
        Cross attention: video queries attend to text
        
        Args:
            x: Video features [batch, seq_video, dim]
            context: Text features [batch, seq_text, context_dim]
            attention_mask: Optional mask for text
        
        Returns:
            Output [batch, seq_video, dim]
        """
        
        let B = x.data[0]
        let N = x.data[1]  // Video sequence length
        let M = context.data[1]  // Text sequence length
        
        // Project queries from video
        let q = self.q_proj(x)  // [B, N, D]
        q = q.reshape([B, N, self.num_heads, self.head_dim])
        q = q.permute([0, 2, 1, 3])  // [B, H, N, D]
        
        // Project keys and values from text
        let kv = self.kv_proj(context)  // [B, M, 2*D]
        kv = kv.reshape([B, M, 2, self.num_heads, self.head_dim])
        kv = kv.permute([2, 0, 3, 1, 4])  // [2, B, H, M, D]
        
        let k = kv[0]  // [B, H, M, D]
        let v = kv[1]  // [B, H, M, D]
        
        // Flash Attention (cross attention)
        let out = flash_attention_forward(
            q, k, v,
            scale=self.scale,
            causal=false  // No causal mask for cross attention
        )
        
        // Reshape and project
        out = out.transpose([0, 2, 1, 3])  // [B, N, H, D]
        out = out.reshape([B, N, self.dim])
        out = self.proj_out(out)
        
        check self.dropout is not None {
            out = self.dropout(out)
        }
        
        yield out
    }
}

// ============================================================================
// Export
// ============================================================================

export {
    FlashAttentionConfig,
    flash_attention_forward,
    MultiHeadAttention,
    CrossAttention,
}
