            KnowledgeItem {
                source: KnowledgeSource::ArXiv,
                content: format("Paper: Advances in {} research\nAbstract: This paper presents...", category),
                url: format("https://arxiv.org/list/{}/recent", category),
                timestamp: Instant::now(),
                metadata: HashMap::new(),
            }
        ])
    }
}

