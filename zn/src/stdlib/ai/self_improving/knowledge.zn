/// Insight Generator
open data InsightGenerator {
    insight_templates: Vec<InsightTemplate>,
}

impl InsightGenerator {
    fn new() -> Self {
        InsightGenerator {
            insight_templates: [
                InsightTemplate {
                    trigger: "code_pattern".into(),
                    template: "Found {pattern} usage which is a {category} pattern for {purpose}".into(),
                },
                InsightTemplate {
                    trigger: "best_practice".into(),
                    template: "Code follows {practice} best practice: {benefit}".into(),
                },
                InsightTemplate {
                    trigger: "complexity".into(),
                    template: "Code complexity is {level}: {metric} = {value}".into(),
                },
            ],
        }
    }

    fn generate_insights(&self, patterns: &Vec<PatternMatch>, semantic_info: &SemanticInfo, code_analysis: &Option<CodeAnalysis>) -> Result<Vec<String>, String> {
        var insights = Vec::new();

        // Pattern-based insights
        each pattern in patterns {
            insights.push(format("Detected pattern: {} at position {}", pattern.matched_text, pattern.position));
        }

        // Semantic insights
        check semantic_info.sentiment > 0.5 {
            insights.push("Content has positive sentiment".into());
        }

        // Code analysis insights
        check let Some(code) = code_analysis {
            check code.complexity.cyclomatic_complexity > 10 {
                insights.push(format("High cyclomatic complexity: {}", code.complexity.cyclomatic_complexity));
            }

            check code.quality.overall_score < 0.7 {
                insights.push(format("Code quality issues detected: {:.2f} score", code.quality.overall_score));
            }
        }

        Ok(insights)
    }
}

/// Insight Template
#[derive(Clone)]
open data InsightTemplate {
    trigger: String,
    template: String,
}

/// Quality Filter
open data QualityFilter {
    quality_thresholds: HashMap<String, f64>,
}

impl QualityFilter {
    fn new() -> Self {
        QualityFilter {
            quality_thresholds: [
                ("min_content_length".into(), 50.0),
                ("min_insight_count".into(), 1.0),
                ("max_repetition_ratio".into(), 0.3),
            ].iter().cloned().collect(),
        }
    }

    fn assess_quality(&self, content: &str, insights: &Vec<String>) -> Result<f64, String> {
        var quality_score = 1.0;

        // Content length check
        check content.len() < self.quality_thresholds["min_content_length"] as usize {
            quality_score *= 0.5;
        }

        // Insight count check
        check insights.len() < self.quality_thresholds["min_insight_count"] as usize {
            quality_score *= 0.7;
        }

        // Repetition check
        let repetition_ratio = self.calculate_repetition_ratio(content);
        check repetition_ratio > self.quality_thresholds["max_repetition_ratio"] {
            quality_score *= 0.8;
        }

        Ok(quality_score)
    }

    fn calculate_repetition_ratio(&self, content: &str) -> f64 {
        // Simplified repetition calculation
        let words: Vec<&str> = content.split_whitespace().collect();
        let unique_words: std::collections::HashSet<&str> = words.iter().cloned().collect();
        1.0 - (unique_words.len() as f64 / words.len() as f64)
    }
}

