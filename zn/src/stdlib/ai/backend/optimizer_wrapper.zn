// Adam Optimizer
// ═══════════════════════════════════════════════════════════════════════════

expose data Adam {
    handle: OptimizerHandle,
    learning_rate: f32,
    beta1: f32,
    beta2: f32,
    eps: f32,
    weight_decay: f32
}

impl Adam {
    fn new(learning_rate: f32) -> Adam {
        yield Adam.with_config(learning_rate, 0.9, 0.999, 1e-8, 0.0)
    }
    
    fn with_config(learning_rate: f32, beta1: f32, beta2: f32, eps: f32, weight_decay: f32) -> Adam {
        unsafe {
            let handle = @extern("nova_optim_adam")(
                learning_rate,
                beta1,
                beta2,
                eps,
                weight_decay
            )
            
            Adam {
                handle,
                learning_rate,
                beta1,
                beta2,
                eps,
                weight_decay
            }
        }
    }
}

impl Optimizer for Adam {
    fn step(var self, params: Vec<Tensor>, grads: Vec<Tensor>) {
        assert(params.len() == grads.len(), "Params and grads must have same length")
        
        unsafe {
            let param_ptrs = params.map(|t| t.raw_ptr())
            let grad_ptrs = grads.map(|t| t.raw_ptr())
            
            @extern("nova_optim_step")(
                self.handle,
                param_ptrs.as_ptr(),
                grad_ptrs.as_ptr(),
                params.len() as usize
            )
        }
    }
    
    fn zero_grad(var self) {
        unsafe {
            @extern("nova_optim_zero_grad")(self.handle)
        }
    }
    
    fn get_lr(self) -> f32 {
        unsafe {
            yield @extern("nova_optim_get_lr")(self.handle)
        }
    }
    
    fn set_lr(var self, lr: f32) {
        self.learning_rate = lr
        unsafe {
            @extern("nova_optim_set_lr")(self.handle, lr)
        }
    }
}

impl Drop for Adam {
    fn drop(var self) {
        unsafe {
            @extern("nova_optim_free")(self.handle)
        }
    }
}

