// ═══════════════════════════════════════════════════════════════════════════
// Nova AI Backend Wrapper - Optimizers
// ═══════════════════════════════════════════════════════════════════════════
// Type-safe wrapper for C optimizer implementations (src/ai/nn/optim.c)
// 
// Supported Optimizers:
// - SGD (with optional momentum & Nesterov)
// - Adam
// - AdamW (decoupled weight decay)
// - RMSprop
// - Adagrad
// ═══════════════════════════════════════════════════════════════════════════

// Updated to v9.0 - Modern Nova Syntax
use stdlib.ml.tensor::{Tensor}
use ffi.native::*
// use crate::core_ir::{IRModule, create_ir_optimizer}; // For advanced optimization

// ═══════════════════════════════════════════════════════════════════════════
// Optimizer Types
// ═══════════════════════════════════════════════════════════════════════════

expose cases OptimizerType {
    SGD,
    Momentum,
    Adam,
    AdamW,
    RMSprop,
    Adagrad
}

// Opaque pointer to C optimizer
alias OptimizerHandle = *var void

// ═══════════════════════════════════════════════════════════════════════════
// Base Optimizer Trait
// ═══════════════════════════════════════════════════════════════════════════

open impl Optimizer {
    fn step(var self, params: Vec<Tensor>, grads: Vec<Tensor>)
    fn zero_grad(var self)
    fn get_lr(self) -> f32
    fn set_lr(var self, lr: f32)
}

// ═══════════════════════════════════════════════════════════════════════════
// SGD Optimizer
// ═══════════════════════════════════════════════════════════════════════════

expose data SGD {
    handle: OptimizerHandle,
    learning_rate: f32,
    momentum: f32,
    weight_decay: f32,
    nesterov: bool
}

impl SGD {
    fn new(learning_rate: f32) -> SGD {
        yield SGD.with_config(learning_rate, 0.0, 0.0, false)
    }
    
    fn with_momentum(learning_rate: f32, momentum: f32) -> SGD {
        yield SGD.with_config(learning_rate, momentum, 0.0, false)
    }
    
    fn with_nesterov(learning_rate: f32, momentum: f32) -> SGD {
        yield SGD.with_config(learning_rate, momentum, 0.0, true)
    }
    
    fn with_config(learning_rate: f32, momentum: f32, weight_decay: f32, nesterov: bool) -> SGD {
        unsafe {
            let handle = @extern("nova_optim_sgd")(
                learning_rate,
                momentum,
                weight_decay,
                nesterov
            )
            
            SGD {
                handle,
                learning_rate,
                momentum,
                weight_decay,
                nesterov
            }
        }
    }
}

impl Optimizer for SGD {
    fn step(var self, params: Vec<Tensor>, grads: Vec<Tensor>) {
        assert(params.len() == grads.len(), "Params and grads must have same length")
        
        unsafe {
            // Convert to raw pointers
            let param_ptrs = params.map(|t| t.raw_ptr())
            let grad_ptrs = grads.map(|t| t.raw_ptr())
            
            @extern("nova_optim_step")(
                self.handle,
                param_ptrs.as_ptr(),
                grad_ptrs.as_ptr(),
                params.len() as usize
            )
        }
    }
    
    fn zero_grad(var self) {
        unsafe {
            @extern("nova_optim_zero_grad")(self.handle)
        }
    }
    
    fn get_lr(self) -> f32 {
        unsafe {
            yield @extern("nova_optim_get_lr")(self.handle)
        }
    }
    
    fn set_lr(var self, lr: f32) {
        self.learning_rate = lr
        unsafe {
            @extern("nova_optim_set_lr")(self.handle, lr)
        }
    }
}

impl Drop for SGD {
    fn drop(var self) {
        unsafe {
            @extern("nova_optim_free")(self.handle)
        }
    }
}

