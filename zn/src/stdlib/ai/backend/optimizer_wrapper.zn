// ═══════════════════════════════════════════════════════════════════════════
// Learning Rate Schedulers
// ═══════════════════════════════════════════════════════════════════════════

expose data CosineAnnealingLR {
    optimizer: &var dyn Optimizer,
    base_lr: f32,
    min_lr: f32,
    T_max: u32,
    current_step: u32
}

impl CosineAnnealingLR {
    fn new(optimizer: &var dyn Optimizer, T_max: u32, min_lr: f32) -> CosineAnnealingLR {
        let base_lr = optimizer.get_lr()
        CosineAnnealingLR {
            optimizer,
            base_lr,
            min_lr,
            T_max,
            current_step: 0
        }
    }
    
    fn step(var self) {
        self.current_step += 1
        let progress = self.current_step as f32 / self.T_max as f32
        let cos_term = (1.0 + cos(3.14159 * progress)) / 2.0
        let new_lr = self.min_lr + (self.base_lr - self.min_lr) * cos_term
        self.optimizer.set_lr(new_lr)
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Example Usage
// ═══════════════════════════════════════════════════════════════════════════

/**
 * Example 1: SGD with Momentum
 * 
 * ```nova
 * import ai.backend.optimizer_wrapper::*
 * 
 * var optimizer = SGD.with_momentum(learning_rate: 0.01, momentum: 0.9)
 * 
 * each epoch in 0..100 {
 *     // Forward pass
 *     let output = model.forward(input)
 *     let loss = loss_fn.compute(output, targets)
 *     
 *     // Backward pass
 *     let grads = compute_gradients(loss)
 *     
 *     // Update
 *     optimizer.step(model.parameters(), grads)
 *     optimizer.zero_grad()
 * }
 * ```
 */

/**
 * Example 2: AdamW with Learning Rate Scheduling
 * 
 * ```nova
 * import ai.backend.optimizer_wrapper::*
 * 
 * var optimizer = AdamW.new(learning_rate: 1e-3, weight_decay: 0.01)
 * var scheduler = CosineAnnealingLR.new(&var optimizer, T_max: 100, min_lr: 1e-6)
 * 
 * each epoch in 0..100 {
 *     // Training step
 *     optimizer.step(params, grads)
 *     
 *     // Update learning rate
 *     scheduler.step()
 *     
 *     println(f"Epoch {epoch}, LR: {optimizer.get_lr()}")
 * }
 * ```
 */

/**
 * Example 3: Polymorphic Optimizer
 * 
 * ```nova
 * fn train_model(optimizer: &var dyn Optimizer, model: Model, data: Dataset) {
 *     each batch in data {
 *         let (input, target) = batch
 *         let output = model.forward(input)
 *         let grads = compute_gradients(output, target)
 *         
 *         optimizer.step(model.parameters(), grads)
 *         optimizer.zero_grad()
 *     }
 * }
 * 
 * // Can use any optimizer!
 * var adam = Adam.new(1e-3)
 * train_model(&var adam, my_model, my_data)
 * ```
 */

// Helper function
fn cos(x: f32) -> f32 {
    // Placeholder - would use actual cos from math lib
    yield 0.0
}
