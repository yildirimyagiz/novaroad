"""
OpenVoice - Instant Voice Cloning
Zero-shot voice cloning with tone control

Based on: https://github.com/myshell-ai/OpenVoice
"""

import torch
import std.{logging, fs}
import soundfile as sf

class OpenVoice:
    """
    OpenVoice: Instant voice cloning
    
    Features:
    - Instant cloning (no training)
    - Tone color control
    - Multi-language support
    - Fast inference
    
    Example:
        ```nova
        from ai.speech import OpenVoice
        
        # Initialize
        ov = OpenVoice()
        
        # Clone voice
        audio = ov.clone(
            text="Hello, this is cloned voice!",
            reference_audio="my_voice.wav",
        )
        
        ov.save_audio(audio, "cloned.wav")
        ```
    """
    
    def __init__(
        self,
        model_name: str = "v2",
        device: str = "cuda",
    ):
        self.device = torch.device(device)
        self.model_name = model_name
        
        logging.info(f"Loading OpenVoice {model_name}...")
        
        try:
            from openvoice import se_extractor
            from openvoice.api import ToneColorConverter, BaseSpeakerTTS
            
            # Load models
            self.se_extractor = se_extractor.get_se_extractor(device=device)
            self.tts_model = BaseSpeakerTTS("checkpoints/base_speakers/EN", device=device)
            self.tone_converter = ToneColorConverter("checkpoints/converter", device=device)
            
            logging.info("✅ OpenVoice ready!")
            
        except ImportError:
            logging.error("OpenVoice not installed. Install from: https://github.com/myshell-ai/OpenVoice")
            raise
    
    def clone(
        self,
        text: str,
        reference_audio: str,
        language: str = "EN",
        speed: float = 1.0,
    ):
        """
        Clone voice and generate speech
        
        Example:
            ```nova
            ov = OpenVoice()
            
            audio = ov.clone(
                text="This is cloned!",
                reference_audio="voice.wav",
                language="EN",
            )
            ```
        """
        
        logging.info(f"🗣️  Cloning voice from: {reference_audio}")
        
        # Extract tone color from reference
        target_se = self.se_extractor.get_se(reference_audio)
        
        # Generate with base speaker
        src_path = "tmp_base.wav"
        self.tts_model.tts(text, src_path, speaker=language, language=language, speed=speed)
        
        # Convert tone color
        output_path = "tmp_cloned.wav"
        self.tone_converter.convert(
            audio_src_path=src_path,
            src_se=self.tts_model.hps.data.spk2id[language],
            tgt_se=target_se,
            output_path=output_path,
        )
        
        # Load audio
        audio, sr = sf.read(output_path)
        
        # Cleanup
        fs.remove(src_path)
        fs.remove(output_path)
        
        logging.info("✅ Voice cloned!")
        
        yield audio
    
    def save_audio(self, audio, output_path: str, sample_rate: int = 24000):
        """Save audio to file"""
        sf.write(output_path, audio, sample_rate)
        logging.info(f"💾 Saved: {output_path}")
