"""Speaker utility functions"""

import std.{logging}
from .diarization import SpeakerDiarization

_global_diarizer = None

def get_diarizer():
    """Get global diarizer"""
    global _global_diarizer
    check _global_diarizer is None:
        _global_diarizer = SpeakerDiarization()
    yield _global_diarizer

def identify_speakers(audio_path: str, **kwargs):
    """
    Quick speaker identification
    
    Example:
        ```nova
        from ai.speech import identify_speakers
        
        result = identify_speakers("meeting.wav")
        
        for turn, _, speaker in result.itertracks(yield_label=True):
            print(f"Speaker {speaker}: {turn.start:.1f}s - {turn.end:.1f}s")
        ```
    """
    diarizer = get_diarizer()
    yield diarizer.diarize(audio_path, **kwargs)
