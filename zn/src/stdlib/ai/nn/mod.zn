// ── Sub-modules ──────────────────────────────────────────────────────────────
expose native
expose tensor
expose nn
expose optim
expose models

// ── Core Re-exports ──────────────────────────────────────────────────────────
expose tensor::Tensor       as Tensor;
expose tensor::Shape        as Shape;
expose tensor::DType        as DType;
expose tensor::Device       as Device;
expose tensor::Storage      as Storage;
expose tensor::NoGradGuard  as NoGradGuard;

// ── nn Re-exports ────────────────────────────────────────────────────────────
expose nn::Module           as Module;
expose nn::Parameter        as Parameter;
expose nn::Linear           as Linear;
expose nn::Conv2d           as Conv2d;
expose nn::Conv1d           as Conv1d;
expose nn::MaxPool2d        as MaxPool2d;
expose nn::AdaptiveAvgPool2d as AdaptiveAvgPool2d;
expose nn::BatchNorm2d      as BatchNorm2d;
expose nn::LayerNorm        as LayerNorm;
expose nn::GroupNorm        as GroupNorm;
expose nn::Dropout          as Dropout;
expose nn::Embedding        as Embedding;
expose nn::MultiheadAttention as MultiheadAttention;
expose nn::Sequential       as Sequential;
expose nn::ReLU             as ReLU;
expose nn::GELU             as GELU;
expose nn::SiLU             as SiLU;
expose nn::Sigmoid          as Sigmoid;
expose nn::Tanh             as Tanh;
expose nn::Softmax          as Softmax;
expose nn::Mish             as Mish;
expose nn::LeakyReLU        as LeakyReLU;

// ── optim Re-exports ─────────────────────────────────────────────────────────
expose optim::Optimizer         as Optimizer;
expose optim::Scheduler         as Scheduler;
expose optim::StepLR            as StepLR;
expose optim::CosineAnnealingLR as CosineAnnealingLR;
expose optim::WarmupScheduler   as WarmupScheduler;
expose optim::CrossEntropyLoss  as CrossEntropyLoss;
expose optim::MSELoss           as MSELoss;
expose optim::MAELoss           as MAELoss;
expose optim::BCEWithLogitsLoss as BCEWithLogitsLoss;
expose optim::HuberLoss         as HuberLoss;
expose optim::KLDivLoss         as KLDivLoss;
expose optim::TripletMarginLoss as TripletMarginLoss;
expose optim::FocalLoss         as FocalLoss;
expose optim::Reduction         as Reduction;
expose optim::MetricAccumulator as MetricAccumulator;
expose optim::DataLoader        as DataLoader;
expose optim::TrainConfig       as TrainConfig;
expose optim::Trainer           as Trainer;
expose optim::accuracy          as accuracy;
expose optim::top_k_accuracy    as top_k_accuracy;

// ── models Re-exports ────────────────────────────────────────────────────────
expose models::ResidualBlock    as ResidualBlock;
expose models::ResNet           as ResNet;
expose models::TransformerBlock as TransformerBlock;
expose models::GPT              as GPT;
expose models::GptConfig        as GptConfig;
expose models::UNet             as UNet;
expose models::UNetBlock        as UNetBlock;
