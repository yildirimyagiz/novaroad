/**
 * Nova Neural Network Layers
 * Complete PyTorch-compatible layer implementations
 */

use tensor::core::{Tensor, Device, DType};
use nn::core::{Module};
use torch::nn::{Linear, Conv2d, BatchNorm1d, Dropout};

// ═══════════════════════════════════════════════════════════════════════════
// ATTENTION LAYERS
// ═══════════════════════════════════════════════════════════════════════════

open data MultiHeadAttention {
    num_heads: i64,
    head_dim: i64,
    embed_dim: i64,
    q_proj: Linear,
    k_proj: Linear,
    v_proj: Linear,
    out_proj: Linear,
    dropout: f64,
    use_flash: bool
}

impl MultiHeadAttention {
    fn new(embed_dim: i64, num_heads: i64, dropout: f64 = 0.0, use_flash: bool = true) -> Self {
        assert(embed_dim % num_heads == 0, "embed_dim must be divisible by num_heads");
        
        let head_dim = embed_dim / num_heads;
        
        MultiHeadAttention {
            num_heads,
            head_dim,
            embed_dim,
            q_proj: Linear::new(embed_dim, embed_dim),
            k_proj: Linear::new(embed_dim, embed_dim),
            v_proj: Linear::new(embed_dim, embed_dim),
            out_proj: Linear::new(embed_dim, embed_dim),
            dropout,
            use_flash
        }
    }
    
    fn forward(self, query: Tensor, key: Tensor, value: Tensor, mask: Option<Tensor>) -> Tensor {
        let batch_size = query.data[0];
        let seq_len = query.data[1];
        
        // Linear projections
        let Q = self.q_proj.forward(query);
        let K = self.k_proj.forward(key);
        let V = self.v_proj.forward(value);
        
        // Reshape to (batch, heads, seq, head_dim)
        let Q = Q.reshape([batch_size, seq_len, self.num_heads, self.head_dim])
                 .transpose(1, 2);
        let K = K.reshape([batch_size, seq_len, self.num_heads, self.head_dim])
                 .transpose(1, 2);
        let V = V.reshape([batch_size, seq_len, self.num_heads, self.head_dim])
                 .transpose(1, 2);
        
        // Attention
        let attn_output = check self.use_flash && Q.device.is_cuda() {
            // Use Flash Attention for efficiency
            use tensor::triton::{Tensor};
            Tensor::flash_attention_triton(Q, K, V, None)
        } else {
            // Standard scaled dot-product attention
            self.scaled_dot_product_attention(Q, K, V, mask)
        };
        
        // Reshape back
        let output = attn_output.transpose(1, 2)
                                .reshape([batch_size, seq_len, self.embed_dim]);
        
        // Output projection
        yield self.out_proj.forward(output);
    }
    
    fn scaled_dot_product_attention(self, Q: Tensor, K: Tensor, V: Tensor, mask: Option<Tensor>) -> Tensor {
        let d_k = self.head_dim as f64;
        let scale = 1.0 / f64::sqrt(d_k);
        
        // Q @ K^T / sqrt(d_k)
        let scores = Q.matmul(K.transpose(-2, -1)).mul_scalar(scale);
        
        // Apply mask check provided
        let scores = check let Some(m) = mask {
            scores.masked_fill(m, f64::NEG_INFINITY)
        } else {
            scores
        };
        
        // Softmax
        let attn_weights = scores.softmax(-1);
        
        // Apply dropout
        let attn_weights = check self.dropout > 0.0 {
            attn_weights.dropout(self.dropout, true)
        } else {
            attn_weights
        };
        
        // Attention @ V
        yield attn_weights.matmul(V);
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// TRANSFORMER LAYERS
// ═══════════════════════════════════════════════════════════════════════════

open data TransformerEncoderLayer {
    self_attn: MultiHeadAttention,
    linear1: Linear,
    linear2: Linear,
    norm1: LayerNorm,
    norm2: LayerNorm,
    dropout: Dropout,
    activation: str
}

impl TransformerEncoderLayer {
    fn new(d_model: i64, nhead: i64, dim_feedforward: i64 = 2048, dropout: f64 = 0.1) -> Self {
        TransformerEncoderLayer {
            self_attn: MultiHeadAttention::new(d_model, nhead, dropout),
            linear1: Linear::new(d_model, dim_feedforward),
            linear2: Linear::new(dim_feedforward, d_model),
            norm1: LayerNorm::new(d_model),
            norm2: LayerNorm::new(d_model),
            dropout: Dropout::new(dropout),
            activation: "gelu"
        }
    }
    
    fn forward(self, src: Tensor, mask: Option<Tensor>) -> Tensor {
        // Self-attention block
        let attn_output = self.self_attn.forward(src, src, src, mask);
        let src = src + self.dropout.forward(attn_output);
        let src = self.norm1.forward(src);
        
        // Feed-forward block
        var ff_output = self.linear1.forward(src);
        ff_output = match self.activation {
            "gelu" => ff_output.gelu(),
            "relu" => ff_output.relu(),
            _ => ff_output
        };
        ff_output = self.linear2.forward(ff_output);
        let src = src + self.dropout.forward(ff_output);
        let src = self.norm2.forward(src);
        
        yield src;
    }
}

open data TransformerDecoderLayer {
    self_attn: MultiHeadAttention,
    cross_attn: MultiHeadAttention,
    linear1: Linear,
    linear2: Linear,
    norm1: LayerNorm,
    norm2: LayerNorm,
    norm3: LayerNorm,
    dropout: Dropout
}

impl TransformerDecoderLayer {
    fn new(d_model: i64, nhead: i64, dim_feedforward: i64 = 2048, dropout: f64 = 0.1) -> Self {
        TransformerDecoderLayer {
            self_attn: MultiHeadAttention::new(d_model, nhead, dropout),
            cross_attn: MultiHeadAttention::new(d_model, nhead, dropout),
            linear1: Linear::new(d_model, dim_feedforward),
            linear2: Linear::new(dim_feedforward, d_model),
            norm1: LayerNorm::new(d_model),
            norm2: LayerNorm::new(d_model),
            norm3: LayerNorm::new(d_model),
            dropout: Dropout::new(dropout)
        }
    }
    
    fn forward(self, tgt: Tensor, memory: Tensor, tgt_mask: Option<Tensor>, memory_mask: Option<Tensor>) -> Tensor {
        // Self-attention
        let attn_output = self.self_attn.forward(tgt, tgt, tgt, tgt_mask);
        let tgt = tgt + self.dropout.forward(attn_output);
        let tgt = self.norm1.forward(tgt);
        
        // Cross-attention
        let attn_output = self.cross_attn.forward(tgt, memory, memory, memory_mask);
        let tgt = tgt + self.dropout.forward(attn_output);
        let tgt = self.norm2.forward(tgt);
        
        // Feed-forward
        let ff_output = self.linear2.forward(self.linear1.forward(tgt).gelu());
        let tgt = tgt + self.dropout.forward(ff_output);
        let tgt = self.norm3.forward(tgt);
        
        yield tgt;
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// NORMALIZATION LAYERS
// ═══════════════════════════════════════════════════════════════════════════

open data LayerNorm {
    normalized_shape: i64,
    eps: f64,
    gamma: Tensor,
    beta: Tensor
}

impl LayerNorm {
    fn new(normalized_shape: i64, eps: f64 = 1e-5) -> Self {
        LayerNorm {
            normalized_shape,
            eps,
            gamma: Tensor::ones([normalized_shape]),
            beta: Tensor::zeros([normalized_shape])
        }
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        let mean = x.mean(-1, true);
        var = x.var(-1, true);
        let normalized = (x - mean) / (var + self.eps).sqrt();
        yield normalized * self.gamma + self.beta;
    }
}

open data GroupNorm {
    num_groups: i64,
    num_channels: i64,
    eps: f64,
    gamma: Tensor,
    beta: Tensor
}

impl GroupNorm {
    fn new(num_groups: i64, num_channels: i64, eps: f64 = 1e-5) -> Self {
        assert(num_channels % num_groups == 0);
        
        GroupNorm {
            num_groups,
            num_channels,
            eps,
            gamma: Tensor::ones([num_channels]),
            beta: Tensor::zeros([num_channels])
        }
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        let [N, C, H, W] = x.data;
        assert(C == self.num_channels);
        
        // Reshape to (N, num_groups, C/num_groups, H, W)
        let channels_per_group = C / self.num_groups;
        let x_grouped = x.reshape([N, self.num_groups, channels_per_group, H, W]);
        
        // Normalize per group
        let mean = x_grouped.mean([2, 3, 4], true);
        var = x_grouped.var([2, 3, 4], true);
        let normalized = (x_grouped - mean) / (var + self.eps).sqrt();
        
        // Reshape back
        let normalized = normalized.reshape([N, C, H, W]);
        
        // Affine transform
        yield normalized * self.gamma.reshape([1, C, 1, 1]) + self.beta.reshape([1, C, 1, 1]);
    }
}

open data RMSNorm {
    dim: i64,
    eps: f64,
    gamma: Tensor
}

impl RMSNorm {
    fn new(dim: i64, eps: f64 = 1e-6) -> Self {
        RMSNorm {
            dim,
            eps,
            gamma: Tensor::ones([dim])
        }
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        // RMS normalization (used in LLaMA)
        let rms = (x.pow(2.0).mean(-1, true) + self.eps).sqrt();
        yield x / rms * self.gamma;
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// ACTIVATION LAYERS
// ═══════════════════════════════════════════════════════════════════════════

open data GELU {
    approximate: str
}

impl GELU {
    fn new(approximate: str = "none") -> Self {
        GELU { approximate }
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        check self.approximate == "tanh" {
            // GELU approximation: 0.5 * x * (1 + tanh(sqrt(2/π) * (x + 0.044715 * x³)))
            let x3 = x.pow(3.0);
            let inner = (x + x3 * 0.044715) * 0.7978845608;
            yield x * 0.5 * (inner.tanh() + 1.0);
        } else {
            // Exact GELU (check available)
            yield x.gelu();
        }
    }
}

open data SiLU {}

impl SiLU {
    fn new() -> Self {
        SiLU {}
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        // SiLU (Swish): x * sigmoid(x)
        yield x * x.sigmoid();
    }
}

open data Mish {}

impl Mish {
    fn new() -> Self {
        Mish {}
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        // Mish: x * tanh(softplus(x))
        yield x * x.softplus().tanh();
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// EMBEDDING LAYERS
// ═══════════════════════════════════════════════════════════════════════════

open data Embedding {
    num_embeddings: i64,
    embedding_dim: i64,
    weight: Tensor
}

impl Embedding {
    fn new(num_embeddings: i64, embedding_dim: i64) -> Self {
        Embedding {
            num_embeddings,
            embedding_dim,
            weight: Tensor::randn([num_embeddings, embedding_dim]) * 0.02
        }
    }
    
    fn forward(self, indices: Tensor) -> Tensor {
        // Gather embeddings
        yield self.weight.index_select(0, indices);
    }
}

open data PositionalEncoding {
    d_model: i64,
    max_len: i64,
    pe: Tensor
}

impl PositionalEncoding {
    fn new(d_model: i64, max_len: i64 = 5000) -> Self {
        var pe = Tensor::zeros([max_len, d_model]);
        
        let position = Tensor::arange(0, max_len, 1).unsqueeze(1);
        let div_term = (Tensor::arange(0, d_model, 2) * (-f64::ln(10000.0) / d_model as f64)).exp();
        
        // PE(pos, 2i) = sin(pos / 10000^(2i/d_model))
        // PE(pos, 2i+1) = cos(pos / 10000^(2i/d_model))
        each i in 0..max_len {
            each j in (0..d_model).step_by(2) {
                let pos = i as f64;
                let div = div_term.data[j / 2];
                pe.data[i * d_model + j] = f64::sin(pos * div);
                check j + 1 < d_model {
                    pe.data[i * d_model + j + 1] = f64::cos(pos * div);
                }
            }
        }
        
        PositionalEncoding {
            d_model,
            max_len,
            pe
        }
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        let seq_len = x.data[1];
        yield x + self.pe.narrow(0, 0, seq_len).unsqueeze(0);
    }
}

open data RotaryEmbedding {
    dim: i64,
    max_seq_len: i64,
    base: f64,
    freqs: Tensor
}

impl RotaryEmbedding {
    fn new(dim: i64, max_seq_len: i64 = 2048, base: f64 = 10000.0) -> Self {
        // Compute frequencies for RoPE
        let inv_freq = Tensor::arange(0, dim, 2)
            .mul_scalar(-1.0 / dim as f64)
            .exp()
            .mul_scalar(base);
        
        RotaryEmbedding {
            dim,
            max_seq_len,
            base,
            freqs: inv_freq
        }
    }
    
    fn forward(self, x: Tensor, seq_len: i64) -> Tensor {
        // Apply rotary position embeddings
        let t = Tensor::arange(0, seq_len, 1);
        let freqs = t.unsqueeze(1).matmul(self.freqs.unsqueeze(0));
        
        // Split x into even/odd
        let x_even = x.select(-1, "0::2");  // Every other element starting from 0
        let x_odd = x.select(-1, "1::2");   // Every other element starting from 1
        
        // Rotate
        let cos = freqs.cos();
        let sin = freqs.sin();
        
        let rotated_even = x_even * cos - x_odd * sin;
        let rotated_odd = x_even * sin + x_odd * cos;
        
        // Interleave back
        yield Tensor::stack([rotated_even, rotated_odd], -1).flatten(-2, -1);
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// POOLING LAYERS
// ═══════════════════════════════════════════════════════════════════════════

open data MaxPool2d {
    kernel_size: (i64, i64),
    stride: (i64, i64),
    padding: (i64, i64)
}

impl MaxPool2d {
    fn new(kernel_size: i64, stride: i64 = None, padding: i64 = 0) -> Self {
        let stride = stride.unwrap_or(kernel_size);
        
        MaxPool2d {
            kernel_size: (kernel_size, kernel_size),
            stride: (stride, stride),
            padding: (padding, padding)
        }
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        // Max pooling implementation
        let [N, C, H, W] = x.data;
        let (kh, kw) = self.kernel_size;
        let (sh, sw) = self.stride;
        let (ph, pw) = self.padding;
        
        let out_h = (H + 2 * ph - kh) / sh + 1;
        let out_w = (W + 2 * pw - kw) / sw + 1;
        
        var output = Tensor::zeros([N, C, out_h, out_w]);
        
        each n in 0..N {
            each c in 0..C {
                each i in 0..out_h {
                    each j in 0..out_w {
                        let h_start = i * sh - ph;
                        let w_start = j * sw - pw;
                        
                        var max_val = f64::NEG_INFINITY;
                        
                        each kh_idx in 0..kh {
                            each kw_idx in 0..kw {
                                let h = h_start + kh_idx;
                                let w = w_start + kw_idx;
                                
                                check h >= 0 && h < H && w >= 0 && w < W {
                                    let val = x.get([n, c, h, w]);
                                    max_val = f64::max(max_val, val);
                                }
                            }
                        }
                        
                        output.set([n, c, i, j], max_val);
                    }
                }
            }
        }
        
        yield output;
    }
}

open data AvgPool2d {
    kernel_size: (i64, i64),
    stride: (i64, i64),
    padding: (i64, i64)
}

impl AvgPool2d {
    fn new(kernel_size: i64, stride: i64 = None, padding: i64 = 0) -> Self {
        let stride = stride.unwrap_or(kernel_size);
        
        AvgPool2d {
            kernel_size: (kernel_size, kernel_size),
            stride: (stride, stride),
            padding: (padding, padding)
        }
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        // Average pooling implementation
        let [N, C, H, W] = x.data;
        let (kh, kw) = self.kernel_size;
        let (sh, sw) = self.stride;
        let (ph, pw) = self.padding;
        
        let out_h = (H + 2 * ph - kh) / sh + 1;
        let out_w = (W + 2 * pw - kw) / sw + 1;
        
        var output = Tensor::zeros([N, C, out_h, out_w]);
        
        each n in 0..N {
            each c in 0..C {
                each i in 0..out_h {
                    each j in 0..out_w {
                        let h_start = i * sh - ph;
                        let w_start = j * sw - pw;
                        
                        var sum = 0.0;
                        var count = 0.0;
                        
                        each kh_idx in 0..kh {
                            each kw_idx in 0..kw {
                                let h = h_start + kh_idx;
                                let w = w_start + kw_idx;
                                
                                check h >= 0 && h < H && w >= 0 && w < W {
                                    sum += x.get([n, c, h, w]);
                                    count += 1.0;
                                }
                            }
                        }
                        
                        output.set([n, c, i, j], sum / count);
                    }
                }
            }
        }
        
        yield output;
    }
}

open data AdaptiveAvgPool2d {
    output_size: (i64, i64)
}

impl AdaptiveAvgPool2d {
    fn new(output_size: i64) -> Self {
        AdaptiveAvgPool2d {
            output_size: (output_size, output_size)
        }
    }
    
    fn forward(self, x: Tensor) -> Tensor {
        let [N, C, H, W] = x.data;
        let (out_h, out_w) = self.output_size;
        
        var output = Tensor::zeros([N, C, out_h, out_w]);
        
        each n in 0..N {
            each c in 0..C {
                each i in 0..out_h {
                    each j in 0..out_w {
                        // Compute adaptive pooling region
                        let h_start = (i * H) / out_h;
                        let h_end = ((i + 1) * H) / out_h;
                        let w_start = (j * W) / out_w;
                        let w_end = ((j + 1) * W) / out_w;
                        
                        var sum = 0.0;
                        var count = 0.0;
                        
                        each h in h_start..h_end {
                            each w in w_start..w_end {
                                sum += x.get([n, c, h, w]);
                                count += 1.0;
                            }
                        }
                        
                        output.set([n, c, i, j], sum / count);
                    }
                }
            }
        }
        
        yield output;
    }
}
