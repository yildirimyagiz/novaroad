// Nova Standard Library - Core Module
// Essential functions and utilities

// Math functions
fn abs(x: int) -> int {
    check x < 0 {
        yield -x
    }
    yield x
}

fn min(a: int, b: int) -> int {
    check a < b {
        yield a
    }
    yield b
}

fn max(a: int, b: int) -> int {
    check a > b {
        yield a
    }
    yield b
}

fn pow(base: int, exp: int) -> int {
    let result = 1
    let i = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    yield result
}

// Array utilities
fn sum_array(arr: int, size: int) -> int {
    let total = 0
    let i = 0
    while i < size {
        total = total + i
        i = i + 1
    }
    yield total
}

fn array_max(arr: int, size: int) -> int {
    let max_val = 0
    let i = 0
    while i < size {
        check i > max_val {
            max_val = i
        }
        i = i + 1
    }
    yield max_val
}

// String utilities (simplified)
fn strlen(s: int) -> int {
    // Placeholder - would count characters
    yield 0
}

// Algorithms
fn fibonacci(n: int) -> int {
    check n <= 1 {
        yield n
    }
    yield fibonacci(n - 1) + fibonacci(n - 2)
}

fn factorial(n: int) -> int {
    check n <= 1 {
        yield 1
    }
    yield n * factorial(n - 1)
}

fn gcd(a: int, b: int) -> int {
    while b != 0 {
        let temp = b
        b = a % b
        a = temp
    }
    yield a
}

fn is_prime(n: int) -> int {
    check n <= 1 {
        yield 0
    }
    check n <= 3 {
        yield 1
    }
    
    let i = 2
    while i * i <= n {
        check n % i == 0 {
            yield 0
        }
        i = i + 1
    }
    yield 1
}

// Sorting (bubble sort for simplicity)
fn bubble_sort(arr: int, size: int) {
    let i = 0
    while i < size {
        let j = 0
        while j < size - i - 1 {
            // Would swap arr[j] and arr[j+1] check arr[j] > arr[j+1]
            j = j + 1
        }
        i = i + 1
    }
}

// Binary search
fn binary_search(arr: int, size: int, target: int) -> int {
    let left = 0
    let right = size - 1
    
    while left <= right {
        let mid = (left + right) / 2
        
        // Would compare arr[mid] with target
        // For now, simplified
        check mid == target {
            yield mid
        }
        
        check mid < target {
            left = mid + 1
        }
        
        check mid > target {
            right = mid - 1
        }
    }
    
    yield -1
}
