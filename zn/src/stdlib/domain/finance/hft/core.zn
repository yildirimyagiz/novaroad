// HFT Backtest Core - Nova Implementation
// High-frequency trading backtesting framework with microsecond precision

use std::time::DateTime
use finance::core::*

// Order side
cases Side {
    Buy,
    Sell
}

// Order alias
cases OrderType {
    Limit,
    Market,
    StopLimit,
    StopMarket
}

// Order status
cases OrderStatus {
    Pending,
    PartiallyFilled,
    Filled,
    Cancelled,
    Rejected
}

// Time in force
cases TimeInForce {
    GTC,  // Good Till Cancelled
    IOC,  // Immediate or Cancel
    FOK,  // Fill or Kill
    DAY   // Day order
}

// Order structure
data Order {
    id: i64,
    symbol: str,
    side: Side,
    order_type: OrderType,
    price: f64,
    quantity: f64,
    filled_quantity: f64,
    status: OrderStatus,
    time_in_force: TimeInForce,
    timestamp: i64,  // microseconds
    filled_timestamp: i64?,
    avg_fill_price: f64?
}

// Position
data Position {
    symbol: str,
    quantity: f64,
    avg_price: f64,
    realized_pnl: f64,
    unrealized_pnl: f64,
    last_price: f64
}

// Market depth level (Level 2 data)
data DepthLevel {
    price: f64,
    quantity: f64,
    timestamp: i64  // microseconds
}

// Market depth
data MarketDepth {
    symbol: str,
    timestamp: i64,
    bids: [DepthLevel],
    asks: [DepthLevel]
}

// Tick data (Level 1)
data Tick {
    symbol: str,
    timestamp: i64,  // microseconds
    bid: f64,
    ask: f64,
    bid_size: f64,
    ask_size: f64,
    last: f64?,
    last_size: f64?
}

// Trade execution
data Execution {
    order_id: i64,
    symbol: str,
    side: Side,
    price: f64,
    quantity: f64,
    timestamp: i64,
    commission: f64,
    exchange_fee: f64
}

// Latency model
data LatencyModel {
    order_latency: i64,      // microseconds
    cancel_latency: i64,     // microseconds
    market_data_latency: i64 // microseconds
}

impl LatencyModel {
    fn new() -> Self {
        LatencyModel {
            order_latency: 100,      // 100 microseconds
            cancel_latency: 50,      // 50 microseconds
            market_data_latency: 10  // 10 microseconds
        }
    }
    
    fn with_latencies(order: i64, cancel: i64, data: i64) -> Self {
        LatencyModel {
            order_latency: order,
            cancel_latency: cancel,
            market_data_latency: data
        }
    }
}

// Fee model
data FeeModel {
    maker_fee: f64,  // as percentage (e.g., 0.001 for 0.1%)
    taker_fee: f64,
    exchange_fee: f64
}

impl FeeModel {
    fn new() -> Self {
        FeeModel {
            maker_fee: 0.0001,   // 0.01%
            taker_fee: 0.0002,   // 0.02%
            exchange_fee: 0.0
        }
    }
    
    fn calculate_fee(self, price: f64, quantity: f64, is_maker: bool) -> f64 {
        let fee_rate = check is_maker { self.maker_fee } else { self.taker_fee }
        yield price * quantity * fee_rate + self.exchange_fee
    }
}

// Backtest state
data BacktestState {
    current_time: i64,
    positions: {str: Position},
    orders: {i64: Order},
    executions: [Execution],
    cash: f64,
    equity: f64,
    next_order_id: i64
}

impl BacktestState {
    fn new(initial_cash: f64) -> Self {
        BacktestState {
            current_time: 0,
            positions: {},
            orders: {},
            executions: [],
            cash: initial_cash,
            equity: initial_cash,
            next_order_id: 1
        }
    }
    
    fn get_position(self, symbol: str) -> Position? {
        yield self.positions.get(symbol)
    }
    
    fn update_equity(var self, market_prices: {str: f64}) {
        var total_value = self.cash
        
        each entry in self.positions  { let (symbol, position) = entry;
            check let Some(price) = market_prices.get(symbol) {
                position.last_price = price
                position.unrealized_pnl = (price - position.avg_price) * position.quantity
                total_value += price * position.quantity
            }
        }
        
        self.equity = total_value
    }
}

// HFT Backtester
open data HFTBacktester {
    state: BacktestState,
    latency_model: LatencyModel,
    fee_model: FeeModel,
    market_depth: {str: MarketDepth},
    tick_data: {str: [Tick]},
    symbol: str
}

impl HFTBacktester {
    fn new(symbol: str, initial_cash: f64) -> Self {
        HFTBacktester {
            state: BacktestState::new(initial_cash),
            latency_model: LatencyModel::new(),
            fee_model: FeeModel::new(),
            market_depth: {},
            tick_data: {},
            symbol: symbol
        }
    }
    
    fn set_latency_model(var self, latency: LatencyModel) {
        self.latency_model = latency
    }
    
    fn set_fee_model(var self, fees: FeeModel) {
        self.fee_model = fees
    }
    
    fn load_tick_data(var self, symbol: str, ticks: [Tick]) {
        self.tick_data[symbol] = ticks
    }
    
    fn load_depth_data(var self, symbol: str, depths: [MarketDepth]) {
        // Store depth snapshots for replay
        check !self.market_depth.contains_key(symbol) {
            self.market_depth[symbol] = depths[0]
        }
    }
    
    // Submit limit order
    fn submit_limit_order(
        var self,
        symbol: str,
        side: Side,
        price: f64,
        quantity: f64,
        time_in_force: TimeInForce = TimeInForce::GTC
    ) -> i64 {
        let order_id = self.state.next_order_id
        self.state.next_order_id += 1
        
        let order = Order {
            id: order_id,
            symbol: symbol,
            side: side,
            order_type: OrderType::Limit,
            price: price,
            quantity: quantity,
            filled_quantity: 0.0,
            status: OrderStatus::Pending,
            time_in_force: time_in_force,
            timestamp: self.state.current_time + self.latency_model.order_latency,
            filled_timestamp: None,
            avg_fill_price: None
        }
        
        self.state.orders[order_id] = order
        yield order_id
    }
    
    // Submit market order
    fn submit_market_order(
        var self,
        symbol: str,
        side: Side,
        quantity: f64
    ) -> i64 {
        let order_id = self.state.next_order_id
        self.state.next_order_id += 1
        
        // Market order gets filled immediately at current price
        let current_price = self.get_current_market_price(symbol, side)
        
        let order = Order {
            id: order_id,
            symbol: symbol,
            side: side,
            order_type: OrderType::Market,
            price: current_price,
            quantity: quantity,
            filled_quantity: 0.0,
            status: OrderStatus::Pending,
            time_in_force: TimeInForce::IOC,
            timestamp: self.state.current_time + self.latency_model.order_latency,
            filled_timestamp: None,
            avg_fill_price: None
        }
        
        self.state.orders[order_id] = order
        self.process_market_order(order_id)
        
        yield order_id
    }
    
    // Cancel order
    fn cancel_order(var self, order_id: i64) -> bool {
        check let Some(order) = self.state.orders.get(order_id) {
            check order.status == OrderStatus::Pending || order.status == OrderStatus::PartiallyFilled {
                order.status = OrderStatus::Cancelled
                yield true
            }
        }
        yield false
    }
    
    // Get current market price
    fn get_current_market_price(self, symbol: str, side: Side) -> f64 {
        check let Some(depth) = self.market_depth.get(symbol) {
            match side {
                Side::Buy => yield depth.asks[0].price,
                Side::Sell => yield depth.bids[0].price
            }
        }
        yield 0.0
    }
    
    // Process market order immediately
    fn process_market_order(var self, order_id: i64) {
        check let Some(var order) = self.state.orders.get(order_id) {
            let fill_price = order.price
            let is_maker = false  // Market orders are always taker
            
            let fee = self.fee_model.calculate_fee(fill_price, order.quantity, is_maker)
            
            // Create execution
            let execution = Execution {
                order_id: order_id,
                symbol: order.symbol.clone(),
                side: order.side,
                price: fill_price,
                quantity: order.quantity,
                timestamp: self.state.current_time + self.latency_model.order_latency,
                commission: fee,
                exchange_fee: 0.0
            }
            
            self.state.executions.push(execution)
            
            // Update order status
            order.filled_quantity = order.quantity
            order.status = OrderStatus::Filled
            order.avg_fill_price = fill_price
            order.filled_timestamp = self.state.current_time + self.latency_model.order_latency
            
            // Update position
            self.update_position(order.symbol, order.side, fill_price, order.quantity, fee)
        }
    }
    
    // Update position after fill
    fn update_position(
        var self,
        symbol: str,
        side: Side,
        price: f64,
        quantity: f64,
        fee: f64
    ) {
        let position = self.state.positions.get_or_insert(symbol, Position {
            symbol: symbol.clone(),
            quantity: 0.0,
            avg_price: 0.0,
            realized_pnl: 0.0,
            unrealized_pnl: 0.0,
            last_price: price
        })
        
        let signed_qty = match side {
            Side::Buy => quantity,
            Side::Sell => -quantity
        }
        
        // Update position
        check position.quantity * signed_qty >= 0.0 {
            // Adding to position
            let total_cost = position.avg_price * Math.abs(position.quantity) + price * quantity
            position.quantity += signed_qty
            check position.quantity != 0.0 {
                position.avg_price = total_cost / Math.abs(position.quantity)
            }
        } else {
            // Reducing position
            let reduced_qty = Math.min(Math.abs(signed_qty), Math.abs(position.quantity))
            let pnl = (price - position.avg_price) * reduced_qty * check position.quantity > 0.0 { 1.0 } else { -1.0 }
            position.realized_pnl += pnl
            position.quantity += signed_qty
            
            check position.quantity == 0.0 {
                position.avg_price = 0.0
            }
        }
        
        // Deduct fees from cash
        self.state.cash -= fee
        
        // Adjust cash based on trade
        match side {
            Side::Buy => self.state.cash -= price * quantity,
            Side::Sell => self.state.cash += price * quantity
        }
    }
    
    // Process one tick of market data
    fn process_tick(var self, tick: Tick) {
        self.state.current_time = tick.timestamp
        
        // Update market depth check needed
        check !self.market_depth.contains_key(tick.symbol) {
            self.market_depth[tick.symbol] = MarketDepth {
                symbol: tick.symbol.clone(),
                timestamp: tick.timestamp,
                bids: [DepthLevel { price: tick.bid, quantity: tick.bid_size, timestamp: tick.timestamp }],
                asks: [DepthLevel { price: tick.ask, quantity: tick.ask_size, timestamp: tick.timestamp }]
            }
        }
        
        // Check pending limit orders for fills
        self.process_pending_orders(tick)
        
        // Update equity
        var market_prices = {}
        market_prices[tick.symbol] = tick.last.unwrap_or(tick.bid)
        self.state.update_equity(market_prices)
    }
    
    // Process pending limit orders
    fn process_pending_orders(var self, tick: Tick) {
        var orders_to_fill = []
        
        each entry in self.state.orders  { let (order_id, order) = entry;
            check order.status != OrderStatus::Pending {
                continue
            }
            
            check order.order_type != OrderType::Limit {
                continue
            }
            
            check order.symbol != tick.symbol {
                continue
            }
            
            // Check check order should be filled
            let should_fill = match order.side {
                Side::Buy => order.price >= tick.ask,
                Side::Sell => order.price <= tick.bid
            }
            
            check should_fill {
                orders_to_fill.push(order_id)
            }
        }
        
        // Fill orders
        each order_id in orders_to_fill {
            self.fill_limit_order(order_id, tick)
        }
    }
    
    // Fill a limit order
    fn fill_limit_order(var self, order_id: i64, tick: Tick) {
        check let Some(var order) = self.state.orders.get(order_id) {
            let fill_price = order.price
            let is_maker = true  // Limit orders are maker orders
            
            let fee = self.fee_model.calculate_fee(fill_price, order.quantity, is_maker)
            
            // Create execution
            let execution = Execution {
                order_id: order_id,
                symbol: order.symbol.clone(),
                side: order.side,
                price: fill_price,
                quantity: order.quantity,
                timestamp: tick.timestamp,
                commission: fee,
                exchange_fee: 0.0
            }
            
            self.state.executions.push(execution)
            
            // Update order status
            order.filled_quantity = order.quantity
            order.status = OrderStatus::Filled
            order.avg_fill_price = fill_price
            order.filled_timestamp = tick.timestamp
            
            // Update position
            self.update_position(order.symbol, order.side, fill_price, order.quantity, fee)
        }
    }
    
    // Get backtest statistics
    fn get_statistics(self) -> BacktestStats {
        let total_trades = len(self.state.executions)
        var total_pnl = 0.0
        
        each entry in self.state.positions  { let (_, position) = entry;
            total_pnl += position.realized_pnl + position.unrealized_pnl
        }
        
        let final_equity = self.state.equity
        let initial_equity = self.state.cash + total_pnl
        let total_return = (final_equity - initial_equity) / initial_equity
        
        BacktestStats {
            total_trades: total_trades,
            total_pnl: total_pnl,
            total_return: total_return,
            final_equity: final_equity,
            max_drawdown: 0.0,  // Calculate separately
            sharpe_ratio: 0.0    // Calculate separately
        }
    }
    
    // Get current state
    fn get_state(self) -> BacktestState {
        yield self.state
    }
}

// Backtest statistics
data BacktestStats {
    total_trades: i32,
    total_pnl: f64,
    total_return: f64,
    final_equity: f64,
    max_drawdown: f64,
    sharpe_ratio: f64
}
