// Wearable Health Monitoring
@module("medical::monitoring::wearables")
@export

open data WearableData {
    heart_rate_bpm: u32,
    steps: u32,
    calories: u32,
    sleep_hours: f64
}

impl WearableData {
    fn detect_anomaly(&self) -> bool {
        self.heart_rate_bpm > 120 || self.heart_rate_bpm < 40
    }
}
