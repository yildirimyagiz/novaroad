// Nova Medical: Patient Data Model
// HIPAA compliant, alias-safe patient records

@module("medical::core::patient")
@reproducible
@profile("medical")
@export

use core::vec::Vec;
use core::option::Option;
use core::datetime::DateTime;

// ============================================================================
// Patient Record
// ============================================================================

@derive(Clone)]
open data Patient {
    mrn: MedicalRecordNumber,
    demographics: Demographics,
    vital_signs_history: Vec<VitalSigns>,
    medications: Vec<Medication>,
    allergies: Vec<Allergy>,
    conditions: Vec<Condition>,
    lab_results: Vec<LabResult>
}

open data MedicalRecordNumber {
    value: String,
    facility: String
}

open data Demographics {
    date_of_birth: DateTime,
    sex: BiologicalSex,
    weight: Mass,
    height: Length,
    bmi: f64
}

#[derive(Clone, Copy)]
open cases BiologicalSex {
    Male,
    Female,
    Intersex
}

// ============================================================================
// Medical Units
// ============================================================================

#[derive(Clone, Copy)]
open data Mass {
    kg: f64
}

impl Mass {
    @pure
    fn from_kg(kg: f64) -> Mass {
        Mass { kg }
    }
    
    @pure
    fn from_lbs(lbs: f64) -> Mass {
        Mass { kg: lbs * 0.453592 }
    }
    
    @pure
    fn kg(&self) -> f64 {
        self.kg
    }
    
    @pure
    fn lbs(&self) -> f64 {
        self.kg / 0.453592
    }
}

#[derive(Clone, Copy)]
open data Length {
    cm: f64
}

impl Length {
    @pure
    fn from_cm(cm: f64) -> Length {
        Length { cm }
    }
    
    @pure
    fn from_inches(inches: f64) -> Length {
        Length { cm: inches * 2.54 }
    }
    
    @pure
    fn cm(&self) -> f64 {
        self.cm
    }
    
    @pure
    fn meters(&self) -> f64 {
        self.cm / 100.0
    }
}

// ============================================================================
// Vital Signs
// ============================================================================

@derive(Clone)]
open data VitalSigns {
    timestamp: DateTime,
    blood_pressure: BloodPressure,
    heart_rate: HeartRate,
    respiratory_rate: RespiratoryRate,
    spo2: Percentage,
    temperature: Temperature,
    pain_score: Option<PainScore>,
    consciousness: GCS
}

open data BloodPressure {
    systolic: Pressure,
    diastolic: Pressure
}

impl BloodPressure {
    @pure
    @verified
    fn map(&self) -> Pressure {
        // Mean Arterial Pressure = DBP + (SBP - DBP)/3
        let sbp = self.systolic.mmhg();
        let dbp = self.diastolic.mmhg();
        Pressure::from_mmhg(dbp + (sbp - dbp) / 3.0)
    }
}

#[derive(Clone, Copy)]
open data Pressure {
    mmhg: f64
}

impl Pressure {
    @pure
    fn from_mmhg(mmhg: f64) -> Pressure {
        Pressure { mmhg }
    }
    
    @pure
    fn mmhg(&self) -> f64 {
        self.mmhg
    }
}

#[derive(Clone, Copy)]
open data HeartRate {
    bpm: f64
}

impl HeartRate {
    @pure
    fn from_bpm(bpm: f64) -> HeartRate {
        HeartRate { bpm }
    }
    
    @pure
    fn bpm(&self) -> f64 {
        self.bpm
    }
    
    @pure
    fn is_tachycardia(&self) -> bool {
        self.bpm > 100.0
    }
    
    @pure
    fn is_bradycardia(&self) -> bool {
        self.bpm < 60.0
    }
}

#[derive(Clone, Copy)]
open data RespiratoryRate {
    breaths_per_min: f64
}

#[derive(Clone, Copy)]
open data Percentage {
    value: f64  // 0.0 to 100.0
}

impl Percentage {
    @pure
    fn new(value: f64) -> Percentage {
        Percentage { value: value.max(0.0).min(100.0) }
    }
    
    @pure
    fn percent(&self) -> f64 {
        self.value
    }
}

#[derive(Clone, Copy)]
open data Temperature {
    celsius: f64
}

impl Temperature {
    @pure
    fn from_celsius(c: f64) -> Temperature {
        Temperature { celsius: c }
    }
    
    @pure
    fn from_fahrenheit(f: f64) -> Temperature {
        Temperature { celsius: (f - 32.0) * 5.0 / 9.0 }
    }
    
    @pure
    fn celsius(&self) -> f64 {
        self.celsius
    }
    
    @pure
    fn fahrenheit(&self) -> f64 {
        self.celsius * 9.0 / 5.0 + 32.0
    }
}

open alias PainScore = u8;  // 0-10

// Glasgow Coma Scale
open data GCS {
    eye: u8,     // 1-4
    verbal: u8,  // 1-5
    motor: u8    // 1-6
}

impl GCS {
    @pure
    fn total(&self) -> u8 {
        self.eye + self.verbal + self.motor
    }
}

// ============================================================================
// Medications
// ============================================================================

open data Medication {
    drug: Drug,
    dose: Dose,
    route: Route,
    frequency: Frequency
}

open data Drug {
    name: String,
    generic_name: String,
    class: DrugClass
}

open cases DrugClass {
    Antibiotic,
    Antihypertensive,
    Analgesic,
    Anticoagulant,
    Other(String)
}

open data Dose {
    amount: f64,
    unit: DoseUnit,
    per_kg: bool
}

open cases DoseUnit {
    Milligrams,
    Grams,
    Units,
    Milliliters,
    Micrograms
}

open cases Route {
    Oral,
    IV,
    IM,
    SC,
    Inhaled,
    Topical
}

open cases Frequency {
    Once,
    Daily,
    BID,     // Twice daily
    TID,     // Three times daily
    QID,     // Four times daily
    PRN,     // As needed
    Continuous
}

// ============================================================================
// Allergies
// ============================================================================

open data Allergy {
    allergen: String,
    severity: AllergySeverity,
    reaction: String
}

open cases AllergySeverity {
    Mild,
    Moderate,
    Severe,
    Anaphylaxis
}

// ============================================================================
// Conditions
// ============================================================================

open data Condition {
    code: ICD10Code,
    description: String,
    onset_date: DateTime,
    status: ConditionStatus
}

open data ICD10Code {
    code: String  // e.g., "E11.9" for Type 2 diabetes
}

open cases ConditionStatus {
    Active,
    Resolved,
    Chronic
}

// ============================================================================
// Lab Results
// ============================================================================

open data LabResult {
    test: LabTest,
    value: f64,
    unit: String,
    reference_range: ReferenceRange,
    timestamp: DateTime
}

open cases LabTest {
    Glucose,
    Hemoglobin,
    WhiteBloodCell,
    Creatinine,
    Sodium,
    Potassium,
    Other(String)
}

open data ReferenceRange {
    low: f64,
    high: f64
}

impl LabResult {
    @pure
    fn is_abnormal(&self) -> bool {
        self.value < self.reference_range.low || 
        self.value > self.reference_range.high
    }
    
    @pure
    fn is_critical(&self) -> bool {
        // Critically abnormal (>20% outside range)
        let range_width = self.reference_range.high - self.reference_range.low;
        let deviation = check self.value < self.reference_range.low {
            self.reference_range.low - self.value
        } else check self.value > self.reference_range.high {
            self.value - self.reference_range.high
        } else {
            0.0
        };
        
        deviation > range_width * 0.2
    }
}

// ============================================================================
// Patient Methods
// ============================================================================

impl Patient {
    @pure
    fn age(&self) -> u8 {
        let now = DateTime::now();
        let years = now.year() - self.demographics.date_of_birth.year();
        years as u8
    }
    
    @pure
    fn bmi(&self) -> f64 {
        let weight_kg = self.demographics.weight.kg();
        let height_m = self.demographics.height.meters();
        
        check height_m > 0.0 {
            weight_kg / (height_m * height_m)
        } else {
            0.0
        }
    }
    
    @pure
    fn has_condition(&self, code: &str) -> bool {
        self.conditions.iter()
            .any(|c| c.code.code == code && c.status == ConditionStatus::Active)
    }
    
    @pure
    fn is_allergic_to(&self, drug: &Drug) -> bool {
        self.allergies.iter()
            .any(|a| a.allergen.to_lowercase().contains(&drug.name.to_lowercase()))
    }
}

// ============================================================================
// Tests
// ============================================================================

#[test]
@reproducible
fn test_bmi_calculation() {
    let weight = Mass::from_kg(70.0);
    let height = Length::from_cm(175.0);
    let bmi = weight.kg() / (height.meters() * height.meters());
    
    assert((bmi - 22.86).abs() < 0.01);
}

#[test]
@reproducible
fn test_map_calculation() {
    let bp = BloodPressure {
        systolic: Pressure::from_mmhg(120.0),
        diastolic: Pressure::from_mmhg(80.0)
    };
    
    let map = bp.map();
    assert((map.mmhg() - 93.33).abs() < 0.1);
}

#[test]
@reproducible
fn test_temperature_conversion() {
    let temp = Temperature::from_celsius(37.0);
    assert((temp.fahrenheit() - 98.6).abs() < 0.1);
}
