// Orbital Mechanics - Kepler, Two-body problem
@module("space::orbital_mechanics")
@export

open data Orbit {
    semi_major_axis: f64,  // meters
    eccentricity: f64,
    inclination: f64,      // radians
}

impl Orbit {
    fn orbital_period(&self, central_mass: f64) -> f64 {
        let mu = 6.674e-11 * central_mass;  // G * M
        let a = self.semi_major_axis;
        2.0 * 3.14159 * (a.powi(3) / mu).sqrt()
    }
}
