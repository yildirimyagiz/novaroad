/// Main microbial CO2 conversion function
open fn microbial_co2_to_alkenes(co2_input: f64, conditions: ProcessConditions) -> MicrobialConversionResult {
    let microbial_system = MicrobialCO2Conversion::new();
    microbial_system.convert_co2_to_alkenes(co2_input, conditions.light_intensity, conditions.temperature)
}

/// Strain optimization function
open fn optimize_for_target_compound(target: &str, current_yield: f64) -> StrainOptimizationResult {
    let microbial_system = MicrobialCO2Conversion::new();
    microbial_system.optimize_microbial_strain(target, current_yield)
}

/// Demonstration function
open fn demonstrate_microbial_co2_conversion() {
    println("🦠🧬⚗️ NOVA MICROBIAL CO2 CONVERSION DEMO");
    println("=======================================");

    let conditions = ProcessConditions {
        temperature: 30.0,
        light_intensity: 200.0,
        ph: 7.2,
        oxygen_level: 0.1,
    };

    let result = microbial_co2_to_alkenes(1000.0, conditions.clone());

    println("🎯 CO2 Input: 1000 kg");
    println("📊 Total Yield: {:.1f} kg alkenes", result.total_yield);
    println("⚡ Conversion Efficiency: {:.1f}%", result.conversion_efficiency * 100.0);
    println("🔋 Energy Return Ratio: {:.2f}", result.energy_balance.energy_return_ratio);
    println("🌱 Net CO2 Impact: {:.1f} kg", result.environmental_impact.net_co2_impact);

    println("");
    println("🧪 Produced Alkenes:");
    each entry in &result.alkenes_produced  { let (alkene, amount) = entry;
        println("  • {}: {:.1f} kg", alkene, amount);
    }

    println("");
    println("🎉 MICROBIAL CONVERSION: CO2 → Alkenes/Alkynes ACHIEVED!");
    println("   🦠 Engineered microbes can produce fuels from CO2!");
}
