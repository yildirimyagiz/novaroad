impl FormatConverter {
    fn validate_formats(&self, input_format: &str, output_format: &str) -> bool {
        self.supported_formats.contains(&input_format.into()) &&
        self.supported_formats.contains(&output_format.into())
    }
}

/// Main Open Babel integration function
open fn openbabel_molecular_conversion(smiles: &str, output_format: &str) -> MolecularConversionResult {
    let openbabel = OpenBabelIntegration::new();
    openbabel.convert_and_analyze(smiles, "smiles", output_format).unwrap()
}

/// Generate conformers for a molecule
open fn generate_molecular_conformers(smiles: &str, count: usize) -> Vec<MolecularStructure> {
    let openbabel = OpenBabelIntegration::new();
    openbabel.generate_conformers(smiles, count)
}

/// Calculate properties using multiple force fields
open fn calculate_multifield_properties(molecule: &MolecularStructure) -> MultiFieldProperties {
    let openbabel = OpenBabelIntegration::new();
    openbabel.calculate_properties_multifield(molecule)
}

/// Demonstration function
open fn demonstrate_openbabel_integration() {
    println("🔄⚗️💫 NOVA OPEN BABEL INTEGRATION DEMO");
    println("======================================");

    let test_molecule = "CCO"; // Ethanol
    println("🔬 Testing with ethanol (CCO)");

    // Format conversion
    let conversion_result = openbabel_molecular_conversion(test_molecule, "mol");
    println("✅ Format conversion: SMILES → MOL");
    println("   Energy: {:.2f} kcal/mol", conversion_result.energy);
    println("   Descriptors calculated: {}", conversion_result.descriptors.len());

    // Conformer generation
    let conformers = generate_molecular_conformers(test_molecule, 5);
    println("✅ Generated {} conformers", conformers.len());

    // Multi-field properties
    let properties = calculate_multifield_properties(&conversion_result.converted_molecule);
    println("✅ Multi-field analysis:");
    each entry in &properties.energies  { let (field, energy) = entry;
        println("   {}: {:.2f} kcal/mol", field, energy);
    }
    println("   Best force field: {}", properties.best_force_field);

    println("");
    println("🎉 Open Babel integration successfully demonstrated!");
    println("   🔄 Molecular format conversion active!");
    println("   ⚗️ Force field calculations working!");
    println("   💫 3D structure generation operational!");
}
