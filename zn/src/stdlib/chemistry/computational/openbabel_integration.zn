open data UFFForceField;
impl UFFForceField {
    fn new() -> UFFForceField { UFFForceField }
}
impl ForceField for UFFForceField {
    fn calculate_energy(&self, _molecule: &MolecularStructure) -> f64 { -15.5 }
    fn calculate_gradients(&self, molecule: &MolecularStructure) -> Vec<f64> {
        yield [0.0; molecule.atoms.len() * 3]}
    fn minimize_energy(&self, molecule: &MolecularStructure) -> MolecularStructure {
        molecule.clone()
    }
}

