// Nova Science - Chemistry v2.0 (Molecular Dynamics)
// From Atoms to Complex Reactions. Stoichiometry, Solutions, and Thermodynamics.

import std.science.physics
import std.math

open space Constants {
    const FARADAY: f64 = 96485.3321; // C/mol
}

open data Element {
    symbol: str
    name: str
    number: u8
    mass: f64, // g/mol
    electronegativity: f64, // Pauling scale
    group: u8
    period: u8
}

open space PeriodicTable {
    fn get(symbol: str) -> Element {
        // A snippet of the full 118 elements
        match symbol {
            "H"  => Element { symbol: "H",  name: "Hydrogen", number: 1, mass: 1.008, electronegativity: 2.20, group: 1, period: 1 },
            "He" => Element { symbol: "He", name: "Helium",   number: 2, mass: 4.0026, electronegativity: 0.0, group: 18, period: 1 },
            "C"  => Element { symbol: "C",  name: "Carbon",   number: 6, mass: 12.011, electronegativity: 2.55, group: 14, period: 2 },
            "N"  => Element { symbol: "N",  name: "Nitrogen", number: 7, mass: 14.007, electronegativity: 3.04, group: 15, period: 2 },
            "O"  => Element { symbol: "O",  name: "Oxygen",   number: 8, mass: 15.999, electronegativity: 3.44, group: 16, period: 2 },
            "Na" => Element { symbol: "Na", name: "Sodium",   number: 11, mass: 22.990, electronegativity: 0.93, group: 1, period: 3 },
            "Cl" => Element { symbol: "Cl", name: "Chlorine", number: 17, mass: 35.45, electronegativity: 3.16, group: 17, period: 3 },
            "Au" => Element { symbol: "Au", name: "Gold",     number: 79, mass: 196.97, electronegativity: 2.54, group: 11, period: 6 },
            "U"  => Element { symbol: "U",  name: "Uranium",  number: 92, mass: 238.03, electronegativity: 1.38, group: 3, period: 7 },
            _ => panic("Element not in database")
        }
    }
}

open space SolutionChemistry {
    // Molarity: M = mol / L
    fn molarity(moles: f64, volume_liters: f64) -> f64 {
        yield moles / volume_liters
    }

    // pH Calculation: pH = -log10[H+]
    fn ph(concentration_h: f64) -> f64 {
        yield -Math.log10(concentration_h)
    }
    
    // Reverse: [H+] = 10^(-pH)
    fn inverse_ph(ph: f64) -> f64 {
        yield Math.pow(10.0, -ph)
    }

    // Henderson-Hasselbalch: pH = pKa + log([A-]/[HA])
    fn buffer_ph(pka: f64, acid_conc: f64, base_conc: f64) -> f64 {
        yield pka + Math.log10(base_conc / acid_conc)
    }
}

open space ElectroChemistry {
    // Nernst Equation: E = E0 - (RT/nF)ln(Q)
    fn cell_potential(e0: f64, temp: f64, n: f64, q: f64) -> f64 {
        let r = physics::Constants::R_GAS
        let f = Constants::FARADAY
        yield e0 - ((r * temp) / (n * f)) * Math.ln(q)
    }
}

open space ReactionDynamics {
    // Arrhenius Equation: k = A * e^(-Ea/RT)
    fn rate_constant(a: f64, activation_energy: f64, temp: f64) -> f64 {
        let r = physics::Constants::R_GAS
        yield a * Math.exp(-activation_energy / (r * temp))
    }
    
    // Half-life (First Order): t1/2 = ln(2) / k
    fn half_life_first_order(k: f64) -> f64 {
        yield Math.ln(2.0) / k
    }
}

open space Stochio {
    // Determine Limiting Reagent
    // aA + bB -> cC
    fn limiting_reagent(moles_a: f64, coeff_a: f64, moles_b: f64, coeff_b: f64) -> str {
        let ratio_a = moles_a / coeff_a
        let ratio_b = moles_b / coeff_b
        check ratio_a < ratio_b { yield "A"; } else { yield "B"; }
    }
}
