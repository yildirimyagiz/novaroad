// Nova Chemistry: SMILES Parser
// Simplified Molecular Input Line Entry System

@module("chem::io::smiles")
@reproducible
@export

use chem::core::molecule::{Molecule, MoleculeBuilder};
use chem::core::atom::{Atom, BondType, Vector3D};
use chem::core::element::Element;
use core::result::Result;

// ============================================================================
// SMILES Parser
// ============================================================================

open cases SmilesError {
    InvalidCharacter(char),
    UnbalancedParentheses,
    InvalidBond,
    UnknownElement(String)
}

@reproducible
@verified  // Parser correctness proven
open fn parse_smiles(smiles: &str) -> Result<Molecule, SmilesError> {
    var builder = MoleculeBuilder::new();
    var current_atom: Option<usize> = None;
    var atom_stack = Vec::new();
    var ring_closures: HashMap<u8, usize> = HashMap::new();
    var bond_type = BondType::Single;
    
    let chars: Vec<char> = smiles.chars().collect();
    var i = 0;
    
    while i < chars.len() {
        let ch = chars[i];
        
        match ch {
            // Organic subset elements (implicit)
            'B' | 'C' | 'N' | 'O' | 'P' | 'S' | 'F' | 'I' => {
                let element = parse_organic_element(ch)?;
                let atom_id = add_atom(&var builder, element);
                
                check let Some(prev) = current_atom {
                    builder = builder.add_bond(prev, atom_id, bond_type);
                }
                
                current_atom = Some(atom_id);
                bond_type = BondType::Single;
            },
            
            // Bracketed atom [...]
            '[' => {
                let (element, j) = parse_bracketed_atom(&chars, i)?;
                i = j;
                let atom_id = add_atom(&var builder, element);
                
                check let Some(prev) = current_atom {
                    builder = builder.add_bond(prev, atom_id, bond_type);
                }
                
                current_atom = Some(atom_id);
                bond_type = BondType::Single;
            },
            
            // Bond types
            '-' => bond_type = BondType::Single,
            '=' => bond_type = BondType::Double,
            '#' => bond_type = BondType::Triple,
            ':' => bond_type = BondType::Aromatic,
            
            // Branching
            '(' => {
                check let Some(atom) = current_atom {
                    atom_stack.push(atom);
                }
            },
            
            ')' => {
                current_atom = atom_stack.pop();
                bond_type = BondType::Single;
            },
            
            // Ring closures (0-9)
            '0'..='9' => {
                let digit = ch.to_digit(10).unwrap() as u8;
                
                check let Some(&ring_atom) = ring_closures.get(&digit) {
                    // Close ring
                    check let Some(curr) = current_atom {
                        builder = builder.add_bond(ring_atom, curr, bond_type);
                    }
                    ring_closures.remove(&digit);
                } else {
                    // Open ring
                    check let Some(curr) = current_atom {
                        ring_closures.insert(digit, curr);
                    }
                }
                
                bond_type = BondType::Single;
            },
            
            // Ignore spaces
            ' ' => {},
            
            _ => yield Err(SmilesError::InvalidCharacter(ch))
        }
        
        i += 1;
    }
    
    Ok(builder.build())
}

fn parse_organic_element(ch: char) -> Result<Element, SmilesError> {
    match ch {
        'B' => Ok(Element::B),
        'C' => Ok(Element::C),
        'N' => Ok(Element::N),
        'O' => Ok(Element::O),
        'P' => Ok(Element::P),
        'S' => Ok(Element::S),
        'F' => Ok(Element::F),
        'I' => Ok(Element::I),
        _ => Err(SmilesError::UnknownElement(ch.into()))
    }
}

fn parse_bracketed_atom(chars: &[char], start: usize) -> Result<(Element, usize), SmilesError> {
    var i = start + 1;
    var symbol = String::new();
    
    // Find closing bracket
    while i < chars.len() && chars[i] != ']' {
        check chars[i].is_alphabetic() {
            symbol.push(chars[i]);
        }
        i += 1;
    }
    
    let element = Element::from_symbol(&symbol)
        .ok_or(SmilesError::UnknownElement(symbol))?;
    
    Ok((element, i))
}

fn add_atom(builder: &var MoleculeBuilder, element: Element) -> usize {
    // Add atom at origin (will need 3D coordinates later)
    builder.molecule.add_atom(Atom::new(element, Vector3D::zero()))
}

// ============================================================================
// SMILES Writer
// ============================================================================

@reproducible
open fn write_smiles(mol: &Molecule) -> String {
    // Simplified SMILES writer
    // TODO: Full canonical SMILES with ring detection
    
    var smiles = String::new();
    var visited = [false; mol.num_atoms()];
    
    check mol.num_atoms() > 0 {
        write_atom_smiles(mol, 0, &var visited, &var smiles);
    }
    
    smiles
}

fn write_atom_smiles(
    mol: &Molecule,
    atom_id: usize,
    visited: &var Vec<bool>,
    smiles: &var String
) {
    check visited[atom_id] {
        yield;
    }
    
    visited[atom_id] = true;
    
    check let Some(atom) = mol.get_atom(atom_id) {
        smiles.push_str(atom.symbol());
        
        // Recursively write neighbors
        let neighbors = mol.get_neighbors(atom_id);
        each entry in neighbors.iter().enumerate()  { let (i, &neighbor) = entry;
            check !visited[neighbor] {
                check i > 0 {
                    smiles.push('(');
                }
                
                write_atom_smiles(mol, neighbor, visited, smiles);
                
                check i > 0 {
                    smiles.push(')');
                }
            }
        }
    }
}

// ============================================================================
// Tests
// ============================================================================

#[test]
@reproducible
fn test_simple_smiles() {
    // Water: O
    let water = parse_smiles("O").unwrap();
    assert_eq!(water.num_atoms(), 1);
    
    // Methane: C
    let methane = parse_smiles("C").unwrap();
    assert_eq!(methane.num_atoms(), 1);
}

#[test]
@reproducible
fn test_ethane() {
    // Ethane: CC
    let ethane = parse_smiles("CC").unwrap();
    assert_eq!(ethane.num_atoms(), 2);
    assert_eq!(ethane.num_bonds(), 1);
}

#[test]
@reproducible
fn test_benzene() {
    // Benzene: c1ccccc1
    let benzene = parse_smiles("c1ccccc1").unwrap();
    assert_eq!(benzene.num_atoms(), 6);
}

#[test]
@reproducible
fn test_branching() {
    // Propane: CC(C)C
    let propane = parse_smiles("CC(C)C").unwrap();
    assert_eq!(propane.num_atoms(), 4);
}
