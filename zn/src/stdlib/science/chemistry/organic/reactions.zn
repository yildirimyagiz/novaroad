// Nova Chemistry - Organic Chemistry
// Carbon-based molecules, reactions, and synthesis pathways

data OrganicMolecule {
    atoms: list<Atom>
    bonds: list<Bond>
    functional_groups: list<FunctionalGroup>
    chirality: Chirality
}

cases FunctionalGroup {
    Alkane       // C-C single bonds
    Alkene       // C=C double
    Alkyne       // C≡C triple
    Alcohol      // -OH
    Aldehyde     // -CHO
    Ketone       // -CO-
    Carboxylic   // -COOH
    Amine        // -NH2
    Amide        // -CONH2
    Ester        // -COOR
    Ether        // R-O-R
    Aromatic     // Benzene ring
}

cases Chirality {
    Achiral
    R  // Rectus (right-handed)
    S  // Sinister (left-handed)
}

impl OrganicMolecule {
    // Determine hybridization state
    fn carbon_hybridization(self, carbon_idx: u32) -> str {
        let bonds_count = self.count_bonds(carbon_idx)
        
        match bonds_count {
            4 => "sp3"  // Tetrahedral
            3 => "sp2"  // Trigonal planar
            2 => "sp"   // Linear
            _ => "error"
        }
    }
    
    fn count_bonds(self, atom_idx: u32) -> u32 {
        var count = 0
        each bond in self.bonds {
            check bond.atom1 == atom_idx || bond.atom2 == atom_idx {
                count += match bond.bond_type {
                    BondType.Single => 1
                    BondType.Double => 2
                    BondType.Triple => 3
                }
            }
        }
        yield count
    }
}

// === ORGANIC REACTIONS ===

// SN2 Nucleophilic Substitution
open fn sn2_reaction(substrate: OrganicMolecule, nucleophile: str) -> OrganicMolecule {
    // Backside attack -> inversion of configuration
    var product = substrate.clone()
    
    // Invert chirality
    product.chirality = match substrate.chirality {
        Chirality.R => Chirality.S
        Chirality.S => Chirality.R
        _ => Chirality.Achiral
    }
    
    yield product
}

// E2 Elimination (Anti-periplanar)
open fn e2_elimination(substrate: OrganicMolecule, base: str) -> OrganicMolecule {
    // Remove H and leaving group -> form C=C
    var product = substrate.clone()
    product.functional_groups.push(FunctionalGroup.Alkene)
    yield product
}

// Diels-Alder Cycloaddition
open fn diels_alder(diene: OrganicMolecule, dienophile: OrganicMolecule) -> OrganicMolecule {
    // [4+2] cycloaddition
    OrganicMolecule {
        atoms: []
        bonds: []
        functional_groups: [FunctionalGroup.Aromatic]
        chirality: Chirality.Achiral
    }
}

// === SYNTHESIS PATHWAYS ===

// Grignard Reaction (C-C bond formation)
open fn grignard_synthesis(r_mgx: str, carbonyl: OrganicMolecule) -> OrganicMolecule {
    // R-MgX + C=O -> R-C-OH (alcohol)
    var product = carbonyl.clone()
    product.functional_groups.push(FunctionalGroup.Alcohol)
    yield product
}

// Retrosynthetic Analysis (simplified)
open fn retrosynthesis(target: OrganicMolecule) -> list<OrganicMolecule> {
    // Break down complex molecule into simpler precursors
    var precursors = []
    
    each fg in target.functional_groups {
        match fg {
            FunctionalGroup.Alcohol => {
                // Could come from Grignard or reduction
                precursors.push(OrganicMolecule {
                    atoms: []
                    bonds: []
                    functional_groups: [FunctionalGroup.Ketone]
                    chirality: Chirality.Achiral
                })
            }
            FunctionalGroup.Aromatic => {
                // Could come from Diels-Alder
                precursors.push(OrganicMolecule {
                    atoms: []
                    bonds: []
                    functional_groups: [FunctionalGroup.Alkene]
                    chirality: Chirality.Achiral
                })
            }
            _ => {}
        }
    }
    
    yield precursors
}
