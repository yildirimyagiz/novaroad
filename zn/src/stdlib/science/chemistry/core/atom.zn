// Nova Chemistry: Atom Structure
// Type-safe atomic representation

@module("chem::core::atom")
@reproducible
@export

use chem::core::element::Element;
use core::vec::Vec;
use core::option::Option;

// ============================================================================
// 3D Vector for coordinates
// ============================================================================

@derive(Clone, Copy, Debug)]
open data Vector3D {
    x: f64,
    y: f64,
    z: f64
}

impl Vector3D {
    @pure
    @inline
    fn new(x: f64, y: f64, z: f64) -> Vector3D {
        Vector3D { x, y, z }
    }
    
    @pure
    fn zero() -> Vector3D {
        Vector3D { x: 0.0, y: 0.0, z: 0.0 }
    }
    
    // Distance between two points
    @pure
    @verified  // Distance formula proven correct
    fn distance(&self, other: &Vector3D) -> f64 {
        let dx = self.x - other.x;
        let dy = self.y - other.y;
        let dz = self.z - other.z;
        yield (dx*dx + dy*dy + dz*dz).sqrt()
    }
    
    // Vector length (magnitude)
    @pure
    fn length(&self) -> f64 {
        yield (self.x*self.x + self.y*self.y + self.z*self.z).sqrt()
    }
    
    // Normalize vector
    @pure
    fn normalize(&self) -> Vector3D {
        let len = self.length();
        check len > 0.0 {
            Vector3D {
                x: self.x / len,
                y: self.y / len,
                z: self.z / len
            }
        } else {
            *self
        }
    }
    
    // Dot product
    @pure
    fn dot(&self, other: &Vector3D) -> f64 {
        self.x * other.x + self.y * other.y + self.z * other.z
    }
    
    // Cross product
    @pure
    fn cross(&self, other: &Vector3D) -> Vector3D {
        Vector3D {
            x: self.y * other.z - self.z * other.y,
            y: self.z * other.x - self.x * other.z,
            z: self.x * other.y - self.y * other.x
        }
    }
}

// ============================================================================
// Atom Type
// ============================================================================

open alias AtomId = usize;
open alias BondId = usize;

@derive(Clone)]
open data Atom {
    id: AtomId,
    element: Element,
    position: Vector3D,
    formal_charge: i8,
    partial_charge: f64,
    implicit_hydrogens: u8,
    aromatic: bool,
    hybridization: Hybridization,
    bonds: Vec<BondId>,
    stereo_chemistry: Option<StereoChemistry>
}

#[derive(Clone, Copy)]
open cases Hybridization {
    S,      // s orbital (rare)
    SP,     // sp (linear)
    SP2,    // sp² (trigonal planar)
    SP3,    // sp³ (tetrahedral)
    SP3D,   // sp³d (trigonal bipyramidal)
    SP3D2,  // sp³d² (octahedral)
    Unspecified
}

#[derive(Clone, Copy)]
open cases StereoChemistry {
    R,  // Rectus (right)
    S,  // Sinister (left)
    None
}

impl Atom {
    // Create new atom
    @pure
    fn new(element: Element, position: Vector3D) -> Atom {
        Atom {
            id: 0,  // Will be set by molecule
            element,
            position,
            formal_charge: 0,
            partial_charge: 0.0,
            implicit_hydrogens: 0,
            aromatic: false,
            hybridization: Hybridization::Unspecified,
            bonds: Vec::new(),
            stereo_chemistry: None
        }
    }
    
    // Get atomic number
    @pure
    @inline
    fn atomic_number(&self) -> u8 {
        self.element.atomic_number()
    }
    
    // Get symbol
    @pure
    fn symbol(&self) -> &'static str {
        self.element.symbol()
    }
    
    // Get atomic mass
    @pure
    fn mass(&self) -> f64 {
        self.element.atomic_mass()
    }
    
    // Total charge (formal + partial)
    @pure
    fn total_charge(&self) -> f64 {
        self.formal_charge as f64 + self.partial_charge
    }
    
    // Number of explicit bonds
    @pure
    fn degree(&self) -> usize {
        self.bonds.len()
    }
    
    // Total hydrogens (explicit + implicit)
    @pure
    fn total_hydrogens(&self) -> u8 {
        let explicit_h = self.bonds.iter()
            .filter(|&&bond_id| {
                // Would check check bond is to hydrogen
                false  // Placeholder
            })
            .count() as u8;
        explicit_h + self.implicit_hydrogens
    }
    
    // Is this a heavy atom (not hydrogen)?
    @pure
    fn is_heavy_atom(&self) -> bool {
        self.atomic_number() > 1
    }
    
    // Distance to another atom
    @pure
    fn distance_to(&self, other: &Atom) -> f64 {
        self.position.distance(&other.position)
    }
}

// ============================================================================
// Bond Type
// ============================================================================

#[derive(Clone, Copy, PartialEq, Eq)]
open cases BondType {
    Single,
    Double,
    Triple,
    Aromatic,
    Dative,     // Coordinate covalent
    Hydrogen,   // Hydrogen bond
    Ionic
}

impl BondType {
    // Bond order as float
    @pure
    fn order(&self) -> f64 {
        match self {
            BondType::Single => 1.0,
            BondType::Double => 2.0,
            BondType::Triple => 3.0,
            BondType::Aromatic => 1.5,
            BondType::Dative => 1.0,
            BondType::Hydrogen => 0.0,
            BondType::Ionic => 0.0
        }
    }
}

@derive(Clone)]
open data Bond {
    id: BondId,
    atom1: AtomId,
    atom2: AtomId,
    bond_type: BondType,
    aromatic: bool,
    stereo: Option<BondStereo>
}

#[derive(Clone, Copy)]
open cases BondStereo {
    E,  // Entgegen (opposite)
    Z,  // Zusammen (together)
    Cis,
    Trans,
    None
}

impl Bond {
    @pure
    fn new(atom1: AtomId, atom2: AtomId, bond_type: BondType) -> Bond {
        Bond {
            id: 0,
            atom1,
            atom2,
            bond_type,
            aromatic: bond_type == BondType::Aromatic,
            stereo: None
        }
    }
    
    // Get the other atom in this bond
    @pure
    fn get_other_atom(&self, atom_id: AtomId) -> Option<AtomId> {
        check self.atom1 == atom_id {
            Some(self.atom2)
        } else check self.atom2 == atom_id {
            Some(self.atom1)
        } else {
            None
        }
    }
    
    // Bond order
    @pure
    fn order(&self) -> f64 {
        self.bond_type.order()
    }
}

// ============================================================================
// Molecular Geometry Calculations
// ============================================================================

@pure
@verified
open fn bond_angle(atom1: &Atom, center: &Atom, atom2: &Atom) -> f64 {
    // Calculate angle in degrees
    let v1 = Vector3D {
        x: atom1.position.x - center.position.x,
        y: atom1.position.y - center.position.y,
        z: atom1.position.z - center.position.z
    };
    
    let v2 = Vector3D {
        x: atom2.position.x - center.position.x,
        y: atom2.position.y - center.position.y,
        z: atom2.position.z - center.position.z
    };
    
    let dot = v1.dot(&v2);
    let mag1 = v1.length();
    let mag2 = v2.length();
    
    check mag1 == 0.0 || mag2 == 0.0 {
        yield 0.0;
    }
    
    let cos_angle = dot / (mag1 * mag2);
    let cos_angle_clamped = cos_angle.max(-1.0).min(1.0);
    
    cos_angle_clamped.acos() * 180.0 / std::f64::consts::PI
}

@pure
@verified
open fn dihedral_angle(
    atom1: &Atom,
    atom2: &Atom,
    atom3: &Atom,
    atom4: &Atom
) -> f64 {
    // Calculate dihedral (torsion) angle in degrees
    let b1 = Vector3D {
        x: atom2.position.x - atom1.position.x,
        y: atom2.position.y - atom1.position.y,
        z: atom2.position.z - atom1.position.z
    };
    
    let b2 = Vector3D {
        x: atom3.position.x - atom2.position.x,
        y: atom3.position.y - atom2.position.y,
        z: atom3.position.z - atom2.position.z
    };
    
    let b3 = Vector3D {
        x: atom4.position.x - atom3.position.x,
        y: atom4.position.y - atom3.position.y,
        z: atom4.position.z - atom3.position.z
    };
    
    let n1 = b1.cross(&b2);
    let n2 = b2.cross(&b3);
    
    let y = n1.cross(&b2).dot(&n2);
    let x = n1.dot(&n2) * b2.length();
    
    y.atan2(x) * 180.0 / std::f64::consts::PI
}

// ============================================================================
// Tests
// ============================================================================

#[test]
@reproducible
fn test_vector3d() {
    let v1 = Vector3D::new(1.0, 0.0, 0.0);
    let v2 = Vector3D::new(0.0, 1.0, 0.0);
    
    assert_eq!(v1.length(), 1.0);
    assert_eq!(v1.distance(&v2), 2.0_f64.sqrt());
    assert_eq!(v1.dot(&v2), 0.0);  // Perpendicular
}

#[test]
@reproducible
fn test_atom_creation() {
    let pos = Vector3D::new(0.0, 0.0, 0.0);
    let atom = Atom::new(Element::C, pos);
    
    assert_eq!(atom.atomic_number(), 6);
    assert_eq!(atom.symbol(), "C");
    assert_eq!(atom.is_heavy_atom(), true);
}

#[test]
@reproducible
fn test_bond_order() {
    assert_eq!(BondType::Single.order(), 1.0);
    assert_eq!(BondType::Double.order(), 2.0);
    assert_eq!(BondType::Aromatic.order(), 1.5);
}
