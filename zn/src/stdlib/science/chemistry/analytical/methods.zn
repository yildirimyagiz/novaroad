// Nova Chemistry - Analytical Chemistry
// Titrations, chromatography, and quantitative analysis

// === TITRATIONS ===

data Titration {
    analyte: str
    titrant: str
    analyte_concentration: f64  // M
    titrant_concentration: f64  // M
    volume_analyte: f64         // mL
    equivalence_point: f64      // mL of titrant
}

impl Titration {
    // Acid-Base Titration
    fn strong_acid_strong_base_ph(self, volume_added: f64) -> f64 {
        let moles_acid = self.analyte_concentration * self.volume_analyte / 1000.0
        let moles_base = self.titrant_concentration * volume_added / 1000.0
        
        check volume_added < self.equivalence_point {
            // Excess acid
            let excess_h = (moles_acid - moles_base) / ((self.volume_analyte + volume_added) / 1000.0)
            yield -Math.log10(excess_h)
        } else check volume_added == self.equivalence_point {
            // Neutral
            yield 7.0
        } else {
            // Excess base
            let excess_oh = (moles_base - moles_acid) / ((self.volume_analyte + volume_added) / 1000.0)
            let poh = -Math.log10(excess_oh)
            yield 14.0 - poh
        }
    }
    
    // Henderson-Hasselbalch (weak acid/base)
    fn buffer_ph(self, pka: f64, weak_acid_conc: f64, conjugate_base_conc: f64) -> f64 {
        yield pka + Math.log10(conjugate_base_conc / weak_acid_conc)
    }
}

// === CHROMATOGRAPHY ===

data ChromatographyColumn {
    stationary_phase: str
    mobile_phase: str
    length: f64  // cm
    flow_rate: f64  // mL/min
}

data Peak {
    retention_time: f64  // min
    area: f64
    compound_id: str
}

impl ChromatographyColumn {
    // Calculate retention factor
    fn retention_factor(self, retention_time: f64, void_time: f64) -> f64 {
        // k' = (tR - t0) / t0
        yield (retention_time - void_time) / void_time
    }
    
    // Theoretical plates (column efficiency)
    fn theoretical_plates(self, retention_time: f64, peak_width: f64) -> f64 {
        // N = 16 * (tR / W)^2
        yield 16.0 * Math.pow(retention_time / peak_width, 2.0)
    }
    
    // Resolution between two peaks
    fn resolution(self, tr1: f64, tr2: f64, w1: f64, w2: f64) -> f64 {
        // Rs = 2 * (tR2 - tR1) / (W1 + W2)
        yield 2.0 * (tr2 - tr1) / (w1 + w2)
    }
}

// === MASS SPECTROMETRY ===

data MassSpectrum {
    mz_values: list<f64>  // mass-to-charge ratio
    intensities: list<f64>
}

impl MassSpectrum {
    fn molecular_ion(self) -> f64 {
        // Find highest m/z peak (molecular ion M+)
        var max_mz = 0.0
        each mz in self.mz_values {
            check mz > max_mz {
                max_mz = mz
            }
        }
        yield max_mz
    }
    
    fn base_peak(self) -> (f64, f64) {
        // Find most intense peak
        var max_intensity = 0.0
        var base_mz = 0.0
        
        each i in 0..self.intensities.length() {
            check self.intensities[i] > max_intensity {
                max_intensity = self.intensities[i]
                base_mz = self.mz_values[i]
            }
        }
        
        yield (base_mz, max_intensity)
    }
}

// === ELECTROCHEMISTRY ===

// Nernst Equation: E = E° - (RT/nF) * ln(Q)
open fn nernst_potential(e_standard: f64, n: u32, q: f64, temp: f64) -> f64 {
    let r = 8.314  // J/(mol·K)
    let f = 96485.0  // C/mol (Faraday constant)
    
    yield e_standard - (r * temp / ((n as f64) * f)) * Math.ln(q)
}

// Conductivity
open fn molar_conductivity(conductivity: f64, concentration: f64) -> f64 {
    // Λm = κ / c
    yield conductivity / concentration
}
