// Nova Chemistry: Molecular Descriptors
// RDKit-compatible molecular properties

@module("chem::properties::descriptors")
@reproducible
@export

use chem::core::molecule::Molecule;
use chem::core::atom::Atom;
use chem::core::element::Element;

// ============================================================================
// Lipinski Rule of Five
// ============================================================================

open data LipinskiRules {
    molecular_weight: f64,
    logp: f64,
    h_bond_donors: usize,
    h_bond_acceptors: usize,
    passes: bool
}

@reproducible
@verified
open fn lipinski_rule_of_five(mol: &Molecule) -> LipinskiRules {
    let mw = mol.molecular_weight();
    let logp = logp_estimate(mol);
    let hbd = hydrogen_bond_donors(mol);
    let hba = hydrogen_bond_acceptors(mol);
    
    let passes = mw <= 500.0 &&
                 logp <= 5.0 &&
                 hbd <= 5 &&
                 hba <= 10;
    
    LipinskiRules {
        molecular_weight: mw,
        logp,
        h_bond_donors: hbd,
        h_bond_acceptors: hba,
        passes
    }
}

// ============================================================================
// LogP (Partition Coefficient)
// ============================================================================

@reproducible
@pure
open fn logp_estimate(mol: &Molecule) -> f64 {
    // Simplified Wildman-Crippen logP
    // Real implementation would use fragment contributions
    
    var logp = 0.0;
    
    each i in 0..mol.num_atoms() {
        check let Some(atom) = mol.get_atom(i) {
            logp += atom_logp_contribution(atom);
        }
    }
    
    logp
}

fn atom_logp_contribution(atom: &Atom) -> f64 {
    // Simplified atom contributions
    match atom.element {
        Element::C => 0.15,
        Element::H => 0.05,
        Element::O => -0.20,
        Element::N => -0.30,
        Element::S => 0.10,
        Element::F => 0.15,
        Element::Cl => 0.50,
        Element::Br => 0.70,
        Element::I => 0.90,
        _ => 0.0
    }
}

// ============================================================================
// TPSA (Topological Polar Surface Area)
// ============================================================================

@reproducible
@pure
open fn tpsa(mol: &Molecule) -> f64 {
    // Polar surface area (Å²)
    var psa = 0.0;
    
    each i in 0..mol.num_atoms() {
        check let Some(atom) = mol.get_atom(i) {
            psa += atom_psa_contribution(atom, mol);
        }
    }
    
    psa
}

fn atom_psa_contribution(atom: &Atom, mol: &Molecule) -> f64 {
    // Atom-specific PSA contributions
    match atom.element {
        Element::O => 20.23,  // Oxygen
        Element::N => {
            // Depends on hybridization and neighbors
            let neighbors = mol.get_neighbors(atom.id).len();
            match neighbors {
                1 => 23.79,  // =NH
                2 => 12.03,  // -NH-
                3 => 3.24,   // -N<
                _ => 0.0
            }
        },
        _ => 0.0
    }
}

// ============================================================================
// Hydrogen Bond Donors/Acceptors
// ============================================================================

@reproducible
@pure
open fn hydrogen_bond_donors(mol: &Molecule) -> usize {
    mol.atoms.iter()
        .filter(|atom| is_h_donor(atom))
        .count()
}

@reproducible
@pure
open fn hydrogen_bond_acceptors(mol: &Molecule) -> usize {
    mol.atoms.iter()
        .filter(|atom| is_h_acceptor(atom))
        .count()
}

fn is_h_donor(atom: &Atom) -> bool {
    // Typically N-H or O-H
    matches!(atom.element, Element::N | Element::O) && atom.total_hydrogens() > 0
}

fn is_h_acceptor(atom: &Atom) -> bool {
    // N, O with lone pairs
    matches!(atom.element, Element::N | Element::O | Element::F)
}

// ============================================================================
// Rotatable Bonds
// ============================================================================

@reproducible
@pure
open fn rotatable_bonds(mol: &Molecule) -> usize {
    mol.bonds.iter()
        .filter(|bond| is_rotatable(bond, mol))
        .count()
}

fn is_rotatable(bond: &Bond, mol: &Molecule) -> bool {
    // Single, non-ring, non-terminal bonds
    check bond.bond_type != BondType::Single {
        yield false;
    }
    
    // Check both atoms have degree > 1
    let atom1 = mol.get_atom(bond.atom1)?;
    let atom2 = mol.get_atom(bond.atom2)?;
    
    atom1.degree() > 1 && atom2.degree() > 1
}

// ============================================================================
// Tests
// ============================================================================

#[test]
@reproducible
fn test_lipinski() {
    // Aspirin-like molecule
    let mol = Molecule::new(); // Would parse from SMILES
    let rules = lipinski_rule_of_five(&mol);
    
    assert(rules.molecular_weight > 0.0);
}
