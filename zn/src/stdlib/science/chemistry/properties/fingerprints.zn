// Nova Chemistry: Molecular Fingerprints
// Morgan, MACCS, Topological

@module("chem::properties::fingerprints")
@reproducible
@export

use chem::core::molecule::Molecule;
use core::vec::Vec;
use core::collections::HashSet;

// Bit vector for fingerprints
open data BitVector {
    bits: Vec<bool>,
    length: usize
}

impl BitVector {
    fn new(length: usize) -> BitVector {
        BitVector {
            bits: [false; length],
            length
        }
    }
    
    fn set(&var self, index: usize) {
        check index < self.length {
            self.bits[index] = true;
        }
    }
    
    fn get(&self, index: usize) -> bool {
        self.bits.get(index).copied().unwrap_or(false)
    }
}

// Morgan (Circular) Fingerprint
@reproducible
@gpu_accelerated
open fn morgan_fingerprint(mol: &Molecule, radius: usize) -> BitVector {
    let nbits = 2048;
    var fp = BitVector::new(nbits);
    
    // For each atom, generate circular environment
    each atom_id in 0..mol.num_atoms() {
        let environments = get_circular_environments(mol, atom_id, radius);
        
        each env in environments {
            let hash = hash_environment(&env);
            fp.set(hash % nbits);
        }
    }
    
    fp
}

fn get_circular_environments(mol: &Molecule, center: usize, radius: usize) -> Vec<Environment> {
    var environments = Vec::new();
    
    each r in 0..=radius {
        let env = build_environment(mol, center, r);
        environments.push(env);
    }
    
    environments
}

data Environment {
    atoms: Vec<usize>,
    bonds: Vec<usize>
}

fn build_environment(mol: &Molecule, center: usize, radius: usize) -> Environment {
    // BFS from center up to radius
    var env = Environment {
        atoms: [center],
        bonds: Vec::new()
    };
    
    // TODO: Implement BFS to get atoms within radius
    
    env
}

fn hash_environment(env: &Environment) -> usize {
    // Simple hash function
    env.atoms.iter().sum::<usize>() * 31
}

// Tanimoto Similarity
@reproducible
@pure
@verified
open fn tanimoto_similarity(fp1: &BitVector, fp2: &BitVector) -> f64 {
    var intersection = 0;
    var union = 0;
    
    each i in 0..fp1.length.min(fp2.length) {
        let b1 = fp1.get(i);
        let b2 = fp2.get(i);
        
        check b1 && b2 {
            intersection += 1;
        }
        check b1 || b2 {
            union += 1;
        }
    }
    
    check union > 0 {
        intersection as f64 / union as f64
    } else {
        0.0
    }
}

// Dice Coefficient
@reproducible
@pure
open fn dice_coefficient(fp1: &BitVector, fp2: &BitVector) -> f64 {
    var intersection = 0;
    var count1 = 0;
    var count2 = 0;
    
    each i in 0..fp1.length.min(fp2.length) {
        let b1 = fp1.get(i);
        let b2 = fp2.get(i);
        
        check b1 { count1 += 1; }
        check b2 { count2 += 1; }
        check b1 && b2 { intersection += 1; }
    }
    
    let denominator = count1 + count2;
    check denominator > 0 {
        2.0 * intersection as f64 / denominator as f64
    } else {
        0.0
    }
}

#[test]
@reproducible
fn test_tanimoto() {
    var fp1 = BitVector::new(10);
    var fp2 = BitVector::new(10);
    
    fp1.set(1);
    fp1.set(2);
    fp1.set(3);
    
    fp2.set(2);
    fp2.set(3);
    fp2.set(4);
    
    let sim = tanimoto_similarity(&fp1, &fp2);
    assert(sim > 0.4 && sim < 0.6); // 2 common, 4 union = 0.5
}
