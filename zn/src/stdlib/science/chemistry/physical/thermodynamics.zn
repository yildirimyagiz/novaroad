// Nova Chemistry - Physical Chemistry
// Thermodynamics, kinetics, quantum chemistry, and spectroscopy

// === THERMODYNAMICS ===

open data ThermodynamicState {
    temperature: f64  // K
    pressure: f64     // atm
    volume: f64       // L
    enthalpy: f64     // kJ/mol
    entropy: f64      // J/(mol·K)
    gibbs: f64        // kJ/mol
}

impl ThermodynamicState {
    // Gibbs Free Energy: ΔG = ΔH - TΔS
    fn calculate_gibbs(var self) -> f64 {
        self.gibbs = self.enthalpy - (self.temperature * self.entropy / 1000.0)
        yield self.gibbs
    }
    
    // Spontaneity check
    fn is_spontaneous(self) -> bool {
        yield self.gibbs < 0.0
    }
    
    // Van't Hoff Equation: ln(K2/K1) = -ΔH/R * (1/T2 - 1/T1)
    fn equilibrium_constant_at_temp(self, k1: f64, t1: f64, t2: f64) -> f64 {
        let r = 8.314  // J/(mol·K)
        let delta_h = self.enthalpy * 1000.0  // Convert to J
        
        let ln_ratio = -(delta_h / r) * (1.0/t2 - 1.0/t1)
        let k2 = k1 * Math.exp(ln_ratio)
        
        yield k2
    }
}

// === CHEMICAL KINETICS ===

open data Reaction {
    rate_constant: f64  // k
    activation_energy: f64  // Ea (kJ/mol)
    reaction_order: u32
    frequency_factor: f64  // A (Arrhenius)
}

impl Reaction {
    // Arrhenius Equation: k = A * e^(-Ea/RT)
    fn rate_at_temperature(self, temp: f64) -> f64 {
        let r = 8.314  // J/(mol·K)
        let ea_joules = self.activation_energy * 1000.0
        
        yield self.frequency_factor * Math.exp(-ea_joules / (r * temp))
    }
    
    // Integrated Rate Laws
    fn concentration_after_time(self, c0: f64, time: f64, temp: f64) -> f64 {
        let k = self.rate_at_temperature(temp)
        
        match self.reaction_order {
            0 => c0 - k * time           // [A] = [A]0 - kt
            1 => c0 * Math.exp(-k * time)  // [A] = [A]0 * e^(-kt)
            2 => c0 / (1.0 + k * c0 * time)  // 1/[A] = 1/[A]0 + kt
            _ => c0
        }
    }
    
    // Half-life
    fn half_life(self, c0: f64, temp: f64) -> f64 {
        let k = self.rate_at_temperature(temp)
        
        match self.reaction_order {
            0 => c0 / (2.0 * k)
            1 => Math.ln(2.0) / k
            2 => 1.0 / (k * c0)
            _ => 0.0
        }
    }
}

// === QUANTUM CHEMISTRY ===

open data MolecularOrbital {
    energy: f64  // eV
    electrons: u32
    orbital_type: OrbitalType
}

cases OrbitalType {
    Bonding
    AntiBonding
    NonBonding
}

// Hückel Molecular Orbital Theory (π systems)
open fn huckel_energy_levels(num_carbons: u32) -> list<f64> {
    // For cyclic conjugated systems (benzene, etc.)
    let alpha = -11.4  // eV (base energy)
    let beta = -0.8    // eV (resonance integral)
    
    var energies = []
    
    each k in 0..num_carbons {
        let energy = alpha + 2.0 * beta * Math.cos(2.0 * Math.PI * (k as f64) / (num_carbons as f64))
        energies.push(energy)
    }
    
    yield energies
}

// === SPECTROSCOPY ===

open data Spectrum {
    wavelengths: list<f64>  // nm
    intensities: list<f64>
    spectrum_type: SpectroscopyType
}

cases SpectroscopyType {
    UV_Vis
    IR
    NMR
    Mass
}

impl Spectrum {
    // Beer-Lambert Law: A = ε * c * l
    fn absorbance(self, concentration: f64, path_length: f64, molar_absorptivity: f64) -> f64 {
        yield molar_absorptivity * concentration * path_length
    }
    
    // Peak finding
    fn find_peaks(self, threshold: f64) -> list<u32> {
        var peaks = []
        
        each i in 1..(self.intensities.length() - 1) {
            check self.intensities[i] > self.intensities[i-1] && 
               self.intensities[i] > self.intensities[i+1] &&
               self.intensities[i] > threshold {
                peaks.push(i)
            }
        }
        
        yield peaks
    }
}

// Molecular Vibrations (IR)
open fn ir_frequency(reduced_mass: f64, force_constant: f64) -> f64 {
    // ν = (1/2π) * sqrt(k/μ)
    let freq = (1.0 / (2.0 * Math.PI)) * Math.sqrt(force_constant / reduced_mass)
    
    // Convert to wavenumber (cm^-1)
    let c = 2.998e10  // cm/s
    yield freq / c
}
