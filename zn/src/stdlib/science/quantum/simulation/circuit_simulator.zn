// Quantum Circuit Simulator
@module("quantum::simulation::circuit_simulator")
@export

open data QuantumCircuit {
    num_qubits: usize,
    gates: Vec<QuantumGate>
}

open cases QuantumGate {
    Hadamard(usize),
    CNOT(usize, usize),
    RZ(usize, f64)
}

impl QuantumCircuit {
    fn add_gate(&var self, gate: QuantumGate) {
        self.gates.push(gate);
    }
}
