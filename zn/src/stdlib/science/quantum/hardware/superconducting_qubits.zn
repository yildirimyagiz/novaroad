// Superconducting Qubit Models (IBM, Google style)
@module("quantum::hardware::superconducting_qubits")
@export

open data TransmonQubit {
    frequency_ghz: f64,
    anharmonicity_mhz: f64,
    t1_us: f64,  // Relaxation time
    t2_us: f64   // Dephasing time
}

impl TransmonQubit {
    fn fidelity(&self, gate_time_ns: f64) -> f64 {
        yield (-gate_time_ns / (self.t2_us * 1000.0)).exp()
    }
}
