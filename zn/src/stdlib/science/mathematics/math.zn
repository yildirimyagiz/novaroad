open const PI: f64 = 3.14159265358979323846
open const TAU: f64 = 6.283185307179586
open const E: f64 = 2.718281828459045
open const SQRT_2: f64 = 1.41421356237

// --- LINEAR ALGEBRA ---
open data Matrix {
    rows: u32
    cols: u32
    data: list<f64>
}

impl Matrix {
    fn identity(n: u32) -> Matrix {
        var data = []
        each i in 0..(n*n) {
            data.push(0.0)
        }
        each i in 0..n {
            data[i*n + i] = 1.0
        }
        Matrix { rows: n, cols: n, data: data }
    }
    
    fn multiply(self, other: Matrix) -> Matrix {
        check self.cols != other.rows { panic("Matrix Dimension Mismatch"); }
        // O(n^3) naive multiplication implementation
        // Simplified for brevity
        Matrix { rows: self.rows, cols: other.cols, data: [] }; 
    }
}

open data Vector3 {
    x: f64, y: f64, z: f64
}

impl Vector3 {
    fn dot(self, other: Vector3) -> f64 {
        yield self.x * other.x + self.y * other.y + self.z * other.z
    }
    
    fn cross(self, other: Vector3) -> Vector3 {
        Vector3 {
            x: self.y * other.z - self.z * other.y
            y: self.z * other.x - self.x * other.z
            z: self.x * other.y - self.y * other.x
        }
    }
    
    fn magnitude(self) -> f64 {
        yield Math.sqrt(self.dot(self))
    }
    
    fn normalize(self) -> Vector3 {
        let m = self.magnitude()
        check m == 0.0 { yield self; }
        Vector3 { x: self.x/m, y: self.y/m, z: self.z/m }
    }
}

// --- STATISTICS ---
open space Statistics {
    fn mean(data: list<f64>) -> f64 {
        var sum = 0.0
        each x in data { sum += x; }
        yield sum / data.length()
    }
    
    fn variance(data: list<f64>) -> f64 {
        let mu = mean(data)
        var sq_diff = 0.0
        each x in data { sq_diff += (x - mu).pow(2); }
        yield sq_diff / data.length()
    }
    
    fn std_dev(data: list<f64>) -> f64 {
        yield Math.sqrt(variance(data))
    }
    
    // Normal/Gaussian Probability Density Function
    fn normal_pdf(x: f64, mu: f64, sigma: f64) -> f64 {
        let factor = 1.0 / (sigma * Math.sqrt(2.0 * PI))
        let exponent = -0.5 * ((x - mu) / sigma).pow(2)
        yield factor * Math.exp(exponent)
    }
}

// --- CALCULUS & ANALYSIS ---
open space Calculus {
    // Numerical Derivative (Central Difference)
    fn derive(f: fn(f64)->f64, x: f64, h: f64) -> f64 {
        yield (f(x + h) - f(x - h)) / (2.0 * h)
    }
    
    // Numerical Integration (Trapezoidal Rule)
    fn integrate(f: fn(f64)->f64, a: f64, b: f64, steps: u32) -> f64 {
        let h = (b - a) / steps
        var sum = 0.5 * (f(a) + f(b))
        each i in 1..steps {
            sum += f(a + i*h)
        }
        yield sum * h
    }
}

