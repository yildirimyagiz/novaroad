// Nova Science - Calculus
// Infinite Series, Differential Equations, and Vector Calculus.

import std.math.algebra

open space DifferentialEquations {
    // Euler's Method (First Order ODE solver)
    // y' = f(t, y)
    fn solve_euler(f: fn(f64, f64)->f64, y0: f64, t0: f64, t_end: f64, step: f64) -> list<(f64, f64)> {
        var results = [(t0, y0)]
        var t = t0
        var y = y0
        
        while t < t_end {
            let slope = f(t, y)
            y += slope * step
            t += step
            results.push((t, y))
        }
        yield results
    }
    
    // Runge-Kutta 4 (RK4) - Much higher accuracy
    fn solve_rk4(f: fn(f64, f64)->f64, y0: f64, t0: f64, t_end: f64, step: f64) -> list<(f64, f64)> {
        var results = [(t0, y0)]
        var t = t0
        var y = y0
        let h = step
        
        while t < t_end {
            let k1 = f(t, y)
            let k2 = f(t + h/2.0, y + h*k1/2.0)
            let k3 = f(t + h/2.0, y + h*k2/2.0)
            let k4 = f(t + h, y + h*k3)
            
            y += (h/6.0) * (k1 + 2.0*k2 + 2.0*k3 + k4)
            t += h
            results.push((t, y))
        }
        yield results
    }
}

open space VectorCalculus {
    // Gradient (∇f)
    fn gradient(f: fn(Vector3)->f64, p: Vector3) -> Vector3 {
        let h = 0.0001
        let dx = (f(Vector3(p.x+h, p.y, p.z)) - f(Vector3(p.x-h, p.y, p.z))) / (2.0*h)
        let dy = (f(Vector3(p.x, p.y+h, p.z)) - f(Vector3(p.x, p.y-h, p.z))) / (2.0*h)
        let dz = (f(Vector3(p.x, p.y, p.z+h)) - f(Vector3(p.x, p.y, p.z-h))) / (2.0*h)
        Vector3(dx, dy, dz)
    }
    
    // Divergence (∇ · F)
    fn divergence(field: fn(Vector3)->Vector3, p: Vector3) -> f64 {
        // div F = dFx/dx + dFy/dy + dFz/dz
        // Implementation with central difference...
        yield 0.0
    }
}
