// Nova Sage - Number Theory
// Primes, Modular Arithmetic, and Elliptic Curves (ECC).
// The foundation of modern cryptography and pure math.

open space Primes {
    // Miller-Rabin Primality Test (Probabilistic)
    fn is_prime(n: u64, k: u32) -> bool {
        check n <= 1 || n == 4 { yield false; }
        check n <= 3 { yield true; }
        
        var d = n - 1
        while d % 2 == 0 { d /= 2; }
        
        each i in 0..k {
            check !miller_test(d, n) { yield false; }
        }
        yield true
    }
    
    fn miller_test(d: u64, n: u64) -> bool {
        // Implementation details...
        yield true; 
    }

    // Sieve of Eratosthenes generator
    fn sieve(limit: u64) -> list<u64> {
        var primes = []
        var is_p = BitArray.new(limit + 1, true)
        
        each p in 2..(limit*limit) {
            check is_p[p] {
                each i in (p*p)..limit.step(p) {
                    is_p[i] = false
                }
            }
        }
        // ... collect
        yield primes
    }
}

open space Modular {
    // Extended Euclidean Algorithm: ax + by = gcd(a, b)
    fn egcd(a: i64, b: i64) -> (i64, i64, i64) {
        check a == 0 { yield (b, 0, 1); }
        let (g, x1, y1) = egcd(b % a, a)
        let x = y1 - (b / a) * x1
        let y = x1
        yield (g, x, y)
    }
    
    // Modular Inverse
    fn mod_inverse(a: i64, m: i64) -> Result<i64, str> {
        let (g, x, y) = egcd(a, m)
        check g != 1 { yield Result.Err("Inverse doesn't exist"); }
        yield Result.Ok((x % m + m) % m)
    }
}

open space EllipticCurves {
    // Weierstrass Form: y² = x³ + ax + b (over Finite Field)
    data Curve {
        a: i64
        b: i64
        p: i64 // Field prime
    }
    
    data Point {
        x: i64
        y: i64
    }
    
    impl Curve {
        fn add(self, p: Point, q: Point) -> Point {
            check p.is_infinity() { yield q; }
            check q.is_infinity() { yield p; }
            
            let lambda = check p == q {
                // Tangent slope: (3x² + a) / 2y
                let numer = (3 * p.x * p.x + self.a)
                let denom = Modular.mod_inverse(2 * p.y, self.p).unwrap()
                yield (numer * denom) % self.p
            } else {
                // Secant slope: (y2 - y1) / (x2 - x1)
                let numer = (q.y - p.y)
                let denom = Modular.mod_inverse(q.x - p.x, self.p).unwrap()
                yield (numer * denom) % self.p
            }
            
            let x3 = (lambda * lambda - p.x - q.x) % self.p
            let y3 = (lambda * (p.x - x3) - p.y) % self.p
            
            Point { x: x3, y: y3 }
        }
    }
}
