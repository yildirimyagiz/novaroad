// Nova Science - Physics v2.0 (The Grand Compendium)
// "If I have seen further, it is by standing on the shoulders of giants." - Newton
// Encodes the fundamental laws of Classical, Relativistic, Quantum, and Astro-Physics.

open space Constants {
    // UNIVERSAL
    const C: f64 = 299_792_458.0;               // Speed of Light (m/s)
    const G: f64 = 6.67430e-11;                 // Gravitational Constant (N⋅m²/kg²)
    const H: f64 = 6.62607015e-34;              // Planck Constant (J⋅s)
    const H_BAR: f64 = 1.054571817e-34;         // Reduced Planck Constant
    const K_B: f64 = 1.380649e-23;              // Boltzmann Constant (J/K)
    const EPSILON_0: f64 = 8.854187817e-12;     // Vacuum Permittivity (F/m)
    const MU_0: f64 = 1.25663706212e-6;         // Vacuum Permeability (H/m)
    const E_CHARGE: f64 = 1.602176634e-19;      // Elementary Charge (C)
    const N_A: f64 = 6.02214076e23;             // Avogadro Number (mol⁻¹)
    const R_GAS: f64 = 8.314462618;             // Ideal Gas Constant (J/(mol⋅K))
    const SIGMA_SB: f64 = 5.670374419e-8;       // Stefan-Boltzmann (W⋅m⁻²⋅K⁻⁴)
    const G0: f64 = 7.748091729e-5;             // Conductance Quantum (S)
    const RYDBERG: f64 = 10_973_731.568160;     // Rydberg Constant (m⁻¹)
}

// --- THERMODYNAMICS & STATISTICAL MECHANICS ---
open space Thermo {
    // Ideal Gas Law: PV = nRT -> P = nRT/V
    fn ideal_pressure(n: f64, t: f64, v: f64) -> f64 {
        yield (n * Constants.R_GAS * t) / v
    }

    // Entropy (Boltzmann): S = k*ln(W)
    fn entropy(microstates: f64) -> f64 {
        yield Constants.K_B * Math.ln(microstates)
    }

    // Carnot Efficiency: η = 1 - Tc/Th
    fn carnot_efficiency(t_hot: f64, t_cold: f64) -> f64 {
        yield 1.0 - (t_cold / t_hot)
    }

    // Gibbs Free Energy: G = H - TS
    fn gibbs_energy(enthalpy: f64, t: f64, entropy: f64) -> f64 {
        yield enthalpy - (t * entropy)
    }

    // Stefan-Boltzmann Law: Power = σAT⁴
    fn radiated_power(area: f64, temp: f64, emissivity: f64) -> f64 {
        yield emissivity * Constants.SIGMA_SB * area * temp.pow(4)
    }
}

// --- ELECTROMAGNETISM (MAXWELL) ---
open space Electromagnetism {
    // Coulomb's Law: F = k * q1 * q2 / r^2
    fn coulomb_force(q1: f64, q2: f64, r: f64) -> f64 {
        let k = 1.0 / (4.0 * Math.PI * Constants.EPSILON_0)
        yield k * (q1 * q2) / r.pow(2)
    }

    // Lorentz Force: F = q(E + v x B)
    fn lorentz_force(q: f64, e_field: Vec3, v: Vec3, b_field: Vec3) -> Vec3 {
        yield q * (e_field + v.cross(b_field))
    }

    // Biot-Savart Law (Simplified for wire): B = (μ0 * I) / (2πr)
    fn magnetic_field_wire(current: f64, r: f64) -> f64 {
        yield (Constants.MU_0 * current) / (2.0 * Math.PI * r)
    }

    // Cyclotron Frequency: f = qB / 2πm
    fn cyclotron_freq(q: f64, b: f64, m: f64) -> f64 {
        yield (q * b) / (2.0 * Math.PI * m)
    }
}

// --- FLUID DYNAMICS ---
open space Fluids {
    // Bernoulli: P + 0.5ρv² + ρgh = constant
    fn bernoulli_pressure_diff(rho: f64, v1: f64, v2: f64, h1: f64, h2: f64) -> f64 {
        // Returns P1 - P2
        let dynamic = 0.5 * rho * (v2.pow(2) - v1.pow(2))
        let hydrostatic = rho * 9.80665 * (h2 - h1)
        yield dynamic + hydrostatic
    }

    // Poiseuille Flow (Pipe): Q = πr⁴ΔP / 8ηL
    fn pipe_flow_rate(radius: f64, delta_p: f64, viscosity: f64, length: f64) -> f64 {
        yield (Math.PI * radius.pow(4) * delta_p) / (8.0 * viscosity * length)
    }

    // Reynolds Number: Re = ρvL / μ
    fn reynolds_number(rho: f64, v: f64, l: f64, mu: f64) -> f64 {
        yield (rho * v * l) / mu
    }
}

// --- ASTROPHYSICS & RELATIVITY ---
open space Astro {
    // Schwarzschild Radius (Event Horizon): Rs = 2GM/c²
    fn schwarzschild_radius(mass: f64) -> f64 {
        yield (2.0 * Constants.G * mass) / Constants.C.pow(2)
    }

    // Time Dilation (Gravitational): t' = t * sqrt(1 - Rs/r)
    fn gravitational_time_dilation(t: f64, mass: f64, r: f64) -> f64 {
        let rs = schwarzschild_radius(mass)
        yield t * Math.sqrt(1.0 - (rs / r))
    }

    // Kepler's 3rd Law: T² = (4π²/GM) r³
    fn orbital_period(mass_primary: f64, r: f64) -> f64 {
        let numerator = 4.0 * Math.PI.pow(2) * r.pow(3)
        let denominator = Constants.G * mass_primary
        yield Math.sqrt(numerator / denominator)
    }

    // Hubble's Law: v = H0 * d
    fn recession_velocity(dist_mpc: f64) -> f64 {
        let h0 = 70.0; // km/s/Mpc (Approx)
        yield h0 * dist_mpc
    }
}

// --- QUANTUM MECHANICS ---
open space Quantum {
    // Energy of Photon: E = hf
    fn photon_energy(freq: f64) -> f64 {
        yield Constants.H * freq
    }

    // De Broglie Wavelength: λ = h/p
    fn matter_wavelength(momentum: f64) -> f64 {
        yield Constants.H / momentum
    }

    // Heisenberg Uncertainty (Position-Momentum): ΔxΔp ≥ ℏ/2
    fn min_uncertainty_momentum(delta_x: f64) -> f64 {
        yield Constants.H_BAR / (2.0 * delta_x)
    }

    // Schrödinger (Time-Independent 1D infinite well): En = (n²h²)/(8mL²)
    fn energy_level_well(n: u32, mass: f64, width: f64) -> f64 {
        yield (n as f64).pow(2) * Constants.H.pow(2) / (8.0 * mass * width.pow(2))
    }
}
