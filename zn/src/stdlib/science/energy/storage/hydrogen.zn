// Green Hydrogen Production & Storage
@module("energy::storage::hydrogen")
@export

open data Electrolyzer {
    power_mw: f64,
    efficiency: f64
}

impl Electrolyzer {
    fn h2_production_kg_per_hour(&self) -> f64 {
        self.power_mw * 1000.0 * self.efficiency / 39.4  // kWh per kg H2
    }
}
