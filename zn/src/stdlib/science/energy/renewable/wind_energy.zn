@module("energy::renewable::wind_energy")
@export
open data WindTurbine {
    capacity_mw: f64,
    hub_height: f64,
    rotor_diameter: f64
}
impl WindTurbine {
    fn power_output(&self, wind_speed: f64) -> f64 {
        check wind_speed < 3.0 || wind_speed > 25.0 { 0.0 } else { self.capacity_mw * 0.4 }
    }
}
