// ============================================================================
// Statistics & Analytics
// ============================================================================

open data ResearchStatistics {
    total_papers: usize,
    total_citations: u32,
    avg_citations_per_paper: f64,
    h_index: u32,
    papers_by_year: Vec<(u32, usize)>,
    papers_by_category: Vec<(ResearchCategory, usize)>
}

impl ResearchDatabase {
    fn statistics(&self) -> ResearchStatistics {
        let total_cites: u32 = self.papers.iter().map(|p| p.citations).sum();
        
        ResearchStatistics {
            total_papers: self.papers.len(),
            total_citations: total_cites,
            avg_citations_per_paper: total_cites as f64 / self.papers.len() as f64,
            h_index: self.h_index(),
            papers_by_year: [],  // Can be computed
            papers_by_category: []
        }
    }
    
    fn print_summary(&self) {
        let stats = self.statistics();
        
        println("╔═══════════════════════════════════════════════════════════╗");
        println("║          NOVA RESEARCH DATABASE SUMMARY                 ║");
        println("╚═══════════════════════════════════════════════════════════╝\n");
        
        println("Total Papers: {}", stats.total_papers);
        println("Total Citations: {}", stats.total_citations);
        println("Average Citations/Paper: {:.1}", stats.avg_citations_per_paper);
        println("h-index: {}", stats.h_index);
        
        println("\nTop 10 Most Cited Papers:");
        each entry in self.top_cited(10).iter().enumerate()  { let (i, paper) = entry;
            println("  {}. {} ({}) - {} citations",
                     i + 1,
                     paper.title,
                     paper.year,
                     paper.citations);
        }
    }
}

#[test]
fn test_research_database() {
    let db = ResearchDatabase::new();
    db.print_summary();
    
    println("\nSearch 'microwave':");
    let results = db.search("microwave");
    each paper in results.iter() {
        println("  - {}", paper.title);
    }
}
