// Nova Research Database
// Comprehensive index of all research papers, citations, and experimental data
// Covers: Physics, Biology, Chemistry, Networking, Magnetism, etc.

@module("research::database")
@export
@research_database

// ============================================================================
// Research Categories
// ============================================================================

#[derive(Clone, Copy, PartialEq)]
open cases ResearchCategory {
    // Physics
    NonlinearOptics,
    ThermalRadiation,
    Biophotonics,
    QuantumOptics,
    CryogenicPhysics,
    Superconductivity,
    Magnetism,
    MaglevTransport,
    
    // Biology & Chemistry
    BiologyGenomics,
    Chemistry,
    MolecularBiology,
    Neuroscience,
    
    // Networking
    WirelessCommunications,
    CellularNetworks,
    FiberOptics,
    SatelliteCommunications,
    
    // Medical
    MedicalImaging,
    NuclearMedicine,
    
    // Other
    MachineLearning,
    ComputerScience
}

/// Research paper metadata
#[derive(Clone)]
open data ResearchPaper {
    id: String,
    title: String,
    authors: Vec<String>,
    institution: String,
    journal: String,
    year: u32,
    doi: String,
    category: ResearchCategory,
    citations: u32,
    impact_factor: f64,
    abstract_text: String,
    key_findings: Vec<String>,
    nova_module: String  // Which module uses this research
}

/// Experimental data from papers
#[derive(Clone)]
open data ExperimentalData {
    paper_id: String,
    experiment_type: String,
    measurements: Vec<Measurement>,
    uncertainty: f64,
    reproducible: bool
}

#[derive(Clone)]
open data Measurement {
    parameter: String,
    value: f64,
    unit: String
}

// ============================================================================
// Complete Research Database
// ============================================================================

open data ResearchDatabase {
    papers: Vec<ResearchPaper>,
    total_citations: u32,
    categories: Vec<ResearchCategory>
}

impl ResearchDatabase {
    @pure
    fn new() -> Self {
        Self {
            papers: all_research_papers(),
            total_citations: 0,
            categories: []
        }
    }
    
    /// Search papers by keyword
    fn search(&self, keyword: &str) -> Vec<&ResearchPaper> {
        self.papers.iter()
            .filter(|p| p.title.to_lowercase().contains(&keyword.to_lowercase()) ||
                       p.abstract_text.to_lowercase().contains(&keyword.to_lowercase()))
            .collect()
    }
    
    /// Get papers by category
    fn by_category(&self, category: ResearchCategory) -> Vec<&ResearchPaper> {
        self.papers.iter()
            .filter(|p| p.category == category)
            .collect()
    }
    
    /// Top cited papers
    fn top_cited(&self, n: usize) -> Vec<&ResearchPaper> {
        var sorted = self.papers.iter().collect::<Vec<_>>();
        sorted.sort_by(|a, b| b.citations.cmp(&a.citations));
        sorted.into_iter().take(n).collect()
    }
    
    /// Papers by year
    fn by_year(&self, year: u32) -> Vec<&ResearchPaper> {
        self.papers.iter()
            .filter(|p| p.year == year)
            .collect()
    }
    
    /// Calculate h-index for the database
    fn h_index(&self) -> u32 {
        var citations: Vec<u32> = self.papers.iter()
            .map(|p| p.citations)
            .collect();
        citations.sort_by(|a, b| b.cmp(a));
        
        each entry in citations.iter().enumerate()  { let (i, &cites) = entry;
            check cites < (i + 1) as u32 {
                yield i as u32;
            }
        }
        citations.len() as u32
    }
}

