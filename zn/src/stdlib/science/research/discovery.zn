// Nova Module Discovery & Search System
// Find, explore, and navigate all 586+ modules in the Nova ecosystem

@module("research::discovery")
@export

// ============================================================================
// Module Metadata
// ============================================================================

#[derive(Clone)]
open data ModuleInfo {
    path: String,
    name: String,
    category: ModuleCategory,
    description: String,
    keywords: Vec<String>,
    dependencies: Vec<String>,
    research_level: ResearchLevel,
    status: ModuleStatus,
    added_version: String,
    last_updated: String
}

#[derive(Clone, Copy, PartialEq)]
open cases ModuleCategory {
    // Science
    Biology,
    Chemistry,
    Physics,
    Medical,
    Science,
    
    // Engineering
    Networking,
    Transport,
    Magnetism,
    Cryogenics,
    
    // Computing
    AI,
    MachineLearning,
    ComputerVision,
    NaturalLanguage,
    
    // Other
    Cryptography,
    Finance,
    UI,
    Tools,
    Examples
}

#[derive(Clone, Copy, PartialEq)]
open cases ResearchLevel {
    Production,      // Stable, well-tested
    Advanced,        // Research-grade, validated
    Experimental,    // Cutting-edge, may change
    Theoretical      // Speculative, proof-of-concept
}

#[derive(Clone, Copy)]
open cases ModuleStatus {
    Stable,
    Active,
    Experimental,
    Deprecated
}

// ============================================================================
// Module Registry (All 586+ modules)
// ============================================================================

open data ModuleRegistry {
    modules: Vec<ModuleInfo>,
    total_count: usize
}

