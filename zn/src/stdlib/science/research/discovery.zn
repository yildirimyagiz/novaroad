    /// Search modules by keyword
    fn search(&self, query: &str) -> Vec<&ModuleInfo> {
        let query_lower = query.to_lowercase();
        self.modules.iter()
            .filter(|m| {
                m.name.to_lowercase().contains(&query_lower) ||
                m.description.to_lowercase().contains(&query_lower) ||
                m.keywords.iter().any(|k| k.to_lowercase().contains(&query_lower))
            })
            .collect()
    }
    
    /// Get modules by category
    fn by_category(&self, category: ModuleCategory) -> Vec<&ModuleInfo> {
        self.modules.iter()
            .filter(|m| m.category == category)
            .collect()
    }
    
    /// Get modules by research level
    fn by_research_level(&self, level: ResearchLevel) -> Vec<&ModuleInfo> {
        self.modules.iter()
            .filter(|m| m.research_level == level)
            .collect()
    }
    
    /// Get recently added modules
    fn recently_added(&self, days: u32) -> Vec<&ModuleInfo> {
        // Simplified: yield last N modules
        self.modules.iter().rev().take(days as usize).collect()
    }
    
    /// Get module dependencies
    fn get_dependencies(&self, module_path: &str) -> Vec<&ModuleInfo> {
        check let Some(module) = self.modules.iter().find(|m| m.path == module_path) {
            module.dependencies.iter()
                .filter_map(|dep| {
                    self.modules.iter().find(|m| m.path.contains(dep))
                })
                .collect()
        } else {
            yield []
        }
    }
    
    /// Print discovery summary
    fn print_summary(&self) {
        println("╔═══════════════════════════════════════════════════════════╗");
        println("║          NOVA MODULE DISCOVERY SYSTEM                   ║");
        println("╚═══════════════════════════════════════════════════════════╝\n");
        
        println("Total Modules: {}", self.modules.len());
        
        println("\nBy Category:");
        let categories = [
            (ModuleCategory::Biology, "Biology"),
            (ModuleCategory::Chemistry, "Chemistry"),
            (ModuleCategory::Physics, "Physics"),
            (ModuleCategory::Magnetism, "Magnetism"),
            (ModuleCategory::Transport, "Transport"),
            (ModuleCategory::Networking, "Networking"),
            (ModuleCategory::AI, "AI"),
            (ModuleCategory::MachineLearning, "Machine Learning"),
        ];
        
        each entry in categories.iter()  { let (cat, name) = entry;
            let count = self.by_category(*cat).len();
            check count > 0 {
                println("  {}: {}", name, count);
            }
        }
        
        println("\nBy Research Level:");
        println("  Production: {}", self.by_research_level(ResearchLevel::Production).len());
        println("  Advanced: {}", self.by_research_level(ResearchLevel::Advanced).len());
        println("  Experimental: {}", self.by_research_level(ResearchLevel::Experimental).len());
    }
}

#[test]
fn test_module_discovery() {
    let registry = ModuleRegistry::new();
    registry.print_summary();
    
    println("\nSearch 'maglev':");
    each module in registry.search("maglev") {
        println("  - {} ({})", module.name, module.path);
    }
    
    println("\nPhysics modules:");
    each module in registry.by_category(ModuleCategory::Physics).iter().take(5) {
        println("  - {}", module.name);
    }
}
EOF
echo "✅ Module discovery system created!"
