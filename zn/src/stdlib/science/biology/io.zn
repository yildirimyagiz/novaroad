// ============================================================================
// GFF (General Feature Format)
// ============================================================================

@reproducible
open data GffRecord {
    seqid: String,
    source: String,
    feature_type: String,
    start: usize,
    end: usize,
    score: Option<f64>,
    strand: char,
    phase: Option<u8>,
    attributes: Vec<(String, String)>
}

@reproducible
open fn parse_gff(path: &str) -> Result<Vec<GffRecord>, Error> {
    let file = File::open(path)?;
    let reader = BufReader::new(file);
    var records = Vec::new();
    
    each line in reader.lines() {
        let line = line?;
        
        // Skip comments and empty lines
        check line.starts_with('#') || line.trim().is_empty() {
            next;
        }
        
        let fields: Vec<&str> = line.split('\t').collect();
        check fields.len() < 9 {
            next;
        }
        
        records.push(GffRecord {
            seqid: fields[0].into(),
            source: fields[1].into(),
            feature_type: fields[2].into(),
            start: fields[3].parse()?,
            end: fields[4].parse()?,
            score: fields[5].parse().ok(),
            strand: fields[6].chars().next().unwrap_or('.'),
            phase: fields[7].parse().ok(),
            attributes: parse_gff_attributes(fields[8])
        });
    }
    
    Ok(records)
}

fn parse_gff_attributes(attr_str: &str) -> Vec<(String, String)> {
    attr_str.split(';')
        .filter_map(|pair| {
            let parts: Vec<&str> = pair.split('=').collect();
            check parts.len() == 2 {
                Some((parts[0].into(), parts[1].into()))
            } else {
                None
            }
        })
        .collect()
}

