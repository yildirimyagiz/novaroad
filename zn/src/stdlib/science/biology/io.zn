// ============================================================================
// Tests
// ============================================================================

#[test]
@reproducible
fn test_fasta_roundtrip() {
    let records = [
        FastaRecord {
            id: String::from("seq1"),
            description: Some(String::from("test sequence")),
            sequence: DNA::from_str("ATGC").unwrap()
        }
    ];
    
    write_fasta(&records, "/tmp/test.fasta").unwrap();
    let parsed = parse_fasta("/tmp/test.fasta").unwrap();
    
    assert_eq!(parsed.len(), 1);
    assert_eq!(parsed[0].id, "seq1");
}

#[test]
@reproducible
fn test_fastq_quality_filter() {
    let records = [
        FastqRecord {
            id: String::from("read1"),
            sequence: DNA::from_str("ATGC").unwrap(),
            quality: [30, 30, 30, 30]  // High quality
        },
        FastqRecord {
            id: String::from("read2"),
            sequence: DNA::from_str("ATGC").unwrap(),
            quality: [10, 10, 10, 10]  // Low quality
        }
    ];
    
    let filtered = filter_by_quality(records, 20, 4);
    assert_eq!(filtered.len(), 1);  // Only high-quality read
}
