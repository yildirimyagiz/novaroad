// Nova Science - Neuroscience
// Synaptic Transmission, Neural Plasticity, and Brain Waves.

import std.science.biology.cell

open data Neuron {
    id: u64
    membrane_potential: f64, // mV
    synapses: list<Synapse>
}

open data Synapse {
    target_neuron: u64
    weight: f64, // Connection strength (0.0 - 1.0)
    neurotransmitter: NeuroTransmitter
}

open cases NeuroTransmitter {
    Glutamate, // Excitatory
    GABA,      // Inhibitory
    Dopamine,  // Modulatory
    Serotonin
}

open space Plasticity {
    // Hebbian Learning: "Neurons that fire together, wire together"
    fn stdp_update(synapse: var Synapse, delta_t: f64) {
        // Spike-Timing-Dependent Plasticity
        check delta_t > 0.0 && delta_t < 20.0 {
            // Pre-before-Post (LTP) -> Strengthen
            synapse.weight += 0.01 * Math.exp(-delta_t / 10.0)
        } else check delta_t < 0.0 && delta_t > -20.0 {
            // Post-before-Pre (LTD) -> Weaken
            synapse.weight -= 0.01 * Math.exp(delta_t / 10.0)
        }
        
        // Clamp weights
        synapse.weight = Math.clamp(synapse.weight, 0.0, 1.0)
    }
}

open space BrainWaves {
    cases Frequency {
        Delta, // 0.5 - 4 Hz
        Theta, // 4 - 8 Hz
        Alpha, // 8 - 13 Hz
        Beta,  // 13 - 30 Hz
        Gamma  // 30 - 100 Hz
    }
    
    fn classify_eeg(freq: f64) -> Frequency {
        check freq < 4.0 { yield Frequency.Delta; }
        check freq < 8.0 { yield Frequency.Theta; }
        check freq < 13.0 { yield Frequency.Alpha; }
        check freq < 30.0 { yield Frequency.Beta; }
        yield Frequency.Gamma
    }
}
