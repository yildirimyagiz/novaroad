// Nova Biology - Microbiology: Viruses & Bacteria
// Viral replication, bacterial growth, and pathogen modeling

// === VIRUSES ===
data Virus {
    genome: ViralGenome
    capsid_proteins: list<Protein>
    envelope: bool
    host_specificity: list<str>  // Cell types it can infect
}

cases ViralGenome {
    DNA_Single
    DNA_Double
    RNA_Single_Positive  // Can directly translate
    RNA_Single_Negative  // Must synthesize complement first
    RNA_Double
    Retrovirus  // RNA -> DNA via reverse transcriptase
}

impl Virus {
    // Viral Replication Cycle
    fn infect_cell(self, host_cell: Cell) -> list<Virus> {
        // 1. Attachment & Entry
        check !self.can_attach(host_cell) {
            yield []  // No infection
        }
        
        // 2. Uncoating - release genome
        let viral_genome = self.genome
        
        // 3. Replication strategy depends on genome alias
        let progeny_count = match viral_genome {
            ViralGenome.DNA_Double => {
                // Use host DNA polymerase
                self.replicate_dsdna(host_cell)
            }
            ViralGenome.RNA_Single_Positive => {
                // Direct translation -> RdRp -> replication
                self.replicate_positive_rna(host_cell)
            }
            ViralGenome.Retrovirus => {
                // Reverse transcription -> integration
                self.retroviral_cycle(host_cell)
            }
            _ => 100
        }
        
        // 4. Assembly & Release
        var new_virions = []
        each _ in 0..progeny_count {
            new_virions.push(self.clone())
        }
        
        yield new_virions
    }
    
    fn can_attach(self, host_cell: Cell) -> bool {
        // Check check host has receptor
        each receptor in host_cell.membrane.surface_proteins {
            check self.host_specificity.contains(receptor) {
                yield true
            }
        }
        yield false
    }
    
    fn replicate_dsdna(self, host: Cell) -> u32 {
        // Lytic cycle: 100-200 virions per cell
        yield 150
    }
    
    fn replicate_positive_rna(self, host: Cell) -> u32 {
        // Rapid replication (e.g., poliovirus)
        yield 10000
    }
    
    fn retroviral_cycle(self, host: Cell) -> u32 {
        // HIV-like: integrate into host genome
        // Slower replication
        yield 50
    }
}

// Specific Virus Examples
open fn create_coronavirus() -> Virus {
    Virus {
        genome: ViralGenome.RNA_Single_Positive
        capsid_proteins: []
        envelope: true
        host_specificity: ["ACE2_receptor"]  // SARS-CoV-2
    }
}

open fn create_hiv() -> Virus {
    Virus {
        genome: ViralGenome.Retrovirus
        capsid_proteins: []
        envelope: true
        host_specificity: ["CD4_receptor"]
    }
}

// === BACTERIA ===
data Bacterium {
    species: str
    genome_size: u32  // base pairs
    plasmids: list<Plasmid>
    generation_time: f64  // minutes
    cell_wall_type: CellWallType
    metabolism: MetabolismType
}

cases CellWallType {
    GramPositive   // Thick peptidoglycan
    GramNegative   // Thin peptidoglycan + outer membrane
    NoWall         // Mycoplasma
}

cases MetabolismType {
    Aerobic
    Anaerobic
    Facultative  // Can do both
}

data Plasmid {
    genes: list<Gene>
    antibiotic_resistance: list<str>
}

impl Bacterium {
    // Bacterial Growth (Exponential Phase)
    fn grow_population(self, initial_count: u32, time_hours: f64) -> u32 {
        // N(t) = N0 * 2^(t/g) where g = generation time
        let generations = (time_hours * 60.0) / self.generation_time
        let final_count = (initial_count as f64) * Math.pow(2.0, generations)
        
        yield final_count as u32
    }
    
    // Horizontal Gene Transfer - Conjugation
    fn transfer_plasmid(var self, recipient: Bacterium, plasmid: Plasmid) -> Bacterium {
        // F-pili mediated transfer
        var new_recipient = recipient
        new_recipient.plasmids.push(plasmid.clone())
        
        yield new_recipient
    }
    
    // Antibiotic Susceptibility
    fn is_resistant(self, antibiotic: str) -> bool {
        each plasmid in self.plasmids {
            check plasmid.antibiotic_resistance.contains(antibiotic) {
                yield true
            }
        }
        yield false
    }
}

// Specific Bacteria Examples
open fn create_ecoli() -> Bacterium {
    Bacterium {
        species: "Escherichia coli"
        genome_size: 4_600_000
        plasmids: []
        generation_time: 20.0  // 20 minutes
        cell_wall_type: CellWallType.GramNegative
        metabolism: MetabolismType.Facultative
    }
}

open fn create_staph_aureus() -> Bacterium {
    let mrsa_plasmid = Plasmid {
        genes: []
        antibiotic_resistance: ["methicillin", "penicillin"]
    }
    
    Bacterium {
        species: "Staphylococcus aureus"
        genome_size: 2_800_000
        plasmids: [mrsa_plasmid]
        generation_time: 30.0
        cell_wall_type: CellWallType.GramPositive
        metabolism: MetabolismType.Facultative
    }
}

// === INFECTION MODELING ===
open fn simulate_infection(pathogen_type: str, initial_viral_load: u32, immune_response: f64) -> u32 {
    // SIR-like model simplified
    var viral_load = initial_viral_load
    
    each day in 0..14 {
        // Viral replication
        viral_load = (viral_load as f64 * 10.0) as u32
        
        // Immune clearance
        let clearance = (viral_load as f64 * immune_response) as u32
        viral_load -= Math.min(clearance, viral_load)
        
        check viral_load < 100 {
            yield day  // Infection cleared
        }
    }
    
    yield 14  // Chronic infection
}
