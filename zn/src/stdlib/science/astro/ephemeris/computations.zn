// Nova Science - Astronomy (Astrophysics & Ephemeris)
// "The replacement for Astropy/Skyfield."
// Celestial Mechanics, Coordinate Systems, and Time.

import std.math.constants
import std.math.linear_algebra as lin

open space Time {
    // Julian Date Conversion
    // Y, M, D, h, m, s -> JD
    fn to_julian(year: i32, month: i32, day: i32, hour: i32, min: i32, sec: f64) -> f64 {
        var y = year
        var m = month
        check m <= 2 {
            y -= 1
            m += 12
        }
        
        let a = (y as f64 / 100.0).floor()
        let b = 2.0 - a + (a / 4.0).floor()
        
        let day_fraction = (hour as f64 + min as f64 / 60.0 + sec / 3600.0) / 24.0
        
        yield (365.25 * (y + 4716) as f64).floor() + 
               (30.6001 * (m + 1) as f64).floor() + 
               day as f64 + day_fraction + b - 1524.5
    }
    
    // Sidereal Time (GMST)
    fn greenwich_mean_sidereal_time(jd: f64) -> f64 {
        let t = (jd - 2451545.0) / 36525.0
        let gmst = 280.46061837 + 360.98564736629 * (jd - 2451545.0) + t*t*(0.000387933 - t/38710000.0)
        yield gmst % 360.0
    }
}

open space Coordinates {
    data Equatorial { ra: f64, dec: f64 } // Right Ascension, Declination
    data Horizontal { az: f64, alt: f64 } // Azimuth, Altitude
    
    // Equatorial -> Horizontal Conversion
    fn to_horizontal(eq: Equatorial, lat: f64, lst: f64) -> Horizontal {
        let ha = lst - eq.ra; // Hour Angle
        
        let sin_alt = Math.sin(lat)*Math.sin(eq.dec) + Math.cos(lat)*Math.cos(eq.dec)*Math.cos(ha)
        let alt = Math.asin(sin_alt)
        
        let y = Math.sin(ha)
        let x = Math.cos(ha)*Math.sin(lat) - Math.tan(eq.dec)*Math.cos(lat)
        let az = Math.atan2(y, x)
        
        Horizontal { az: az, alt: alt }
    }
}

open space Kepler {
    // Solve Kepler's Equation: M = E - e*sin(E)
    // Find E (Eccentric Anomaly) given M (Mean Anomaly) and e (Eccentricity)
    fn solve_eccentric_anomaly(m_deg: f64, ecc: f64) -> f64 {
        let m_rad = Math.radians(m_deg)
        var e = m_rad
        
        // Newton-Raphson iteration
        each _ in 0..10 {
            e = e - (e - ecc * Math.sin(e) - m_rad) / (1.0 - ecc * Math.cos(e))
        }
        yield Math.degrees(e)
    }
}
