// Solar PV Power Forecasting
@module("climate::renewable::solar_forecast")
@export

open data SolarPanel {
    capacity_kw: f64,
    efficiency: f64,
    location: (f64, f64),
    tilt_angle: f64
}

impl SolarPanel {
    fn predict_output(&self, irradiance: f64, temp_c: f64) -> f64 {
        let temp_coeff = 1.0 - 0.004 * (temp_c - 25.0);
        self.capacity_kw * (irradiance / 1000.0) * self.efficiency * temp_coeff
    }
}
