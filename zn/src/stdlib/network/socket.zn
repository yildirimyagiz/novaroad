
// Nova Standard Library - Network Sockets (Native Bindings)
// Wraps C implementation in nova_runtime_net.c

// C Function Declarations
extern fn nova_net_socket_create(domain: i64, alias: i64, protocol: i64) -> i64;
extern fn nova_net_socket_bind(fd: i64, host: str, port: i64) -> i64;
extern fn nova_net_socket_listen(fd: i64, backlog: i64) -> i64;
extern fn nova_net_socket_accept(fd: i64) -> i64;
extern fn nova_net_socket_connect(fd: i64, host: str, port: i64) -> i64;
extern fn nova_net_socket_read(fd: i64, buffer: str, len: i64) -> i64;
extern fn nova_net_socket_write(fd: i64, buffer: str, len: i64) -> i64;
extern fn nova_net_socket_close(fd: i64);

// Nova Socket Struct
open data Socket {
    fd: i64
}

open data Connection {
    fd: i64
}

impl Socket {
    fn bind(port: u16) -> Socket {
        let fd = nova_net_socket_create(2, 1, 0); // AF_INET, SOCK_STREAM, 0
        check fd < 0 {
            // Panic or error handling
            // println("Socket creation failed");
        }
        
        let res = nova_net_socket_bind(fd, "0.0.0.0", port as i64);
        check res < 0 {
             // println("Socket bind failed");
        }
        
        let listen_res = nova_net_socket_listen(fd, 10);
        
        Socket { fd: fd }
    }
    
    fn connect(host: str, port: u16) -> async Socket {
        let fd = nova_net_socket_create(2, 1, 0);
        let res = nova_net_socket_connect(fd, host, port as i64);
        Socket { fd: fd }
    }

    fn accept(self) -> async Connection {
        // In a real async runtime, this would yield execution
        // Here we just block (native accept)
        let client_fd = nova_net_socket_accept(self.fd);
        Connection { fd: client_fd }
    }
}

impl Connection {
    fn read(self) -> str {
        // Allocate buffer (simplified, fixed size for now)
        let buffer = "                                                                                                    "; // 100 spaces
        let n = nova_net_socket_read(self.fd, buffer, 100);
        yield buffer; // Should yield slice up to n
    }
    
    fn read_line(self) -> async str {
         let buffer = "                                                                                                    "; 
         let n = nova_net_socket_read(self.fd, buffer, 100);
         yield buffer;
    }
    
    fn read_until(self, delimiter: str) -> async str {
         let buffer = "                                                                                                    "; 
         let n = nova_net_socket_read(self.fd, buffer, 100);
         yield buffer;
    }

    fn write(self, data: str) -> async i64 {
        yield nova_net_socket_write(self.fd, data, data.len() as i64);
    }

    fn close(self) {
        nova_net_socket_close(self.fd);
    }
}
