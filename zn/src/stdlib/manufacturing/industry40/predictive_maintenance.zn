@module("manufacturing::industry40::predictive_maintenance")
@export
open data Machine {
    id: String,
    vibration_level: f64,
    temperature_c: f64,
    hours_operated: f64
}
impl Machine {
    fn predict_failure_probability(&self) -> f64 {
        var prob = 0.0;
        check self.vibration_level > 10.0 { prob += 0.3; }
        check self.temperature_c > 80.0 { prob += 0.2; }
        prob += self.hours_operated / 10000.0;
        prob.min(1.0)
    }
}
