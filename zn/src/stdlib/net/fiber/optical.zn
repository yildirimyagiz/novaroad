// Nova Networking: Fiber Optic Networks
// FTTH, XGS-PON, GPON, WDM, coherent optics
// Turkey: 8M+ FTTH subscribers (2026)

@module("net::fiber::optical")
@verified
@export

// ============================================================================
// PON (Passive Optical Network) Standards
// ============================================================================

#[derive(Clone, Copy)]
open cases PONStandard {
    GPON,       // 2.5 Gbps down, 1.25 up
    XGPON,      // 10 Gbps down, 2.5 up
    XGS_PON,    // 10 Gbps symmetrical
    NG_PON2,    // 40 Gbps (4x10G wavelengths)
    TenG_EPON,  // 10 Gbps Ethernet PON
    FiftyG_PON  // 50 Gbps (future)
}

open data PONSystem {
    standard: PONStandard,
    downstream_gbps: f64,
    upstream_gbps: f64,
    split_ratio: u16,       // 1:32, 1:64, 1:128
    max_distance_km: f64,
    wavelength_down_nm: u16,
    wavelength_up_nm: u16
}

impl PONSystem {
    @pure
    fn xgs_pon() -> Self {
        Self {
            standard: PONStandard::XGS_PON,
            downstream_gbps: 10.0,
            upstream_gbps: 10.0,
            split_ratio: 64,
            max_distance_km: 20.0,
            wavelength_down_nm: 1577,
            wavelength_up_nm: 1270
        }
    }
    
    @pure
    fn gpon() -> Self {
        Self {
            standard: PONStandard::GPON,
            downstream_gbps: 2.5,
            upstream_gbps: 1.25,
            split_ratio: 32,
            max_distance_km: 20.0,
            wavelength_down_nm: 1490,
            wavelength_up_nm: 1310
        }
    }
    
    @pure
    fn per_user_bandwidth(&self) -> f64 {
        self.downstream_gbps / (self.split_ratio as f64)
    }
}

// ============================================================================
// Turkey FTTH Deployment (2026)
// ============================================================================

open data TurkeyFTTH2026 {
    total_subscribers_millions: f64,
    coverage_households_millions: f64,
    penetration_rate: f64,
    avg_speed_mbps: f64,
    operators: Vec<String>
}

@const
open fn turkey_ftth_2026() -> TurkeyFTTH2026 {
    TurkeyFTTH2026 {
        total_subscribers_millions: 8.5,
        coverage_households_millions: 15.0,
        penetration_rate: 35.0,  // 35% of households
        avg_speed_mbps: 500.0,
        operators: [
            "Türk Telekom".into(),
            "Vodafone".into(),
            "Turkcell Superonline".into()
        ]
    }
}

// ============================================================================
// WDM (Wavelength Division Multiplexing)
// ============================================================================

open data WDMSystem {
    num_channels: u16,
    channel_spacing_ghz: f64,
    per_channel_gbps: f64,
    total_capacity_tbps: f64
}

impl WDMSystem {
    @pure
    fn dwdm_100g() -> Self {
        Self {
            num_channels: 96,
            channel_spacing_ghz: 50.0,
            per_channel_gbps: 100.0,
            total_capacity_tbps: 9.6
        }
    }
    
    @pure
    fn dwdm_400g() -> Self {
        Self {
            num_channels: 96,
            channel_spacing_ghz: 75.0,
            per_channel_gbps: 400.0,
            total_capacity_tbps: 38.4
        }
    }
}

#[test]
fn test_xgs_pon() {
    let pon = PONSystem::xgs_pon();
    assert_eq!(pon.downstream_gbps, 10.0);
    assert_eq!(pon.upstream_gbps, 10.0);
    
    let per_user = pon.per_user_bandwidth();
    println("XGS-PON per user (1:64): {:.0} Mbps", per_user * 1000.0);
}

#[test]
fn test_turkey_ftth() {
    let tr = turkey_ftth_2026();
    println("Türkiye FTTH 2026:");
    println("  Subscribers: {:.1}M", tr.total_subscribers_millions);
    println("  Penetration: {:.0}%", tr.penetration_rate);
    println("  Avg speed: {:.0} Mbps", tr.avg_speed_mbps);
}
