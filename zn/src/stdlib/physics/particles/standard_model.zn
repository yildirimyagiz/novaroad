// Nova Physics - Standard Model of Particle Physics
// Fundamental particles, forces, and interactions

import std.math
import std.math.linear_algebra

// === FUNDAMENTAL PARTICLES ===

open cases ParticleType {
    Quark,
    Lepton,
    Boson,
    Hadron
}

open data FundamentalParticle {
    name: String
    symbol: String
    mass: f64  // MeV/c²
    charge: f64  // e
    spin: f64  // ħ
    particle_type: ParticleType
    generation: u8
}

open const UP_QUARK: FundamentalParticle = FundamentalParticle {
    name: "Up Quark"
    symbol: "u"
    mass: 2.3
    charge: 2.0/3.0
    spin: 0.5
    particle_type: ParticleType.Quark
    generation: 1
}

open const DOWN_QUARK: FundamentalParticle = FundamentalParticle {
    name: "Down Quark"
    symbol: "d"
    mass: 4.8
    charge: -1.0/3.0
    spin: 0.5
    particle_type: ParticleType.Quark
    generation: 1
}

open const ELECTRON: FundamentalParticle = FundamentalParticle {
    name: "Electron"
    symbol: "e⁻"
    mass: 0.511
    charge: -1.0
    spin: 0.5
    particle_type: ParticleType.Lepton
    generation: 1
}

open const ELECTRON_NEUTRINO: FundamentalParticle = FundamentalParticle {
    name: "Electron Neutrino"
    symbol: "νₑ"
    mass: 0.0  // Upper limit < 1 eV
    charge: 0.0
    spin: 0.5
    particle_type: ParticleType.Lepton
    generation: 1
}

open const PHOTON: FundamentalParticle = FundamentalParticle {
    name: "Photon"
    symbol: "γ"
    mass: 0.0
    charge: 0.0
    spin: 1.0
    particle_type: ParticleType.Boson
    generation: 0
}

open const W_BOSON: FundamentalParticle = FundamentalParticle {
    name: "W Boson"
    symbol: "W⁺"
    mass: 80_387.0
    charge: 1.0
    spin: 1.0
    particle_type: ParticleType.Boson
    generation: 0
}

open const Z_BOSON: FundamentalParticle = FundamentalParticle {
    name: "Z Boson"
    symbol: "Z⁰"
    mass: 91_187.6
    charge: 0.0
    spin: 1.0
    particle_type: ParticleType.Boson
    generation: 0
}

open const HIGGS_BOSON: FundamentalParticle = FundamentalParticle {
    name: "Higgs Boson"
    symbol: "H⁰"
    mass: 125_000.0
    charge: 0.0
    spin: 0.0
    particle_type: ParticleType.Boson
    generation: 0
}

// === FUNDAMENTAL FORCES ===

open cases FundamentalForce {
    Gravity,
    Electromagnetic,
    Weak,
    Strong
}

open data ForceProperties {
    force: FundamentalForce
    range: f64  // meters (∞ for gravity and EM)
    mediator: String
    coupling_constant: f64
}

open const GRAVITY: ForceProperties = ForceProperties {
    force: FundamentalForce.Gravity
    range: f64.INFINITY
    mediator: "Graviton (hypothetical)"
    coupling_constant: 1.0  // Not directly comparable
}

open const ELECTROMAGNETISM: ForceProperties = ForceProperties {
    force: FundamentalForce.Electromagnetic
    range: f64.INFINITY
    mediator: "Photon"
    coupling_constant: 0.007297  // α ≈ 1/137
}

open const WEAK_FORCE: ForceProperties = ForceProperties {
    force: FundamentalForce.Weak
    range: 1e-18  // ~10^{-18} m
    mediator: "W⁺, W⁻, Z⁰ bosons"
    coupling_constant: 0.000029  // G_F / √2
}

open const STRONG_FORCE: ForceProperties = ForceProperties {
    force: FundamentalForce.Strong
    range: 1e-15  // ~10^{-15} m
    mediator: "Gluons"
    coupling_constant: 1.0  // α_s ≈ 0.1-0.3 at different scales
}

// === STANDARD MODEL LAGRANGIAN ===

// Simplified representation of the Standard Model
open data StandardModel {
    particles: list<FundamentalParticle>
    forces: list<ForceProperties>
    generations: u8
}

impl StandardModel {
    fn new() -> StandardModel {
        var particles = list.new()
        
        // Add quarks (3 generations)
        particles.push(UP_QUARK)
        particles.push(DOWN_QUARK)
        // ... add other generations
        
        // Add leptons
        particles.push(ELECTRON)
        particles.push(ELECTRON_NEUTRINO)
        // ... add other leptons
        
        // Add bosons
        particles.push(PHOTON)
        particles.push(W_BOSON)
        particles.push(Z_BOSON)
        particles.push(HIGGS_BOSON)
        
        let forces = list.new()
        forces.push(GRAVITY)
        forces.push(ELECTROMAGNETISM)
        forces.push(WEAK_FORCE)
        forces.push(STRONG_FORCE)
        
        StandardModel {
            particles: particles
            forces: forces
            generations: 3
        }
    }
    
    fn particle_count(self) -> u32 {
        yield self.particles.length() as u32
    }
    
    fn force_count(self) -> u32 {
        yield self.forces.length() as u32
    }
    
    // Calculate particle mass spectrum
    fn mass_spectrum(self) -> list<f64> {
        var masses = list.new()
        each particle in self.particles {
            masses.push(particle.mass)
        }
        yield masses
    }
}

// === PARTICLE DECAYS ===

open data DecayChannel {
    parent: FundamentalParticle
    daughters: list<FundamentalParticle>
    branching_ratio: f64
    lifetime: f64  // seconds
}

open fn neutron_beta_decay() -> DecayChannel {
    // n → p + e⁻ + ν̄_e
    let neutron = FundamentalParticle { /* neutron properties */ }
    let proton = FundamentalParticle { /* proton properties */ }
    let electron = ELECTRON
    let antineutrino = FundamentalParticle { /* antineutrino properties */ }
    
    DecayChannel {
        parent: neutron
        daughters: list.new(proton, electron, antineutrino)
        branching_ratio: 1.0
        lifetime: 881.5  // seconds
    }
}

// === CROSS SECTIONS AND INTERACTIONS ===

// Rutherford scattering cross section
open fn rutherford_cross_section(z1: f64, z2: f64, energy: f64, angle: f64) -> f64 {
    // dσ/dΩ = (Z1 Z2 e² / (8 π ε0 μ v² sin⁴(θ/2)))²
    let alpha = 1.0/137.036  // Fine structure constant
    let hbar_c = 197.3  // MeV·fm
    
    let sin_half_theta = Math.sin(angle / 2.0)
    let denominator = Math.pow(sin_half_theta, 4.0)
    
    let prefactor = Math.pow((z1 * z2 * alpha * hbar_c) / (2.0 * energy), 2.0)
    
    yield prefactor / denominator
}

// === HIGGS MECHANISM ===

// Spontaneous symmetry breaking
open data HiggsField {
    vev: f64  // Vacuum expectation value
    mass: f64
}

impl HiggsField {
    fn standard_model() -> HiggsField {
        HiggsField {
            vev: 246_000.0  // MeV
            mass: 125_000.0  // MeV/c²
        }
    }
    
    // W boson mass from Higgs mechanism
    fn w_mass(self) -> f64 {
        let g = 0.65  // Weak coupling constant
        yield g * self.vev / 2.0
    }
    
    // Top quark mass prediction
    fn yukawa_coupling(self, fermion_mass: f64) -> f64 {
        yield Math.sqrt(2.0) * fermion_mass / self.vev
    }
}
