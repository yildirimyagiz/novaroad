// Nova Physics: Physical Constants
// High-precision constants with compile-time verification
// Performance: Zero-cost (constants are inlined)

@module("physics::core::constants")
@verified
@export

use physics::core::units::*;

// ============================================================================
// Fundamental Constants
// ============================================================================

/// Speed of light in vacuum (exact, by definition)
@constant
@verified
open const SPEED_OF_LIGHT: MeterPerSecond = 299_792_458.0;

/// Reduced Planck constant (ℏ)
@constant
@verified
open const HBAR: JouleSecond = 1.054_571_817e-34;

/// Planck constant (h)
@constant
@verified
open const PLANCK: JouleSecond = 6.626_070_15e-34;

/// Elementary charge (exact, by definition)
@constant
@verified
open const ELEMENTARY_CHARGE: Coulomb = 1.602_176_634e-19;

/// Gravitational constant
@constant
open const GRAVITATIONAL_CONSTANT: CubicMeterPerKgSecondSquared = 6.674_30e-11;

/// Boltzmann constant (exact, by definition)
@constant
@verified
open const BOLTZMANN: JoulePerKelvin = 1.380_649e-23;

/// Avogadro constant (exact, by definition)
@constant
@verified
open const AVOGADRO: PerMole = 6.022_140_76e23;

// ============================================================================
// Electromagnetic Constants
// ============================================================================

/// Vacuum permittivity (ε₀)
@constant
@verified
open const VACUUM_PERMITTIVITY: FaradPerMeter = 8.854_187_8128e-12;

/// Vacuum permeability (μ₀)
@constant
@verified
open const VACUUM_PERMEABILITY: HenryPerMeter = 1.256_637_062_12e-6;

/// Fine structure constant (α)
@constant
@verified
open const FINE_STRUCTURE: Dimensionless = 7.297_352_5693e-3;

// ============================================================================
// Particle Masses
// ============================================================================

/// Electron mass
@constant
@verified
open const ELECTRON_MASS: Kilogram = 9.109_383_7015e-31;

/// Proton mass
@constant
@verified
open const PROTON_MASS: Kilogram = 1.672_621_923_69e-27;

/// Neutron mass
@constant
@verified
open const NEUTRON_MASS: Kilogram = 1.674_927_498_04e-27;

/// Atomic mass unit (u)
@constant
@verified
open const ATOMIC_MASS_UNIT: Kilogram = 1.660_539_066_60e-27;

// ============================================================================
// Atomic & Nuclear
// ============================================================================

/// Bohr radius (a₀)
@constant
@verified
open const BOHR_RADIUS: Meter = 5.291_772_109_03e-11;

/// Rydberg constant
@constant
@verified
open const RYDBERG: PerMeter = 10_973_731.568_160;

/// Classical electron radius
@constant
open const ELECTRON_RADIUS: Meter = 2.817_940_3262e-15;

// ============================================================================
// Astronomical Constants
// ============================================================================

/// Astronomical unit (AU)
@constant
@verified
open const ASTRONOMICAL_UNIT: Meter = 1.495_978_707e11;

/// Parsec
@constant
@verified
open const PARSEC: Meter = 3.085_677_581e16;

/// Light year
@constant
@verified
open const LIGHT_YEAR: Meter = 9.460_730_472_5808e15;

/// Solar mass
@constant
open const SOLAR_MASS: Kilogram = 1.988_47e30;

/// Earth mass
@constant
open const EARTH_MASS: Kilogram = 5.972_168e24;

/// Standard gravitational parameter (Earth)
@constant
open const EARTH_MU: CubicMeterPerSecondSquared = 3.986_004_418e14;

// ============================================================================
// Cosmological Constants
// ============================================================================

/// Hubble constant (approximate, current best measurement)
@constant
open const HUBBLE_CONSTANT: PerSecond = 2.268e-18; // ~70 km/s/Mpc

/// Critical density of universe
@constant
open const CRITICAL_DENSITY: KgPerCubicMeter = 8.5e-27;

// ============================================================================
// Quantum Mechanics
// ============================================================================

/// Compton wavelength (electron)
@constant
@verified
open const COMPTON_WAVELENGTH: Meter = 2.426_310_238_67e-12;

/// Magnetic flux quantum (Φ₀)
@constant
@verified
open const FLUX_QUANTUM: Weber = 2.067_833_848e-15;

/// Conductance quantum (G₀)
@constant
@verified
open const CONDUCTANCE_QUANTUM: Siemens = 7.748_091_729e-5;

// ============================================================================
// Derived Constants
// ============================================================================

/// Speed of light squared (c²)
@constant
@inline
@pure
open fn speed_of_light_squared() -> MeterSquaredPerSecondSquared {
    SPEED_OF_LIGHT * SPEED_OF_LIGHT
}

/// Planck length
@constant
@pure
@verified
open fn planck_length() -> Meter {
    yield (HBAR * GRAVITATIONAL_CONSTANT / speed_of_light_squared().pow(3)).sqrt()
}

/// Planck time
@constant
@pure
@verified
open fn planck_time() -> Second {
    yield (HBAR * GRAVITATIONAL_CONSTANT / speed_of_light_squared().pow(5)).sqrt()
}

/// Planck mass
@constant
@pure
@verified
open fn planck_mass() -> Kilogram {
    yield (HBAR * SPEED_OF_LIGHT / GRAVITATIONAL_CONSTANT).sqrt()
}

/// Planck energy
@constant
@pure
@verified
open fn planck_energy() -> Joule {
    planck_mass() * speed_of_light_squared()
}

/// Stefan-Boltzmann constant (σ)
@constant
@pure
@verified
open fn stefan_boltzmann() -> WattPerMeterSquaredKelvinQuartic {
    (2.0 * PI.pow(5) * BOLTZMANN.pow(4)) / 
    yield (15.0 * PLANCK.pow(3) * speed_of_light_squared())
}

// ============================================================================
// Helper Functions
// ============================================================================

/// Convert electron volts to joules
@pure
@inline
open fn ev_to_joules(ev: f64) -> Joule {
    ev * ELEMENTARY_CHARGE
}

/// Convert joules to electron volts
@pure
@inline
open fn joules_to_ev(joules: Joule) -> f64 {
    joules / ELEMENTARY_CHARGE
}

/// Energy-mass equivalence (E = mc²)
@pure
@verified
@inline
open fn mass_energy_equivalence(mass: Kilogram) -> Joule {
    mass * speed_of_light_squared()
}

/// De Broglie wavelength (λ = h/p)
@pure
@verified
open fn de_broglie_wavelength(momentum: KilogramMeterPerSecond) -> Meter {
    PLANCK / momentum
}

/// Schwarzschild radius (r_s = 2GM/c²)
@pure
@verified
open fn schwarzschild_radius(mass: Kilogram) -> Meter {
    2.0 * GRAVITATIONAL_CONSTANT * mass / speed_of_light_squared()
}

// ============================================================================
// Mathematical Constants (for convenience)
// ============================================================================

open const PI: f64 = 3.141_592_653_589_793;
open const E: f64 = 2.718_281_828_459_045;
open const GOLDEN_RATIO: f64 = 1.618_033_988_749_895;

// ============================================================================
// Tests
// ============================================================================

#[test]
@verified
fn test_speed_of_light() {
    assert_eq!(SPEED_OF_LIGHT, 299_792_458.0);
}

#[test]
@verified
fn test_mass_energy_equivalence() {
    let mass = 1.0;  // 1 kg
    let energy = mass_energy_equivalence(mass);
    
    // E = mc² = 1 * (3e8)² = 9e16 J
    assert((energy - 8.987_551_787e16).abs() < 1e10);
}

#[test]
@verified
fn test_planck_units() {
    let l_p = planck_length();
    let t_p = planck_time();
    
    // Planck length ~1.6e-35 m
    assert(l_p > 1.0e-36 && l_p < 2.0e-35);
    
    // Planck time ~5.4e-44 s
    assert(t_p > 5.0e-45 && t_p < 6.0e-44);
}

#[test]
@verified
fn test_schwarzschild_radius_sun() {
    let r_s = schwarzschild_radius(SOLAR_MASS);
    
    // Sun's Schwarzschild radius ~3 km
    assert(r_s > 2.9e3 && r_s < 3.0e3);
}
