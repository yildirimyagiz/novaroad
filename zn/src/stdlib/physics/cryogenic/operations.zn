            year: 2012
        }
    ]
}

// ============================================================================
// Tests & Examples
// ============================================================================

#[test]
fn test_thermal_noise_reduction() {
    let noise = ThermalNoiseReduction::new(4.2, 1e9, 50.0);
    
    let room_noise = noise.room_temp_noise_power();
    let cryo_noise = noise.cryo_noise_power();
    let reduction = noise.noise_reduction_factor();
    
    println("Room temp noise: {:.2e} W", room_noise);
    println("Cryo noise (4K): {:.2e} W", cryo_noise);
    println("Reduction factor: {:.1}x", reduction);
    println("Reduction (dB): {:.1} dB", noise.noise_reduction_db());
    
    // 4K should be ~70x less noise than 293K
    assert(reduction > 50.0);
}

#[test]
fn test_cryogenic_crystal() {
    let ppln_cryo = CryogenicCrystal::ppln_at_77k();
    
    let improvement = ppln_cryo.efficiency_improvement();
    
    println("PPLN at 77K vs 293K:");
    println("  d_eff improvement: {:.1}%", 
             (ppln_cryo.cryo_temp_deff / ppln_cryo.room_temp_deff - 1.0) * 100.0);
    println("  Absorption reduction: {:.1}x", 
             ppln_cryo.room_temp_absorption / ppln_cryo.cryo_temp_absorption);
    println("  Total efficiency improvement: {:.1}x", improvement);
    
    // Should see 1.5-2x improvement
    assert(improvement > 1.3);
}

#[test]
fn test_superconducting_detector() {
    let snspd = SuperconductingDetector::snspd();
    let sis = SuperconductingDetector::sis_mixer();
    
    println("SNSPD:");
    println("  NEP: {:.2e} W/√Hz", snspd.nep);
    println("  Min power (1s): {:.2e} W", snspd.minimum_detectable_power(1.0));
    
    println("\nSIS Mixer:");
    println("  NEP: {:.2e} W/√Hz", sis.nep);
    println("  Min power (1s): {:.2e} W", sis.minimum_detectable_power(1.0));
    
    // Test detection of weak signal
    let weak_signal = 1e-15;  // 1 fW
    println("\nCan detect 1 fW signal:");
    println("  SNSPD: {}", snspd.can_detect(weak_signal, 1.0));
    println("  SIS: {}", sis.can_detect(weak_signal, 1.0));
}

#[test]
fn test_complete_cryo_system() {
    let system = CryogenicIRGHzSystem::optimal_system();
    
    let improvement = system.total_improvement_factor();
    let base_eff = 1e-12;  // Room temperature baseline
    let cryo_eff = system.realistic_cryo_efficiency(base_eff);
    
    println("Cryogenic System Performance:");
    println("  Operating temperature: {:.1} K", system.operating_regime.temperature());
    println("  Total improvement: {:.1}x", improvement);
    println("  Base efficiency: {:.2e}", base_eff);
    println("  Cryo efficiency: {:.2e}", cryo_eff);
    println("  Improvement: {:.0}x", cryo_eff / base_eff);
    
    // Test body IR detection
    let body_ir = 500.0;  // 500 W
    let collection = 0.01;  // 1%
    let detectable = system.is_body_ir_detectable(
        body_ir,
        collection,
        cryo_eff,
        10.0  // 10 second integration
    );
    
    println("\nBody IR Detection:");
    println("  Body IR power: {:.0} W", body_ir);
    println("  Collected: {:.2} W", body_ir * collection);
    println("  GHz output: {:.2e} W", body_ir * collection * cryo_eff);
    println("  Detectable: {}", detectable);
}
