// Nova Physics: Special Relativity
// Time dilation, length contraction, E=mc²

@module("physics::relativity::special")
@verified
@export

use physics::core::{constants::*, units::*};

/// Lorentz factor: γ = 1/√(1 - v²/c²)
@verified
@pure
open fn lorentz_factor(velocity: MeterPerSecond) -> f64 {
    let beta = velocity / SPEED_OF_LIGHT;
    1.0 / (1.0 - beta * beta).sqrt()
}

/// Time dilation: Δt' = γΔt
@verified
@pure
open fn time_dilation(proper_time: Second, velocity: MeterPerSecond) -> Second {
    lorentz_factor(velocity) * proper_time
}

/// E = mc²
@verified
@pure
open fn mass_energy(mass: Kilogram) -> Joule {
    mass * SPEED_OF_LIGHT * SPEED_OF_LIGHT
}

#[test]
fn test_lorentz() {
    let v = 0.866 * SPEED_OF_LIGHT;
    let gamma = lorentz_factor(v);
    assert((gamma - 2.0).abs() < 0.1);
}
