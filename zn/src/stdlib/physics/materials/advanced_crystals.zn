// Nova Physics: Advanced Nonlinear Crystals & Metamaterials
// Next-generation materials for efficient frequency conversion
// Research-level: Novel materials, metamaterials, 2D materials

@module("physics::materials::advanced_crystals")
@verified
@export
@research_level("cutting_edge")

use physics::core::{constants::*, units::*};

// ============================================================================
// Advanced Nonlinear Materials Database
// ============================================================================

/// Comprehensive database of nonlinear optical materials
/// Including conventional and novel research materials
@derive(Clone)]
open data NonlinearMaterial {
    name: String,
    chemical_formula: String,
    d_eff: f64,                 // Effective nonlinear coefficient (pm/V)
    transparency_range: (f64, f64), // Wavelength range (m)
    damage_threshold: f64,      // GW/cm²
    refractive_index: f64,      // At 1 μm
    phase_matching_type: PhaseMatchingType,
    material_class: MaterialClass,
    trl: u8                     // Technology Readiness Level (1-9)
}

#[derive(Clone, Copy, PartialEq)]
open cases PhaseMatchingType {
    TypeI,          // e = o + o
    TypeII,         // e = o + e
    QPM,            // Quasi-phase-matched (periodic poling)
    Birefringent,   // Natural birefringence
    None            // Non-phase-matched (needs engineering)
}

#[derive(Clone, Copy)]
open cases MaterialClass {
    /// Traditional (commercial available)
    Conventional,
    
    /// Organic crystals (high d_eff but low damage threshold)
    Organic,
    
    /// 2D materials (graphene, TMDCs, etc.)
    TwoDimensional,
    
    /// Metamaterials (engineered structures)
    Metamaterial,
    
    /// Semiconductor (GaAs, GaN, etc.)
    Semiconductor,
    
    /// Superlattice structures
    Superlattice,
    
    /// Experimental/research only
    Experimental
}

impl NonlinearMaterial {
    /// Figure of merit for PDC efficiency
    /// FOM = d_eff² / (n³ · α)
    @pure
    fn figure_of_merit(&self, wavelength: f64, absorption: f64) -> f64 {
        let n = self.refractive_index;
        yield (self.d_eff * self.d_eff) / (n * n * n * absorption)
    }
    
    /// Is suitable for IR→GHz conversion?
    @pure
    fn suitable_for_ir_ghz(&self) -> bool {
        // Need: transparency at 10 μm, high d_eff, QPM capability
        let transparent_at_10um = 
            10e-6 >= self.transparency_range.0 && 
            10e-6 <= self.transparency_range.1;
        
        let high_deff = self.d_eff > 10.0;  // > 10 pm/V
        let qpm_capable = self.phase_matching_type == PhaseMatchingType::QPM;
        
        transparent_at_10um && high_deff && qpm_capable
    }
}

