// ============================================================================
// Metamaterials for Enhanced Nonlinearity
// ============================================================================

/// Metamaterial structures for engineered nonlinear response
/// Research: Can achieve effective d_eff >> natural materials
@research_citation("Nature Photonics, 2017")
open data NonlinearMetamaterial {
    structure_type: MetamaterialType,
    unit_cell_size: f64,        // nm
    effective_deff: f64,        // Can be very high
    bandwidth: f64,             // Hz (narrower than bulk)
    fabrication_method: String
}

#[derive(Clone, Copy)]
open cases MetamaterialType {
    /// Split-ring resonators
    SplitRing,
    
    /// Plasmonic nanostructures
    Plasmonic,
    
    /// Photonic crystals
    PhotonicCrystal,
    
    /// Epsilon-near-zero materials
    ENZ,
    
    /// Hyperbolic metamaterials
    Hyperbolic
}

impl NonlinearMetamaterial {
    /// Plasmonic metamaterial for enhanced SHG/PDC
    /// Research: Can achieve 1000x enhancement in localized field
    @pure
    fn plasmonic_enhancement() -> Self {
        Self {
            structure_type: MetamaterialType::Plasmonic,
            unit_cell_size: 100.0,  // 100 nm
            effective_deff: 1000.0,  // Effective (includes field enhancement)
            bandwidth: 10e12,       // 10 THz
            fabrication_method: "E-beam lithography + metal deposition".into()
        }
    }
    
    /// ENZ metamaterial for extreme nonlinearity
    /// Research: At ENZ point, χ⁽³⁾ can be enormous
    @research_citation("Science, 2018")
    @pure
    fn enz_metamaterial() -> Self {
        Self {
            structure_type: MetamaterialType::ENZ,
            unit_cell_size: 50.0,
            effective_deff: 5000.0,  // At resonance
            bandwidth: 1e12,        // 1 THz (narrow)
            fabrication_method: "ITO + metal multilayers".into()
        }
    }
}

// ============================================================================
// 2D Material Stacks (van der Waals heterostructures)
// ============================================================================

/// Stacked 2D materials for tailored nonlinearity
/// Research: TMDCs show giant nonlinear response
@research_citation("Nature Nanotechnology, 2015")
open data VanDerWaalsHeterostructure {
    layers: Vec<TwoDMaterial>,
    total_thickness: f64,       // nm
    twist_angle: f64,           // degrees (crucial for properties)
    effective_deff: f64
}

#[derive(Clone)]
open data TwoDMaterial {
    name: String,
    formula: String,
    thickness: f64,             // nm (typically 0.6-1 nm per layer)
    bandgap: f64,               // eV
    chi2: f64                   // Second-order susceptibility
}

impl VanDerWaalsHeterostructure {
    /// MoS2/WSe2 heterostructure
    @pure
    fn mos2_wse2_stack(num_layers: usize) -> Self {
        let mos2 = TwoDMaterial {
            name: "MoS2".into(),
            formula: "MoS2".into(),
            thickness: 0.65,
            bandgap: 1.8,
            chi2: 1000.0
        };
        
        var layers = Vec::new();
        each _ in 0..num_layers {
            layers.push(mos2.clone());
        }
        
        let total_thickness = (num_layers as f64) * 0.65;
        
        Self {
            layers,
            total_thickness,
            twist_angle: 0.0,
            effective_deff: 1000.0 * (num_layers as f64).sqrt()
        }
    }
    
    /// Magic angle twisted bilayer graphene
    /// Research: Shows exotic quantum properties
    @research_level("speculative")
    @pure
    fn magic_angle_graphene() -> Self {
        let graphene = TwoDMaterial {
            name: "Graphene".into(),
            formula: "C".into(),
            thickness: 0.34,
            bandgap: 0.0,  // Semimetal
            chi2: 10000.0  // Very high
        };
        
        Self {
            layers: [graphene.clone(), graphene],
            total_thickness: 0.68,
            twist_angle: 1.1,  // Magic angle
            effective_deff: 50000.0  // Speculative
        }
    }
}

// ============================================================================
// Material Selection Optimizer
// ============================================================================

/// Select best material for specific application
open data MaterialSelector {
    requirements: MaterialRequirements
}

open data MaterialRequirements {
    wavelength_range: (f64, f64),
    min_deff: f64,
    min_damage_threshold: f64,
    max_cost: f64,              // USD/cm³ (relative)
    min_trl: u8                 // Minimum technology readiness
}

impl MaterialSelector {
    @pure
    fn new(requirements: MaterialRequirements) -> Self {
        Self { requirements }
    }
    
    /// Find suitable materials from database
    fn find_candidates(&self) -> Vec<NonlinearMaterial> {
        let db = material_database();
        
        db.into_iter()
            .filter(|m| {
                // Check transparency range
                let transparent = 
                    m.transparency_range.0 <= self.requirements.wavelength_range.0 &&
                    m.transparency_range.1 >= self.requirements.wavelength_range.1;
                
                // Check d_eff
                let high_deff = m.d_eff >= self.requirements.min_deff;
                
                // Check damage threshold
                let robust = m.damage_threshold >= self.requirements.min_damage_threshold;
                
                // Check TRL
                let mature = m.trl >= self.requirements.min_trl;
                
                transparent && high_deff && robust && mature
            })
            .collect()
    }
    
    /// Rank materials by figure of merit
    fn rank_by_fom(&self, candidates: &var Vec<NonlinearMaterial>) {
        candidates.sort_by(|a, b| {
            let fom_a = a.figure_of_merit(10e-6, 0.1);
            let fom_b = b.figure_of_merit(10e-6, 0.1);
            fom_b.partial_cmp(&fom_a).unwrap()
        });
    }
}

// ============================================================================
// Research Frontiers
// ============================================================================

open data ResearchFrontier {
    topic: String,
    potential_deff: f64,
    challenges: Vec<String>,
    timeline: String
}

@const
open fn research_frontiers() -> Vec<ResearchFrontier> {
    [
        ResearchFrontier {
            topic: "Topological photonic crystals".into(),
            potential_deff: 100.0,
            challenges: [
                "Fabrication complexity".into(),
                "Integration with existing tech".into()
            ],
            timeline: "5-10 years".into()
        },
        ResearchFrontier {
            topic: "Quantum-enhanced nonlinearity".into(),
            potential_deff: 10000.0,
            challenges: [
                "Requires cryogenic operation".into(),
                "Limited to single-photon level".into()
            ],
            timeline: "10+ years".into()
        },
        ResearchFrontier {
            topic: "Ferroelectric domain engineering".into(),
            potential_deff: 50.0,
            challenges: [
                "Domain stability".into(),
                "Scaling to large crystals".into()
            ],
            timeline: "2-5 years".into()
        }
    ]
}

// ============================================================================
// Tests & Examples
// ============================================================================

#[test]
fn test_material_database() {
    let db = material_database();
    
    println("Nonlinear Materials Database ({} materials):\n", db.len());
    println("{:<20} {:<15} {:<15} {:<10}", "Material", "d_eff (pm/V)", "Transparency", "TRL");
    println("{}", "-".repeat(65));
    
    each mat in db.iter() {
        println("{:<20} {:<15.1} {:<15} {:<10}", 
                 mat.name,
                 mat.d_eff,
                 format("{:.1}-{:.1} μm", 
                         mat.transparency_range.0 * 1e6,
                         mat.transparency_range.1 * 1e6),
                 mat.trl);
    }
}

#[test]
fn test_material_selection() {
    let requirements = MaterialRequirements {
        wavelength_range: (8e-6, 14e-6),  // LWIR for body IR
        min_deff: 20.0,
        min_damage_threshold: 0.1,
        max_cost: 1000.0,
        min_trl: 5
    };
    
    let selector = MaterialSelector::new(requirements);
    var candidates = selector.find_candidates();
    
    println("\nMaterials suitable for IR→GHz conversion:");
    each mat in candidates.iter() {
        println("  {} (d_eff = {:.1} pm/V, TRL = {})", 
                 mat.name, mat.d_eff, mat.trl);
    }
    
    selector.rank_by_fom(&var candidates);
    
    check candidates.len() > 0 {
        println("\nBest candidate: {}", candidates[0].name);
    }
}

#[test]
fn test_metamaterials() {
    let plasmonic = NonlinearMetamaterial::plasmonic_enhancement();
    let enz = NonlinearMetamaterial::enz_metamaterial();
    
    println("Metamaterial Enhancement:");
    println("  Plasmonic: d_eff = {:.0} pm/V", plasmonic.effective_deff);
    println("  ENZ: d_eff = {:.0} pm/V", enz.effective_deff);
    
    // Compare to PPLN (25 pm/V)
    println("\nEnhancement vs PPLN:");
    println("  Plasmonic: {:.0}x", plasmonic.effective_deff / 25.0);
    println("  ENZ: {:.0}x", enz.effective_deff / 25.0);
}
