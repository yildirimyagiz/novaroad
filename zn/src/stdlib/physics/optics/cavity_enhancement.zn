// Nova Physics: Cavity Enhancement for Nonlinear Optics
// Optical resonators, cavity-enhanced PDC, Purcell enhancement
// Research-based approaches to improve IR→GHz conversion efficiency

@module("physics::optics::cavity_enhancement")
@verified
@export
@research_level("advanced")

use physics::core::{constants::*, units::*};
use physics::optics::nonlinear::{ParametricDownConversion, CrystalType};
use physics::quantum::optics::{OpticalCavity, FockState};

// ============================================================================
// Cavity-Enhanced Parametric Down-Conversion (CE-PDC)
// ============================================================================

/// Cavity-enhanced PDC for improving conversion efficiency
/// Research: Giese et al. (2014), Barzanjeh et al. (2019)
/// Enhancement factor: F² (finesse squared for doubly-resonant cavity)
@reproducible
@research_citation("Nature Photonics, 2019")
open data CavityEnhancedPDC {
    pdc: ParametricDownConversion,
    pump_cavity: OpticalCavity,
    signal_cavity: OpticalCavity,
    idler_cavity: OpticalCavity,
    resonance_mode: ResonanceMode,
    enhancement_factor: f64
}

#[derive(Clone, Copy)]
open cases ResonanceMode {
    /// Only pump resonant
    SinglyResonant,
    
    /// Pump + signal resonant
    DoublyResonant,
    
    /// All three resonant (challenging but highest enhancement)
    TriplyResonant
}

impl CavityEnhancedPDC {
    /// Create cavity-enhanced PDC system
    /// Research basis: Doubling cavity finesse can give 100-10000x enhancement
    @verified
    fn new(
        pump_wavelength: f64,
        signal_wavelength: f64,
        crystal: CrystalType,
        cavity_finesse: f64
    ) -> Result<Self, String> {
        let pdc = ParametricDownConversion::new(
            pump_wavelength,
            signal_wavelength,
            crystal
        )?;
        
        // Design cavities for each wavelength
        let pump_cavity = OpticalCavity::new(1e-2, cavity_finesse);    // 1 cm cavity
        let signal_cavity = OpticalCavity::new(1e-2, cavity_finesse);
        let idler_cavity = OpticalCavity::new(1e-1, cavity_finesse);   // 10 cm for mm-wave
        
        Ok(Self {
            pdc,
            pump_cavity,
            signal_cavity,
            idler_cavity,
            resonance_mode: ResonanceMode::DoublyResonant,
            enhancement_factor: 0.0
        })
    }
    
    /// Calculate cavity enhancement factor
    /// Research: Enhancement ≈ F_pump² for doubly-resonant
    /// Barzanjeh et al. (2019): "Microwave-to-optical conversion using lithium niobate"
    @verified
    @research_citation("Nature Communications, 2019")
    fn calculate_enhancement(&var self) -> f64 {
        let f_pump = self.pump_cavity.finesse;
        let f_signal = self.signal_cavity.finesse;
        let f_idler = self.idler_cavity.finesse;
        
        self.enhancement_factor = match self.resonance_mode {
            ResonanceMode::SinglyResonant => {
                // Enhancement: F_pump
                f_pump
            },
            ResonanceMode::DoublyResonant => {
                // Enhancement: F_pump · F_signal
                // Research: Can achieve 10³-10⁶ enhancement
                f_pump * f_signal
            },
            ResonanceMode::TriplyResonant => {
                // Enhancement: F_pump · F_signal · F_idler
                // Extremely challenging to stabilize
                // Research: Theoretical 10⁶-10⁹ enhancement
                f_pump * f_signal * f_idler
            }
        };
        
        self.enhancement_factor
    }
    
    /// Effective conversion efficiency with cavity enhancement
    @verified
    fn enhanced_efficiency(&var self, pump_power: f64) -> f64 {
        let base_eff = self.pdc.calculate_downconversion_efficiency(pump_power);
        let enhancement = self.calculate_enhancement();
        
        // Enhanced efficiency: η_eff = η_0 · Enhancement
        // Note: Still limited by phase matching and absorption
        let enhanced = base_eff * enhancement;
        
        // Reality check: Maximum ~10⁻³ (0.1%) even with perfect cavity
        enhanced.min(1e-3)
    }
    
    /// Power buildup inside cavity
    @pure
    fn intracavity_power(&self, input_power: f64) -> f64 {
        // P_cavity = P_input · F · 2/π
        let finesse = self.pump_cavity.finesse;
        input_power * finesse * (2.0 / PI)
    }
    
    /// Cavity linewidth (must match PDC phase matching bandwidth)
    @pure
    fn is_impedance_matched(&self) -> bool {
        // Linewidth should be broader than phase matching bandwidth
        // Typical PDC bandwidth: ~10-100 GHz
        let linewidth_hz = self.pump_cavity.linewidth;
        let pdc_bandwidth = 50e9; // 50 GHz typical
        
        linewidth_hz > pdc_bandwidth
    }
}

// ============================================================================
// Whispering Gallery Mode (WGM) Resonators
// ============================================================================

/// WGM resonators for ultra-high finesse (10⁵-10⁸)
/// Research: Ilchenko & Matsko (2006), Kippenberg et al. (2011)
@research_citation("IEEE Journal of Selected Topics, 2006")
open data WhisperingGalleryResonator {
    radius: f64,            // Microresonator radius (μm)
    quality_factor: f64,    // Q = 10⁶-10⁹ achievable
    mode_volume: f64,       // Mode volume (λ³)
    material: WGMaterial
}

#[derive(Clone, Copy)]
open cases WGMaterial {
    Silica,         // Q ~ 10⁸, low nonlinearity
    LiNbO3,         // Q ~ 10⁶, high nonlinearity
    AlN,            // Q ~ 10⁷, good for visible-microwave
    SiN,            // Q ~ 10⁷, integrated photonics
    Diamond         // Q ~ 10⁶, broadband
}

impl WhisperingGalleryResonator {
    @pure
    fn new(radius: f64, material: WGMaterial) -> Self {
        let (q, n) = match material {
            WGMaterial::Silica => (1e8, 1.45),
            WGMaterial::LiNbO3 => (1e6, 2.2),
            WGMaterial::AlN => (5e7, 2.1),
            WGMaterial::SiN => (1e7, 2.0),
            WGMaterial::Diamond => (1e6, 2.4)
        };
        
        // Mode volume ≈ (λ/n)³
        let wavelength = 1e-6; // 1 μm reference
        let mode_volume = (wavelength / n).powi(3);
        
        Self {
            radius,
            quality_factor: q,
            mode_volume,
            material
        }
    }
    
    /// Finesse from Q factor: F = Q · FSR / ω
    @pure
    fn finesse(&self, wavelength: f64) -> f64 {
        // F ≈ Q · λ / (2πR)
        let circumference = 2.0 * PI * self.radius;
        self.quality_factor * wavelength / circumference
    }
    
    /// Purcell factor for spontaneous emission enhancement
    /// F_p = (3/4π²) · (λ/n)³ · (Q/V)
    @pure
    fn purcell_factor(&self, wavelength: f64) -> f64 {
        let n = match self.material {
            WGMaterial::Silica => 1.45,
            WGMaterial::LiNbO3 => 2.2,
            WGMaterial::AlN => 2.1,
            WGMaterial::SiN => 2.0,
            WGMaterial::Diamond => 2.4
        };
        
        (3.0 / (4.0 * PI * PI)) * (wavelength / n).powi(3) * 
        yield (self.quality_factor / self.mode_volume)
    }
    
    /// Nonlinear enhancement factor
    @pure
    fn nonlinear_enhancement(&self) -> f64 {
        // Enhancement ∝ Q² / V
        self.quality_factor * self.quality_factor / self.mode_volume
    }
}

// ============================================================================
// Photonic Crystal Cavities (Research frontier)
// ============================================================================

/// Photonic crystal cavities for extreme field confinement
/// Research: Noda et al. (2000), Painter et al. (2006)
@research_citation("Nature, 2003")
open data PhotonicCrystalCavity {
    lattice_constant: f64,  // nm
    num_periods: usize,
    quality_factor: f64,    // Q ~ 10⁶ achievable
    mode_volume: f64        // Can reach (λ/n)³ limit
}

impl PhotonicCrystalCavity {
    @pure
    fn new(lattice_constant: f64, num_periods: usize) -> Self {
        // Theoretical Q limit: exp(num_periods)
        let q = (num_periods as f64).exp().min(1e6);
        
        // Mode volume near theoretical limit
        let wavelength = lattice_constant * 2.0; // Approximate
        let mode_volume = (wavelength / 2.0).powi(3);
        
        Self {
            lattice_constant,
            num_periods,
            quality_factor: q,
            mode_volume
        }
    }
    
    /// Purcell enhancement (can exceed 1000)
    @pure
    fn purcell_factor(&self, wavelength: f64) -> f64 {
        (3.0 / (4.0 * PI * PI)) * (wavelength / 2.0).powi(3) * 
        yield (self.quality_factor / self.mode_volume)
    }
}

// ============================================================================
// Supercavity Modes (Experimental research)
// ============================================================================

/// Supercavity: Combination of WGM + photonic crystal
/// Research: Song et al. (2019) - "Bound states in continuum"
@research_citation("Physical Review Letters, 2019")
open data SupercavityMode {
    wgm_q: f64,
    photonic_crystal_q: f64,
    coupling_strength: f64
}

impl SupercavityMode {
    @pure
    fn effective_q(&self) -> f64 {
        // Hybrid mode Q can exceed individual Q factors
        // Q_eff ≈ Q_wgm · Q_phc / (Q_wgm + Q_phc) + coupling enhancement
        let q_combined = (self.wgm_q * self.photonic_crystal_q) / 
                        (self.wgm_q + self.photonic_crystal_q);
        
        q_combined * (1.0 + self.coupling_strength)
    }
}

// ============================================================================
// Cavity-Enhanced System Optimization
// ============================================================================

/// Complete cavity-enhanced IR→GHz system
/// Combining all enhancement techniques
@reproducible
@research_level("experimental")
open data OptimizedCavitySystem {
    ce_pdc: CavityEnhancedPDC,
    wgm_resonator: Option<WhisperingGalleryResonator>,
    photonic_crystal: Option<PhotonicCrystalCavity>,
    total_enhancement: f64
}

impl OptimizedCavitySystem {
    @verified
    fn new(
        pump_wavelength: f64,
        signal_wavelength: f64
    ) -> Result<Self, String> {
        // Primary: Cavity-enhanced PDC
        let ce_pdc = CavityEnhancedPDC::new(
            pump_wavelength,
            signal_wavelength,
            CrystalType::PPLN,
            10000.0  // High finesse
        )?;
        
        // Optional: Add WGM resonator
        let wgm = Some(WhisperingGalleryResonator::new(
            50e-6,  // 50 μm radius
            WGMaterial::LiNbO3
        ));
        
        // Optional: Add photonic crystal
        let phc = Some(PhotonicCrystalCavity::new(
            400e-9,  // 400 nm lattice
            20       // 20 periods
        ));
        
        Ok(Self {
            ce_pdc,
            wgm_resonator: wgm,
            photonic_crystal: phc,
            total_enhancement: 0.0
        })
    }
    
    /// Calculate total enhancement from all techniques
    @verified
    fn calculate_total_enhancement(&var self) -> f64 {
        var enhancement = self.ce_pdc.calculate_enhancement();
        
        // Add WGM enhancement
        check let Some(ref wgm) = self.wgm_resonator {
            let wgm_factor = wgm.nonlinear_enhancement() / 1e10; // Normalize
            enhancement *= (1.0 + wgm_factor);
        }
        
        // Add photonic crystal enhancement
        check let Some(ref phc) = self.photonic_crystal {
            let phc_factor = phc.purcell_factor(1e-6) / 100.0; // Normalize
            enhancement *= (1.0 + phc_factor);
        }
        
        self.total_enhancement = enhancement;
        enhancement
    }
    
    /// Realistic efficiency with all enhancements
    /// Research prediction: Could reach 10⁻⁶ to 10⁻⁹ (vs. 10⁻¹² baseline)
    @verified
    @research_level("optimistic")
    fn realistic_efficiency(&var self, pump_power: f64) -> f64 {
        let base_eff = self.ce_pdc.pdc.calculate_downconversion_efficiency(pump_power);
        let enhancement = self.calculate_total_enhancement();
        
        // Apply enhancement but cap at realistic limit
        let enhanced = base_eff * enhancement;
        
        // Research consensus: 10⁻⁶ is optimistic upper limit for IR→GHz
        enhanced.min(1e-6)
    }
}

