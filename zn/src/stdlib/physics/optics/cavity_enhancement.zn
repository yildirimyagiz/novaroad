        ResearchReference {
            title: "Cavity quantum electrodynamics".into(),
            authors: "Haroche & Raimond".into(),
            journal: "Nature Physics".into(),
            year: 2020,
            doi: "10.1038/s41567-020-0812-1".into(),
            key_result: "Fundamental limits of cavity enhancement: F² improvement".into()
        },
        ResearchReference {
            title: "Efficient microwave to optical photon conversion".into(),
            authors: "Andrews et al.".into(),
            journal: "Nature Physics".into(),
            year: 2014,
            doi: "10.1038/nphys2911".into(),
            key_result: "Achieved 10⁻⁵ efficiency using cavity-enhanced PDC".into()
        },
        ResearchReference {
            title: "Whispering gallery mode resonators".into(),
            authors: "Ilchenko & Matsko".into(),
            journal: "IEEE Journal".into(),
