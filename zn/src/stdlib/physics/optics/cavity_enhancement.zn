            doi: "10.1109/JSTQE.2005.862943".into(),
            key_result: "Q factors exceeding 10⁸ demonstrated in silica".into()
        }
    ]
}

// ============================================================================
// Tests & Examples
// ============================================================================

#[test]
fn test_cavity_enhanced_pdc() {
    var ce_pdc = CavityEnhancedPDC::new(
        10e-6,   // 10 μm IR
        5e-6,    // 5 μm signal
        CrystalType::PPLN,
        10000.0  // High finesse
    ).unwrap();
    
    ce_pdc.resonance_mode = ResonanceMode::DoublyResonant;
    
    let enhancement = ce_pdc.calculate_enhancement();
    let base_eff = ce_pdc.pdc.calculate_downconversion_efficiency(1e-3);
    let enhanced_eff = ce_pdc.enhanced_efficiency(1e-3);
    
    println("Cavity enhancement factor: {:.2e}", enhancement);
    println("Base efficiency: {:.2e}", base_eff);
    println("Enhanced efficiency: {:.2e}", enhanced_eff);
    println("Improvement: {:.1}x", enhanced_eff / base_eff);
    
    // Should see 10⁴-10⁶ enhancement for doubly-resonant
    assert(enhancement > 1e4);
    assert(enhanced_eff > base_eff * 1000.0);
}

#[test]
fn test_wgm_resonator() {
    let wgm = WhisperingGalleryResonator::new(50e-6, WGMaterial::LiNbO3);
    
    let finesse = wgm.finesse(1e-6);
    let purcell = wgm.purcell_factor(1e-6);
    
    println("WGM Q factor: {:.2e}", wgm.quality_factor);
    println("WGM finesse: {:.2e}", finesse);
    println("Purcell factor: {:.1}", purcell);
    
    assert(wgm.quality_factor > 1e5);
}

#[test]
fn test_optimized_system() {
    var system = OptimizedCavitySystem::new(10e-6, 5e-6).unwrap();
    
    let total_enhancement = system.calculate_total_enhancement();
    let realistic_eff = system.realistic_efficiency(1e-3);
    
    println("Total enhancement: {:.2e}", total_enhancement);
    println("Realistic efficiency: {:.2e}", realistic_eff);
    println("Output power (1mW pump): {:.2e} W", 1e-3 * realistic_eff);
    
    // With all techniques: could reach 10⁻⁶ to 10⁻⁹
    assert(realistic_eff > 1e-9);
}
