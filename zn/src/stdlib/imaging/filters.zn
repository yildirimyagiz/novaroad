// Image Filters and Transformations
// Blur, Sharpen, Edge Detection, Color Adjustments

use imaging::core::{Image, Pixel, ImageMode}

// ===== Convolution Filters =====

open fn blur(image: &Image, radius: f64) -> Image {
    let kernel = gaussian_kernel(radius);
    convolve(image, &kernel)
}

open fn sharpen(image: &Image, amount: f64) -> Image {
    let kernel = [
        [0.0, -amount, 0.0],
        [-amount, 1.0 + 4.0 * amount, -amount],
        [0.0, -amount, 0.0],
    ];
    convolve(image, &kernel)
}

open fn edge_detect(image: &Image) -> Image {
    let kernel = [
        [-1.0, -1.0, -1.0],
        [-1.0,  8.0, -1.0],
        [-1.0, -1.0, -1.0],
    ];
    convolve(image, &kernel)
}

open fn emboss(image: &Image) -> Image {
    let kernel = [
        [-2.0, -1.0, 0.0],
        [-1.0,  1.0, 1.0],
        [ 0.0,  1.0, 2.0],
    ];
    convolve(image, &kernel)
}

// ===== Color Adjustments =====

open fn brightness(image: &Image, factor: f64) -> Image {
    var result = image.clone();
    each y in 0..image.height {
        each x in 0..image.width {
            let pixel = image.get_pixel(x, y);
            let new_pixel = Pixel::rgb(
                clamp((pixel.r as f64 * factor) as u8),
                clamp((pixel.g as f64 * factor) as u8),
                clamp((pixel.b as f64 * factor) as u8),
            );
            result.set_pixel(x, y, new_pixel);
        }
    }
    result
}

open fn contrast(image: &Image, factor: f64) -> Image {
    var result = image.clone();
    each y in 0..image.height {
        each x in 0..image.width {
            let pixel = image.get_pixel(x, y);
            let new_pixel = Pixel::rgb(
                clamp(((pixel.r as f64 - 128.0) * factor + 128.0) as u8),
                clamp(((pixel.g as f64 - 128.0) * factor + 128.0) as u8),
                clamp(((pixel.b as f64 - 128.0) * factor + 128.0) as u8),
            );
            result.set_pixel(x, y, new_pixel);
        }
    }
    result
}

open fn saturation(image: &Image, factor: f64) -> Image {
    var result = image.clone();
    each y in 0..image.height {
        each x in 0..image.width {
            let pixel = image.get_pixel(x, y);
            let gray = (pixel.r as f64 * 0.299 + pixel.g as f64 * 0.587 + pixel.b as f64 * 0.114);
            
            let new_pixel = Pixel::rgb(
                clamp((gray + (pixel.r as f64 - gray) * factor) as u8),
                clamp((gray + (pixel.g as f64 - gray) * factor) as u8),
                clamp((gray + (pixel.b as f64 - gray) * factor) as u8),
            );
            result.set_pixel(x, y, new_pixel);
        }
    }
    result
}

open fn grayscale(image: &Image) -> Image {
    var result = Image::new(image.width, image.height, ImageMode::L);
    each y in 0..image.height {
        each x in 0..image.width {
            let pixel = image.get_pixel(x, y);
            let gray = (pixel.r as f64 * 0.299 + pixel.g as f64 * 0.587 + pixel.b as f64 * 0.114) as u8;
            result.set_pixel(x, y, Pixel::rgb(gray, gray, gray));
        }
    }
    result
}

open fn invert(image: &Image) -> Image {
    var result = image.clone();
    each y in 0..image.height {
        each x in 0..image.width {
            let pixel = image.get_pixel(x, y);
            result.set_pixel(x, y, Pixel::rgb(255 - pixel.r, 255 - pixel.g, 255 - pixel.b));
        }
    }
    result
}

// ===== Helper Functions =====

fn convolve(image: &Image, kernel: &[[f64; 3]; 3]) -> Image {
    var result = image.clone();
    
    each y in 1..image.height - 1 {
        each x in 1..image.width - 1 {
            var r_sum = 0.0;
            var g_sum = 0.0;
            var b_sum = 0.0;
            
            each ky in 0..3 {
                each kx in 0..3 {
                    let pixel = image.get_pixel(x + kx - 1, y + ky - 1);
                    let k = kernel[ky][kx];
                    r_sum += pixel.r as f64 * k;
                    g_sum += pixel.g as f64 * k;
                    b_sum += pixel.b as f64 * k;
                }
            }
            
            result.set_pixel(x, y, Pixel::rgb(
                clamp(r_sum as u8),
                clamp(g_sum as u8),
                clamp(b_sum as u8),
            ));
        }
    }
    
    result
}

fn gaussian_kernel(radius: f64) -> [[f64; 3]; 3] {
    let sigma = radius / 2.0;
    var kernel = [[0.0; 3]; 3];
    var sum = 0.0;
    
    each y in 0..3 {
        each x in 0..3 {
            let dx = x as f64 - 1.0;
            let dy = y as f64 - 1.0;
            let value = (-((dx * dx + dy * dy) / (2.0 * sigma * sigma))).exp();
            kernel[y][x] = value;
            sum += value;
        }
    }
    
    // Normalize
    each y in 0..3 {
        each x in 0..3 {
            kernel[y][x] /= sum;
        }
    }
    
    kernel
}

fn clamp(value: u8) -> u8 {
    value.max(0).min(255)
}
