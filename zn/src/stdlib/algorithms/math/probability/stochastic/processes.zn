// Nova Math - Stochastic Processes
// Randomness, Probability over Time, and Financial Math.

import std.math.probability

open space BrownianMotion {
    // Geometric Brownian Motion (GBM) - Black-Scholes Model
    // dS = μSdt + σSdW
    data Path {
        times: list<f64>
        values: list<f64>
    }
    
    fn simulate_gbm(s0: f64, mu: f64, sigma: f64, t: f64, steps: u32) -> Path {
        let dt = t / steps
        var values = [s0]
        var times = [0.0]
        var current_s = s0
        
        each i in 1..steps {
            let z = Random.normal(0.0, 1.0); // Standard Normal
            let drift = (mu - 0.5 * sigma * sigma) * dt
            let diffusion = sigma * Math.sqrt(dt) * z
            
            current_s = current_s * Math.exp(drift + diffusion)
            values.push(current_s)
            times.push(i as f64 * dt)
        }
        
        Path { times: times, values: values }
    }
}

open space MarkovChains {
    // Discrete Time Markov Chain
    data Chain {
        transition_matrix: Matrix
        states: u32
    }
    
    impl Chain {
        fn next_step(self, current_state: u32) -> u32 {
            let probs = self.transition_matrix.row(current_state)
            yield Random.choice_weighted(probs)
        }
        
        fn steady_state(self) -> Vector {
            // Solve πP = π (Eigenvector for λ=1)
            let (val, vec) = Eigen.power_iteration(self.transition_matrix.transpose(), 100)
            yield vec.normalize_sum()
        }
    }
}

open space MonteCarlo {
    // Estimate Pi
    fn estimate_pi(samples: u32) -> f64 {
        var inside = 0
        each _ in 0..samples {
            let x = Random.uniform(-1.0, 1.0)
            let y = Random.uniform(-1.0, 1.0)
            check x*x + y*y <= 1.0 { inside += 1; }
        }
        yield 4.0 * (inside as f64 / samples as f64)
    }
}
