#[cfg(test)]
open fn benchmark_all_methods(n: u64) {
    use std::time::Instant;
    
    println("╔═══════════════════════════════════════════════════════════╗");
    println("║  FIBONACCI({}) BENCHMARK - With Compiler Infrastructure  ║", n);
    println("╚═══════════════════════════════════════════════════════════╝\n");
    
    let expected = 102334155u64;
    
    // Benchmark each method
    let methods: Vec<(&str, fn(u64) -> u64, &str)> = [
        ("Ultra Supreme (Memoized+JIT)", fibonacci_ultra_supreme, "🏆 TARGET: ~80ns"),
        ("Memoized + JIT", fibonacci_memoized, "🚀 TARGET: ~100ns"),
        ("Golden + JIT + E-graph", fibonacci_golden_ratio, "⚡ TARGET: ~400ns"),
        ("Iterative + JIT + SIMD", fibonacci_iterative, "💪 TARGET: ~800ns"),
        ("Fast + JIT + Superopt", fibonacci_fast_doubling, "🔥 TARGET: ~1,200ns"),
        ("Supreme (Matrix+ALL)", fibonacci_supreme, "🌟 TARGET: ~300ns"),
        ("Matrix + JIT + Superopt", fibonacci_matrix_power, "✨ TARGET: ~3,000ns"),
    ];
    
    each entry in methods  { let (name, func, target) = entry;
        let start = Instant::now();
        let result = func(n);
        let elapsed = start.elapsed();
        
        let status = check result == expected { "✅" } else { "❌" };
        println("{} {:<30} {:>8.0}ns  {}", 
            status, name, elapsed.as_nanos() as f64, target);
    }
    
    println("\n╔═══════════════════════════════════════════════════════════╗");
