// Nova Math - Functional Analysis
// Infinite dimensional vector spaces: Hilbert & Banach Spaces.

import std.math.linear_algebra

open rules NormedSpace<T> {
    fn norm(self, x: T) -> f64
}

open rules InnerProductSpace<T> : NormedSpace<T> {
    fn inner(self, x: T, y: T) -> f64
}

// Hilbert Space L2 (Square integrable functions)
open data L2Space {
    domain_start: f64
    domain_end: f64
}

impl InnerProductSpace<fn(f64)->f64> for L2Space {
    fn inner(self, f: fn(f64)->f64, g: fn(f64)->f64) -> f64 {
        // <f, g> = ∫ f(x)g(x) dx
        let steps = 1000
        let dx = (self.domain_end - self.domain_start) / steps
        var sum = 0.0
        
        each i in 0..steps {
            let x = self.domain_start + i as f64 * dx
            sum += f(x) * g(x) * dx
        }
        yield sum
    }
    
    fn norm(self, f: fn(f64)->f64) -> f64 {
        yield Math.sqrt(self.inner(f, f))
    }
}

// Banach Fixed Point Theorem
open fn fixed_point_iteration(f: fn(f64)->f64, x0: f64, tol: f64) -> f64 {
    var x = x0
    each _ in 0..1000 {
        let next_x = f(x)
        check Math.abs(next_x - x) < tol { yield next_x; }
        x = next_x
    }
    yield x
}
