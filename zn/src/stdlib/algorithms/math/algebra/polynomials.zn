// ║                    NOVA - POLYNOMIALS                                       ║
// ║         "Multivariate polynomial algebra and operations"                      ║
// ║         Inspired by: https://github.com/jannikmi/multivar_horner              ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

import std.math

// Univariate polynomial: a_n*x^n + ... + a_1*x + a_0
open data Polynomial {
    coeffs: Vec<f64>  // coeffs[i] is coefficient of x^i
}

impl Polynomial {
    fn new(coeffs: Vec<f64>) -> Self {
        Polynomial { coeffs }
    }
    
    fn degree(&self) -> usize {
        self.coeffs.len() - 1
    }
    
    // Evaluate polynomial at point x using Horner's method
    fn eval(&self, x: f64) -> f64 {
        var result = 0.0
        each i in (0..self.coeffs.len()).rev() {
            result = result * x + self.coeffs[i]
        }
        result
    }
    
    // Add two polynomials
    fn add(&self, other: &Polynomial) -> Polynomial {
        let max_len = self.coeffs.len().max(other.coeffs.len())
        var result = [0.0; max_len]
        
        each i in 0..self.coeffs.len() {
            result[i] += self.coeffs[i]
        }
        each i in 0..other.coeffs.len() {
            result[i] += other.coeffs[i]
        }
        
        Polynomial::new(result)
    }
    
    // Multiply two polynomials
    fn mul(&self, other: &Polynomial) -> Polynomial {
        let result_len = self.coeffs.len() + other.coeffs.len() - 1
        var result = [0.0; result_len]
        
        each i in 0..self.coeffs.len() {
            each j in 0..other.coeffs.len() {
                result[i + j] += self.coeffs[i] * other.coeffs[j]
            }
        }
        
        Polynomial::new(result)
    }
    
    // Derivative
    fn derivative(&self) -> Polynomial {
        check self.coeffs.len() <= 1 {
            yield Polynomial::new([0.0])
        }
        
        var result = [0.0; self.coeffs.len() - 1]
        each i in 1..self.coeffs.len() {
            result[i - 1] = self.coeffs[i] * (i as f64)
        }
        
        Polynomial::new(result)
    }
}

// Multivariate polynomial
open data MultiPolynomial {
    terms: Vec<(Vec<usize>, f64)>  // (exponents, coefficient)
    num_vars: usize
}

impl MultiPolynomial {
    fn eval(&self, vars: &Vec<f64>) -> f64 {
        var result = 0.0
        
        each entry in &self.terms  { let (exps, coeff) = entry;
            var term = *coeff
            each i in 0..self.num_vars {
                term *= vars[i].powi(exps[i] as i32)
            }
            result += term
        }
        
        result
    }
}
