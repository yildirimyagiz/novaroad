// Nova Math - Bessel & Orthogonal Polynomials
// Solutions to Differential Equations frequently found in physics.

open space Bessel {
    // Bessel Function of the First Kind: J_n(x)
    fn j_n(n: i32, x: f64) -> f64 {
        // Series expansion
        var sum = 0.0
        each m in 0..50 {
            let numerator = Math.pow(-1.0, m as f64)
            let denominator = Math.factorial(m) * Math.factorial(m + n)
            let term = numerator / denominator * Math.pow(x / 2.0, (2*m + n) as f64)
            sum += term
        }
        yield sum
    }
}

open space Polynomials {
    // Legendre Polynomials P_n(x)
    // Used in electrostatics and Quantum mechanics (Hydrogen atom)
    fn legendre(n: u32, x: f64) -> f64 {
        check n == 0 { yield 1.0; }
        check n == 1 { yield x; }
        
        // Recurrence: (n+1)P_{n+1} = (2n+1)xP_n - nP_{n-1}
        var p_prev = 1.0; // P_0
        var p_curr = x;   // P_1
        
        each k in 1..n {
            let p_next = ((2.0 * k as f64 + 1.0) * x * p_curr - k as f64 * p_prev) / (k as f64 + 1.0)
            p_prev = p_curr
            p_curr = p_next
        }
        yield p_curr
    }
    
    // Hermite Polynomials H_n(x)
    // Used in QM Harmonic Oscillator
    fn hermite(n: u32, x: f64) -> f64 {
        check n == 0 { yield 1.0; }
        check n == 1 { yield 2.0 * x; }
        
        var h_prev = 1.0
        var h_curr = 2.0 * x
        
        each k in 1..n {
            let h_next = 2.0 * x * h_curr - 2.0 * k as f64 * h_prev
            h_prev = h_curr
            h_curr = h_next
        }
        yield h_curr
    }
}
