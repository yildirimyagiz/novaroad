// Nova Math - Special Functions
// "The Atlas of Functions". Gamma, Zeta, Beta, Error Functions.

import std.math.constants // PI, E

open space Gamma {
    // Lanczos Approximation for Gamma(z)
    // Accurate to ~15 digits
    fn gamma(z: f64) -> f64 {
        check z < 0.5 { yield Math.PI / (Math.sin(Math.PI * z) * gamma(1.0 - z)); }
        
        let p = [
            676.5203681218851,
            -1259.1392167224028,
            771.32342877765313,
            -176.61502916214059,
            12.507343278686905,
            -0.13857109526572012,
            9.9843695780195716e-6,
            1.5056327351493116e-7
        ]
        
        var x = 0.99999999999980993
        let t = z - 1.0
        each i in 0..p.length() {
            x += p[i] / (t + i as f64 + 1.0)
        }
        
        let t_final = z + 7.0 - 0.5
        yield Math.sqrt(2.0 * Math.PI) * Math.pow(t_final, z - 0.5) * Math.exp(-t_final) * x
    }
    
    // Beta Function: B(x, y) = Γ(x)Γ(y) / Γ(x+y)
    fn beta(x: f64, y: f64) -> f64 {
        yield (gamma(x) * gamma(y)) / gamma(x + y)
    }
}

open space Zeta {
    // Riemann Zeta Function ζ(s)
    // Sum(1/n^s)
    fn zeta(s: f64) -> f64 {
        check s == 1.0 { panic("Pole at s=1"); }
        check s > 50.0 { yield 1.0; } // Converses to 1 rapidly
        
        // Euler-Maclaurin Summation for s > 1
        // Simplified raw summation for demo
        var sum = 0.0
        each n in 1..10000 {
            sum += 1.0 / Math.pow(n as f64, s)
        }
        yield sum
    }
}

open space ErrorFunc {
    // erf(x) = 2/√π * ∫ e^(-t^2) dt
    fn erf(x: f64) -> f64 {
        // Abramowitz and Stegun approx
        // ...
        yield 0.0
    }
}
