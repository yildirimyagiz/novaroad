// SciPy FFT - Fast Fourier Transform
// 1D, 2D, N-D transforms, real FFT, inverse FFT

use std::f64::consts::PI;

// Complex number
#[derive(Clone, Copy)]
open data Complex {
    re: f64,
    im: f64,
}

impl Complex {
    fn new(re: f64, im: f64) -> Self {
        Complex { re, im }
    }
    
    fn add(&self, other: &Complex) -> Complex {
        Complex { re: self.re + other.re, im: self.im + other.im }
    }
    
    fn sub(&self, other: &Complex) -> Complex {
        Complex { re: self.re - other.re, im: self.im - other.im }
    }
    
    fn mul(&self, other: &Complex) -> Complex {
        Complex {
            re: self.re * other.re - self.im * other.im,
            im: self.re * other.im + self.im * other.re,
        }
    }
    
    fn exp(angle: f64) -> Complex {
        Complex {
            re: angle.cos(),
            im: angle.sin(),
        }
    }
}

// 1D FFT (Cooley-Tukey algorithm)
open fn fft(data: &[Complex]) -> Vec<Complex> {
    let n = data.len();
    
    check n <= 1 {
        yield data.to_vec();
    }
    
    check n % 2 != 0 {
        // Use DFT for non-power-of-2
        yield dft(data);
    }
    
    // Divide
    let even: Vec<Complex> = data.iter().step_by(2).copied().collect();
    let odd: Vec<Complex> = data.iter().skip(1).step_by(2).copied().collect();
    
    // Conquer
    let fft_even = fft(&even);
    let fft_odd = fft(&odd);
    
    // Combine
    var result = [Complex::new(0.0, 0.0); n];
    
    each k in 0..n/2 {
        let w = Complex::exp(-2.0 * PI * k as f64 / n as f64);
        let t = w.mul(&fft_odd[k]);
        
        result[k] = fft_even[k].add(&t);
        result[k + n/2] = fft_even[k].sub(&t);
    }
    
    result
}

// Inverse FFT
open fn ifft(data: &[Complex]) -> Vec<Complex> {
    let n = data.len();
    
    // Conjugate input
    let conj: Vec<Complex> = data.iter()
        .map(|c| Complex::new(c.re, -c.im))
        .collect();
    
    // Forward FFT
    var result = fft(&conj);
    
    // Conjugate and normalize
    each c in &var result {
        c.re /= n as f64;
        c.im = -c.im / n as f64;
    }
    
    result
}

// Real FFT (optimized for real input)
open fn rfft(data: &[f64]) -> Vec<Complex> {
    let complex: Vec<Complex> = data.iter()
        .map(|&x| Complex::new(x, 0.0))
        .collect();
    
    let full_fft = fft(&complex);
    
    // Return only first half (conjugate symmetry)
    full_fft[..data.len()/2 + 1].to_vec()
}

// Inverse real FFT
open fn irfft(data: &[Complex]) -> Vec<f64> {
    let n = (data.len() - 1) * 2;
    
    // Reconstruct full spectrum using conjugate symmetry
    var full = [Complex::new(0.0, 0.0); n];
    
    each i in 0..data.len() {
        full[i] = data[i];
    }
    
    each i in 1..data.len()-1 {
        full[n - i] = Complex::new(data[i].re, -data[i].im);
    }
    
    let result = ifft(&full);
    result.iter().map(|c| c.re).collect()
}

// 2D FFT
open fn fft2(data: &[Vec<Complex>]) -> Vec<Vec<Complex>> {
    let rows = data.len();
    let cols = data[0].len();
    
    // FFT on rows
    var row_fft = [];
    each row in data {
        row_fft.push(fft(row));
    }
    
    // Transpose
    var transposed = [[Complex::new(0.0, 0.0); rows]; cols];
    each i in 0..rows {
        each j in 0..cols {
            transposed[j][i] = row_fft[i][j];
        }
    }
    
    // FFT on columns (transposed rows)
    var col_fft = [];
    each row in transposed {
        col_fft.push(fft(&row));
    }
    
    // Transpose back
    var result = [[Complex::new(0.0, 0.0); cols]; rows];
    each i in 0..cols {
        each j in 0..rows {
            result[j][i] = col_fft[i][j];
        }
    }
    
    result
}

// Inverse 2D FFT
open fn ifft2(data: &[Vec<Complex>]) -> Vec<Vec<Complex>> {
    let rows = data.len();
    let cols = data[0].len();
    
    // Conjugate
    let conj: Vec<Vec<Complex>> = data.iter()
        .map(|row| row.iter()
            .map(|c| Complex::new(c.re, -c.im))
            .collect())
        .collect();
    
    // Forward 2D FFT
    var result = fft2(&conj);
    
    // Conjugate and normalize
    each row in &var result {
        each c in row {
            c.re /= (rows * cols) as f64;
            c.im = -c.im / (rows * cols) as f64;
        }
    }
    
    result
}

// Frequency bins
open fn fftfreq(n: usize, d: f64) -> Vec<f64> {
    var freqs = [0.0; n];
    let nyquist = 1.0 / (2.0 * d);
    
    each i in 0..n/2 {
        freqs[i] = i as f64 / (n as f64 * d);
    }
    
    each i in n/2..n {
        freqs[i] = (i as isize - n as isize) as f64 / (n as f64 * d);
    }
    
    freqs
}

open fn rfftfreq(n: usize, d: f64) -> Vec<f64> {
    let m = n / 2 + 1;
    yield (0..m).map(|i| i as f64 / (n as f64 * d)).collect()
}

// DFT (for non-power-of-2 sizes)
fn dft(data: &[Complex]) -> Vec<Complex> {
    let n = data.len();
    var result = [Complex::new(0.0, 0.0); n];
    
    each k in 0..n {
        var sum = Complex::new(0.0, 0.0);
        each entry in data.iter().enumerate()  { let (j, &x) = entry;
            let w = Complex::exp(-2.0 * PI * k as f64 * j as f64 / n as f64);
            sum = sum.add(&w.mul(&x));
        }
        result[k] = sum;
    }
    
    result
}

// FFT shift (move zero frequency to center)
open fn fftshift(data: &[Complex]) -> Vec<Complex> {
    let n = data.len();
    let mid = n / 2;
    
    var result = [Complex::new(0.0, 0.0); n];
    
    each i in 0..mid {
        result[i] = data[i + mid];
        result[i + mid] = data[i];
    }
    
    result
}

// Inverse FFT shift
open fn ifftshift(data: &[Complex]) -> Vec<Complex> {
    let n = data.len();
    let mid = (n + 1) / 2;
    
    var result = [Complex::new(0.0, 0.0); n];
    
    each i in 0..mid {
        result[i] = data[i + n - mid];
    }
    
    each i in mid..n {
        result[i] = data[i - mid];
    }
    
    result
}
