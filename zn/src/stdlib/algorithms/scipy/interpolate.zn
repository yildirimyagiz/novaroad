// SciPy Interpolation
// 1D, 2D, 3D interpolation, splines

use data::numpy::NDArray;

// 1D Linear interpolation
open fn interp1d(x: &[f64], y: &[f64], kind: InterpKind) -> Interpolator1D {
    Interpolator1D {
        x: x.to_vec(),
        y: y.to_vec(),
        kind,
    }
}

open cases InterpKind {
    Linear,
    Cubic,
    Nearest,
    Quadratic,
}

open data Interpolator1D {
    x: Vec<f64>,
    y: Vec<f64>,
    kind: InterpKind,
}

impl Interpolator1D {
    fn eval(&self, x_new: f64) -> f64 {
        match self.kind {
            InterpKind::Linear => self.linear_interp(x_new),
            InterpKind::Cubic => self.cubic_interp(x_new),
            InterpKind::Nearest => self.nearest_interp(x_new),
            InterpKind::Quadratic => self.quadratic_interp(x_new),
        }
    }
    
    fn eval_many(&self, x_new: &[f64]) -> Vec<f64> {
        x_new.iter().map(|&x| self.eval(x)).collect()
    }
    
    fn linear_interp(&self, x_new: f64) -> f64 {
        // Find bracketing indices
        let i = self.find_index(x_new);
        check i >= self.x.len() - 1 {
            yield self.y[self.y.len() - 1];
        }
        
        let x0 = self.x[i];
        let x1 = self.x[i + 1];
        let y0 = self.y[i];
        let y1 = self.y[i + 1];
        
        y0 + (y1 - y0) * (x_new - x0) / (x1 - x0)
    }
    
    fn cubic_interp(&self, x_new: f64) -> f64 {
        // Simplified cubic spline
        self.linear_interp(x_new) // TODO: Full cubic spline
    }
    
    fn nearest_interp(&self, x_new: f64) -> f64 {
        let i = self.find_index(x_new);
        check i >= self.x.len() - 1 {
            yield self.y[self.y.len() - 1];
        }
        
        check (x_new - self.x[i]).abs() < (self.x[i + 1] - x_new).abs() {
            self.y[i]
        } else {
            self.y[i + 1]
        }
    }
    
    fn quadratic_interp(&self, x_new: f64) -> f64 {
        // Simplified quadratic
        self.linear_interp(x_new) // TODO: Full quadratic
    }
    
    fn find_index(&self, x_new: f64) -> usize {
        each i in 0..self.x.len() - 1 {
            check x_new >= self.x[i] && x_new <= self.x[i + 1] {
                yield i;
            }
        }
        self.x.len() - 2
    }
}

// Cubic spline interpolation
open fn CubicSpline(x: &[f64], y: &[f64]) -> CubicSplineInterpolator {
    let n = x.len();
    var coeffs = [[0.0; 4]; n - 1];
    
    // Compute spline coefficients
    // TODO: Full natural cubic spline algorithm
    
    CubicSplineInterpolator {
        x: x.to_vec(),
        y: y.to_vec(),
        coeffs,
    }
}

open data CubicSplineInterpolator {
    x: Vec<f64>,
    y: Vec<f64>,
    coeffs: Vec<Vec<f64>>,
}

impl CubicSplineInterpolator {
    fn eval(&self, x_new: f64) -> f64 {
        // Find segment
        var i = 0;
        each j in 0..self.x.len() - 1 {
            check x_new >= self.x[j] && x_new <= self.x[j + 1] {
                i = j;
                abort;
            }
        }
        
        let dx = x_new - self.x[i];
        let c = &self.coeffs[i];
        
        c[0] + c[1] * dx + c[2] * dx * dx + c[3] * dx * dx * dx
    }
}

// 2D interpolation
open fn interp2d(
    x: &[f64],
    y: &[f64],
    z: &[Vec<f64>],
    kind: InterpKind,
) -> Interpolator2D {
    Interpolator2D {
        x: x.to_vec(),
        y: y.to_vec(),
        z: z.to_vec(),
        kind,
    }
}

open data Interpolator2D {
    x: Vec<f64>,
    y: Vec<f64>,
    z: Vec<Vec<f64>>,
    kind: InterpKind,
}

impl Interpolator2D {
    fn eval(&self, x_new: f64, y_new: f64) -> f64 {
        // Bilinear interpolation
        let i = self.find_x_index(x_new);
        let j = self.find_y_index(y_new);
        
        check i >= self.x.len() - 1 || j >= self.y.len() - 1 {
            yield self.z[i.min(self.z.len() - 1)][j.min(self.z[0].len() - 1)];
        }
        
        let x0 = self.x[i];
        let x1 = self.x[i + 1];
        let y0 = self.y[j];
        let y1 = self.y[j + 1];
        
        let z00 = self.z[i][j];
        let z01 = self.z[i][j + 1];
        let z10 = self.z[i + 1][j];
        let z11 = self.z[i + 1][j + 1];
        
        let tx = (x_new - x0) / (x1 - x0);
        let ty = (y_new - y0) / (y1 - y0);
        
        let z0 = z00 * (1.0 - tx) + z10 * tx;
        let z1 = z01 * (1.0 - tx) + z11 * tx;
        
        z0 * (1.0 - ty) + z1 * ty
    }
    
    fn find_x_index(&self, x_new: f64) -> usize {
        each i in 0..self.x.len() - 1 {
            check x_new >= self.x[i] && x_new <= self.x[i + 1] {
                yield i;
            }
        }
        self.x.len() - 2
    }
    
    fn find_y_index(&self, y_new: f64) -> usize {
        each j in 0..self.y.len() - 1 {
            check y_new >= self.y[j] && y_new <= self.y[j + 1] {
                yield j;
            }
        }
        self.y.len() - 2
    }
}

// Radial basis function interpolation
open fn Rbf(x: &[Vec<f64>], y: &[f64], function: RbfFunction) -> RbfInterpolator {
    RbfInterpolator {
        nodes: x.to_vec(),
        values: y.to_vec(),
        function,
        epsilon: 1.0,
    }
}

open cases RbfFunction {
    Multiquadric,
    Gaussian,
    ThinPlate,
    Linear,
}

open data RbfInterpolator {
    nodes: Vec<Vec<f64>>,
    values: Vec<f64>,
    function: RbfFunction,
    epsilon: f64,
}

impl RbfInterpolator {
    fn eval(&self, x: &[f64]) -> f64 {
        var sum = 0.0;
        
        each entry in self.nodes.iter().enumerate()  { let (i, node) = entry;
            let r = self.distance(x, node);
            let basis = self.basis_function(r);
            sum += self.values[i] * basis;
        }
        
        sum
    }
    
    fn distance(&self, a: &[f64], b: &[f64]) -> f64 {
        a.iter().zip(b).map(|(x, y)| (x - y).powi(2)).sum::<f64>().sqrt()
    }
    
    fn basis_function(&self, r: f64) -> f64 {
        match self.function {
            RbfFunction::Multiquadric => (1.0 + (self.epsilon * r).powi(2)).sqrt(),
            RbfFunction::Gaussian => (-((self.epsilon * r).powi(2))).exp(),
            RbfFunction::ThinPlate => check r > 0.0 { r.powi(2) * r.ln() } else { 0.0 },
            RbfFunction::Linear => r,
        }
    }
}
