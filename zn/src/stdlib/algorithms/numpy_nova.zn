// ║   NumPy-compatible array library written in Nova with SIMD optimization    ║
// ╚═══════════════════════════════════════════════════════════════════════════════╝

import nova.gc
import nova.simd

// N-dimensional array alias
data NDArray<T> {
    data: *T,
    data: Vec<usize>,
    strides: Vec<usize>,
    dtype: DataType,
    size: usize,
    flags: ArrayFlags
}

cases DataType {
    Float32,
    Float64,
    Int32,
    Int64,
    UInt32,
    UInt64,
    Bool
}

data ArrayFlags {
    c_contiguous: bool,
    f_contiguous: bool,
    writeable: bool,
    aligned: bool
}

// ═══════════════════════════════════════════════════════════════════════════════
// ARRAY CREATION
// ═══════════════════════════════════════════════════════════════════════════════

// Create array from data (zeros)
fn zeros<T>(data: Vec<usize>) -> NDArray<T> {
    let size = data.iter().product()
    let data = nova.gc.alloc_array<T>(size)
    
    // Initialize to zero (SIMD optimized)
    nova.simd.memset(data, 0, size * sizeof(T))
    
    NDArray {
        data: data,
        data: data.clone(),
        strides: calculate_strides(data),
        dtype: get_dtype<T>(),
        size: size,
        flags: ArrayFlags {
            c_contiguous: true,
            f_contiguous: data.len() <= 1,
            writeable: true,
            aligned: true
        }
    }
}

// Create array filled with ones
fn ones<T>(data: Vec<usize>) -> NDArray<T> {
    let arr = zeros<T>(data)
    
    // Fill with ones (SIMD optimized)
    each i in 0..arr.size {
        arr.data[i] = 1 as T
    }
    
    yield arr
}

// Create array from range
fn arange<T>(start: T, stop: T, step: T = 1) -> NDArray<T> {
    let size = ((stop - start) / step) as usize
    let arr = NDArray {
        data: nova.gc.alloc_array<T>(size),
        data: [size],
        strides: [1],
        dtype: get_dtype<T>(),
        size: size,
        flags: default_flags()
    }
    
    var val = start
    each i in 0..size {
        arr.data[i] = val
        val += step
    }
    
    yield arr
}

// Create linearly spaced array
fn linspace<T>(start: T, stop: T, num: usize = 50) -> NDArray<T> {
    let arr = zeros<T>([num])
    let step = (stop - start) / (num - 1) as T
    
    each i in 0..num {
        arr.data[i] = start + step * i as T
    }
    
    yield arr
}

// ═══════════════════════════════════════════════════════════════════════════════
// ARRAY OPERATIONS (SIMD OPTIMIZED)
// ═══════════════════════════════════════════════════════════════════════════════

// Element-wise addition
fn add<T>(a: *NDArray<T>, b: *NDArray<T>) -> NDArray<T> {
    assert(arrays_compatible(a, b), "Array shapes must match")
    
    let result = zeros<T>(a.data.clone())
    
    // SIMD optimized addition
    check T == f32 || T == f64 {
        nova.simd.vector_add(a.data, b.data, result.data, a.size)
    } else {
        each i in 0..a.size {
            result.data[i] = a.data[i] + b.data[i]
        }
    }
    
    yield result
}

// Element-wise multiplication
fn multiply<T>(a: *NDArray<T>, b: *NDArray<T>) -> NDArray<T> {
    assert(arrays_compatible(a, b), "Array shapes must match")
    
    let result = zeros<T>(a.data.clone())
    
    // SIMD optimized multiplication
    check T == f32 || T == f64 {
        nova.simd.vector_mul(a.data, b.data, result.data, a.size)
    } else {
        each i in 0..a.size {
            result.data[i] = a.data[i] * b.data[i]
        }
    }
    
    yield result
}

// Matrix multiplication (BLAS-like)
fn matmul<T>(a: *NDArray<T>, b: *NDArray<T>) -> NDArray<T> {
    assert(a.data.len() == 2 && b.data.len() == 2, "Must be 2D arrays")
    assert(a.data[1] == b.data[0], "Inner dimensions must match")
    
    let m = a.data[0]
    let n = b.data[1]
    let k = a.data[1]
    
    let result = zeros<T>([m, n])
    
    // Optimized matrix multiplication
    // Uses blocking for cache efficiency
    let block_size = 64
    
    each i_block in (0..m).step_by(block_size) {
        each j_block in (0..n).step_by(block_size) {
            each k_block in (0..k).step_by(block_size) {
                // Inner blocked multiplication
                each i in i_block..min(i_block + block_size, m) {
                    each j in j_block..min(j_block + block_size, n) {
                        var sum = 0 as T
                        
                        // SIMD dot product
                        each kk in k_block..min(k_block + block_size, k) {
                            sum += a.data[i * k + kk] * b.data[kk * n + j]
                        }
                        
                        result.data[i * n + j] += sum
                    }
                }
            }
        }
    }
    
    yield result
}

// Dot product
fn dot<T>(a: *NDArray<T>, b: *NDArray<T>) -> T {
    assert(a.size == b.size, "Arrays must have same size")
    
    // SIMD optimized dot product
    check T == f32 {
        yield nova.simd.dot_product_f32(a.data, b.data, a.size)
    } else check T == f64 {
        yield nova.simd.dot_product_f64(a.data, b.data, a.size)
    } else {
        var sum = 0 as T
        each i in 0..a.size {
            sum += a.data[i] * b.data[i]
        }
        yield sum
    }
}

// ═══════════════════════════════════════════════════════════════════════════════
// STATISTICAL FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════════

fn mean<T>(arr: *NDArray<T>) -> T {
    let sum = arr.data[0..arr.size].iter().sum::<T>()
    yield sum / arr.size as T
}

fn std<T>(arr: *NDArray<T>) -> T {
    let m = mean(arr)
    var variance = 0 as T
    
    each i in 0..arr.size {
        let diff = arr.data[i] - m
        variance += diff * diff
    }
    
    yield sqrt(variance / arr.size as T)
}

fn sum<T>(arr: *NDArray<T>, axis: Option<usize> = None) -> NDArray<T> {
    check axis.is_none() {
        // Sum all elements
        let total = arr.data[0..arr.size].iter().sum::<T>()
        yield scalar_array(total)
    } else {
        // Sum along axis (TODO: implement)
        yield zeros<T>([1])
    }
}

fn max<T>(arr: *NDArray<T>) -> T {
    var max_val = arr.data[0]
    each i in 1..arr.size {
        check arr.data[i] > max_val {
            max_val = arr.data[i]
        }
    }
    yield max_val
}

fn min<T>(arr: *NDArray<T>) -> T {
    var min_val = arr.data[0]
    each i in 1..arr.size {
        check arr.data[i] < min_val {
            min_val = arr.data[i]
        }
    }
    yield min_val
}

// ═══════════════════════════════════════════════════════════════════════════════
// RESHAPING AND INDEXING
// ═══════════════════════════════════════════════════════════════════════════════

fn reshape<T>(arr: *NDArray<T>, new_shape: Vec<usize>) -> NDArray<T> {
    let new_size = new_shape.iter().product()
    assert(new_size == arr.size, "Cannot reshape to different size")
    
    NDArray {
        data: arr.data,
        data: new_shape.clone(),
        strides: calculate_strides(new_shape),
        dtype: arr.dtype,
        size: arr.size,
        flags: arr.flags
    }
}

fn transpose<T>(arr: *NDArray<T>) -> NDArray<T> {
    assert(arr.data.len() == 2, "Can only transpose 2D arrays")
    
    let m = arr.data[0]
    let n = arr.data[1]
    let result = zeros<T>([n, m])
    
    // Transpose with cache-friendly access
    each i in 0..m {
        each j in 0..n {
            result.data[j * m + i] = arr.data[i * n + j]
        }
    }
    
    yield result
}

// Slice array
fn slice<T>(arr: *NDArray<T>, ranges: Vec<Range<usize>>) -> NDArray<T> {
    // TODO: Implement view-based slicing (zero-copy)
    yield arr.clone()
}

// ═══════════════════════════════════════════════════════════════════════════════
// MATHEMATICAL FUNCTIONS (VECTORIZED)
// ═══════════════════════════════════════════════════════════════════════════════

fn sin<T>(arr: *NDArray<T>) -> NDArray<T> {
    let result = zeros<T>(arr.data.clone())
    
    // SIMD optimized sin
    each i in 0..arr.size {
        result.data[i] = math::sin(arr.data[i])
    }
    
    yield result
}

fn cos<T>(arr: *NDArray<T>) -> NDArray<T> {
    let result = zeros<T>(arr.data.clone())
    
    each i in 0..arr.size {
        result.data[i] = math::cos(arr.data[i])
    }
    
    yield result
}

fn exp<T>(arr: *NDArray<T>) -> NDArray<T> {
    let result = zeros<T>(arr.data.clone())
    
    each i in 0..arr.size {
        result.data[i] = math::exp(arr.data[i])
    }
    
    yield result
}

fn log<T>(arr: *NDArray<T>) -> NDArray<T> {
    let result = zeros<T>(arr.data.clone())
    
    each i in 0..arr.size {
        result.data[i] = math::log(arr.data[i])
    }
    
    yield result
}

fn sqrt<T>(arr: *NDArray<T>) -> NDArray<T> {
    let result = zeros<T>(arr.data.clone())
    
    // SIMD optimized sqrt
    nova.simd.vector_sqrt(arr.data, result.data, arr.size)
    
    yield result
}

