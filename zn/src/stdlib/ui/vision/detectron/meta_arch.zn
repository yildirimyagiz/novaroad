// Nova Detectron - Generalized R-CNN
// The Meta-Architecture connecting Backbone, RPN, and ROI Heads.

import std.ai.core
import std.vision.detectron.modeling.backbone.fpn
import std.vision.detectron.modeling.proposal.rpn
import std.vision.detectron.modeling.roi_heads

open data GeneralizedRCNN {
    backbone: fpn.FPN
    proposal_generator: rpn.RPN
    roi_heads: roi_heads.StandardROIHeads
}

impl GeneralizedRCNN {
    fn new(config: Config) -> GeneralizedRCNN {
        GeneralizedRCNN {
            backbone: fpn.build_backbone(config)
            proposal_generator: rpn.build_rpn(config)
            roi_heads: roi_heads.build_roi_heads(config)
        }
    }

    fn forward(var self, images: list<Image>) -> list<Result> {
        // 1. Feature Extraction
        let features = self.backbone.forward(images.to_tensor())
        
        // 2. Region Proposal (RPN)
        // Returns list of "Proposals" (potential object boxes)
        let (proposals, rpn_losses) = self.proposal_generator.forward(images, features)
        
        // 3. ROI Heads (Classification + Box Reg + Mask)
        // Takes features and crops them using proposals
        let (detection_results, roi_losses) = self.roi_heads.forward(images, features, proposals)
        
        check self.training {
            yield rpn_losses + roi_losses
        } else {
            // Post-Processing (NMS, Score Filtering)
            yield self.postprocess(detection_results)
        }
    }
    
    fn postprocess(self, results: list<Instances>) -> list<Result> {
        // Resize boxes back to original image size
        // Apply Non-Maximum Suppression (NMS)
        yield results
    }
}
