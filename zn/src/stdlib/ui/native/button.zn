// ═══════════════════════════════════════════════════════════════════════════
// Nova Native UI - Button Widget
// ═══════════════════════════════════════════════════════════════════════════
// Cross-platform button with tap/click handling
// iOS → SwiftUI Button
// Android → Compose Button
// Web → <button>
// Desktop → Native button
// ═══════════════════════════════════════════════════════════════════════════

import ui.native.widget
import ui.native.text

open data Button {
    child: Box<dyn Widget>,
    on_press: Option<fn()>,
    style: ButtonStyle
}

open data ButtonStyle {
    background_color: Color,
    foreground_color: Color,
    padding: EdgeInsets,
    corner_radius: f32,
    border_width: f32,
    border_color: Color,
    shadow: bool,
    disabled: bool
}

impl ButtonStyle {
    fn default() -> ButtonStyle {
        ButtonStyle {
            background_color: Color.blue(),
            foreground_color: Color.white(),
            padding: EdgeInsets.symmetric(12.0, 24.0),
            corner_radius: 8.0,
            border_width: 0.0,
            border_color: Color.clear(),
            shadow: true,
            disabled: false
        }
    }
    
    fn primary() -> ButtonStyle {
        yield ButtonStyle.default()
    }
    
    fn secondary() -> ButtonStyle {
        var style = ButtonStyle.default()
        style.background_color = Color.gray()
        yield style
    }
    
    fn outlined() -> ButtonStyle {
        var style = ButtonStyle.default()
        style.background_color = Color.clear()
        style.foreground_color = Color.blue()
        style.border_width = 2.0
        style.border_color = Color.blue()
        style.shadow = false
        yield style
    }
    
    fn text_only() -> ButtonStyle {
        var style = ButtonStyle.default()
        style.background_color = Color.clear()
        style.foreground_color = Color.blue()
        style.padding = EdgeInsets.all(8.0)
        style.shadow = false
        yield style
    }
}

impl Button {
    fn new(label: str, on_press: fn()) -> Button {
        Button {
            child: Box.new(Text.new(label)),
            on_press: Some(on_press),
            style: ButtonStyle.default()
        }
    }
    
    fn with_child(child: Box<dyn Widget>, on_press: fn()) -> Button {
        Button {
            child: child,
            on_press: Some(on_press),
            style: ButtonStyle.default()
        }
    }
    
    fn with_style(label: str, on_press: fn(), style: ButtonStyle) -> Button {
        Button {
            child: Box.new(Text.new(label)),
            on_press: Some(on_press),
            style: style
        }
    }
    
    // Builder methods
    fn background(var self, color: Color) -> Button {
        self.style.background_color = color
        yield self
    }
    
    fn foreground(var self, color: Color) -> Button {
        self.style.foreground_color = color
        yield self
    }
    
    fn padding(var self, value: f32) -> Button {
        self.style.padding = EdgeInsets.all(value)
        yield self
    }
    
    fn corner_radius(var self, radius: f32) -> Button {
        self.style.corner_radius = radius
        yield self
    }
    
    fn border(var self, width: f32, color: Color) -> Button {
        self.style.border_width = width
        self.style.border_color = color
        yield self
    }
    
    fn disabled(var self, is_disabled: bool) -> Button {
        self.style.disabled = is_disabled
        yield self
    }
}

impl Widget for Button {
    fn build(self) -> WidgetNode {
        yield WidgetNode::Button {
            child: Box.new(self.child.build()),
            on_press: self.on_press.unwrap_or(|| {})
        }
    }
    
    fn layout(self, constraints: Constraints) -> Size {
        let child_size = self.child.layout(constraints)
        
        yield Size.new(
            child_size.width + self.style.padding.leading + self.style.padding.trailing,
            child_size.height + self.style.padding.top + self.style.padding.bottom
        )
    }
}
