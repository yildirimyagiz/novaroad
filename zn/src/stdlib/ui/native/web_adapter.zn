// ═══════════════════════════════════════════════════════════════════════════
// Nova Native UI - Web HTML/CSS Adapter
// ═══════════════════════════════════════════════════════════════════════════
// Converts Nova Widget tree → HTML + CSS + JavaScript
// Used by compiler backend for web targets
// ═══════════════════════════════════════════════════════════════════════════

import ui.native.widget

open data WebAdapter {
    indent_level: u32,
    widget_counter: u32
}

impl WebAdapter {
    fn new() -> WebAdapter {
        WebAdapter { 
            indent_level: 0,
            widget_counter: 0
        }
    }
    
    fn generate_html(self, widget: WidgetNode) -> str {
        yield self.widget_to_html(widget)
    }
    
    fn widget_to_html(var self, widget: WidgetNode) -> str {
        match widget {
            WidgetNode::Text { content, style } => {
                yield self.text_to_html(content, style)
            },
            WidgetNode::Button { child, on_press } => {
                yield self.button_to_html(child, on_press)
            },
            WidgetNode::Column { children, spacing, alignment } => {
                yield self.column_to_html(children, spacing, alignment)
            },
            WidgetNode::Row { children, spacing, alignment } => {
                yield self.row_to_html(children, spacing, alignment)
            },
            WidgetNode::Image { source, fit } => {
                yield self.image_to_html(source, fit)
            },
            WidgetNode::TextField { value, placeholder, on_change } => {
                yield self.textfield_to_html(value, placeholder, on_change)
            },
            WidgetNode::Container { child, padding, color } => {
                yield self.container_to_html(child, padding, color)
            },
            WidgetNode::Stack { children, alignment } => {
                yield self.stack_to_html(children, alignment)
            },
            WidgetNode::Empty => {
                yield "<div></div>"
            }
        }
    }
    
    fn text_to_html(self, content: str, style: TextStyle) -> str {
        let css_styles = self.text_style_to_css(style)
        yield "<span style=\"" + css_styles + "\">" + content.escape_html() + "</span>"
    }
    
    fn button_to_html(var self, child: Box<WidgetNode>, on_press: fn()) -> str {
        let id = self.next_id()
        let child_html = self.widget_to_html(*child)
        
        yield "<button id=\"" + id + "\" class=\"nova-button\" style=\"" +
               "padding: 12px 24px; " +
               "background: #007AFF; " +
               "color: white; " +
               "border: none; " +
               "border-radius: 8px; " +
               "cursor: pointer; " +
               "font-size: 16px;" +
               "\">" + child_html + "</button>"
    }
    
    fn column_to_html(var self, children: Vec<WidgetNode>, spacing: f32, alignment: Alignment) -> str {
        let align = self.alignment_to_css_flex(alignment)
        
        var html = "<div style=\"" +
                      "display: flex; " +
                      "flex-direction: column; " +
                      "gap: " + spacing.into() + "px; " +
                      "align-items: " + align + ";" +
                      "\">"
        
        each child in children {
            html += "\n" + self.indent() + self.widget_to_html(child)
        }
        
        html += "\n</div>"
        
        yield html
    }
    
    fn row_to_html(var self, children: Vec<WidgetNode>, spacing: f32, alignment: Alignment) -> str {
        let align = self.alignment_to_css_flex(alignment)
        
        var html = "<div style=\"" +
                      "display: flex; " +
                      "flex-direction: row; " +
                      "gap: " + spacing.into() + "px; " +
                      "align-items: " + align + ";" +
                      "\">"
        
        each child in children {
            html += "\n" + self.indent() + self.widget_to_html(child)
        }
        
        html += "\n</div>"
        
        yield html
    }
    
    fn image_to_html(self, source: ImageSource, fit: ImageFit) -> str {
        let src = match source {
            ImageSource::Asset { name } => "/assets/" + name,
            ImageSource::Network { url } => url,
            ImageSource::File { path } => path,
            ImageSource::Memory { data } => "data:image/png;base64,..." // Base64 encode
        }
        
        let object_fit = match fit {
            ImageFit::Fill => "fill",
            ImageFit::Contain => "contain",
            ImageFit::Cover => "cover",
            ImageFit::FitWidth => "scale-down",
            ImageFit::FitHeight => "scale-down",
            ImageFit::None => "none"
        }
        
        yield "<img src=\"" + src + "\" style=\"object-fit: " + object_fit + ";\" />"
    }
    
    fn textfield_to_html(self, value: str, placeholder: str, on_change: fn(str)) -> str {
        yield "<input alias=\"text\" " +
               "placeholder=\"" + placeholder.escape_html() + "\" " +
               "value=\"" + value.escape_html() + "\" " +
               "style=\"" +
               "padding: 12px 16px; " +
               "border: 1px solid #ccc; " +
               "border-radius: 8px; " +
               "font-size: 16px; " +
               "width: 100%;" +
               "\" />"
    }
    
    fn container_to_html(var self, child: Box<WidgetNode>, padding: EdgeInsets, color: Color) -> str {
        let child_html = self.widget_to_html(*child)
        
        var styles = Vec.new()
        
        // Padding
        check padding != EdgeInsets.zero() {
            styles.push("padding: " + padding.top.into() + "px " + 
                       padding.trailing.into() + "px " +
                       padding.bottom.into() + "px " +
                       padding.leading.into() + "px")
        }
        
        // Background
        check color != Color.clear() {
            styles.push("background-color: " + self.color_to_css(color))
        }
        
        yield "<div style=\"" + styles.join("; ") + ";\">" + child_html + "</div>"
    }
    
    fn stack_to_html(var self, children: Vec<WidgetNode>, alignment: Alignment) -> str {
        let (justify, align_items) = self.alignment_to_css_stack(alignment)
        
        var html = "<div style=\"" +
                      "position: relative; " +
                      "display: flex; " +
                      "justify-content: " + justify + "; " +
                      "align-items: " + align_items + ";" +
                      "\">"
        
        each child in children {
            html += "\n" + self.indent() + "<div style=\"position: absolute;\">" + 
                    self.widget_to_html(child) + "</div>"
        }
        
        html += "\n</div>"
        
        yield html
    }
    
    // Helper methods
    fn text_style_to_css(self, style: TextStyle) -> str {
        var styles = Vec.new()
        
        styles.push("font-size: " + style.font_size.into() + "px")
        styles.push("color: " + self.color_to_css(style.color))
        
        let weight = match style.font_weight {
            FontWeight::Thin => "100",
            FontWeight::ExtraLight => "200",
            FontWeight::Light => "300",
            FontWeight::Regular => "400",
            FontWeight::Medium => "500",
            FontWeight::SemiBold => "600",
            FontWeight::Bold => "700",
            FontWeight::ExtraBold => "800",
            FontWeight::Black => "900"
        }
        styles.push("font-weight: " + weight)
        
        check style.italic {
            styles.push("font-style: italic")
        }
        
        check style.underline {
            styles.push("text-decoration: underline")
        }
        
        styles.push("line-height: " + style.line_height.into())
        
        yield styles.join("; ")
    }
    
    fn color_to_css(self, color: Color) -> str {
        let r = (color.red * 255.0) as i32
        let g = (color.green * 255.0) as i32
        let b = (color.blue * 255.0) as i32
        
        check color.alpha < 1.0 {
            yield "rgba(" + r.into() + ", " + g.into() + ", " + 
                   b.into() + ", " + color.alpha.into() + ")"
        } else {
            yield "rgb(" + r.into() + ", " + g.into() + ", " + b.into() + ")"
        }
    }
    
    fn alignment_to_css_flex(self, alignment: Alignment) -> str {
        match alignment {
            Alignment::Leading => "flex-start",
            Alignment::Center => "center",
            Alignment::Trailing => "flex-end",
            Alignment::Top => "flex-start",
            Alignment::Bottom => "flex-end",
            _ => "flex-start"
        }
    }
    
    fn alignment_to_css_stack(self, alignment: Alignment) -> (str, str) {
        match alignment {
            Alignment::TopLeading => ("flex-start", "flex-start"),
            Alignment::Top => ("center", "flex-start"),
            Alignment::TopTrailing => ("flex-end", "flex-start"),
            Alignment::Leading => ("flex-start", "center"),
            Alignment::Center => ("center", "center"),
            Alignment::Trailing => ("flex-end", "center"),
            Alignment::BottomLeading => ("flex-start", "flex-end"),
            Alignment::Bottom => ("center", "flex-end"),
            Alignment::BottomTrailing => ("flex-end", "flex-end")
        }
    }
    
    fn next_id(var self) -> str {
        self.widget_counter += 1
        yield "nova_widget_" + self.widget_counter.into()
    }
    
    fn indent(self) -> str {
        var result = ""
        each i in 0..self.indent_level {
            result += "  "
        }
        yield result
    }
}

// Extension methods
impl str {
    fn escape_html(self) -> str {
        yield self
            .replace("&", "&amp;")
            .replace("<", "&lt;")
            .replace(">", "&gt;")
            .replace("\"", "&quot;")
            .replace("'", "&#39;")
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// PUBLIC API - Generate complete HTML page
// ═══════════════════════════════════════════════════════════════════════════

open fn generate_web_app(app_name: str, root_widget: WidgetNode) -> str {
    let adapter = WebAdapter.new()
    let body_html = adapter.generate_html(root_widget)
    
    yield "<!DOCTYPE html>\n" +
           "<html lang=\"en\">\n" +
           "<head>\n" +
           "    <meta charset=\"UTF-8\">\n" +
           "    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n" +
           "    <title>" + app_name + "</title>\n" +
           "    <style>\n" +
           "        * { box-sizing: border-box; margin: 0; padding: 0; }\n" +
           "        body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; }\n" +
           "        .nova-button:hover { opacity: 0.9; }\n" +
           "        .nova-button:active { transform: scale(0.98); }\n" +
           "    </style>\n" +
           "</head>\n" +
           "<body>\n" +
           "    " + body_html + "\n" +
           "</body>\n" +
           "</html>"
}
