// ═══════════════════════════════════════════════════════════════════════════
// ZenFlow Widgets - Data Table
// ═══════════════════════════════════════════════════════════════════════════

import ui.zenflow.core

open fn table(data: list<map<str, any>>) {
    emit_component("table", {
        "data": data,
        "sortable": true,
        "filterable": true,
        "paginated": false
    })
}

open fn dataframe(df: DataFrame) {
    let data = df.to_dict_list()
    
    emit_component("dataframe", {
        "data": data,
        "columns": df.columns(),
        "index": df.index(),
        "sortable": true,
        "filterable": true
    })
}

open fn editable_table(data: list<map<str, any>>) -> list<map<str, any>> {
    let widget_id = generate_widget_id("editable_table", "")
    let edited_data = CURRENT_SESSION.get(widget_id + "_data", data)
    
    emit_component("editable_table", {
        "id": widget_id,
        "data": edited_data
    })
    
    yield edited_data
}
