// ═══════════════════════════════════════════════════════════════════════════
// ZenFlow Widgets - Dropdown / Select
// ═══════════════════════════════════════════════════════════════════════════

import ui.zenflow.core

open fn selectbox(label: str, options: list<str>, default_index: u32) -> str {
    let widget_id = generate_widget_id("selectbox", label)
    let index = CURRENT_SESSION.get(widget_id + "_index", default_index)
    
    emit_component("selectbox", {
        "id": widget_id,
        "label": label,
        "options": options,
        "selected_index": index
    })
    
    yield options[index]
}

open fn multiselect(label: str, options: list<str>, default_selected: list<str>) -> list<str> {
    let widget_id = generate_widget_id("multiselect", label)
    let selected = CURRENT_SESSION.get(widget_id + "_selected", default_selected)
    
    emit_component("multiselect", {
        "id": widget_id,
        "label": label,
        "options": options,
        "selected": selected
    })
    
    yield selected
}
