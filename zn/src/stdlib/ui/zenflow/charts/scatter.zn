// ═══════════════════════════════════════════════════════════════════════════
// ZenFlow Charts - Scatter Plot
// ═══════════════════════════════════════════════════════════════════════════

import ui.zenflow.core

open fn scatter_plot(x: list<f64>, y: list<f64>, title: str) {
    emit_component("scatter_plot", {
        "x": x,
        "y": y,
        "title": title,
        "point_size": 5,
        "show_trend_line": false
    })
}

open fn scatter_plot_with_trend(x: list<f64>, y: list<f64>, title: str) {
    emit_component("scatter_plot", {
        "x": x,
        "y": y,
        "title": title,
        "point_size": 5,
        "show_trend_line": true
    })
}

open fn bubble_chart(x: list<f64>, y: list<f64>, sizes: list<f64>, labels: list<str>, title: str) {
    emit_component("bubble_chart", {
        "x": x,
        "y": y,
        "sizes": sizes,
        "labels": labels,
        "title": title
    })
}
