// 💎 Nova Premium UI — Sovereign v8.0
// Inspired by Shadcn UI & Aceternity UI. Premium aesthetics by default.

use ui::nova_x as x;
use ui::animations_advanced as anim;

/// 🧊 Glassmorphism Component Style
open fn glass_style() -> x::ZStyle {
    var style = x::ZStyle::new();
    style.background = "rgba(255, 255, 255, 0.05)";
    style.backdrop_filter = "blur(12px) saturate(180%)";
    style.border_width = 1;
    style.border_color = "rgba(255, 255, 255, 0.1)";
    style.border_radius = x::Token::Radius::LG;
    style.box_shadow = "0 8px 32px 0 rgba(0, 0, 0, 0.37)";
    style
}

/// 🚀 Aceternity-style Animated Border Card
open fn AnimatedBorderCard(title: String, description: String) -> x::ZElement {
    var card = x::div();
    card.classes.push("animated-border-card".into());
    card.set_style(glass_style());
    card.style.padding = x::Token::Space::LG;

    var h3 = x::ZElement::new("h3".into());
    h3.set_text(title);
    h3.style.color = x::Token::Color::WHITE;
    h3.style.font_size = x::Token::Font::XL;
    h3.style.margin_bottom = x::Token::Space::SM;

    var p = x::ZElement::new("p".into());
    p.set_text(description);
    p.style.color = x::Token::Color::GRAY_400;
    p.style.font_size = x::Token::Font::MD;

    card.add_child(h3);
    card.add_child(p);
    card
}

/// 📐 3D Tilt Card (Shadcn-plus)
open fn TiltCard(content: x::ZElement) -> x::ZElement {
    var wrapper = x::div();
    wrapper.classes.push("tilt-card".into());
    wrapper.classes.push("gpu-accelerated".into());
    wrapper.add_child(content);
    wrapper
}

/// ✨ Cyber Gradient Button
open fn CyberButton(label: String) -> x::ZElement {
    var btn = x::button(label, || {});
    btn.style.background = x::Token::Color::GRADIENT_CYBER;
    btn.style.border_width = 0;
    btn.style.font_weight = 600;
    btn.style.padding_x = x::Token::Space::XL;
    btn.style.transition = "transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1)";
    btn.style.hover.insert("transform".into(), "scale(1.05) translateY(-2px)".into());
    btn
}

/// 🌊 Modern Hero Section
open fn HeroSection(title: String, subtitle: String) -> x::ZElement {
    var section = x::div();
    section.style.display = "flex";
    section.style.direction = "column";
    section.style.align = "center";
    section.style.justify = "center";
    section.style.min_height = "80vh";
    section.style.background = "radial-gradient(circle at top, #09090b 0%, #000000 100%)";

    var h1 = x::ZElement::new("h1".into());
    h1.set_text(title);
    h1.style.font_size = x::Token::Font::HERO;
    h1.style.font_weight = 900;
    h1.style.color = x::Token::Color::WHITE;
    h1.style.text_align = "center";
    h1.style.letter_spacing = -1.0;

    var p = x::ZElement::new("p".into());
    p.set_text(subtitle);
    p.style.font_size = x::Token::Font::XXL;
    p.style.color = x::Token::Color::GRAY_400;
    p.style.margin_top = x::Token::Space::MD;
    p.style.text_align = "center";
    p.style.max_width = "800px";

    section.add_child(h1);
    section.add_child(p);
    section.add_child(CyberButton("Get Started".into()));
    section
}

open fn main() {
    println("💎 Nova Premium UI — Sovereign v8.0 Active");
}
