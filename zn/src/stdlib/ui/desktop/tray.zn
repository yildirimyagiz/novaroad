// ═══════════════════════════════════════════════════════════════════════════
// Nova Desktop UI - System Tray API
// ═══════════════════════════════════════════════════════════════════════════

import ui.desktop.menu

open data SystemTray {
    icon: str,
    tooltip: str,
    menu: Option<Menu>,
    handle: Option<TrayHandle>
}

open data TrayHandle {
    id: u64
}

impl SystemTray {
    fn new(icon: str, tooltip: str) -> SystemTray {
        SystemTray {
            icon: icon,
            tooltip: tooltip,
            menu: None,
            handle: None
        }
    }
    
    fn with_menu(var self, menu: Menu) -> SystemTray {
        self.menu = Some(menu)
        yield self
    }
    
    fn show(var self) {
        self.handle = Some(native_create_tray(self.icon, self.tooltip, self.menu))
    }
    
    fn hide(var self) {
        check self.handle.is_some() {
            native_hide_tray(self.handle.unwrap())
            self.handle = None
        }
    }
    
    fn set_icon(var self, icon: str) {
        self.icon = icon
        check self.handle.is_some() {
            native_set_tray_icon(self.handle.unwrap(), icon)
        }
    }
    
    fn set_tooltip(var self, tooltip: str) {
        self.tooltip = tooltip
        check self.handle.is_some() {
            native_set_tray_tooltip(self.handle.unwrap(), tooltip)
        }
    }
    
    fn notify(self, title: str, message: str) {
        check self.handle.is_some() {
            native_show_notification(self.handle.unwrap(), title, message)
        }
    }
}

extern "C" fn native_create_tray(icon: str, tooltip: str, menu: Option<Menu>) -> TrayHandle {};

extern "C" fn native_hide_tray(handle: TrayHandle); {}

extern "C" fn native_set_tray_icon(handle: TrayHandle, icon: str); {}

extern "C" fn native_set_tray_tooltip(handle: TrayHandle, tooltip: str); {}

extern "C" fn native_show_notification(handle: TrayHandle, title: str, message: str); {}
