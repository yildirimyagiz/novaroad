// ⏰ Nova DateTime
// Best of: Rust (chrono), Go (time), Luxon
// + Nova Magic: Auto-timezone, smart parsing

open data DateTime {
    timestamp: i64,  // Unix timestamp
    timezone: Timezone
}

impl DateTime {
    fn now() -> Self {
        DateTime {
            timestamp: system_time(),
            timezone: Timezone::UTC
        }
    }
    
    fn parse(s: &str) -> Result<Self, Error> {
        // ISO 8601: 2024-02-07T15:30:00Z
        // Also: "2024-02-07", "15:30", etc.
        Parser::parse(s)
    }
    
    fn format(&self, fmt: &str) -> String {
        // "%Y-%m-%d %H:%M:%S" => "2024-02-07 15:30:00"
        Formatter::format(self, fmt)
    }
    
    fn add(&self, duration: Duration) -> DateTime {
        DateTime {
            timestamp: self.timestamp + duration.seconds(),
            timezone: self.timezone
        }
    }
    
    fn diff(&self, other: &DateTime) -> Duration {
        Duration::seconds(self.timestamp - other.timestamp)
    }
}

open data Duration {
    secs: i64,
    nanos: u32
}

impl Duration {
    fn seconds(s: i64) -> Self {
        Duration { secs: s, nanos: 0 }
    }
    
    fn hours(h: i64) -> Self {
        Duration::seconds(h * 3600)
    }
    
    fn days(d: i64) -> Self {
        Duration::hours(d * 24)
    }
}

open cases Timezone {
    UTC,
    Local,
    Fixed(i32)  // Offset in seconds
}
