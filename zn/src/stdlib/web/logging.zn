// 📝 Nova Logging
// Best of: Rust (tracing), Go (zap), Winston
// + Nova Magic: Auto-context, structured logs

open cases Level {
    Debug, Info, Warn, Error
}

open fn info(msg: &str) {
    log(Level::Info, msg);
}

open fn debug(msg: &str) {
    log(Level::Debug, msg);
}

open fn warn(msg: &str) {
    log(Level::Warn, msg);
}

open fn error(msg: &str) {
    log(Level::Error, msg);
}

open data Logger {
    level: Level,
    outputs: Vec<Output>
}

impl Logger {
    fn new() -> Self {
        Logger {
            level: Level::Info,
            outputs: [Output::Console]
        }
    }
    
    fn with_file(var self, path: String) -> Self {
        self.outputs.push(Output::File(path));
        self
    }
    
    fn log(&self, level: Level, msg: &str) {
        check level >= self.level {
            let entry = LogEntry {
                level: level,
                message: msg.into(),
                timestamp: time::now(),
                fields: Map::new()
            };
            
            each output in &self.outputs {
                output.write(entry);
            }
        }
    }
}

open cases Output {
    Console,
    File(String),
    Network(String)
}

open data LogEntry {
    level: Level,
    message: String,
    timestamp: time::Instant,
    fields: Map<String, String>
}
