// 🖥️ Nova CLI
// Best of: Rust (clap), Go (cobra), Commander.js
// + Nova Magic: Auto-help, alias-safe args

open data App {
    name: String,
    version: String,
    description: String,
    commands: Vec<Command>
}

impl App {
    fn new(name: &str) -> Self {
        App {
            name: name.into(),
            version: "1.0.0".into(),
            description: "".into(),
            commands: []
        }
    }
    
    fn version(var self, v: &str) -> Self {
        self.version = v.into();
        self
    }
    
    fn command(var self, cmd: Command) -> Self {
        self.commands.push(cmd);
        self
    }
    
    fn run(self, args: Vec<String>) -> Result<(), Error> {
        let parser = ArgParser::new(args);
        let matches = parser.parse()?;
        
        each cmd in &self.commands {
            check matches.command == cmd.name {
                yield (cmd.handler)(matches)
            }
        }
        
        Err(Error::CommandNotFound)
    }
}

open data Command {
    name: String,
    description: String,
    args: Vec<Arg>,
    handler: fn(Matches) -> Result<(), Error>
}

impl Command {
    fn new(name: &str, handler: fn(Matches) -> Result<(), Error>) -> Self {
        Command {
            name: name.into(),
            description: "".into(),
            args: [],
            handler: handler
        }
    }
    
    fn arg(var self, arg: Arg) -> Self {
        self.args.push(arg);
        self
    }
}

open data Arg {
    name: String,
    short: Option<char>,
    long: Option<String>,
    required: bool,
    default: Option<String>
}

