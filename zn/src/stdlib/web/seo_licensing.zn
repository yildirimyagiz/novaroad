// Nova SEO - Premium Licensing System
// ═══════════════════════════════════════════════════════════════════════════
// SEO modülü ücretli lisans gerektirir
// Free tier: Temel özellikler
// Pro tier: Gelişmiş özellikler
// Enterprise: Tüm özellikler + destek
// ═══════════════════════════════════════════════════════════════════════════

import std.crypto
import std.net.http

// ═══════════════════════════════════════════════════════════════════════════
// LICENSE TIERS
// ═══════════════════════════════════════════════════════════════════════════

open cases SEOLicense {
    Free,           // Basic meta tags only
    Starter,        // $29/month - SSR + basic SEO
    Pro,            // $99/month - Full SEO + advanced features
    Enterprise      // $499/month - Everything + priority support
}

open data LicenseConfig {
    tier: SEOLicense,
    license_key: str,
    domain: str,
    expires_at: i64,
    features: LicenseFeatures
}

open data LicenseFeatures {
    // Meta Tags
    basic_meta_tags: bool,          // FREE
    open_graph: bool,               // STARTER+
    twitter_cards: bool,            // STARTER+
    canonical_urls: bool,           // STARTER+
    
    // Rendering
    ssr: bool,                      // STARTER+
    ssg: bool,                      // PRO+
    isr: bool,                      // PRO+
    streaming_ssr: bool,            // ENTERPRISE
    
    // SEO Automation
    auto_sitemap: bool,             // STARTER+
    auto_robots: bool,              // STARTER+
    image_sitemap: bool,            // PRO+
    video_sitemap: bool,            // PRO+
    
    // Schema.org
    basic_schema: bool,             // STARTER+
    advanced_schema: bool,          // PRO+
    custom_schema: bool,            // ENTERPRISE
    
    // Performance
    preload_hints: bool,            // PRO+
    prefetch_hints: bool,           // PRO+
    edge_optimization: bool,        // ENTERPRISE
    
    // Multi-language
    hreflang_tags: bool,            // PRO+
    auto_translation_hints: bool,   // ENTERPRISE
    
    // Analytics & Monitoring
    seo_analytics: bool,            // PRO+
    crawl_monitoring: bool,         // ENTERPRISE
    
    // Support
    email_support: bool,            // PRO+
    priority_support: bool,         // ENTERPRISE
    dedicated_account: bool         // ENTERPRISE
}

impl LicenseConfig {
    fn free() -> LicenseConfig {
        LicenseConfig {
            tier: SEOLicense::Free,
            license_key: "",
            domain: "",
            expires_at: 0,
            features: LicenseFeatures {
                basic_meta_tags: true,
                open_graph: false,
                twitter_cards: false,
                canonical_urls: false,
                ssr: false,
                ssg: false,
                isr: false,
                streaming_ssr: false,
                auto_sitemap: false,
                auto_robots: false,
                image_sitemap: false,
                video_sitemap: false,
                basic_schema: false,
                advanced_schema: false,
                custom_schema: false,
                preload_hints: false,
                prefetch_hints: false,
                edge_optimization: false,
                hreflang_tags: false,
                auto_translation_hints: false,
                seo_analytics: false,
                crawl_monitoring: false,
                email_support: false,
                priority_support: false,
                dedicated_account: false
            }
        }
    }
    
    fn starter(license_key: str, domain: str) -> Result<LicenseConfig, str> {
        let config = LicenseConfig {
            tier: SEOLicense::Starter,
            license_key: license_key,
            domain: domain,
            expires_at: 0,
            features: LicenseFeatures {
                basic_meta_tags: true,
                open_graph: true,
                twitter_cards: true,
                canonical_urls: true,
                ssr: true,
                ssg: false,
                isr: false,
                streaming_ssr: false,
                auto_sitemap: true,
                auto_robots: true,
                image_sitemap: false,
                video_sitemap: false,
                basic_schema: true,
                advanced_schema: false,
                custom_schema: false,
                preload_hints: false,
                prefetch_hints: false,
                edge_optimization: false,
                hreflang_tags: false,
                auto_translation_hints: false,
                seo_analytics: false,
                crawl_monitoring: false,
                email_support: false,
                priority_support: false,
                dedicated_account: false
            }
        }
        
        yield verify_license(config)
    }
    
    fn pro(license_key: str, domain: str) -> Result<LicenseConfig, str> {
        let config = LicenseConfig {
            tier: SEOLicense::Pro,
            license_key: license_key,
            domain: domain,
            expires_at: 0,
            features: LicenseFeatures {
                basic_meta_tags: true,
                open_graph: true,
                twitter_cards: true,
                canonical_urls: true,
                ssr: true,
                ssg: true,
                isr: true,
                streaming_ssr: false,
                auto_sitemap: true,
                auto_robots: true,
                image_sitemap: true,
                video_sitemap: true,
                basic_schema: true,
                advanced_schema: true,
                custom_schema: false,
                preload_hints: true,
                prefetch_hints: true,
                edge_optimization: false,
                hreflang_tags: true,
                auto_translation_hints: false,
                seo_analytics: true,
                crawl_monitoring: false,
                email_support: true,
                priority_support: false,
                dedicated_account: false
            }
        }
        
        yield verify_license(config)
    }
    
    fn enterprise(license_key: str, domain: str) -> Result<LicenseConfig, str> {
        let config = LicenseConfig {
            tier: SEOLicense::Enterprise,
            license_key: license_key,
            domain: domain,
            expires_at: 0,
            features: LicenseFeatures {
                basic_meta_tags: true,
                open_graph: true,
                twitter_cards: true,
                canonical_urls: true,
                ssr: true,
                ssg: true,
                isr: true,
                streaming_ssr: true,
                auto_sitemap: true,
                auto_robots: true,
                image_sitemap: true,
                video_sitemap: true,
                basic_schema: true,
                advanced_schema: true,
                custom_schema: true,
                preload_hints: true,
                prefetch_hints: true,
                edge_optimization: true,
                hreflang_tags: true,
                auto_translation_hints: true,
                seo_analytics: true,
                crawl_monitoring: true,
                email_support: true,
                priority_support: true,
                dedicated_account: true
            }
        }
        
        yield verify_license(config)
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// LICENSE VERIFICATION
// ═══════════════════════════════════════════════════════════════════════════

fn verify_license(var config: LicenseConfig) -> Result<LicenseConfig, str> {
    // Call Nova license server
    let response = HttpClient::post(
        "https://api.nova.org/v1/licenses/verify",
        {
            "license_key": config.license_key,
            "domain": config.domain,
            "product": "nova-seo"
        }
    )
    
    check response.status != 200 {
        Err("Invalid license key")
    }
    
    let data = JSON.parse(response.body)
    
    check !data.valid {
        Err(data.error)
    }
    
    config.expires_at = data.expires_at
    
    Ok(config)
}

// ═══════════════════════════════════════════════════════════════════════════
// FEATURE GUARDS
// ═══════════════════════════════════════════════════════════════════════════

open fn require_feature(license: LicenseConfig, feature: str) -> Result<(), str> {
    let allowed = match feature {
        "open_graph" => license.features.open_graph,
        "twitter_cards" => license.features.twitter_cards,
        "ssr" => license.features.ssr,
        "ssg" => license.features.ssg,
        "isr" => license.features.isr,
        "auto_sitemap" => license.features.auto_sitemap,
        "schema_org" => license.features.basic_schema,
        "advanced_schema" => license.features.advanced_schema,
        _ => false
    }
    
    check !allowed {
        let upgrade_msg = get_upgrade_message(license.tier, feature)
        Err(upgrade_msg)
    }
    
    // Check expiration
    check license.expires_at > 0 && now() > license.expires_at {
        Err("License expired. Please renew at https://nova.org/pricing")
    }
    
    Ok(())
}

fn get_upgrade_message(tier: SEOLicense, feature: str) -> str {
    match tier {
        SEOLicense::Free => {
            yield f"⚠️  '{feature}' requires Nova SEO Starter ($29/mo) or higher.\n" +
                   "   Upgrade at: https://nova.org/pricing\n" +
                   "   Free tier includes: basic meta tags only"
        },
        SEOLicense::Starter => {
            yield f"⚠️  '{feature}' requires Nova SEO Pro ($99/mo) or higher.\n" +
                   "   Upgrade at: https://nova.org/pricing"
        },
        SEOLicense::Pro => {
            yield f"⚠️  '{feature}' requires Nova SEO Enterprise ($499/mo).\n" +
                   "   Upgrade at: https://nova.org/pricing"
        },
        SEOLicense::Enterprise => {
            yield "Feature should be available. Contact support@nova.org"
        }
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// WATERMARK (for free tier)
// ═══════════════════════════════════════════════════════════════════════════

open fn add_watermark(license: LicenseConfig, html: str) -> str {
    check matches!(license.tier, SEOLicense::Free) {
        let watermark = "\n<!-- Powered by Nova SEO Free - Upgrade to remove this: https://nova.org/pricing -->\n"
        yield html.replace("</body>", watermark + "</body>")
    }
    
    yield html
}

// ═══════════════════════════════════════════════════════════════════════════
// USAGE TRACKING (for analytics and billing)
// ═══════════════════════════════════════════════════════════════════════════

open data UsageTracker {
    license: LicenseConfig,
    page_renders: i64,
    sitemap_generations: i64,
    schema_generations: i64
}

impl UsageTracker {
    fn new(license: LicenseConfig) -> UsageTracker {
        UsageTracker {
            license: license,
            page_renders: 0,
            sitemap_generations: 0,
            schema_generations: 0
        }
    }
    
    fn track_render(var self) {
        self.page_renders += 1
        
        // Report to analytics server every 100 renders
        check self.page_renders % 100 == 0 {
            self.report_usage()
        }
    }
    
    fn track_sitemap(var self) {
        self.sitemap_generations += 1
    }
    
    fn track_schema(var self) {
        self.schema_generations += 1
    }
    
    fn report_usage(self) {
        // Async report to analytics
        async {
            HttpClient::post(
                "https://api.nova.org/v1/analytics/usage",
                {
                    "license_key": self.license.license_key,
                    "page_renders": self.page_renders,
                    "sitemap_generations": self.sitemap_generations,
                    "schema_generations": self.schema_generations
                }
            )
        }
    }
}

