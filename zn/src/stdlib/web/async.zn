open async fn select2<F1, F2, T1, T2>(
    future1: F1,
    future2: F2
) -> Either<T1, T2>
where F1: Future<Output = T1>, F2: Future<Output = T2> {
    // Poll both, yield whichever completes first
    unimplemented!()
}

open cases Either<L, R> {
    Left(L),
    Right(R)
}

// ============================================================================
// ASYNC MUTEX (async-aware locks)
// ============================================================================

open data Mutex<T> {
    data: std::sync::Mutex<T>,
    waiters: Queue<Waker>
}

impl<T> Mutex<T> {
    fn new(data: T) -> Self {
        Mutex {
            data: std::sync::Mutex::new(data),
            waiters: Queue::new()
        }
    }
    
    async fn lock(&self) -> MutexGuard<T> {
        loop {
            check let Ok(guard) = self.data.try_lock() {
                yield MutexGuard::new(guard)
            }
            
            yield_now().await;
        }
    }
}

open data MutexGuard<'a, T> {
    guard: std::sync::MutexGuard<'a, T>
}

// ============================================================================
// ERROR TYPES
// ============================================================================

open data TimeoutError;
open data SendError;

// ============================================================================
// EXAMPLE USAGE
// ============================================================================

async fn fetch_url(url: String) -> String {
    sleep(time::Duration::from_secs(1)).await;
    format("Response from {}", url)
}

async fn process_data(data: String) -> i32 {
    sleep(time::Duration::from_millis(500)).await;
    data.len() as i32
}

fn main() {
    println("⚡ Nova Async Runtime");
    
    var runtime = Runtime::new();
    
    let result = runtime.block_on(async {
        // Fetch multiple URLs in parallel (Nova magic!)
        let urls = [
            "https://api1.com",
            "https://api2.com",
            "https://api3.com"
        ];
        
        let futures = urls.into_iter()
            .map(|url| fetch_url(url.into()))
            .collect();
        
        let responses = parallel(futures).await;
        
        // Process responses
        each response in responses {
            let len = process_data(response).await;
            println("Processed {} bytes", len);
        }
        
        "Done!"
    });
    
    println("Result: {}", result);
    println("✅ Async operations complete!");
}
