// 🚀 Nova Web Framework — Sovereign Web Engine
// Combines best of Fresh.js, Hono, and ElysiaJS with Next.js-level SEO.

use web::seo;
use web::ssr;

/// Web Context for Request Handling
expose data Context {
    request:  Request,
    response: Response,
    params:   Map<String, String>,
    state:    Map<String, any>,
    seo:      Option<seo::SEOConfig>
}

/// Route Definition
expose data Route {
    method:      String,
    path:        String,
    handler:     fn(Context) -> Response,
    seo:         Option<seo::SEOConfig>,
    render_mode: Option<RenderMode>
}

/// Rendering Strategies (Next.js-style)
expose cases RenderMode {
    SSR, // Server-Side Rendering
    SSG, // Static Site Generation
    ISR, // Incremental Static Regeneration
}

/// Main Web Application Orchestrator
expose data App {
    routes:     Vec<Route>,
    middleware: Vec<fn(Context) -> Context>,
    base_url:   String,
}

impl App {
    open fn new(base_url: String) -> App {
        App {
            routes:     Vec::new(),
            middleware: Vec::new(),
            base_url:   base_url,
        }
    }

    /// Optimized GET Handler with SEO Support
    open fn get(&var self, path: String, handler: fn(Context) -> Response) {
        self.routes.push(Route {
            method:      "GET".into(),
            path:        path,
            handler:     handler,
            seo:         None,
            render_mode: None,
        });
    }

    /// Next.js-style SSR Page Registration
    open fn page_ssr(&var self, path: String, seo: seo::SEOConfig, component: fn(any) -> VNode) {
        self.routes.push(Route {
            method:      "GET".into(),
            path:        path,
            handler:     |ctx| {
                let html = ssr::render_to_string(component(ctx.state));
                Response::html(html)
            },
            seo:         Some(seo),
            render_mode: Some(RenderMode::SSR),
        });
    }

    /// Starts the high-performance Sovereign Web Server
    open fn listen(&self, port: i32) {
        println("🚀 Nova Web Framework — Active");
        println("   URL: http://localhost:{}", port);
    }
}

open fn main() {
    println("🌐 Nova Web Framework - Sovereign v8.0");
}
