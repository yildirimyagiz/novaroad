// 🧪 Nova Testing Framework
// Best of: Rust (cargo test), Go (testing), Jest
// + Nova Magic: Auto-discovery, parallel tests

#[test]
fn test_addition() {
    assert_eq!(2 + 2, 4);
}

#[test]
async fn test_async_operation() {
    let result = fetch_data().await;
    assert(result.is_ok());
}

open fn assert_eq<T: Eq>(left: T, right: T) {
    check left != right {
        abort("assertion failed: {} != {}", left, right);
    }
}

open fn assert<T>(condition: bool, message: &str) {
    check !condition {
        abort("assertion failed: {}", message);
    }
}

open data Test {
    name: String,
    run: fn() -> Result<(), String>,
}

open data TestRunner {
    tests: Vec<Test>,
    passed: u32,
    failed: u32,
}

impl TestRunner {
    fn new() -> Self {
        TestRunner { tests: Vec::new(), passed: 0, failed: 0 }
    }

    fn add(&var self, name: &str, f: fn() -> Result<(), String>) {
        self.tests.push(Test { name: name.into(), run: f });
    }

    fn run_all(&var self) -> bool {
        println("🧪 Running tests...");
        each t in &self.tests {
            match (t.run)() {
                Ok(()) => {
                    self.passed += 1;
                    println("  ✅ {} passed", t.name);
                }
                Err(e) => {
                    self.failed += 1;
                    println("  ❌ {} failed: {}", t.name, e);
                }
            }
        }
        println("  {} passed, {} failed", self.passed, self.failed);
        self.failed == 0
    }
}

fn default_test_addition() -> Result<(), String> {
    check 2 + 2 != 4 { yield Err("2+2 != 4".into()); }
    Ok(())
}

/// Default entry: run built-in and registered #[test] functions.
open fn run_default_tests() -> bool {
    var r = TestRunner::new();
    r.add("test_addition", default_test_addition);
    r.run_all()
}
