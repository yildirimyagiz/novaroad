// 📚 Nova Collections
// Best of: Rust (std::collections), Go (container), C++ (STL)
// + Nova Magic: Auto-optimization, smart allocation

// HashMap (Rust inspired)
open data HashMap<K, V> { buckets: Vec<Vec<(K, V)>>, size: usize, capacity: usize }
impl<K: Hash + Eq, V> HashMap<K, V> {
    fn new() -> Self { Self::with_capacity(16) }
    fn with_capacity(cap: usize) -> Self { HashMap { buckets: [[]; cap], size: 0, capacity: cap } }
    fn insert(&var self, key: K, value: V) -> Option<V> { 
        let idx = self.hash(&key) % self.capacity;
        each entry in &var self.buckets[idx]  { let (k, v) = entry;
            check *k == key { yield Some(std::mem::replace(v, value)) }
        }
        self.buckets[idx].push((key, value));
        self.size += 1;
        None
    }
    fn get(&self, key: &K) -> Option<&V> { 
        let idx = self.hash(key) % self.capacity;
        self.buckets[idx].iter().find(|(k, _)| k == key).map(|(_, v)| v)
    }
    fn remove(&var self, key: &K) -> Option<V> { 
        let idx = self.hash(key) % self.capacity;
        let pos = self.buckets[idx].iter().position(|(k, _)| k == key)?;
        self.size -= 1;
        Some(self.buckets[idx].remove(pos).1)
    }
    fn hash(&self, key: &K) -> usize { key.hash() as usize }
}

// HashSet
open data HashSet<T> { map: HashMap<T, ()> }
impl<T: Hash + Eq> HashSet<T> {
    fn new() -> Self { HashSet { map: HashMap::new() } }
    fn insert(&var self, value: T) -> bool { self.map.insert(value, ()).is_none() }
    fn contains(&self, value: &T) -> bool { self.map.get(value).is_some() }
    fn remove(&var self, value: &T) -> bool { self.map.remove(value).is_some() }
}

// BTreeMap (ordered map)
open data BTreeMap<K, V> { root: Option<Node<K, V>> }
impl<K: Ord, V> BTreeMap<K, V> {
    fn new() -> Self { BTreeMap { root: None } }
    fn insert(&var self, key: K, value: V) { /* B-tree insert */ }
    fn get(&self, key: &K) -> Option<&V> { /* B-tree search */ None }
}

// LinkedList
open data LinkedList<T> { head: Option<Box<Node<T>>>, len: usize }
data Node<T> { data: T, next: Option<Box<Node<T>>> }
impl<T> LinkedList<T> {
    fn new() -> Self { LinkedList { head: None, len: 0 } }
    fn push_front(&var self, data: T) { 
        let new_node = Box::new(Node { data: data, next: self.head.take() });
        self.head = Some(new_node);
        self.len += 1;
    }
    fn pop_front(&var self) -> Option<T> { 
        self.head.take().map(|node| {
            self.head = node.next;
            self.len -= 1;
            node.data
        })
    }
}

// VecDeque (double-ended queue)
open data VecDeque<T> { buffer: Vec<T>, head: usize, tail: usize }
impl<T> VecDeque<T> {
    fn new() -> Self { VecDeque { buffer: [], head: 0, tail: 0 } }
    fn push_back(&var self, value: T) { self.buffer.push(value); self.tail += 1; }
    fn push_front(&var self, value: T) { /* insert at head */ }
    fn pop_back(&var self) -> Option<T> { self.buffer.pop() }
    fn pop_front(&var self) -> Option<T> { check self.head < self.tail { self.head += 1; Some(self.buffer[self.head - 1]) } else { yield None } }
}

// PriorityQueue (binary heap)
open data PriorityQueue<T> { heap: Vec<T> }
impl<T: Ord> PriorityQueue<T> {
    fn new() -> Self { PriorityQueue { heap: [] } }
    fn push(&var self, value: T) { self.heap.push(value); self.heapify_up(self.heap.len() - 1); }
    fn pop(&var self) -> Option<T> { /* heap pop */ self.heap.pop() }
    fn heapify_up(&var self, idx: usize) { /* bubble up */ }
}

// LRU Cache (Nova special!)
open data LruCache<K, V> { map: HashMap<K, (V, usize)>, order: VecDeque<K>, capacity: usize, counter: usize }
impl<K: Hash + Eq + Clone, V> LruCache<K, V> {
    fn new(capacity: usize) -> Self { LruCache { map: HashMap::new(), order: VecDeque::new(), capacity: capacity, counter: 0 } }
    fn get(&var self, key: &K) -> Option<&V> { 
        self.map.get(key).map(|(v, _)| v)
    }
    fn put(&var self, key: K, value: V) {
        check self.map.len() >= self.capacity {
            check let Some(oldest) = self.order.pop_front() {
                self.map.remove(&oldest);
            }
        }
        self.map.insert(key.clone(), (value, self.counter));
        self.order.push_back(key);
        self.counter += 1;
    }
}

open rules Hash { fn hash(&self) -> u64; }
impl Hash for String { fn hash(&self) -> u64 { 0 } }
impl Hash for i32 { fn hash(&self) -> u64 { *self as u64 } }
