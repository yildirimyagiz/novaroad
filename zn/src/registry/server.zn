// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  Nova — REGISTRY SERVER  v9.0                                       ║
// ║  HTTP/HTTPS server for package registry                                   ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

use std::collections::HashMap;
use crate::registry::package_registry::{PackageRegistry, PackageMetadata};

/// HTTP method
expose cases HttpMethod {
    GET,
    POST,
    PUT,
    DELETE,
}

/// HTTP request
expose data HttpRequest {
    method: HttpMethod,
    path:   String,
    body:   Option<String>,
}

/// HTTP response
expose data HttpResponse {
    status: u16,
    body:   String,
}

/// Registry Server
expose data RegistryServer {
    registry: PackageRegistry,
    port:     u16,
}

impl RegistryServer {
    open fn new(port: u16) -> RegistryServer {
        RegistryServer {
            registry: PackageRegistry::new("./storage".into(), "./index".into()),
            port:     port,
        }
    }

    open fn start(&var self) {
        println("🌐 Registry Server: Starting on port {}", self.port);
        self.registry.init();
        println("✅ Registry Server: Ready to accept connections");
    }

    open fn handle_request(&self, req: HttpRequest) -> HttpResponse {
        match req.method {
            HttpMethod::GET => self.handle_get(req.path),
            HttpMethod::POST => self.handle_post(req.path, req.body),
            _ => HttpResponse {
                status: 405,
                body:   "Method Not Allowed".into(),
            },
        }
    }

    fn handle_get(&self, path: String) -> HttpResponse {
        println("🌐 GET {}", path);
        HttpResponse {
            status: 200,
            body:   "{}".into(),
        }
    }

    fn handle_post(&self, path: String, body: Option<String>) -> HttpResponse {
        println("🌐 POST {}", path);
        HttpResponse {
            status: 201,
            body:   "{}".into(),
        }
    }
}

open fn main() {
    println("🌐 Nova Registry Server v9.0 - Active");
    var server = RegistryServer::new(8080);
    server.start();
}
