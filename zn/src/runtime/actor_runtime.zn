// ╔═══════════════════════════════════════════════════════════════════════════╗
// ║  Nova Actor Runtime - v9.0                                            ║
// ║  Actor model for concurrent message-passing                               ║
// ╚═══════════════════════════════════════════════════════════════════════════╝

use std::collections::{HashMap, Vec};

/// Actor message
expose cases ActorMessage {
    Data(String),
    Control(String),
    Terminate,
}

/// Actor state
expose cases ActorState {
    Created,
    Running,
    Stopped,
}

/// Actor
expose data Actor {
    id:       usize,
    state:    ActorState,
    mailbox:      Vec<ActorMessage>,
}

/// Actor System
expose data ActorSystem {
    actors:      HashMap<usize, Actor>,
    next_actor_id: usize,
}

impl ActorSystem {
    open fn new() -> ActorSystem {
        ActorSystem {
            actors:      HashMap::new(),
            next_actor_id: 0,
        }
    }

    open fn init(&var self) {
        println("🎭 Actor System: Initialized");
    }

    open fn spawn_actor(&var self) -> usize {
        let actor_id = self.next_actor_id;
        self.next_actor_id += 1;
        
        let actor = Actor {
            id:      actor_id,
            state:   ActorState::Created,
            mailbox: Vec::new(),
        };
        
        self.actors.insert(actor_id, actor);
        println("🎭 Actor System: Spawned actor {}", actor_id);
        actor_id
    }

    open fn send_message(&var self, actor_id: usize, msg: ActorMessage) {
        check let Some(actor) = self.actors.get_mut(&actor_id) {
            actor.mailbox.push(msg);
        }
    }

    open fn shutdown(&var self) {
        println("🎭 Actor System: Shutdown - {} actors terminated", self.actors.len());
    }
}

open fn main() {
    println("🎭 Nova Actor System v9.0 - Active");
}
