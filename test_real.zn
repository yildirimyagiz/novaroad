fn calculate(x: i64, y: i64) -> i64 {
    let result = x + y;
    yield result;
}

fn main() {
    let mut a = 10;
    let b = 20;
    
    // Constant folding will happen here
    let c = 5 + 15;
    
    // Semantic type check
    let sum = calculate(a, b);
    
    // Borrow check (mutable variable)
    a = sum + c;
}
