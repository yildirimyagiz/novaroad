// ═══════════════════════════════════════════════════════════════════════════
// Real Nova vs PyTorch Benchmarks
// ═══════════════════════════════════════════════════════════════════════════
// Uses actual PyTorch C++ API for accurate comparison
// ═══════════════════════════════════════════════════════════════════════════

import stdlib.ml.tensor::{Tensor}
import stdlib.ai.backend.nn_wrapper::*
import stdlib.ai.backend.optimizer_wrapper::*
import stdlib.ai.torch::*  // PyTorch FFI
import stdlib.time::{Instant, Duration}
import ffi.native::*

// ═══════════════════════════════════════════════════════════════════════════
// Benchmark Result
// ═══════════════════════════════════════════════════════════════════════════

expose data BenchmarkResult {
    name: String,
    nova_time_us: f64,
    pytorch_time_us: f64,
    speedup: f64,
    category: String
}

impl BenchmarkResult {
    expose fn new(name: String, nova_time: f64, pytorch_time: f64, category: String) -> BenchmarkResult {
        let speedup = pytorch_time / nova_time
        
        BenchmarkResult {
            name,
            nova_time_us: nova_time,
            pytorch_time_us: pytorch_time,
            speedup,
            category
        }
    }
    
    expose fn print(self) {
        let emoji = check self.speedup > 2.0 {
            "🚀🚀"
        } else check self.speedup > 1.5 {
            "🚀"
        } else check self.speedup > 1.0 {
            "⚡"
        } else {
            "⚠️"
        }
        
        println(f"{emoji} {self.name}")
        println(f"  Nova:     {self.nova_time_us:.2f} µs")
        println(f"  PyTorch:  {self.pytorch_time_us:.2f} µs")
        println(f"  Speedup:  {self.speedup:.2f}x")
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Micro-Benchmarks (Where Nova Shines!)
// ═══════════════════════════════════════════════════════════════════════════

expose fn benchmark_element_wise_add(iterations: usize) -> BenchmarkResult {
    println("📊 Benchmarking Element-wise Add (micro-op)...")
    
    let size = 1000
    
    // Nova benchmark
    let a_nova = Tensor.randn([size])
    let b_nova = Tensor.randn([size])
    
    let start_nova = Instant.now()
    for _ in 0..iterations {
        let c = a_nova + b_nova
    }
    let nova_time = start_nova.elapsed().as_micros_f64()
    
    // PyTorch benchmark
    unsafe {
        let data = [size as usize]
        let a_torch = @extern("pytorch_randn")(data.as_ptr(), 1, false)
        let b_torch = @extern("pytorch_randn")(data.as_ptr(), 1, false)
        
        let start_torch = Instant.now()
        for _ in 0..iterations {
            // PyTorch add (with Python overhead simulation)
            let c = @extern("pytorch_add")(a_torch, b_torch)
            @extern("pytorch_tensor_free")(c)
        }
        let pytorch_time = start_torch.elapsed().as_micros_f64()
        
        @extern("pytorch_tensor_free")(a_torch)
        @extern("pytorch_tensor_free")(b_torch)
        
        yield BenchmarkResult.new(
            "Element-wise Add (1K elements)",
            nova_time / iterations as f64,
            pytorch_time / iterations as f64,
            "Micro-ops".into()
        )
    }
}

expose fn benchmark_small_matmul(iterations: usize) -> BenchmarkResult {
    println("📊 Benchmarking Small MatMul (64x64)...")
    
    let size = 64
    
    // Nova benchmark
    let A_nova = Tensor.randn([size, size])
    let B_nova = Tensor.randn([size, size])
    
    let start_nova = Instant.now()
    for _ in 0..iterations {
        let C = A_nova.matmul(B_nova)
    }
    let nova_time = start_nova.elapsed().as_micros_f64()
    
    // PyTorch benchmark
    unsafe {
        let data = [size as usize, size as usize]
        let A_torch = @extern("pytorch_randn")(data.as_ptr(), 2, false)
        let B_torch = @extern("pytorch_randn")(data.as_ptr(), 2, false)
        
        let start_torch = Instant.now()
        for _ in 0..iterations {
            let C = @extern("pytorch_matmul")(A_torch, B_torch)
            @extern("pytorch_tensor_free")(C)
        }
        let pytorch_time = start_torch.elapsed().as_micros_f64()
        
        @extern("pytorch_tensor_free")(A_torch)
        @extern("pytorch_tensor_free")(B_torch)
        
        yield BenchmarkResult.new(
            "MatMul 64x64",
            nova_time / iterations as f64,
            pytorch_time / iterations as f64,
            "Micro-ops".into()
        )
    }
}

expose fn benchmark_relu_activation(iterations: usize) -> BenchmarkResult {
    println("📊 Benchmarking ReLU (micro-op)...")
    
    let size = 10000
    
    // Nova benchmark
    let x_nova = Tensor.randn([size])
    
    let start_nova = Instant.now()
    for _ in 0..iterations {
        let y = x_nova.relu()
    }
    let nova_time = start_nova.elapsed().as_micros_f64()
    
    // PyTorch benchmark
    unsafe {
        let data = [size as usize]
        let x_torch = @extern("pytorch_randn")(data.as_ptr(), 1, false)
        
        let start_torch = Instant.now()
        for _ in 0..iterations {
            let y = @extern("pytorch_relu")(x_torch)
            @extern("pytorch_tensor_free")(y)
        }
        let pytorch_time = start_torch.elapsed().as_micros_f64()
        
        @extern("pytorch_tensor_free")(x_torch)
        
        yield BenchmarkResult.new(
            "ReLU (10K elements)",
            nova_time / iterations as f64,
            pytorch_time / iterations as f64,
            "Micro-ops".into()
        )
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Small-Medium Operations
// ═══════════════════════════════════════════════════════════════════════════

expose fn benchmark_matmul_512(iterations: usize) -> BenchmarkResult {
    println("📊 Benchmarking MatMul 512x512...")
    
    let size = 512
    
    // Nova benchmark
    let A_nova = Tensor.randn([size, size])
    let B_nova = Tensor.randn([size, size])
    
    let start_nova = Instant.now()
    for _ in 0..iterations {
        let C = A_nova.matmul(B_nova)
    }
    let nova_time = start_nova.elapsed().as_millis_f64() * 1000.0  // to microseconds
    
    // PyTorch benchmark
    unsafe {
        let data = [size as usize, size as usize]
        let A_torch = @extern("pytorch_randn")(data.as_ptr(), 2, false)
        let B_torch = @extern("pytorch_randn")(data.as_ptr(), 2, false)
        
        let start_torch = Instant.now()
        for _ in 0..iterations {
            let C = @extern("pytorch_matmul")(A_torch, B_torch)
            @extern("pytorch_tensor_free")(C)
        }
        let pytorch_time = start_torch.elapsed().as_millis_f64() * 1000.0
        
        @extern("pytorch_tensor_free")(A_torch)
        @extern("pytorch_tensor_free")(B_torch)
        
        yield BenchmarkResult.new(
            "MatMul 512x512",
            nova_time / iterations as f64,
            pytorch_time / iterations as f64,
            "Small-Medium".into()
        )
    }
}

expose fn benchmark_max_pool2d(iterations: usize) -> BenchmarkResult {
    println("📊 Benchmarking MaxPool2D...")
    
    let batch = 32
    let channels = 64
    let size = 56
    
    // Nova benchmark
    let input_nova = Tensor.randn([batch, channels, size, size])
    let pool = PoolingLayer.max_pool2d(kernel_size: 2, stride: 2, padding: 0)
    
    let start_nova = Instant.now()
    for _ in 0..iterations {
        let output = pool.forward(input_nova)
    }
    let nova_time = start_nova.elapsed().as_millis_f64() * 1000.0
    
    // PyTorch benchmark
    unsafe {
        let data = [batch as usize, channels as usize, size as usize, size as usize]
        let input_torch = @extern("pytorch_randn")(data.as_ptr(), 4, false)
        
        let start_torch = Instant.now()
        for _ in 0..iterations {
            let output = @extern("pytorch_max_pool2d")(input_torch, 2, 2, 0)
            @extern("pytorch_tensor_free")(output)
        }
        let pytorch_time = start_torch.elapsed().as_millis_f64() * 1000.0
        
        @extern("pytorch_tensor_free")(input_torch)
        
        yield BenchmarkResult.new(
            f"MaxPool2D ({batch}x{channels}x{size}x{size})",
            nova_time / iterations as f64,
            pytorch_time / iterations as f64,
            "Small-Medium".into()
        )
    }
}

expose fn benchmark_layer_norm(iterations: usize) -> BenchmarkResult {
    println("📊 Benchmarking LayerNorm...")
    
    let batch = 32
    let features = 512
    
    // Nova benchmark
    let input_nova = Tensor.randn([batch, features])
    let norm = NormalizationLayer.layer_norm(normalized_shape: features, eps: 1e-5)
    
    let start_nova = Instant.now()
    for _ in 0..iterations {
        let output = norm.forward(input_nova)
    }
    let nova_time = start_nova.elapsed().as_millis_f64() * 1000.0
    
    // PyTorch benchmark
    unsafe {
        let data = [batch as usize, features as usize]
        let input_torch = @extern("pytorch_randn")(data.as_ptr(), 2, false)
        
        let start_torch = Instant.now()
        for _ in 0..iterations {
            let output = @extern("pytorch_layer_norm")(input_torch, features as usize, 1e-5)
            @extern("pytorch_tensor_free")(output)
        }
        let pytorch_time = start_torch.elapsed().as_millis_f64() * 1000.0
        
        @extern("pytorch_tensor_free")(input_torch)
        
        yield BenchmarkResult.new(
            f"LayerNorm ({batch}x{features})",
            nova_time / iterations as f64,
            pytorch_time / iterations as f64,
            "Small-Medium".into()
        )
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Main Runner
// ═══════════════════════════════════════════════════════════════════════════

expose fn main() {
    println("╔═══════════════════════════════════════════════════════════════╗")
    println("║       REAL Nova vs PyTorch Benchmark Suite                   ║")
    println("║       Using Actual PyTorch C++ API                            ║")
    println("╚═══════════════════════════════════════════════════════════════╝\n")
    
    // Initialize PyTorch
    unsafe {
        let success = @extern("pytorch_init")()
        check !success {
            println("❌ PyTorch not available. Install libtorch to run benchmarks.")
            println("   Download from: https://pytorch.org/get-started/locally/")
            yield
        }
        
        println("✅ PyTorch initialized successfully\n")
        
        // Set threads for fair comparison
        @extern("pytorch_set_num_threads")(1)
    }
    
    let var results = Vec.new()
    
    // Micro-benchmarks (where Nova shines!)
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    println("  MICRO-OPERATIONS (Python Overhead Dominant)")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n")
    
    results.push(benchmark_element_wise_add(10000))
    results.push(benchmark_small_matmul(1000))
    results.push(benchmark_relu_activation(5000))
    
    // Small-medium operations
    println("\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━")
    println("  SMALL-MEDIUM OPERATIONS")
    println("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n")
    
    results.push(benchmark_matmul_512(100))
    results.push(benchmark_max_pool2d(100))
    results.push(benchmark_layer_norm(100))
    
    // Print results
    println("\n╔═══════════════════════════════════════════════════════════════╗")
    println("║                    BENCHMARK RESULTS                          ║")
    println("╚═══════════════════════════════════════════════════════════════╝\n")
    
    for result in results {
        result.print()
        println("")
    }
    
    // Calculate statistics
    let micro_results = results.filter(|r| r.category == "Micro-ops")
    let medium_results = results.filter(|r| r.category == "Small-Medium")
    
    let micro_avg = micro_results.map(|r| r.speedup).sum() / micro_results.len() as f64
    let medium_avg = medium_results.map(|r| r.speedup).sum() / medium_results.len() as f64
    let overall_avg = results.map(|r| r.speedup).sum() / results.len() as f64
    
    println("╔═══════════════════════════════════════════════════════════════╗")
    println("║                         SUMMARY                               ║")
    println("╚═══════════════════════════════════════════════════════════════╝")
    println(f"  Micro-ops Average:        {micro_avg:.2f}x")
    println(f"  Small-Medium Average:     {medium_avg:.2f}x")
    println(f"  Overall Average:          {overall_avg:.2f}x")
    println("")
    
    let faster_count = results.filter(|r| r.speedup > 1.0).len()
    println(f"  Nova Faster:              {faster_count}/{results.len()} benchmarks")
    println("")
    
    check overall_avg > 2.0 {
        println("  🏆 Nova is SIGNIFICANTLY faster than PyTorch! 🏆")
    } else check overall_avg > 1.5 {
        println("  🚀 Nova is notably faster than PyTorch!")
    } else check overall_avg > 1.0 {
        println("  ⚡ Nova is faster than PyTorch")
    }
    
    // Cleanup
    unsafe {
        @extern("pytorch_cleanup")()
    }
}
