# Nova Language - .gitignore

# Build artifacts
*.o
*.a
*.so
*.dylib
*.dll
*.exe
build/
build_*/
!build_stage0/
dist/
target/
*.dSYM/
build_artifacts/

# Compiler outputs
nova
nova-*
!nova/
*.bc
*.ll
*.s
*.asm

# Object files
*.obj
*.lib
*.pdb

# Test executables
test_*
!test_*.c
!test_*.zn
!test_*.py
!tests/
simple_test
cli_stability_tests
abi_gate_tests
bootstrap_gate_tests

# Temporary files
tmp_*
*.tmp
*.temp
*.swp
*.swo
*~
.DS_Store

# IDE and editor files
.vscode/
.idea/
*.iml
*.sublime-*
.vs/
.cache/
compile_commands.json.bak

# Package manager
*.lock
node_modules/
Cargo.lock

# Benchmarks and profiling
*.prof
*.perf
callgrind.out.*
perf.data*
*.gcda
*.gcno
*.gcov

# Logs
*.log
*.out
*.err
build.log
build_output.log

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
*.egg-info/
.coverage

# Backup files
*.bak
*.backup
*_backup
*.orig

# Archives
*.tar.gz
*.zip
*.tar
*.tgz

# CMake
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
install_manifest.txt

# Ninja
.ninja_*

# macOS
.AppleDouble
.LSOverride
Icon?

# Linux
.fuse_hidden*
.nfs*

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Documentation builds
docs/book/
docs/_build/

# Keep important files
!nova/nova
!nova/*.md
!README.md
!CHANGELOG.md
!CONTRIBUTING.md
!INSTALL.md
!QUICK_START.md
