#!/usr/bin/env bash
# Nova REPL/VM (znrepl) - Execute Nova Bytecode or start interactive session
# Version: 1.0.0

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
MAGENTA='\033[0;35m'
CYAN='\033[0;36m'
NC='\033[0m'

# Detect paths
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NOVA_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
REAL_VM="$NOVA_ROOT/build/tools/znrepl"

# Determine VM binary location
if [ -n "$NOVA_HOME" ] && [ -f "$NOVA_HOME/binaries/znrepl" ]; then
    REAL_VM="$NOVA_HOME/binaries/znrepl"
elif [ -f "$NOVA_ROOT/build/tools/znrepl" ]; then
    REAL_VM="$NOVA_ROOT/build/tools/znrepl"
else
    REAL_VM="$NOVA_ROOT/binaries/znrepl"
fi

if [ ! -f "$REAL_VM" ]; then
    echo -e "${RED}❌ Error: Nova VM binary not found.${NC}"
    echo -e "${YELLOW}Please run 'make' or 'install.sh'.${NC}"
    exit 1
fi

# Show banner if no file provided
show_banner() {
    echo -e "${CYAN}╔════════════════════════════════════════════╗${NC}"
    echo -e "${CYAN}║${NC}   ${MAGENTA}Nova Sovereign VM/REPL v1.0${NC}            ${CYAN}║${NC}"
    echo -e "${CYAN}║${NC}   Powered by Nova Native Engine            ${CYAN}║${NC}"
    echo -e "${CYAN}╚════════════════════════════════════════════╝${NC}"
}

# Main
if [ $# -eq 0 ]; then
    show_banner
    echo -e "${YELLOW}Usage: znrepl <file.nbc> [args...]${NC}"
    echo -e "Interactive REPL mode coming soon to Nova Native."
    exit 0
fi

# Execute the VM with provided arguments
exec "$REAL_VM" "$@"
