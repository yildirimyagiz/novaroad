#!/usr/bin/env bash
# Nova Compiler (znc) - Compile Nova source files
# Version: 9.0.0

set -e

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

# Detect script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NOVA_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# Determine compiler binary location
if [ -n "$NOVA_HOME" ] && [ -f "$NOVA_HOME/binaries/znc" ]; then
    NOVA_COMPILER="$NOVA_HOME/binaries/znc"
elif [ -f "$NOVA_ROOT/build/tools/znc" ]; then
    NOVA_COMPILER="$NOVA_ROOT/build/tools/znc"
else
    NOVA_COMPILER="$NOVA_ROOT/binaries/znc"
fi

if [ ! -f "$NOVA_COMPILER" ]; then
    echo -e "${RED}❌ Error: Nova compiler binary not found.${NC}"
    echo -e "${YELLOW}Please run 'make' or 'install.sh'.${NC}"
    exit 1
fi

# Default options
INPUT_FILE=""
OUTPUT_FILE=""
OPTIMIZATION_LEVEL="-O0"
BACKEND="llvm"
VERBOSE=false
SHOW_HELP=false

# Parse arguments
FFI_LIBS=""
LINK_FRAMEWORKS=""

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            -o|--output)
                OUTPUT_FILE="$2"
                shift 2
                ;;
            -O0|-O1|-O2|-O3)
                OPTIMIZATION_LEVEL="$1"
                shift
                ;;
            --backend)
                BACKEND="$2"
                shift 2
                ;;
            -v|--verbose)
                VERBOSE=true
                shift
                ;;
            -h|--help)
                SHOW_HELP=true
                shift
                ;;
            --emit-ir)
                EMIT_IR=true
                shift
                ;;
            --emit-asm)
                EMIT_ASM=true
                shift
                ;;
            --ffi)
                FFI_LIBS="$FFI_LIBS $2"
                shift 2
                ;;
            --framework)
                LINK_FRAMEWORKS="$LINK_FRAMEWORKS -framework $2"
                shift 2
                ;;
            -*)
                echo -e "${RED}❌ Unknown option: $1${NC}"
                exit 1
                ;;
            *)
                if [ -z "$INPUT_FILE" ]; then
                    INPUT_FILE="$1"
                else
                    echo -e "${RED}❌ Multiple input files not supported yet${NC}"
                    exit 1
                fi
                shift
                ;;
        esac
    done
}

# Show help
show_help() {
    cat << EOF
Nova Compiler (znc) v9.0.0

USAGE:
    znc [OPTIONS] <input.zn>

OPTIONS:
    -o, --output <file>     Output file name
    -O0, -O1, -O2, -O3      Optimization level (default: -O0)
    --backend <backend>     Code generation backend (llvm, vm, wasm)
    --emit-ir               Emit LLVM IR
    --emit-asm              Emit assembly
    -v, --verbose           Verbose output
    -h, --help              Show this help message

EXAMPLES:
    znc main.zn -o app              # Compile to executable
    znc main.zn -O3 -o app          # Compile with optimizations
    znc main.zn --emit-ir           # Emit LLVM IR
    znc main.zn --backend wasm      # Compile to WebAssembly

EOF
}

# Compile using Nova compiler
compile() {
    local input="$1"
    local output="$2"
    
    if [ ! -f "$input" ]; then
        echo -e "${RED}❌ Error: Input file not found: $input${NC}"
        exit 1
    fi
    
    if $VERBOSE; then
        echo -e "${BLUE}Compiling: $input${NC}"
        echo -e "${BLUE}Output: $output${NC}"
        echo -e "${BLUE}Optimization: $OPTIMIZATION_LEVEL${NC}"
        echo -e "${BLUE}Backend: $BACKEND${NC}"
    fi
    
    # ── Real Compilation Step ───────────────────────────────────────────────
    local cmd="\"$NOVA_COMPILER\" \"$input\" -o \"$output\" $OPTIMIZATION_LEVEL --backend $BACKEND -M \"$NOVA_ROOT/zn/stdlib\""
    
    if $VERBOSE; then
        echo -e "${CYAN}Executing: $cmd${NC}"
    fi

    eval $cmd || {
        echo -e "${RED}❌ Nova compilation failed${NC}"
        exit 1
    }

    # ── Optional: Link FFI/Frameworks if it's a native build ─────────────────
    # (The compiler might emit an object file or C code; znc wrapper handles 
    # the final assembly/linking phase if needed)
    
    if [ -f "$output" ]; then
        chmod +x "$output"
        if $VERBOSE; then
            echo -e "${GREEN}✅ Compilation successful: $output${NC}"
        fi
    else
        echo -e "${RED}❌ Compilation failed (output not generated)${NC}"
        exit 1
    fi
}

# Main
main() {
    parse_args "$@"
    
    if $SHOW_HELP || [ -z "$INPUT_FILE" ]; then
        show_help
        exit 0
    fi
    
    # Determine output file
    if [ -z "$OUTPUT_FILE" ]; then
        OUTPUT_FILE="${INPUT_FILE%.zn}"
    fi
    
    compile "$INPUT_FILE" "$OUTPUT_FILE"
}

main "$@"
