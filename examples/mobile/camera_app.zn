// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Example: Camera App - Photo Capture                                        ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use nova::ui::mobile::*;
use nova::ui::mobile::platform::camera::*;

fn main() {
    // Request camera permission first
    match Camera::request_permission() {
        Ok(()) => {
            let app = CameraApp::new();
            run_app(app);
        }
        Err(e) => {
            println("Camera permission denied: {}", e);
        }
    }
}

data CameraApp {
    camera: Camera,
    photo: ViewState<Option<CameraImage>>,
}

apply CameraApp {
    fn new() -> CameraApp {
        CameraApp {
            camera: Camera::new(),
            photo: ViewState::new(None),
        }
    }
}

apply View for CameraApp {
    fn build(&self, ctx: BuildContext) -> Element {
        Column::new([
            // Title
            Box::new(Text::new("Camera App".into()).font_size(24.0).bold()),
            
            // Photo preview
            Box::new(
                check let Some(ref photo) = *self.photo.get() {
                    Image::from_data(photo.data.clone())
                        .frame(300.0, 300.0)
                } else {
                    Text::new("No photo taken".into())
                }
            ),
            
            // Capture button
            Box::new(
                Button::new("Capture Photo".into())
                    .background(Color::blue())
                    .on_tap(Box::new(|| {
                        match self.camera.capture_photo() {
                            Ok(img) => {
                                let var p = self.photo.clone();
                                p.set(Some(img));
                            }
                            Err(e) => println("Capture failed: {}", e),
                        }
                    }))
            ),
            
            // Switch camera button
            Box::new(
                Button::new("Switch Camera".into())
                    .on_tap(Box::new(|| {
                        self.camera.is_front = !self.camera.is_front;
                    }))
            ),
        ])
        .spacing(20.0)
        .padding(EdgeInsets::all(20.0))
        .build(ctx)
    }
    
    fn update(&var self, msg: Message) {}
}

fn run_app(app: CameraApp) {
    #[cfg(target_os = "ios")]
    {
        let vc = iOSViewController::new(Box::new(app)).title("Camera".into());
    }
    
    #[cfg(target_os = "android")]
    {
        let activity = AndroidActivity::new(Box::new(app)).title("Camera".into());
    }
}
