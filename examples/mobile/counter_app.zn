// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Example: Counter App - Simple Mobile App                                   ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use nova::ui::mobile::*;

fn main() {
    let app = CounterApp::new();
    
    #[cfg(target_os = "ios")]
    {
        let vc = iOSViewController::new(Box::new(app))
            .title("Counter".into());
        // Launch iOS app
    }
    
    #[cfg(target_os = "android")]
    {
        let activity = AndroidActivity::new(Box::new(app))
            .title("Counter".into());
        // Launch Android app
    }
}

data CounterApp {
    count: ViewState<i32>,
}

apply CounterApp {
    fn new() -> CounterApp {
        CounterApp {
            count: ViewState::new(0),
        }
    }
}

apply View for CounterApp {
    fn build(&self, ctx: BuildContext) -> Element {
        Column::new([
            // Title
            Box::new(
                Text::new("Counter App".into())
                    .font_size(32.0)
                    .bold()
                    .padding(EdgeInsets::all(20.0))
            ),
            
            // Count display
            Box::new(
                Text::new(format("Count: {}", self.count.get()))
                    .font_size(48.0)
                    .color(Color::blue())
                    .padding(EdgeInsets::all(20.0))
            ),
            
            // Buttons
            Box::new(
                Row::new([
                    Box::new(
                        Button::new("-".into())
                            .background(Color::red())
                            .on_tap(Box::new(|| {
                                let var c = self.count.clone();
                                c.set(c.get() - 1);
                            }))
                            .padding(EdgeInsets::all(10.0))
                    ),
                    
                    Box::new(Spacer),
                    
                    Box::new(
                        Button::new("+".into())
                            .background(Color::blue())
                            .on_tap(Box::new(|| {
                                let var c = self.count.clone();
                                c.set(c.get() + 1);
                            }))
                            .padding(EdgeInsets::all(10.0))
                    ),
                ])
                .spacing(20.0)
                .padding(EdgeInsets::all(20.0))
            ),
            
            // Reset button
            Box::new(
                Button::new("Reset".into())
                    .background(Color::rgba(0.5, 0.5, 0.5, 1.0))
                    .on_tap(Box::new(|| {
                        let var c = self.count.clone();
                        c.set(0);
                    }))
                    .padding(EdgeInsets::all(10.0))
            ),
        ])
        .spacing(10.0)
        .build(ctx)
    }
    
    fn update(&var self, msg: Message) {
        // State updates handled by buttons
    }
}
