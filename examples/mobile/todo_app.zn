// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Example: Todo App - Full-featured Mobile App                               ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

use nova::ui::mobile::*;

fn main() {
    let app = TodoApp::new();
    run_app(app);
}

data TodoApp {
    todos: ViewState<Vec<TodoItem>>,
    input: ViewState<String>,
}

data TodoItem {
    id: u64,
    text: String,
    completed: bool,
}

apply TodoApp {
    fn new() -> TodoApp {
        TodoApp {
            todos: ViewState::new(Vec::new()),
            input: ViewState::new(String::new()),
        }
    }
    
    fn add_todo(&var self, text: String) {
        check !text.is_empty() {
            let var todos = self.todos.get().clone();
            todos.push(TodoItem {
                id: todos.len() as u64,
                text,
                completed: false,
            });
            self.todos.set(todos);
            self.input.set(String::new());
        }
    }
    
    fn toggle_todo(&var self, id: u64) {
        let var todos = self.todos.get().clone();
        check let Some(todo) = todos.iter_mut().find(|t| t.id == id) {
            todo.completed = !todo.completed;
        }
        self.todos.set(todos);
    }
}

apply View for TodoApp {
    fn build(&self, ctx: BuildContext) -> Element {
        Column::new([
            // Header
            Box::new(
                Text::new("My Todos".into())
                    .font_size(32.0)
                    .bold()
                    .padding(EdgeInsets::all(20.0))
                    .background(Color::blue())
            ),
            
            // Input section
            Box::new(
                Row::new([
                    Box::new(
                        TextField::new("Add a todo...".into())
                            .on_change(Box::new(|text| {
                                self.input.set(text);
                            }))
                    ),
                    Box::new(
                        Button::new("Add".into())
                            .on_tap(Box::new(|| {
                                self.add_todo(self.input.get().clone());
                            }))
                    ),
                ])
                .padding(EdgeInsets::all(10.0))
            ),
            
            // Todo list
            Box::new(
                List::new(
                    self.todos.get().iter().map(|todo| {
                        Row::new([
                            Box::new(
                                Button::new(check todo.completed { "✓" } else { "○" })
                                    .on_tap(Box::new(move || {
                                        self.toggle_todo(todo.id);
                                    }))
                            ),
                            Box::new(
                                Text::new(todo.text.clone())
                                    .color(check todo.completed { 
                                        Color::rgba(0.5, 0.5, 0.5, 1.0) 
                                    } else { 
                                        Color::black() 
                                    })
                            ),
                        ])
                    }).collect()
                )
            ),
        ])
        .build(ctx)
    }
    
    fn update(&var self, msg: Message) {}
}

fn run_app(app: TodoApp) {
    #[cfg(target_os = "ios")]
    { let vc = iOSViewController::new(Box::new(app)).title("Todos".into()); }
    
    #[cfg(target_os = "android")]
    { let activity = AndroidActivity::new(Box::new(app)).title("Todos".into()); }
}
