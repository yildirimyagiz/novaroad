// REAL Window with FFI calls

expose fn main() {
    println("🚀 Creating REAL macOS Window via FFI");
    println("═══════════════════════════════════════");
    println("");
    
    // FFI calls - these will be translated to C
    unsafe {
        let window = NSWindow_new(1200.0, 800.0, "Nova AI Studio");
        NSWindow_show(window);
    }
    
    println("✅ Window created and shown!");
    println("Check your screen - window should be visible!");
}
