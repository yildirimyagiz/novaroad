// ╔══════════════════════════════════════════════════════════════════════════════╗
// ║  Nova AI Studio — Desktop Application  v1.0                               ║
// ║                                                                            ║
// ║  Native macOS desktop app using Cocoa FFI                                 ║
// ║  Demonstrates: FFI calls, window mgmt, UI components, event loop         ║
// ╚══════════════════════════════════════════════════════════════════════════════╝

// ── FFI Declarations ────────────────────────────────────────────────────────
// These map to the C functions in cocoa_bridge.m

foreign "C" {
    // App lifecycle
    fn nova_app_init();
    fn nova_app_run();
    fn nova_app_quit();

    // Window management
    fn nova_window_create(width: f64, height: f64, title: *const i8) -> *var u8;
    fn nova_window_show(window: *var u8);
    fn nova_window_set_title(window: *var u8, title: *const i8);

    // UI components
    fn nova_label_create(window: *var u8, text: *const i8, x: f64, y: f64, w: f64, h: f64) -> *var u8;
    fn nova_title_label_create(window: *var u8, text: *const i8, x: f64, y: f64, w: f64, h: f64) -> *var u8;
    fn nova_label_set_text(label: *var u8, text: *const i8);
    fn nova_button_create(window: *var u8, title: *const i8, x: f64, y: f64, w: f64, h: f64, id: i32, callback: *const u8) -> *var u8;
    fn nova_text_input_create(window: *var u8, placeholder: *const i8, x: f64, y: f64, w: f64, h: f64) -> *var u8;
    fn nova_panel_create(window: *var u8, x: f64, y: f64, w: f64, h: f64, r: f64, g: f64, b: f64, a: f64, corner: f64) -> *var u8;
    fn nova_progress_create(window: *var u8, x: f64, y: f64, w: f64, h: f64) -> *var u8;
    fn nova_progress_set_value(progress: *var u8, value: f64);
    fn nova_alert(title: *const i8, message: *const i8) -> i32;
}

// ── Application Setup ───────────────────────────────────────────────────────

expose fn main() {
    println("╔══════════════════════════════════════════╗");
    println("║  🚀 Nova AI Studio — Desktop Edition    ║");
    println("║  Native macOS app via Cocoa FFI         ║");
    println("╚══════════════════════════════════════════╝");

    // Initialize Cocoa application
    nova_app_init();

    // Create main window
    let window = nova_window_create(900.0, 650.0, "Nova AI Studio");

    // ── Header Panel ────────────────────────────────────────────────────
    nova_panel_create(window, 0.0, 580.0, 900.0, 70.0,
                      0.12, 0.14, 0.22, 1.0, 0.0);

    nova_title_label_create(window,
        "⚡ Nova AI Studio", 20.0, 590.0, 400.0, 40.0);

    nova_label_create(window,
        "v1.0 — Built with Nova FFI", 600.0, 598.0, 280.0, 25.0);

    // ── Sidebar Panel ──────────────────────────────────────────────────
    nova_panel_create(window, 0.0, 0.0, 200.0, 580.0,
                      0.10, 0.10, 0.16, 1.0, 0.0);

    // Sidebar labels
    nova_label_create(window, "📊 Dashboard",    20.0, 530.0, 170.0, 25.0);
    nova_label_create(window, "🧠 Model Train",  20.0, 500.0, 170.0, 25.0);
    nova_label_create(window, "🔬 Inference",     20.0, 470.0, 170.0, 25.0);
    nova_label_create(window, "📡 FFI Monitor",   20.0, 440.0, 170.0, 25.0);
    nova_label_create(window, "⚙️  Settings",     20.0, 410.0, 170.0, 25.0);

    // ── Main Content Area ──────────────────────────────────────────────

    // Dashboard card 1: Compiler Status
    nova_panel_create(window, 220.0, 420.0, 310.0, 150.0,
                      0.14, 0.16, 0.24, 1.0, 12.0);

    nova_label_create(window, "🔧 Compiler Status", 240.0, 535.0, 270.0, 25.0);
    nova_label_create(window, "Lexer:     ✅ Active",   240.0, 505.0, 270.0, 20.0);
    nova_label_create(window, "Parser:    ✅ Active",   240.0, 480.0, 270.0, 20.0);
    nova_label_create(window, "Semantic:  ✅ Active",   240.0, 455.0, 270.0, 20.0);
    nova_label_create(window, "Codegen:   ✅ Active",   240.0, 430.0, 270.0, 20.0);

    // Dashboard card 2: FFI Status
    nova_panel_create(window, 550.0, 420.0, 330.0, 150.0,
                      0.14, 0.16, 0.24, 1.0, 12.0);

    nova_label_create(window, "🔗 FFI Bridge Status", 570.0, 535.0, 290.0, 25.0);
    nova_label_create(window, "Cocoa:     ✅ Linked",   570.0, 505.0, 290.0, 20.0);
    nova_label_create(window, "Metal:     ⏳ Pending",   570.0, 480.0, 290.0, 20.0);
    nova_label_create(window, "WebKit:    ⏳ Pending",   570.0, 455.0, 290.0, 20.0);
    nova_label_create(window, "libffi:    ✅ Loaded",   570.0, 430.0, 290.0, 20.0);

    // Dashboard card 3: Performance
    nova_panel_create(window, 220.0, 240.0, 660.0, 160.0,
                      0.14, 0.16, 0.24, 1.0, 12.0);

    nova_label_create(window, "📈 Self-Compilation Benchmark",
                      240.0, 365.0, 400.0, 25.0);

    nova_label_create(window, "Lex time:      0.42ms",   240.0, 335.0, 300.0, 20.0);
    nova_label_create(window, "Parse time:    1.21ms",   240.0, 310.0, 300.0, 20.0);
    nova_label_create(window, "Semantic:      0.87ms",   240.0, 285.0, 300.0, 20.0);
    nova_label_create(window, "Codegen:       2.14ms",   240.0, 260.0, 300.0, 20.0);

    nova_label_create(window, "Total:   4.64ms",   600.0, 335.0, 200.0, 20.0);
    nova_label_create(window, "Lines:   3,156",     600.0, 310.0, 200.0, 20.0);
    nova_label_create(window, "Tokens:  42,891",    600.0, 285.0, 200.0, 20.0);
    nova_label_create(window, "AST:     1,847 nodes", 600.0, 260.0, 200.0, 20.0);

    // Progress bar
    let progress = nova_progress_create(window, 240.0, 248.0, 620.0, 8.0);
    nova_progress_set_value(progress, 100.0);

    // ── Action Buttons ─────────────────────────────────────────────────

    nova_panel_create(window, 220.0, 60.0, 660.0, 160.0,
                      0.14, 0.16, 0.24, 1.0, 12.0);

    nova_label_create(window, "🎯 Actions", 240.0, 185.0, 200.0, 25.0);

    // Note: button callbacks are null for now — just visual demo
    nova_button_create(window, "🔨 Build",       240.0, 140.0, 120.0, 32.0, 1, 0 as *const u8);
    nova_button_create(window, "▶️ Run",          370.0, 140.0, 120.0, 32.0, 2, 0 as *const u8);
    nova_button_create(window, "🧪 Test",        500.0, 140.0, 120.0, 32.0, 3, 0 as *const u8);
    nova_button_create(window, "📦 Package",     630.0, 140.0, 120.0, 32.0, 4, 0 as *const u8);

    // Input field
    nova_text_input_create(window, "Enter Nova source file...",
                           240.0, 90.0, 400.0, 28.0);

    nova_button_create(window, "Open", 650.0, 90.0, 100.0, 28.0, 5, 0 as *const u8);

    // ── Status Bar ─────────────────────────────────────────────────────
    nova_panel_create(window, 0.0, 0.0, 900.0, 30.0,
                      0.06, 0.06, 0.10, 1.0, 0.0);

    nova_label_create(window,
        "Ready — Nova Compiler v1.0.0 | macOS arm64 | Cocoa FFI active",
        10.0, 5.0, 880.0, 20.0);

    // Show window and run event loop
    nova_window_show(window);

    println("✅ Desktop UI rendered — starting event loop");
    println("   Window: 900x650, Dark mode");
    println("   UI Components: 4 cards, 5 buttons, 1 input, 1 progress bar");
    println("   FFI calls: ~35 Cocoa function calls");

    nova_app_run();
}
