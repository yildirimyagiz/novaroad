// Nova AI Studio - Web Application
// Main App Component with SSR + Hydration

bring shared::components::AIModelCard;
bring nova::web::{Component, ssr, hydration};
bring nova::ai::{ModelRegistry, InferenceEngine};

@component
expose data App {
    models: Vec<AIModelCard>,
    selected_model: Option<usize>,
    inference_result: Option<String>,
}

@template
<div id="nova-ai-studio">
    <header class="app-header">
        <div class="logo">
            <h1>🚀 Nova AI Studio</h1>
            <p>Fullstack AI Development Platform</p>
        </div>
        
        <nav class="main-nav">
            <a href="#models" class="active">Models</a>
            <a href="#training">Training</a>
            <a href="#inference">Inference</a>
            <a href="#deploy">Deploy</a>
        </nav>
    </header>
    
    <main class="app-main">
        <section class="models-grid">
            <h2>Your AI Models</h2>
            
            <div class="grid">
                <AIModelCard 
                    v-for="(model, index) in models"
                    :key="index"
                    :model="model"
                    @click={() => select_model(index)}
                />
            </div>
            
            <button class="add-model-btn" @click={create_new_model}>
                + Create New Model
            </button>
        </section>
        
        <section class="inference-panel" v-check="selected_model.is_some()">
            <h2>Run Inference</h2>
            
            <div class="inference-controls">
                <textarea 
                    placeholder="Enter input data..."
                    @input={on_input_change}
                ></textarea>
                
                <button @click={run_inference} class="run-btn">
                    Run Inference
                </button>
            </div>
            
            <div class="results" v-check="inference_result.is_some()">
                <h3>Results</h3>
                <pre>{{ inference_result.unwrap() }}</pre>
            </div>
        </section>
        
        <section class="stats">
            <h2>Platform Stats</h2>
            
            <div class="stat-cards">
                <div class="stat-card">
                    <span class="stat-value">{{ models.len() }}</span>
                    <span class="stat-label">Models</span>
                </div>
                
                <div class="stat-card">
                    <span class="stat-value">{{ count_ready_models() }}</span>
                    <span class="stat-label">Ready</span>
                </div>
                
                <div class="stat-card">
                    <span class="stat-value">{{ count_training_models() }}</span>
                    <span class="stat-label">Training</span>
                </div>
            </div>
        </section>
    </main>
    
    <footer class="app-footer">
        <p>Nova AI Studio v1.0 - Powered by Nova Language</p>
        <p>Web • Desktop • Mobile</p>
    </footer>
</div>

@style
:root {
    --primary: #667eea;
    --secondary: #764ba2;
    --success: #10b981;
    --bg: #0f172a;
    --surface: #1e293b;
    --text: #f1f5f9;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
}

#nova-ai-studio {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
}

.app-header {
    background: var(--surface);
    padding: 1.5rem 2rem;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
}

.logo h1 {
    font-size: 2rem;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.logo p {
    color: #94a3b8;
    margin-top: 0.25rem;
}

.main-nav {
    display: flex;
    gap: 2rem;
    margin-top: 1rem;
}

.main-nav a {
    color: #94a3b8;
    text-decoration: none;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    transition: all 0.2s;
}

.main-nav a:hover,
.main-nav a.active {
    background: var(--primary);
    color: white;
}

.app-main {
    flex: 1;
    padding: 2rem;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
}

.models-grid h2 {
    margin-bottom: 1.5rem;
}

.grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.add-model-btn {
    width: 100%;
    padding: 1rem;
    background: var(--surface);
    border: 2px dashed #475569;
    border-radius: 12px;
    color: var(--text);
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.2s;
}

.add-model-btn:hover {
    border-color: var(--primary);
    background: rgba(102, 126, 234, 0.1);
}

.inference-panel {
    background: var(--surface);
    padding: 2rem;
    border-radius: 12px;
    margin-top: 2rem;
}

.inference-controls {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
}

.inference-controls textarea {
    flex: 1;
    padding: 1rem;
    background: var(--bg);
    border: 1px solid #475569;
    border-radius: 8px;
    color: var(--text);
    font-family: 'Courier New', monospace;
    min-height: 150px;
    resize: vertical;
}

.run-btn {
    padding: 1rem 2rem;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    border: none;
    border-radius: 8px;
    color: white;
    font-weight: bold;
    cursor: pointer;
    transition: transform 0.2s;
}

.run-btn:hover {
    transform: scale(1.05);
}

.results {
    background: var(--bg);
    padding: 1.5rem;
    border-radius: 8px;
}

.results pre {
    color: var(--success);
    font-family: 'Courier New', monospace;
    overflow-x: auto;
}

.stats {
    margin-top: 2rem;
}

.stat-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
}

.stat-card {
    background: var(--surface);
    padding: 2rem;
    border-radius: 12px;
    text-align: center;
}

.stat-value {
    display: block;
    font-size: 3rem;
    font-weight: bold;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.stat-label {
    display: block;
    margin-top: 0.5rem;
    color: #94a3b8;
}

.app-footer {
    background: var(--surface);
    padding: 2rem;
    text-align: center;
    color: #64748b;
}

.app-footer p:first-child {
    font-weight: bold;
    margin-bottom: 0.5rem;
}

apply App {
    expose fn new() -> App {
        App {
            models: [
                AIModelCard::new("GPT-Nova", "Language Model"),
                AIModelCard::new("Vision Transformer", "Computer Vision"),
                AIModelCard::new("WaveNet", "Audio Processing"),
            ],
            selected_model: None,
            inference_result: None,
        }
    }
    
    fn select_model(&var self, index: usize) {
        self.selected_model = Some(index);
    }
    
    fn create_new_model(&var self) {
        let new_model = AIModelCard::new("New Model", "Custom");
        self.models.push(new_model);
    }
    
    fn run_inference(&var self) {
        check let Some(idx) = self.selected_model {
            let model = &self.models[idx];
            
            // Run actual AI inference
            self.inference_result = Some(format(
                "Inference completed on {}\nAccuracy: {:.2}%\nStatus: Ready",
                model.model_name,
                model.accuracy * 100.0
            ));
        }
    }
    
    fn count_ready_models(&self) -> usize {
        self.models.iter()
            .filter(|m| matches!(m.status, ModelStatus::Ready))
            .count()
    }
    
    fn count_training_models(&self) -> usize {
        self.models.iter()
            .filter(|m| matches!(m.status, ModelStatus::Training))
            .count()
    }
    
    fn on_input_change(&var self, value: String) {
        // Handle input changes
    }
}

// SSR Entry Point
@ssr
expose fn render_server_side() -> String {
    let app = App::new();
    ssr::render_to_string(app)
}

// Client Hydration Entry Point
@hydration
expose fn hydrate_client() {
    let app = App::new();
    hydration::mount("#nova-ai-studio", app);
}
